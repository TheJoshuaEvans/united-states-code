{"tag":"section","attrib":{"id":"idbcf7bbf6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901"},"text":null,"children":[{"tag":"num","attrib":{"value":"901"},"text":"§ 901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of agency Chief Financial Officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf7bbf7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There shall be within each agency described in subsection (b) an agency Chief Financial Officer. Each agency Chief Financial Officer shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf7bbf8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for those agencies described in subsection (b)(1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf7bbf9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the President, by and with the advice and consent of the Senate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bbfa-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be designated by the President, in consultation with the head of the agency, from among officials of the agency who are required by law to be so appointed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7bbfb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for those agencies described in subsection (b)(2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf7bbfc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the head of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bbfd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be in the competitive service or the senior executive service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bbfe-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be career appointees; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7bbff-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed or designated, as applicable, from among individuals who possess demonstrated ability in general management of, and knowledge of and extensive practical experience in financial management practices in large governmental or business entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7bc00-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf7bc01-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The agencies referred to in subsection (a)(1) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf7bc02-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc03-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc04-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc05-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Education.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc06-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc07-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc08-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc09-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Housing and Urban Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc0a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc0b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc0c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc0d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc0e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc0f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc10-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc11-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Environmental Protection Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc12-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/1/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7bc13-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The agencies referred to in subsection (a)(2) are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf7bc14-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Agency for International Development.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc15-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Services Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc16-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Science Foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc17-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Nuclear Regulatory Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc18-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Personnel Management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc19-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Small Business Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bc1a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Social Security Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7bc1b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf7bc1c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be within the Executive Office of the President a Chief Financial Officer, who shall be designated or appointed by the President from among individuals meeting the standards described in subsection (a)(3). The position of Chief Financial Officer established under this paragraph may be so established in any Office (including the Office of Administration) of the Executive Office of the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7bc1d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Financial Officer designated or appointed under this subsection shall, to the extent that the President determines appropriate and in the interest of the United States, have the same authority and perform the same functions as apply in the case of a Chief Financial Officer of an agency described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7bc1e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall submit to Congress notification with respect to any provision of section 902 that the President determines shall not apply to a Chief Financial Officer designated or appointed under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7bc1f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s901/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may designate an employee of the Executive Office of the President (other than the Chief Financial Officer), who shall be deemed “the head of the agency” for purposes of carrying out section 902, with respect to the Executive Office of the President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf7bc20-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/576/tII/s205/a"},"text":"Pub. L. 101–576, title II, § 205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2842"},"text":"104 Stat. 2842","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/tI/s108/j/1"},"text":"Pub. L. 103–296, title I, § 108(j)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-15"},"text":"Aug. 15, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1488"},"text":"108 Stat. 1488","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/58/tVI/s638/a"},"text":"Pub. L. 106–58, title VI, § 638(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-09-29"},"text":"Sept. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/475"},"text":"113 Stat. 475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/330/s3/a"},"text":"Pub. L. 108–330, § 3(a)","children":[],"tail":", (d)(2), "},{"tag":"date","attrib":{"date":"2004-10-16"},"text":"Oct. 16, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1276"},"text":"118 Stat. 1276","children":[],"tail":", 1277.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf7bc21-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf7bc22-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf7bc23-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(1)(G) to (Q). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/330/s3/a"},"text":"Pub. L. 108–330, § 3(a)","children":[],"tail":", added subpar. (G) and redesignated former subpars. (G) to (P) as (H) to (Q), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(B) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/330/s3/d/2"},"text":"Pub. L. 108–330, § 3(d)(2)","children":[],"tail":", redesignated subpars. (C) to (H) as (B) to (G), respectively, and struck out former subpar. (B) which read as follows: “The Federal Emergency Management Agency.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/58"},"text":"Pub. L. 106–58","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(2)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296"},"text":"Pub. L. 103–296","children":[],"tail":" added subpar. (H)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf7bc24-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf7bc25-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/58"},"text":"Pub. L. 106–58","children":[],"tail":" effective at noon on "},{"tag":"date","attrib":{"date":"2001-01-20"},"text":"Jan. 20, 2001","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/58/s638/h"},"text":"section 638(h) of Pub. L. 106–58","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s503"},"text":"section 503 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf7bc26-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/296"},"text":"Pub. L. 103–296","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1995-03-31"},"text":"Mar. 31, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/296/s110/a"},"text":"section 110(a) of Pub. L. 103–296","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s401"},"text":"section 401 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbcf7bc27-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of all functions, personnel, assets, components, authorities, grant programs, and liabilities of the Federal Emergency Management Agency, including the functions of the Under Secretary for Federal Emergency Management relating thereto, to the Federal Emergency Management Agency, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s315/a/1"},"text":"section 315(a)(1) of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the Federal Emergency Management Agency, including the functions of the Director of the Federal Emergency Management Agency relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see former section 313(1) and sections 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcf7bc28-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Chief Financial Officer of Department of Homeland Security","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/330/s3/b"},"text":"Pub. L. 108–330, § 3(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2004-10-16"},"text":"Oct. 16, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1276"},"text":"118 Stat. 1276","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/330/s3/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment or Designation of","children":[],"tail":" CFO.—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall appoint or designate a Chief Financial Officer of the Department of Homeland Security under the amendment made by subsection (a) [amending this section] by not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-16"},"text":"Oct. 16, 2004","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continued Service of Current Official","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual serving as Chief Financial Officer of the Department of Homeland Security immediately before the enactment of this Act, or another person who is appointed to replace such an individual in an acting capacity after the enactment of this Act, may continue to serve in that position until the date of the confirmation or designation, as applicable (under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s901/a/1/B"},"text":"section 901(a)(1)(B) of title 31","children":[],"tail":", United States Code), of a successor under the amendment made by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcf7bc29-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Chief Financial Officer Within Executive Office of the President","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/58/tVI/s638/b"},"text":"Pub. L. 106–58, title VI, § 638(b)","children":[],"tail":"–(e), "},{"tag":"date","attrib":{"date":"1999-09-29"},"text":"Sept. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/475"},"text":"113 Stat. 475","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/58/tVI/s638/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan for Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the effective date of this section [noon on ","children":[{"tag":"date","attrib":{"date":"2001-01-20"},"text":"Jan. 20, 2001","children":[],"tail":"], the President shall communicate in writing, to the Chairmen of the Committees on Appropriations, the Chairman of the Committee on Government Reform [now Committee on Oversight and Accountability] of the House of Representatives, and the Chairman of the Committee on Governmental Affairs [now Committee on Homeland Security and Governmental Affairs] of the Senate, a plan for implementation of the provisions of, and amendments made by, this section [amending this section and sections 503 and 1105 of this title]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief Financial Officer designated or appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s901/c"},"text":"section 901(c) of title 31","children":[],"tail":", United States Code (as added by subsection (a)), shall be so designated or appointed not later than 180 days after the effective date of this section [noon on "},{"tag":"date","attrib":{"date":"2001-01-20"},"text":"Jan. 20, 2001","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief Financial Officer designated or appointed under such section shall receive basic pay at the rate payable for level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Functions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President may transfer such offices, functions, powers, or duties thereof, as the President determines are properly related to the functions of the Chief Financial Officer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s901/c"},"text":"section 901(c) of title 31","children":[],"tail":", United States Code (as added by subsection (a))."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The personnel, assets, liabilities, contracts, property, records, and unexpended balances of appropriations, authorizations, allocations, and other funds employed, held, used, arising from, available or to be made available, of any office the functions, powers, or duties of which are transferred under paragraph (1) shall also be so transferred.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcf7bc2a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Chief Financial Officers of Department of Veterans Affairs and Department of Housing and Urban Development","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/576/tII/s205/c/1"},"text":"Pub. L. 101–576, title II, § 205(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2845"},"text":"104 Stat. 2845","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/576/tII/s205/c/1"},"text":"“The Secretary of Veterans Affairs and the Secretary of Housing and Urban Development may each designate as the agency Chief Financial Officer of that department for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s901"},"text":"section 901 of title 31","children":[],"tail":", United States Code, as amended by this section, the officer designated, respectively, under section 4(c) of the Department of Veterans Affairs Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t38/s201"},"text":"38 U.S.C. 201","children":[],"tail":" note) and section 4(e) of the Department of Housing and Urban Development Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3533/e"},"text":"42 U.S.C. 3533(e)","children":[],"tail":"), as in effect before the effective date of this Act ["},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcf7bc2b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions and Personnel of Agency Chief Financial Officers","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/576/tII/s206"},"text":"Pub. L. 101–576, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2845"},"text":"104 Stat. 2845","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/576/tII/s206"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Reviews of Financial Management Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":"], the Director of the Office of Management and Budget shall require each agency listed in subsection (b) of "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s901"},"text":"section 901 of title 31","children":[],"tail":", United States Code, as amended by this Act, to conduct a review of its financial management activities for the purpose of consolidating its accounting, budgeting, and other financial management activities under the agency Chief Financial Officer appointed under subsection (a) of that section for the agency."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reorganization Proposal","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 120 days after the issuance of requirements under subsection (a) and subject to all laws vesting functions in particular officers and employees of the United States, the head of each agency shall submit to the Director of the Office of Management and Budget a proposal for reorganizing the agency for the purposes of this Act [see Short Title of 1990 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s501"},"text":"section 501 of this title","children":[],"tail":"]. Such proposal shall include—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of all functions, powers, duties, personnel, property, or records which the agency Chief Financial Officer is proposed to have authority over, including those relating to functions that are not related to financial management activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed outline of the administrative structure of the office of the agency Chief Financial Officer, including a description of the responsibility and authority of financial management personnel and resources in agencies or other subdivisions as appropriate to that agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review and Approval of Proposal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after receiving a proposal from the head of an agency under subsection (b), the Director of the Office of Management and Budget shall approve or disapprove the proposal and notify the head of the agency of that approval or disapproval. The Director shall approve each proposal which establishes an agency Chief Financial Officer in conformance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s901"},"text":"section 901 of title 31","children":[],"tail":", United States Code, as added by this Act, and which establishes a financial management structure reasonably tailored to the functions of the agency. Upon approving or disapproving a proposal of an agency under this section, the Director shall transmit to the head of the agency a written notice of that approval or disapproval."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation of Proposal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon receiving written notice of approval of a proposal under this section from the Director of the Office of Management and Budget, the head of an agency shall implement that proposal.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcfa051c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Chief Financial Officers Council","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/576/tIII/s302"},"text":"Pub. L. 101–576, title III, § 302","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2848"},"text":"104 Stat. 2848","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/576/tIII/s302"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is established a Chief Financial Officers Council, consisting of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Deputy Director for Management of the Office of Management and Budget, who shall act as chairperson of the council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Controller of the Office of Federal Financial Management of the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Fiscal Assistant Secretary of Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the agency Chief Financial Officers appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s901"},"text":"section 901 of title 31","children":[],"tail":", United States Code, as amended by this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief Financial Officers Council shall meet periodically to advise and coordinate the activities of the agencies of its members on such matters as consolidation and modernization of financial systems, improved quality of financial information, financial data and information standards, internal controls, legislation affecting financial operations and organizations, and any other financial management matter.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
