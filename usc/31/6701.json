{"tag":"section","attrib":{"id":"idbd81fa20-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701"},"text":null,"children":[{"tag":"num","attrib":{"value":"6701"},"text":"§ 6701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments to local governments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd81fa21-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment and Use.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd81fa22-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall pay to each unit of general local government which qualifies for a payment under this chapter an amount equal to the sum of any amounts allocated to the government under this chapter for each payment period. The Secretary shall pay such amount out of the Local Government Fiscal Assistance Fund under section 6702.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd81fa23-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts paid to a unit of general local government under this section shall be used by that unit for carrying out one or more programs of the unit related to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd81fa24-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" education to prevent crime;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd81fa25-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substance abuse treatment to prevent crime; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd81fa26-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" job programs to prevent crime.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd81fa27-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Programs funded under this title shall be coordinated with other existing Federal programs to meet the overall needs of communities that benefit from funds received under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd81fa28-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing of Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall pay each amount allocated under this chapter to a unit of general local government for a payment period by the later of 90 days after the date the amount is available or the first day of the payment period provided that the unit of general local government has provided the Secretary with the assurances required by section 6703(d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd81fa29-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustments.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd81fa2a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), the Secretary shall adjust a payment under this chapter to a unit of general local government to the extent that a prior payment to the government was more or less than the amount required to be paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd81fa2b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may increase or decrease under this subsection a payment to a unit of local government only if the Secretary determines the need for the increase or decrease, or the unit requests the increase or decrease, within one year after the end of the payment period for which the payment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd81fa2c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reservation for Adjustments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may reserve a percentage of not more than 2 percent of the amount under this section for a payment period for all units of general local government in a State if the Secretary considers the reserve is necessary to ensure the availability of sufficient amounts to pay adjustments after the final allocation of amounts among the units of general local government in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd81fa2d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment of Unexpended Amounts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd81fa2e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repayment required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A unit of general local government shall repay to the Secretary, by not later than 15 months after receipt from the Secretary, any amount that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd81fa2f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid to the unit from amounts appropriated under the authority of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd81fa30-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not expended by the unit within one year after receipt from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd81fa31-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty for failure to repay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the amount required to be repaid is not repaid, the Secretary shall reduce payments in future payment periods accordingly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd81fa32-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit of amounts repaid","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts received by the Secretary as repayments under this subsection shall be deposited in the Local Government Fiscal Assistance Fund for future payments to units of general local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd81fa33-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenditure With Disadvantaged Business Enterprises.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd81fa34-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of amounts paid to a unit of general local government under this chapter for a payment period, not less than 10 percent of the total combined amounts obligated by the unit for contracts and subcontracts shall be expended with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd81fa35-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" small business concerns controlled by socially and economically disadvantaged individuals and women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd81fa36-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" historically Black colleges and universities and colleges and universities having a student body in which more than 20 percent of the students are Hispanic Americans or Native Americans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd81fa37-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualified HUBZone small business concerns.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd81fa38-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall not apply to amounts paid to a unit of general local government to the extent the unit determines that the paragraph does not apply through a process that provides for public participation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd81fa39-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd81fa3a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “small business concern” has the meaning such term has under section 3 of the Small Business Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd81fa3b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “socially and economically disadvantaged individuals” has the meaning such term has under section 8(d) of the Small Business Act and relevant subcontracting regulations promulgated pursuant to that section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd81fa3c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified HUBZone small business concern” has the meaning given that term in section 3(p) ","children":[{"tag":"ref","attrib":{"idref":"fn002104"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002104"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Small Business Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"15 U.S.C. 632","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") "},{"tag":"ref","attrib":{"idref":"fn002105"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002105"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “632(p)”."}],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd81fa3d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonsupplanting Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd81fa3e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds made available under this chapter to units of local government shall not be used to supplant State or local funds, but will be used to increase the amount of funds that would, in the absence of funds under this chapter, be made available from State or local sources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd81fa3f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6701/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Base level amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The total level of funding available to a unit of local government for accounts serving eligible purposes under this chapter in the fiscal year immediately preceding receipt of a grant under this chapter shall be designated the “base level account” for the fiscal year in which a grant is received. Grants under this chapter in a given fiscal year shall be reduced on a dollar for dollar basis to the extent that a unit of local government reduces its base level account in that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd81fa40-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31001/a"},"text":"Pub. L. 103–322, title III, § 31001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1859"},"text":"108 Stat. 1859","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/135/tVI/s604/e/2"},"text":"Pub. L. 105–135, title VI, § 604(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2633"},"text":"111 Stat. 2633","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd81fa41-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd81fa42-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd81fa43-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 3 and 8(d) of the Small Business Act, referred to in subsec. (f)(3), are classified to sections 632 and 637(d), respectively, of Title 15, Commerce and Trade. Section 3(p) of the Act was redesignated as section 31(b) by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXVII/s1701/a/2"},"text":"Pub. L. 115–91, div. A, title XVII, § 1701(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1795"},"text":"131 Stat. 1795","children":[],"tail":", and is now classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s657a/b"},"text":"section 657a(b) of Title 15","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd81fa44-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6701, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1010"},"text":"96 Stat. 1010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/185"},"text":"Pub. L. 98–185","children":[],"tail":", §§ 2, 9(a), "},{"tag":"date","attrib":{"date":"1983-11-30"},"text":"Nov. 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/1309"},"text":"97 Stat. 1309","children":[],"tail":", 1311, related to definitions and application of chapter, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIV/s14001/a/1"},"text":"Pub. L. 99–272, title XIV, § 14001(a)(1)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/327"},"text":"100 Stat. 327","children":[],"tail":", 329, eff. "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd81fa45-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (f)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s604/e/2/A"},"text":"Pub. L. 105–135, § 604(e)(2)(A)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135/s604/e/2/B"},"text":"Pub. L. 105–135, § 604(e)(2)(B)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd81fa46-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd81fa47-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/135"},"text":"Pub. L. 105–135","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/135/s3"},"text":"section 3 of Pub. L. 105–135","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s631"},"text":"section 631 of Title 15","children":[],"tail":", Commerce and Trade."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd81fa48-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31001/b"},"text":"Pub. L. 103–322, title III, § 31001(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1881"},"text":"108 Stat. 1881","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/322/tIII/s31001/b"},"text":"“Within 90 days of the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":"] the Secretary shall issue regulations, which may be interim regulations, to implement subsection (a) [enacting this chapter], modifying the regulations for carrying into effect the Revenue Sharing Act [former chapter 67 of this title] that were in effect as of "},{"tag":"date","attrib":{"date":"1987-07-01"},"text":"July 1, 1987","children":[],"tail":", and that were published in 31 C.F.R. part 51. The Secretary need not hold a public hearing before issuing these regulations.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
