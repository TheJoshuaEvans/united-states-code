{"tag":"section","attrib":{"id":"idbd202bc8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3301"},"text":null,"children":[{"tag":"num","attrib":{"value":"3301"},"text":"§ 3301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General duties of the Secretary of the Treasury","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd202bc9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Treasury shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd202bca-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive and keep public money;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd202bcb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take receipts for money paid out by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd202bcc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3301/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give receipts for money deposited in the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd202bcd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3301/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" endorse warrants for receipts for money deposited in the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd202bce-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3301/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the accounts of the Secretary to the Comptroller General every 3 months, or more often if required by the Comptroller General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd202bcf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3301/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to inspection at any time by the Comptroller General of money in the possession of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd202bd0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3326"},"text":"section 3326 of this title","children":[],"tail":", an acknowledgment for money deposited in the Treasury is not valid if the Secretary does not endorse a warrant as required by subsection (a)(4) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd202bd1-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/948"},"text":"96 Stat. 948","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd202bd2-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd202bd3-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd202bd4-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3301","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:44(1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18/s304"},"text":"June 10, 1921, ch. 18, § 304","children":[],"tail":"(1st par. 1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/42/24"},"text":"42 Stat. 24","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:147(less disbursement).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 305(less disbursement).","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “public money” are substituted for “the moneys of the United States” to eliminate unnecessary words and for consistency. The words “Secretary of the Treasury” are substituted for “Treasurer” because of the source provisions restated in section 321(c) of the revised title. In clauses (3) and (4), the words “deposited in the Treasury” are substituted for “received by him” for clarity and consistency in the revised title. In clause (4), the words “signed by the Secretary of the Treasury” are omitted as surplus. In clauses (5) and (6), the words “Comptroller General” are substituted for “General Accounting Office” for consistency. In clause (5), the word “submit” is substituted for “render” for consistency. The words “and shall transmit a copy thereof, when settled, to the Secretary of the Treasury” are omitted because of the restatement. In clause (6), the words “Secretary of the Treasury . . . or either of them” are omitted because of the restatement. The word “public” is added for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3326"},"text":"section 3326 of this title","children":[],"tail":"” are added for clarity. The words “endorse . . . as required by subsection (a)(4) of this section” are substituted for “so signed” for clarity and consistency."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd202bd5-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd202bd6-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2020 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117/s1"},"text":"Pub. L. 116–117, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/113"},"text":"134 Stat. 113","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/117/s1"},"text":"“This Act [enacting subchapter IV of this chapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3562"},"text":"section 3562 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s612"},"text":"section 612 of Title 6","children":[],"tail":", Domestic Security, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1397ee"},"text":"section 1397ee of Title 42","children":[],"tail":", The Public Health and Welfare, amending provisions set out as a note under 5701 of Title 5, Government Organization and Employees, and repealing provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3321"},"text":"section 3321 of this title","children":[],"tail":"] may be cited as the ‘Payment Integrity Information Act of 2019’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd202bd7-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/109/s1"},"text":"Pub. L. 114–109, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2225"},"text":"129 Stat. 2225","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/109/s1"},"text":"“This Act [amending provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3321"},"text":"section 3321 of this title","children":[],"tail":"] may be cited as the ‘Federal Improper Payments Coordination Act of 2015’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd202bd8-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/204/s1"},"text":"Pub. L. 111–204, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-22"},"text":"July 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2224"},"text":"124 Stat. 2224","children":[],"tail":", which provided that "},{"tag":"ref","attrib":{"href":"/us/pl/111/204"},"text":"Pub. L. 111–204","children":[],"tail":" (amending sections 3501 and 3562 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s612"},"text":"section 612 of Title 6","children":[],"tail":", Domestic Security, repealing sections 3561 and 3563 to 3567 of this title, enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3321"},"text":"section 3321 of this title","children":[],"tail":", and amending provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3321"},"text":"section 3321 of this title","children":[],"tail":") could be cited as the “Improper Payments Elimination and Recovery Act of 2010”, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/116/117/s3/a/2"},"text":"Pub. L. 116–117, § 3(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/133"},"text":"134 Stat. 133","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd202bd9-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/433/s1"},"text":"Pub. L. 106–433, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1910"},"text":"114 Stat. 1910","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/433/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3327"},"text":"section 3327 of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3327"},"text":"section 3327 of this title","children":[],"tail":"] may be cited as the ‘Social Security Number Confidentiality Act of 2000’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd202bda-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/356/s1/a"},"text":"Pub. L. 103–356, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3410"},"text":"108 Stat. 3410","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/356/s1/a"},"text":"“This Act [see Tables for classification] may be cited as the ‘Government Management Reform Act of 1994’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/356/tIV/s401"},"text":"Pub. L. 103–356, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3412"},"text":"108 Stat. 3412","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/356/tIV/s401"},"text":"“This title [amending sections 331, 3332, 3515, and 3521 of this title and enacting provisions set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s501"},"text":"section 501 of this title","children":[],"tail":"] may be cited as the ‘Federal Financial Management Act of 1994’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
