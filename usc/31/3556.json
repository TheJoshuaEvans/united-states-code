":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4751"},"text":"section 4751 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd381f63-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Nonexclusivity of GAO Remedies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/320/s12/f"},"text":"Pub. L. 104–320, § 12(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3876"},"text":"110 Stat. 3876","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/320/s12/f"},"text":"“In the event that the bid protest jurisdiction of the district courts of the United States is terminated pursuant to subsection (d) [set out as a Sunset Provision note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1491"},"text":"section 1491 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure], then "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3556"},"text":"section 3556 of title 31","children":[],"tail":", United States Code, shall be amended by striking ‘a court of the United States or’ in the first sentence.”"}],"tail":"\n [Bid protest jurisdiction of the district courts of the United States terminated on "},{"tag":"date","attrib":{"date":"2001-01-01"},"text":"Jan. 1, 2001","children":[],"tail":", pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/104/320/s12/d"},"text":"section 12(d) of Pub. L. 104–320","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
