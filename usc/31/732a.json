{"tag":"section","attrib":{"id":"idbcf30089-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s732a"},"text":null,"children":[{"tag":"num","attrib":{"value":"732a"},"text":"§ 732a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Critical positions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf3008a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s732a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Comptroller General may establish senior-level positions to meet critical scientific, technical or professional needs of the Government Accountability Office. An individual serving in such a position shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf3008b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s732a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to the laws and regulations applicable to the General Accounting Office Senior Executive Service ","children":[{"tag":"ref","attrib":{"idref":"fn002013"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002013"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s733"},"text":"section 733 of this title","children":[],"tail":", with respect to rates of basic pay, performance awards, ranks, carry over of annual leave, benefits, performance appraisals, removal or suspension, and reductions in force;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf3008c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s732a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the same rights of appeal to the General Accounting Office Personnel Appeals Board ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" as are provided to the Office Senior Executive Service;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf3008d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s732a/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be exempt from the same provisions of law as are made inapplicable to the Office Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s733/d"},"text":"section 733(d) of this title","children":[],"tail":", except for "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s732/e"},"text":"section 732(e) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf3008e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s732a/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be entitled to discontinued service retirement under chapter 83 or 84 of title 5 as if a member of the Office Senior Executive Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf3008f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s732a/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be subject to reassignment by the Comptroller General to any position in the Office Senior Executive Service under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s733"},"text":"section 733 of this title","children":[],"tail":", as the Comptroller General determines necessary and appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf30090-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s732a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Senior-level positions under this section may include positions referred to in paragraph (1) or (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s731/e"},"text":"section 731(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf30091-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/303/s4/a/1"},"text":"Pub. L. 106–303, § 4(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-13"},"text":"Oct. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1068"},"text":"114 Stat. 1068","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/323/s9/b/1"},"text":"Pub. L. 110–323, § 9(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-09-22"},"text":"Sept. 22, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3548"},"text":"122 Stat. 3548","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf30092-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf30093-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf30094-47c4-11f1-bea6-82cea74