{"tag":"section","attrib":{"id":"idbcd3dfea-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312"},"text":null,"children":[{"tag":"num","attrib":{"value":"312"},"text":"§ 312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terrorism and financial intelligence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcd3dfeb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Office of Terrorism and Financial Intelligence.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd3dfec-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established within the Department of the Treasury the Office of Terrorism and Financial Intelligence (in this section referred to as “OTFI”), which shall be the successor to any such office in existence on the date of enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd3dfed-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leadership.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd3dfee-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Undersecretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established within the Department of the Treasury, the Office of the Undersecretary for Terrorism and Financial Crimes, who shall serve as the head of the OTFI, and shall report to the Secretary of the Treasury through the Deputy Secretary of the Treasury. The Office of the Undersecretary for Terrorism and Financial Crimes shall be the successor to the Office of the Undersecretary for Enforcement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd3dfef-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Undersecretary for Terrorism and Financial Crimes shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd3dff0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistant secretary for terrorist financing.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd3dff1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established within the OTFI the position of Assistant Secretary for Terrorist Financing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd3dff2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Assistant Secretary for Terrorist Financing shall be appointed by the President, by and with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd3dff3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Assistant Secretary for Terrorist Financing shall be responsible for formulating and coordinating the counter terrorist financing and anti-money laundering efforts of the Department of the Treasury, and shall report directly to the Undersecretary for Terrorism and Financial Crimes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd3dff4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The functions of the OTFI include providing policy, strategic, and operational direction to the Department on issues relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd3dff5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation of titles I and II of the Bank Secrecy Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd3dff6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States economic sanctions programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd3dff7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combating terrorist financing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd3dff8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combating financial crimes, including money laundering, counterfeiting, and other offenses threatening the integrity of the banking and financial systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd3dff9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combating illicit financing relating to human trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd3dffa-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other enforcement matters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd3dffb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/4/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those intelligence analysis and coordination functions described in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd3dffc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/4/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the security functions and programs of the Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd650fd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to congress on proposed measures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Undersecretary for Terrorism and Financial Crimes and the Assistant Secretary for Terrorist Financing shall report to the Committee on Banking, Housing, and Urban Affairs of the Senate and the Committee on Financial Services of the House of Representatives not later than 72 hours after proposing by rule, regulation, order, or otherwise, any measure to reorganize the structure of the Department for combatting money laundering and terrorist financing, before any such proposal becomes effective.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd650fe-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other offices within otfi","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the following offices of the Department of the Treasury shall be within the OTFI:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd650ff-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Assistant Secretary for Intelligence and Analysis, which shall report directly to the Undersecretary for Terrorism and Financial Crimes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd65100-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of the Assistant Secretary for Terrorist Financing, which shall report directly to the Undersecretary for Terrorism and Financial Crimes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd65101-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Foreign Assets Control (in this section referred to as the “OFAC”), which shall report directly to the Undersecretary for Terrorism and Financial Crimes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd65102-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Executive Office for Asset Forfeiture, which shall report to the Undersecretary for Terrorism and Financial Crimes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd65103-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Intelligence and Analysis (in this section referred to as the “OIA”), which shall report to the Assistant Secretary for Intelligence and Analysis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd65104-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Office of Terrorist Financing, which shall report to the Assistant Secretary for Terrorist Financing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd65105-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"FinCEN.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd65106-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting to undersecretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Financial Crimes Enforcement Network (in this section referred to as “FinCEN”), a bureau of the Department of the Treasury, shall report to the Undersecretary for Terrorism and Financial Crimes. The Undersecretary for Terrorism and Financial Crimes may not redelegate its reporting authority over FinCEN.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd65107-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Office of compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established within FinCEN, an Office of Compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd65108-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interagency coordination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury, after consultation with the Undersecretary for Terrorism and Financial Crimes, shall designate an office within the OTFI that shall coordinate efforts to combat the illicit financing of human trafficking with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd65109-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other offices of the Department of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd6510a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other Federal agencies, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcd6510b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/8/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office to Monitor and Combat Trafficking in Persons of the Department of State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcd6510c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/8/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Interagency Task Force to Monitor and Combat Trafficking;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd6510d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local law enforcement agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd6510e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/a/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreign governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd6510f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Office of Intelligence and Analysis.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd65110-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistant secretary for intelligence and analysis","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Assistant Secretary for Intelligence and Analysis shall head the OIA.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd65111-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The OIA shall be responsible for the receipt, analysis, collation, and dissemination of intelligence and counterintelligence information related to the operations and responsibilities of the entire Department of the Treasury, including all components and bureaus of the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd65112-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Primary functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The primary functions of the OIA are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd65113-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to build a robust analytical capability on terrorist finance by coordinating and overseeing work involving intelligence analysts in all components of the Department of the Treasury, focusing on the highest priorities of the Department, as well as ensuring that the existing intelligence needs of the OFAC and FinCEN are met; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd65114-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide intelligence support to senior officials of the Department on a wide range of international economic and other relevant issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd65115-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other functions and duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The OIA shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcd65116-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the intelligence support functions that are assigned, to the Office of Intelligence Support under section 311 (pursuant to section 105 of the Intelligence Authorization Act for Fiscal Year 2004);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd65117-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve in a liaison capacity with the intelligence community; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcd65118-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the Department in various intelligence related activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd65119-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties of the assistant secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Assistant Secretary for Intelligence and Analysis shall serve as the Senior Officer Intelligence Community, and shall represent the Department in intelligence community fora, including the National Foreign Intelligence Board committees and the Intelligence Community Management Staff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd6511a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent that any authorities, powers, and responsibilities over enforcement matters delegated to the Undersecretary for Terrorism and Financial Crimes, or the positions of Assistant Secretary for Terrorism and Financial Crimes, Assistant Secretary for Enforcement and Operations, or Deputy Assistant Secretary for Terrorist Financing and Financial Crimes, have not been transferred to the Department of Homeland Security, the Department of Justice, or the Assistant Secretary for Tax Policy (related to the customs revenue functions of the Bureau of Alcohol and Tobacco Tax and Trade), those remaining authorities, powers, and responsibilities are delegated to the Undersecretary for Terrorism and Financial Crimes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd6511b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation as Enforcement Organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of Terrorism and Financial Intelligence (including any components thereof) is designated as a law enforcement organization of the Department of the Treasury for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s9705"},"text":"section 9705 of title 31","children":[],"tail":", United States Code, and other relevant authorities."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd6511c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Existing Resources","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may employ personnel, facilities, and other Department of the Treasury resources available to the Secretary on the date of enactment of this section in carrying out this section, except as otherwise prohibited by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd6511d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"References in this section to the “Secretary”, “Undersecretary”, “Deputy Secretary”, “Deputy Assistant Secretary”, “Office”, “Assistant Secretary”, and “Department” are references to positions and offices of the Department of the Treasury, unless otherwise specified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd6511e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Hiring Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcd6511f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury may appoint, without regard to the provisions of sections 3309 through 3318 of title 5, candidates directly to positions in the competitive service, as defined in section 2102 of that title, in the OTFI.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcd65120-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Primary responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The primary responsibility of candidates appointed under paragraph (1) shall be to provide substantive support in support of the duties described in subparagraphs (A) through (G) of subsection (a)(4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcd65121-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s312/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deployment of Staff","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury may detail, without regard to the provisions of section 300.301 of title 5, Code of Federal Regulations, any employee in the OTFI to any position in the OTFI for which the Secretary has determined there is a need.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcd65122-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dH/tII/s222/a"},"text":"Pub. L. 108–447, div. H, title II, § 222(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3242"},"text":"118 Stat. 3242","children":[],"tail":", § 313; renumbered § 312, "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tV/s502/a/2"},"text":"Pub. L. 111–203, title V, § 502(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1580"},"text":"124 Stat. 1580","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/22/tI/s105/c/2/A/ii/I"},"text":"Pub. L. 114–22, title I, § 105(c)(2)(A)(ii)(I)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-05-29"},"text":"May 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/237"},"text":"129 Stat. 237","children":[],"tail":"; "},{"tag":"