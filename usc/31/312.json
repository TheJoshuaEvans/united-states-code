:{},"text":"Section 105 of the Intelligence Authorization Act for Fiscal Year 2004, referred to in subsec. (b)(4)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/177/s105"},"text":"section 105 of Pub. L. 108–177","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"2003-12-13"},"text":"Dec. 13, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2603"},"text":"117 Stat. 2603","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s311"},"text":"section 311 of this title","children":[],"tail":". For complete classification of section 105 to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbcd65126-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 312 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s315"},"text":"section 315 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcd65127-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added subsecs. (g) and (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(4)(E) to (H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s7153/a"},"text":"Pub. L. 116–92, § 7153(a)","children":[],"tail":", added subpar. (E) and redesignated former subpars. (E) to (G) as (F) to (H), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92/s7153/b"},"text":"Pub. L. 116–92, § 7153(b)","children":[],"tail":", added par. (8)."}],"tai