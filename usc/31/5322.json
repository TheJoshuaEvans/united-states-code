:{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5322(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1058.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/508"},"text":"Pub. L. 91–508","children":[],"tail":", §§ 205(b)(last sentence related to criminal penalties), 209, 210, "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1120"},"text":"84 Stat. 1120","children":[],"tail":", 1121."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5322(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1059.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5322(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1054(b)(last sentence related to criminal penalties).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “(except ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5315"},"text":"section 5315 of this title","children":[],"tail":" or a regulation prescribed under section 5315)” are added because 31:1141–1143 was not enacted as part of the Currency and Foreign Transactions Reporting Act that is restated in the subchapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “prescribed” is added for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “or a regulation prescribed under this subchapter” are added because of the restatement. The words “committed” and “the commission of” are omitted as surplus. The words “United States” are substituted for “Federal” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “the purposes of both civil and criminal penalties for” are omitted because of the restatement. The word “separate” before “office” is omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd6c9d5d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd6c9d5e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 21 of the Federal Deposit Insurance Act, referred to in subsecs. (a) and (b), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1829b"},"text":"section 1829b of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/91/508/s123"},"text":"Section 123 of Public Law 91–508","children":[],"tail":", referred to in subsecs. (a) and (b), is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1953"},"text":"section 1953 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6003 of the Anti-Money Laundering Act of 2020, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dF/s6003"},"text":"section 6003 of div. F of Pub. L. 116–283","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5311"},"text":"section 5311 of this title","children":[],"tail":". Such section 6003 defines terms, including the Bank Secrecy Act, as used in div. F of "},{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd6c9d5f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s6403/b/2"},"text":"Pub. L. 116–283, § 6403(b)(2)","children":[],"tail":", substituted “section 5315, 5324, or 5336” for “section 5315 or 5324” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s6312/a"},"text":"Pub. L. 116–283, § 6312(a)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s353/b/1"},"text":"Pub. L. 107–56, § 353(b)(1)","children":[],"tail":", inserted “or order issued” after “willfully violating this subchapter or a regulation prescribed” and “, or willfully violating a regulation prescribed under section 21 of the Federal Deposit Insurance Act or "},{"tag":"ref","attrib":{"href":"/us/pl/91/508/s123"},"text":"section 123 of Public Law 91–508","children":[],"tail":",” after “under section 5315 or 5324)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s353/b/2"},"text":"Pub. L. 107–56, § 353(b)(2)","children":[],"tail":", inserted “or order issued” after “willfully violating this subchapter or a regulation prescribed” and “or willfully violating a regulation prescribed under section 21 of the Federal Deposit Insurance Act or "},{"tag":"ref","attrib":{"href":"/us/pl/91/508/s123"},"text":"section 123 of Public Law 91–508","children":[],"tail":",” after “under section 5315 or 5324),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s363/b"},"text":"Pub. L. 107–56, § 363(b)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":" inserted “or 5324” after “section 5315” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/550"},"text":"Pub. L. 102–550","children":[],"tail":" substituted “imprisoned for” for “imprisonment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s1357/g"},"text":"Pub. L. 99–570, § 1357(g)","children":[],"tail":", substituted “any illegal activity involving” for “illegal activity involving transactions of” and “10 years” for “5 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s1356/c/1"},"text":"Pub. L. 99–570, § 1356(c)(1)","children":[],"tail":", substituted “5318(a)(2)” for “5318(2)” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":", which directed the substitution of “$250,000, or imprisonment not more than five years, or both” for “$1,000, or imprisonment not more than one year, or both”, was executed by substituting the quoted wording for “$1,000, imprisoned for not more than one year, or both” to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd6c9d60-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd6c9d61-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s1357/g"},"text":"section 1357(g) of Pub. L. 99–570","children":[],"tail":" applicable with respect to violations committed after "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/s1364/c"},"text":"section 1364(c) of Pub. L. 99–570","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5321"},"text":"section 5321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd6c9d62-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dF/tLXIII/s6312/b"},"text":"Pub. L. 116–283, div. F, title LXIII, § 6312(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4596"},"text":"134 Stat. 4596","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dF/tLXIII/s6312/b"},"text":"“The amendment made by subsection (a) [amending this section] may not be construed to prohibit a financial institution from requiring the repayment of a bonus paid to a partner, director, officer, or employee if the financial institution determines that the partner, director, officer, or employee engaged in unethical, but non-criminal, activities.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
