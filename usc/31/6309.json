{"tag":"section","attrib":{"id":"idbd7d4020-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6309"},"text":null,"children":[{"tag":"num","attrib":{"value":"6309"},"text":"§ 6309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-propagation of core-based statistical area delineations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7d4021-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on the date of enactment of the MAPS Act of 2021, and notwithstanding any other provision of law, any change to the standards of core-based statistical area delineations pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3504/e"},"text":"section 3504(e) of title 44","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d4022-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6309/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not propagate automatically for any non-statistical use by any domestic assistance program, including any such use as required through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7d4023-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6309/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statutory reference to any core-based statistical area delineation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d4024-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6309/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative or regulatory reference to any core-based statistical area delineation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4025-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6309/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall propagate for any non-statistical use by any domestic assistance program only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7d4026-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6309/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if a relevant agency determines that such a propagation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd7d4027-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6309/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supports the purposes of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd7d4028-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6309/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the public interest; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7d4029-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6309/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through affirmative adoption through notice-and-comment rulemaking pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7d402a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The definitions in section 4 of the MAPS Act of 2021 shall apply to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7d402b-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219/s5/a"},"text":"Pub. L. 117–219, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-05"},"text":"Dec. 5, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2272"},"text":"136 Stat. 2272","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7d402c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd7d402d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd7d402e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the MAPS Act of 2021, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219"},"text":"Pub. L. 117–219","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-12-05"},"text":"Dec. 5, 2022","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4 of the MAPS Act of 2021, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/219/s4"},"text":"section 4 of Pub. L. 117–219","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s6102"},"text":"section 6102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
