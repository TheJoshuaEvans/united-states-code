ren":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1155(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/510/s205/a"},"text":"Pub. L. 91–510, § 205(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1168"},"text":"84 Stat. 1168","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"702(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:51–1.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/604/s501/a"},"text":"Pub. L. 93–604, § 501(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1962"},"text":"88 Stat. 1962","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"702(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:41(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “instrumentality of the United States Government” are substituted for “establishment of the Government” for consistency. The words “created . . . to be” and 31:41(2d, 3d sentences) are omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for 31:41(1st sentence last 14 words) and 42(a)(1st sentence words before comma) to eliminate unnecessary words and for consistency. The word “Deputy” is substituted for “Assistant” because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1971-07-09/s101"},"text":"section 101 of the Act of July 9, 1971","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/92/51"},"text":"Pub. L. 92–51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/143"},"text":"85 Stat. 143","children":[],"tail":"). The text of 31:1154(d)(1st sentence) and 1155(a) is omitted as unnecessary because the Comptroller General, as the head of the Office, has the authority to establish constituent parts of the Office to carry out duties and powers unless otherwise specified by law."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Administrator of General Services” are substituted for “the head of any Federal agency which exercises authority over such building” for clarity. The words “of the United States” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbce96495-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbce96496-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in section catchline and subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/545"},"text":"Pub. L. 100–545","children":[],"tail":" redesignated subsec. (d) as (c) and struck out former subsec. (c) which directed Administrator of General Services to provide Comptroller General with space in General Accounting Office Building."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbce96497-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbce96498-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8"},"text":"Pub. L. 108–271, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/271/s8"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The General Accounting Office is hereby redesignated the Government Accountability Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference to the General Accounting Office in any law, rule, regulation, certificate, directive, instruction, or other official paper in force on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":"] shall be considered to refer and apply to the Government Accountability Office.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbce96499-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfers and Terminations of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s101/a"},"text":"Pub. L. 104–316, title I, § 101(a)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3826"},"text":"110 Stat. 3826","children":[],"tail":", 3827, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/316/tI/s101/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions transferred","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any case in which a provision of law authorizing the performance of a function by the Comptroller General of the United States or the General Accounting Office [now Government Accountability Office] is amended by this title [see Tables for classification] to substitute another Federal officer, employee, or agency in that authorization, the authority under that provision to perform that function is transferred to the other Federal officer, employee, or agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions terminated","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any case in which a provision of law authorizing the performance of a function by the Comptroller General of the United States or the General Accounting Office [now Government Accountability Office] is repealed by this Act [see Tables for classification], the authority under that provision to perform that function is terminated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation of functions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Management and Budget may delegate, in whole or in part, to any other agency or agencies any function transferred to or vested in the Director under section 103(d), 105(b), 116, or 202(n) of this Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3702"},"text":"section 3702 of this title","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5584"},"text":"section 5584 of Title 5","children":[],"tail":", Government Organization and Employees, "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2774"},"text":"section 2774 of Title 10","children":[],"tail":", Armed Forces, and "},{"tag":"ref","attrib":{"href":"/us/usc/t32/s716"},"text":"section 716 of Title 32","children":[],"tail":", National Guard], and may transfer to such agency or agencies any personnel, budget authority, records, and property received by the Director pursuant to subsection (b) of this section that relate to the delegated functions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incidental Transfers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Incident to any transfer of authority under subsection (a)(1), there shall be transferred to the recipient Federal officer, employee, or agency such personnel, records, budget authority, and property of the General Accounting Office [now Government Accountability Office] as the Comptroller General and the Director of the Office of Management and Budget jointly determine to be necessary to effectuate the transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Personnel transferred under this section shall not be separated or reduced in classification or compensation for one year after any such transfer, except for cause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to any function or authority transferred under this Act and exercised on or after the effective date of that transfer, reference in any Federal law to the Comptroller General or to any officer or employee of the General Accounting Office [now Government Accountability Office] is deemed to refer to the Federal officer or agency to which the function or authority is transferred under this Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Provisions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Orders and other official actions not affected","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"All orders, determinations, rules, regulations, permits, grants, contracts, certificates, licenses, and privileges—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which have been issued, made, granted, or allowed to become effective by the Comptroller General or any official of the General Accounting Office [now Government Accountability Office], or by a court of competent jurisdiction, in the performance of any function or authority transferred under this Act, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which are in effect at the time of the transfer;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall continue in effect according to their terms until modified, terminated, superseded, set aside, or revoked in accordance with law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pending matters and proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This Act shall not affect any pending matters or proceedings, including notices of proposed rulemaking, relating to a function or authority transferred under this Act. Such matters or proceedings shall continue under the authority of the agency to which the function or authority is transferred until completed or terminated in accordance with law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judicial proceedings and causes of actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No suit, action, or other proceeding or cause of action relating to a function or authority transferred under this Act shall abate by reason of the enactment of this Act. If, before the date on which a transfer of a function or authority this Act takes effect, the Comptroller General of the United States or any officer or employee of the General Accounting Office [now Government Accountability Office] in their official capacity is party to a suit relating to the function or authority, then such suit shall be continued and the head of the agency to which the function or authority is transferred, or other appropriate official of that agency, shall be substituted or added as a party.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcebd49a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Contract Appeals Board","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dH/tI/s1501"},"text":"Pub. L. 110–161, div. H, title I, § 1501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2249"},"text":"121 Stat. 2249","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/235/dH/tI/s1301/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Board’ means the Contract Appeals Board established under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term ‘legislative branch agency’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Architect of the Capitol;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Botanic Gardens [sic];","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Accountability Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Publishing Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Library of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Congressional Budget Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Capitol Police; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"“(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other agency, including any office, board, or commission, established in the legislative branch; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a Contract Appeals Board within the Government Accountability Office. The Board shall hear and decide appeals from decisions of a contracting officer with respect to any contract entered into by a legislative branch agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members of the Board.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall appoint at least 3 members to the Contract Appeals Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member shall have not less than 5 years experience in public contract law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to any provision of law relating to pay applicable to the Office of General Counsel of the Government Accountability Office, the Comptroller General shall establish and adjust the annual rate of basic pay of members of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provisions Applicable to Appeals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Contract Disputes Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/563"},"text":"Public Law 95–563","children":[],"tail":", [former] "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s601"},"text":"41 U.S.C. 601","children":[],"tail":" et seq. [see "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s7101"},"text":"41 U.S.C. 7101","children":[],"tail":" et seq.]), as amended, shall apply to appeals to the Board, except that section 4 [now "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s7102/d"},"text":"41 U.S.C. 7102(d)","children":[],"tail":"], subsections 8(a), (b), and (c) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s7105/a"},"text":"41 U.S.C. 7105(a)","children":[],"tail":", (c), (d), (e)(1)(C)], and subsection 10(a) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s7104/b"},"text":"41 U.S.C. 7104(b)","children":[],"tail":"] shall not apply to such appeals and the amount of any claim referenced in subsection 6(c) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s7103/b"},"text":"41 U.S.C. 7103(b)","children":[],"tail":", (f)] shall be $50,000. The Comptroller General shall prescribe regulations for procedures for appeals to the Board that are consistent with procedures under the Contract Disputes Act of 1978."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall apply with respect to fiscal year 2008 and each fiscal year thereafter.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
