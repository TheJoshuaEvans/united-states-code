{"tag":"section","attrib":{"id":"idbd48c178-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802"},"text":null,"children":[{"tag":"num","attrib":{"value":"3802"},"text":"§ 3802.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" False claims and statements; liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd48c179-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd48c17a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person who makes, presents, or submits, or causes to be made, presented, or submitted, a claim that the person knows or has reason to know—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd48c17b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is false, fictitious, or fraudulent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd48c17c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes or is supported by any written statement which asserts a material fact which is false, fictitious, or fraudulent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd48c17d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes or is supported by any written statement that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd48c17e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" omits a material fact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd48c17f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is false, fictitious, or fraudulent as a result of such omission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd48c180-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a statement in which the person making, presenting, or submitting such statement has a duty to include such material fact; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd48c181-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is for payment for the provision of property or services which the person has not provided as claimed,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to, in addition to any other remedy that may be prescribed by law, a civil penalty of not more than $5,000 for each such claim. Except as provided in paragraph (3) of this subsection, such person shall also be subject to an assessment, in lieu of damages sustained by the United States because of such claim, of not more than twice the amount of such claim, or the portion of such claim, which is determined under this chapter to be in violation of the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd48c182-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any person who makes, presents, or submits, or causes to be made, presented, or submitted, a written statement that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd48c183-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the person knows or has reason to know—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd48c184-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" asserts a material fact which is false, fictitious, or fraudulent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd48c185-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd48c186-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" omits a material fact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd48c187-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is false, fictitious, or fraudulent as a result of such omission;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd48c188-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a statement described in clause (ii) of subparagraph (A), is a statement in which the person making, presenting, or submitting such statement has a duty to include such material fact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd48c189-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contains or is accompanied by an express certification or affirmation of the truthfulness and accuracy of the contents of the statement,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be subject to, in addition to any other remedy that may be prescribed by law, a civil penalty of not more than $5,000 for each such statement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd48c18a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd48c18b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), an assessment shall not be made under the second sentence of paragraph (1) with respect to a claim if payment by the Government has not been made on such claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd48c18c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a claim described in section 3801(a)(3)(C), an assessment shall not be made under the second sentence of paragraph (1) in an amount that is more than double the value of the property, services, or money that was wrongfully withheld from the authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd48c18d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd48c18e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraphs (2) and (3) of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd48c18f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803/a/2"},"text":"section 3803(a)(2) of this title","children":[],"tail":" that there is adequate evidence to believe that a person is liable under subsection (a) of this section; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd48c190-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a determination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803"},"text":"section 3803 of this title","children":[],"tail":" that a person is liable under subsection (a) of this section,"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"may provide the authority with grounds for commencing any administrative or contractual action against such person which is authorized by law and which is in addition to any action against such person under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd48c191-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A determination referred to in paragraph (1) of this subsection may be used by the authority, but shall not require such authority, to commence any administrative or contractual action which is authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd48c192-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3802/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an administrative or contractual action to suspend or debar any person who is eligible to enter into contracts with the Federal Government, a determination referred to in paragraph (1) of this subsection shall not be considered as a conclusive determination of such person’s responsibility pursuant to Federal procurement laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd48c193-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVI/s6103/a"},"text":"Pub. L. 99–509, title VI, § 6103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1937"},"text":"100 Stat. 1937","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLII/s5203/b/2"},"text":"Pub. L. 118–159, div. E, title LII, § 5203(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2440"},"text":"138 Stat. 2440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd48c194-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd48c195-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd48c196-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" designated existing provisions as subpar. (A), substituted “Except as provided in subparagraph (B), an assessment” for “An assessment”, and added subpar. (B)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
