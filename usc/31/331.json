43, ch. 52, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/57/63"},"text":"57 Stat. 63","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1945-04-03/ch51/s3"},"text":"Apr. 3, 1945, ch. 51, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/48"},"text":"59 Stat. 48","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"331(a)(7)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:725p(a)(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1934-06-26/ch756"},"text":"June 26, 1934, ch. 756","children":[],"tail":", §§ 17(a)(last sentence), 18(a)(last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/48/1230"},"text":"48 Stat. 1230","children":[],"tail":", 1231."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:725q(a)(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"331(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:757f.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 13, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/809/s402"},"text":"Pub. L. 89–809, § 402","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/1590"},"text":"80 Stat. 1590","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/273/s2/17"},"text":"Pub. L. 94–273, § 2(17)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/375"},"text":"90 Stat. 375","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"331(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1029.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1894-07-31/ch174/s15"},"text":"July 31, 1894, ch. 174, § 15","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/28/210"},"text":"28 Stat. 210","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"331(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1002(words between 4th and 5th semicolons)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 248(words between 4th and 5th semicolons).","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (c), the word “receipts” is substituted for “revenues” for consistency in the section and the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “public receipts and public expenditures” are substituted for “receipts and expenditures of the Government” in 31:1030 for consistency in the section. The word “completed” is omitted as surplus. In clause (2), the words “First. A report on the subject of finance” in 31:1027 are omitted because of the restatement. The word “containing” is omitted as surplus. In clause (4), the words “Second. A report containing” are omitted because of the restatement. The words “prior fiscal year” are substituted for “during the year preceding” for consistency. In clause (5), the words “paid at the Treasury” are omitted as unnecessary. The 3d paragraph of section 257 of the Revised Statutes, providing for a report on rules and regulations of the Secretary of the Treasury on imported goods, wares, and merchandise, is omitted as obsolete because section 252 of the Revised Statutes, authorizing those rules and regulations, was repealed by the Act of ","children":[{"tag":"date","attrib":{"date":"1877-02-27"},"text":"February 27, 1877","children":[],"tail":" (ch. 69, "},{"tag":"ref","attrib":{"href":"/us/stat/19/241"},"text":"19 Stat. 241","children":[],"tail":"). The 4th paragraph of section 257, providing for a report on amounts of hospital taxes collected from sick and disabled seamen, is omitted as obsolete because "},{"tag":"ref","attrib":{"href":"/us/act/1884-06-26/s15"},"text":"section 15 of the Act of June 26, 1884","children":[],"tail":" (ch. 121, "},{"tag":"ref","attrib":{"href":"/us/stat/23/57"},"text":"23 Stat. 57","children":[],"tail":"), repealed the tax. In clause (7), the words “the Commissioners of the District of Columbia” (subsequently changed to “the Mayor of the District of Columbia” by section 422 of the District of Columbia Self-Government and Governmental Reorganization Act ("},{"tag":"ref","attrib":{"href":"/us/pl/93/198"},"text":"Pub. L. 93–198","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/790"},"text":"87 Stat. 790","children":[],"tail":")) in 31:725p are omitted as unnecessary because of § 448 of the District of Columbia Self-Government and Governmental Reorganization Act. The text of 31:725q(proviso) is omitted because of the restatement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “for the prior fiscal year” are substituted for “as of the close of the preceding September 30 (beginning with the report as of ","children":[{"tag":"date","attrib":{"date":"1967-06-30"},"text":"June 30, 1967","children":[],"tail":")” to eliminate unnecessary words. In clause (C), the word “obligations” is substituted for “securities” for consistency in the revised title. Clause (D) is substituted for “and of each department, agency, and instrumentality thereof” for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “a report for the prior fiscal year on the total amount of public receipts and public expenditures” are substituted for “an accurate combined statement of the receipts and expenditures during the last preceding fiscal year of all public moneys” because of the restatement. The words “including those of the United States Postal Service” are omitted as unnecessary and superseded by 39:410.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “either House of Congress” are substituted for “either branch of the legislature” for clarity and consistency. The words “that House of Congress” are substituted for “the Senate or House of Representatives” for consistency and because of the restatement. The words “or which appertain to his office” are omitted as unnecessary because of subsections (a)–(c) of the section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcdd7c9e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcdd7c9f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/356"},"text":"Pub. L. 103–356","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcdd7ca0-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcdd7ca1-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For termination, effective ","children":[{"tag":"date","attrib":{"date":"2000-05-15"},"text":"May 15, 2000","children":[],"tail":", of provisions of law requiring submittal to Congress of any annual, semiannual, or other regular periodic report listed in House Document No. 103–7 (in which certain reporting requirements under subsecs. (a), (b)(1)(A), and (c) of this section are listed on pages 140 and 142), see "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/s3003"},"text":"section 3003 of Pub. L. 104–66","children":[],"tail":", as amended, and section 1(a)(4) [div. A, § 1402(1)] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/554"},"text":"Pub. L. 106–554","children":[],"tail":", set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1113"},"text":"section 1113 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
