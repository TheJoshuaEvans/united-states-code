{"tag":"section","attrib":{"id":"idbcdd7c85-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331"},"text":null,"children":[{"tag":"num","attrib":{"value":"331"},"text":"§ 331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcdd7c86-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Treasury shall submit to Congress each year an annual report. The report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcdd7c87-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the public receipts and public expenditures for the prior fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7c88-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates of public receipts and public expenditures for the current and next fiscal years;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7c89-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans for improving and increasing public receipts to provide Congress with information on ways to raise amounts necessary to meet public expenditures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7c8a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of all contracts for supplies or services made by the Secretary during the prior fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7c8b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of appropriations expended to pay for miscellaneous claims not otherwise provided for;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7c8c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement on all payments made from the fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3126"},"text":"section 3126 of this title","children":[],"tail":" for the prior fiscal year; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7c8d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" estimates of amounts for payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1322/b"},"text":"section 1322(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdd7c8e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcdd7c8f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On the first day of each regular session of Congress, the Secretary shall submit to Congress a report for the prior fiscal year on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcdd7c90-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total and individual amounts of contingent liabilities and unfunded liabilities of the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcdd7c91-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as far as practicable, trust fund liabilities, liabilities of Government corporations, indirect liabilities not included as a part of the public debt, and liabilities of insurance and annuity programs (including their actuarial status);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcdd7c92-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collateral pledged and assets available (or to be realized) as security for the liabilities (separately noting Government obligations) and other assets specifically available to liquidate the liabilities of the Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcdd7c93-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total amount in each category under clauses (A)–(C) of this paragraph for each agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7c94-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report shall present the information required under paragraph (1) of this subsection in a concise way, with explanatory material (including an analysis of the significance of liabilities based on past experience and probable risk) the Secretary considers desirable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdd7c95-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On the first day of each regular session of Congress, the Secretary shall submit to Congress a report for the prior fiscal year on the total amount of public receipts and public expenditures listing receipts, when practicable, by ports, districts, and States and the expenditures by each appropriation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdd7c96-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall report to either House of Congress in person or in writing, as required, on matters referred to the Secretary by that House of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdd7c97-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcdd7c98-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than March 31 of 1998 and each year thereafter, the Secretary of the Treasury, in coordination with the Director of the Office of Management and Budget, shall annually prepare and submit to the President and the Congress an audited financial statement for the preceding fiscal year, covering all accounts and associated activities of the executive branch of the United States Government. The financial statement shall reflect the overall financial position, including assets and liabilities, and results of operations of the executive branch of the United States Government, and shall be prepared in accordance with the form and content requirements set forth by the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdd7c99-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s331/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General of the United States shall audit the financial statement required by this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcdd7c9a-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/884"},"text":"96 Stat. 884","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/356/tIV/s405/c"},"text":"Pub. L. 103–356, title IV, § 405(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3416"},"text":"108 Stat. 3416","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcdd7c9b-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcdd7c9c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbcdd7c9d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"childre