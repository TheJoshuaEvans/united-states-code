{"tag":"section","attrib":{"id":"idbd5e456a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5301"},"text":null,"children":[{"tag":"num","attrib":{"value":"5301"},"text":"§ 5301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buying obligations of the United States Government","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd5e456b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President may direct the Secretary of the Treasury to make an agreement with the Federal reserve banks and the Board of Governors of the Federal Reserve System when the President decides that the foreign commerce of the United States is affected adversely because—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5e456c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the value of coins and currency of a foreign country compared to the present standard value of gold is depreciating;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5e456d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" action is necessary to regulate and maintain the parity of United States coins and currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5e456e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5301/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an economic emergency requires an expansion of credit; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5e456f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5301/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an expansion of credit is necessary so that the United States Government and the governments of other countries can stabilize the value of coins and currencies of a country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5e4570-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under an agreement under subsection (a) of this section, the Board shall permit the banks (and the Board is authorized to permit the banks notwithstanding another law) to agree that the banks will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5e4571-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct through each entire specified period open market operations in obligations of the United States Government or corporations in which the Government is the majority stockholder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5e4572-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buy directly and hold an additional $3,000,000,000 of obligations of the Government for each agreed period, unless the Secretary consents to the sale of the obligations before the end of the period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5e4573-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With the approval of the Secretary, the Board may require Federal reserve banks to take action the Secretary and Board consider necessary to prevent unreasonable credit expansion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd5e4574-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/993"},"text":"96 Stat. 993","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd5e4575-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd5e4576-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd5e4577-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5301(a), (b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:821(less (a)(last sentence)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1933-05-12/ch25/s43"},"text":"May 12, 1933, ch. 25, § 43","children":[],"tail":"(less (b)(1)(last sentence)), "},{"tag":"html:a","attrib":{"href":"/us/stat/48/51"},"text":"48 Stat. 51","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1934-01-30/ch6/s12"},"text":"Jan. 30, 1934, ch. 6, § 12","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/342"},"text":"48 Stat. 342","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1937-01-23/ch5/s2"},"text":"Jan. 23, 1937, ch. 5, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/50/4"},"text":"50 Stat. 4","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1939-07-06/ch260/s3"},"text":"July 6, 1939, ch. 260, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/998"},"text":"53 Stat. 998","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1941-06-30/ch265/s2"},"text":"June 30, 1941, ch. 265, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/55/396"},"text":"55 Stat. 396","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1945-06-12/ch186/s4"},"text":"June 12, 1945, ch. 186, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/238"},"text":"59 Stat. 238","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Mar. 18, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/269/s9"},"text":"Pub. L. 90–269, § 9","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/50"},"text":"82 Stat. 50","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5301(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:821(a)(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the text of 31:821(b)(matter before (1)) is omitted as obsolete because clause (1) is omitted as executed, and clause (2) is omitted as expired. The text of 31:821(b)(matter after (2)) is omitted as obsolete because silver is no longer coined. The words “in his discretion” and “several” are omitted as surplus. The words “Board of Governors of the Federal Reserve System” are substituted for “Federal Reserve Board” because of 12:241. The words “upon investigation” are omitted as surplus. In clause (1), the word “foreign” is substituted for “of any other government or governments” to eliminate unnecessary words. The words “coins and” are added for consistency. In clause (2), the words “United States coins and currency” are substituted for “currency issues of the United States” for consistency. In clause (4), the words “so that the United States Government and the governments of other countries can stabilize” are substituted for “to secure by international agreement a stabilization” for clarity. The words “at proper levels” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “(and the Board is authorized to permit the banks notwithstanding another law)” are substituted for “notwithstanding any provisions of law or rules and regulations to the contrary” for clarity. In clause (1), the words “pursuant to existing law” are omitted as surplus. The words “through each entire” are substituted for “throughout” for clarity. In clause (2), the words “in portfolio”, “or periods of time Treasury bills or other” and “in an aggregate sum of” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd5e4578-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd5e4579-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dF/s6001"},"text":"Pub. L. 116–283, div. F, § 6001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"t