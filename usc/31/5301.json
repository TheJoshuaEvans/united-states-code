ail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd5e457a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2006 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tVIII/s801"},"text":"Pub. L. 109–347, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1952"},"text":"120 Stat. 1952","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/347/tVIII/s801"},"text":"“This title [enacting sections 5361 to 5367 of this title and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5361"},"text":"section 5361 of this title","children":[],"tail":"] may be cited as the ‘Unlawful Internet Gambling Enforcement Act of 2006’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd5e457b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVI/s6201"},"text":"Pub. L. 108–458, title VI, § 6201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3745"},"text":"118 Stat. 3745","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/458/tVI/s6201"},"text":"“This subtitle [subtitle C (§§ 6201–6205) of title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":", amending sections 310, 5312, 5318, 5318A, 5324, and 5332 of this title, sections 1828, 1829b, and 1953 of Title 12, Banks and Banking, "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681v"},"text":"section 1681v of Title 15","children":[],"tail":", Commerce and Trade, and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–4r"},"text":"section 262p–4r of Title 22","children":[],"tail":", Foreign Relations and Intercourse, enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1828"},"text":"section 1828 of Title 12","children":[],"tail":", amending provisions set out as notes under sections 310, 5311, and 5331 of this title and sections 1828 and 1842 of Title 12, and repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5311"},"text":"section 5311 of this title","children":[],"tail":"] may be cited as the ‘International Money Laundering Abatement and Financial Antiterrorism Technical Corrections Act of 2004’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd5e457c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2001 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s301"},"text":"Pub. L. 107–56, title III, § 301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/296"},"text":"115 Stat. 296","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/56/tIII/s301"},"text":"“This title [enacting sections 310, 5318A, 5331, and 5332 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681v"},"text":"section 1681v of Title 15","children":[],"tail":", Commerce and Trade, and "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s262p–4r"},"text":"section 262p–4r of Title 22","children":[],"tail":", Foreign Relations and Intercourse, amending sections 5311, 5312, 5317, 5318, 5319, 5321, 5322, 5324, 5326, 5328, 5330, and 5341 of this title, sections 248, 1828, 1829b, 1842, 1953, 3412, 3414, and 3420 of Title 12, Banks and Banking, "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681u"},"text":"section 1681u of Title 15","children":[],"tail":", sections 470 to 474, 476 to 484, 493, 981 to 983, 1029, 1956, and 1960 of Title 18, Crimes and Criminal Procedure, "},{"tag":"ref","attrib":{"href":"/us/usc/t21/s853"},"text":"section 853 of Title 21","children":[],"tail":", Food and Drugs, and sections 2466 and 2467 of Title 28, Judiciary and Judicial Procedure, renumbering former "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s310"},"text":"section 310 of this title","children":[],"tail":" as section 311, and enacting provisions set out as notes under sections 310, 5311, 5313, 5314, 5318, 5331, and 5332 of this title, sections 1828, 1829b, and 1842 of Title 12, and "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s983"},"text":"section 983 of Title 18","children":[],"tail":"] may be cited as the ‘International Money Laundering Abatement and Financial Anti-Terrorism Act of 2001’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd5e457d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/310/s1"},"text":"Pub. L. 105–310, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2941"},"text":"112 Stat. 2941","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/310/s1"},"text":"“This Act [enacting subchapter III of this chapter and provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5342"},"text":"section 5342 of this title","children":[],"tail":"] may be cited as the ‘Money Laundering and Financial Crimes Strategy Act of 1998’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd5e457e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIV/s401"},"text":"Pub. L. 103–325, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2243"},"text":"108 Stat. 2243","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/325/tIV/s401"},"text":"“This title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5330"},"text":"section 5330 of this title","children":[],"tail":", amending sections 5312, 5313, 5318, 5321, 5322, and 5324 of this title, sections 93, 1464, 1772d, 1786, 1818, and 1821 of Title 12, Banks and Banking, and sections 984, 986, 1956, 1957, and 1960 of Title 18, Crimes and Criminal Procedure, and enacting provisions set out as notes under sections 5311, 5313, 5318, and 5330 of this title] may be cited as the ‘Money Laundering Suppression Act of 1994’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
