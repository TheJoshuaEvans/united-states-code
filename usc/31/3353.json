{"tag":"section","attrib":{"id":"idbd29c856-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353"},"text":null,"children":[{"tag":"num","attrib":{"value":"3353"},"text":"§ 3353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd29c857-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Compliance Report by Inspectors General of Executive Agencies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd29c858-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each fiscal year, the Inspector General of each executive agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd29c859-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether the executive agency is in compliance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd29c85a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit a report on the determination made under subparagraph (A) to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd29c85b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of the executive agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd29c85c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd29c85d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Oversight and Reform of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd29c85e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Comptroller General of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd29c85f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development or use of a central website","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council of the Inspectors General on Integrity and Efficiency (in this subsection referred to as the “Council”) shall develop a public central website, or make use of a public central website in existence on the date of enactment of this section, to contain individual compliance determination reports issued by Inspectors General under paragraph (1)(B) and such additional information as determined by the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd29c860-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"OMB guidance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of this section, the Director of the Office of Management and Budget, in consultation with the Council and with consideration given to the available resources and independence of individual Offices of Inspectors General, shall develop and promulgate guidance for the compliance determination reports issued by the Inspectors General under paragraph (1)(B), which shall require that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd29c861-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reporting format used by the Inspectors General is consistent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd29c862-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inspectors General evaluate and take into account the adequacy of executive agency risk assessments, improper payment estimates methodology, and executive agency action plans to address the causes of improper payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd29c863-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inspectors General take into account whether the executive agency has correctly identified the causes of improper payments and whether the actions of the executive agency to address those causes are adequate and effective;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd29c864-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inspectors General evaluate the adequacy of executive agency action plans on how the executive agency addresses the causes of improper payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd29c865-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of the report, Inspectors General include an evaluation of executive agency efforts to prevent and reduce improper payments and any recommendations for actions to further improve that prevention and reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c3966-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"CIGIE guidance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of this section, the Council shall, with consideration given to the available resources and independence of individual Offices of Inspectors General, develop and promulgate guidance that specifies procedures for compliance determinations made by the Inspectors General under paragraph (1)(A), which shall describe procedures for Inspectors General—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c3967-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make the determinations consistent regarding compliance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c3968-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to evaluate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd2c3969-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for compliance with the requirement described in section 3351(2)(B), the risk assessment methodology of the executive agency, including whether the audits, examinations, and legal actions of the Inspector General indicate a higher risk of improper payments or actual improper payments that were not included in the risk assessments of the executive agency conducted under section 3352(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd2c396a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for compliance with the requirement described in section 3351(2)(C), the accuracy of the rate estimates and whether the sampling and estimation plan used is appropriate given program characteristics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd2c396b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for compliance with the requirement described in section 3351(2)(D), the corrective action plans and whether the plans are adequate and focused on the true causes of improper payments, including whether the corrective action plans are—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd2c396c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/4/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing improper payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd2c396d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/4/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effectively implemented; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd2c396e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/4/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritized within the executive agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd2c396f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy of executive agency action plans to address the causes of improper payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd2c3970-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" executive agency efforts to prevent and reduce improper payments, and any recommendations for actions to further improve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd2c3971-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/a/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether an executive agency has published an annual financial statement in accordance with the requirement described in section 3351(2)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c3972-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remediation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c3973-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Noncompliance.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c3974-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an executive agency is determined by the Inspector General of that executive agency not to be in compliance under subsection (a) in a fiscal year with respect to a program or activity, the head of the executive agency shall submit to the appropriate authorizing and appropriations committees of Congress a plan describing the actions that the executive agency will take to come into compliance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c3975-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan described in subparagraph (A) shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd2c3976-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measurable milestones to be accomplished in order to achieve compliance for each program or activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd2c3977-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designation of a senior executive agency official who shall be accountable for the progress of the executive agency in coming into compliance for each program or activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd2c3978-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment of an accountability mechanism, such as a performance agreement, with appropriate incentives and consequences tied to the success of the official designated under clause (ii) in leading the efforts of the executive agency to come into compliance for each program or activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c3979-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Noncompliance for 2 fiscal years.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c397a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an executive agency is determined by the Inspector General of that executive agency not to be in compliance under subsection (a) for 2 consecutive fiscal years for the same program or activity, the executive agency shall propose to the Director of the Office of Management and Budget additional program integrity proposals that would help the executive agency come into compliance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c397b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional funding.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idbd2c397c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Director of the Office of Management and Budget determines that additional funding would help an executive agency described in subparagraph (A) come into compliance, the head of the executive agency shall obligate additional funding, in an amount determined by the Director, to intensified compliance efforts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd2c397d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reprogramming or transfer authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In providing additional funding under clause (i)—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd2c397e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of an executive agency shall use any reprogramming or transfer authority available to the executive agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd2c397f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if after exercising the reprogramming or transfer authority described in subclause (I), additional funding is necessary to obligate the full level of funding determined by the Director of the Office of Management and Budget under clause (i), the executive agency shall submit a request to Congress for additional reprogramming or transfer authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c3980-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reauthorization and statutory proposals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an executive agency is determined by the Inspector General of that executive agency not to be in compliance under subsection (a) for 3 consecutive fiscal years for the same program or activity, the head of the executive agency shall, not later than 30 days after the date of that determination, submit to the appropriate authorizing and appropriations committees of Congress and the Comptroller General of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c3981-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd2c3982-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reauthorization proposals for each program or activity that has not been in compliance for 3 or more consecutive fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd2c3983-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed statutory changes necessary to bring the program or activity into compliance; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c3984-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the head of the executive agency determines that clauses (i) and (ii) of subparagraph (A) will not bring the program or activity into compliance, a description of the actions that the executive agency is undertaking to bring the program or activity into compliance and a timeline of when the compliance will be achieved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c3985-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan and timeline for compliance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an executive agency is determined by the Inspector General of that executive agency not to be in compliance under subsection (a) for 4 or more consecutive fiscal years for the same program or activity, the head of the executive agency shall, not later than 30 days after such determination, submit to the appropriate authorizing and appropriations committees of Congress a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c3986-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the activities taken to comply with the requirements for 1, 2, 3, 4, or more years of noncompliance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c3987-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any requirements that were fulfilled for 1, 2, or 3 consecutive years of noncompliance that are still relevant and being pursued as a means to bring the program or activity into compliance and prevent and reduce improper payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c3988-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of any new corrective actions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c3989-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a timeline for when the program or activity will achieve compliance based on the actions described within the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c398a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each executive agency shall submit to the appropriate authorizing and appropriations committees of Congress and the Comptroller General of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c398b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of each program or activity that was determined to not be in compliance under paragraph (1), (2), (3), or (4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c398c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions that are planned to bring the program or activity into compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c398d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance Enforcement Pilot Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Office of Management and Budget may establish 1 or more pilot programs that shall test potential accountability mechanisms with appropriate incentives and consequences tied to success in ensuring compliance with this section and eliminating improper payments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c398e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Improved Estimates Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidance required to be provided under section 3(b) of the Improper Payments Elimination and Recovery Improvement Act of 2012, as in effect on the day before the date of enactment of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c398f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall continue to be in effect on and after the date of enactment of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c3990-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3353/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be modified as determined appropriate by the Director of the Office of Management and Budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd2c3991-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117/s2/a"},"text":"Pub. L. 116–117, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/123"},"text":"134 Stat. 123","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd2c3992-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd2c3993-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd2c3994-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (a)(2) to (4) and (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117"},"text":"Pub. L. 116–117","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 3(b) of the Improper Payments Elimination and Recovery Improvement Act of 2012, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/248/s3"},"text":"section 3 of Pub. L. 112–248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2390"},"text":"126 Stat. 2390","children":[],"tail":", which was formerly set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3321"},"text":"section 3321 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/117/s3/a/3"},"text":"Pub. L. 116–117, § 3(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/133"},"text":"134 Stat. 133","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd2c3995-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbd2c3996-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
