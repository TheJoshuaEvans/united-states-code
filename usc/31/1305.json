{"tag":"section","attrib":{"id":"idbd085d88-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1305"},"text":null,"children":[{"tag":"num","attrib":{"value":"1305"},"text":"§ 1305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous permanent appropriations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Necessary amounts are appropriated for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd085d89-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1305/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay the proceeds of the personal estate of a United States citizen dying abroad to the legal representative of the deceased on proper demand and proof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d8a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1305/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay interest on the public debt under laws authorizing payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d8b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1305/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay proceeds from derelict and salvage cases adjudged by the courts of the United States to salvors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d8c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1305/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make payments required under contracts made under section 108 of the Housing and Community Development Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5308"},"text":"42 U.S.C. 5308","children":[],"tail":") for the payment of interest on obligations guaranteed by the Secretary of Housing and Urban Development under section 108."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d8d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1305/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make payments required under contracts made under section 103(b) of the Housing Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1453/b"},"text":"42 U.S.C. 1453(b)","children":[],"tail":") for projects or programs for which amounts had been committed before "},{"tag":"date","attrib":{"date":"1975-01-01"},"text":"January 1, 1975","children":[],"tail":", and for which amounts have not been appropriated."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d8e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1305/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay the interest on the fund derived from the bequest of James Smithson, for the construction of buildings and expenses of the Smithsonian Institution, at the rates determined under section 5590 of the Revised Statutes (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s54"},"text":"20 U.S.C. 54","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":"annual contributions for assisted housing","children":[],"tail":null}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd085d8f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1305/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content",