le IV of the Housing Act of 1950, which was classified generally to subchapter IX (§ 1749 et seq.) of chapter 13 of Title 12, Banks and Banking, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/99/498/tVII/s702"},"text":"Pub. L. 99–498, title VII, § 702","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-17"},"text":"Oct. 17, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1545"},"text":"100 Stat. 1545","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1950 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701"},"text":"section 1701 of Title 12","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 101 of the Housing and Urban Development Act of 1965, referred to in par. (9), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/117/s101"},"text":"section 101 of Pub. L. 89–117","children":[],"tail":", title I, "},{"tag":"date","attrib":{"date":"1965-08-10"},"text":"Aug. 10, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/451"},"text":"79 Stat. 451","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1701s"},"text":"section 1701s of Title 12","children":[],"tail":", and amended sections 1451 and 1465 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd085d99-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd085d9a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Pars. (7) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/371"},"text":"Pub. L. 98–371","children":[],"tail":" added pars. (7) to (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452"},"text":"Pub. L. 97–452","children":[],"tail":" substituted provisions relating to payment of the interest on the fund derived from the bequest of James Smithson, for the construction of buildings and the expenses of the Smithsonian Institution, at rates determined under section 5590 of the Revised Statutes, for provisions relating to payment for construction of buildings and expenses of the Smithsonian Institution, at 6 percent on the fund derived from the bequest of James Smithson."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
