{"tag":"section","attrib":{"id":"idbd7d4000-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6305"},"text":null,"children":[{"tag":"num","attrib":{"value":"6305"},"text":"§ 6305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Using cooperative agreements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An executive agency shall use a cooperative agreement as the legal instrument reflecting a relationship between the United States Government and a State, a local government, or other recipient when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d4001-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6305/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal purpose of the relationship is to transfer a thing of value to the State, local government, or other recipient to carry out a public purpose of support or stimulation authorized by a law of the United States instead of acquiring (by purchase, lease, or barter) property or services for the direct benefit or use of the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d4002-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6305/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial involvement is expected between the executive agency and the State, local government, or other recipient when carrying out the activity contemplated in the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7d4003-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1004"},"text":"96 Stat. 1004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7d4004-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd7d4005-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd7d4006-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6305","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:505.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Feb. 3, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/224/s6"},"text":"Pub. L. 95–224, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/5"},"text":"92 Stat. 5","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “type of” are omitted as unnecessary. The words “money, property, services” are omitted as being included in “a thing of value”. The words “law of the United States” are substituted for “Federal statute” for consistency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd7d4007-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7d4008-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of North American Wetlands Conservation Act and North American Waterfowl Management Plan","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/154/tI"},"text":"Pub. L. 102–154, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-13"},"text":"Nov. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/995"},"text":"105 Stat. 995","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/154/tI"},"text":"“Notwithstanding the provisions of the Federal Grant and Cooperative Agreements Act of 1977 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6301–630"},"text":"31 U.S.C. 6301–630","children":[],"tail":"8), the Fish and Wildlife Service is hereafter authorized to negotiate and enter into cooperative arrangements and grants with public and private agencies, organizations, institutions, and individuals to implement on a public-private cost sharing basis, the North American Wetlands Conservation Act ["},{"tag":"ref","attrib":{"href":"/us/usc/t16/s4401"},"text":"16 U.S.C. 4401","children":[],"tail":" et seq.] and the North American Waterfowl Management Plan”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7d4009-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Printing of Educational Materials and Continuation of Challenge Cost-Share Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/154/tII"},"text":"Pub. L. 102–154, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-13"},"text":"Nov. 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1018"},"text":"105 Stat. 1018","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/154/tII"},"text":"“Notwithstanding the provisions of the Federal Grant and Cooperative Agreements Act of 1977 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6301–630"},"text":"31 U.S.C. 6301–630","children":[],"tail":"8), the Forest Service is authorized hereafter to negotiate and enter into cooperative arrangements with public and private agencies, organizations, institutions, and individuals to print educational materials and to continue the Challenge Cost-Share Program.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd7d400a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Bureau of Land Management; Authorization To Use Cooperative Arrangements To Implement Challenge Cost-Share Programs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/512/tI"},"text":"Pub. L. 101–512, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1918"},"text":"104 Stat. 1918","children":[],"tail":", provided in part that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/101/512/tI"},"text":"“the Bureau [of Land Management] is authorized hereafter to negotiate and enter into cooperative arrangements with public and private agencies, organizations, institutions, and individuals, to implement challenge cost-share programs.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
