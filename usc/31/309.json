{"tag":"section","attrib":{"id":"idbccf253c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s309"},"text":null,"children":[{"tag":"num","attrib":{"value":"309"},"text":"§ 309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Thrift Supervision","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Office of Thrift Supervision established under section 3(a) ","children":[{"tag":"ref","attrib":{"idref":"fn002002"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002002"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the Home Owners’ Loan Act shall be an office in the Department of the Treasury."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbccf253d-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/73/tIII/s307/a/1"},"text":"Pub. L. 101–73, title III, § 307(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-08-09"},"text":"Aug. 9, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/352"},"text":"103 Stat. 352","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/f/1/A"},"text":"Pub. L. 103–272, § 4(f)(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1361"},"text":"108 Stat. 1361","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbccf253e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbccf253f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbccf2540-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3(a) of the Home Owners’ Loan Act, referred to in text, which established the Office of Thrift Supervision, was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1462a/a"},"text":"section 1462a(a) of Title 12","children":[],"tail":", Banks and Banking, and was struck out by "},{"tag":"ref","attrib":{"href":"/us/pl/111/203/tIII/s369/3/B"},"text":"Pub. L. 111–203, title III, § 369(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-21"},"text":"July 21, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/1558"},"text":"124 Stat. 1558","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbccf2541-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 309 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s315"},"text":"section 315 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbccf2542-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":" substituted “section 3(a)” for “section 2A(a)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbccf2543-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idbccf2544-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Office of Thrift Supervision abolished and functions transferred to the Board of Governors of the Federal Reserve System, the Office of the Comptroller of the Currency and the Comptroller of the Currency, and the Federal Deposit Insurance Corporation by sections 5412 and 5413 of Title 12, Banks and Banking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
