{"tag":"section","attrib":{"id":"idbcf54aeb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753"},"text":null,"children":[{"tag":"num","attrib":{"value":"753"},"text":"§ 753.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties and powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf54aec-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The General Accounting Office Personnel Appeals Board ","children":[{"tag":"ref","attrib":{"idref":"fn002018"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002018"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" may consider and order corrective or disciplinary action in a case arising from—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf54aed-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an officer or employee appeal about a removal, suspension for more than 14 days, reduction in grade or pay, or furlough of not more than 30 days;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54aee-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prohibited personnel practice under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s732/b/2"},"text":"section 732(b)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54aef-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a prohibited political activity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s732/b/3"},"text":"section 732(b)(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54af0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a decision of an appropriate unit of employees for collective bargaining;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54af1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an election or certification of a collective bargaining representative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54af2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a matter appealable to the Board under the labor-management relations program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s732/e/2"},"text":"section 732(e)(2) of this title","children":[],"tail":", including a labor practice prohibited under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s732/e/1"},"text":"section 732(e)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54af3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an action involving discrimination prohibited under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s732/f/1"},"text":"section 732(f)(1) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54af4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an issue about Office personnel the Comptroller General by regulation decides the Board shall resolve; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54af5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an action involving discrimination prohibited under section 312(e)(2) ","children":[{"tag":"ref","attrib":{"idref":"fn002019"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002019"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" of the Architect of the Capitol Human Resources Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf54af6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board has no authority to issue a stay of any reduction in force action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf54af7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may delegate to a member or a panel of members the authority to act under subsection (a) of this section. A decision of a member or panel under subsection (a) is deemed to be a final decision of the Board unless the Board reconsiders the decision under subsection (d) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf54af8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On motion of a party or on its own initiative, the Board may reconsider a decision under subsection (a) of this section by the 30th day after the decision is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf54af9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board shall prescribe regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf54afa-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for officer and employee appeals consistent with sections 7701 and 7702 of title 5; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54afb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s753/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the operating procedure of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf54afc-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 19