ted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf54b00-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbcf54b01-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 312(e)(2) of the Architect of the Capitol Human Resources Act, referred to in subsec. (a)(9), was classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1831/e/2"},"text":"section 1831(e)(2) of Title 2","children":[],"tail":", The Congress, and was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/1/tV/s504/c/1"},"text":"Pub. L. 104–1, title V, § 504(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-01-23"},"text":"Jan. 23, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/41"},"text":"109 Stat. 41","children":[],"tail":", except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1435"},"text":"section 1435 of Title 2","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf54b02-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53/s213/2"},"text":"Pub. L. 104–53, § 213(2)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53/s213/1"},"text":"Pub. L. 104–53, § 213(1)","children":[],"tail":", (3), redesignated subsec. (b) as (c) and in second sentence substituted “under subsection (d)” for “under subsection (c)”. Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/53/s213/1"},"text":"Pub. L. 104–53, § 213(1)","children":[],"tail":", redesignated subsecs. (c) and (d) as (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/283"},"text":"Pub. L. 103–283","children":[],"tail":" added par. (9). See Application of Provisions Amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/283"},"text":"Pub. L. 103–283","children":[],"tail":" note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf54b03-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbcf54b04-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"General Accounting Office redesignated Government Accountability Office. See ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8"},"text":"section 8 of Pub. L. 108–271","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s702"},"text":"section 702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcf54b05-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of Provisions Amended by Pub. L. 103–283","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions of this section amended by ","child