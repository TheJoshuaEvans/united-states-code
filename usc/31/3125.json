{"tag":"section","attrib":{"id":"idbd1de18b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3125"},"text":null,"children":[{"tag":"num","attrib":{"value":"3125"},"text":"§ 3125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief for lost, stolen, destroyed, mutilated, or defaced obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1de18c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3125/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this section, “obligation” means a direct obligation of the United States Government issued under law for valuable consideration, including bonds, notes, certificates of indebtedness, Treasury bills, and interim certificates issued for an obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd202b7d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3125/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury may provide relief for the loss, theft, destruction, mutilation, or defacement of an obligation identified by number and description.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd202b7e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3125/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd202b7f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3125/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An indemnity bond is required as a condition of relief if the obligation is payable to bearer or assigned so as to become payable to bearer and is not proven clearly to have been destroyed. The Secretary may prescribe for the indemnity bond the form, amount, and surety or security requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd202b80-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3125/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Relief for interest coupons claimed to have been attached to an obligation may be provided only if the Secretary is satisfied that the coupons have not been paid and are destroyed or will not become the basis of a valid claim against the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd202b81-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/946"},"text":"96 Stat. 946","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd202b82-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd202b83-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd202b84-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3125(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:738a(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1937-07-08/ch444/s8/a"},"text":"July 8, 1937, ch. 444, § 8(a)","children":[],"tail":"–(d), "},{"tag":"html:a","attrib":{"href":"/us/stat/50/481"},"text":"50 Stat. 481","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1939-08-10/ch665/s4"},"text":"Aug. 10, 1939, ch. 665, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/1359"},"text":"53 Stat. 1359","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1945-11-08/ch453/s153"},"text":"Nov. 8, 1945, ch. 453, § 153","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/574"},"text":"59 Stat. 574","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"May 27, 1971","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/19"},"text":"Pub. L. 92–19","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/85/74"},"text":"85 Stat. 74","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3125(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:738a(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3125(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:738a(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3125(c)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:738a(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the word “obligation” is substituted for “security” in the defined term for consistency in the chapter and the revised title and to eliminate using the word “security” in 2 different ways in the same section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Under such regulations as he may deem necessary for the administration of this section” are omitted as unnecessary because of section 321(b) of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “whether before, at, or after maturity” and “in effect” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
