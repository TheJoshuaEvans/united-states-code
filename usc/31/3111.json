{"tag":"section","attrib":{"id":"idbd1b7116-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3111"},"text":null,"children":[{"tag":"num","attrib":{"value":"3111"},"text":"§ 3111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New issue used to buy, redeem, or refund outstanding obligations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An obligation may be issued under this chapter to buy, redeem, or refund, at or before maturity, outstanding bonds, notes, certificates of indebtedness, Treasury bills, or savings certificates of the United States Government. Under regulations of the Secretary of the Treasury, money received from the sale of an obligation and other money in the general fund of the Treasury may be used in making the purchases, redemptions, or refunds.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd1b7117-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/942"},"text":"96 Stat. 942","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1b7118-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd1b7119-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd1b711a-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","chi