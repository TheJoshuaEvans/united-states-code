{"tag":"section","attrib":{"id":"idbd846c14-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710"},"text":null,"children":[{"tag":"num","attrib":{"value":"6710"},"text":"§ 6710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd846c15-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hearings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd846c16-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A unit of general local government expending payments under this chapter shall hold at least one public hearing on the proposed use of the payment in relation to its entire budget. At the hearing, persons shall be given an opportunity to provide written and oral views to the governmental authority responsible for enacting the budget and to ask questions about the entire budget and the relation of the payment to the entire budget. The government shall hold the hearing at a time and a place that allows and encourages public attendance and participation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd846c17-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Senior citizens","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A unit of general local government holding a hearing required under this subsection or by the budget process of the government shall try to provide senior citizens and senior citizen organizations with an opportunity to present views at the hearing before the government makes a final decision on the use of the payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd846c18-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure of Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd846c19-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"By the 10th day before a hearing required under subsection (a)(1) is held, a unit of general local government shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd846c1a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available for inspection by the public at the principal office of the government a statement of the proposed use of the payment and a summary of the proposed budget of the government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd846c1b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish in at least one newspaper of general circulation the proposed use of the payment with the summary of the proposed budget and a notice of the time and place of the hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd846c1c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"By the 30th day after adoption of the budget under State or local law, the government shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd846c1d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available for inspection by the public at the principal office of the government a summary of the adopted budget, including the proposed use of the payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd846c1e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish in at least one newspaper of general circulation a notice that the information referred to in subparagraph (A) is available for inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd846c1f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waivers of Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A requirement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd846c20-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" under subsection (a)(1) may be waived if the budget process required under the applicable State or local law or charter provisions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd846c21-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures the opportunity for public attendance and participation contemplated by subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd846c22-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a hearing on the proposed use of a payment received under this chapter in relation to the entire budget of the government; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd846c23-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under subsection (b)(1)(B) and paragraph (2)(B) may be waived if the cost of publishing the information would be unreasonably burdensome in relation to the amount allocated to the government from amounts available for payment under this chapter, or if publication is otherwise impracticable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd846c24-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6710/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception to","children":[],"tail":" 10-"},{"tag":"inline","attrib":{},"text":"Day Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary is satisfied that a unit of general local government will provide adequate notice of the proposed use of a payment received under this chapter, the 10-day period under subsection (b)(1) may be changed to the extent necessary to comply with applicable State or local law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd846c25-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31001/a"},"text":"Pub. L. 103–322, title III, § 31001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1873"},"text":"108 Stat. 1873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd846c26-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd846c27-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd846c28-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6710, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1020"},"text":"96 Stat. 1020","children":[],"tail":", related to separate law enforcement officer allocations for Louisiana, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIV/s14001/a/1"},"text":"Pub. L. 99–272, title XIV, § 14001(a)(1)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/327"},"text":"100 Stat. 327","children":[],"tail":", 329, eff. "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
