{"tag":"section","attrib":{"id":"idbd86b55e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6715"},"text":null,"children":[{"tag":"num","attrib":{"value":"6715"},"text":"§ 6715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by the Attorney General of prohibitions on discrimination","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General may bring a civil action in an appropriate district court of the United States against a unit of general local government that the Attorney General has reason to believe has engaged or is engaging in a pattern or practice in violation of section 6711(a) or (b). The court may grant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd86b55f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6715/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a temporary restraining order;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b560-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6715/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an injunction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b561-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6715/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate order to ensure enjoyment of rights under section 6711(a) or (b), including an order suspending, terminating, or requiring repayment of, payments under this chapter or placing additional payments under this chapter in escrow pending the outcome of the action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd86b562-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tIII/s31001/a"},"text":"Pub. L. 103–322, title III, § 31001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1877"},"text":"108 Stat. 1877","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd86b563-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd86b564-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbd86b565-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 6715, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1024"},"text":"96 Stat. 1024","children":[],"tail":", related to prohibition on using payments to influence legislation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/99/272/tXIV/s14001/a/1"},"text":"Pub. L. 99–272, title XIV, § 14001(a)(1)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1986-04-07"},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/327"},"text":"100 Stat. 327","children":[],"tail":", 329, eff. "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
