{"tag":"section","attrib":{"id":"idbd7fb088-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501"},"text":null,"children":[{"tag":"num","attrib":{"value":"6501"},"text":"§ 6501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7fb089-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “assistance” means the transfer of anything of value for a public purpose of support or stimulation that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7fb08a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized by a law of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fb08b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided by the United States Government through grant or contractual arrangements (including technical assistance programs providing assistance by loan, loan guarantee, or insurance); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fb08c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not an annual payment by the United States Government to the District of Columbia government under section 502 of the District of Columbia Home Rule Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/198"},"text":"Public Law 93–198","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/813"},"text":"87 Stat. 813","children":[],"tail":", D.C. Code, § 47–3406)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb08d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “comprehensive planning” includes, to the extent directly related to area needs or needs of a unit of general local government—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7fb08e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" preparation, as a guide for governmental policies and action, of general plans on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd7fb08f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pattern and intensity of land use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd7fb090-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing public facilities (including transportation facilities) and other governmental services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd7fb091-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective development and use of human and natural resources;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fb092-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long-range physical and fiscal plans for an action referred to in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fb093-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a program for capital improvements and other major expenditures based on their relative urgency, and definitive financing plans for the expenditures in the earlier years of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fb094-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination of related plans and activities of States and local governments and agencies concerned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fb095-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation of regulatory and administrative measures to support the items referred to in subparagraphs (A), (B), (C), and (D).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb096-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “executive agency” does not include a mixed-ownership Government corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb097-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd7fb098-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “grant” (except as provided in subparagraph (C)) means money, or property provided instead of money, that is paid or provided by the United States Government under a fixed annual or total authorization, to a State, to a local government, or to a beneficiary under a plan or program administered by a State or a local government that is subject to approval by an executive agency, if the authorization—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd7fb099-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires the State or local government to expend non-Government money as a condition of receiving money or property from the United States Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd7fb09a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifies directly, or establishes by means of a formula, the amount that may be provided to the State or local government, or the amount to be allotted for use in each State by the State, local government, and beneficiaries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fb09b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “grant” (except as provided in subparagraph (C)) also means money, or property provided instead of money, that is paid or provided by the United States Government to a private, nonprofit community organization eligible to receive amounts under the Community Services Block Grant Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9901"},"text":"42 U.S.C. 9901","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd7fb09c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “grant” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd7fb09d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shared revenue;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd7fb09e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of taxes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd7fb09f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/4/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment instead of taxes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd7fb0a0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/4/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan or repayable advance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd7fb0a1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/4/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" surplus property or surplus agricultural commodities provided as surplus property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd7fb0a2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/4/C/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment under a research and development procurement contract or grant awarded directly and on similar terms to all qualifying organizations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd7fb0a3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/4/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a payment to a State or local government as complete reimbursement for costs incurred in paying benefits or providing services to persons entitled to them under a law of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb0a4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “head of a State agency” includes the designated delegate of the head of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb0a5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “local government” means a unit of general local government, a school district, or other special district established under State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb0a6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb0a7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “special-purpose unit of local government” means a special district, public-purpose local government of a State except a school district.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb0a8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State of the United States, the District of Columbia, a territory or possession of the United States, and an agency, instrumentality, or fiscal agent of a State but does not mean a local government of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7fb0a9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6501/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “unit of general local government” means a county, city, town, village, or other general purpose political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7fb0aa-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1005"},"text":"96 Stat. 1005","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/452/s1/24"},"text":"Pub. L. 97–452, § 1(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2478"},"text":"96 Stat. 2478","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/453"},"text":"Pub. L. 101–453","children":[],"tail":", §§ 3, 5(a), "},{"tag":"date","attrib":{"date":"1990-10-24"},"text":"Oct. 24, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1058"},"text":"104 Stat. 1058","children":[],"tail":", 1059; "},{"tag":"ref","attrib":{"href":"/us/pl/105/33/tXI/s11717/b"},"text":"Pub. L. 105–33, title XI, § 11717(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-08-05"},"text":"Aug. 5, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/786"},"text":"111 Stat. 786","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7fb0ab-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd7fb0ac-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd7fb0ad-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attr