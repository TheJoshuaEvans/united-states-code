{"tag":"section","attrib":{"id":"idbd48c229-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806"},"text":null,"children":[{"tag":"num","attrib":{"value":"3806"},"text":"§ 3806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Collection of civil penalties and assessments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd48c22a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall be responsible for judicial enforcement of any civil penalty or assessment imposed pursuant to the provisions of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd48c22b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any penalty or assessment imposed in a determination which has become final pursuant to this chapter may be recovered in a civil action brought by the Attorney General. In any such action, no matter that was raised or that could have been raised in a hearing conducted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803/f"},"text":"section 3803(f) of this title","children":[],"tail":" or pursuant to judicial review under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3805"},"text":"section 3805 of this title","children":[],"tail":" may be raised as a defense, and the determination of liability and the determination of amounts of penalties and assessments shall not be subject to review."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd48c22c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The district courts of the United States shall have jurisdiction of any action commenced by the United States under subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd48c22d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any action under subsection (b) of this section may, without regard to venue requirements, be joined and consolidated with or asserted as a counterclaim, cross-claim, or setoff by the United States in any other civil action which includes as parties the United States and the person against whom such action may be brought.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd48c22e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Court of Federal Claims shall have jurisdiction of any action under subsection (b) of this section to recover any penalty or assessment if the cause of action is asserted by the United States as a counterclaim in a matter pending in such court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd48c22f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall have exclusive authority to compromise or settle any penalty or assessment the determination of which is the subject of a pending petition pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3805"},"text":"section 3805 of this title","children":[],"tail":" or a pending action to recover such penalty or assessment pursuant to this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd48c230-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd48c231-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd48c232-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd48c233-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amount collected under this chapter shall be credited first to reimburse the authority or other Federal entity that expended costs in support of the investigation or prosecution of the action, including any court or hearing costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd48c234-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" amounts reimbursed under clause (i) shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd48c235-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be deposited in—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idbd48c236-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/1/A/ii/I/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriations account of the authority or other Federal entity from which the costs described in subparagraph (A) were obligated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbd48c237-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/1/A/ii/I/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a similar appropriations account of the authority or other Federal entity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idbd48c238-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/1/A/ii/I/cc"},"text":null,"children":[{"tag":"num","attrib":{"value":"cc"},"text":"(cc)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the authority or other Federal entity expended nonappropriated funds, another appropriate account; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd48c239-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd48c23a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount remaining after reimbursements described in subparagraph (A) shall be deposited as miscellaneous receipts in the Treasury of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd48c23b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd48c23c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount of a penalty or assessment imposed by the United States Postal Service under this chapter shall be deposited in the Postal Service Fund established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t39/s2003"},"text":"section 2003 of title 39","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd48c23d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount of a penalty or assessment imposed by the Secretary of Health and Human Services under this chapter with respect to a claim or statement made in connection with old age and survivors benefits under title II of the Social Security Act shall be deposited in the Federal Old-Age and Survivors Insurance Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd48c23e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount of a penalty or assessment imposed by the Secretary of Health and Human Services under this chapter with respect to a claim or statement made in connection with disability benefits under title II of the Social Security Act shall be deposited in the Federal Disability Insurance Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd48c23f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount of a penalty or assessment imposed by the Secretary of Health and Human Services under this chapter with respect to a claim or statement made in connection with benefits under part A of title XVIII of the Social Security Act shall be deposited in the Federal Hospital Insurance Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd48c240-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3806/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any amount of a penalty or assessment imposed by the Secretary of Health and Human Services under this chapter with respect to a claim or statement made in connection with benefits under part B of title XVIII of the Social Security Act shall be deposited in the Federal Supplementary Medical Insurance Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd48c241-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVI/s6103/a"},"text":"Pub. L. 99–509, title VI, § 6103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1945"},"text":"100 Stat. 1945","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/tIX/s902/b/1"},"text":"Pub. L. 102–572, title IX, § 902(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4516"},"text":"106 Stat. 4516","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLII/s5203/d"},"text":"Pub. L. 118–159, div. E, title LII, § 5203(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2440"},"text":"138 Stat. 2440","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd48c242-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd48c243-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd48c244-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Social Security Act, referred to in subsec. (g)(2)(B) to (E), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-14/ch531"},"text":"act Aug. 14, 1935, ch. 531","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/620"},"text":"49 Stat. 620","children":[],"tail":". Title II and parts A and B of title XVIII of the Social Security Act are classified generally to subchapter II (§ 401 et seq.) and parts A (§ 1395c et seq.) and B (§ 1395j et seq.) of subchapter XVIII, respectively, of chapter 7 of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s1305"},"text":"section 1305 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd48c245-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159"},"text":"Pub. L. 118–159","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “Except as provided in paragraph (2) of this subsection, any amount of penalty or assessment collected under this chapter shall be deposited as miscellaneous receipts in the Treasury of the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" substituted “United States Court of Federal Claims” for “United States Claims Court”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd48c246-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd48c247-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1992 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/572"},"text":"Pub. L. 102–572","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1992-10-29"},"text":"Oct. 29, 1992","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/572/s911"},"text":"section 911 of Pub. L. 102–572","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
