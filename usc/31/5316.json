{"tag":"section","attrib":{"id":"idbd657154-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316"},"text":null,"children":[{"tag":"num","attrib":{"value":"5316"},"text":"§ 5316.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on exporting and importing monetary instruments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd657155-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (c) of this section, a person or an agent or bailee of the person shall file a report under subsection (b) of this section when the person, agent, or bailee knowingly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd657156-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transports, is about to transport, or has transported, monetary instruments of more than $10,000 at one time—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd657157-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from a place in the United States to or through a place outside the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd657158-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a place in the United States from or through a place outside the United States; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd657159-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives monetary instruments of more than $10,000 at one time transported into the United States from or through a place outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd65715a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A report under this section shall be filed at the time and place the Secretary of the Treasury prescribes. The report shall contain the following information to the extent the Secretary prescribes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd65715b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the legal capacity in which the person filing the report is acting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd65715c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the origin, destination, and route of the monetary instruments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd65715d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the monetary instruments are not legally and beneficially owned by the person transporting the instruments, or if the person transporting the instruments personally is not going to use them, the identity of the person that gave the instruments to the person transporting them, the identity of the person who is to receive them, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd65715e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount and kind of monetary instruments transported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd65715f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd657160-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section or a regulation under this section does not apply to a common carrier of passengers when a passenger possesses a monetary instrument, or to a common carrier of goods if the shipper does not declare the instrument.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd657161-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5316/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cumulation of Closely Related Events","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury may prescribe regulations under this section defining the term “at one time” for purposes of subsection (a). Such regulations may permit the cumulation of closely related events in order that such events may collectively be considered to occur at one time for the purposes of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd657162-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/998"},"text":"96 Stat. 998","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/473/tII/s901/c"},"text":"Pub. L. 98–473, title II, § 901(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-12"},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2135"},"text":"98 Stat. 2135","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tI/s1358"},"text":"Pub. L. 99–570, title I, § 1358","children":[],"tail":", title III, § 3153, "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-26"},"text":"100 Stat. 3207–26","children":[],"tail":", 3207–94.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd657163-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd657164-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd657165-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5316(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1101(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/508/s231"},"text":"Pub. L. 91–508, § 231","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1122"},"text":"84 Stat. 1122","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5316(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1101(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5316(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1101(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “a person or an agent or bailee of the person shall” are substituted for “whoever, whether as principal, agent, or bailee, or by an agent or bailee” for consistency. The words “or reports” are omitted as unnecessary because of 1:1. In clause (2), the words “transported into the United States” are substituted for “at the termination of their transportation to the United States” for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the word “required” is omitted as surplus. The word “prescribes” is substituted for “require” for consistency in the revised title and with other titles of the United States Code. The words “to the extent” are substituted for “in such detail” for clarity. In clause (1), the words “with respect to the monetary instruments transported” are omitted as surplus. In clause (3), the words “or if the person transporting the instruments personally is not going to use them” are substituted for “or are transported for any purpose other than the use in his own behalf of the person transporting the same” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “or a regulation under this section” are added because of the restatement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd657166-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd657167-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s1358/b"},"text":"Pub. L. 99–570, § 1358(b)","children":[],"tail":", substituted “transports, is about to transport, or has transported” for “transports or has transported, or attempts to transport or have transported”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":", §§ 1358(c), 3153, made identical amendments substituting “$10,000” for “$5,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s1358/a"},"text":"Pub. L. 99–570, § 1358(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/473"},"text":"Pub. L. 98–473","children":[],"tail":" inserted “, or attempts to transport or have transported,” after “transports or has transported” and substituted “$10,000” for “$5,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd657168-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd657169-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Regulations Prescribed Under 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/tI/s1364/d"},"text":"Pub. L. 99–570, title I, § 1364(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-34"},"text":"100 Stat. 3207–34","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/570/tI/s1364/d"},"text":"“Any regulation prescribed under the amendments made by section 1358 [amending this section] shall apply with respect to transactions completed after the effective date of such regulation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
