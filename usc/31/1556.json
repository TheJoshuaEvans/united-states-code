tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:703(b)(1st sentence words after 4th comma, last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the word “President” is substituted for “Director of the Office of Management and Budget” because sections 101 and 102(a) of Reorganization Plan No. 2 of 1970 (eff. ","children":[{"tag":"date","attrib":{"date":"1970-07-01"},"text":"July 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2085"},"text":"84 Stat. 2085","children":[],"tail":") designated the Bureau of the Budget as the Office of Management and Budget and transferred all functions of the Bureau to the President."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd16b512-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd16b513-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" substituted “General: reports” for “General reports” in section catchline and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) In carrying out audit responsibilities, the Comptroller General shall report on operations under this subchapter to—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the head of the agency concerned;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the Secretary of the Treasury; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) the President.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) A report under this section shall include an appraisal of unpaid obligations under appropriation accounts established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1552"},"text":"section 1552 of this title","children":[],"tail":". By the 30th day after receiving a report, the head of the agency concerned shall carry out actions required by "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1554"},"text":"section 1554 of this title","children":[],"tail":" that the report shows is necessary.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd16b514-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd16b515-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" applicable to any appropriation account the obligated balance of which, on "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", has not been transferred under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1552/a/1"},"text":"section 1552(a)(1) of this title","children":[],"tail":", as in effect "},{"tag":"date","attrib":{"date":"1990-11-04"},"text":"Nov. 4, 1990","children":[],"tail":", with transitional provisions, see "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1405/b"},"text":"section 1405(b) of Pub. L. 101–510","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1551"},"text":"section 1551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
