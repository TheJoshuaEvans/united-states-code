{"tag":"section","attrib":{"id":"idbd7d3fcd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6206"},"text":null,"children":[{"tag":"num","attrib":{"value":"6206"},"text":"§ 6206.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Data consistency and uniformity of data elements","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director shall designate a single organizational unit to provide for data consistency and uniform reporting of data elements.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd7d3fce-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/547/s2/a"},"text":"Pub. L. 99–547, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3059"},"text":"100 Stat. 3059","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
