{"tag":"section","attrib":{"id":"idbd085dac-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1308"},"text":null,"children":[{"tag":"num","attrib":{"value":"1308"},"text":"§ 1308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telephone and metered services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Charges for telephone and metered services (such as gas, electricity, water, and steam) for a time period beginning in one fiscal year or allotment period and ending in another fiscal year or allotment period may be charged against the appropriation or allotment current at the end of the time period covered by the service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd085dad-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/919"},"text":"96 Stat. 919","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd085dae-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd085daf-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd085db0-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1308","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:668a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1937-04-27/ch143"},"text":"Apr. 27, 1937, ch. 143","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/50/119"},"text":"50 Stat. 119","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1939-04-26/ch103"},"text":"Apr. 26, 1939, ch. 103","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/624"},"text":"53 Stat. 624","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “On and after ","children":[{"tag":"date","attrib":{"date":"1937-04-27"},"text":"April 27, 1937","children":[],"tail":"” are omitted as executed. The words “Charges for telephone and metered services” are substituted for “in making payments for commodities or services the quantity of which is determined by metered readings . . . and for telephone services” to eliminate unnecessary words. The words “another fiscal year or allotment period” are substituted for “another”, and the words “time period covered by the service” are substituted for “such period”, for clarity."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
