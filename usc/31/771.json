{"tag":"section","attrib":{"id":"idbcf54b1f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s771"},"text":null,"children":[{"tag":"num","attrib":{"value":"771"},"text":"§ 771.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf54b20-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s771/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “dependent child” means an unmarried dependent child (including a stepchild or adopted child) who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf54b21-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s771/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under 18 years of age;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf54b22-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s771/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incapable of self-support because of physical or mental disability; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf54b23-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s771/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between 18 and 22 years of age and is a student regularly pursuing a full-time course of study or training in residence in a high school, trade school, technical or vocational institute, junior college, college, university, or comparable recognized educational institution. For the purposes of this subchapter, a child whose 22nd birthday occurs before July 1 or after August 31 of a calendar year, and while such child is regularly pursuing such a course of study or training, is deemed to have become 22 years of age on the first day of July after that birthday. A child who is a student is deemed not to have ceased to be a student during an interim period between school years if the interim period is not more than 5 months and if such child shows to the satisfaction of the General Counsel of the Government Accountability Office that such child has a bona fide intention of continuing in the same or a different school during the school semester (or other period into which the school year is divided) immediately after the interim period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54b24-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s771/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “surviving spouse” means a surviving spouse of an individual who was a Comptroller General or retired Comptroller General and the spouse—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf54b25-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s771/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was married to the individual for at least 1 year immediately before the individual died; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf54b26-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s771/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not remarried before age 55 and is the parent of issue by the marriage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54b27-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s771/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service as a Comptroller General equals the number of years and complete months an individual is Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf54b28-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/902"},"text":"96 Stat. 902","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/426/tII/s202"},"text":"Pub. L. 100–426, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1600"},"text":"102 Stat. 1600","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf54b29-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcf54b2a-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbcf54b2b-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attr