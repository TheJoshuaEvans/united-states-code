{"tag":"section","attrib":{"id":"idbd202bfc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3304"},"text":null,"children":[{"tag":"num","attrib":{"value":"3304"},"text":"§ 3304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of public money from depositaries","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of the Treasury may transfer public money in the possession of a depositary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd202bfd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3304/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the Treasury; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd202bfe-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3304/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary believes the safety of the public money and convenience require it, to another depositary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd202bff-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/949"},"text":"96 Stat. 949","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd202c00-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd202c01-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd202c02-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n"