{"tag":"section","attrib":{"id":"idbd16b51f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1558"},"text":null,"children":[{"tag":"num","attrib":{"value":"1558"},"text":"§ 1558.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability of funds following resolution of a formal protest or other challenge","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd16b520-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1558/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1552"},"text":"section 1552 of this title","children":[],"tail":" or any other provision of law, funds available to an agency for obligation for a contract at the time a protest or other action referred to in subsection (b) is filed in connection with a solicitation for, proposed award of, or award of such contract shall remain available for obligation for 100 days after the date on which the final ruling is made on the protest or other action. A ruling is considered final on the date on which the time allowed for filing an appeal or request for reconsideration has expired, or the date on which a decision is rendered on such an appeal or request, whichever is later."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd16b521-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1558/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) applies with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd16b522-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1558/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any protest filed under subchapter V of chapter 35 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd16b523-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1558/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an action commenced under administrative procedures or for a judicial remedy if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd16b524-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1558/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the action involves a challenge to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd16b525-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1558/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a solicitation for a contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd16b526-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1558/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposed award of a contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd16b527-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1558/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an award of a contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd16b528-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1558/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibility of an offeror or potential offeror for a contract or of the contractor awarded the contract; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd16b529-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1558/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commencement of the action delays or prevents an executive agency from making an award of a contract or proceeding with a procurement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd16b52a-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tVIII/s813/a"},"text":"Pub. L. 101–189, div. A, title VIII, § 813(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1494"},"text":"103 Stat. 1494","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dE/tLV/s5502/a"},"text":"Pub. L. 104–106, div. E, title LV, § 5502(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/698"},"text":"110 Stat. 698","children":[],"tail":", 699.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd16b52b-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd16b52c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd16b52d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s5502/b"},"text":"Pub. L. 104–106, § 5502(b)","children":[],"tail":", substituted “of a formal protest or other challenge” for “of a protest” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s5502/a/1"},"text":"Pub. L. 104–106, § 5502(a)(1)","children":[],"tail":", inserted “or other action referred to in subsection (b)” after “time a protest”, substituted “100 days” for “90 working days”, and inserted “or other action” after “on the protest”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s5502/a/2"},"text":"Pub. L. 104–106, § 5502(a)(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which read as follows: “Subsection (a) applies with respect to any protest filed under subchapter V of chapter 35 of this title or under section 111(f) of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s759/f"},"text":"40 U.S.C. 759(f)","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd16b52e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd16b52f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" effective 180 d