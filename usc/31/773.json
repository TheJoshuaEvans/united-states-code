{"tag":"section","attrib":{"id":"idbcf54b46-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s773"},"text":null,"children":[{"tag":"num","attrib":{"value":"773"},"text":"§ 773.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of survivor benefits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf54b47-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s773/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide survivor benefits, a Comptroller General may elect in writing to reduce the pay and annuity of the Comptroller General. An election shall be made within 6 months of taking office or, if an election is made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s772/c"},"text":"section 772(c) of this title","children":[],"tail":", by the 60th day after making an election under section 772(c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf54b48-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s773/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A Comptroller General electing to provide survivor benefits shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf54b49-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s773/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have 4.5 percent of the pay received as Comptroller General and 5 percent of the annuity of the Comptroller General deducted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54b4a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s773/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" deposit with the Government Accountability Office for redeposit in the Treasury as miscellaneous receipts—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf54b4b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s773/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4.5 percent of the pay and annuity received as Comptroller General before the deductions begin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf54b4c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s773/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4.5 percent of basic pay received as a member of Congress or for other civilian service on which a surviving spouse’s annuity is computed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s774/d"},"text":"section 774(d) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf54b4d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s773/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 percent interest before ","children":[{"tag":"date","attrib":{"date":"1948-01-01"},"text":"January 1, 1948","children":[],"tail":", and 3 percent interest after "},{"tag":"date","attrib":{"date":"1947-12-31"},"text":"December 31, 1947","children":[],"tail":", compounded every December 31, on amounts deposited."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf54b4e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s773/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subchapter does not prevent a surviving spouse or dependent child from receiving another annuity while receiving an annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s774"},"text":"section 774 of this title","children":[],"tail":". However, service used in computing an annuity under section 774 may not be used in computing the other annuity."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf54b4f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s773/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The reduction in the Comptroller General’s annuity under subsection (b)(1) for the purpose of providing survivor benefits shall be terminated for each full month after the death of the spouse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf54b50-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/903"},"text":"96 Stat. 903","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/426/tII/s204"},"text":"Pub. L. 100–426, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1600"},"text":"102 Stat. 1600","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf54b51-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcf54b52-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbcf54b53-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"773(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43b(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18"},"text":"June 10, 1921, ch. 18","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/42/20"},"text":"42 Stat. 20","children":[],"tail":", § 319(a); added "},{"tag":"html:span","attrib":{},"text":"July 13, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/87"},"text":"Pub. L. 86–87","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/197"},"text":"73 Stat. 197","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 26, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/520/s2"},"text":"Pub. L. 89–520, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/329"},"text":"80 Stat. 329","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"773(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43b(b), (c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18"},"text":"June 10, 1921, ch. 18","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/42/20"},"text":"42 Stat. 20","children":[],"tail":", § 319(b), (c); added "},{"tag":"html:span","attrib":{},"text":"July 13, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/87"},"text":"Pub. L. 86–87","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/197"},"text":"73 Stat. 197","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/512/s2/1"},"text":"Pub. L. 95–512, § 2(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1799"},"text":"92 Stat. 1799","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"773(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43b(q).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18"},"text":"June 10, 1921, ch. 18","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/42/20"},"text":"42 Stat. 20","children":[],"tail":", § 319(q); added "},{"tag":"html:span","attrib":{},"text":"July 13, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/87"},"text":"Pub. L. 86–87","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/200"},"text":"73 Stat. 200","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the word “pay” is substituted for “salary”, and the word “annuity” is substituted for “retirement pay”, for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “To provide” are substituted for “for purposes of” for clarity. The words “or in the case of the Comptroller General currently in office and any retired Comptroller General, within six months after ","children":[{"tag":"date","attrib":{"date":"1959-07-13"},"text":"July 13, 1959","children":[],"tail":"” are omitted as executed. The words “as hereinafter provided” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “of the United States” are omitted as surplus. The words “or retired Comptroller General” are omitted as executed. The word “provide” is substituted for “receive” for clarity and consistency. In clause (2), before subclause (A), the word “redeposit” is substituted for “covering” for clarity. The words “the general fund of” and “a sum equal to” are omitted as surplus. In subclause (A), the words “the date current . . . from his salary and retirement pay” and 31:43b(c)(last sentence) are omitted as surplus. In subclause (B), the words “salary . . . or compensation for service” are omitted as surplus. The words “member of Congress” are substituted for “Senator, Representative, Delegate, or Resident Commissioner in the Congress of the United States” for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “be construed to” and “eligible therefore” are omitted as surplus. The words “receiving another annuity while” are substituted for “simultaneously . . . and any annuity . . . to which she would otherwise be entitled under any other law” to eliminate unnecessary words. The words “(including old age and survivor benefits)” and “without regard to this section” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf54b54-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf54b55-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426/s204/1"},"text":"Pub. L. 100–426, § 204(1)","children":[],"tail":", inserted “5 percent of the” before “annuity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426/s204/2"},"text":"Pub. L. 100–426, § 204(2)","children":[],"tail":", substituted “3 percent” for “4.5 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426/s204/3"},"text":"Pub. L. 100–426, § 204(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf54b56-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf54b57-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426"},"text":"Pub. L. 100–426","children":[],"tail":" effective after end of 60-day period beginning "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/426/s208"},"text":"section 208 of Pub. L. 100–426","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s772"},"text":"section 772 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
