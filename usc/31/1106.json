{"tag":"section","attrib":{"id":"idbcfee738-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1106"},"text":null,"children":[{"tag":"num","attrib":{"value":"1106"},"text":"§ 1106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Supplemental budget estimates and changes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcfee739-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Before July 16 of each year, the President shall submit to Congress a supplemental summary of the budget for the fiscal year for which the budget is submitted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105/a"},"text":"section 1105(a) of this title","children":[],"tail":". The summary shall include—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcfee73a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for that fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcfee73b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1106/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial changes in or reappraisals of estimates of expenditures and receipts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfee73c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1106/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantial obligations imposed on the budget after its submission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfee73d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1106/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" current information on matters referred to in section 1105(a)(8) and (9)(B) and (C) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfee73e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1106/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional information the President decides is advisable to provide Congress with complete and current information about the budget and current estimates of the functions, obligations, requirements, and financial condition of the United States Government;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcfee73f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the 4 fiscal years following the fiscal year for which the budget is submitted, information on estimated expenditures for programs authorized to continue in future years, or that are considered mandatory, under law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcfee740-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for future fiscal years, information on estimated expenditures of balances carried over from the fiscal year for which the budget is submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcfee741-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before July 16 of each year, the President shall submit to Congress a statement of changes in budget authority requested, estimated budget outlays, and estimated receipts for the fiscal year for which the budget is submitted (including prior changes proposed for the executive branch of the Government) that the President decides are necessary and appropriate based on current information. The statement shall include the effect of those changes on the information submitted under section 1105(a)(1)–(14) and (b) of this title and shall include supporting information as practicable. The statement submitted before July 16 may be included in the information submitted under subsection (a)(1) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcfee742-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (f) of section 1105 shall apply to revisions and supplemental summaries submitted under this section to the same extent that such subsection applies to the budget submitted under section 1105(a) to which such revisions and summaries relate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcfee743-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/911"},"text":"96 Stat. 911","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/177/tII/s242"},"text":"Pub. L. 99–177, title II, § 242","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1063"},"text":"99 Stat. 1063","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcfee744-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcfee745-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbcfee746-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1106(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:11(b), (c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18"},"text":"June 10, 1921, ch. 18","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/42/20"},"text":"42 Stat. 20","children":[],"tail":", § 201(b), (c); added "},{"tag":"html:span","attrib":{},"text":"Aug. 25, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/759/s1"},"text":"Pub. L. 85–759, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/852"},"text":"72 Stat. 852","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/510/s221/b"},"text":"Pub. L. 91–510, § 221(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1169"},"text":"84 Stat. 1169","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/344/s602"},"text":"Pub. L. 93–344, § 602","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/324"},"text":"88 Stat. 324","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1106(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:11(g)(1st–3d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18"},"text":"June 10, 1921, ch. 18","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/42/20"},"text":"42 Stat. 20","children":[],"tail":", § 201(g)(1st–3d sentences); added "},{"tag":"html:span","attrib":{},"text":"July 12, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/344/s601"},"text":"Pub. L. 93–344, § 601","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/323"},"text":"88 Stat. 323","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “Before July 16” are substituted for “on or before July 15” for consistency. The words “budget for the fiscal year for which the budget is submitted” are substituted for “Budget for the ensuing fiscal year transmitted to the Congress by the President” to eliminate unnecessary words and for consistency in the chapter. The words “in such form and detail as he may determine” are omitted as unnecessary. In clause (1)(D), the words “in summary form” and “summary of” are omitted as unnecessary. The word “necessary” is omitted as being included in “advisable”. In clauses (2) and (3), the word “information” is substituted for “summaries” because of the restatement. In clause (2), the words “programs authorized to continue in future years, or that are considered mandatory, under law” are substituted for “continuing programs which have a legal commitment for future years or are considered mandatory under existing law” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Before April 11 and July 16” are substituted for “on or before April 10 and July 15”, the word “changes” is substituted for “all amendments to or revisions in”, and the words “budget outlays” are substituted for “outlays”, the words “fiscal year for which the budget is submitted” are substituted for “ensuing fiscal year set forth in the Budget transmitted pursuant to subsection (a) of this section”, for consistency. The word “information” is substituted for “summary data” because of the restatement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcfee747-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcfee748-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1985—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177/s242/a"},"text":"Pub. L. 99–177, § 242(a)","children":[],"tail":", struck out “April 11 and” before “July 16”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177/s242/b"},"text":"Pub. L. 99–177, § 242(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcfee749-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcfee74a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-12-12"},"text":"Dec. 12, 1985","children":[],"tail":", and applicable with respect to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1985-09-30"},"text":"Sept. 30, 1985","children":[],"tail":", but with subsec. (c) to expire "},{"tag":"date","attrib":{"date":"2002-09-30"},"text":"Sept. 30, 2002","children":[],"tail":", see section 275(a)(1), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Pub. L. 99–177","children":[],"tail":", formerly set out as an Effective and Termination Dates note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s900"},"text":"section 900 of Title 2","children":[],"tail":", The Congress, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/112/25/tI/s104/a"},"text":"Pub. L. 112–25, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-08-02"},"text":"Aug. 2, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/246"},"text":"125 Stat. 246","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
