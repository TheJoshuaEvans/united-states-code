{"tag":"section","attrib":{"id":"idbd90527e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303"},"text":null,"children":[{"tag":"num","attrib":{"value":"9303"},"text":"§ 9303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of eligible obligations instead of surety bonds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd90527f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If a person is required under a law of the United States to give a surety bond, the person may give an eligible obligation as security instead of a surety bond. The obligation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd905280-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be given to the official having authority to approve the surety bond;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd905281-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as determined by the Secretary of the Treasury, have a market value that is equal to or greater than the amount of the required surety bond; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd905282-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the official receiving the obligation to collect or sell the obligation if the person defaults on a required condition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd905283-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd905284-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An official receiving an eligible obligation under subsection (a) of this section may deposit it with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd905285-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Treasury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd905286-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal reserve bank; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd905287-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a depositary designated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd905288-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, bank, or depositary shall issue a receipt that describes the obligation deposited.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd905289-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Using an eligible obligation instead of a surety bond for security is the same as using—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd90528a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a personal or corporate surety bond;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd90528b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certified check;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd90528c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bank draft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd90528d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a post office money order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd90528e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd90528f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When security is no longer required, an eligible obligation given instead of a surety bond shall be returned to the person giving the obligation. If a person, supplying labor or material to a contractor defaulting under sections 3131 and 3133 of title 40, files with the United States Government the application and affidavit provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3133/a"},"text":"section 3133(a) of title 40","children":[],"tail":", the Government—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd905290-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may return to the contractor the eligible obligation given as security (or proceeds of the eligible obligation given) under sections 3131 and 3133 of title 40 only after the 90-day period for bringing a civil action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3133/b"},"text":"section 3133(b) of title 40","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd905291-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a civil action is brought in the 90-day period, shall hold the eligible obligation or the proceeds subject to the order of the court having jurisdiction of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd905292-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section does not affect the—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd905293-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" priority of a claim of the Government against an eligible obligation given under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd905294-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" right or remedy of the Government for default on an obligation provided under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd905295-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 3131 and 3133 of title 40; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd905296-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd905297-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authority of a court over an eligible obligation given as security in a civil action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd905298-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authority of an official of the Government authorized by another law to receive an eligible obligation as security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd905299-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9303/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To avoid frequent substitution of eligible obligations, the Secretary may prescribe regulations limiting the effect of this section to an eligible obligation maturing more than one year after the date the obligation is given as security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd90529a-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1046"},"text":"96 Stat. 1046","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/h/9"},"text":"Pub. L. 107–217, § 3(h)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1300"},"text":"116 Stat. 1300","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/178/s4/f/2"},"text":"Pub. L. 108–178, § 4(f)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-15"},"text":"Dec. 15, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2641"},"text":"117 Stat. 2641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/351/tIX/s901/b"},"text":"Pub. L. 109–351, title IX, § 901(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2007"},"text":"120 Stat. 2007","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd90529b-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd90529c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd90529d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9303(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6:15(1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9303(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6:15(3d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9303(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6:15(2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9303(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6:15(4th, 5th sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9303(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6:15(6th, 8th sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9303(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6:15(7th, 9th, 11th sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “If a person is required under a law of the United States to give a surety bond, the person may give a Government obligation as security instead of a surety bond” are substituted for “Wherever by the laws of the United States or regulations made pursuant thereto, any person is required to furnish any recognizance, stipulation, bond, guaranty, or undertaking, hereinafter called ‘penal bond’, with surety or sureties, such person may, in lieu of such surety or sureties, deposit as security . . . United States Liberty bonds or other bonds or notes of the United States” to eliminate unnecessary words and for consistency. The words “The obligation shall be” are added because of the restatement. Clause (3) is substituted for “together with an agreement authorizing such official to collect or sell such bonds or notes so deposited in case of any default in the performance of any of the conditions or stipulations of such penal bond” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “An official receiving a Government obligation under subsection (a) of this section may deposit it with” are substituted for “The bonds or notes deposited hereunder, and such other United States bonds or notes as may be substituted therefor from time to time as such security, may be deposited with” for clarity and consistency and to eliminate unnecessary words. Clause (A) is substituted for “Treasurer of the United States” because of the source provisions restated in section 321(c) of the revised title. In clause (C), the words “duly” and “for that purpose” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(2) is substituted for “which shall issue receipt therefor, describing such bonds or notes so deposited” to eliminate unnecessary words and for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), before clause (1), the words “Using a Government obligation instead of a surety bond for security is the same as using” are substituted for “The acceptance of such United States bonds or notes in lieu of surety or sureties required by law shall have the same force and effect as” to eliminate unnecessary words and for consistency. In clause (1), the word “personal” is substituted for “individual” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) is substituted for 6:15(4th, 5th sentences) to eliminate unnecessary words and for consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), before clause (1), the words “This section does not” are substituted for “Nothing herein contained shall” for clarity and consistency. The words “or impair” are omitted as being covered by “affect”. Clause (1) is substituted for “the bonds or notes deposited” for clarity and consistency. In clause (2), the words “of said penal bond” are omitted because of the restatement. In clause (3), the words “civil action” are substituted for “judicial proceedings” for consistency. In clause (4), the word “official” is substituted for “administrative officer” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “in order” are omitted as unnecessary. The words “Government obligations” are substituted for “securities” and for “bonds and notes of the United States” for consistency. The words “the Secretary may prescribe regulations limiting” are substituted for “such rules and regulations may limit” for clarity and consistency. The words “in appropriate classes of cases” are omitted as unnecessary. The words “the obligation is given” are substituted for “of deposit of such bonds” for clarity and consistency. The text of 6:15(7th sentence) is omitted as executed. The text of 6:15(9th sentence) is omitted because of section 321 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd90529e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd90529f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s901/c/1"},"text":"Pub. L. 109–351, § 901(c)(1)","children":[],"tail":", substituted “eligible obligations” for “Government obligations” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s901/b"},"text":"Pub. L. 109–351, § 901(b)","children":[],"tail":", (c)(3), substituted “an eligible obligation” for “a Government obligation” in introductory provisions and amended par. (2) generally. Prior to amendment, par. (2) read as follows: “be in an amount equal at par value to the amount of the required surety bond; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s901/c/3"},"text":"Pub. L. 109–351, § 901(c)(3)","children":[],"tail":", (4), substituted “an eligible obligation” for “a Government obligation” and “the eligible obligation” for “the Government obligation” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/351/s901/c/2"},"text":"Pub. L. 109–351, § 901(c)(2)","children":[],"tail":", (3), substituted “eligible obligations” for “Government obligations” and “an eligible obligation” for “a Government obligation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/178"},"text":"Pub. L. 108–178","children":[],"tail":" struck out comma after “sections 3131 and 3133 of title 40”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/h/9/A"},"text":"Pub. L. 107–217, § 3(h)(9)(A)","children":[],"tail":", in introductory provisions substituted “sections 3131 and 3133 of title 40” for “the Act of "},{"tag":"date","attrib":{"date":"1935-08-24"},"text":"August 24, 1935","children":[],"tail":" (known as the Miller Act) ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s270a–270d"},"text":"40 U.S.C. 270a–270d","children":[],"tail":")” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3133/a"},"text":"section 3133(a) of title 40","children":[],"tail":"” for “section 3 of the Ac