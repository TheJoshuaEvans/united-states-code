{"tag":"section","attrib":{"id":"idbd8de098-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701"},"text":null,"children":[{"tag":"num","attrib":{"value":"7701"},"text":"§ 7701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Taxpayer identifying number","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd8de099-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd8de09a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “included Federal loan program” has the same meaning given that term in section 6103(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3)(C) of the Internal Revenue Code of 1986 ("},{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"26 U.S.C. 6103","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3)(C))."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8de09b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “taxpayer identifying number” means the identifying number required under section 6109 of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6109"},"text":"26 U.S.C. 6109","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd8de09c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of an agency administering an included Federal loan program shall require a person applying for a loan under the program to provide that person’s taxpayer identifying number.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd8de09d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd8de09e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each Federal agency shall require each person doing business with that agency to furnish to that agency such person’s taxpayer identifying number.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8de09f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this subsection, a person shall be considered to be doing business with a Federal agency if the person is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd8de0a0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lender or servicer in a Federal guaranteed or insured loan program administered by the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8de0a1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicant for, or recipient of, a Federal license, permit, right-of-way, grant, or benefit payment administered by the agency or insurance administered by the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8de0a2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contractor of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8de0a3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessed a fine, fee, royalty or penalty by the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8de0a4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a relationship with the agency that may give rise to a receivable due to that agency, such as a partner of a borrower in or a guarantor of a Federal direct or insured loan administered by the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8de0a5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each agency shall disclose to a person required to furnish a taxpayer identifying number under this subsection its intent to use such number for purposes of collecting and reporting on any delinquent amounts arising out of such person’s relationship with the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8de0a6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, a person shall not be treated as doing business with a Federal agency solely by reason of being a debtor under third party claims of the United States. The preceding sentence shall not apply to a debtor owing claims resulting from petroleum pricing violations or owing claims resulting from Federal loan or loan guarantee/insurance programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd8de0a7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7701/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a/b"},"text":"section 552a(b) of title 5","children":[],"tail":", United States Code, creditor agencies to which a delinquent claim is owed, and their agents, may match their debtor records with Department of Health and Human Services, and Department of Labor records to obtain names (including names of employees), name controls, names of employers, taxpayer identifying numbers, addresses (including addresses of employers), and dates of birth. The preceding sentence shall apply to the disclosure of taxpayer identifying numbers only if such disclosure is not otherwise prohibited by section 6103 of the Internal Revenue Code of 1986. The Department of Health and Human Services, and the Department of Labor shall release that information to creditor agencies and may charge reasonable fees sufficient to pay the costs associated with that release."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd8de0a8-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/f/1/Y/i"},"text":"Pub. L. 103–272, § 4(f)(1)(Y)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1363"},"text":"108 Stat. 1363","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/134/tIII/s31001/i/1"},"text":"Pub. L. 104–134, title III, § 31001(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1321-364"},"text":"110 Stat. 1321–364","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd8de0a9-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd8de0aa-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd8de0ab-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 6103 of the Internal Revenue Code of 1986, referred to in subsecs. (a)(1) and (d), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"section 6103 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd8de0ac-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134"},"text":"Pub. L. 104–134","children":[],"tail":" added subsecs. (c) and (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
