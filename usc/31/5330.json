{"tag":"section","attrib":{"id":"idbd6ee811-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330"},"text":null,"children":[{"tag":"num","attrib":{"value":"5330"},"text":"§ 5330.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of money transmitting businesses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd6ee812-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registration With Secretary of the Treasury Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6ee813-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who owns or controls a money transmitting business shall register the business (whether or not the business is licensed as a money transmitting business in any State) with the Secretary of the Treasury not later than the end of the 180-day period beginning on the later of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd6ee814-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date of enactment of the Money Laundering Suppression Act of 1994; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6ee815-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the business is established.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6ee816-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form and manner of registration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the requirements of subsection (b), the Secretary of the Treasury shall prescribe, by regulation, the form and manner for registering a money transmitting business pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6ee817-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Businesses remain subject to state law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall not be construed as superseding any requirement of State law relating to money transmitting businesses operating in such State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6ee818-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"False and incomplete information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The filing of false or materially incomplete information in connection with the registration of a money transmitting business shall be considered as a failure to comply with the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd6ee819-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Registration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The registration of a money transmitting business under subsection (a) shall include the following information:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6ee81a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name and location of the business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6ee81b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The name and address of each person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd6ee81c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns or controls the business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6ee81d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a director or officer of the business; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6ee81e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise participates in the conduct of the affairs of the business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6ee81f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name and address of any depository institution at which the business maintains a transaction account (as defined in section 19(b)(1)(C) of the Federal Reserve Act).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6ee820-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An estimate of the volume of business in the coming year (which shall be reported annually to the Secretary).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6ee821-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other information as the Secretary of the Treasury may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd6ee822-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agents of Money Transmitting Businesses.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6ee823-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of lists of agents of money transmitting businesses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pursuant to regulations which the Secretary of the Treasury shall prescribe, each money transmitting business shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd6ee824-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a list containing the names and addresses of all persons authorized to act as an agent for such business in connection with activities described in subsection (d)(1)(A) and such other information about such agents as the Secretary may require; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6ee825-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the list and other information available on request to any appropriate law enforcement agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6ee826-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of agent as money transmitting business","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Treasury shall prescribe regulations establishing, on the basis of such criteria as the Secretary determines to be appropriate, a threshold point for treating an agent of a money transmitting business as a money transmitting business for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd6ee827-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6ee828-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Money transmitting business","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “money transmitting business” means any business other than the United States Postal Service which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd6ee829-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides check cashing, currency exchange, or money transmitting or remittance services, or issues or redeems money orders, travelers’ checks, and other similar instruments or any other person who engages as a business in the transmission of currency, funds, or value that substitutes for currency, including any person who engages as a business in an informal money transfer system or any network of people who engage as a business in facilitating the transfer of money domestically or internationally outside of the conventional financial institutions system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6ee82a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to file reports under section 5313; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6ee82b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a depository institution (as defined in section 5313(g)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6ee82c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Money transmitting service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “money transmitting service” includes accepting currency, funds, or value that substitutes for currency and transmitting the currency, funds, or value that substitutes for currency by any means, including through a financial agency or institution, a Federal reserve bank or other facility of the Board of Governors of the Federal Reserve System, or an electronic funds transfer network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd6ee82d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty for Failure To Comply With Registration Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6ee82e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who fails to comply with any requirement of this section or any regulation prescribed under this section shall be liable to the United States for a civil penalty of $5,000 for each such violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6ee82f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing violation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each day a violation described in paragraph (1) continues shall constitute a separate violation for purposes of such paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6ee830-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5330/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any penalty imposed under this subsection shall be assessed and collected by the Secretary of the Treasury in the manner provided in section 5321 and any such assessment shall be subject to the provisions of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd6ee831-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIV/s408/b"},"text":"Pub. L. 103–325, title IV, § 408(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2250"},"text":"108 Stat. 2250","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s359/b"},"text":"Pub. L. 107–56, title III, § 359(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/328"},"text":"115 Stat. 328","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dF/tLXI/s6102/d/2"},"text":"Pub. L. 116–283, div. F, title LXI, § 6102(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4553"},"text":"134 Stat. 4553","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd6ee832-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd6ee833-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd6ee834-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Money Laundering Suppression Act of 1994, referred to in subsec. (a)(1)(A), is the date of enactment of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325"},"text":"Pub. L. 103–325","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 19(b)(1)(C) of the Federal Reserve Act, referred to in subsec. (b)(3), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s461/b/1/C"},"text":"section 461(b)(1)(C) of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd6ee835-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s6102/d/2/A"},"text":"Pub. L. 116–283, § 6102(d)(2)(A)","children":[],"tail":", substituted “currency, funds, or value that substitutes for currency,” for “funds,” and “system;” for “system;;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s6102/d/2/B"},"text":"Pub. L. 116–283, § 6102(d)(2)(B)","children":[],"tail":", substituted “currency, funds, or value that substitutes for currency” for “currency or funds denominated in the currency of any country” after “accepting”, substituted “currency, funds, or value that substitutes for currency” for “currency or funds, or the value of the currency or funds,” after “transmitting the”, and inserted “, including” after “means”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" inserted before semicolon “or any other person who engages as a business in the transmission of funds, including any person who engages as a business in an informal money transfer system or any network of people who engage as a business in facilitating the transfer of money domestically or internationally outside of the conventional financial institutions system;”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd6ee836-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd6ee837-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings and Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIV/s408/a"},"text":"Pub. L. 103–325, title IV, § 408(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2249"},"text":"108 Stat. 2249","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/325/tIV/s408/a"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress hereby finds the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Money transmitting businesses are subject to the recordkeeping and reporting requirements of subchapter II of chapter 53 of title 31, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Money transmitting businesses are largely unregulated businesses and are frequently used in sophisticated schemes to—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer large amounts of money which are the proceeds of unlawful enterprises; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evade the requirements of such subchapter II, the Internal Revenue Code of 1986 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"26 U.S.C. 1","children":[],"tail":" et seq.], and other laws of the United States."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information on the identity of money transmitting businesses and the names of the persons who own or control, or are officers or employees of, a money transmitting business would have a high degree of usefulness in criminal, tax, or regulatory investigations and proceedings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the purpose of this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1960"},"text":"section 1960 of Title 18","children":[],"tail":", Crimes and Criminal Procedure] to establish a registration requirement for businesses engaged in providing check cashing, currency exchange, or money transmitting or remittance services, or issuing or redeeming money orders, travelers’ checks, and other similar instruments to assist the Secretary of the Treasury, the Attorney General, and other supervisory and law enforcement agencies to effectively enforce the criminal, tax, and regulatory laws and prevent such money transmitting businesses from engaging in illegal activities.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
