":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 305(related to disbursement); ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1894-07-31/ch174/s11"},"text":"July 31, 1894, ch. 174, § 11","children":[],"tail":"(last sentence related to § 305), "},{"tag":"html:a","attrib":{"href":"/us/stat/28/209"},"text":"28 Stat. 209","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3323(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:76(2d sentence words after 3d comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3323(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:76(3d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3323(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:44(1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:77.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3675.","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “Comptroller General” are substituted for “General Accounting Office” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is substituted for 31:76(2d sentence words before 3d comma) and 147(related to disbursement) to eliminate unnecessary words and for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “Secretary” is substituted for “Treasurer” because of the source provisions restated in section 321 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “instead of being specified on the warrant” are omitted as surplus. The reference to “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3526"},"text":"section 3526 of this title","children":[],"tail":"” is used because section 72, referred to in 31:76, has been omitted from the restatement superseded by 31:82i and 31:82i is restated in section 3526."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “depositing” is substituted for “covering” for clarity and consistency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
