{"tag":"section","attrib":{"id":"idbcf7bba7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s777"},"text":null,"children":[{"tag":"num","attrib":{"value":"777"},"text":"§ 777.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annuity increases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf7bba8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s777/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An annuity payable under this subchapter shall be increased at the same time that, and by the same percent as the percentage by which, annuities are increased under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8340/b"},"text":"section 8340(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7bba9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s777/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s772"},"text":"section 772 of this title","children":[],"tail":" may not be more than the basic pay of the Comptroller General. A surviving spouse’s annuity may be increased under this section without regard to any limitation set forth in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s774/e"},"text":"section 774(e) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf7bbaa-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/906"},"text":"96 Stat. 906","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/426/tII/s207"},"text":"Pub. L. 100–426, title II, § 207","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1601"},"text":"102 Stat. 1601","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf7bbab-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcf7bbac-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbcf7bbad-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"777(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43c(a)(words before colon), (1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18"},"text":"June 10, 1921, ch. 18","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/42/20"},"text":"42 Stat. 20","children":[],"tail":", § 320; added "},{"tag":"html:span","attrib":{},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/512/s3"},"text":"Pub. L. 95–512, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1799"},"text":"92 Stat. 1799","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"777(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43c(a)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"777(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43c(a)(3), (b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the text of 31:43c(a)(words before colon) is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “in any year” and “commencing” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “per centum” and “by the Comptroller General” are omitted as surplus. The words “Civil Service Commission” (subsequently changed to “Office of Personnel Management” because of section 101 of Reorganization Plan No. 2 of 1978 (eff. ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"Jan. 1, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/3783"},"text":"92 Stat. 3783","children":[],"tail":")) are omitted because of the restatement of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s8340/b"},"text":"section 8340(b) of title 5","children":[],"tail":" by section 1702(a) of the Omnibus Budget Reconciliation Act of 1981."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “by reason of the application of subsection (a) of this section” and “annual” are omitted as surplus. The words “basic pay” are substituted for “compensation” for consistency with other titles of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf7bbae-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf7bbaf-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426"},"text":"Pub. L. 100–426","children":[],"tail":" amended section generally. Prior to amendment, section read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) The Comptroller General shall compute—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) on January 1 of each year, or within a reasonable time after January 1, the percent change in the Consumer Price Index between June and December of the prior year; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) on July 1 of each year, or within a reasonable time after July 1, the percent change in the Index between June of the same year and December of the prior year.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) If a percent change computed under subsection (a)(1) of this section indicates a rise in the Index, an annuity payable under this subchapter and beginning before March 2 shall increase on March 1 by the percent change computed under subsection (a)(1), adjusted to the nearest .1 percent. If a percent change computed under subsection (a)(2) of this section indicates a rise in the Index, an annuity payable under this subchapter and beginning before September 2 shall increase on September 1 by the percent change computed under subsection (a)(2), adjusted to the nearest .1 percent.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c)(1) An increase under this section may not be more than an increase prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8340/b"},"text":"section 8340(b) of title 5","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) An annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s772"},"text":"section 772 of this title","children":[],"tail":" may not be more than the basic pay of the Comptroller General.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf7bbb0-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf7bbb1-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426"},"text":"Pub. L. 100–426","children":[],"tail":" effective after end of 60-day period beginning "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/426/s208"},"text":"section 208 of Pub. L. 100–426","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s772"},"text":"section 772 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
