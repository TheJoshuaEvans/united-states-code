{"tag":"section","attrib":{"id":"idbcf7bbd8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s783"},"text":null,"children":[{"tag":"num","attrib":{"value":"783"},"text":"§ 783.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rules and regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf7bbd9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s783/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General is authorized to make all needful rules and regulations for the Government of the General Accounting Office Building,","children":[{"tag":"ref","attrib":{"idref":"fn002025"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002025"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See Change of Name note below."}],"tail":" and to annex to such rules and regulations such reasonable penalties, within the limits prescribed in subsection (b), as will ensure their enforcement. Such rules and regulations shall be posted and kept posted in a conspicuous place on such Federal property."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7bbda-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s783/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Whoever shall violate any rule or regulation promulgated pursuant to subsection (a) shall be fined not more than $500 or imprisoned not more than 6 months, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf7bbdb-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/545/s1"},"text":"Pub. L. 100–545, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-28"},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2728"},"text":"102 Stat. 2728","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf7bbdc-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf7bbdd-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbcf7bbde-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"General Accounting Office redesignated Government Accountability Office. See ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8"},"text":"section 8 of Pub. L. 108–271","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s702"},"text":"section 702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
