{"tag":"section","attrib":{"id":"idbcebd4c2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s704"},"text":null,"children":[{"tag":"num","attrib":{"value":"704"},"text":"§ 704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcebd4c3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent applicable, all laws generally related to administering an agency apply to the Comptroller General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcebd4c4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A copy of a record and a transcript from a record or proceeding of the Comptroller General, that the Comptroller General or Deputy Comptroller General certifies under seal, shall be admitted as evidence with the same effect as a copy or transcript referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1733"},"text":"section 1733 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcebd4c5-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/889"},"text":"96 Stat. 889","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcebd4c6-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcebd4c7-47c4-11f1-bea6-82cea744851c"},"t