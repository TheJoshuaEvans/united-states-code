,"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:752(last par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1917-09-24/ch56"},"text":"Sept. 24, 1917, ch. 56","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/40/288"},"text":"40 Stat. 288","children":[],"tail":", § 1(last par.); added "},{"tag":"html:span","attrib":{},"text":"Dec. 24, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/595/s2/a"},"text":"Pub. L. 96–595, § 2(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/3465"},"text":"94 Stat. 3465","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “interest rate” are added for consistency in the chapter and with 26:405(b) and 409(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1b70f7-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd1b70f8-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 405(b) and 409(a) of the Internal Revenue Code of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s405/b"},"text":"26 U.S.C. 405(b)","children":[],"tail":", 409(a)), referred to in text, were repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s491/a"},"text":"Pub. L. 98–369, div. A, title IV, § 491(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/848"},"text":"98 Stat. 848","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Enactment of the Tax Reform Act of 1984, referred to in text, means the date of enactment of division A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd1b70f9-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" inserted “, as in effect before the enactment of the Tax Reform Act of 1984” after “("},{"tag":"ref","attrib":{"href":"/us/usc/t26/s405/b"},"text":"26 U.S.C. 405(b)","children":[],"tail":", 409(a))”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd1b70fa-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd1b70fb-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" applicable to obligations issued after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"Dec. 31, 1983","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s491/f/1"},"text":"section 491(f)(1) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s62"},"text":"section 62 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
