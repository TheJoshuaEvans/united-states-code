{"tag":"section","attrib":{"id":"idbd8b96f7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501"},"text":null,"children":[{"tag":"num","attrib":{"value":"7501"},"text":"§ 7501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd8b96f8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" As used in this chapter, the term—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd8b96f9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Comptroller General” means the Comptroller General of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b96fa-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Director” means the Director of the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b96fb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal agency” has the same meaning as the term “agency” in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551/1"},"text":"section 551(1) of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b96fc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal awards” means Federal financial assistance and Federal cost-reimbursement contracts that non-Federal entities receive directly from Federal awarding agencies or indirectly from pass-through entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b96fd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal financial assistance” means assistance that non-Federal entities receive or administer in the form of grants, loans, loan guarantees, property, cooperative agreements, interest subsidies, insurance, food commodities, direct appropriations, or other assistance, but does not include amounts received as reimbursement for services rendered to individuals in accordance with guidance issued by the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b96fe-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Federal program” means all Federal awards to a non-Federal entity assigned a single number in the Catalog of Federal Domestic Assistance or encompassed in a group of numbers or other category as defined by the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b96ff-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “generally accepted government auditing standards” means the government auditing standards issued by the Comptroller General;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b9700-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “independent auditor” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd8b9701-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an external State or local government auditor who meets the independence standards included in generally accepted government auditing standards; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8b9702-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public accountant who meets such independence standards;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b9703-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian tribe” means any Indian tribe, band, nation, or other organized group or community, including any Alaskan Native village or regional or village corporation (as defined in, or established under, the Alaskan Native Claims Settlement Act) that is recognized by the United States as eligible for the special programs and services provided by the United States to Indians because of their status as Indians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b9704-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “internal controls” means a process, effected by an entity’s management and other personnel, designed to provide reasonable assurance regarding the achievement of objectives in the following categories:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd8b9705-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Effectiveness and efficiency of operations.","children":[{"tag":"ref","attrib":{"idref":"fn002121"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002121"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8b9706-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reliability of financial reporting.","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8b9707-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compliance with applicable laws and regulations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b9708-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “local government” means any unit of local government within a State, including a county, borough, municipality, city, town, township, parish, local public authority, special district, school district, intrastate district, council of governments, any other instrumentality of local government and, in accordance with guidelines issued by the Director, a group of local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b9709-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “major program” means a Federal program identified in accordance with risk-based criteria prescribed by the Director under this chapter, subject to the limitations described under subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b970a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “non-Federal entity” means a State, local government, or nonprofit organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b970b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “nonprofit organization” means any corporation, trust, association, cooperative, or other organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd8b970c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is operated primarily for scientific, educational, service, charitable, or similar purposes in the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8b970d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not organized primarily for profit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8b970e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses net proceeds to maintain, improve, or expand the operations of the organization;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b970f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “pass-through entity” means a non-Federal entity that provides Federal awards to a subrecipient to carry out a Federal program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b9710-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “program-specific audit” means an audit of one Federal program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b9711-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “recipient” means a non-Federal entity that receives awards directly from a Federal agency to carry out a Federal program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b9712-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “single audit” means an audit, as described under section 7502(d), of a non-Federal entity that includes the entity’s financial statements and Federal awards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b9713-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means any State of the United States, the District of Columbia, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, American Samoa, the Commonwealth of the Northern Mariana Islands, and the Trust Territory of the Pacific Islands, any instrumentality thereof, any multi-State, regional, or interstate entity which has governmental functions, and any Indian tribe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b9714-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/a/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “subrecipient” means a non-Federal entity that receives Federal awards through another non-Federal entity to carry out a Federal program, but does not include an individual who receives financial assistance through such awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd8b9715-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In prescribing risk-based program selection criteria for major programs, the Director shall not require more programs to be identified as major for a particular non-Federal entity, except as prescribed under subsection (c) or as provided under subsection (d), than would be identified if the major programs were defined as any program for which total expenditures of Federal awards by the non-Federal entity during the applicable year exceed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd8b9716-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the larger of $30,000,000 or 0.15 percent of the non-Federal entity’s total Federal expenditures, in the case of a non-Federal entity for which such total expenditures for all programs exceed $10,000,000,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b9717-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the larger of $3,000,000, or 0.30 percent of the non-Federal entity’s total Federal expenditures, in the case of a non-Federal entity for which such total expenditures for all programs exceed $100,000,000 but are less than or equal to $10,000,000,000; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b9718-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the larger of $300,000, or 3 percent of such total Federal expenditures for all programs, in the case of a non-Federal entity for which such total expenditures for all programs equal or exceed $300,000 but are less than or equal to $100,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd8b9719-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the total expenditures of a non-Federal entity’s major programs are less than 50 percent of the non-Federal entity’s total expenditures of all Federal awards (or such lower percentage as specified by the Director), the auditor shall select and test additional programs as major programs as necessary to achieve audit coverage of at least 50 percent of Federal expenditures by the non-Federal entity (or such lower percentage as specified by the Director), in accordance with guidance issued by the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd8b971a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Loan or loan guarantee programs, as specified by the Director, shall not be subject to the application of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd8b971b-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/502/s2/a"},"text":"Pub. L. 98–502, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2327"},"text":"98 Stat. 2327","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/156/s2"},"text":"Pub. L. 104–156, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-05"},"text":"July 5, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1396"},"text":"110 Stat. 1396","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd8b971c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd8b971d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd8b971e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Alaskan Native Claims Settlement Act, referred to in subsec. (a)(9), probably means the Alaska Native Claims Settlement Act, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/203"},"text":"Pub. L. 92–203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1971-12-18"},"text":"Dec. 18, 1971","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/85/688"},"text":"85 Stat. 688","children":[],"tail":", which is classified generally to chapter 33 (§ 1601 et seq.) of Title 43, Public Lands. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1601"},"text":"section 1601 of Title 43","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd8b971f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/156"},"text":"Pub. L. 104–156","children":[],"tail":" reenacted section catchline without change and amended text generally, substituting present provisions for similar provisions defining terms used in this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd8b9720-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd8b9721-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/207/s1"},"text":"Pub. L. 118–207, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2701"},"text":"138 Stat. 2701","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/207/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s7504"},"text":"section 7504 of this title","children":[],"tail":"] may be cited as the ‘Financial Management Risk Reduction Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd8b9722-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/301/s1"},"text":"Pub. L. 114–301, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1514"},"text":"130 Stat. 1514","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/301/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s5226"},"text":"section 5226 of Title 12","children":[],"tail":", Banks and Banking, "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s280g–15"},"text":"section 280g–15 of Title 42","children":[],"tail":", The Public Health and Welfare, and "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s114"},"text":"section 114 of Title 49","children":[],"tail":", Transportation, renumbering "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s7507"},"text":"section 7507 of this title","children":[],"tail":" as section 7506, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s7506"},"text":"section 7506 of this title","children":[],"tail":", amending provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78m"},"text":"section 78m of Title 15","children":[],"tail":", Commerce and Trade, and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5189a"},"text":"section 5189a of Title 42","children":[],"tail":", and repealing provisions set out as a note under section 1395"},{"tag":"i","attrib":{},"text":"l","children":[],"tail":" of Title 42] may be cited as the ‘GAO Mandates Revision Act of 2016’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd8b9723-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/156/s1/a"},"text":"Pub. L. 104–156, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-05"},"text":"July 5, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1396"},"text":"110 Stat. 1396","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/156/s1/a"},"text":"“This Act [amending this chapter and enacting provisions set out as notes below] may be cited as the ‘Single Audit Act Amendments of 1996’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd8b9724-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/502/s1/a"},"text":"Pub. L. 98–502, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2327"},"text":"98 Stat. 2327","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/502/s1/a"},"text":"“This Act [enacting this chapter and provisions set out as notes under this section] may be cited as the ‘Single Audit Act of 1984’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd8b9725-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transitional Application","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/156/s3"},"text":"Pub. L. 104–156, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-05"},"text":"July 5, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1404"},"text":"110 Stat. 1404","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/156/s3"},"text":"“Subject to [former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s7507"},"text":"section 7507 of title 31","children":[],"tail":", United States Code (as amended by section 2 of this Act) [now "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s7506"},"text":"31 U.S.C. 7506","children":[],"tail":"] the provisions of chapter 75 of such title (before amendment by section 2 of this Act) shall continue to apply to any State or local government with respect to any of its fiscal years beginning before "},{"tag":"date","attrib":{"date":"1996-07-01"},"text":"July 1, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd8b9726-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Statement of Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/156/s1/b"},"text":"Pub. L. 104–156, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-05"},"text":"July 5, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1396"},"text":"110 Stat. 1396","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/156/s1/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The purposes of this Act [see Short Title of 1996 Amendment note above] are to—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote sound financial management, including effective internal controls, with respect to Federal awards administered by non-Federal entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish uniform requirements for audits of Federal awards administered by non-Federal entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the efficient and effective use of audit resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce burdens on State and local governments, Indian tribes, and nonprofit organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that Federal departments and agencies, to the maximum extent practicable, rely upon and use audit work done pursuant to chapter 75 of title 31, United States Code (as amended by this Act).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/502/s1/b"},"text":"Pub. L. 98–502, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2327"},"text":"98 Stat. 2327","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/502/s1/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“It is the purpose of this Act [enacting this chapter and provisions set out as notes under this section]—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the financial management of State and local governments with respect to Federal financial assistance programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish uniform requirements for audits of Federal financial assistance provided to State and local governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the efficient and effective use of audit resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that Federal departments and agencies, to the maximum extent practicable, rely upon and use audit work done pursuant to chapter 75 of title 31, United States Code (as added by this Act).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd8b9727-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Tennessee Valley Authority Audits Unaffected by Single Audit Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/502/s2/b"},"text":"Pub. L. 98–502, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2334"},"text":"98 Stat. 2334","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/502/s2/b"},"text":"“The provisions of this Act [enacting this chapter and provisions set out as notes under this section] shall not diminish or otherwise affect the authority of the Tennessee Valley Authority to conduct its own audits of any matter involving funds disbursed by the Tennessee Valley Authority.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbd8b9728-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd8b9729-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
