{"tag":"section","attrib":{"id":"idbd9052a2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9304"},"text":null,"children":[{"tag":"num","attrib":{"value":"9304"},"text":"§ 9304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Surety corporations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd9052a3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When a law of the United States Government requires or permits a person to give a surety bond through a surety, the person satisfies the law if the surety bond is provided for the person by a corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd9052a4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" incorporated under the laws of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd9052a5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9304/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9052a6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9304/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, the District of Columbia, or a territory or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9052a7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that may under those laws guarantee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd9052a8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9304/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fidelity of persons holding positions of trust; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd9052a9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9304/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bonds and undertakings in judicial proceedings; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd9052aa-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complying with sections 9305 and 9306 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd9052ab-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each surety bond shall be approved by the official of the Government required to approve or accept the bond. The official may not require that the surety bond be given through a guaranty corporation or through any particular guaranty corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd9052ac-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1047"},"text":"96 Stat. 1047","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd9052ad-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd9052ae-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd9052af-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"9304","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"6:6.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is substituted for 6:6(1st sentence) to eliminate unnecessary words and for clarity and consistency. Clause (3) is added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Each surety bond” are substituted for “Such recognizance, stipulation, bond, or undertaking”, the words “official of the Government” are substituted for “head of department, court, judge, officer, board, or body executive, legislative, or judicial”, and the word “official” is substituted for “officer or person having the approval of any bond”, to eliminate unnecessary words and for clarity and consistency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
