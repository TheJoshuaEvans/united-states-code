{"tag":"section","attrib":{"id":"idbd1444ae-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1551"},"text":null,"children":[{"tag":"num","attrib":{"value":"1551"},"text":"§ 1551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions; applicability of subchapter","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd1444af-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1551/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1444b0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1551/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An obligated balance of an appropriation account as of the end of a fiscal year is the amount of unliquidated obligations applicable to the appropriation less amounts collectible as repayments to the appropriation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1444b1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1551/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An unobligated balance is the difference between the obligated balance and the total unexpended balance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1444b2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1551/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A fixed appropriation account is an appropriation account available for obligation for a definite period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1444b3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1551/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The limitations on the availability for expenditure prescribed in this subchapter apply to all appropriations unless specifically otherwise authorized by a law that specifically—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1444b4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1551/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the appropriate account for which the availability for expenditure is to be extended;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1444b5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1551/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that such account shall be available for recording, adjusting, and liquidating obligations properly chargeable to that account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1444b6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1551/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extends the availability for expenditure of the obligated balances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd1444b7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1551/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This subchapter does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd1444b8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1551/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriations for the District of Columbia government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd1444b9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1551/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriations to be disbursed by the Secretary of the Senate or the Chief Administrative Officer of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd1444ba-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/935"},"text":"96 Stat. 935","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1405/a/1"},"text":"Pub. L. 101–510, div. A, title XIV, § 1405(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1676"},"text":"104 Stat. 1676","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1054/e/2"},"text":"Pub. L. 102–484, div. A, title X, § 1054(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2503"},"text":"106 Stat. 2503","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s219/b/1"},"text":"Pub. L. 104–186, title II, § 219(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1748"},"text":"110 Stat. 1748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd1444bb-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd1444bc-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd1444bd-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1551(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:701(c)(1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-07-25/ch727/s1/c"},"text":"July 25, 1956, ch. 727, § 1(c)","children":[],"tail":"(1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/70/648"},"text":"70 Stat. 648","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 8, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/79/s210/b"},"text":"Pub. L. 86–79, § 210(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/167"},"text":"73 Stat. 167","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1551(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:707.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-07-25/ch727/s8"},"text":"July 25, 1956, ch. 727, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/650"},"text":"70 Stat. 650","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “District of Columbia government” are substituted for “District of Columbia” for consistency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd1444be-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd1444bf-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer” for “Clerk”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484"},"text":"Pub. L. 102–484","children":[],"tail":" substituted “Definitions; applicability of subchapter” for “Definitions and applications” as section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" amended text generally, reenacting former subsec. (a)(1) and (2) with a change in capitalization, adding subsecs. (a)(3) and (b), and restating former subsec. (b) as (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd1444c0-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd1444c1-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1990 Amendment; Transitional Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXIV/s1405/b"},"text":"Pub. L. 101–510, div. A, title XIV, § 1405(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1679"},"text":"104 Stat. 1679","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tX/s1004"},"text":"Pub. L. 102–484, div. A, title X, § 1004","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2481"},"text":"106 Stat. 2481","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/484/dA/tX/s1004"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of amendments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendments made by subsection (a) [amending this section and sections 1552 to 1557 of this title] shall apply to any appropriation account the obligated balance of which, on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":"], has not been transferred under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1552/a/1"},"text":"section 1552(a)(1) of title 31","children":[],"tail":", United States Code, as in effect on the day before the date of the enactment of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restoration of certain unobligated amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The balance of any unobligated amount withdrawn under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1552/a/2"},"text":"section 1552(a)(2) of title 31","children":[],"tail":", United States Code, as in effect on the day before the date of the enactment of this Act, from an account the obligated balance of which has not been transferred under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1552/a/1"},"text":"section 1552(a)(1) of title 31","children":[],"tail":", United States Code, as in effect on the day before the date of the enactment of this section, is hereby restored to that account."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cancellation of unobligated balances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All balances of unobligated funds withdrawn from an account under sub","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1552/a/2"},"text":"section 1552(a)(2) of title 31","children":[],"tail":", United States Code, as in effect on the day before the date of the enactment of this Act (other than funds restored under paragraph (2)) are canceled, effective at the end of the 30-day period beginning on the date of the enactment of this Act."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cancellation of obligated balances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On the third September 30th after the date of the enactment of this Act, all obligated balances transferred under sub","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1552/a/1"},"text":"section 1552(a)(1) of title 31","children":[],"tail":", United States Code, as in effect on the day before the date of the enactment of this Act, shall be canceled."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligation of existing balances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After the date of the enactment of this Act, an obligation of any part of a balance transferred before the date of the enactment of this Act under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1552/a/1"},"text":"section 1552(a)(1) of title 31","children":[],"tail":", United States Code, shall be subject to section 1553(c) of such title, as amended by subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cancellation of oldest obligated balances","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the end of the 30-day period beginning on the date on which the President submits to Congress the budget for fiscal year 1992, any amount in an account established under paragraph (1) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1552"},"text":"section 1552 of title 31","children":[],"tail":", United States Code, as in effect before the date of the enactment of this Act, that has been in that account as of that date for a period in excess of five years shall be deobligated and shall be withdrawn in the manner provided in paragraph (2) of that section. Amounts so deobligated and withdrawn may not be restored."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subparagraph (A) shall not apply so as to require the deobligation of amounts—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which there is documentary evidence that payment will be required within 180 days of the date of the enactment of this Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are determined to be necessary for severance payments for foreign national employees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligations and adjustment of obligations","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After cancellation of unobligated balances under paragraph (3) or cancellation of obligated balances under paragraph (4) or paragraph (6) and subject to the provisions of subparagraph (B), obligations and adjustments to obligations that would have been chargeable to those balances before such cancellations and that are not otherwise chargeable to current appropriations of the agency concerned may be charged to current appropriations of that agency available for the same purpose. Any charge made pursuant to this subsection shall be limited to the unobligated expired balances of the original appropriation available for the same purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any charge made pursuant to subparagraph (A) shall be subject to the maximum amount chargeable under subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1553"},"text":"section 1553 of title 31","children":[],"tail":", United States Code, as amended by this section, and shall be included in the calculation of the total amount charged to any account under that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligations and adjustments of obligations for expired but not closed accounts","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to subparagraphs (B), (C), and (D), in the case of an appropriation account for a fiscal year before fiscal year 1992 for which the period of availability for obligation has expired but which has not been closed under the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1552/a"},"text":"section 1552(a) of title 31","children":[],"tail":", United States Code, or paragraph (4) of this section, an obligation and an adjustment of an obligation may be charged to any current appropriation account of the Department of Defense that is available for the same purpose as the expired account if—"}],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligation would have been properly chargeable (except as to amount) to the expired account before the end of the period of availability of that account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligation is not otherwise properly chargeable to any current appropriation account of the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The total amount charged to a current appropriation account under subparagraph (A) may not exceed an amount equal to the lesser of—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one percent of the total amount of the appropriations for that account; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one percent of the total amount of the appropriations for the expired account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No obligation or adjustment of an obligation may be charged pursuant to the provisions of this paragraph until the Committees on Armed Services and the Committees on Appropriations of the Senate and House of Representatives are notified of the intent to make such a charge and a period of 30 days elapses after the notification is submitted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No obligation or adjustment of an obligation may be charged pursuant to the provisions of this paragraph until the Secretary of Defense (except as otherwise provided in subparagraph (E)) certifies to Congress the following:","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That the limitations on expending and obligating amounts established pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1341"},"text":"section 1341 of title 31","children":[],"tail":", United States Code, are being observed within the Department of Defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" That reports on any violations of such section 1341, whether intentional or inadvertent, are being submitted to the President and Congress immediately and with all relevant facts and a statement of actions taken as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1351"},"text":"section 1351 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative to certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of Defense is unable to make the certifications referred to in subparagraph (D) within 60 days after the date of the enactment of this subparagraph [","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":"], the Secretary shall submit to the Congress a report stating that the Secretary is unable to make such certifications and setting forth the actions that the Secretary will take in order to enable the Secretary to make such certifications after the end of that period.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
