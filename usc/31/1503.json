{"tag":"section","attrib":{"id":"idbd11f9d9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1503"},"text":null,"children":[{"tag":"num","attrib":{"value":"1503"},"text":"§ 1503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comptroller General reports of amounts for which no accounting is made","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Comptroller General shall make a special report each year to Congress on recommendations for changes in laws, that the Comptroller General believes may be in the public interest, about amounts—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd11f9da-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1503/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which no accounting is made to the Comptroller General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd11f9db-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1503/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that are in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd11f9dc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1503/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accounts of the United States Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd11f9dd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1503/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the custody of an officer or employee of the Government if the Government is financially concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"ta