{"tag":"section","attrib":{"id":"idbd27575e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342"},"text":null,"children":[{"tag":"num","attrib":{"value":"3342"},"text":"§ 3342.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Check cashing and exchange transactions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd27575f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A disbursing official of the United States Government may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd275760-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cash and negotiate negotiable instruments payable in United States currency or currency of a foreign country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd275761-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exchange United States currency, coins, and negotiable instruments and currency, coins, and negotiable instruments of foreign countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd275762-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" cash checks drawn on the Treasury to accommodate United States citizens in a foreign country, but only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd275763-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" satisfactory banking facilities are not available in the foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd275764-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a check is presented by the payee who is a United States citizen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd275765-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A disbursing official may act under subsection (a)(1) and (2) of this section only for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd275766-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An official purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd275767-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personnel of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd275768-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A dependent of personnel of the Government, but only—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd275769-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at a United States installation at which adequate banking facilities are not available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd27576a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of negotiation of negotiable instruments, if the dependent’s sponsor authorizes, in writing, the presentation of negotiable instruments to the disbursing official for negotiation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd27576b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A veteran hospitalized or living in an institution operated by an agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd27576c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contractor, or personnel of a contractor, carrying out a Government project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd27576d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Personnel of an authorized agency not part of the Government that operates with an agency of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd27576e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Federal credit union (as defined in section 101(1) of the Federal Credit Union Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1752/1"},"text":"12 U.S.C. 1752(1)","children":[],"tail":")) that at the request of the Secretary of Defense is operating on a United States military installation in a foreign country, but only if that country does not permit contractor-operated military banking facilities to operate on such installations."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd27576f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the military forces of an allied or coalition nation who is participating in a combined operation, combined exercise, or combined humanitarian or peacekeeping mission with the Armed Forces of the United States, but—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd275770-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" only if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd275771-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/8/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such disbursing official action for members of the military forces of that nation is approved by the senior United States military commander assigned to that operation, exercise, or mission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd275772-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/8/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that nation has guaranteed payment for any deficiency resulting from such disbursing official action; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd275773-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/b/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of negotiable instruments, only for a negotiable instrument drawn on a financial institution located in the United States or on a foreign branch of such an institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd275774-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd275775-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An amount held by the disbursing official that is available for expenditure may be used to carry out subsection (a) of this section with the approval of the head of the agency having jurisdiction over the amount.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd275776-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of an agency having jurisdiction over a disbursing official may offset, within the same fiscal year, a deficiency resulting from a transaction under subsection (a) of this section with a gain from a transaction under subsection (a). A gain in the account of a disbursing official not used to offset deficiencies under subsection (a) shall be deposited in the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd275777-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of any deficiency resulting from cashing a check for a dependent under subsection (b)(3), including any charges assessed against the disbursing official by a financial institution for insufficient funds to pay the check, may be offset from the pay of the dependent’s sponsor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd275778-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts necessary to adjust for deficiencies in the account of a disbursing official because of transactions under subsection (a) of this section are authorized to be appropriated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd275779-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury and, with the approval of the Secretary, the head of an agency having jurisdiction over a disbursing official, may issue regulations to carry out this section. However, under conditions the Secretary decides are necessary, the Secretary may delegate to the head of an agency the authority to issue regulations applying to a disbursing official that is an officer or employee of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd27577a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulations prescribed under subsection (d) shall include regulations that define the terms “dependent” and “sponsor” for the purposes of this section. In the regulations, the term “dependent”, with respect to a member of a uniformed service, shall have the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s401"},"text":"section 401 of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd27577b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to automated teller machines on naval vessels, the authority of a disbursing official of the United States Government under subsection (a) also includes the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd27577c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority to provide operating funds to the automated teller machines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd27577d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3342/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority to accept, for safekeeping, deposits and transfers of funds made through the automated teller machines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd27577e-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/957"},"text":"96 Stat. 957","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dA/tX/s1090"},"text":"Pub. L. 104–106, div. A, title X, § 1090","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/459"},"text":"110 Stat. 459","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1011"},"text":"Pub. L. 104–201, div. A, title X, § 1011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2635"},"text":"110 Stat. 2635","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIII/s372"},"text":"Pub. L. 106–65, div. A, title III, § 372","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/580"},"text":"113 Stat. 580","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/136/dA/tXII/s1224"},"text":"Pub. L. 108–136, div. A, title XII, § 1224","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-11-24"},"text":"Nov. 24, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1653"},"text":"117 Stat. 1653","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd27577f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd275780-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd275781-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3342(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:492a(less 1st sentence words between 2d–7th commas, last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1944-12-23/ch716"},"text":"Dec. 23, 1944, ch. 716","children":[],"tail":", §§ 1–3, "},{"tag":"html:a","attrib":{"href":"/us/stat/58/921"},"text":"58 Stat. 921","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1953-06-16/ch115"},"text":"June 16, 1953, ch. 115","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/61"},"text":"67 Stat. 61","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3342(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:492a(1st sentence words between 2d–7th commas).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3342(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:492a(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"3342(c)(2), (3)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:492b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3342(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:492c.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “disbursing official” are substituted for “disbursing officers” for clarity and consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “negotiable instruments” are substituted for “checks, drafts, bills of exchange, and other instruments” for clarity and consistency. Before clause (1), the words “Subject to regulations promulgated pursuant to sections 492a–492c of this title” are omitted as unnecessary. In clause (3), before subclause (A), the words “disbursing officers in foreign countries are also authorized . . . to” are omitted because of the restatement. The word “Treasury” is substituted for “Treasurer of the United States” because of the source provisions restated in section 321 of the revised title and Department of the Treasury Order 229 of ","children":[{"tag":"date","attrib":{"date":"1974-01-14"},"text":"January 14, 1974","children":[],"tail":" (39 F.R. 2280). The words “person who is” are omitted as surplus. In subclause (B), the word “payee” is substituted for “person to whose order they are drawn” to eliminate unnecessary words. The words “who is a United States citizen” are added for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b), before clause (1), is added because of the restatement. In clause (2), the words “the accommodation of” are omitted as surplus. The word “personnel” is substituted for “members of the Armed Forces and civilian personnel” to eliminate unnecessary words and for consistency in the revised title and with other titles of the United States Code. In clause (3), the words “of the Armed Forces of the United States . . . institutions operated by the Veterans’ Administration and other” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “For the purposes of this section” are omitted because of the restatement. The words “in the accounts of such disbursing officers” are omitted as unnecessary. The words “resulting from a transaction under subsection (a) of this section” are added for clarity. The words “not used to offset deficiencies from transactions under subsection (a)” are substituted for “resulting from operations permitted by sections 492a to 492c of this title” for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c)(3) is substituted for 31:492b(2d sentence) to eliminate unnecessary words and for consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “rules and . . . governing the disbursing officers under their respective jurisdictions, as may be deemed necessary or proper . . . the purposes of” are omitted as surplus. The words “under conditions the Secretary decides are necessary” are substituted for “subject to such terms and conditions as he may prescribe” for clarity and consistency. The words “and exercise the function of disbursement pursuant to a delegation by the Secretary of the Treasury” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd275782-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd275783-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1224/b/1"},"text":"Pub. L. 108–136, § 1224(b)(1)","children":[],"tail":", substituted “only for the following:” for “only for—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1224/b/2"},"text":"Pub. L. 108–136, § 1224(b)(2)","children":[],"tail":", (5), substituted “An” for “an” and period for semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1224/b/3"},"text":"Pub. L. 108–136, § 1224(b)(3)","children":[],"tail":", (5), substituted “Personnel” for “personnel” and period for semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1224/b/4"},"text":"Pub. L. 108–136, § 1224(b)(4)","children":[],"tail":", (5), substituted “A” for “a” and period for semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1224/b/3"},"text":"Pub. L. 108–136, § 1224(b)(3)","children":[],"tail":", (6), substituted “Personnel” for “personnel” and period for “; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1224/b/4"},"text":"Pub. L. 108–136, § 1224(b)(4)","children":[],"tail":", (7), substituted “A” for “a” and “1752(1)))” for “1752(1))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/136/s1224/a"},"text":"Pub. L. 108–136, § 1224(a)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/65"},"text":"Pub. L. 106–65","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1011/1"},"text":"Pub. L. 104–201, § 1011(1)","children":[],"tail":", substituted a semicolon for the period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1090/a/2"},"text":"Pub. L. 104–106, § 1090(a)(2)","children":[],"tail":", added par. (3). Former par. (3) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1090/a/1"},"text":"Pub. L. 104–106, § 1090(a)(1)","children":[],"tail":", redesignated pars. (3) to (5) as (4) to (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1011/2"},"text":"Pub. L. 104–201, § 1011(2)","children":[],"tail":"–(4), added par. (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1090/b"},"text":"Pub. L. 104–106, § 1090(b)","children":[],"tail":", added par. (3) and redesignated former par. (3) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106/s1090/c"},"text":"Pub. L. 104–106, § 1090(c)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
