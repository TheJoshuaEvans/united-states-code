{"tag":"section","attrib":{"id":"idbd48c265-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3812"},"text":null,"children":[{"tag":"num","attrib":{"value":"3812"},"text":"§ 3812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition against delegation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Any function, duty, or responsibility which this chapter specifies be carried out by the Attorney General or an Assistant Attorney General designated by the Attorney General, shall not be delegated to, or carried out by, any other officer or employee of the Department of Justice.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd4b3266-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVI/s6103/a"},"text":"Pub. L. 99–509, title VI, § 6103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1948"},"text":"100 Stat. 1948","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
