{"tag":"section","attrib":{"id":"idbd2c39e5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357"},"text":null,"children":[{"tag":"num","attrib":{"value":"3357"},"text":"§ 3357.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial and administrative controls relating to fraud and improper payments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd2c39e6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “agency” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551"},"text":"section 551 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c39e7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidelines required to be established under section 3(a) of the Fraud Reduction and Data Analytics Act of 2015, as in effect on the day before the date of enactment of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c39e8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall continue to be in effect on and after the date of enactment of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39e9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be periodically modified by the Director of the Office of Management and Budget, in consultation with the Comptroller General of the United States, as the Director and Comptroller General may determine necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c39ea-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Controls","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The guidelines described in subsection (b) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c39eb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting an evaluation of fraud risks and using a risk-based approach to design and implement financial and administrative control activities to mitigate identified fraud risks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39ec-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collecting and analyzing data from reporting mechanisms on detected fraud to monitor fraud trends and using that data and information to continuously improve fraud prevention controls; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39ed-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using the results of monitoring, evaluation, audits, and investigations to improve fraud prevention, detection, and response.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd2c39ee-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of fiscal years 2019 and 2020, each agency shall submit to Congress, as part of the annual financial report of the agency, a report of the agency on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd2c39ef-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" implementing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd2c39f0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financial and administrative controls described in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39f1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fraud risk principle in the Standards for Internal Control in the Federal Government published by the Government Accountability Office (commonly known as the “Green Book”); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd2c39f2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Office of Management and Budget Circular A–123, or any successor thereto, with respect to the leading practices for managing fraud risk;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39f3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying risks and vulnerabilities to fraud, including with respect to payroll, beneficiary payments, grants, large contracts, and purchase and travel cards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd2c39f4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3357/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing strategies, procedures, and other steps to curb fraud.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd2c39f5-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117/s2/a"},"text":"Pub. L. 116–117, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/131"},"text":"134 Stat. 131","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd2c39f6-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd2c39f7-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd2c39f8-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 3(a) of the Fraud Reduction and Data Analytics Act of 2015, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/186/s3/a"},"text":"section 3(a) of Pub. L. 114–186","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-30"},"text":"June 30, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/546"},"text":"130 Stat. 546","children":[],"tail":", which was formerly set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3321"},"text":"section 3321 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/116/117/s3/a/4"},"text":"Pub. L. 116–117, § 3(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/133"},"text":"134 Stat. 133","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117"},"text":"Pub. L. 116–117","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
