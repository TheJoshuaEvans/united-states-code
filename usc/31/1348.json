,"text":"31:679(words before 2d comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1912-08-23/ch350/s7"},"text":"Aug. 23, 1912, ch. 350, § 7","children":[],"tail":"(less proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/37/414"},"text":"37 Stat. 414","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1348(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:679(proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1912-08-23/ch350"},"text":"Aug. 23, 1912, ch. 350","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/37/360"},"text":"37 Stat. 360","children":[],"tail":", § 7(proviso); added "},{"tag":"html:a","attrib":{"href":"/us/act/1940-04-30/ch175"},"text":"Apr. 30, 1940, ch. 175","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/54/175"},"text":"54 Stat. 175","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1348(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:679(words between 2d comma and proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:680a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1939-05-10/ch119/s4"},"text":"May 10, 1939, ch. 119, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/738"},"text":"53 Stat. 738","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1348(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:680.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1922-09-22/ch427/s7"},"text":"Sept. 22, 1922, ch. 427, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/42/1042"},"text":"42 Stat. 1042","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1950-05-17/ch188/s203"},"text":"May 17, 1950, ch. 188, § 203","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/170"},"text":"64 Stat. 170","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1955-06-28/ch198"},"text":"June 28, 1955, ch. 198","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/69/188"},"text":"69 Stat. 188","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “or private apartment” are omitted as being included in “private residences”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the word “appropriations” is substituted for “Government funds”, and the word “calls” is substituted for “tolls”, for consistency. The word “official” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “On and after ","children":[{"tag":"date","attrib":{"date":"1939-05-10"},"text":"May 10, 1939","children":[],"tail":"” in 31:680a are omitted as executed. The word “agency” is substituted for “executive department, establishment, or agency” for clarity and because of section 101 of the revised title. The words “official business” are substituted for “public business” in 31:679 and “transaction of public business which the interests of the Government require to be so transacted” in 31:680a to eliminate unnecessary words. The words “division, bureau, or office” in 31:679 are omitted as being included in “agency”. The words “or such subordinates as he may specially designate” in 31:680a are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “On and after ","children":[{"tag":"date","attrib":{"date":"1922-09-22"},"text":"September 22, 1922","children":[],"tail":" the provisions of "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s679"},"text":"section 679 of this title","children":[],"tail":", or any other law prohibiting the expenditure of public money . . . shall not be construed to apply to or forbid” are omitted as unnecessary because of the restatement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0f8923-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd0f8924-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1721/1"},"text":"Pub. L. 104–201, § 1721(1)","children":[],"tail":", struck out at end “Subsection (b) of this section applies to long-distance calls made on those telephones.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1721/2"},"text":"Pub. L. 104–201, § 1721(2)","children":[],"tail":", (3), redesignated subsecs. (c) and (d) as (b) and (c), respectively, and struck out former subsec. (b) which read as follows: “Appropriations of an agency are available to pay charges for a long-distance call if required for official business and the voucher to pay for the call is sworn to by the head of the agency. Appropriations of an executive agency are available only if the head of the agency also certifies that the call is necessary in the interest of the Government.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/407"},"text":"Pub. L. 98–407","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd0f8925-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd0f8926-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1725/a"},"text":"section 1725(a) of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5722"},"text":"section 5722 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd0f8927-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/407/tVIII/s811/b"},"text":"Pub. L. 98–407, title VIII, § 811(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-28"},"text":"Aug. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1523"},"text":"98 Stat. 1523","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/407/tVIII/s811/b"},"text":"“The amendment made by subsection (a) [amending this section] shall be effective as of ","children":[{"tag":"date","attrib":{"date":"1984-01-01"},"text":"January 1, 1984","children":[],"tail":". Funds appropriated to the Department of Defense may be used to reimburse persons for expenditures made after "},{"tag":"date","attrib":{"date":"1983-12-31"},"text":"December 31, 1983","children":[],"tail":", for the installation, repair, and maintenance of telephone wiring in any Government-owned or leased housing unit before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1984-08-28"},"text":"Aug. 28, 1984","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd0f8928-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Employees Authorized To Work at Home","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/52/tVI/s620"},"text":"Pub. L. 104–52, title VI, § 620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-19"},"text":"Nov. 19, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/501"},"text":"109 Stat. 501","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/52/tVI/s620"},"text":"“Notwithstanding any provisions of this or any other Act, during the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", and hereafter, any department, division, bureau, or office may use funds appropriated by this or any other Act to install telephone lines, and necessary equipment, and to pay monthly charges, in any private residence or private apartment of an employee who has been authorized to work at home in accordance with guidelines issued by the Office of Personnel Management: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the head of the department, division, bureau, or office certifies that adequate safeguards against private misuse exist, and that the service is necessary for direct support of the agency’s mission.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
