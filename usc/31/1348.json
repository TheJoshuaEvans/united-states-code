{"tag":"section","attrib":{"id":"idbd0d1919-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1348"},"text":null,"children":[{"tag":"num","attrib":{"value":"1348"},"text":"§ 1348.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Telephone installation and charges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0d191a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1348/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0d191b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1348/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in this section, appropriations are not available to install telephones in private residences or for tolls or other charges for telephone service from private residences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0f891c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1348/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations of the Secretary of State, appropriations may be used to install and pay for the use of telephones in residences owned or leased by the United States Government in foreign countries for the use of the Foreign Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f891d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1348/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary of the Army on recommendation of the Chief of Engineers, not more than $30,000 may be expended each fiscal year to install and use in private residences telephones required for official business in constructing and operating locks and dams for navigation, flood control, and related water uses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0f891e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1348/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations prescribed by the Secretary of Defense, funds appropriated to the Department of Defense are available to install, repair, and maintain telephone wiring in residences owned or leased by the United States Government and, if necessary for national defense purposes, in other private residences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0f891f-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/926"},"text":"96 Stat. 926","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/407/tVIII/s811/a"},"text":"Pub. L. 98–407, title VIII, § 811(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-08-28"},"text":"Aug. 28, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1523"},"text":"98 Stat. 1523","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXVII/s1721"},"text":"Pub. L. 104–201, div. A, title XVII, § 1721","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2758"},"text":"110 Stat. 2758","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0f8920-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib"