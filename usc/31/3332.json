"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3620(d); added ","children":[{"tag":"html:span","attrib":{},"text":"Aug. 7, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/366"},"text":"Pub. L. 92–366","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/506"},"text":"86 Stat. 506","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3332(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:492(b)(1)(1st sentence words between 1st and 2d commas), (2)(32d–43d words), (d)(51st–last words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:492(note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the definition of “agency” is omitted because of section 101 of the revised title. The words “and the municipal government of the District of Columbia” are omitted because of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1973-12-24/s448"},"text":"section 448 of the Act of December 24, 1973","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/93/198"},"text":"Pub. L. 93–198","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/801"},"text":"87 Stat. 801","children":[],"tail":"). The text of section 1(b)(1st sentence) and (c)(1st sentence) of the Act of "},{"tag":"date","attrib":{"date":"1975-07-19"},"text":"July 19, 1975","children":[],"tail":", is omitted as executed. In clause (2), the words “savings bank” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b)–(f), the words “officer or employee” are substituted for “employee” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (d), the word “official” is substituted for “officer” for consistency in the revised title and with other titles of the Code. The words “issue a check payable to” are substituted for “make the payment . . . by sending to . . . a check that is drawn in favor of the organization” for clarity and consistency and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “Notwithstanding subsection (a) of this section or any other provision of law” are omitted as unnecessary. The words “may designate in writing not more than 3 financial organizations to which a payment of pay of the officer or employee shall be sent and the amount to be sent to each organization” are substituted for “upon the written request of an employee of the agency to whom a payment for wages or salary is to be made . . . in the form of one, two, or three checks (the number of checks . . . if more than one . . . designated by such employee” for clarity, consistency in the revised title and with other titles of the Code, and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “(except for a financial organization designated by an officer or employee of either House of Congress)” are substituted for section 1(b)(last sentence) and (c)(last sentence) of the Act of ","children":[{"tag":"date","attrib":{"date":"1975-07-19"},"text":"July 19, 1975","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/94/57"},"text":"Pub. L. 94–57","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/265"},"text":"89 Stat. 265","children":[],"tail":"), because of the restatement. The words “to which such check is sent” are omitted because of the restatement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “to whom a payment is to be made” are omitted as surplus. The words “upon the written request of such employee” are omitted as unnecessary. The words “accompanied by a schedule” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the word “payment” is substituted for “acquittance” for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (f) is substituted for 31:492(d)(1st–50th words) to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the words “rules and” in section 1(b) and (c) of the Act of ","children":[{"tag":"date","attrib":{"date":"1975-07-19"},"text":"July 19, 1975","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/94/57"},"text":"Pub. L. 94–57","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/265"},"text":"89 Stat. 265","children":[],"tail":"), are omitted as surplus."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd27571e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd27571f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Debt Collection Improvement Act of 1996, referred to in subsec. (e)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134/s31001"},"text":"section 31001 of Pub. L. 104–134","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1996-04-26"},"text":"Apr. 26, 1996","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (j)(3), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd275720-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsecs. (e) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/134"},"text":"Pub. L. 104–134","children":[],"tail":" added subsecs. (e) to (g), redesignated former subsec. (e) as (h), and added subsecs. (i) and (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/356"},"text":"Pub. L. 103–356","children":[],"tail":" substituted “Required direct deposit” for “Checks payable to financial organizations designated by Government officers and employees” as section catchline and amended text generally. Prior to amendment, section authorized agency officers and employees to designate not more than 3 financial organizations to which a payment of pay or other recurring payments was to be sent without charge and required the agency head to authorize issuance of checks payable to those financial organizations in the designated amounts."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2814/a"},"text":"Pub. L. 98–369, § 2814(a)","children":[],"tail":", inserted “without charge” after “shall be sent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2814/b"},"text":"Pub. L. 98–369, § 2814(b)","children":[],"tail":", struck out subsec. (c) which related to reimbursement of an agency for issuing additional checks, and redesignated subsecs. (d) to (g) as (c) to (f), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd275721-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idbd275722-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Any waiver in effect on ","children":[{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", under subsec. (f)(2)(A)(i) of this section to remain in effect until otherwise provided by the Secretary of Defense under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2786"},"text":"section 2786 of Title 10","children":[],"tail":", Armed Forces, see "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/s1008/a/3"},"text":"section 1008(a)(3) of Pub. L. 106–65","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2786"},"text":"section 2786 of Title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd275723-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Electronic Pay Stubs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/423/s1"},"text":"Pub. L. 110–423, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-15"},"text":"Oct. 15, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4818"},"text":"122 Stat. 4818","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/423/s1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of Personnel Management shall take such measures as may be appropriate to ensure that all employees who receive their pay by electronic funds transfer shall be given the option of receiving their pay stubs electronically.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘electronic funds transfer’ has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3332"},"text":"section 3332 of title 31","children":[],"tail":", United States Code;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘employee’ means an individual employed in or under an Executive agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term ‘Executive agency’ has the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
