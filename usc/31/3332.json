{"tag":"section","attrib":{"id":"idbd250e02-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332"},"text":null,"children":[{"tag":"num","attrib":{"value":"3332"},"text":"§ 3332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required direct deposit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd250e03-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250e04-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law, all Federal wage, salary, and retirement payments shall be paid to recipients of such payments by electronic funds transfer, unless another method has been determined by the Secretary of the Treasury to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250e05-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each recipient of Federal wage, salary, or retirement payments shall designate one or more financial institutions or other authorized payment agents and provide the payment certifying or authorizing agency information necessary for the recipient to receive electronic funds transfer payments through each institution so designated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250e06-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250e07-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each agency shall waive the requirements of subsection (a) of this section for a recipient of Federal wage, salary, or retirement payments authorized or certified by the agency upon written request by such recipient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250e08-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal wage, salary, or retirement payments shall be paid to any recipient granted a waiver under paragraph (1) of this subsection by any method determined appropriate by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250e09-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250e0a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury may waive the requirements of subsection (a) of this section for any group of recipients upon request by the head of an agency under standards prescribed by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250e0b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal wage, salary, or retirement payments shall be paid to any member of a group granted a waiver under paragraph (1) of this subsection by any method determined appropriate by the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250e0c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall apply only to recipients of Federal wage or salary payments who begin to receive such payments on or after ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":", and recipients of Federal retirement payments who begin to receive such payments on or after "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250e0d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250e0e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsections (a) through (d) of this section, sections 5120(a) and (d) of title 38, and any other provision of law, all Federal payments to a recipient who becomes eligible for that type of payment after 90 days after the date of the enactment of the Debt Collection Improvement Act of 1996 shall be made by electronic funds transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250e0f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of a Federal agency shall, with respect to Federal payments made or authorized by the agency, waive the application of paragraph (1) to a recipient of those payments upon receipt of written certification from the recipient that the recipient does not have an account with a financial institution or an authorized payment agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250e10-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250e11-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding any other provision of law (including subsections (a) through (e) of this section and sections 5120(a) and (d) of title 38), except as provided in paragraph (2) all Federal payments made after ","children":[{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":", shall be made by electronic funds transfer."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250e12-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd250e13-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Treasury may waive application of this subsection to payments—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd250e14-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for individuals or classes of individuals for whom compliance imposes a hardship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd250e15-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for classifications or types of checks; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd250e16-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/f/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in other circumstances as may be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250e17-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall make determinations under subparagraph (A) based on standards developed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250e18-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each recipient of Federal payments required to be made by electronic funds transfer shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250e19-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate 1 or more financial institutions or other authorized agents to which such payments shall be made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250e1a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the Federal agency that makes or authorizes the payments information necessary for the recipient to receive electronic funds transfer payments through each institution or agent designated under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250e1b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The crediting of the amount of a payment to the appropriate account on the books of a financial institution or other authorized payment agent designated by a payment recipient under this section shall constitute a full acquittance to the United States for the amount of the payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250e1c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250e1d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury may prescribe regulations that the Secretary considers necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250e1e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Regulations under this subsection shall ensure that individuals required under subsection (g) to have an account at a financial institution because of the application of subsection (f)(1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd250e1f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will have access to such an account at a reasonable cost; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250e20-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are given the same consumer protections with respect to the account as other account holders at the same financial institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd250e21-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd250e22-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “electronic funds transfer” means any transfer of funds, other than a transaction originated by cash, check, or similar paper instrument, that is initiated through an electronic terminal, telephone, computer, or magnetic tape, for the purpose of ordering, instructing, or authorizing a financial institution to debit or credit an account. The term includes Automated Clearing House transfers, Fed Wire transfers, transfers made at automatic teller machines, and point-of-sale terminals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250e23-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Federal agency” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd250e24-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s101"},"text":"section 101 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250e25-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Government corporation (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s103"},"text":"section 103 of title 5","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd250e26-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Federal payments” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd250e27-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/j/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal wage, salary, and retirement payments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250e28-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/j/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vendor and expense reimbursement payments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd250e29-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3332/j/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefit payments.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such term shall not include any payment under the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd250e2a-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/955"},"text":"96 Stat. 955","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVIII/s2814"},"text":"Pub. L. 98–369, div. B, title VIII, § 2814","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1207"},"text":"98 Stat. 1207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/356/tIV/s402/a"},"text":"Pub. L. 103–356, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3412"},"text":"108 Stat. 3412","children":[