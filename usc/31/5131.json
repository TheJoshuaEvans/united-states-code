{"tag":"section","attrib":{"id":"idbd598b20-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5131"},"text":null,"children":[{"tag":"num","attrib":{"value":"5131"},"text":"§ 5131.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd598b21-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5131/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States Mint has—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd598b22-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5131/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States mint at Philadelphia, Pennsylvania.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd598b23-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5131/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States mint at Denver, Colorado.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd598b24-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5131/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States mint at West Point, New York.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd598b25-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5131/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a United States mint at San Francisco, California.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd598b26-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5131/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall carry out duties and powers related to refining and assaying bullion, minting coins, striking medals, and numismatic items at the mints. However, until the Secretary decides that the mints are adequate for minting and striking an ample supply of coins and medals, the Secretary may use any facility of the United States Mint to mint coins and strike medals and to store coins and medals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd598b27-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5131/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Laws on mints, officers and employees of mints, and punishment of offenses related to mints and minting coins apply to assay offices, as applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd598b28-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/988"},"text":"96 Stat. 988","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/274/s2/a"},"text":"Pub. L. 100–274, § 2(a)","children":[],"tail":"–(c)(2), "},{"tag":"date","attrib":{"date":"1988-03-31"},"text":"Mar. 31, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/48"},"text":"102 Stat. 48","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/390/tII"},"text":"Pub. L. 102–390, title II","children":[],"tail":", §§ 224, 225(b)(3), (4), "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1629"},"text":"106 Stat. 1629","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tI/s101/f/tV/s503"},"text":"Pub. L. 104–208, div. A, title I, § 101(f) [title V, §§ 503, 522]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-314"},"text":"110 Stat. 3009–314","children":[],"tail":", 3009–344, 3009–347; "},{"tag":"ref","attrib":{"href":"/us/pl/104/329/tIII/s304"},"text":"Pub. L. 104–329, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-20"},"text":"Oct. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4015"},"text":"110 Stat. 4015","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd598b29-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd598b2a-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd598b2b-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":