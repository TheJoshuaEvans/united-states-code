"children":[{"tag":"html:p","attrib":{},"text":"31:324f.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 18, 1973","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/127/s3"},"text":"Pub. L. 93–127, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/456"},"text":"87 Stat. 456","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:361(1st sentence words before 1st comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1878-06-19/ch329/s1"},"text":"June 19, 1878, ch. 329, § 1","children":[],"tail":"(1st sentence on p. 191), "},{"tag":"html:a","attrib":{"href":"/us/stat/20/191"},"text":"20 Stat. 191","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1898-07-07/ch571"},"text":"July 7, 1898, ch. 571","children":[],"tail":"(7th par. 1st sentence words before 1st comma under heading “Mints and Assay Offices”), "},{"tag":"html:a","attrib":{"href":"/us/stat/30/661"},"text":"30 Stat. 661","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5131(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:263.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3496; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1912-08-23/ch350/s1"},"text":"Aug. 23, 1912, ch. 350, § 1","children":[],"tail":"(last par. words before 7th comma under heading “Assay Office at Salt Lake City, Utah”), "},{"tag":"html:a","attrib":{"href":"/us/stat/37/384"},"text":"37 Stat. 384","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:279.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3554; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1912-08-23/ch350/s1"},"text":"Aug. 23, 1912, ch. 350, § 1","children":[],"tail":"(last par. words before 7th comma under heading “Assay Office at Salt Lake City, Utah”), "},{"tag":"html:a","attrib":{"href":"/us/stat/37/384"},"text":"37 Stat. 384","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:281.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3555; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1912-08-23/ch350/s1"},"text":"Aug. 23, 1912, ch. 350, § 1","children":[],"tail":"(last par. words before 7th comma under heading “Assay Office at Salt Lake City, Utah”), "},{"tag":"html:a","attrib":{"href":"/us/stat/37/384"},"text":"37 Stat. 384","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/310/s231/g"},"text":"Pub. L. 92–310, § 231(g)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/210"},"text":"86 Stat. 210","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5131(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:287.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3562.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5131(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:292.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 20, 1963","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/102/s2"},"text":"Pub. L. 88–102, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/77/129"},"text":"77 Stat. 129","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “The Bureau of the Mint has” are substituted for “embracing in its organization and under its control all mints . . . and all assay offices” in 31:251(1st sentence words after 1st comma) because of the restatement and to eliminate unnecessary words. The words “for the manufacture of coin . . . for the stamping of bars, which have been, or which may be, authorized by law” are omitted as superseded by the source provisions restated in subsection (b).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “The Secretary of the Treasury shall carry out duties and powers” are added because of the source provisions restated in section 321 of the revised title. The words “related to refining and assaying bullion, minting coins, striking medals, and numismatic items at the mints and assay offices” are substituted for 31:278(1st sentence words before comma), 283(1st–26th words), and 361(1st sentence words before 1st comma) to eliminate unnecessary words and for consistency with the source provisions restated in sections 5111(a)(1)–(3) and 5120(a) of the revised title. The words “and not coin” in 31:278 are omitted as unnecessary because of the restatement. The words “and no metals shall be purchased for minor coinage” are omitted as superseded by section 5111(b) of the revised title. The text of 31:278(2d, last sentences) is omitted as obsolete because the Secretary of the Treasury has authority to mint coins containing silver only under section 5112(e) of the revised title and the Secretary holds sufficient silver to mint those coins. See Sen. Rept. No. 91–1084 (1970). The words “except that until the Secretary of the Treasury determines that the mints of the United States are adequate for the production of ample supplies of coins, its facilities may be used for the production of coins” in 31:283(1st sentence) are omitted as superseded by the source provisions restated in the subsection. The words “striking” and “strike” are added for consistency with section 5111 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the text of 31:281(words before semicolon) is omitted as superseded by the source provisions restated in section 321 of the revised title, and 31:281(words after semicolon) is omitted as superseded by the source provisions restated in subsection (d) and by 5:ch. 35, subch. II.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “the mint at Philadelphia” are substituted for “any building constructed pursuant to this subchapter” because that is the building that was constructed under the subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd598b2c-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd598b2d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208/s101/f/tV/s503"},"text":"Pub. L. 104–208, § 101(f) [title V, §§ 503, 522]","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/104/329"},"text":"Pub. L. 104–329","children":[],"tail":", amended section identically, redesignating subsec. (d) as (c) and striking out former subsec. (c) which read as follows: “Each mint has a superintendent and an assayer appointed by the President, by and with the advice and consent of the Senate. The mint at Philadelphia has an engraver appointed by the President, by and with the advice and consent of the Senate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1992—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/390/s225/b/3"},"text":"Pub. L. 102–390, § 225(b)(3)","children":[],"tail":", substituted “United States Mint” for “Bureau of the Mint” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/390/s225/b/4"},"text":"Pub. L. 102–390, § 225(b)(4)","children":[],"tail":", substituted “United States Mint” for “Bureau”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/390/s224"},"text":"Pub. L. 102–390, § 224","children":[],"tail":", struck out subsec. (e) which read as follows: “The Secretary shall operate, maintain, and have custody of, the mint at Philadelphia. However, the Administrator of General Services shall make repairs and improvements to the mint.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/274/s2/b"},"text":"Pub. L. 100–274, § 2(b)","children":[],"tail":", substituted “mint at West Point, New York” for “assay office at New York, New York”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/274/s2/a"},"text":"Pub. L. 100–274, § 2(a)","children":[],"tail":", substituted “mint” for “assay office”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/274/s2/c/1"},"text":"Pub. L. 100–274, § 2(c)(1)","children":[],"tail":", struck out “and assay offices, except that only bars may be made at the assay offices” before period at end of first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/274/s2/c/2"},"text":"Pub. L. 100–274, § 2(c)(2)","children":[],"tail":", substituted “Each mint has” for “Each mint and the assay office at New York have”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd598b2e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd598b2f-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authority of Special Police Officers","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For authority of special police officers of United States Mint over buildings and land under control and in vicinity of the Mint and to protection in transit of bullion, coins, dies, and other property and assets of the Mint, see section 101(f) [title V, § 517(2), (3)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5141"},"text":"section 5141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
