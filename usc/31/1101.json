{"tag":"section","attrib":{"id":"idbcfa0556-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1101"},"text":null,"children":[{"tag":"num","attrib":{"value":"1101"},"text":"§ 1101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcfa0557-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “agency” includes the District of Columbia government but does not include the legislative branch or the Supreme Court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcfa0558-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “appropriations” means appropriated amounts and includes, in appropriate context—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcfa0559-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1101/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa055a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1101/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authority to make obligations by contract before appropriations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcfa055b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1101/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other authority making amounts available for obligation or expenditure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcfa055c-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/907"},"text":"96 Stat. 907","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcfa055d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcfa055e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbcfa055f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1101(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:2(1st–4th pars.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18/s2"},"text":"June 10, 1921, ch. 18, § 2","children":[],"tail":"(1st–5th pars.), "},{"tag":"html:a","attrib":{"href":"/us/stat/42/20"},"text":"42 Stat. 20","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1939-04-03/ch36/s201"},"text":"Apr. 3, 1939, ch. 36, § 201","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/565"},"text":"53 Stat. 565","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-07-31/ch302/s101"},"text":"July 31, 1953, ch. 302, § 101","children":[],"tail":"(1st proviso in par. under heading “Bureau of the Budget”), "},{"tag":"html:a","attrib":{"href":"/us/stat/67/299"},"text":"67 Stat. 299","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1101(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:2(last par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18"},"text":"June 10, 1921, ch. 18","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/42/20"},"text":"42 Stat. 20","children":[],"tail":", § 2(last par.); added "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-12/ch946/s101"},"text":"Sept. 12, 1950, ch. 946, § 101","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/832"},"text":"64 Stat. 832","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, a reference to 31:71 and 471 is omitted because the definitions in the section are not used in 31:71 and 471.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), “agency” (which is defined for purposes of this title in section 101 to mean a department, agency, or instrumentality of the United States) is coextensive with and substituted for the term “department or establishment” which was defined in 31:2 as in part meaning “any executive department, independent commission, board, bureau, office, agency, or other establishment of the Government, including any independent regulatory commission or board”. This definition merely restates and continues, and does not in any way change or expand, the definition in 31:2. Under that definition, entities such as the Tennessee Valley Authority that have been interpreted to be outside the purview of the definition will continue to be outside the purview in the same manner and to the same extent that they were under 31:2. The words “includes the District of Columbia government” are used because of existing law but the inclusion of these words is not to be interpreted as construing the extent to which the District of Columbia Self-Government and Governmental Reorganizational Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/198"},"text":"Pub. L. 93–198","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/774"},"text":"87 Stat. 774","children":[],"tail":") supersedes the provisions codified in this title. The words “of the United States” are omitted as surplus. The text of 31:2(2d–4th pars.) is omitted as unnecessary because of the restatement. The text of section 2(3d par.) of the Budget and Accounting Act, 1921 (ch. 18, "},{"tag":"ref","attrib":{"href":"/us/stat/42/20"},"text":"42 Stat. 20","children":[],"tail":"), is omitted as obsolete because of section 501 of the revised title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcfa0560-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbcfa0561-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/190/s1"},"text":"Pub. L. 118–190, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2653"},"text":"138 Stat. 2653","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/190/s1"},"text":"“This Act [amending sections 1115, 1116, 1120 to 1122, and 9704 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees, and repealing sections 1118 and 1119 of this title] may be cited as the ‘Federal Agency Performance Act of 2024’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/172/s1"},"text":"Pub. L. 118–172, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2593"},"text":"138 Stat. 2593","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/172/s1"},"text":"“This Act [amending sections 1105 and 1125 of this title, enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1125"},"text":"section 1125 of this title","children":[],"tail":", and amending provisions set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s4101"},"text":"section 4101 of Title 44","children":[],"tail":", Public Printing and Documents] may be cited as the ‘Eliminate Useless Reports Act of 2024’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbcfa0562-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIII/s5303/a"},"text":"Pub. L. 117–263, div. E, title LIII, § 5303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3250"},"text":"136 Stat. 3250","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/263/dE/tLIII/s5303/a"},"text":"“This section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115"},"text":"section 1115 of this title","children":[],"tail":"] may be cited as the ‘Performance Enhancement Reform Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbcfa0563-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/414/s1"},"text":"Pub. L. 115–414, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5430"},"text":"132 Stat. 5430","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/414/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s720"},"text":"section 720 of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of this title","children":[],"tail":"] may be cited as the ‘Good Accounting Obligation in Government Act’ or the ‘GAO–IG Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbcfa0564-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2011 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/352/s1/a"},"text":"Pub. L. 111–352, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3866"},"text":"124 Stat. 3866","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/352/s1/a"},"text":"“This Act [enacting sections 1115, 1116, and 1120 to 1125 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees, amending "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of this title","children":[],"tail":", repealing sections 1115 and 1116 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115"},"text":"section 1115 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5105"},"text":"section 5105 of Title 5","children":[],"tail":"] may be cited as the ‘GPRA Modernization Act of 2010’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbcfa0565-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/291/tIV/s401"},"text":"Pub. L. 111–291, title IV, § 401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-12-08"},"text":"Dec. 8, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3097"},"text":"124 Stat. 3097","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/111/291/tIV/s401"},"text":"“This title [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of this title","children":[],"tail":", enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of this title","children":[],"tail":", and amending provisions set out as a note under this section] may be cited as the ‘Crow Tribe Water Rights Settlement Act of 2010’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbcfa0566-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62/s1"},"text":"Pub. L. 103–62, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-03"},"text":"Aug. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/285"},"text":"107 Stat. 285","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/62/s1"},"text":"“This Act [enacting sections 1115 to 1119, 9703, and 9704 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees, and sections 2801 to 2805 of Title 39, Postal Service, amending "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of this title","children":[],"tail":", and enacting provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115"},"text":"section 1115 of this title","children":[],"tail":"] may be cited as the ‘Government Performance and Results Act of 1993’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbcfa0567-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/501/tII/s201"},"text":"Pub. L. 98–501, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2324"},"text":"98 Stat. 2324","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/501/tII/s201"},"text":"“This title [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of this title","children":[],"tail":" and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of this title","children":[],"tail":"] may be cited as the ‘Federal Capital Investment Program Information Act of 1984’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcfa0568-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 1993 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62/s10"},"text":"Pub. L. 103–62, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-03"},"text":"Aug. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/295"},"text":"107 Stat. 295","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/62/s10"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“No provision or amendment made by this Act [see Short Title of 1993 Amendment note set out above] may be construed as—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating any right, privilege, benefit, or entitlement for any person who is not an officer or employee of the United States acting in such capacity, and no person who is not an officer or employee of the United States acting in such capacity shall have standing to file any civil action in a court of the United States to enforce any provision or amendment made by this Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" superseding any statutory requirement, including any requirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"section 553 of title 5","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcfa0569-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings and Statement of Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62/s2"},"text":"Pub. L. 103–62, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-03"},"text":"Aug. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/285"},"text":"107 Stat. 285","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/62/s2"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waste and inefficiency in Federal programs undermine the confidence of the American people in the Government and reduces the Federal Government’s ability to address adequately vital public needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal managers are seriously disadvantaged in their efforts to improve program efficiency and effectiveness, because of insufficient articulation of program goals and inadequate information on program performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" congressional policymaking, spending decisions and program oversight are seriously handicapped by insufficient attention to program performance and results.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this Act [see Short Title of 1993 Amendment note set out above] are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the confidence of the American people in the capability of the Federal Government, by systematically holding Federal agencies accountable for achieving program results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiate program performance reform with a series of pilot projects in setting program goals, measuring program performance against those goals, and reporting publicly on their progress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve Federal program effectiveness and public accountability by promoting a new focus on results, service quality, and customer satisfaction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help Federal managers improve service delivery, by requiring that they plan for meeting program objectives and by providing them with information about program results and service quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve congressional decisionmaking by providing more objective information on achieving statutory objectives, and on the relative effectiveness and efficiency of Federal programs and spending; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve internal management of the Federal Government.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbcfa056a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Oversight","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62/s8/a"},"text":"Pub. L. 103–62, § 8(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-03"},"text":"Aug. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/294"},"text":"107 Stat. 294","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/62/s8/a"},"text":"“Nothing in this Act [see Short Title of 1993 Amendment note set out above] shall be construed as limiting the ability of Congress to establish, amend, suspend, or annul a performance goal. Any such action shall have the effect of superseding that goal in the plan submitted under section 1105(a)(29) [now 1105(a)(28)] of title 31, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbcfa056b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"executiveOrder","id":"idbcfa056c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Executive Order No. 13037","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Ex. Ord. No. 13037, ","children":[{"tag":"date","attrib":{"date":"1997-03-03"},"text":"Mar. 3, 1997","children":[],"tail":", 62 F.R. 10185, as amended by Ex. Ord. No. 13066, "},{"tag":"date","attrib":{"date":"1997-10-29"},"text":"Oct. 29, 1997","children":[],"tail":", 62 F.R. 59273; Ex. Ord. No. 13108, "},{"tag":"date","attrib":{"date":"1998-12-11"},"text":"Dec. 11, 1998","children":[],"tail":", 63 F.R. 69175, which established the Commission to Study Capital Budgeting, was revoked by Ex. Ord. No. 13138, § 3(d), "},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", 64 F.R. 53880, formerly set out as a note under section 14 of the Appendix to Title 5, Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
