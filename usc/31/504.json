{"tag":"section","attrib":{"id":"idbce9644e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s504"},"text":null,"children":[{"tag":"num","attrib":{"value":"504"},"text":"§ 504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Federal Financial Management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbce9644f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Office of Management and Budget an office to be known as the “Office of Federal Financial Management”. The Office of Federal Financial Management, under the direction and control of the Deputy Director for Management of the Office of Management and Budget, shall carry out the financial management functions listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s503/a"},"text":"section 503(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce96450-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There shall be at the head of the Office of Federal Financial Management a Controller, who shall be appointed by the President, by and with the advice and consent of the Senate. The Controller shall be appointed from among individuals who possess—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbce96451-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrated ability and practical experience in accounting, financial management, and financial systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbce96452-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extensive practical experience in financial management in large governmental or business entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbce96453-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Controller of the Office of Federal Financial Management shall be the deputy and principal advisor to the Deputy Director for Management in the performance by the Deputy Director for Management of functions described in section 503(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbce96454-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/576/tII/s203/a"},"text":"Pub. L. 101–576, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-15"},"text":"Nov. 15, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/2841"},"text":"104 Stat. 2841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbce96455-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbce96456-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idbce96457-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 504 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s506"},"text":"section 506 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
