{"tag":"section","attrib":{"id":"idbd8b96ca-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7302"},"text":null,"children":[{"tag":"num","attrib":{"value":"7302"},"text":"§ 7302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd8b96cb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “block grant amounts” means amounts received for a program that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd8b96cc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7302/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly allocates amounts to States only, except for amounts allocated for use by the agency administering the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd8b96cd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7302/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides that the State may use any part of the amounts at its discretion to continue to support activities financed on ","children":[{"tag":"date","attrib":{"date":"1981-08-12"},"text":"August 12, 1981","children":[],"tail":", under programs whose authorizations were discontinued by the Omnibus Budget Reconciliation Act of 1981 ("},{"tag":"ref","attrib":{"href":"/us/pl/97/35"},"text":"Public Law 97–35","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/95/357"},"text":"95 Stat. 357","children":[],"tail":") and that were financed on "},{"tag":"date","attrib":{"date":"1981-08-12"},"text":"August 12, 1981","children":[],"tail":", by allocations by the United States Government to local governments or other eligible entities, or both local governments and other eligible entities."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8b96ce-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” includes the District of Columbia and territories and possessions of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd8b96cf-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1040"},"text":"96 Stat. 1040","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd8b96d0-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd8b96d1-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd8b96d2-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7302","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1243(note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/35/s1741/b"},"text":"Pub. L. 97–35, § 1741(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/763"},"text":"95 Stat. 763","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1)(A), the word “Federal” is omitted as surplus because of section 101 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd8b96d3-47c4-11f1-bea6-82cea744851c"},"