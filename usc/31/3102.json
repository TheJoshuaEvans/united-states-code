ildren":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:752(2d par. less form of bonds).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1917-09-24/ch56/s1"},"text":"Sept. 24, 1917, ch. 56, § 1","children":[],"tail":"(2d par. less form of bonds), "},{"tag":"html:a","attrib":{"href":"/us/stat/40/288"},"text":"40 Stat. 288","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1918-04-04/ch44/s1"},"text":"Apr. 4, 1918, ch. 44, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/40/502"},"text":"40 Stat. 502","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Mar. 17, 1971","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/5/s3"},"text":"Pub. L. 92–5, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/85/5"},"text":"85 Stat. 5","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/53/s2"},"text":"Pub. L. 93–53, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/135"},"text":"87 Stat. 135","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Mar. 15, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/232/s3/a"},"text":"Pub. L. 94–232, § 3(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/217"},"text":"90 Stat. 217","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 30, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/334/s2"},"text":"Pub. L. 94–334, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/793"},"text":"90 Stat. 793","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/120/s3"},"text":"Pub. L. 95–120, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1090"},"text":"91 Stat. 1090","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 3, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/333/s3"},"text":"Pub. L. 95–333, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/419"},"text":"92 Stat. 419","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Apr. 2, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/5/s3"},"text":"Pub. L. 96–5, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/8"},"text":"93 Stat. 8","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/78/s102"},"text":"Pub. L. 96–78, § 102","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/589"},"text":"93 Stat. 589","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 3, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/377/s2"},"text":"Pub. L. 96–377, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1512"},"text":"94 Stat. 1512","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3102(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:752(3d par. 1st sentence words before 4th comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1917-09-24/ch56/s1"},"text":"Sept. 24, 1917, ch. 56, § 1","children":[],"tail":"(3d par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/40/288"},"text":"40 Stat. 288","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1918-04-04/ch44/s1"},"text":"Apr. 4, 1918, ch. 44, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/40/502"},"text":"40 Stat. 502","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:752(4th par. related to a popular loan).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1917-09-24/ch56"},"text":"Sept. 24, 1917, ch. 56","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/40/288"},"text":"40 Stat. 288","children":[],"tail":", § 1(4th par.); added "},{"tag":"html:a","attrib":{"href":"/us/act/1934-01-30/ch6/s14/a/1"},"text":"Jan. 30, 1934, ch. 6, § 14(a)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/343"},"text":"48 Stat. 343","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3102(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:752(3d par. 1st sentence words between 4th comma and proviso), (4th par. related to allotments).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3102(c)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:752(3d par. 1st sentence proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3102(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:752(3d par. last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3102(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:752(3d par. 2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “amounts” is substituted for “sum or sums” for consistency. The words “as in his judgment may be” are omitted as surplus. The words “for expenditures authorized by law” are substituted for “for the purposes of this Act . . . and to meet expenditures authorized for the national security and defense and other public purposes authorized by law” because they are inclusive and for consistency. The words “under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3111"},"text":"section 3111 of this title","children":[],"tail":"” are substituted for “at or before maturity, of any outstanding bonds, notes, certificates of indebtedness, or Treasury bills of the United States” because of the restatement. The words “prescribe conditions under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3121"},"text":"section 3121 of this title","children":[],"tail":"” are substituted for the text of 31:752(2d par. 1st sentence less form of bonds, 2d sentence) because of the restatement. The words “at any annual interest rate” are added for clarity and to more precisely define the 4.25 percent limitation. The words “bonds may not be issued under this section to the public, or sold by a Government account to the public, with a rate of interest exceeding 4¼ per centum per annum in an amount which would cause” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b), (d), and (e), the words “not less than par” are omitted as superseded by section 3 of the Public Debt Act of 1942 (ch. 205, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/56/189"},"text":"56 Stat. 189","children":[],"tail":"), restated in section 3121 of the revised title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “under regulations of the Secretary that allow” are substituted for “under such regulations, prescribed by the Secretary of the Treasury from time to time, as will in his opinion give” to eliminate unnecessary words. The words “subscribing to the offered bonds” are substituted for “therein” for clarity. The words “However . . . when the Secretary decides the other way is in the public interest” are substituted for “Notwithstanding the provisions of the foregoing paragraph, the Secretary of the Treasury may from time to time, when he deems it to be in the public interest” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), before clause (A), the words “and may from time to time adopt any or all of said methods, should any such action” in 31:752(3d par. 1st sentence words between 4th comma and proviso) are omitted because of the restatement. The word “decides” is substituted for “deemed” in 31:752(3d par. 1st sentence words between 4th comma and proviso) and “deems” in 31:752a(4th par. related to allotments) for consistency. The words “in making a bond offering under this section” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the word “regulations” is substituted for “general rules” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “members of armed forces” are substituted for “persons in the military or naval forces of the United States” for clarity and consistency with title 10.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd192698-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd192699-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":"1983 ","children":[{"tag":"html:span","attrib":{},"text":"Act","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3102(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31 App.:752(2d par. less form of bonds).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/248/s289/c"},"text":"Pub. L. 97–248, § 289(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/572"},"text":"96 Stat. 572","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd19269a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd19269b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/647"},"text":"Pub. L. 100–647","children":[],"tail":" struck out at end: “However, the face amount of bonds issued under this section and held by the public with interest rates of more than 4.25 percent a year may not be more than $270,000,000,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1987—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/203"},"text":"Pub. L. 100–203","children":[],"tail":" substituted “$270,000,000,000” for “$250,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/272"},"text":"Pub. L. 99–272","children":[],"tail":" substituted “$250,000,000,000” for “$200,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/302"},"text":"Pub. L. 98–302","children":[],"tail":" substituted “$200,000,000,000” for “$150,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/34"},"text":"Pub. L. 98–34","children":[],"tail":" substituted “$150,000,000,000” for “$110,000,000,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/452"},"text":"Pub. L. 97–452","children":[],"tail":" substituted “$110,000,000,000” for “$70,000,000,000”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
