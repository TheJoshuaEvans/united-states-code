{"tag":"section","attrib":{"id":"idbd7d400b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6306"},"text":null,"children":[{"tag":"num","attrib":{"value":"6306"},"text":"§ 6306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to vest title in tangible personal property for research","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The head of an executive agency may vest title in tangible personal property in a nonprofit institution of higher education or in a nonprofit organization whose primary purpose is conducting scientific research—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd7d400c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6306/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the property is bought with amounts provided under a procurement contract, grant agreement, or cooperative agreement with the institution or organization to conduct basic or applied scientific research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d400d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6306/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the head of the agency decides the vesting furthers the objectives of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d400e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6306/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without further obligation to the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd7d400f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6306/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under conditions the head of the agency considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7d4010-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1004"},"text":"96 Stat. 1004","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd7d4011-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd7d4012-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd7d4013-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6306","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"41:506.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Feb. 3, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/224/s7"},"text":"Pub. L. 95–224, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/5"},"text":"92 Stat. 5","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of 41:506(a) is omitted as unnecessary because it duplicates the requirements of sections 6303–6305 of the revised title. The word “equipment” is omitted as being included in “tangible personal property”. The words “amounts provided under a contract, grant agreement, or cooperative agreement” are substituted for “such funds” for clarity. The words “decides the vesting” are substituted for “it is deemed” for clarity. The word “conditions” is substituted for “terms and conditions” because it is inclusive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
