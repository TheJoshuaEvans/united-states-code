{"tag":"section","attrib":{"id":"idbd0d18f9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1345"},"text":null,"children":[{"tag":"num","attrib":{"value":"1345"},"text":"§ 1345.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Expenses of meetings","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as specifically provided by law, an appropriation may not be used for travel, transportation, and subsistence expenses for a meeting. This section does not prohibit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0d18fa-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1345/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency from paying the expenses of an officer or employee of the United States Government carrying out an official duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0d18fb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1345/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Agriculture from paying necessary expenses for a meeting called by the Secretary for 4–H Boys and Girls Clubs as part of the cooperative extension work of the Department of Agriculture.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0d18fc-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/925"},"text":"96 Stat. 925","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd0d18fd-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd0d18fe-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd0d18ff-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1345","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:551.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-02-02/ch4"},"text":"Feb. 2, 1935, ch. 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/19"},"text":"49 Stat. 19","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:552.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-06-17/ch271"},"text":"June 17, 1935, ch. 271","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/387"},"text":"49 Stat. 387","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, before clause (1), the word “appropriation” is substituted for “no moneys from funds appropriated for any purpose” in 31:551 for consistency in the revised title. The words “travel, transportation, and subsistence expenses for a meeting” are substituted for “the purpose of lodging, feeding, conveying, or furnishing transportation to, any conventions or other form of assemblage or gathering” to eliminate unnecessary words. The words “to be held in the District of Columbia or elsewhere” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words “agency from paying” are substituted for “the payment of” for clarity and because of section 101 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd0d1900-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd0d1901-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Availability of Appropriations for Expenses of Attending Meetings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/394/tV/s505"},"text":"Pub. L. 102–394, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-06"},"text":"Oct. 6, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/1825"},"text":"106 Stat. 1825","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/394/tV/s505"},"text":"“Appropriations contained in this Act or subsequent Departments of Labor, Health and Human Services, and Education, and Related Agencies Appropriations Acts, available for salaries and expenses, shall be available for expenses of attendance at meetings which are concerned with the functions or activities for which the appropriation is made or which will contribute to improved conduct, supervision, or management of those functions or activities.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/170/tV/s505"},"text":"Pub. L. 102–170, title V, § 505","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-11-26"},"text":"Nov. 26, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1141"},"text":"105 Stat. 1141","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/517/tV/s505"},"text":"Pub. L. 101–517, title V, § 505","children"