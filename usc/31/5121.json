ail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3518.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:327(1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3519.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:328(1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3520; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1887-03-03/ch396/s3"},"text":"Mar. 3, 1887, ch. 396, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/24/635"},"text":"24 Stat. 635","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:329.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3521; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1912-08-23/ch350/s1"},"text":"Aug. 23, 1912, ch. 350, § 1","children":[],"tail":"(last par. words before 7th comma under heading “Assay Office at Salt Lake City, Utah”), "},{"tag":"html:a","attrib":{"href":"/us/stat/37/384"},"text":"37 Stat. 384","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5121(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:327(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:328(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5121(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:360.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3546.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:362.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1878-06-19/ch329/s1"},"text":"June 19, 1878, ch. 329, § 1","children":[],"tail":"(2d sentence words after last semicolon on p. 191), "},{"tag":"html:a","attrib":{"href":"/us/stat/20/191"},"text":"20 Stat. 191","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5121(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:325(words between 4th and last commas).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:347.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3534; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1912-08-23/ch350/s1"},"text":"Aug. 23, 1912, ch. 350, § 1","children":[],"tail":"(last par. words before 7th comma under heading “Assay Office at Salt Lake City, Utah”), "},{"tag":"html:a","attrib":{"href":"/us/stat/37/384"},"text":"37 Stat. 384","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the word “Secretary” is substituted for “superintendent”, “superintendent of melting and refining department”, “assayer”, “Director of the Mint”, and “Director of the Mint, with the approval of the Secretary of the Treasury” because of the source provisions restated in section 321(c) of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), clause (1) is added to provide a complete list of the duties and powers of the Secretary and for consistency with section 5131 of the revised title. In clause (2), the words “as required” are substituted for “required by the operations of the Bureau of the Mint” and “whenever required by the superintendent” in 31:277 to eliminate unnecessary words. The text of 31:330 is omitted as superseded by the source provisions restated in section 321(c) of the revised title. In clause (3), the word “bars” is substituted for “bars conformable in all respects to the law” in 31:274 to eliminate unnecessary words. In clause (4), the word “alloys” is substituted for “standard silver or gold, and alloys for minor” in 31:274, and the text of 31:343(last sentence) is omitted, because coins issued by the Secretary under this chapter are composed of alloys. The words “minting coins” are substituted for “coinage” for consistency in the revised chapter. The words “suitable for the superintendent of coining department, from the metals legally delivered to him for that purpose” in 31:274 and the text of 31:274(last sentence) and 31:343(1st, 2d sentences) are omitted as superseded by the source provisions restated in section 321(c) of the revised title. The text of 31:344(last sentence) is omitted as unnecessary because of the restatement of the source provisions in sections 5112 and 5113 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (d), the word “unrefined” is substituted for “unparted” for consistency in the revised chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “At the option of the owner” and “as he may prefer” in 31:325 and “for his benefit” in 31:327 are omitted as unnecessary because of the restatement. The words “weighing at least” are substituted for “and no such bars shall be issued of a less weight than” in 31:325 to eliminate unnecessary words. The word “troy” is added for clarity. The words “into coin” in section 3519 of the Revised Statutes are omitted because the coinage of gold was discontinued by 31:315b. The text of 31:329(last sentence) is omitted because of the source provisions restated in section 321(c) of the revised title. The words “and no deposit of silver for other coinage shall be received” in 31:328(1st sentence) are omitted as unnecessary because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “economically” is substituted for “advantageously” in 31:327(last sentence) for consistency in the section. The text of 31:328(last sentence) is omitted as unnecessary because of the source provisions restated in section 5121(a) of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1), before clause (A), the words “at any of the mints” in 31:360(1st sentence) are omitted as superseded by the source provisions restated in section 321(c) of the revised title. The text of 31:360(2d sentence) is omitted as unnecessary because of the source provisions restated in section 5121(a) of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), the words “in an exchange under this subsection” are added for clarity. The word “refining” is substituted for “refining or parting” for consistency in the revised chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the word “suitable” is substituted for “expedient” in 31:325(words between 4th and last commas) for clarity. The words “but the fineness thereof shall be ascertained and” in 31:347 are omitted as unnecessary because of the source provisions restated in section 5121(a) of the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbd598b0d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd598b0e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Possession of Gold Coins and Bullion","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The possession of gold coins and bullion was prohibited except under Government license by Ex. Ord. No. 6260, eff. ","children":[{"tag":"date","attrib":{"date":"1933-08-28"},"text":"Aug. 28, 1933","children":[],"tail":". That prohibition was revoked by Ex. Ord. No. 11825, "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":", 40 F.R. 1003, eff. "},{"tag":"date","attrib":{"date":"1974-12-31"},"text":"Dec. 31, 1974","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
