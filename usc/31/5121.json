{"tag":"section","attrib":{"id":"idbd598afb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121"},"text":null,"children":[{"tag":"num","attrib":{"value":"5121"},"text":"§ 5121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refining, assaying, and valuation of bullion","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd598afc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Treasury shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd598afd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" melt and refine bullion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd598afe-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as required, assay coins, metal, and bullion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd598aff-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cast gold and silver bullion deposits into bars; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd598b00-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cast alloys into bars for minting coins.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd598b01-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person owning gold or silver bullion may deposit the bullion with the Secretary to be cast into fine, standard fineness, or unrefined bars weighing at least 5 troy ounces. When practicable, the Secretary shall weigh the bullion in front of the depositor. The Secretary shall give the depositor a receipt for the bullion stating the description and weight of the bullion. When the Secretary has to melt the bullion or remove base metals before the value of the bullion can be determined, the weight is the weight after the melting or removal of the metals. The Secretary may refuse a deposit of gold bullion if the deposit is less than $100 in value or the bullion is so base that it is unsuitable for the operations of the Bureau of the Mint.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd598b02-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the gold and silver are combined in bullion that is deposited and either the gold or silver is so little that it cannot be separated economically, the Secretary may not pay the depositor for the gold or silver that cannot be separated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd598b03-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd598b04-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under conditions prescribed by the Secretary, a person may exchange unrefined bullion for fine bars when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd598b05-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gold and silver are combined in the bullion in proportions that cannot be economically refined; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd598b06-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary supplies of acids cannot be procured at reasonable rates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd598b07-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The charge for refining in an exchange under this subsection may be not more than the charge imposed in an exchange of unrefined bullion for refined bullion.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd598b08-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5121/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prepare bars for payment of deposits. The Secretary shall stamp each bar with a designation of the weight and fineness of the bar and a symbol the Secretary considers suitable to prevent fraudulent imitation of the bar.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd598b09-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/987"},"text":"96 Stat. 987","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd598b0a-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd598b0b-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd598b0c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5121(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:274.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3508; ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1912-08-23/ch350/s1"},"text":"Aug. 23, 1912, ch. 350, § 1","children":[],"tail":"(last par. words before 7th comma under heading “Assay Office at Salt Lake City, Utah”), "},{"tag":"html:a","attrib":{"href":"/us/stat/37/384"},"text":"37 Stat. 384","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:277.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3507.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:330.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3522.","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"