{"tag":"section","attrib":{"id":"idbd11fa5b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1531"},"text":null,"children":[{"tag":"num","attrib":{"value":"1531"},"text":"§ 1531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of functions and activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd11fa5c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1531/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The balance of an appropriation available and necessary to finance or discharge a function or activity transferred or assigned under law within an executive agency or from one executive agency to another may be transferred to and used—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd11fa5d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1531/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the organizational unit or agency to which the function or activity was transferred or assigned; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd11fa5e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1531/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a purpose for which the appropriation was originally available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd11fa5f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1531/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the executive agency determines the amount that, with the approval of the President, is necessary to be transferred when the transfer or assignment of the function or activity is within the agency. The President determines the amount necessary to be transferred when the transfer or assignment of the function or activity is from one executive agency to another.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd11fa60-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1531/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A balance transferred under this section is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd11fa61-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1531/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" credited to an applicable existing or new appropriation account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd11fa62-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1531/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" merged with the amount in an account to which the balance is credited; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd11fa63-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1531/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the amount with which the balance is merged, accounted for as one amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd11fa64-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1531/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" New appropriation accounts may be established to carry out subsection (c)(1) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd11fa65-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/932"},"text":"96 Stat. 932","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd11fa66-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd11fa67-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd11fa68-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1531(a), (b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:581c(a)(1st sentence), (b)(1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-12/ch946/s202"},"text":"Sept. 12, 1950, ch. 946, § 202","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/838"},"text":"64 Stat. 838","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1531(c), (d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:581c(a)(last sentence), (b)(last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the defined term “executive agency” in section 102 of the revised title is substituted for “department or establishment” for consistency and clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “organizational unit or agency” are substituted for “agency”, and the word “appropriation” is substituted for “said funds”, for consistency and clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) is substituted for “which are hereby authorized to be established” because of the restatement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd11fa69-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd11fa6a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prohibition on Transfer of Funds to Other Departments and Agencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189/dA/tXVI/s1604"},"text":"Pub. L. 101–189, div. A, title XVI, § 1604","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/103/1598"},"text":"103 Stat. 1598","children":[],"tail":", provided that funds available for military functions of Department of Defense could not be made available to any other department or agency of Federal Government pursuant to a provision of law enacted after "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", unless, not less than 30 days before such funds were made available to such other department or agency, Secretary of Defense submitted to congressional defense committees a report describing effect on military preparedness of making such funds available to such department or agency, prior to repeal and restatement in "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2215"},"text":"section 2215 of Title 10","children":[],"tail":", Armed Forces, by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tXI/s1106/a/1"},"text":"Pub. L. 103–160, div. A, title XI, § 1106(a)(1)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1750"},"text":"107 Stat. 1750","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
