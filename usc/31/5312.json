html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5312(a)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1052(","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5312(a)(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1052(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5312(a)(5)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1052(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5312(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1052(f), (h).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the text of 31:1052(a) is omitted as unnecessary. The text of 31:1052(b) is omitted because of the restatement. The text of 31:1052(i) is omitted as unnecessary because the source provision is restated where necessary in the revised subchapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), (3), (4), and (5), the words “the Secretary . . . prescribes” are substituted for “specified by the Secretary by regulation”, “as the Secretary may by regulation specify”, “specified by the Secretary”, and “the Secretary shall by regulation specify” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2) and (3), the words “for the purposes of the provision of this chapter to which the regulation relates” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), before subclause (A), the words “any person which does business in any one or more of the following capacities” are omitted as surplus. In subclause (F), the words “savings bank, building and loan association, credit union, industrial bank, or other” are omitted as surplus. In subclause (T), the words “agency of the United States Government or of a State or local government” are substituted for “Federal, State, or local government institution” for consistency. In subclause (U), the words “type of” are omitted as surplus. The word “agency” is substituted for “institution” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3)(B)–(5), the word “prescribe” is substituted for “specify” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3)(B), the words “in addition”, and “and such types of” are omitted as surplus. The words “similar material” are substituted for “the equivalent thereof” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(4), the words “in addition to its meaning under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":"” are substituted for “natural persons, partnerships, . . . associations, corporations, and all entities cognizable as legal personalities” for consistency because 1:1 is applicable to all laws unless otherwise provided. The words “a trustee, a representative of an estate” are substituted for “trusts, estates”, and the word “entity” is substituted for “department or agency”, for consistency. The words “either for the purpose of this chapter generally or any particular requirement thereunder” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(5), the words “used in a geographic sense” are omitted because of the restatement. The words “either for the purposes of this chapter generally or any particular requirement thereunder” are omitted as surplus. The words “territory or” are added for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for 31:1052(f) and (h) to eliminate unnecessary words and for consistency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"idbd6300f2-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendment of Subsection (a)(2)","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dF/tLXI/s6110/a"},"text":"Pub. L. 116–283, div. F, title LXI, § 6110(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4561"},"text":"134 Stat. 4561","children":[],"tail":", provided that, effective on the effective date of the final rules issued by the Secretary of the Treasury pursuant to "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/s6110/b"},"text":"section 6110(b) of Pub. L. 116–283","children":[],"tail":" (set out below), subsection (a)(2) of this section is amended—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"(1) by redesignating subparagraphs (Y) and (Z) as subparagraphs (Z) and (AA), respectively; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"(2) by inserting after subparagraph (X) the following:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"“(Y) a person engaged in the trade of antiquities, including an advisor, consultant, or any other person who engages as a business in the solicitation or the sale of antiquities, subject to regulations prescribed by the Secretary;”.","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":"See 2021 Amendment note and Rulemaking note below.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd6300f3-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd6300f4-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Securities Exchange Act of 1934, referred to in subsec. (a)(2)(G), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1934-06-06/ch404"},"text":"act June 6, 1934, ch. 404","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/881"},"text":"48 Stat. 881","children":[],"tail":", which is classified principally to chapter 2B (§ 78a et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"section 78a of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Indian Gaming Regulatory Act, referred to in subsec. (a)(2)(X)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/497"},"text":"Pub. L. 100–497","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-17"},"text":"Oct. 17, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2467"},"text":"102 Stat. 2467","children":[],"tail":", which is classified principally to chapter 29 (§ 2701 et seq.) of Title 25, Indians. Section 4(6) of the Act is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s2703/6"},"text":"section 2703(6) of Title 25","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s2701"},"text":"section 2701 of this title","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Commodity Exchange Act, referred to in subsec. (c)(1)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-09-21/ch369"},"text":"act Sept. 21, 1922, ch. 369","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/998"},"text":"42 Stat. 998","children":[],"tail":", which is classified generally to chapter 1 (§ 1 et seq.) of Title 7, Agriculture. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t7/s1"},"text":"section 1 of Title 7","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd6300f5-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s6102/d/1/A"},"text":"Pub. L. 116–283, § 6102(d)(1)(A)","children":[],"tail":", substituted “, a transaction in money, credit, securities or gold, or a service provided with respect to money, securities, futures, precious metals, stones and jewels, or value that substitutes for currency” for “, or a transaction in money, credit, securities, or gold”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(J). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s6102/d/1/B/i"},"text":"Pub. L. 116–283, § 6102(d)(1)(B)(i)","children":[],"tail":", inserted “, or a business engaged in the exchange of currency, funds, or value that substitutes for currency or funds” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(R). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s6102/d/i/B/ii"},"text":"Pub. L. 116–283, § 6102(d)(i)(B)(ii)","children":[],"tail":", substituted “currency, funds, or value that substitutes for currency,” for “funds,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(Y) to (AA). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s6110/a/1"},"text":"Pub. L. 116–283, § 6110(a)(1)","children":[],"tail":", added subpar. (Y) and redesignated former subpars. (Y) and (Z) as (Z) and (AA), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s6102/d/1/C"},"text":"Pub. L. 116–283, § 6102(d)(1)(C)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6202/g"},"text":"Pub. L. 108–458, § 6202(g)","children":[],"tail":", made technical correction to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/s321/a"},"text":"Pub. L. 107–56, § 321(a)","children":[],"tail":". See 2001 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6203/b"},"text":"Pub. L. 108–458, § 6203(b)","children":[],"tail":", substituted “sections 5316 and 5331” for “sections 5333 and 5316”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s321/a"},"text":"Pub. L. 107–56, § 321(a)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6202/g"},"text":"Pub. L. 108–458, § 6202(g)","children":[],"tail":", amended subpar. (E) generally. Prior to amendment, subpar. (E) read as follows: “an insured institution (as defined in section 401(a) of the National Housing Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1724/a"},"text":"12 U.S.C. 1724(a)","children":[],"tail":"));”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(R). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s359/a"},"text":"Pub. L. 107–56, § 359(a)","children":[],"tail":", amended subpar. (R) generally. Prior to amendment, subpar. (R) read as follows: “a licensed sender of money;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s365/c/2/A"},"text":"Pub. L. 107–56, § 365(c)(2)(A)","children":[],"tail":", substituted “sections 5333 and 5316,” for “section 5316,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s365/c/1"},"text":"Pub. L. 107–56, § 365(c)(1)","children":[],"tail":", added par. (4) and redesignated former pars. (4) and (5) as (5) and (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s321/b"},"text":"Pub. L. 107–56, § 321(b)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(2)(X) to (Z). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s409"},"text":"Pub. L. 103–325, § 409","children":[],"tail":", added subpar. (X) and redesignated former subpars. (X) and (Y) as (Y) and (Z), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/325/s405"},"text":"Pub. L. 103–325, § 405","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (a)(2)(T) to (Y). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s6185/a"},"text":"Pub. L. 100–690, § 6185(a)","children":[],"tail":", added subpars. (T) to (Y) and struck out former subpars. (T) and (U) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(T) an agency of the United States Government or of a State or local government carrying out a duty or power of a business described in this clause (2), including the United States Postal Service; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(U) another business or agency carrying out a similar, related, or substitute duty or power the Secretary of the Treasury prescribes.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/s6185/g/1"},"text":"Pub. L. 100–690, § 6185(g)(1)","children":[],"tail":", inserted a comma after “Puerto Rico” and struck out second comma after “Pacific Islands”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(2)(T). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s1362/a"},"text":"Pub. L. 99–570, § 1362(a)","children":[],"tail":", which directed that the Postal Service be included within United States agencies by amending subsec. (a)(2)(U) of this section by inserting before the semicolon at the end thereof the following “, including the United States Postal Service”, was executed to subsec. (a)(2)(T) of this section as the probable intent of Congress, because subsec. (a)(2)(U) does not contain a semicolon and subsec. (a)(2)(T) relates to United States agencies."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/570/s1362/b"},"text":"Pub. L. 99–570, § 1362(b)","children":[],"tail":", inserted “the Virgin Islands, Guam, the Northern Mariana Islands, American Samoa, the Trust Territory of the Pacific Islands,” after “Puerto Rico”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd6300f6-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd6300f7-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dF/tLXI/s6110/a/2"},"text":"Pub. L. 116–283, div. F, title LXI, § 6110(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4562"},"text":"134 Stat. 4562","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dF/tLXI/s6110/a/2"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5312/a/2/Y"},"text":"Section 5312(a)(2)(Y) of title 31","children":[],"tail":", United States Code, as added by paragraph (1), shall take effect on the effective date of the final rules issued by the Secretary of the Treasury pursuant to subsection (b) [see note below].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd6300f8-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":", as of the date of enactment of such Act, and no amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" that is inconsistent with such amendment to be deemed to have taken effect, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/s6205"},"text":"section 6205 of Pub. L. 108–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t12/s1828"},"text":"section 1828 of Title 12","children":[],"tail":", Banks and Banking."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd6570f9-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rulemaking","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dF/tLXI/s6110/b"},"text":"Pub. L. 116–283, div. F, title LXI, § 6110(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4562"},"text":"134 Stat. 4562","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dF/tLXI/s6110/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 360 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":"], the Secretary of the Treasury shall issue proposed rules to carry out the amendments made by subsection (a) [amending this section]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before issuing a proposed rule under paragraph (1), the Secretary of the Treasury (acting through the Director of the FinCEN [Financial Crimes Enforcement Network of the Department of the Treasury]), in coordination with the Federal Bureau of Investigation, the Attorney General, and Homeland Security Investigations, shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate scope for the rulemaking, including determining which persons should be subject to the rulemaking, by size, type of business, domestic or international geographical locations, or otherwise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree to which the regulations should focus on high-value trade in antiquities, and on the need to identify the actual purchasers of such antiquities, in addition to the agents or intermediaries acting for or on behalf of such purchasers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need, if any, to identify persons who are dealers, advisors, consultants, or any other persons who engage as a business in the trade in antiquities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether thresholds should apply in determining which persons to regulate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether certain exemptions should apply to the regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other matter the Secretary determines appropriate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"idbd6570fa-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd6570fb-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Termination of Trust Territory of the Pacific Islands","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For termination of Trust Territory of the Pacific Islands, see note set out preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"section 1681 of Title 48","children":[],"tail":", Territories and Insular Possessions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
