{"tag":"section","attrib":{"id":"idbd6300c0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312"},"text":null,"children":[{"tag":"num","attrib":{"value":"5312"},"text":"§ 5312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd6300c1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6300c2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “financial agency” means a person acting for a person (except for a country, a monetary or financial authority acting as a monetary or financial authority, or an international financial institution of which the United States Government is a member) as a financial institution, bailee, depository trustee, or agent, or acting in a similar way related to money, credit, securities, gold, a transaction in money, credit, securities or gold, or a service provided with respect to money, securities, futures, precious metals, stones and jewels, or value that substitutes for currency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6300c3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “financial institution” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd6300c4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insured bank (as defined in section 3(h) of the Federal Deposit Insurance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1813/h"},"text":"12 U.S.C. 1813(h)","children":[],"tail":"));"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300c5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a commercial bank or trust company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300c6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private banker;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300c7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency or branch of a foreign bank in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300c8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any credit union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300c9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a thrift institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300ca-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a broker or dealer registered with the Securities and Exchange Commission under the Securities Exchange Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s78a"},"text":"15 U.S.C. 78a","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300cb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a broker or dealer in securities or commodities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300cc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an investment banker or investment company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300cd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a currency exchange, or a business engaged in the exchange of currency, funds, or value that substitutes for currency or funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300ce-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an issuer, redeemer, or cashier of travelers’ checks, checks, money orders, or similar instruments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300cf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an operator of a credit card system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300d0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an insurance company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300d1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a dealer in precious metals, stones, or jewels;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300d2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pawnbroker;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300d3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a loan or finance company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300d4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a travel agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300d5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a licensed sender of money or any other person who engages as a business in the transmission of currency, funds, or value that substitutes for currency, including any person who engages as a business in an informal money transfer system or any network of people who engage as a business in facilitating the transfer of money domestically or internationally outside of the conventional financial institutions system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300d6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/S"},"text":null,"children":[{"tag":"num","attrib":{"value":"S"},"text":"(S)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a telegraph company;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300d7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/T"},"text":null,"children":[{"tag":"num","attrib":{"value":"T"},"text":"(T)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a business engaged in vehicle sales, including automobile, airplane, and boat sales;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300d8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/U"},"text":null,"children":[{"tag":"num","attrib":{"value":"U"},"text":"(U)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" persons involved in real estate closings and settlements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300d9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300da-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/W"},"text":null,"children":[{"tag":"num","attrib":{"value":"W"},"text":"(W)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agency of the United States Government or of a State or local government carrying out a duty or power of a business described in this paragraph;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300db-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/X"},"text":null,"children":[{"tag":"num","attrib":{"value":"X"},"text":"(X)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a casino, gambling casino, or gaming establishment with an annual gaming revenue of more than $1,000,000 which—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd6300dc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/X/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed as a casino, gambling casino, or gaming establishment under the laws of any State or any political subdivision of any State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd6300dd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/X/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an Indian gaming operation conducted under or pursuant to the Indian Gaming Regulatory Act other than an operation which is limited to class I gaming (as defined in section 4(6) of such Act);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300de-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/Y"},"text":null,"children":[{"tag":"num","attrib":{"value":"Y"},"text":"(Y)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any business or agency which engages in any activity which the Secretary of the Treasury determines, by regulation, to be an activity which is similar to, related to, or a substitute for any activity in which any business described in this paragraph is authorized to engage; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300df-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/2/Z"},"text":null,"children":[{"tag":"num","attrib":{"value":"Z"},"text":"(Z)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other business designated by the Secretary whose cash transactions have a high degree of usefulness in criminal, tax, or regulatory matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6300e0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “monetary instruments” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd6300e1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States coins and currency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300e2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the Secretary may prescribe by regulation, coins and currency of a foreign country, travelers’ checks, bearer negotiable instruments, bearer investment securities, bearer securities, stock on which title is passed on delivery, and similar material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300e3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the Secretary of the Treasury shall provide by regulation for purposes of sections 5316 and 5331, checks, drafts, notes, money orders, and other similar instruments which are drawn on or by a foreign financial institution and are not in bearer form; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd6300e4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the Secretary shall provide by regulation, value that substitutes for any monetary instrument described in subparagraph (A), (B), or (C).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6300e5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonfinancial trade or business","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “nonfinancial trade or business” means any trade or business other than a financial institution that is subject to the reporting requirements of section 5313 and regulations prescribed under such section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6300e6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person”, in addition to its meaning under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":", includes a trustee, a representative of an estate and, when the Secretary prescribes, a governmental entity."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6300e7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States” means the States of the United States, the District of Columbia, and, when the Secretary prescribes by regulation, the Commonwealth of Puerto Rico, the Virgin Islands, Guam, the Northern Mariana Islands, American Samoa, the Trust Territory of the Pacific Islands, a territory or possession of the United States, or a military or diplomatic establishment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd6300e8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6300e9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “domestic financial agency” and “domestic financial institution” apply to an action in the United States of a financial agency or institution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd6300ea-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “foreign financial agency” and “foreign financial institution” apply to an action outside the United States of a financial agency or institution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd6300eb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subchapter, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd6300ec-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002088"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002088"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" "},{"tag":"inline","attrib":{},"text":"Certain institutions included in definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “financial institution” (as defined in subsection (a)) includes the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd6300ed-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5312/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002089"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002089"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. No subpar. (B) has been enacted."}],"tail":" Any futures commission merchant, commodity trading advisor, or commodity pool operator registered, or required to register, under the Commodity Exchange Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd6300ee-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/995"},"text":"96 Stat. 995","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/570/tI/s1362"},"text":"Pub. L. 99–570, title I, § 1362","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-27"},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3207-33"},"text":"100 Stat. 3207–33","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/690/tVI/s6185/a"},"text":"Pub. L. 100–690, title VI, § 6185(a)","children":[],"tail":", (g)(1), "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4354"},"text":"102 Stat. 4354","children":[],"tail":", 4357; "},{"tag":"ref","attrib":{"href":"/us/pl/103/325/tIV"},"text":"Pub. L. 103–325, title IV","children":[],"tail":", §§ 405, 409, "},{"tag":"date","attrib":{"date":"1994-09-23"},"text":"Sept. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/2247"},"text":"108 Stat. 2247","children":[],"tail":", 2252; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII"},"text":"Pub. L. 107–56, title III","children":[],"tail":", §§ 321(a), (b), 359(a), 365(c)(1), (2)(A), "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/315"},"text":"115 Stat. 315","children":[],"tail":", 328, 335; "},{"tag":"ref","attrib":{"href":"/us/pl/