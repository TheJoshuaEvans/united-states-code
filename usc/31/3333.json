{"tag":"section","attrib":{"id":"idbd275724-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3333"},"text":null,"children":[{"tag":"num","attrib":{"value":"3333"},"text":"§ 3333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relief for payments made without negligence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd275725-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd275726-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3333/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Treasury is not liable for a payment made by the Secretary or depositary in due course and without negligence, of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd275727-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3333/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a check, draft, or warrant drawn on the Treasury or the depositary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd275728-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3333/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electronic payment issued by the Treasury or the depositary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd275729-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3333/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a debt obligation guaranteed or assumed by the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd27572a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3333/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General shall credit the accounts of the Treasury or the depositary for the payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd27572b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3333/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the relief and the amount of any relief granted to an official or agent of the Department of the Treasury under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3527"},"text":"31 U.S.C. 3527","children":[],"tail":", shall be charged to the Check Forgery Insurance Fund ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3343"},"text":"31 U.S.C. 3343","children":[],"tail":"). A recovery or repayment of a loss for which replacement is made out of the fund shall be credited to the fund and is available for the purposes for which the fund was established."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd27572c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not relieve another individual from civil or criminal liability for a check, draft, warrant, or debt obligation of the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd27572d-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/956"},"text":"96 Stat. 956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dH/tII/s220/a"},"text":"Pub. L. 108–447, div. H, title II, § 220(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3242"},"text":"118 Stat. 3242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/161/dD/tI/s119"},"text":"Pub. L. 110–161, div. D, title I, § 119","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1979"},"text":"121 Stat. 1979","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd27572e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd27572f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd275730-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3333(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:156(less proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1947-08-04/ch455/s3"},"text":"Aug. 4, 1947, ch. 455, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/730"},"text":"61 Stat. 730","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3333(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:156(proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the words “Secretary of the Treasury” are substituted for “Treasurer” before “is not liable” because of the source provisions restated in section 321(c) of the revised title. The word “depositary” is substituted for “upon the Treasurer of the United States through any Federal Reserve Bank” for consistency in the revised title. The words “Whenever . . . heretofore has been or hereafter” and “or on behalf of” are omitted as surplus. In clause (A), the word “Treasury” is substituted for “Treasurer of the United States” after “drawn upon the” because of the source provisions restated in section 321 of the revised title and Department of the Treasury Order 229 of ","children":[{"tag":"date","attrib":{"date":"1974-01-14"},"text":"January 14, 1974","children":[],"tail":" (39 F.R. 2280). In clause (B), the words “public . . . of the United States, including any obligation of any type whatever, the payment of which is” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “of the United States” are omitted as unnecessary. The words “of the Treasury or the depositary” are substituted for “Treasurer’s” because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “another individual” are substituted for “any person, other than the Treasurer of the United States” to eliminate unnecessary words. The words “now existing or which may hereafter exist” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd275731-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd275732-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161"},"text":"Pub. L. 110–161","children":[],"tail":" added par. (3) and struck out former par. (3) which read as follows: “The amount of the relief shall be charged to the Check Forgery Insurance Fund ("},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3343"},"text":"31 U.S.C. 3343","children":[],"tail":"). A recovery or repayment of a loss for which replacement is made out of the fund shall be credited to the fund and is available for the purposes for which the fund was established.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s220/a/1"},"text":"Pub. L. 108–447, § 220(a)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follow: “The Secretary of the Treasury is not liable for a payment made by the Secretary or depositary in due course and without negligence, of a—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) check, draft, or warrant drawn on the Treasury or the depositary; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) debt obligation guaranteed or assumed by the United States Government.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/s220/a/2"},"text":"Pub. L. 108–447, § 220(a)(2)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
