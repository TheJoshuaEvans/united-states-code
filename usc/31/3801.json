{"tag":"section","attrib":{"id":"idbd46512a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801"},"text":null,"children":[{"tag":"num","attrib":{"value":"3801"},"text":"§ 3801.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd46512b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd46512c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “authority” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd46512d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an executive department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd46512e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a military department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd46512f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an establishment (as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s401"},"text":"section 401 of title 5","children":[],"tail":") which is not an executive department;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd465130-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Postal Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd465131-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Science Foundation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd465132-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a designated Federal entity (as such term is defined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s415/a"},"text":"section 415(a) of title 5","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd465133-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “authority head” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd465134-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the head of an authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd465135-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an official or employee of the authority designated, in regulations promulgated by the head of the authority, to act on behalf of the head of the authority;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd465136-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “claim” means any request, demand, or submission—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd465137-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made to an authority for property, services, or money (including money representing grants, loans, insurance, or benefits);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd465138-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" made to a recipient of property, services, or money from an authority or to a party to a contract with an authority—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd465139-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for property or services if the United States—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd46513a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/3/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided such property or services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd46513b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/3/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided any portion of the funds for the purchase of such property or services; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd46513c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/3/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will reimburse such recipient or party for the purchase of such property or services; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd46513d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for the payment of money (including money representing grants, loans, insurance, or benefits) if the United States—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd46513e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/3/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided any portion of the money requested or demanded; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd46513f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/3/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will reimburse such recipient or party for any portion of the money paid on such request or demand; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd465140-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made to an authority which has the effect of concealing or improperly avoiding or decreasing an obligation to pay or transmit property, services, or money to the authority,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that such term does not include any claim made in any return of tax imposed by the Internal Revenue Code of 1986;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd465141-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “investigating official” means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd465142-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd465143-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an authority in which an Office of Inspector General is established by chapter 4 of title 5 or by any other Federal law, is the Inspector General of that authority or an officer or employee of such Office designated by the Inspector General;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd465144-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an authority in which an Office of Inspector General is not established by chapter 4 of title 5 or by any other Federal law, is an officer or employee of the authority designated by the authority head to conduct investigations under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803/a/1"},"text":"section 3803(a)(1) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd465145-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a military department, is the Inspector General of the Department of Defense or an officer or employee of the Office of Inspector General of the Department of Defense who is designated by the Inspector General; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd465146-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, if a member of the Armed Forces of the United States on active duty, is serving in grade O–7 or above or, if a civilian employee, is serving in a position for which the rate of basic pay is not less than the minimum rate of basic pay for grade GS–16 under the General Schedule;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd465147-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “knows or has reason to know”, for purposes of establishing liability under section 3802, means that a person, with respect to a claim or statement—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd465148-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has actual knowledge that the claim or statement is false, fictitious, or fraudulent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd465149-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acts in deliberate ignorance of the truth or falsity of the claim or statement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd46514a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acts in reckless disregard of the truth or falsity of the claim or statement,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"and no proof of specific intent to defraud is required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd46514b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person” means any individual, partnership, corporation, association, or private organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd46514c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “presiding officer” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd46514d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an authority to which the provisions of subchapter II of chapter 5 of title 5 apply, an administrative law judge appointed in the authority pursuant to section 3105 of such title or detailed to the authority pursuant to section 3344 of such title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd46514e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the case of an authority to which the provisions of such subchapter do not apply, an officer or employee of the authority who—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd46514f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is selected under chapter 33 of title 5 pursuant to the competitive examination process applicable to administrative law judges;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd465150-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is appointed by the authority head to conduct hearings under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803"},"text":"section 3803 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd465151-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/7/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is assigned to cases in rotation so far as practicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd465152-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/7/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not perform duties inconsistent with the duties and responsibilities of a presiding officer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd465153-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/7/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is entitled to pay prescribed by the Office of Personnel Management independently of ratings and recommendations made by the authority and in accordance with chapter 51 of such title and subchapter III of chapter 53 of such title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd465154-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/7/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not subject to performance appraisal pursuant to chapter 43 of such title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd465155-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/7/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be removed, suspended, furloughed, or reduced in grade or pay only for good cause established and determined by the Merit Systems Protection Board on the record after opportunity for hearing by such Board; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd465156-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the board of contract appeals pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s7105"},"text":"section 7105 of title 41","children":[],"tail":", if the authority does not employ an available presiding officer under subparagraph (A);"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd465157-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “reviewing official” means any officer or employee of an authority—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd465158-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is designated by the authority head to make the determination required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803/a/2"},"text":"section 3803(a)(2) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd465159-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who, if a member of the Armed Forces of the United States on active duty, is serving in grade O–7 or above or, if a civilian employee, is serving in a position for which the rate of basic pay is not less than the minimum rate of basic pay for grade GS–16 under the General Schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd46515a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd46515b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/8/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not subject to supervision by, or required to report to, the investigating official; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd46515c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/8/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not employed in the organizational unit of the authority in which the investigating official is employed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd46515d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “statement” means any representation, certification, affirmation, document, record, or accounting or bookkeeping entry made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd46515e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to a claim or to obtain the approval or payment of a claim (including relating to eligibility to make a claim); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd46515f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to (including relating to eligibility for)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd465160-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a contract with, or a bid or proposal for a contract with; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd465161-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grant, loan, or benefit from,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"an authority, or any State, political subdivision of a State, or other party, if the United States Government provides any portion of the money or property under such contract or for such grant, loan, or benefit, or if the Government will reimburse such State, political subdivision, or party for any portion of the money or property under such contract or for such grant, loan, or benefit,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"except that such term does not include any statement made in any return of tax imposed by the Internal Revenue Code of 1986;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd465162-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “material” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3729/b"},"text":"section 3729(b) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd465163-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “obligation” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3729/b"},"text":"section 3729(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd465164-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (3) of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd465165-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each voucher, invoice, claim form, or other individual request or demand for property, services, or money constitutes a separate claim;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd465166-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each claim for property, services, or money is subject to this chapter regardless of whether such property, services, or money is actually delivered or paid; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd465167-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a claim shall be considered made, presented, or submitted to an authority, recipient, or party when such claim is actually made to an agent, fiscal intermediary, or other entity, including any State or political subdivision thereof, acting for or on behalf of such authority, recipient, or party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd465168-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of paragraph (9) of subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd465169-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each written representation, certification, or affirmation constitutes a separate statement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd46516a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement shall be considered made, presented, or submitted to an authority when such statement is actually made to an agent, fiscal intermediary, or other entity, including any State or political subdivision thereof, acting for or on behalf of such authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd46516b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3801/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of subsection (a)(10), materiality shall be determined in the same manner as under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3729"},"text":"section 3729 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd46516c-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVI/s6103/a"},"text":"Pub. L. 99–509, title VI, § 6103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1934"},"text":"100 Stat. 1934","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/f/1/Q"},"text":"Pub. L. 103–272, § 4(f)(1)(Q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1362"},"text":"108 Stat. 1362","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/69/tVII/s7017"},"text":"Pub. L. 110–69, title VII, § 7017","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-09"},"text":"Aug. 9, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/684"},"text":"121 Stat. 684","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/409/s10"},"text":"Pub. L. 110–409, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4314"},"text":"122 Stat. 4314","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/56"},"text":"Pub. L. 117–286, § 4(b)(56)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4349"},"text":"136 Stat. 4349","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLII/s5203/b/1"},"text":"Pub. L. 118–159, div. E, title LII, § 5203(b)(1)","children":[],"tail":", (g)(1)(A), (i), "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2440"},"text":"138 Stat. 2440","children":[],"tail":", 2442, 2443.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd46516d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd46516e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd46516f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in subsec. (a)(3), (9), is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd465170-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s5203/b/1"},"text":"Pub. L. 118–159, § 5203(b)(1)","children":[],"tail":", amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “made to an authority which has the effect of decreasing an obligation to pay or account for property, services, or money,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s5203/g/1/A"},"text":"Pub. L. 118–159, § 5203(g)(1)(A)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s5203/i/1"},"text":"Pub. L. 118–159, § 5203(i)(1)","children":[],"tail":", added pars. (10) and (11)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s5203/i/2"},"text":"Pub. L. 118–159, § 5203(i)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/56/A"},"text":"Pub. L. 117–286, § 4(b)(56)(A)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s401"},"text":"section 401 of title 5","children":[],"tail":")” for “section 11(2) of the Inspector General Act of 1978)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/56/B"},"text":"Pub. L. 117–286, § 4(b)(56)(B)","children":[],"tail":", substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s415/a"},"text":"section 415(a) of title 5","children":[],"tail":")” for “section 8G(a)(2) of the Inspector General Act of 1978)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/56/C"},"text":"Pub. L. 117–286, § 4(b)(56)(C)","children":[],"tail":", substituted “chapter 4 of title 5” for “the Inspector General Act of 1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/56/D"},"text":"Pub. L. 117–286, § 4(b)(56)(D)","children":[],"tail":", substituted “chapter 4 of title 5” for “the Inspector General Act of 1978”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/409"},"text":"Pub. L. 110–409","children":[],"tail":" added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/69"},"text":"Pub. L. 110–69","children":[],"tail":" added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(7)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803"},"text":"section 3803 of this title","children":[],"tail":"” for “section 3803 of such title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1986—Subsec. (a)(3), (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd465171-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idbd465172-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLII/s5203/a/2"},"text":"Pub. L. 118–159, div. E, title LII, § 5203(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2440"},"text":"138 Stat. 2440","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dE/tLII/s5203/a/2"},"text":"“Any reference to the Program Fraud Civil Remedies Act of 1986 in any provision of law, regulation, map, document, record, or other paper of the United States shall be deemed a reference to the Administrative False Claims Act [see Short Title note below].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd465173-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVI"},"text":"Pub. L. 99–509, title VI","children":[],"tail":", subtitle B (§§ 6101–6104), § 6104, "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1948"},"text":"100 Stat. 1948","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/509/tVI"},"text":"“This subtitle and the amendments made by this subtitle [see Short Title note below] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":"], and shall apply to any claim or statement made, presented, or submitted on or after such date.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idbd465174-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVI"},"text":"Pub. L. 99–509, title VI","children":[],"tail":", subtitle B (§§ 6101–6104), § 6101, "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1934"},"text":"100 Stat. 1934","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLII/s5203/a/1/B"},"text":"Pub. L. 118–159, div. E, title LII, § 5203(a)(1)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2440"},"text":"138 Stat. 2440","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dE/tLII/s5203/a/1/B"},"text":"“This subtitle [enacting this chapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s504"},"text":"section 504 of Title 5","children":[],"tail":", Government Organization and Employees, and enacting provisions set out as notes under this section] may be cited as the ‘Administrative False Claims Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd48c175-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLII/s5203/g/3"},"text":"Pub. L. 118–159, div. E, title LII, § 5203(g)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2443"},"text":"138 Stat. 2443","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dE/tLII/s5203/g/3"},"text":"“Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], each authority head, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3801"},"text":"section 3801 of title 31","children":[],"tail":", United States Code, and each board of contract appeals of a board described in subparagraph (B), (C), or (D) of section 7105(e)[(1)] of title 41, United States Code, shall amend procedures regarding proceedings as necessary to implement the amendments made by this subsection [amending this section, "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803"},"text":"section 3803 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s7105"},"text":"section 7105 of Title 41","children":[],"tail":", Public Contracts].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/dE/tLII/s5203/j"},"text":"Pub. L. 118–159, div. E, title LII, § 5203(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2443"},"text":"138 Stat. 2443","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/159/dE/tLII/s5203/j"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":"], each authority head, as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3801"},"text":"section 3801 of title 31","children":[],"tail":", United States Code, shall—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgate regulations and procedures to carry out this Act [probably should be “this section”, which amended this section, sections 3802, 3803, 3806, and 3808 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s405"},"text":"section 405 of Title 5","children":[],"tail":", Government Organization and Employees, and "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s7105"},"text":"section 7105 of Title 41","children":[],"tail":", Public Contracts, and enacted and amended provisions set out as notes under this section] and the amendments made by this Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and update existing regulations and procedures of the authority to ensure compliance with this Act and the amendments made by this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd48c176-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idbd48c177-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings and Purposes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVI"},"text":"Pub. L. 99–509, title VI","children":[],"tail":", subtitle B (§§ 6101–6104), § 6102, "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1934"},"text":"100 Stat. 1934","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/509/tVI"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" false, fictitious, and fraudulent claims and statements in Government programs are a serious problem;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" false, fictitious, and fraudulent claims and statements in Government programs result in the loss of millions of dollars annually by allowing persons to receive Federal funds to which they are not entitled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" false, fictitious, and fraudulent claims and statements in Government programs undermine the integrity of such programs by allowing ineligible persons to participate in such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present civil and criminal remedies for such claims and statements are not sufficiently responsive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subtitle [see Short Title note above] are—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide Federal agencies which are the victims of false, fictitious, and fraudulent claims and statements with an administrative remedy to recompense such agencies for losses resulting from such claims and statements, to permit administrative proceedings to be brought against persons who make, present, or submit such claims and statements, and to deter the making, presenting, and submitting of such claims and statements in the future; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide due process protections to all persons who are subject to the administrative adjudication of false, fictitious, or fraudulent claims or statements.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
