[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1606(a)(6).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 20, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/565"},"text":"Pub. L. 94–565","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/2662"},"text":"90 Stat. 2662","children":[],"tail":", § 6(a)(6); added "},{"tag":"html:span","attrib":{},"text":"Dec. 23, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/99/s912/a/3"},"text":"Pub. L. 97–99, § 912(a)(3)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/1387"},"text":"95 Stat. 1387","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6901(1)(G)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"16:715s(h)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-06-15/ch261"},"text":"June 15, 1935, ch. 261","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/378"},"text":"49 Stat. 378","children":[],"tail":", § 401(h)(1); added "},{"tag":"html:span","attrib":{},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/469/s1/a/4"},"text":"Pub. L. 95–469, § 1(a)(4)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1321"},"text":"92 Stat. 1321","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"6901(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:1606(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), before subclause (A), the text of 31:1606(b) is omitted as unnecessary because of the restatement of the source provisions. In subclause (A), the word “and” is substituted for “within each, or any combination thereof” to eliminate unnecessary words. The words “but not limited to” are omitted as surplus. In subclause (D), the words “effective ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":"” are omitted as executed. The words “Secretary of the Army” are substituted for “Army” for consistency. In subclause (E), the words “owned by the United States” are omitted as surplus. The words “Secretary of the Army” are substituted for “Army Corps of Engineers” because of 10:3012. In subclause (F), the word “Government” is added for clarity. In subclause (G), the words “In administering sections 1601 to 1607 of title 31” are omitted as unnecessary. The words “for fiscal years occurring after "},{"tag":"date","attrib":{"date":"1978-09-30"},"text":"September 30, 1978","children":[],"tail":"” are omitted as executed. Subclause (G) is substituted for 16:715s(h)(1) because of the restatement."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), before subclause (A), the word “general” is added for consistency in the title. In subclause (A), the word “parish” is omitted as unnecessary because of 1:2. The word “city” is substituted for “municipality” for consistency in the subtitle. The words “State of” are omitted as surplus. The words “political subdivision of a State” are substituted for “unit of government below the State” for consistency. The words “the basis of” are omitted as surplus. The word “basis” is substituted for “principle” for consistency in the subtitle. The words “Secretary of Commerce” are substituted for “Bureau of the Census”, and the words “general purpose political subdivision of a State” are substituted for “unit of general government”, for consistency. In subclause (B), the words “Such term also includes” are omitted as unnecessary. Subclause (D) is added because of section 502 of the Covenant to Establish a Commonwealth of the Northern Mariana Islands in Political Union with the United States of America.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd86b5d5-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd86b5d6-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5 of the Southern Nevada Public Land Management Act of 1998, referred to in par. (1)(H), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/263/s5"},"text":"section 5 of Pub. L. 105–263","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2347"},"text":"112 Stat. 2347","children":[],"tail":", subsec. (d) of which amended this section. Subsecs. (a) to (c) of section 5, which related to acquisition of certain environmentally sensitive land, are not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd86b5d7-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Par. (1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/263"},"text":"Pub. L. 105–263","children":[],"tail":" added subpar. (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Par. (2)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/83"},"text":"Pub. L. 105–83","children":[],"tail":" inserted “(other than in Alaska)” after “borough, or city”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/333"},"text":"Pub. L. 104–333","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “ ‘unit of general local government’ means:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) a county (or parish), township, borough, or city where the city is independent of any other unit of general local government, that: (i) is within the class or classes of such political subdivisions in a State that the Secretary of the Interior, in his discretion, determines to be the principal provider or providers of governmental services within the State; and (ii) is a unit of general government as determined by the Secretary of the Interior on the basis of the same principles as were used on ","children":[{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":", by the Secretary of Commerce for general statistical purposes. The term ‘governmental services’ includes, but is not limited to, those services that relate to public safety, environment, housing, social services, transportation, and governmental administration;"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the District of Columbia;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) the Commonwealth of Puerto Rico;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(D) Guam; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(E) the Virgin Islands.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/100/446"},"text":"Pub. L. 100–446","children":[],"tail":". See 1988 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/446"},"text":"Pub. L. 100–446","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":", struck out “existing in Alaska on "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"October 20, 1976","children":[],"tail":"” after “township, borough”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1983—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/63"},"text":"Pub. L. 98–63","children":[],"tail":" amended par. (2) generally, substituting in subpar. (A) “a county (or parish), township, borough existing in Alaska on "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"October 20, 1976","children":[],"tail":", or city where the city is independent of any other unit of general local government, that: (i) is within the class or classes of such political subdivisions in a State that the Secretary of the Interior, in his discretion, determines to be the principal provider or providers of governmental services within the State; and (ii) is a unit of general government as determined by the Secretary of the Interior on the basis of the same principles as were used on "},{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":", by the Secretary of Commerce for general statistical purposes. The term ‘governmental services’ includes, but is not limited to, those services that relate to public safety, environment, housing, social services, transportation, and governmental administration” for “a county, city, township, borough existing in Alaska on "},{"tag":"date","attrib":{"date":"1976-10-20"},"text":"October 20, 1976","children":[],"tail":", or other political subdivision of a State that the Secretary of the Interior, on the same basis that the Secretary of Commerce uses for general statistical purposes, decides is a general purpose political subdivision of a State”; including the District of Columbia in definition; and excluding the Commonwealth of the Northern Mariana Islands from definition."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd86b5d8-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd86b5d9-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/f/3"},"text":"Pub. L. 103–272, § 4(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1364"},"text":"108 Stat. 1364","children":[],"tail":", provided that the amendment made by that section is effective "},{"tag":"date","attrib":{"date":"1988-09-27"},"text":"Sept. 27, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd86b5da-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/263/s1"},"text":"Pub. L. 105–263, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-19"},"text":"Oct. 19, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2343"},"text":"112 Stat. 2343","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/263/s1"},"text":"“This Act [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s460ccc–1"},"text":"section 460ccc–1 of Title 16","children":[],"tail":", Conservation] may be cited as the ‘Southern Nevada Public Land Management Act of 1998’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd86b5db-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/397/s1"},"text":"Pub. L. 103–397, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-22"},"text":"Oct. 22, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4156"},"text":"108 Stat. 4156","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/397/s1"},"text":"“This Act [amending sections 6902 and 6903 of this title and enacting provisions set out as notes under sections 6902 and 6903 of this title] may be cited as the ‘Payments In Lieu of Taxes Act’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
