{"tag":"section","attrib":{"id":"idbd86b5bc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901"},"text":null,"children":[{"tag":"num","attrib":{"value":"6901"},"text":"§ 6901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd86b5bd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “entitlement land” means land owned by the United States Government—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd86b5be-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is in the National Park System or the National Forest System, including wilderness areas and lands described in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-22/s2"},"text":"section 2 of the Act of June 22, 1948","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s577d"},"text":"16 U.S.C. 577d","children":[],"tail":"), and "},{"tag":"ref","attrib":{"href":"/us/act/1956-06-22/s1"},"text":"section 1 of the Act of June 22, 1956","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s577d–1"},"text":"16 U.S.C. 577d–1","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b5bf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Interior administers through the Bureau of Land Management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b5c0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dedicated to the use of the Government for water resource development projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b5c1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on which are located semi-active or inactive installations (except industrial installations) that the Secretary of the Army keeps for mobilization and for reserve component training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b5c2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is a dredge disposal area under the jurisdiction of the Secretary of the Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b5c3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is located in the vicinity of Purgatory River Canyon and Pinon Canyon, Colorado, and acquired after ","children":[{"tag":"date","attrib":{"date":"1981-12-23"},"text":"December 23, 1981","children":[],"tail":", by the United States Government to expand the Fort Carson military installation;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b5c4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is a reserve area (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-06-15/s401/g/3"},"text":"section 401(g)(3) of the Act of June 15, 1935","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s715s/g/3"},"text":"16 U.S.C. 715s(g)(3)","children":[],"tail":")); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b5c5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired by the Secretary of the Interior or the Secretary of Agriculture under section 5 of the Southern Nevada Public Land Management Act of 1998 that is not otherwise described in subparagraphs (A) through (G).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd86b5c6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd86b5c7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “unit of general local government” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd86b5c8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a county (or parish), township, borough, or city (other than in Alaska) where the city is independent of any other unit of general local government, that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idbd86b5c9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is within the class or classes of such political subdivision in a State that the Secretary of the Interior, in his discretion, determines to be the principal provider or providers of governmental services within the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idbd86b5ca-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a unit of general government, as determined by the Secretary of the Interior on the basis of the same principles as were used by the Secretary of Commerce on ","children":[{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":", for general statistical purposes;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd86b5cb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any area in Alaska that is within the boundaries of a census area used by the Secretary of Commerce in the decennial census, but that is not included within the boundary of a governmental entity described under clause (i);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd86b5cc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd86b5cd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commonwealth of Puerto Rico;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd86b5ce-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Guam; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd86b5cf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd86b5d0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s6901/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “governmental services” includes, but is not limited to, those services that relate to public safety, the environment, housing, social services, transportation, and governmental administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd86b5d1-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1031"},"text":"96 Stat. 1031","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/63/tI"},"text":"Pub. L. 98–63, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-07-30"},"text":"July 30, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/97/323"},"text":"97 Stat. 323","child