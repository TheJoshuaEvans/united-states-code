ildren":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:665(a), (d)(2)(last sentence related to spending and obligations).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"R.S. § 3679(a), (d)(2)(last sentence related to spending and obligations); ","children":[{"tag":"html:a","attrib":{"href":"/us/act/1905-03-03/ch1484/s4"},"text":"Mar. 3, 1905, ch. 1484, § 4","children":[],"tail":"(1st par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/33/1257"},"text":"33 Stat. 1257","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1906-02-27/ch510/s3"},"text":"Feb. 27, 1906, ch. 510, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/48"},"text":"34 Stat. 48","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1950-09-06/ch896/s1211"},"text":"Sept. 6, 1950, ch. 896, § 1211","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/765"},"text":"64 Stat. 765","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1341(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:669(words after semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1912-08-23/ch350/s6"},"text":"Aug. 23, 1912, ch. 350, § 6","children":[],"tail":"(words after semicolon), "},{"tag":"html:a","attrib":{"href":"/us/stat/37/414"},"text":"37 Stat. 414","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “another amount available for obligation” are substituted for “any other fund” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd0ace95-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd0ace96-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 252 of the Balanced Budget and Emergency Deficit Control Act of 1985, referred to in subsec. (a)(1)(C), (D), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s902"},"text":"section 902 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd0ace97-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/1/s2/1"},"text":"Pub. L. 116–1, § 2(1)","children":[],"tail":", in introductory provisions, substituted “Except as specified in this subchapter or any other provision of law, an officer” for “An officer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/1/s2/2"},"text":"Pub. L. 116–1, § 2(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/5"},"text":"Pub. L. 116–5","children":[],"tail":" inserted “, and subject to the enactment of appropriations Acts ending the lapse” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1990—Subsec. (a)(1)(C), (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Pub. L. 101–508","children":[],"tail":" added subpars. (C) and (D)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
