{"tag":"section","attrib":{"id":"idbd0ace7d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341"},"text":null,"children":[{"tag":"num","attrib":{"value":"1341"},"text":"§ 1341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on expending and obligating amounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0ace7e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0ace7f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as specified in this subchapter or any other provision of law, an officer or employee of the United States Government or of the District of Columbia government may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0ace80-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make or authorize an expenditure or obligation exceeding an amount available in an appropriation or fund for the expenditure or obligation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0ace81-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve either government in a contract or obligation for the payment of money before an appropriation is made unless authorized by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0ace82-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make or authorize an expenditure or obligation of funds required to be sequestered under section 252 of the Balanced Budget and Emergency Deficit Control Act of 1985; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0ace83-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve either government in a contract or obligation for the payment of money required to be sequestered under section 252 of the Balanced Budget and Emergency Deficit Control Act of 1985.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0ace84-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not apply to a corporation getting amounts to make loans (except paid in capital amounts) without legal liability of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0ace85-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An article to be used by an executive department in the District of Columbia that could be bought out of an appropriation made to a regular contingent fund of the department may not be bought out of another amount available for obligation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0ace86-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0ace87-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0ace88-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “covered lapse in appropriations” means any lapse in appropriations that begins on or after ","children":[{"tag":"date","attrib":{"date":"2018-12-22"},"text":"December 22, 2018","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0ace89-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “District of Columbia public employer” means—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbd0ace8a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia Courts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd0ace8b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Public Defender Service for the District of Columbia; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbd0ace8c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia government;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0ace8d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employee” includes an officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0ace8e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “excepted employee” means an excepted employee or an employee performing emergency work, as such terms are defined by the Office of Personnel Management or the appropriate District of Columbia public employer, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0ace8f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each employee of the United States Government or of a District of Columbia public employer furloughed as a result of a covered lapse in appropriations shall be paid for the period of the lapse in appropriations, and each excepted employee who is required to perform work during a covered lapse in appropriations shall be paid for such work, at the employee’s standard rate of pay, at the earliest date possible after the lapse in appropriations ends, regardless of scheduled pay dates, and subject to the enactment of appropriations Acts ending the lapse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0ace90-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1341/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During a covered lapse in appropriations, each excepted employee who is required to perform work shall be entitled to use leave under chapter 63 of title 5, or any other applicable law governing the use of leave by the excepted employee, for which compensation shall be paid at the earliest date possible after the lapse in appropriations ends, regardless of scheduled pay dates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0ace91-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/923"},"text":"96 Stat. 923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXIII/s13213/a"},"text":"Pub. L. 101–508, title XIII, § 13213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-621"},"text":"104 Stat. 1388–621","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/1/s2"},"text":"Pub. L. 116–1, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-16"},"text":"Jan. 16, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/3"},"text":"133 Stat. 3","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/5/s103"},"text":"Pub. L. 116–5, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-25"},"text":"Jan. 25, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/11"},"text":"133 Stat. 11","children":[],"tail":".)"}],"tail":"\n"},