{"tag":"section","attrib":{"id":"idbd5e454b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5152"},"text":null,"children":[{"tag":"num","attrib":{"value":"5152"},"text":"§ 5152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Value of United States money holdings in international institutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury shall maintain the value in terms of gold of the holdings of United States money of the International Bank for Reconstruction and Development, the Inter-American Development Bank, the International Development Association, and the Asian Development Bank to the extent provided in the articles of agreement of those institutions. Amounts necessary to maintain the value may be appropriated. Amounts appropriated under this section remain available until expended.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idbd5e454c-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/992"},"text":"96 Stat. 992","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd5e454d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd5e454e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd5e454f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"ta