{"tag":"section","attrib":{"id":"idbd35af41-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555"},"text":null,"children":[{"tag":"num","attrib":{"value":"3555"},"text":"§ 3555.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations; authority of Comptroller General to verify assertions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd35af42-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General shall prescribe such procedures as may be necessary to the expeditious decision of protests under this subchapter, including procedures for accelerated resolution of protests under the express option authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3554/a/2"},"text":"section 3554(a)(2) of this title","children":[],"tail":". Such procedures shall provide that the protest process may not be delayed by the failure of a party to make a filing within the time provided for the filing."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd35af43-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The procedures shall provide that, in the computation of any period described in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd35af44-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the day of the act, event, or default from which the designated period of time begins to run not be included; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd35af45-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the last day after such act, event, or default be included, unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd35af46-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such last day is a Saturday, a Sunday, or a legal holiday; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd35af47-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a filing of a paper at the Government Accountability Office or a Federal agency, such last day is a day on which weather or other conditions cause the closing of the Government Accountability Office or Federal agency, in which event the next day that is not a Saturday, Sunday, or legal holiday shall be included.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd35af48-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic Filing and Document Dissemination System.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd35af49-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and operation of system","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General shall establish and operate an electronic filing and document dissemination system under which, in accordance with procedures prescribed by the Comptroller General—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd35af4a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person filing a protest under this subchapter may file the protest through electronic means; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd35af4b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all documents and information required with respect to the protest may be disseminated and made available to the parties to the protest through electronic means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd35af4c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Imposition of fees.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd35af4d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General may require each person who files a protest under this subchapter to pay a fee to support the establishment and operation of the electronic system under this subsection, without regard to whether or not the person uses the system with respect to the protest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd35af4e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall establish (and from time to time shall update) a schedule setting forth the amount of the fee to be paid under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd35af4f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of amounts collected.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd35af50-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall maintain a separate account among the accounts of the Government Accountability Office for the electronic system under this subsection, and shall deposit all amounts received as fees under paragraph (2) into the account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd35af51-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts in the account maintained under this paragraph shall be available to the Comptroller General, without fiscal year limitation, solely to establish and operate the electronic system under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd35af52-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3555/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Comptroller General may use any authority available under chapter 7 of this title and this chapter to verify assertions made by parties in protests under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd35af53-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369/dB/tVII/s2741/a"},"text":"Pub. L. 98–369, div. B, title VII, § 2741(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1202"},"text":"98 Stat. 1202","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tI/s1404"},"text":"Pub. L. 103–355, title I, § 1404","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3291"},"text":"108 Stat. 3291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/dI/tI/s1501"},"text":"Pub. L. 113–76, div. I, title I, § 1501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/433"},"text":"128 Stat. 433","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd35af54-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd35af55-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd35af56-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76"},"text":"Pub. L. 113–76","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, subsec. (c) read as follows: “The Comptroller General may prescribe procedures for the electronic filing and dissemination of documents and information required under this subchapter. In prescribing such procedures, the Comptroller General shall consider the ability of all parties to achieve electronic access to such documents and records.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/271"},"text":"Pub. L. 108–271","children":[],"tail":" substituted “Government Accountability Office” for “General Accounting Office” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/s1404/c"},"text":"Pub. L. 103–355, § 1404(c)","children":[],"tail":", substituted “The Comptroller General” for “Not later than "},{"tag":"date","attrib":{"date":"1985-01-15"},"text":"January 15, 1985","children":[],"tail":", the Comptroller General”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355/s1404/a"},"text":"Pub. L. 103–355, § 1404(a)","children":[],"tail":", (b), added subsecs. (b) and (c) and redesignated former subsec. (b) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd381f57-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd381f58-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date and applicability of amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/355"},"text":"Pub. L. 103–355","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/s10001"},"text":"section 10001 of Pub. L. 103–355","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s8752"},"text":"section 8752 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idbd381f59-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable with respect to any protest filed after ","children":[{"tag":"date","attrib":{"date":"1985-01-14"},"text":"Jan. 14, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/s2751/b"},"text":"section 2751(b) of Pub. L. 98–369","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4751"},"text":"section 4751 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
