{"tag":"section","attrib":{"id":"idbd8de0f7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9104"},"text":null,"children":[{"tag":"num","attrib":{"value":"9104"},"text":"§ 9104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional action on budgets of wholly owned Government corporations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd8de0f8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Congress shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd8de0f9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider budget programs for wholly owned Government corporations the President submits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8de0fa-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make necessary appropriations authorized by law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8de0fb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9104/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make corporate financial resources available for operating and administrative expenses; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd8de0fc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s9104/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"te