":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/201/s1"},"text":"Pub. L. 107–201, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-07-23"},"text":"July 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/736"},"text":"116 Stat. 736","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/201/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s5116"},"text":"section 5116 of this title","children":[],"tail":" and enacting provisions set out as notes under sections 5112 and 5116 of this title] may be cited as the ‘Support of American Eagle Silver Bullion Program Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd4d7c4d-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/445/s1"},"text":"Pub. L. 106–445, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1931"},"text":"114 Stat. 1931","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/445/s1"},"text":"“This Act [amending sections 5112, 5132 and 5134 of this title] may be cited as the ‘United States Mint Numismatic Coin Clarification Act of 2000’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idbd4d7c4e-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/124/s1"},"text":"Pub.