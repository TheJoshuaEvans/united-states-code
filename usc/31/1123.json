{"tag":"section","attrib":{"id":"idbd0613cb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1123"},"text":null,"children":[{"tag":"num","attrib":{"value":"1123"},"text":"§ 1123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Operating Officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0613cc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At each agency, the deputy head of agency, or equivalent, shall be the Chief Operating Officer of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0613cd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each Chief Operating Officer shall be responsible for improving the management and performance of the agency, and shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0613ce-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide overall organization management to improve agency performance and achieve the mission and goals of the agency through the use of strategic and performance planning, measurement, analysis, regular assessment of progress, and use of performance information to improve the results achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0613cf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise and assist the head of agency in carrying out the requirements of sections 1115 through 1122 of this title and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0613d0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1123/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee agency-specific efforts to improve management functions within the agency and across Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0613d1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1123/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and collaborate with relevant personnel within and external to the agency who have a significant role in contributing to and achieving the mission and goals of the agency, such as the Chief Financial Officer, Chief Human Capital Officer, Chief Acquisition Officer/Senior Procurement Executive, Chief Information Officer, and other line of business chiefs at the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd0613d2-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/352/s8"},"text":"Pub. L. 111–352, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3878"},"text":"124 Stat. 3878","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
