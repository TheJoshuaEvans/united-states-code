{"tag":"section","attrib":{"id":"idbd7613de-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5366"},"text":null,"children":[{"tag":"num","attrib":{"value":"5366"},"text":"§ 5366.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd7613df-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5366/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person who violates section 5363 shall be fined under title 18, imprisoned for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd7613e0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5366/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permanent Injunction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon conviction of a person under this section, the court may enter a permanent injunction enjoining such person from placing, receiving, or otherwise making bets or wagers or sending, receiving, or inviting information assisting in the placing of bets or wagers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd7613e1-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/347/tVIII/s802/a"},"text":"Pub. L. 109–347, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-13"},"text":"Oct. 13, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1961"},"text":"120 Stat. 1961","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
