{"tag":"section","attrib":{"id":"idbd0ace59-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1324"},"text":null,"children":[{"tag":"num","attrib":{"value":"1324"},"text":"§ 1324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refund of internal revenue collections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd0ace5a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Necessary amounts are appropriated to the Secretary of the Treasury for refunding internal revenue collections as provided by law, including payment of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0ace5b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1324/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" claims for prior fiscal years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0ace5c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1324/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" accounts arising under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd0ace5d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1324/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Allowance or drawback (Internal Revenue)”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0ace5e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1324/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Redemption of stamps (Internal Revenue)”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0ace5f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1324/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Refunding legacy taxes, Act of ","children":[{"tag":"date","attrib":{"date":"1928-03-30"},"text":"March 30, 1928","children":[],"tail":"”;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0ace60-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1324/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Repayment of taxes on distilled spirits destroyed by casualty”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd0ace61-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1324/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Refunds and payments of processing and related taxes”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd0ace62-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Disbursements may be made from the appropriation made by this section only for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd0ace63-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s1324/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refunds to the limit of liability of an individual tax account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd0ac