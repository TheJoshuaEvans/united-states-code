{"tag":"section","attrib":{"id":"idbd5719b5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118"},"text":null,"children":[{"tag":"num","attrib":{"value":"5118"},"text":"§ 5118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gold clauses and consent to sue","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd5719b6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5719b7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “gold clause” means a provision in or related to an obligation alleging to give the obligee a right to require payment in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd5719b8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gold;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd5719b9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a particular United States coin or currency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd5719ba-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" United States money measured in gold or a particular United States coin or currency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5719bb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “public debt obligation” means a domestic obligation issued or guaranteed by the United States Government to repay money or interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5719bc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The United States Government may not pay out any gold coin. A person lawfully holding United States coins and currency may present the coins and currency to the Secretary of the Treasury for exchange (dollar for dollar) for other United States coins and currency (other than gold and silver coins) that may be lawfully held. The Secretary shall make the exchange under regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5719bd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5719be-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Government withdraws its consent given to anyone to assert against the Government, its agencies, or its officers, employees, or agents, a claim—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd5719bf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a gold clause public debt obligation or interest on the obligation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd5719c0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for United States coins or currency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd5719c1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arising out of the surrender, requisition, seizure, or acquisition of United States coins or currency, gold, or silver involving the effect or validity of a change in the metallic content of the dollar or in a regulation about the value of money.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5719c2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) of this subsection does not apply to a proceeding in which no claim is made for payment or credit in an amount greater than the face or nominal value in dollars of public debt obligations or United States coins or currency involved in the proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5719c3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except when consent is not withdrawn under this subsection, an amount appropriated for payment on public debt obligations and for United States coins and currency may be expended only dollar for dollar.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd5719c4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd5719c5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, “obligation” means any obligation (except United States currency) payable in United States money.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd5719c6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5118/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An obligation issued containing a gold clause or governed by a gold clause is discharged on payment (dollar for dollar) in United States coin or currency that is legal tender at the time of payment. This paragraph does not apply to an obligation issued after ","children":[{"tag":"date","attrib":{"date":"1977-10-27"},"text":"October 27, 1977","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd5719c7-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/985"},"text":"96 Stat. 985","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/185/s2/d"},"text":"Pub. L. 99–185, § 2(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1985-12-17"},"text":"Dec. 17, 1985","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/99/1178"},"text":"99 Stat. 1178","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/208/dA/tII/s2609"},"text":"Pub. L. 104–208, div. A, title II, § 2609","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3009-475"},"text":"110 Stat. 3009–475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/61/tVI/s641"},"text":"Pub. L. 105–61, title VI, § 641","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-10-10"},"text":"Oct. 10, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1318"},"text":"111 Stat. 1318","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd5719c8-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd5719c9-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd5719ca-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5118(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:773d.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1935-08-27/ch780"},"text":"Aug. 27, 1935, ch. 780","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/938"},"text":"49 Stat. 938","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5118(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:315b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1934-01-30/ch6/s5"},"text":"Jan. 30, 1934, ch. 6, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/340"},"text":"48 Stat. 340","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:773a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"5118(c)(1), (2)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:773b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5118(c)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:773c.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5118(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:463.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1933-06-05/ch48/s1"},"text":"June 5, 1933, ch. 48, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/113"},"text":"48 Stat. 113","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:463(note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 28, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/147/s4/c"},"text":"Pub. L. 95–147, § 4(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1229"},"text":"91 Stat. 1229","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “the phrase” are omitted as surplus. In clause (1), the words “declared to be against public policy by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s463"},"text":"section 463 of this title","children":[],"tail":"” are omitted as surplus. Clause (2) is substituted for 31:773d(words after semicolon) for consistency in the revised title and to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “after ","children":[{"tag":"date","attrib":{"date":"1934-01-30"},"text":"January 30, 1934","children":[],"tail":"” in 31:315b are omitted as executed. The words “that may be lawfully held” are substituted for “which may be lawfully acquired and are legal tender for public and private debts” in 31:773a for consistency in the subsection and to eliminate unnecessary words. The words “and that the owners of the gold clause securities of the United States shall be, at their election, entitled to receive immediate payment of the stated dollar amount thereof with interest to the date of payment or to prior maturity or to prior redemption date, whichever is earlier” in "},{"tag":"ref","attrib":{"href":"/us/act/1935-08-27/s1"},"text":"section 1 of the Act of August 27, 1935","children":[],"tail":" (ch. 780, "},{"tag":"ref","attrib":{"href":"/us/stat/49/938"},"text":"49 Stat. 938","children":[],"tail":"), are omitted as expired. The words “make the exchange” are substituted for “make such exchanges and payments upon presentation hereunder” to eliminate unnecessary words. The words “No gold shall after "},{"tag":"date","attrib":{"date":"1934-01-30"},"text":"January 30, 1934","children":[],"tail":", be coined” in 31:315b are omitted because of section 5112 of the revised title. The text of 31:315b(proviso) is omitted as unnecessary because of the restatement. The text of 31:315b(last sentence) is omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), before clause (A), the word “Government” is substituted for “United States” for consistency in the revised title and with other titles of the United States Code. The words “to anyone” are added for clarity. The words “whether by way of suit, counterclaim, set-off, recoupment, or other affirmative action or defense in its own name or in the name of” are omitted as surplus. The word “employees” is added for consistency in the revised title and with other titles of the Code. The word “instrumentalities” is omitted as unnecessary because of section 101 of the revised title. The word “claim” is substituted for “right, privilege, or power” to eliminate unnecessary words and for consistency in the revised title and with other titles of the Code. The words “in any proceeding of any nature whatsoever” are omitted as surplus. In clause (C), the words “or demand” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “any suit commenced prior to ","children":[{"tag":"date","attrib":{"date":"1935-08-27"},"text":"August 27, 1935","children":[],"tail":", or which may be commenced by "},{"tag":"date","attrib":{"date":"1936-01-01"},"text":"January 1, 1936","children":[],"tail":"” are omitted as executed. The words “referred to in this section” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “may be expended” are substituted for “an amount appropriated or authorized to be expended” and “shall be available for or expended in”, and the words “dollar for dollar” are substituted for “on an equal and uniform dollar for dollar basis”, to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1), the words “including every obligation of and to the United States” are omitted as surplus. The text of 31:463(b)(words after semicolon) is omitted as unnecessary because of the restatement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd598acb-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd598acc-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/61"},"text":"Pub. L. 105–61","children":[],"tail":" struck out at end “This paragraph shall apply to any obligation issued on or before "},{"tag":"date","attrib":{"date":"1977-10-27"},"text":"October 27, 1977","children":[],"tail":", notwithstanding any assignment or novation of such obligation after "},{"tag":"date","attrib":{"date":"1977-10-27"},"text":"October 27, 1977","children":[],"tail":", unless all parties to the assignment or novation specifically agree to include a gold clause in the new agreement. Nothing in the preceding sentence shall be construed to affect the enforceability of a Gold Clause contained in any obligation issued after "},{"tag":"date","attrib":{"date":"1977-10-27"},"text":"October 27, 1977","children":[],"tail":" if the enforceability of that Gold Clause has been finally adjudicated before the date of enactment of the Economic Growth and Regulatory Paperwork Reduction Act of 1996.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/208"},"text":"Pub. L. 104–208","children":[],"tail":" inserted at end “This paragraph shall apply to any obligation issued on or before "},{"tag":"date","attrib":{"date":"1977-10-27"},"text":"October 27, 1977","children":[],"tail":", notwithstanding any assignment or novation of such obligation after "},{"tag":"date","attrib":{"date":"1977-10-27"},"text":"October 27, 1977","children":[],"tail":", unless all parties to the assignment or novation specifically agree to include a gold clause in the new agreement. Nothing in the preceding sentence shall be construed to affect the enforceability of a Gold Clause contained in any obligation issued after "},{"tag":"date","attrib":{"date":"1977-10-27"},"text":"October 27, 1977","children":[],"tail":" if the enforceability of that Gold Clause has been finally adjudicated before the date of enactment of the Economic Growth and Regulatory Paperwork Reduction Act of 1996.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—Subsec.(b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/185"},"text":"Pub. L. 99–185","children":[],"tail":" struck out “or deliver” after “pay out” and inserted “(other than gold and silver coins)” before “that may be lawfully held”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbd598acd-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbd598ace-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1985 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/185"},"text":"Pub. L. 99–185","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-10-01"},"text":"Oct. 1, 1985","children":[],"tail":", except that no coins may be issued or sold under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112/i"},"text":"section 5112(i) of this title","children":[],"tail":" before "},{"tag":"date","attrib":{"date":"1986-10-01"},"text":"Oct. 1, 1986","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/99/185/s3"},"text":"section 3 of Pub. L. 99–185","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s5112"},"text":"section 5112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
