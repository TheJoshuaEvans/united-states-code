{"tag":"section","attrib":{"id":"idbd89268b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7106"},"text":null,"children":[{"tag":"num","attrib":{"value":"7106"},"text":"§ 7106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delegation of supervision of assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"With the approval of the President, the head of an executive agency may delegate or otherwise arrange to have another executive agency carry out or supervise a project or class of projects jointly financed under this chapter. A delegation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd89268c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7106/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be made under conditions ensuring that duties and powers delegated are exercised consistent with law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd89268d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s7106/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not relieve the head of an executive agency of responsibility for the proper and efficient management of a project for which the agency provides assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd89268e-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1038"},"text":"96 Stat. 1038","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd89268f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbd892690-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbd892691-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"7106","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"42:4256.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Dec. 5, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/510/s7"},"text":"Pub. L. 93–510, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1606"},"text":"88 Stat. 1606","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, before clause (1), the words “to have another executive agency carry out or supervise” are substituted for “to other Federal agencies powers and functions relating to the supervision or administration” to eliminate unnecessary words. In clause (1), the words “under conditions ensuring” are substituted for “only on such conditions as may be appropriate to assure”, the word “consistent” is substituted for “in full conformity”, and the word “law” is substituted for “applicable statutory provisions and policies”, to eliminate unnecessary words. In clause (2), the words “for which the agency provides assistance” are substituted for “funded by their agencies”, for clarity because the source provisions do not provide for funding. The words “of Federal assistance”, “for other agencies to perform”, “such activities with respect to”, and “under this section” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
