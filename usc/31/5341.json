{"tag":"section","attrib":{"id":"idbd73a2bf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341"},"text":null,"children":[{"tag":"num","attrib":{"value":"5341"},"text":"§ 5341.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National money laundering and related financial crimes strategy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd73a2c0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development and Transmittal to Congress.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd73a2c1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President, acting through the Secretary and in consultation with the Attorney General, shall develop a national strategy for combating money laundering and related financial crimes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2c2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transmittal to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"By August 1 of 1999, 2000, 2001, 2002, 2003, 2005, and 2007, the President shall submit a national strategy developed in accordance with paragraph (1) to the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2c3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separate presentation of classified material","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any part of the strategy that involves information which is properly classified under criteria established by Executive Order shall be submitted to the Congress separately in classified form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd73a2c4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of Strategy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The national strategy for combating money laundering and related financial crimes shall address any area the President, acting through the Secretary and in consultation with the Attorney General, considers appropriate, including the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd73a2c5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goals, objectives, and priorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Comprehensive, research-based goals, objectives, and priorities for reducing money laundering and related financial crime in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2c6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prevention","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Coordination of regulatory and other efforts to prevent the exploitation of financial systems in the United States for money laundering and related financial crimes, including a requirement that the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd73a2c7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" regularly review enforcement efforts under this subchapter and other provisions of law and, when appropriate, modify existing regulations or prescribe new regulations for purposes of preventing such criminal activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd73a2c8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate prevention efforts and other enforcement action with the Board of Governors of the Federal Reserve System, the Securities and Exchange Commission, the Federal Trade Commission, other Federal banking agencies, the National Credit Union Administration Board, and such other Federal agencies as the Secretary, in consultation with the Attorney General, determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2c9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detection and prosecution initiatives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A description of operational initiatives to improve detection and prosecution of money laundering and related financial crimes and the seizure and forfeiture of proceeds and instrumentalities derived from such crimes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2ca-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enhancement of the role of the private financial sector in prevention","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The enhancement of partnerships between the private financial sector and law enforcement agencies with regard to the prevention and detection of money laundering and related financial crimes, including providing incentives to strengthen internal controls and to adopt on an industrywide basis more effective policies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2cb-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enhancement of intergovernmental cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The enhancement of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd73a2cc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperative efforts between the Federal Government and State and local officials, including State and local prosecutors and other law enforcement officials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd73a2cd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperative efforts among the several States and between State and local officials, including State and local prosecutors and other law enforcement officials,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"for financial crimes control which could be utilized or should be encouraged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2ce-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project and budget priorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A 3-year projection for program and budget priorities and achievable projects for reductions in financial crimes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2cf-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment of funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A complete assessment of how the proposed budget is intended to implement the strategy and whether the funding levels contained in the proposed budget are sufficient to implement the strategy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2d0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designated areas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A description of geographical areas designated as “high-risk money laundering and related financial crime areas” in accordance with, but not limited to, section 5342.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2d1-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons consulted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Persons or officers consulted by the Secretary pursuant to subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2d2-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data regarding trends in money laundering and related financial crimes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The need for additional information necessary for the purpose of developing and analyzing data in order to ascertain financial crime trends.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2d3-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Improved communications systems","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A plan for enhancing the compatibility of automated information and facilitating access of the Federal Government and State and local governments to timely, accurate, and complete information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2d4-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data regarding funding of terrorism","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Data concerning money laundering efforts related to the funding of acts of international terrorism, and efforts directed at the prevention, detection, and prosecution of such funding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd73a2d5-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effectiveness Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the time each national strategy for combating financial crimes is transmitted by the President to the Congress (other than the first transmission of any such strategy) pursuant to subsection (a), the Secretary shall submit a report containing an evaluation of the effectiveness of policies to combat money laundering and related financial crimes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd73a2d6-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to the consultations required under this section with the Attorney General, in developing the national strategy for combating money laundering and related financial crimes, the Secretary shall consult with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd73a2d7-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board of Governors of the Federal Reserve System and other Federal banking agencies and the National Credit Union Administration Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2d8-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local officials, including State and local prosecutors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2d9-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Securities and Exchange Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2da-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commodities and Futures Trading Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2db-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of National Drug Control Policy, with respect to money laundering and related financial crimes involving the proceeds of drug trafficking;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2dc-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief of the United States Postal Inspection Service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2dd-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent appropriate, State and local officials responsible for financial institution and financial market regulation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2de-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other State or local government authority, to the extent appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2df-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal Government authority or instrumentality, to the extent appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd73a2e0-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5341/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of the private financial services sector, to the extent appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd73a2e1-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/310/s2/a"},"text":"Pub. L. 105–310, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2942"},"text":"112 Stat. 2942","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tIII/s354"},"text":"Pub. L. 107–56, title III, § 354","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/323"},"text":"115 Stat. 323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tVI/s6102/a"},"text":"Pub. L. 108–458, title VI, § 6102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3744"},"text":"118 Stat. 3744","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd73a2e2-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd73a2e3-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd73a2e4-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":" substituted “August 1” for “February 1” and “2003, 2005, and 2007,” for “and 2003,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" added par. (12)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
