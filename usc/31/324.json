{"tag":"section","attrib":{"id":"idbcdb0c14-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s324"},"text":null,"children":[{"tag":"num","attrib":{"value":"324"},"text":"§ 324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposing and extending the maturity of obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcdb0c15-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Treasury may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcdb0c16-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s324/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" dispose of obligations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcdb0c17-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s324/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquired by the Secretary for the United States Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcdb0c18-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s324/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delivered by an executive agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdb0c19-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s324/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make arrangements to extend the maturity of those obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdb0c1a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may dispose or extend the maturity of obligations under subsection (a) of this section in the way, in amounts, at prices (for cash, obligations, property, or a combination of cash, obligations, or property), and on conditions the Secretary considers advisable and in the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdb0c1b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s324/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority under this section is in addition to authority under another law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcdb0c1c-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/882"},"text":"96 Stat. 882","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/369/dA/tIV/s444"},"text":"Pub. L. 98–369, div. A, title IV, § 444","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-07-18"},"text":"July 18, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/816"},"text":"98 Stat. 816","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcdb0c1d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcdb0c1e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbcdb0c1f-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"324(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:741a(a)(1st sentence words before 9th comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1945-04-03/ch51/s5"},"text":"Apr. 3, 1945, ch. 51, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/59/48"},"text":"59 Stat. 48","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"324(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:741a(a)(1st sentence words after 9th comma, last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"324(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:741a(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “sell, exchange” are omitted as being included in “dispose”. The word “obligations” is substituted for “bonds, notes, or other securities” for consistency in the revised title. The words “under judicial process or otherwise” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s302"},"text":"section 302 of title 40","children":[],"tail":"” are omitted as unnecessary and because section 302 was repealed by "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/s1/95"},"text":"section 1(95) of the Act of October 31, 1951","children":[],"tail":" (ch. 654, "},{"tag":"ref","attrib":{"href":"/us/stat/65/705"},"text":"65 Stat. 705","children":[],"tail":"). In clause (2), the words “those obligations” are substituted for “thereof” for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “The Secretary may dispose or extend the maturity of obligations under subsection (a) of this section” are added for clarity and because of the restatement. The words “combination of cash, obligations, or property” are substituted for “or any combination thereof” for clarity. The words “terms and conditions” are omitted as being included in “on conditions”. The words “under the authority of this section” are omitted as unnecessary because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is substituted for 31:741a(b) to eliminate unnecessary words and for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcdb0c20-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcdb0c21-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/369"},"text":"Pub. L. 98–369","children":[],"tail":" struck out provision that the Secretary could not dispose of obligations of one issuer, held by the Secretary at one time, having on the date of disposal a total face or par value of more than $1,000,000 or, if no-par obligations, a stated or book value of more than $1,000,000."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
