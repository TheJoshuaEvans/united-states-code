{"tag":"section","attrib":{"id":"idbcdb0c44-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s327"},"text":null,"children":[{"tag":"num","attrib":{"value":"327"},"text":"§ 327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advancements and reimbursements for services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcdb0c45-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s327/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section, “service” includes service provided in—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcdb0c46-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s327/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disbursing and receiving amounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdb0c47-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s327/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" servicing bonds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdb0c48-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s327/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making accounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcdb0c49-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s327/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining bank accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcdb0c4a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s327/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Secretary of the Treasury provides a service for an agency (except the Department of the Treasury) for which amounts have not been appropriated to the Department, the agency may advance for credit or reimburse the Department the amounts necessary to provide the service. Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of this title","children":[],"tail":", amounts advanced or reimbursed may be credited to the appropriation of the Department that is current when the service is provided."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcdb0c4b-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/883"},"text":"96 Stat. 883","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcdb0c4c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcdb0c4d-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbcdb0c4e-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"327(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:157(c)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-08-14/ch705"},"text":"Aug. 14, 1950, ch. 705","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/440"},"text":"64 Stat. 440","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"327(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:157(a)–(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the word “amounts” is substituted for “funds” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “shall not be limited to” are omitted as surplus. The words “disbursing and receiving” are substituted for “collection and disbursement”, the word “making” is substituted for “rendition of”, and the word “maintaining” is substituted for “keeping”, for consistency in the revised title. The word “checking” is omitted as being included in “bank”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “When the Secretary of the Treasury provides a service” are substituted for “When any service authorized by law and directed by the Secretary of the Treasury is performed or to be performed” to eliminate unnecessary words. The words “by the Fiscal Service or the Office of the Treasurer of the United States of the Department of the Treasury” are omitted because of the source provisions restated in section 321 of the revised title. The words “agency (except the Department of the Treasury)” are substituted for 31:157(c)(1) for consistency in the revised title and with other titles of the Code. The word “reimburse” is substituted for “pay”, and the words “advanced or reimbursed” are substituted for “transferred”, for clarity and because of the restatement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
