{"tag":"section","attrib":{"id":"idbd761330-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5353"},"text":null,"children":[{"tag":"num","attrib":{"value":"5353"},"text":"§ 5353.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information collection and dissemination with respect to grant recipients","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd761331-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5353/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicant and Grantee Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd761332-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5353/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall issue requests for proposal, as necessary, regarding, with respect to the grants awarded under section 5352, the application process, grant renewal, and suspension or withholding of renewal grants. Each application under this paragraph shall be in writing and shall be subject to review by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd761333-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5353/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall, to the maximum extent practicable and in a manner consistent with applicable law, minimize reporting requirements by a grant recipient and expedite any application for a renewal grant made under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd761334-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5353/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd761335-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5353/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the utility of specific initiatives relating to the purposes of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd761336-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5353/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct an evaluation of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd761337-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5353/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" disseminate information described in this subsection to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbd761338-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5353/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible State local law enforcement agencies or prosecutors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbd761339-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s5353/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the general public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd76133a-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/310/s2/a"},"text":"Pub. L. 105–310, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-30"},"text":"Oct. 30, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2948"},"text":"112 Stat. 2948","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
