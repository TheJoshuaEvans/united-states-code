{"tag":"section","attrib":{"id":"idbcf54b58-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774"},"text":null,"children":[{"tag":"num","attrib":{"value":"774"},"text":"§ 774.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Survivor annuities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbcf54b59-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf54b5a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “allowable military service” means honorable active service of not more than 5 years in an armed force (including service in the National Guard when ordered to active duty for the United States Government), when the service is not creditable in computing another annuity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54b5b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “other prior allowable service” means civilian service as an officer or employee of the Government or District of Columbia government not covered by subsection (d)(1) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54b5c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “congressional employee” has the same meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s2107"},"text":"section 2107 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf54b5d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A survivor annuity shall be paid under this subchapter when a Comptroller General—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf54b5e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes an election under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s773"},"text":"section 773 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54b5f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dies in office or while receiving an annuity under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s772"},"text":"section 772 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf54b60-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had at least 18 months of civilian service at death computed under subsections (a) and (d) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7bb61-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had deductions or deposits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s773"},"text":"section 773 of this title","children":[],"tail":" made for the last 18 months of civilian service."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7bb62-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Comptroller General or retired Comptroller General is survived—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf7bb63-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only by a spouse, the surviving spouse shall receive an annuity computed under subsection (d) of this section beginning on the death of the Comptroller General or retired Comptroller General or when the spouse is 50 years of age, whichever is later;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7bb64-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" by a spouse and a dependent child, the surviving spouse shall receive an immediate annuity computed under subsection (d) of this section and each dependent child shall receive an immediate annuity equal to the smaller of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf7bb65-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 10 percent of the average annual pay computed under subsection (d)(1) of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bb66-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent of the average annual pay computed under subsection (d)(1) of this section, divided by the number of dependent children; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7bb67-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" only by a dependent child, each dependent child shall receive an immediate annuity equal to the smaller of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf7bb68-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annuity a surviving spouse would be entitled to receive under clause (2) of this subsection, divided by the number of dependent children;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bb69-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 20 percent of the average annual pay computed under subsection (d)(1) of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bb6a-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 40 percent of the average annual pay computed under subsection (d)(1) of this section, divided by the number of dependent children.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7bb6b-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The annuity of a surviving spouse is equal to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbcf7bb6c-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 1.5 percent of the average annual pay (based on the 3 years of highest pay received as Comptroller General and other prior allowable service) times—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idbcf7bb6d-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the number of years of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idbcf7bb6e-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service as Comptroller General or a member of Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idbcf7bb6f-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prior allowable military service; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idbcf7bb70-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 15 years of prior allowable service as a congressional employee; plus","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbcf7bb71-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" .75 percent of the average pay computed under clause (1) of this subsection times the number of years of other allowable service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbcf7bb72-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s774/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A surviving spouse’s annuity may not be more than 50 percent nor less than 25 percent of the average annual pay computed under subsection (d)(1) of this section. If a Comptroller General does not make the deposit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s773/b"},"text":"section 773(b) of this title","children":[],"tail":", a surviving spouse’s annuity shall be credited with the service during which a deposit was not made, unless the spouse elects not to have the service credited. However, the annuity shall be reduced by 10 percent of the amount of the unpaid deposit, computed on the date the Comptroller General or retired Comptroller General dies."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbcf7bb73-47c4-11f1-bea6-82cea744851c"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Pub. L. 97–258","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-13"},"text":"Sept. 13, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/904"},"text":"96 Stat. 904","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/426/tII/s205"},"text":"Pub. L. 100–426, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/1600"},"text":"102 Stat. 1600","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbcf7bb74-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idbcf7bb75-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idbcf7bb76-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"774(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43b(","children":[{"tag":"html:i","attrib":{},"text":"o","children":[],"tail":")."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18"},"text":"June 10, 1921, ch. 18","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/42/20"},"text":"42 Stat. 20","children":[],"tail":", § 319(d), ("},{"tag":"html:i","attrib":{},"text":"o","children":[],"tail":"); added "},{"tag":"html:span","attrib":{},"text":"July 13, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/87"},"text":"Pub. L. 86–87","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/197"},"text":"73 Stat. 197","children":[],"tail":", 200."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"774(b), (c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43b(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1921-06-10/ch18"},"text":"June 10, 1921, ch. 18","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/42/20"},"text":"42 Stat. 20","children":[],"tail":", § 319(e), (n); added "},{"tag":"html:span","attrib":{},"text":"July 13, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/87"},"text":"Pub. L. 86–87","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/197"},"text":"73 Stat. 197","children":[],"tail":", 200; "},{"tag":"html:span","attrib":{},"text":"Oct. 25, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/512/s2/2"},"text":"Pub. L. 95–512, § 2(2)","children":[],"tail":"–(4), "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1799"},"text":"92 Stat. 1799","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"774(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43b(n)(less words after last comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"774(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43b(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"31:43b(n)(words after last comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “in an armed force” are substituted for “in the Army, Navy, Air Force, Marine Corps, or Coast Guard” for consistency with title 10. The word “only” is omitted as surplus. The word “Government” is added for consistency. The word “computing” is added for clarity. The word “annuity” is substituted for “retirement or retired pay” for consistency in the revised title and with other titles of the United States Code. The words “under any other provision of law” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(3) is substituted for 31:43b(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(1st sentence) for consistency in the revised title and with other titles of the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “A survivor annuity shall be paid under this subchapter when” are added for clarity. The words “or retired Comptroller General” are omitted as executed. In clause (1), the words “made an election under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s733"},"text":"section 733 of this title","children":[],"tail":"” are substituted for “has elected to bring himself within the purview of this section” for clarity. In clause (2), the word “annuity” is substituted for “retirement pay” for consistency in the revised title and with other titles of the Code. In clause (4), the words “salary” and “actually” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “only by a spouse” are substituted for “by a widow but not by a dependent child” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), before subclause (A), the words “or children” and “in an amount” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), before subclause (A), the words “only by a dependent child” are substituted for “no surviving widow but leaves a surviving dependent child or children” to eliminate unnecessary words. In subclause (A), the words “the amount of” are omitted as surplus. The words “a surviving spouse” are substituted for “such widow . . . had she survived” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), before clause (1), the words “of a Comptroller General or retired Comptroller General who has elected to bring himself within the purview of this section” are omitted as surplus. In clauses (1) and (2), the word “pay” is substituted for “salary” for consistency in the revised title and with other titles of the Code. In clause (1), before subclause (A), the words “by him for service . . . service in which his” are omitted as surplus. In subclause (A)(i), the words “member of Congress” are substituted for “Senator, Representative, Delegate, or Resident Commissioner in the Congress of the United States” for consistency and to eliminate unnecessary words. The words “his years of service as” and “of the United States” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “and shall be further reduced in accordance with subsection (d) of this section if applicable” are omitted because of the restatement. The words “or a retired Comptroller General” are omitted as executed. The words “during which a deposit was not made” are substituted for “rendered” for clarity. The word “unpaid” is added for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbcf7bb77-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbcf7bb78-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1988—Subsec. (b)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426/s205/1"},"text":"Pub. L. 100–426, § 205(1)","children":[],"tail":", substituted “18 months” for “5 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426/s205/2"},"text":"Pub. L. 100–426, § 205(2)","children":[],"tail":", amended pars. (2) and (3) generally. Prior to amendment, pars. (2) and (3) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) by a spouse and a dependent child, the surviving spouse shall receive an immediate annuity under subsection (d) of this section and each dependent child shall receive an immediate annuity equal to the smaller of—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) $1,548; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $4,644 divided by the number of dependent children; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) only by a dependent child, each dependent child shall receive an immediate annuity equal to the smaller of—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the annuity a surviving spouse would be entitled to receive under clause (2) of this subsection divided by the number of dependent children;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) $1,860; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) $5,580 divided by the number of dependent children.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426/s205/3"},"text":"Pub. L. 100–426, § 205(3)","children":[],"tail":", substituted “1.5 percent” for “1.25 percent” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426/s205/4"},"text":"Pub. L. 100–426, § 205(4)","children":[],"tail":", substituted “more than 50 percent nor less than 25 percent” for “more than 40 percent”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idbcf7bb79-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idbcf7bb7a-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/426"},"text":"Pub. L. 100–426","children":[],"tail":" effective after end of 60-day period beginning "},{"tag":"date","attrib":{"date":"1988-09-09"},"text":"Sept. 9, 1988","children":[],"tail":", with certain exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/426/s208"},"text":"section 208 of Pub. L. 100–426","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s772"},"text":"section 772 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
