{"tag":"section","attrib":{"id":"idbd381f71-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3562"},"text":null,"children":[{"tag":"num","attrib":{"value":"3562"},"text":"§ 3562.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of recovered funds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idbd381f72-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3562/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Funds for Recovery Audits and Activities Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds collected under a program carried out by an executive agency under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3352/i"},"text":"section 3352(i) of this title","children":[],"tail":" shall be available to the executive agency to reimburse the actual expenses incurred by the executive agency in the administration of the program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idbd381f73-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3562/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"[(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":", (c). Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/204/s2/h/6/A/i"},"text":"Pub. L. 111–204, § 2(h)(6)(A)(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-22"},"text":"July 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2231"},"text":"124 Stat. 2231","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd381f74-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tVIII/s831/a/1"},"text":"Pub. L. 107–107, div. A, title VIII, § 831(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1187"},"text":"115 Stat. 1187","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/204/s2/h/6/A"},"text":"Pub. L. 111–204, § 2(h)(6)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-07-22"},"text":"July 22, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2231"},"text":"124 Stat. 2231","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/117/s3/b/4"},"text":"Pub. L. 116–117, § 3(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-03-02"},"text":"Mar. 2, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/134"},"text":"134 Stat. 134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd381f75-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd381f76-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idbd381f77-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/117"},"text":"Pub. L. 116–117","children":[],"tail":" substituted “section 3352(i)” for “section 3561” and “agency to reimburse” for “agency for the following purposes: (1) To reimburse” and struck out par. (2) which read as follows: “To pay contractors for services under the program in accordance with the guidance issued under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3561/c/5"},"text":"section 3561(c)(5) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/204"},"text":"Pub. L. 111–204","children":[],"tail":" repealed section but provided that subsec. (a) was to continue in effect, with certain exceptions related to programs carried out under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3561"},"text":"section 3561 of this title","children":[],"tail":". Prior to amendment, in addition to subsec. (a), section contained subsecs. (b) and (c) which related to treatment of funds not used for programs under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3561"},"text":"section 3561 of this title","children":[],"tail":" and priority of other authorized dispositions, respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
