{"tag":"section","attrib":{"id":"idbd48c256-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3809"},"text":null,"children":[{"tag":"num","attrib":{"value":"3809"},"text":"§ 3809.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Within 180 days after the date of enactment of this chapter, each authority head shall promulgate rules and regulations necessary to implement the provisions of this chapter. Such rules and regulations shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idbd48c257-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3809/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that investigating officials and reviewing officials are not responsible for conducting the hearing required in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803/f"},"text":"section 3803(f) of this title","children":[],"tail":", making the determinations required by subsections (f) and (h) of "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803"},"text":"section 3803 of this title","children":[],"tail":", or making collections under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s3806"},"text":"section 3806 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idbd48c258-47c4-11f1-bea6-82cea744851c","identifier":"/us/usc/t31/s3809/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a reviewing official to include in any notice required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3803/a/2"},"text":"section 3803(a)(2) of this title","children":[],"tail":" a statement which specifies that the reviewing official has determined that there is a reasonable prospect of collecting, from a person with respect to whom the reviewing official is referring allegations of liability in such notice, the amount for which such person may be liable."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idbd48c259-47c4-11f1-bea6-82cea744851c"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509/tVI/s6103/a"},"text":"Pub. L. 99–509, title VI, § 6103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1947"},"text":"100 Stat. 1947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idbd48c25a-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idbd48c25b-47c4-11f1-bea6-82cea744851c"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idbd48c25c-47c4-11f1-bea6-82cea744851c"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in text, means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/509"},"text":"Pub. L. 99–509","children":[],"tail":" which was approved "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
