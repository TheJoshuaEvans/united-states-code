{"tag":"section","attrib":{"id":"idfe9f6bb7-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417"},"text":null,"children":[{"tag":"num","attrib":{"value":"417"},"text":"§ 417.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrators, Ombudsmen, and staff of facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idfe9f6bb8-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of Defense shall appoint an Administrator and an Ombudsman for each facility of the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6bb9-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrator","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of a facility shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6bba-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a civilian with experience as a continuing care retirement community professional or a member of the Armed Forces serving on active duty in a grade below brigadier general or, in the case of the Navy, rear admiral (lower half);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6bbb-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have appropriate leadership and management skills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6bbc-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be required to pursue a course of study to receive certification as a retirement facilities director by an appropriate civilian certifying organization, if the Administrator is not so certified at the time of appointment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6bbd-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve at the pleasure of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6bbe-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Administrator","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6bbf-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of a facility shall be responsible for the day-to-day operation of the facility, including the acceptance of applicants to be residents of that facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6bc0-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of a facility shall keep accurate and complete records of the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6bc1-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ombudsman","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6bc2-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Ombudsman of a facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe9f6bc3-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a member of the Armed Forces serving on active duty in the grade of Sergeant Major, Master Chief Petty Officer, or Chief Master Sergeant or a member or former member retired in that grade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6bc4-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have appropriate leadership and management skills.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6bc5-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Ombudsman of a facility shall serve at the pleasure of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6bc6-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties of Ombudsman","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6bc7-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Ombudsman of a facility shall, under the authority, direction, and control of the Administrator of the facility, serve as ombudsman for the residents and perform such other duties as the Administrator may assign.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6bc8-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Ombudsman may provide information to the Administrator, the Chief Operating Officer, the Senior Medical Advisor, and the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6bc9-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6bca-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of a facility may, subject to the approval of the Chief Operating Officer, appoint and prescribe the pay of such principal staff as the Administrator considers appropriate to assist the Administrator in operating the facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6bcb-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The principal staff of a facility shall include persons with experience and expertise in the operation and management of retirement homes and in the provision of long-term medical care for older persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6bcc-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual evaluation of Administrators","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6bcd-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Operating Officer shall evaluate the performance of each of the Administrators of the facilities of the Retirement Home each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6bce-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s417/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Operating Officer shall submit to the Secretary of Defense any recommendations regarding an Administrator that the Chief Operating Officer determines appropriate taking into consideration the annual evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idfe9f6bcf-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1517"},"text":"Pub. L. 101–510, div. A, title XV, § 1517","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1729"},"text":"104 Stat. 1729","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1062/a/5"},"text":"Pub. L. 102–190, div. A, title X, § 1062(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1475"},"text":"105 Stat. 1475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1051/c"},"text":"Pub. L. 104–201, div. A, title X, § 1051(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2649"},"text":"110 Stat. 2649","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tX/s1041/a"},"text":"Pub. L. 105–261, div. A, title X, § 1041(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2124"},"text":"112 Stat. 2124","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXIV/s1407"},"text":"Pub. L. 107–107, div. A, title XIV, § 1407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1264"},"text":"115 Stat. 1264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV"},"text":"Pub. L. 112–81, div. A, title V","children":[],"tail":", §§ 564(a), 567(c)(4), "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1424"},"text":"125 Stat. 1424","children":[],"tail":", 1426; "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXIV/s1413/a/2"},"text":"Pub. L. 115–91, div. A, title XIV, § 1413(a)(2)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1707"},"text":"131 Stat. 1707","children":[],"tail":", 1708; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXIV/s1413/b/3"},"text":"Pub. L. 116–283, div. A, title XIV, § 1413(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4032"},"text":"134 Stat. 4032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe9f6bd0-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe9f6bd1-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idfe9f6bd2-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" struck out “the Inspector General of the Department of Defense,” after “the Senior Medical Advisor,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1413/c"},"text":"Pub. L. 115–91, § 1413(c)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1413/a/2"},"text":"Pub. L. 115–91, § 1413(a)(2)","children":[],"tail":", substituted “the Secretary of Defense” for “the Under Secretary of Defense for Personnel and Readiness”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s567/c/4"},"text":"Pub. L. 112–81, § 567(c)(4)","children":[],"tail":", substituted “Administrators, Ombudsmen, and staff of facilities” for “Directors, deputy directors, associate directors, and staff of facilities” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s564/a/1"},"text":"Pub. L. 112–81, § 564(a)(1)","children":[],"tail":", substituted “an Administrator and an Ombudsman” for “a Director, a Deputy Director, and an Associate Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s564/a/2"},"text":"Pub. L. 112–81, § 564(a)(2)","children":[],"tail":", substituted “Administrator” for “Director” wherever appearing in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s564/a/4"},"text":"Pub. L. 112–81, § 564(a)(4)","children":[],"tail":", substituted “Ombudsman” for “Associate Director” wherever appearing in heading and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s564/a/3"},"text":"Pub. L. 112–81, § 564(a)(3)","children":[],"tail":", redesignated subsec. (f) as (d) and struck out former subsec. (d) which related to Deputy Director."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s564/a/5"},"text":"Pub. L. 112–81, § 564(a)(5)","children":[],"tail":", designated existing provisions as par. (1), substituted “Ombudsman” for “Associate Director” in heading and text, substituted “Administrator of” for “Director and Deputy Director of” and “Administrator may” for “Director may”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s564/a/3"},"text":"Pub. L. 112–81, § 564(a)(3)","children":[],"tail":", redesignated subsec. (g) as (e) and struck out former subsec. (e) which related to duties of Deputy Director."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s564/a/3"},"text":"Pub. L. 112–81, § 564(a)(3)","children":[],"tail":", redesignated subsec. (h) as (f). Former subsec. (f) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s564/a/6"},"text":"Pub. L. 112–81, § 564(a)(6)","children":[],"tail":", substituted “Administrator” for “Director” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s564/a/7"},"text":"Pub. L. 112–81, § 564(a)(7)","children":[],"tail":", substituted “Administrators” for “Directors” in heading and par. (1) and “an Administrator” for “a Director” in par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s564/a/3"},"text":"Pub. L. 112–81, § 564(a)(3)","children":[],"tail":", redesignated subsec. (i) as (g). Former subsec. (g) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h), (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s564/a/3"},"text":"Pub. L. 112–81, § 564(a)(3)","children":[],"tail":", redesignated subsecs. (h) and (i) as (f) and (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to directors, deputy directors, associate directors, and staff of facilities for provisions relating to directors and staff."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s1041/a/1/A"},"text":"Pub. L. 105–261, § 1041(a)(1)(A)","children":[],"tail":", substituted “The Director of the United States Soldiers’ and Airmen’s Home” for “Each Director” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s1041/a/1/B"},"text":"Pub. L. 105–261, § 1041(a)(1)(B)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “have appropriate leadership and management skills, an appreciation and understanding of the culture and norms associated with military service, and a significant military background.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3) to (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s1041/a/2"},"text":"Pub. L. 105–261, § 1041(a)(2)","children":[],"tail":", (3), added pars. (3) and (4) and redesignated former par. (3) as (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s1041/b"},"text":"Pub. L. 105–261, § 1041(b)","children":[],"tail":", substituted “Terms of Directors” for “Term of Director” in heading, designated existing provisions as par. (1), substituted “The term of office of the Director of the United States Soldiers’ and Airmen’s Home shall be five years. The Director” for “The term of office of a Director shall be five years. A Director”, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/s1041/c"},"text":"Pub. L. 105–261, § 1041(c)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" added subsec. (f) and struck out heading and text of former subsec. (f). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Until the date on which the Secretary of Defense first appoints the Director for the establishment of the Retirement Home known as the Naval Home, the Governor of the Naval Home shall operate that facility consistent with this chapter and other laws applicable to the Retirement Home.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Until the date on which the Secretary of Defense first appoints the Director for the facility of the Retirement Home known as the United States Soldiers’ and Airmen’s Home, the Governor of the United States Soldiers’ and Airmen’s Home shall operate that establishment consistent with this chapter and other laws applicable to the Retirement Home.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Pub. L. 102–190","children":[],"tail":" made technical amendment to references to this chapter to correct reference to corresponding provision of original act."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idfe9f6bd3-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idfe9f6bd4-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/261/dA/tX/s1041/d"},"text":"Pub. L. 105–261, div. A, title X, § 1041(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-17"},"text":"Oct. 17, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2124"},"text":"112 Stat. 2124","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/261/dA/tX/s1041/d"},"text":"“The amendments made by this section [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idfe9f6bd5-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective one year after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1541/a"},"text":"section 1541(a) of Pub. L. 101–510","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
