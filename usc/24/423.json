{"tag":"section","attrib":{"id":"idfea1dc40-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s423"},"text":null,"children":[{"tag":"num","attrib":{"value":"423"},"text":"§ 423.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of historic buildings and grounds at the Armed Forces Retirement Home—Washington","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idfea1dc41-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s423/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historic nature of facility","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfea1dc42-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s423/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four buildings located on six acres of the establishment of the Retirement Home known as the Armed Forces Retirement Home—Washington are included on the National Register of Historic Places maintained by the Secretary of the Interior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfea1dc43-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s423/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the Armed Forces Retirement Home Trust Fund, which consists primarily of deductions from the pay of members of the Armed Forces, are insufficient to both maintain and operate the Retirement Home for the benefit of the residents of the Retirement Home and adequately maintain, repair, and preserve these historic buildings and grounds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfea1dc44-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s423/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other sources of funding are available to contribute to the maintenance, repair, and preservation of these historic buildings and grounds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfea1dc45-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s423/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to accept assistance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Operating Officer and the Administrator of the Armed Forces Retirement Home—Washington may apply for and accept a direct grant from the Secretary of the Interior under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302904"},"text":"section 302904 of title 54","children":[],"tail":" for the purpose of maintaining, repairing, and preserving the historic buildings and grounds of the Armed Forces Retirement Home—Washington included on the National Register of Historic Places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfea1dc46-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s423/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements and limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts received as a grant under subsection (b) shall be deposited in the Fund, but shall be kept separate from other amounts in the Fund. The amounts received may only be used for the purpose specified in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idfea1dc47-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1523"},"text":"Pub. L. 101–510, div. A, title XV, § 1523","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tIII/s383"},"text":"Pub. L. 106–65, div. A, title III, § 383","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/583"},"text":"113 Stat. 583","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXIV"},"text":"Pub. L. 107–107, div. A, title XIV","children":[],"tail":", §§ 1404(b)(5), 1410(a)(4), "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1261"},"text":"115 Stat. 1261","children":[],"tail":", 1266; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s564/b/1"},"text":"Pub. L. 112–81, div. A, title V, § 564(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1424"},"text":"125 Stat. 1424","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfea1dc48-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfea1dc49-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idfea1dc4a-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsec. (b), “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s302904"},"text":"section 302904 of title 54","children":[],"tail":"” substituted for “section 101(e)(3) of the National Historic Preservation Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s470a/e/3"},"text":"16 U.S.C. 470a(e)(3)","children":[],"tail":")” on authority of "},{"tag":"ref","attrib":{"href":"/us/pl/113/287/s6/e"},"text":"Pub. L. 113–287, § 6(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3272"},"text":"128 Stat. 3272","children":[],"tail":", which Act enacted Title 54, National Park Service and Related Programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idfea1dc4b-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" substituted “Administrator” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1410/a/4/B"},"text":"Pub. L. 107–107, § 1410(a)(4)(B)","children":[],"tail":", amended section catchline generally, substituting “the Armed Forces Retirement Home—Washington” for “United States Soldiers’ and Airmen’s Home”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1410/a/4/A"},"text":"Pub. L. 107–107, § 1410(a)(4)(A)","children":[],"tail":", substituted “Armed Forces Retirement Home—Washington” for “United States Soldiers’ and Airmen’s Home”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":", §§ 1404(b)(5), 1410(a)(4)(A), substituted “Chief Operating Officer” for “Chairman of the Retirement Home Board” and substituted “Armed Forces Retirement Home—Washington” for “United States Soldiers’ and Airmen’s Home” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
