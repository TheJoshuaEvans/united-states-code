{"tag":"section","attrib":{"id":"idfe879d22-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"§ 13.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Admission of cases for study","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There may be admitted into marine hospitals for study persons with infectious or other diseases affecting the public health, and not to exceed ten cases in any one hospital at one time.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe8a0e23-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1920-06-05/ch235/s1"},"text":"June 5, 1920, ch. 235, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/41/884"},"text":"41 Stat. 884","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
