{"tag":"section","attrib":{"id":"idfe9ab0b8-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s327"},"text":null,"children":[{"tag":"num","attrib":{"value":"327"},"text":"§ 327.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification to committing court of discharge or conditional release","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In the case of any person hospitalized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s324"},"text":"section 324 of this title","children":[],"tail":" who has been judicially committed to the Secretary’s custody, the Secretary shall, upon the discharge or conditional release of such person, or upon such person’s transfer and release under "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s323"},"text":"section 323 of this title","children":[],"tail":", notify the committing court of such discharge or conditional release or such transfer and release."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe9ab0b9-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/571/s7"},"text":"Pub. L. 86–571, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-05"},"text":"July 5, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/310"},"text":"74 Stat. 310","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
