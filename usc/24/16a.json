{"tag":"section","attrib":{"id":"idfe8a0e35-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s16a"},"text":null,"children":[{"tag":"num","attrib":{"value":"16a"},"text":"§ 16a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional personnel for patients of Department of Veterans Affairs in naval hospitals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On and after ","children":[{"tag":"date","attrib":{"date":"1945-05-29"},"text":"May 29, 1945","children":[],"tail":", additional commissioned, warranted, appointed, enlisted, and civilian personnel of the Medical Department of the Navy, required for the care of patients of the Department of Veterans Affairs in naval hospitals, may be employed in addition to the numbers annually appropriated for."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe8a0e36-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1945-05-29/ch130/s1"},"text":"May 29, 1945, ch. 130, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/59/208"},"text":"59 Stat. 208","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13/i/1"},"text":"Pub. L. 102–54, § 13(i)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/276"},"text":"105 Stat. 276","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe8a0e37-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe8a0e38-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idfe8a0e39-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is from act ","children":[{"tag":"date","attrib":{"date":"1945-05-29"},"text":"May 29, 1945","children":[],"tail":", popularly known as the Naval Appropriation Act, 1946."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idfe8a0e3a-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted “Department of Veterans Affairs” for “United States Veterans’ Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idfe8a0e3b-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"idfe8a0e3c-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1944-06-22/ch269/s1"},"text":"June 22, 1944, ch. 269, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/308"},"text":"58 Stat. 308","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1943-06-26/ch147/s101"},"text":"June 26, 1943, ch. 147, § 101","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/