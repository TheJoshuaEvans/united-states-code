{"tag":"section","attrib":{"id":"idfe93845c-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225"},"text":null,"children":[{"tag":"num","attrib":{"value":"225"},"text":"§ 225.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idfe93845d-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Congress makes the following findings:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe93845e-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Governmentally administered mental health services in the District of Columbia are currently provided through two separate public entities, the federally administered Saint Elizabeths Hospital and the Mental Health Services Administration of the District of Columbia Department of Human Resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe93845f-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The District of Columbia has a continuing responsibility to provide mental health services to its residents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe938460-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Government, through its operation of a national mental health program at Saint Elizabeths Hospital, has for over 100 years assisted the District of Columbia in carrying out that responsibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe938461-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Since its establishment by Congress in 1855, Saint Elizabeths Hospital has developed into a respected national mental health hospital and study, training, and treatment center, providing a range of quality mental health and related services, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idfe938462-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/4/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acute and chronic inpatient psychiatric care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idfe938463-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/4/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outpatient psychiatric and substance abuse clinical and related services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idfe938464-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/4/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal court system forensic psychiatry referral, evaluation, and patient treatment services for prisoners, and for individuals awaiting trial or requiring post-trial or post-sentence psychiatric evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idfe938465-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/4/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" patient care and related services for designated classes of individuals entitled to mental health benefits under Federal law, such as certain members and employees of the United States Armed Forces and the Foreign Service, and residents of American overseas dependencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idfe938466-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/4/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" District of Columbia court system forensic psychiatry referral, evaluation, and patient treatment services for prisoners, and for individuals awaiting trial or requiring post-trial or postsentence psychiatric evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idfe938467-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/4/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" programs for special populations such as the mentally ill deaf;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idfe938468-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/4/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support for basic and applied clinical psychiatric research and related patient services conducted by the National Institute of Mental Health and other institutions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idfe938469-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/4/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" professional and paraprofessional training in the major mental health disciplines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe93846a-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The continuation of the range of services currently provided by federally administered Saint Elizabeths Hospital must be assured, as these services are integrally related to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idfe93846b-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/5/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of adequate mental health services to District of Columbia residents, nonresidents who require mental health services while in the District of Columbia, individuals entitled to mental health services under Federal law, and individuals referred by both Federal and local court systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idfe93846c-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/5/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Nation’s capacity to increase our knowledge and understanding about mental illness and to facilitate and continue the development and broad availability of sound and modern methods and approaches for the treatment of mental illness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe93846d-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The assumption of all or selected functions, programs, and resources of Saint Elizabeths Hospital from the Federal Government by the District of Columbia, and the integration of those functions, resources, and programs into a comprehensive mental health care system administered solely by the District of Columbia, will improve the efficiency and effectiveness of the services currently provided through those two separate entities by shifting the primary focus of care to an integrated community-based system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe93846e-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such assumption of all or selected functions, programs, and resources of Saint Elizabeths Hospital by the District of Columbia would further the principle of home rule for the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe93846f-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is the intent of Congress that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe938470-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the District of Columbia have in operation no later than ","children":[{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":", an integrated coordinated mental health system in the District which provides—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe938471-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high quality, cost-effective, and community-based programs and facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe938472-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a continuum of inpatient and outpatient mental health care, residential treatment, and support services through an appropriate balance of public and private resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe938473-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that patient rights and medical needs are protected;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe938474-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the comprehensive District mental health care system be in full compliance with the Federal court consent decree in Dixon v. Heckler;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe938475-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District and Federal Governments bear equitable shares of the costs of a transition from the present system to a comprehensive District mental health system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe938476-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transition to a comprehensive District mental health system provided for by this subchapter be carried out with maximum consideration for the interests of employees of the Hospital and provide a right-of-first-refusal to such employees for employment at comparable levels in positions created under the system implementation plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe938477-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government have the responsibility for the retraining of Hospital employees to prepare such employees for the requirements of employment in a comprehensive District mental health system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe938478-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Government continue high quality mental health research, training, and demonstration programs at Saint Elizabeths Hospital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe938479-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District government establish and maintain accreditation and licensing standards for all services provided in District mental health facilities which assure quality care consistent with appropriate Federal regulations and comparable with standards of the Joint Commission on Accreditation of Hospitals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe93847a-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the comprehensive mental health system plan include a component for direct services for the homeless mentally ill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idfe93847b-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/621/s2"},"text":"Pub. L. 98–621, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3369"},"text":"98 Stat. 3369","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/150/s3/a"},"text":"Pub. L. 102–150, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-31"},"text":"Oct. 31, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/980"},"text":"105 Stat. 980","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe93847c-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe93847d-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idfe93847e-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This subchapter, referred to in subsec. (b)(4), was in the original “this Act”, meaning ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/621"},"text":"Pub. L. 98–621","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3369"},"text":"98 Stat. 3369","children":[],"tail":", known as the Saint Elizabeths Hospital and District of Columbia Mental Health Services Act. For complete classification of this Act to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idfe93847f-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/150"},"text":"Pub. L. 102–150","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idfe938480-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idfe938481-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/621/s12"},"text":"Pub. L. 98–621, § 12","children":[],"tail":", formerly § 11, "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3382"},"text":"98 Stat. 3382","children":[],"tail":", renumbered § 12, "},{"tag":"ref","attrib":{"href":"/us/pl/102/150/s4/1"},"text":"Pub. L. 102–150, § 4(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-31"},"text":"Oct. 31, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/981"},"text":"105 Stat. 981","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/150/s4/1"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b), this Act [see Short Title note below] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"October 1, 1985","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) Section 10 [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s324"},"text":"section 324 of this title","children":[],"tail":" and repealing sections 161, 164 to 166, 168, 168a, 169, 169a, 170 to 172, 175 to 177, 180 to 185, 191, 192, 194, 195, 195a, 196, 196b, 197 to 204, 206, 211 to 214, 221, and 222 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–3"},"text":"section 300aa–3 of Title 42","children":[],"tail":", The Public Health and Welfare] shall take effect on "},{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idfe938482-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/150/s1"},"text":"Pub. L. 102–150, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-10-31"},"text":"Oct. 31, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/980"},"text":"105 Stat. 980","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/150/s1"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s225h"},"text":"section 225h of this title","children":[],"tail":", amending this section and sections 225b and 225f of this title, and renumbering provisions set out as a note under this section] may be cited as the ‘District of Columbia Mental Health Program Assistance Act of 1991’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idfe938483-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/98/621/s1"},"text":"Pub. L. 98–621, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3369"},"text":"98 Stat. 3369","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/621/s1"},"text":"“This Act [enacting this subchapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s324"},"text":"section 324 of this title","children":[],"tail":", repealing sections 161, 164 to 166, 168, 168a, 169, 169a, 170 to 172, 175 to 177, 180 to 185, 191, 192, 194, 195, 195a, 196, 196b, 197 to 204, 206, 211 to 214, 221, and 222 of this title and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s300aa–3"},"text":"section 300aa–3 of Title 42","children":[],"tail":", The Public Health and Welfare] may be cited as the ‘Saint Elizabeths Hospital and District of Columbia Mental Health Services Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
