{"tag":"section","attrib":{"id":"idfe879d0f-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s6a"},"text":null,"children":[{"tag":"num","attrib":{"value":"6a"},"text":"§ 6a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of amounts deducted from pensions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Pensions of inmates of a naval hospital, required by law prior to ","children":[{"tag":"date","attrib":{"date":"1943-07-01"},"text":"July 1, 1943","children":[],"tail":", to be deducted from the account of the pensioner and applied for the benefit of the fund from which such home or "},{"tag":"ref","attrib":{"idref":"fn002000"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002000"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The words “home or” probably should not appear after amendment by "},{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":", see 1990 Amendment note below."}],"tail":" hospital is maintained, shall be deposited into the Treasury of the United States as miscellaneous receipts."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe879d10-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1943-06-15/ch125/s3"},"text":"June 15, 1943, ch. 125, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/153"},"text":"57 Stat. 153","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1533/c/2"},"text":"Pub. L. 101–510, div. A, title XV, § 1533(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1736"},"text":"104 Stat. 1736","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNo