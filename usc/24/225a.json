{"tag":"section","attrib":{"id":"idfe938484-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225a"},"text":null,"children":[{"tag":"num","attrib":{"value":"225a"},"text":"§ 225a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purpose of this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe938485-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Hospital” means the institution in the District of Columbia known as Saint Elizabeths Hospital operated on ","children":[{"tag":"date","attrib":{"date":"1984-11-08"},"text":"November 8, 1984","children":[],"tail":", by the Secretary of Health and Human Services."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe938486-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe938487-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Mayor” means the Mayor of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe938488-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “District” means the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe938489-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Federal court consent decree” means the consent decree in Dixon v. Heckler, Civil Action No. 74–285.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe93848a-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “service coordination period” means a period beginning on ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"October 1, 1985","children":[],"tail":", and terminating on "},{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe93848b-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “financial transition period” means a period beginning on ","children":[{"tag":"date","attrib":{"date":"1985-10-01"},"text":"October 1, 1985","children":[],"tail":", and terminating on "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe93848c-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “system implementation plan” means the plan for a comprehensive mental health system for the District of Columbia to be developed pursuant to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe93848d-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s225a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Council” means the Council of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idfe93848e-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/621/s3"},"text":"Pub. L. 98–621, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-11-08"},"text":"Nov. 8, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/3371"},"text":"98 Stat. 3371","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
