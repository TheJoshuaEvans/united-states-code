{"tag":"section","attrib":{"id":"idfe8a0e24-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"§ 14.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of Navy hospitals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Navy shall procure at suitable places proper sites for Navy hospitals, and if the necessary buildings are not procured with the site, shall cause such to be erected, having due regard to economy, and giving preference to such plans as with most convenience and least cost will admit of subsequent additions, when the funds permit and circumstances require; and shall provide, at one of the establishments, a permanent asylum for disabled and decrepit Navy officers, seamen, and marines: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no sites shall be procured or hospital buildings erected or extensions to existing hospitals made unless authorized by Congress."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe8a0e25-9d45-11f0-a0db-bff75580f504"},"text":"(R.S. § 4810; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch148"},"text":"Mar. 4, 1913, ch. 148","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/902"},"text":"37 Stat. 902","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe8a0e26-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe8a0e27-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idfe8a0e28-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4810 derived from acts ","children":[{"tag":"ref","attrib":{"href":"/us/act/1811-02-26/ch26/s3"},"text":"Feb. 26, 1811, ch. 26, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/2/650"},"text":"2 Stat. 650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1832-07-10/ch194/s5"},"text":"July 10, 1832, ch. 194, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/4/573"},"text":"4 Stat. 573","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
