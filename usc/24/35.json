{"tag":"section","attrib":{"id":"idfe8c5872-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s35"},"text":null,"children":[{"tag":"num","attrib":{"value":"35"},"text":"§ 35.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of medical, surgical or hospital services","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Hospitalization of the dependents of naval and Marine Corps personnel and of the persons outside the naval service mentioned in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s34"},"text":"section 34 of this title","children":[],"tail":" shall be furnished only for acute medical and surgical conditions, exclusive of nervous, mental, or contagious diseases or those requiring domiciliary care. Routine dental care, other than dental prosthesis and orthodontia, may be furnished to such persons who are outside the naval service under the same conditions as are prescribed in "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s34"},"text":"section 34 of this title","children":[],"tail":" for hospital and dispensary care for such persons."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe8c5873-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1943-05-10/ch95/s5"},"text":"May 10, 1943, ch. 95, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/81"},"text":"57 Stat. 81","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/251/tIII/s304"},"text":"Pub. L. 99–251, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-02-27"},"text":"Feb. 27, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/26"},"text":"100 Stat. 26","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe8c5874-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe8c5875-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idfe8c5876-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/251"},"text":"Pub. L. 99–251","children":[],"tail":" amended second sentence generally. Prior to amendment, second sentence read as follows: “Dental treatment shall be administered only as an adjunct to inpatient hospital care and shall not include dental prosthesis or orthodontia.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idfe8c5877-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idfe8c5878-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Partial Repeal; Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1956-06-07/ch374/s306/2"},"text":"Act June 7, 1956, ch. 374, § 306(2)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/254"},"text":"70 Stat. 254","children":[],"tail":", repealed this section except insofar as it relates to persons outside the Naval Service mentioned in "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s34"},"text":"section 34 of this title","children":[],"tail":". Section 307 of "},{"tag":"ref","attrib":{"href":"/us/act/1956-06-07/ch374"},"text":"act June 7, 1956, ch. 374","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/254"},"text":"70 Stat. 254","children":[],"tail":", provided that such repeal was effective six months after "},{"tag":"date","attrib":{"date":"1956-06-07"},"text":"June 7, 1956","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
