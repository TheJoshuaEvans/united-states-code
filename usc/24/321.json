{"tag":"section","attrib":{"id":"idfe983f8e-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s321"},"text":null,"children":[{"tag":"num","attrib":{"value":"321"},"text":"§ 321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For the purposes of this chapter except as the context may otherwise require—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idfe983f8f-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Department” means the Department of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe983f90-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Health and Human Services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9ab091-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “State” means a State or Territory of the United States, the Commonwealth of Puerto Rico, or the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9ab092-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “eligible person” means an individual with respect to whom the following certificates are furnished to the Secretary:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9ab093-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s321/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certificate of the Secretary of State that such individual is a national of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9ab094-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s321/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Either (A) a certificate obtained or transmitted by the Secretary of State that such individual has been legally adjudged insane in a named foreign country, or (B) a certificate of an appropriate authority or person (as determined in accordance with regulations prescribed by the Secretary of Health and Human Services) stating that at the time of such certification such individual was in a named foreign country and was in need of care and treatment in a mental hospital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9ab095-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s321/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “residence” means residence as determined under the applicable law or regulations of a State or political subdivision for the purpose of determining the eligibility of an individual for hospitalization in a public mental hospital.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idfe9ab096-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/571/s1"},"text":"Pub. L. 86–571, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-05"},"text":"July 5, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/308"},"text":"74 Stat. 308","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/tV/s509/b"},"text":"Pub. L. 96–88, title V, § 509(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-10-17"},"text":"Oct. 17, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/695"},"text":"93 Stat. 695","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe9ab097-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idfe9ab098-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idfe9ab099-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Department of Health and Human Services” substituted for “Department of Health, Education, and Welfare” in subsec. (a) and “Secretary of Health and Human Services” substituted for “Secretary of Health, Education, and Welfare” in subsecs. (b) and (d)(2), pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88/s509/b"},"text":"section 509(b) of Pub. L. 96–88","children":[],"tail":" which is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3508/b"},"text":"section 3508(b) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idfe9ab09a-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/86/571/s11"},"text":"Pub. L. 86–571, § 11","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1960-07-05"},"text":"July 5, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/310"},"text":"74 Stat. 310","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/86/571/s11"},"text":"“This Act [enacting this chapter and repealing sections 191a and 196a of this title] shall, except as otherwise specified, take effect on the date of its enactment [","children":[{"tag":"date","attrib":{"date":"1960-07-05"},"text":"July 5, 1960","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
