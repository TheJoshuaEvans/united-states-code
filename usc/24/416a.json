{"tag":"section","attrib":{"id":"idfe9f6bab-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416a"},"text":null,"children":[{"tag":"num","attrib":{"value":"416a"},"text":"§ 416a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resident Advisory Committees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idfe9f6bac-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment and purpose","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6bad-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A Resident Advisory Committee is an elected body of residents at each facility of the Retirement Home established to provide a forum for all residents to express their needs, ideas, and interests through elected representatives of their respective floor or area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6bae-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A Resident Advisory Committee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe9f6baf-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416a/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves as a forum for ideas, recommendations, and representation to management of that facility of the Retirement Home to enhance the morale, safety, health, and well-being of residents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6bb0-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416a/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a means to communicate policy and general information between residents and management.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6bb1-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election process","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The election process for the Resident Advisory Committee at a facility of the Retirement Home shall be coordinated by the facility Ombudsman.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6bb2-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chairperson","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6bb3-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416a/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairperson of a Resident Advisory Committee shall be elected at large and serve a two-year term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6bb4-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416a/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chairpersons serve as a liaison to the Administrator and are voting members of the Advisory Council. Chairpersons shall create meeting agendas, conduct the meetings, and provide a copy of the minutes to the Administrator, who will forward the copy to the Chief Operating Officer for approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6bb5-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meetings","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"At a minimum, meetings of a Resident Advisory Committee shall be conducted quarterly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idfe9f6bb6-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1516A"},"text":"Pub. L. 101–510, div. A, title XV, § 1516A","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s563/a"},"text":"Pub. L. 112–81, div. A, title V, § 563(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1423"},"text":"125 Stat. 1423","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
