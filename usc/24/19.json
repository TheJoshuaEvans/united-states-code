{"tag":"section","attrib":{"id":"idfe8a0e4b-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"§ 19.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tubercular hospital at Fort Bayard","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The hospital at Fort Bayard, New Mexico, for the treatment of tuberculosis, shall be opened to the treatment of the officers and men of the Navy and Marine Corps.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe8a0e4c-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-02/ch2511"},"text":"Mar. 2, 1907, ch. 2511","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1172"},"text":"34 Stat. 1172","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
