{"tag":"section","attrib":{"id":"idfe8a0e4d-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"§ 20.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discipline of patients at Army and Navy Hospital","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"All persons admitted to treatment in the Army and Navy General Hospital at Hot Springs, Arkansas, shall, while patients in said hospital, be subject to the rules and articles for the government of the armies of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe8a0e4e-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1909-03-03/ch252"},"text":"Mar. 3, 1909, ch. 252","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/748"},"text":"35 Stat. 748","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe8a0e4f-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idfe8a0e50-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"repeals","id":"idfe8a0e51-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeals","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1944-07-01/ch373/tXIII/s1313"},"text":"Act July 1, 1944, ch. 373, title XIII, § 1313","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/58/714"},"text":"58 Stat. 714","children":[],"tail":", as amended and renumbered by acts "},{"tag":"ref","attrib":{"href":"/us/act