{"tag":"section","attrib":{"id":"idfe8a0e3d-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"§ 17.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government of Naval Asylum","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The asylum for disabled and decrepit Navy officers, seamen, and marines shall be governed in accordance with the rules and regulations prescribed by the Secretary of the Navy.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe8a0e3e-9d45-11f0-a0db-bff75580f504"},"text":"(R.S. § 4811.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe8a0e3f-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe8a0e40-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idfe8a0e41-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4811 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1811-02-26/ch26/s4"},"text":"act Feb. 26, 1811, ch. 26, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/2/650"},"text":"2 Stat. 650","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
