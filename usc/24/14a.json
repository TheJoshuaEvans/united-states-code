{"tag":"section","attrib":{"id":"idfe8a0e29-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s14a"},"text":null,"children":[{"tag":"num","attrib":{"value":"14a"},"text":"§ 14a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual appropriations for maintenance, operation, and improvement of naval hospitals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Commencing with the fiscal year 1944, annual appropriations in such amounts as may be necessary are authorized from the general fund of the Treasury for the maintenance, operation, and improvement of naval hospitals.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe8a0e2a-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1943-06-15/ch125/s1/c"},"text":"June 15, 1943, ch. 125, § 1(c)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/152"},"text":"57 Stat. 152","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
