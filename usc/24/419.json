{"tag":"section","attrib":{"id":"idfe9f6be4-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s419"},"text":null,"children":[{"tag":"num","attrib":{"value":"419"},"text":"§ 419.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Armed Forces Retirement Home Trust Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idfea1dbe5-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s419/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is hereby established in the Treasury of the United States a trust fund to be known as the Armed Forces Retirement Home Trust Fund. The Fund shall consist of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfea1dbe6-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s419/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such amounts as may be transferred to the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfea1dbe7-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s419/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Moneys deposited in the Fund by the Chief Operating Officer realized from gifts or from the disposition of property and facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfea1dbe8-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s419/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts deposited in the Fund as monthly fees paid by residents of the Retirement Home under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s414"},"text":"section 414 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfea1dbe9-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s419/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts of fines and forfeitures deposited in the Fund under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2772"},"text":"section 2772 of title 10","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfea1dbea-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s419/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts deposited in the Fund as deductions from the pay of enlisted members, warrant officers, and limited duty officers under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s1007/i"},"text":"section 1007(i) of title 37","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfea1dbeb-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s419/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Interest from investments made under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfea1dbec-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s419/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability and use of Fund","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Amounts in the Fund shall be available solely for the operation of the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfea1dbed-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s419/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investments","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Secretary of the Treasury may invest in obligations issued or guaranteed by the United States any monies in the Fund that the Chief Operating Officer determines are not currently needed to pay for the operation of the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfea1dbee-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s419/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Financial Officer of the Armed Forces Retirement Home shall comply with the reporting requirements of subchapter II of chapter 35 of title 31.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idfea1dbef-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1519"},"text":"Pub. L. 101–510, div. A, title XV, § 1519","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1730"},"text":"104 Stat. 1730","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXIV"},"text":"Pub. L. 107–107, div. A, title XIV","children":[],"tail":", §§ 1404(b)(2), 1410(a)(2), (b)(2), "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1260"},"text":"115 Stat. 1260","children":[],"tail":", 1266; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXIV/s1422/g"},"text":"Pub. L. 110–181, div. A, title XIV, § 1422(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/423"},"text":"122 Stat. 423","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s567/b/1"},"text":"Pub. L. 112–81, div. A, title V, § 567(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1425"},"text":"125 Stat. 1425","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfea1dbf0-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfea1dbf1-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idfea1dbf2-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" substituted “Chief Operating Officer” for “Retirement Home Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/181"},"text":"Pub. L. 110–181","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1410/a/2"},"text":"Pub. L. 107–107, § 1410(a)(2)","children":[],"tail":", inserted “Armed Forces” before “Retirement Home Trust Fund” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1404/b/2"},"text":"Pub. L. 107–107, § 1404(b)(2)","children":[],"tail":", substituted “Chief Operating Officer” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1410/b/2"},"text":"Pub. L. 107–107, § 1410(b)(2)","children":[],"tail":", struck out heading and text of subsec. (d). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) During the period beginning on ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"September 30, 1994","children":[],"tail":", the Fund shall contain a separate account for each establishment of the Retirement Home. During that period, contributions shall be collected under subsection (a) of this section for the account of the Naval Home for the purpose of achieving a trust fund five times the estimated annual operating budget of the Naval Home."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Beginning on ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":", funds required for the operation of the United States Soldiers’ and Airmen’s Home shall be drawn from the appropriate account. Beginning on "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":", funds required for the operation of the Naval Home shall be drawn from the account of the Naval Home."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) During the period beginning on ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":", and ending on "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"September 30, 1994","children":[],"tail":"—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) amounts collected as monthly fees paid by residents of the Naval Home and amounts referred to in subsections (a)(4) and (a)(5) of this section derived from enlisted members, warrant officers, and limited duty officers of the Navy, Marine Corps, and Coast Guard shall be credited to the account relating to that establishment; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) amounts collected as monthly fees paid by residents of the United States Soldiers’ and Airmen’s Home and amounts referred to in subsections (a)(4) and (a)(5) of this section derived from members and warrant officers of the Army and Air Force shall be credited to the account relating to that establishment.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idfea1dbf3-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idfea1dbf4-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1541/b"},"text":"section 1541(b) of Pub. L. 101–510","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
