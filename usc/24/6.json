{"tag":"section","attrib":{"id":"idfe879d0a-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"§ 6.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pension paid to fund for benefit of naval hospital","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever any officer, seaman, or marine entitled to a pension is admitted to a naval hospital, his pension, while he remains there, shall be deducted from his accounts and paid to the Secretary of the Navy for the benefit of the fund from which such hospital is maintained.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe879d0b-9d45-11f0-a0db-bff75580f504"},"text":"(R.S. § 4813; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1898-05-04/ch234"},"text":"May 4, 1898, ch. 234","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/377"},"text":"30 Stat. 377","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1899-03-03/ch421"},"text":"Mar. 3, 1899, ch. 421","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/30/1027"},"text":"30 Stat. 1027","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1914-06-30/ch130"},"text":"June 30, 1914, ch. 130","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/398"},"text":"38 Stat. 398","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe879d0c-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe879d0d-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idfe879d0e-9d45-11f0-a0db-bff75580f504"},