{"tag":"section","attrib":{"id":"idfe9f6b84-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416"},"text":null,"children":[{"tag":"num","attrib":{"value":"416"},"text":"§ 416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idfe9f6b85-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Retirement Home shall have an Advisory Council, to be known as the “Armed Forces Retirement Home Advisory Council”. The Advisory Council shall serve the interests of both facilities of the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6b86-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duties","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6b87-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Advisory Council shall provide to the Chief Operating Officer and the Administrator of each facility such guidance and recommendations on the administration of the Retirement Home and the quality of care provided to residents as the Advisory Council considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6b88-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less often than annually, the Advisory Council shall submit to the Secretary of Defense a report summarizing its activities during the preceding year and providing such observations and recommendations with respect to the Retirement Home as the Advisory Council considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6b89-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out its functions, the Advisory Council shall provide for participation in its activities by a representative of the Resident Advisory Committee of each facility of the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6b8a-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Composition","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6b8b-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Advisory Council shall consist of at least 15 members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6b8c-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Advisory Council shall be designated by the Secretary of Defense, except that an individual who is not an employee of the Department of Defense shall be designated, in consultation with the Secretary of Defense, by the head of the Federal department or agency that employs the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6b8d-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Advisory Council shall include the following members:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe9f6b8e-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member who is an expert in nursing home or retirement home administration and financing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6b8f-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member who is an expert in gerontology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6b90-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member who is an expert in financial management.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6b91-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two representatives of the Department of Veterans Affairs, one to be designated from each of the regional offices nearest in proximity to the facilities of the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6b92-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairpersons of the Resident Advisory Committees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6b93-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One enlisted representative of the Services’ Retiree Advisory Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6b94-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The senior noncommissioned officer of one of the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6b95-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two senior representatives of military medical treatment facilities, one to be designated from each of the military hospitals nearest in proximity to the facilities of the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6b96-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/3/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One senior judge advocate from one of the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6b97-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/3/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One senior representative of one of the chief personnel officers of the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6b98-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/3/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other members as the Secretary of Defense may designate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6b99-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the each facility of the Retirement Home shall be a nonvoting member of the Advisory Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6b9a-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall designate one member of the Advisory Council to serve as the Chairperson of the Advisory Council. The Chairperson shall conduct the meetings of the Advisory Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6b9b-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Term of service","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6b9c-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraphs (2), (3), and (4), the term of service of a member of the Advisory Council shall be two years. The Secretary of Defense may designate a member to serve one additional term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6b9d-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Unless earlier terminated by the Secretary of Defense, a person may continue to serve as a member of the Advisory Council after the expiration of the member’s term until a successor is designated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6b9e-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may terminate the term of service of a member of the Advisory Council before the expiration of the member’s term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6b9f-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Advisory Council serves as a member of the Advisory Council only for as long as the member is assigned to or serving in a position for which the duties include the duty to serve as a member of the Advisory Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6ba0-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A vacancy in the Advisory Council shall be filled in the manner in which the original designation was made. A member designated to fill a vacancy occurring before the end of the term of the predecessor shall be designated for the remainder of the term of the predecessor. A vacancy in the Advisory Council shall not affect its authority to perform its duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6ba1-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6ba2-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2), a member of the Advisory Council may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe9f6ba3-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be provided a stipend consistent with the daily government consultant fee for each day on which the member is engaged in the performance of services for the Advisory Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6ba4-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" while away from home or regular place of business in the performance of services for the Advisory Council, be allowed travel expenses (including per diem in lieu of subsistence) in the same manner as a person employed intermittently in Government under sections 5701 through 5707 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6ba5-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s416/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the Advisory Council who is a member of the Armed Forces on active duty or a full-time officer or employee of the United States shall receive no additional pay by reason of serving as a member of the Advisory Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idfe9f6ba6-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1516"},"text":"Pub. L. 101–510, div. A, title XV, § 1516","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s563/a"},"text":"Pub. L. 112–81, div. A, title V, § 563(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1421"},"text":"125 Stat. 1421","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/91/dA/tXIV/s1413/b"},"text":"Pub. L. 115–91, div. A, title XIV, § 1413(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-12-12"},"text":"Dec. 12, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1708"},"text":"131 Stat. 1708","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXIV/s1413/b/2"},"text":"Pub. L. 116–283, div. A, title XIV, § 1413(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4032"},"text":"134 Stat. 4032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe9f6ba7-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe9f6ba8-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idfe9f6ba9-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 416, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1516"},"text":"Pub. L. 101–510, div. A, title XV, § 1516","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1728"},"text":"104 Stat. 1728","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXIV/s1406"},"text":"Pub. L. 107–107, div. A, title XIV, § 1406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1262"},"text":"115 Stat. 1262","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/181/dA/tXIV/s1422/e"},"text":"Pub. L. 110–181, div. A, title XIV, § 1422(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-01-28"},"text":"Jan. 28, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/421"},"text":"122 Stat. 421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title X, § 1061(b)(12), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4613"},"text":"122 Stat. 4613","children":[],"tail":", related to local boards of trustees, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s563/a"},"text":"Pub. L. 112–81, div. A, title V, § 563(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1421"},"text":"125 Stat. 1421","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idfe9f6baa-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" struck out dash after “shall” and subpar. (A) designation before “provide”, substituted period at end for “; and”, and struck out subpar. (B) which read as follows: “make recommendations to the Inspector General of the Department of Defense regarding issues that the Inspector General should investigate.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1413/b/1"},"text":"Pub. L. 115–91, § 1413(b)(1)","children":[],"tail":", substituted “15 members.” for “15 members, each of whom shall be a full or part-time Federal employee or a member of the Armed Forces.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91/s1413/b/2"},"text":"Pub. L. 115–91, § 1413(b)(2)","children":[],"tail":", substituted “may” for “shall” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
