{"tag":"section","attrib":{"id":"idfe9d2170-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415"},"text":null,"children":[{"tag":"num","attrib":{"value":"415"},"text":"§ 415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Operating Officer","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idfe9d2171-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Appointment","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9d2172-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall appoint the Chief Operating Officer of the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9d2173-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Operating Officer shall serve at the pleasure of the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9d2174-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense shall evaluate the performance of the Chief Operating Officer at least once each year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9d2175-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Qualifications","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"To qualify for appointment as the Chief Operating Officer, a person shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9d2176-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be a continuing care retirement community professional;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9d2177-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have appropriate leadership and management skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9d2178-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have experience and expertise in the operation and management of retirement homes and in the provision of long-term medical care for older persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9d2179-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibilities","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9d217a-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Operating Officer shall be responsible to the Secretary of Defense for the overall direction, operation, and management of the Retirement Home and shall report to the Secretary on those matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9d217b-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Operating Officer shall supervise the operation and administration of the Armed Forces Retirement Home—Washington and the Armed Forces Retirement Home—Gulfport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9d217c-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Chief Operating Officer shall perform the following duties:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe9d217d-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issue, and ensure compliance with, appropriate rules for the operation of the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9d217e-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Periodically visit, and inspect the operation of, the facilities of the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9d217f-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Periodically examine and audit the accounts of the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6b70-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Establish any advisory body or bodies that the Chief Operating Officer considers to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6b71-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6b72-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense may prescribe the pay of the Chief Operating Officer, except that the annual rate of basic pay, including locality pay, of the Chief Operating Officer may not exceed the annual rate of basic pay payable for level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6b73-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to basic pay and any locality pay prescribed for the Chief Operating Officer, the Secretary may award the Chief Operating Officer, not more than once each year, a bonus based on the performance of the Chief Operating Officer for the year. The Secretary shall prescribe the amount of any such bonus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6b74-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total amount of the basic pay and bonus paid the Chief Operating Officer for a year under this section may not exceed the annual rate of basic pay payable for level I of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5312"},"text":"section 5312 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6b75-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative staff","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6b76-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Operating Officer may, subject to the approval of the Secretary of Defense, appoint a staff to assist in the performance of the Chief Operating Officer’s duties in the overall administration of the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6b77-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Chief Operating Officer shall prescribe the rates of pay applicable to the members of the staff appointed under paragraph (1), except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe9f6b78-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a staff member who is a member of the Armed Forces on active duty or who is a full-time officer or employee of the United States may not receive additional pay by reason of service on the administrative staff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9f6b79-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the limitations in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5373"},"text":"section 5373 of title 5","children":[],"tail":", relating to pay set by administrative action, shall apply to the rates of pay prescribed under this paragraph."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9f6b7a-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance of gifts","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9f6b7b-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Operating Officer may accept, receive, solicit, hold, administer, and use any gift, devise, or bequest, either absolutely or in trust, of real or personal property, or any income therefrom or other interest therein, for the benefit of the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9f6b7c-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s415/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Monies received as gifts, or realized from the disposition of property and facilities received as gifts, shall be deposited in the Armed Forces Retirement Home Trust Fund.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idfe9f6b7d-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1515"},"text":"Pub. L. 101–510, div. A, title XV, § 1515","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1726"},"text":"104 Stat. 1726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/190/dA/tX/s1062/a/4"},"text":"Pub. L. 102–190, div. A, title X, § 1062(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-05"},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1475"},"text":"105 Stat. 1475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIII/s366/b"},"text":"Pub. L. 103–160, div. A, title III, § 366(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1630"},"text":"107 Stat. 1630","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1051/a"},"text":"Pub. L. 104–201, div. A, title X, § 1051(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2648"},"text":"110 Stat. 2648","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXIV/s1404/a"},"text":"Pub. L. 107–107, div. A, title XIV, § 1404(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1259"},"text":"115 Stat. 1259","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s563/b/2"},"text":"Pub. L. 112–81, div. A, title V, § 563(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1423"},"text":"125 Stat. 1423","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXIV/s1414"},"text":"Pub. L. 115–232, div. A, title XIV, § 1414","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2092"},"text":"132 Stat. 2092","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe9f6b7e-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe9f6b7f-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idfe9f6b80-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “The Chief Operating Officer may accept gifts of money, property, and facilities on behalf of the Retirement Home.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" struck out “, including the Local Boards of those facilities” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to the Chief Operating Officer of the Retirement Home for provisions relating to the composition and operation of Retirement Home Board."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1051/a"},"text":"Pub. L. 104–201, § 1051(a)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1051/b/1"},"text":"Pub. L. 104–201, § 1051(b)(1)","children":[],"tail":", amended heading and text of subsec. (f) generally. Prior to amendment, text read as follows: “Not later than the effective date specified in section 1541(a), members of the Retirement Home Board and the members of each Local Board shall be first appointed to staggered terms.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1993—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/160"},"text":"Pub. L. 103–160","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “The Secretary of Defense shall select one of the members of the Retirement Home Board to serve as chairman. The term of office of the chairman of the Retirement Home Board shall be five years.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1062/a/4/A"},"text":"Pub. L. 102–190, § 1062(a)(4)(A)","children":[],"tail":", substituted “Local Boards” for “local boards”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1062/a/4/B"},"text":"Pub. L. 102–190, § 1062(a)(4)(B)","children":[],"tail":", substituted “that Board” for “that board”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idfe9f6b81-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idfe9f6b82-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective one year after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", except that provisions of this section relating to appointment and designation of members of Retirement Home Board and Local Boards effective "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":", see section 1541(a), (c) of "},{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idfe9f6b83-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1051/b/2"},"text":"Pub. L. 104–201, div. A, title X, § 1051(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2649"},"text":"110 Stat. 2649","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/201/dA/tX/s1051/b/2"},"text":"“The amendment made by this subsection [amending this section] shall not affect the staggered terms of members of the Armed Forces Retirement Home Board or a Local Board of the Retirement Home under section 1515(f) of such Act [subsec. (f) of this section], as such section is in effect before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
