{"tag":"section","attrib":{"id":"idfe983f85-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s301"},"text":null,"children":[{"tag":"num","attrib":{"value":"301"},"text":"§ 301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Ancon Hospital to be known as Gorgas Hospital","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In recognition of his distinguished services to humanity and as a fitting perpetuation of the name and memory of Major General William Crawford Gorgas, the Government hospital within the Canal Zone, near the City of Panama, known prior to ","children":[{"tag":"date","attrib":{"date":"1928-03-24"},"text":"March 24, 1928","children":[],"tail":", as the Ancon Hospital, shall after such date be known and designated on the public records as the Gorgas Hospital."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe983f86-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1928-03-24/ch240/s1"},"text":"Mar. 24, 1928, ch. 240, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/365"},"text":"45 Stat. 365","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe983f87-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe983f88-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idfe983f89-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For definition of Canal Zone, referred to in text, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s3602/b"},"text":"section 3602(b) of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
