{"tag":"section","attrib":{"id":"idfea1dc19-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s421"},"text":null,"children":[{"tag":"num","attrib":{"value":"421"},"text":"§ 421.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of residents for services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idfea1dc1a-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s421/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Operating Officer is authorized to accept for the Armed Forces Retirement Home the part-time or intermittent services of a resident of the Retirement Home, to pay the resident for such services, and to fix the rate of such pay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfea1dc1b-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s421/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employment status","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"A resident receiving pay for services authorized under subsection (a) shall not, by reason of performing such services and receiving pay for such services, be considered as—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfea1dc1c-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s421/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receiving the pay of a position or being employed in a position for the purposes of section 5532 ","children":[{"tag":"ref","attrib":{"idref":"fn002009"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002009"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 5; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfea1dc1d-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s421/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" being an employee of the United States for any purpose other than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfea1dc1e-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s421/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subchapter I of chapter 81 of title 5 (relating to compensation for work-related injuries); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfea1dc1f-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s421/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 171 of title 28 (relating to claims for damages or loss).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfea1dc20-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s421/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Position” defined","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"In subsection (b)(1), the term “position” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5531"},"text":"section 5531 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idfea1dc21-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1521"},"text":"Pub. L. 101–510, div. A, title XV, § 1521","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIII/s385/a"},"text":"Pub. L. 102–484, div. A, title III, § 385(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2394"},"text":"106 Stat. 2394","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1052/b"},"text":"Pub. L. 104–201, div. A, title X, § 1052(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2650"},"text":"110 Stat. 2650","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXIV/s1404/b/3"},"text":"Pub. L. 107–107, div. A, title XIV, § 1404(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1260"},"text":"115 Stat. 1260","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfea1dc22-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfea1dc23-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idfea1dc24-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5532"},"text":"Section 5532 of title 5","children":[],"tail":", referred to in subsec. (b)(1), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/65/dA/tVI/s651/a/1"},"text":"Pub. L. 106–65, div. A, title VI, § 651(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-10-05"},"text":"Oct. 5, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/664"},"text":"113 Stat. 664","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idfea1dc25-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107"},"text":"Pub. L. 107–107","children":[],"tail":" substituted “Chief Operating Officer” for “Chairman of the Armed Forces Retirement Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “being an employee of the United States for any other purpose.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idfea1dc26-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idfea1dc27-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Forgiveness of Indebtedness","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/484/dA/tIII/s385/b"},"text":"Pub. L. 102–484, div. A, title III, § 385(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/2394"},"text":"106 Stat. 2394","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/484/dA/tIII/s385/b"},"text":"“The Chairman of the Armed Forces Retirement Board is authorized to cancel the indebtedness of any resident of the Armed Forces Retirement Home for repayment to the United States of amounts paid the resident for services provided to the Retirement Home before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-23"},"text":"Oct. 23, 1992","children":[],"tail":"] if the Chairman determines that it would be in the interest of the United States to do so and against equity and good conscience to require the repayment.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
