{"tag":"section","attrib":{"id":"idfe9d211a-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412"},"text":null,"children":[{"tag":"num","attrib":{"value":"412"},"text":"§ 412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Residents of Retirement Home","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idfe9d211b-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons eligible to be residents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b), the following persons who served as members of the Armed Forces, at least one-half of whose service was not commissioned service (other than as a warrant officer or limited-duty officer), are eligible to become residents of the Retirement Home:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9d211c-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons who were discharged or released from service in the Armed Forces after 20 or more years of active service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9d211d-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons who are determined under rules prescribed by the Chief Operating Officer to be suffering from a service-connected disability incurred in the line of duty in the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9d211e-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons who served in a war theater during a time of war declared by Congress or were eligible for hostile fire special pay under section 310 or 351 of title 37 and who are determined under rules prescribed by the Chief Operating Officer to be suffering from injuries, disease, or disability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9d211f-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Persons who served in a women’s component of the Armed Forces before ","children":[{"tag":"date","attrib":{"date":"1948-06-12"},"text":"June 12, 1948","children":[],"tail":", and are determined under rules prescribed by the Chief Operating Officer to be eligible for admission because of compelling personal circumstances."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9d2120-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Persons who are eligible for retired pay under chapter 1223 of title 10 and are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe9d2121-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eligible for care under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1710"},"text":"section 1710 of title 38","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9d2122-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrolled in coverage under chapter 55 of title 10; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9d2123-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enrolled in a qualified health plan (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s18021/a"},"text":"section 18021(a) of title 42","children":[],"tail":") that is acceptable to the Chief Operating Officer."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9d2124-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Persons ineligible to be residents","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following persons are ineligible to become a resident of the Retirement Home:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9d2125-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe9d2126-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been convicted of a felony; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9d2127-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was discharged or released from service in the Armed Forces under other than honorable conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9d2128-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person with substance abuse or mental health problems, except upon a judgment and satisfactory determination by the Chief Operating Officer that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe9d2129-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person has been evaluated by a qualified health professional selected by the Retirement Home;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9d212a-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Retirement Home can accommodate the person’s condition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9d212b-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person agrees to such conditions of residency as the Retirement Home may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9d212c-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acceptance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"To apply for acceptance as a resident of a facility of the Retirement Home, a person eligible to be a resident shall submit to the Administrator of that facility an application in such form and containing such information as the Chief Operating Officer may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9d212d-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Priorities for acceptance","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Operating Officer shall establish a system of priorities for the acceptance of residents so that the most deserving applicants will be accepted whenever the number of eligible applicants is greater than the Retirement Home can accommodate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfe9d212e-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Spouses of residents","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9d212f-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to admit","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise established pursuant to subsection (d), the spouse of a person accepted as a resident of a facility of the Retirement Home may be admitted to that facility if the spouse—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe9d2130-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a covered beneficiary within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s1072/5"},"text":"section 1072(5) of title 10","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9d2131-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not ineligible to become a resident as provided in subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9d2132-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submits an application for admittance in accordance with subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9d2133-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s412/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Treatment as resident","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"A spouse admitted in accordance with paragraph (1) shall be a resident of the Retirement Home consistent with this chapter, except as the Chief Operating Officer may otherwise provide.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idfe9d2134-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1512"},"text":"Pub. L. 101–510, div. A, title XV, § 1512","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1724"},"text":"104 Stat. 1724","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXIV"},"text":"Pub. L. 107–107, div. A, title XIV","children":[],"tail":", §§ 1404(b)(1)(A), 1405(a), 1410(b)(1), "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1260"},"text":"115 Stat. 1260","children":[],"tail":", 1261, 1266; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV"},"text":"Pub. L. 112–81, div. A, title V","children":[],"tail":", §§ 564(b)(1), 567(c)(6), "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1424"},"text":"125 Stat. 1424","children":[],"tail":", 1426; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s618/f"},"text":"Pub. L. 114–328, div. A, title VI, § 618(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2160"},"text":"130 Stat. 2160","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tXIV/s1412"},"text":"Pub. L. 115–232, div. A, title XIV, § 1412","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/2090"},"text":"132 Stat. 2090","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXIV/s1412/a"},"text":"Pub. L. 116–283, div. A, title XIV, § 1412(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4030"},"text":"134 Stat. 4030","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe9d2135-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe9d2136-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idfe9d2137-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in subsec. (e)(2), was in the original “this Act”, and was translated as meaning title XV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA"},"text":"Pub. L. 101–510, div. A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1722"},"text":"104 Stat. 1722","children":[],"tail":", known as the Armed Forces Retirement Home Act of 1991, which is classified principally to this chapter, to reflect the probable intent of Congress. For complete classification of title XV to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s401"},"text":"section 401 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idfe9d2138-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1412/a/1"},"text":"Pub. L. 116–283, § 1412(a)(1)","children":[],"tail":", struck out “active” before “commissioned service” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1412/a/2"},"text":"Pub. L. 116–283, § 1412(a)(2)","children":[],"tail":", struck out “are 60 years of age or over and” before “were discharged”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1412/a/3"},"text":"Pub. L. 116–283, § 1412(a)(3)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (d) relating to persons eligible to be residents, persons ineligible to be residents, acceptance, and priorities for acceptance, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Pub. L. 114–328","children":[],"tail":" inserted “or 351” after “section 310”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s567/c/6"},"text":"Pub. L. 112–81, § 567(c)(6)","children":[],"tail":", made technical amendment to section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s564/b/1"},"text":"Pub. L. 112–81, § 564(b)(1)","children":[],"tail":", substituted “Administrator” for “Director”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsecs. (a), (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1404/b/1/A"},"text":"Pub. L. 107–107, § 1404(b)(1)(A)","children":[],"tail":", substituted “Chief Operating Officer” for “Retirement Home Board” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1405/a"},"text":"Pub. L. 107–107, § 1405(a)","children":[],"tail":", struck out heading and text of subsec. (e). Text read as follows: “A resident of the Retirement Home who leaves the Retirement Home for more than 45 consecutive days (other than for inpatient medical care) shall be required to reapply for acceptance as a resident.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1410/b/1"},"text":"Pub. L. 107–107, § 1410(b)(1)","children":[],"tail":", struck out heading and text of subsec. (f). Text read as follows: “Residents of the Naval Home and the United States Soldiers’ and Airmen’s Home as of the effective date specified in section 1541(a)—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) shall not be required to apply for acceptance as residents of the Retirement Home; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) shall become residents of the Retirement Home on that date.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idfe9d2139-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idfe9d213a-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective one year after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/101/510/s1541/a"},"text":"section 1541(a) of Pub. L. 101–510","children":[],"tail":", formerly set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
