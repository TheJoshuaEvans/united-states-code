ef","attrib":{"href":"/us/stat/138/2129"},"text":"138 Stat. 2129","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe9ab0db-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe9ab0dc-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idfe9ab0dd-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This chapter, referred to in text, was in the original “this title”, meaning title XV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA"},"text":"Pub. L. 101–510, div. A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1722"},"text":"104 Stat. 1722","children":[],"tail":", which is classified principally to this chapter. For complete classification of title XV to the Code, see Short Title note below and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idfe9ab0de-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Par. (5)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1422/a"},"text":"Pub. L. 118–159, § 1422(a)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/159/s1422/b"},"text":"Pub. L. 118–159, § 1422(b)","children":[],"tail":", added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Pars. (2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" added pars. (3) and (4), redesignated former par. (3) as (2), and struck out former par. (2) which read as follows: “The term ‘Local Board’ means a Local Board of Trustees established under "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s416"},"text":"section 416 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s205/a/1"},"text":"Pub. L. 111–281, § 205(a)(1)","children":[],"tail":", struck out par. (4) which read as follows: “The term ‘Armed Forces’ does not include the Coast Guard when it is not operating as a service in the Navy.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s205/a/2"},"text":"Pub. L. 111–281, § 205(a)(2)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (6)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/281/s205/a/3"},"text":"Pub. L. 111–281, § 205(a)(3)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Pars. (1) to (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1402/1"},"text":"Pub. L. 107–107, § 1402(1)","children":[],"tail":", added pars. (1) to (3) and struck out former pars. (1) to (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) The term ‘Retirement Home’ means the Armed Forces Retirement Home established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s411/a"},"text":"section 411(a) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The term ‘Retirement Home Board’ means the Armed Forces Retirement Home Board.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The term ‘Local Board’ means a Board of Trustees established for each facility of the Retirement Home maintained as a separate establishment of the Retirement Home for administrative purposes.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1402/1"},"text":"Pub. L. 107–107, § 1402(1)","children":[],"tail":", (2), redesignated par. (6) as (4) and struck out former par. (4) which read as follows: “The term ‘Director’ means a Director of the Armed Forces Retirement Home appointed under "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s417/a"},"text":"section 417(a) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1402/1"},"text":"Pub. L. 107–107, § 1402(1)","children":[],"tail":", (2), redesignated par. (7) as (5) and struck out former par. (5) which read as follows: “The term ‘Fund’ means the Armed Forces Retirement Home Trust Fund established under "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s419/a"},"text":"section 419(a) of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1402/3/A"},"text":"Pub. L. 107–107, § 1402(3)(A)","children":[],"tail":", substituted “for Personnel” for “, Manpower and Personnel”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1402/3/B"},"text":"Pub. L. 107–107, § 1402(3)(B)","children":[],"tail":", substituted “for Manpower and Reserve Affairs” for “with responsibility for personnel matters”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1402/2"},"text":"Pub. L. 107–107, § 1402(2)","children":[],"tail":", redesignated pars. (6) to (8) as (4) to (6), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Par. (7)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" amended subpar. (D) generally. Prior to amendment, subpar. (D) read as follows: “the Deputy Chief of Staff for Manpower of the Marine Corps.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idfe9ab0df-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idfe9ab0e0-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1541"},"text":"Pub. L. 101–510, div. A, title XV, § 1541","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1736"},"text":"104 Stat. 1736","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/103/160/dA/tIII/s366/f"},"text":"Pub. L. 103–160, div. A, title III, § 366(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-11-30"},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/1632"},"text":"107 Stat. 1632","children":[],"tail":", which provided that title XV of "},{"tag":"ref","attrib":{"href":"/us/pl/101/510"},"text":"Pub. L. 101–510","children":[],"tail":" (see Short Title note below) and the amendments made by such title were effective one year after "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", except that sections 1519, 1531, and 1533(c)(1) of the Act (enacting sections 419 and 431 of this title and amending "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1321"},"text":"section 1321 of Title 31","children":[],"tail":", Money and Finance) were effective "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", provisions of section 1515 of the Act (enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s415"},"text":"section 415 of this title","children":[],"tail":") relating to the appointment and designation of members of the Retirement Home Board and Local Boards were effective "},{"tag":"date","attrib":{"date":"1991-10-01"},"text":"Oct. 1, 1991","children":[],"tail":", and section 1520 of the Act (enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t24/s420"},"text":"section 420 of this title","children":[],"tail":") was applicable to the estate of each resident of the Armed Forces Retirement Home who dies after "},{"tag":"date","attrib":{"date":"1989-11-29"},"text":"Nov. 29, 1989","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXIV/s1410/b/3"},"text":"Pub. L. 107–107, div. A, title XIV, § 1410(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1266"},"text":"115 Stat. 1266","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"idfe9ab0e1-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1501/a"},"text":"Pub. L. 101–510, div. A, title XV, § 1501(a)","children":[],"tail":", formerly § 1501, "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1722"},"text":"104 Stat. 1722","children":[],"tail":", as renumbered by "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXIV/s1410/c/1"},"text":"Pub. L. 107–107, div. A, title XIV, § 1410(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1266"},"text":"115 Stat. 1266","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/107/dA/tXIV/s1410/c/1"},"text":"“This title [enacting this chapter, amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s6a"},"text":"section 6a of this title","children":[],"tail":", sections 1089, 2575, 2772, 4624, 4712, 9624, and 9712 of Title 10, Armed Forces, "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1321"},"text":"section 1321 of Title 31","children":[],"tail":", Money and Finance, "},{"tag":"ref","attrib":{"href":"/us/usc/t37/s1007"},"text":"section 1007 of Title 37","children":[],"tail":", Pay and Allowances of the Uniformed Services, and "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s906"},"text":"section 906 of Title 44","children":[],"tail":", Public Printing and Documents, repealing sections 21a to 25, 41 to 43, 44b, 45 to 46b, 48 to 50, 54, and 59 of this title and sections 4713 and 9713 of Title 10, and enacting provisions set out as notes above and under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2772"},"text":"section 2772 of Title 10","children":[],"tail":"] may be cited as the ‘Armed Forces Retirement Home Act of 1991’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idfe9ab0e2-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
