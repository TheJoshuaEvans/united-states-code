{"tag":"section","attrib":{"id":"idfe9ab0c5-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401"},"text":null,"children":[{"tag":"num","attrib":{"value":"401"},"text":"§ 401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfe9ab0c6-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “Retirement Home” includes the institutions established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s411"},"text":"section 411 of this title","children":[],"tail":", as follows:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe9ab0c7-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Armed Forces Retirement Home—Washington.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9ab0c8-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Armed Forces Retirement Home—Gulfport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9ab0c9-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms “Armed Forces Retirement Home Trust Fund” and “Fund” mean the Armed Forces Retirement Home Trust Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s419/a"},"text":"section 419(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9ab0ca-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Advisory Council” means the Armed Forces Retirement Home Advisory Council established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s416"},"text":"section 416 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9ab0cb-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Resident Advisory Committee” means an elected body of residents at a facility of the Retirement Home established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t24/s416a"},"text":"section 416a of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9ab0cc-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “chief personnel officers” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe9ab0cd-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Deputy Chief of Staff for Personnel of the Army;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9ab0ce-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief of Naval Personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9ab0cf-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Deputy Chief of Staff for Personnel of the Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9ab0d0-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Deputy Commandant of the Marine Corps for Manpower and Reserve Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9ab0d1-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Commandant of the Coast Guard for Human Resources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9ab0d2-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Deputy Chief of Space Operations for Human Capital of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfe9ab0d3-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “senior noncommissioned officers” means the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfe9ab0d4-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Sergeant Major of the Army.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9ab0d5-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Master Chief Petty Officer of the Navy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9ab0d6-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Master Sergeant of the Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9ab0d7-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Sergeant Major of the Marine Corps.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9ab0d8-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Master Chief Petty Officer of the Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfe9ab0d9-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s401/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Master Sergeant of the Space Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"