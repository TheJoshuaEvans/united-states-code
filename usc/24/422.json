{"tag":"section","attrib":{"id":"idfea1dc28-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422"},"text":null,"children":[{"tag":"num","attrib":{"value":"422"},"text":"§ 422.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to accept certain uncompensated services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idfea1dc29-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to accept services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"Subject to subsection (b) and notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", the Chief Operating Officer or the Administrator of a facility of the Retirement Home may accept from any person voluntary personal services or gratuitous services."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfea1dc2a-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements and limitations","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfea1dc2b-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Operating Officer or the Administrator of a facility accepting the services shall notify the person offering the services of the scope of the services accepted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfea1dc2c-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Chief Operating Officer or Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfea1dc2d-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervise the person providing the services to the same extent as that official would supervise a compensated employee providing similar services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfea1dc2e-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the person is licensed, privileged, has appropriate credentials, or is otherwise qualified under applicable laws or regulations to provide such services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfea1dc2f-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person providing services accepted under subsection (a) may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfea1dc30-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve in a policymaking position of the Retirement Home; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfea1dc31-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be compensated for the services by the Retirement Home.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfea1dc32-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to recruit and train persons providing services","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Operating Officer or the Administrator of a facility of the Retirement Home may recruit and train persons to provide services authorized to be accepted under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfea1dc33-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Status of persons providing services","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idfea1dc34-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (3), while providing services accepted under subsection (a) or receiving training under subsection (c), a person shall be considered to be an employee of the Federal Government only for purposes of the following provisions of law:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfea1dc35-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subchapter I of chapter 81 of title 5 (relating to compensation for work-related injuries).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfea1dc36-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 171 of title 28 (relating to claims for damages or loss).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfea1dc37-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person providing services accepted under subsection (a) shall be considered to be an employee of the Federal Government under paragraph (1) only with respect to services that are within the scope of the services accepted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idfea1dc38-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For purposes of determining the compensation for work-related injuries payable under chapter 81 of title 5 (pursuant to this subsection) to a person providing services accepted under subsection (a), the monthly pay of the person for such services shall be deemed to be the amount determined by multiplying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idfea1dc39-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the average monthly number of hours that the person provided the services, by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idfea1dc3a-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the minimum wage determined in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s206/a/1"},"text":"section 206(a)(1) of title 29","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idfea1dc3b-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s422/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reimbursement of incidental expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"p","attrib":{},"text":"The Chief Operating Officer or the Administrator of a facility accepting services under subsection (a) may provide for reimbursement of a person for incidental expenses incurred by the person in providing the services accepted under subsection (a). The Chief Operating Officer or Administrator shall determine which expenses qualify for reimbursement under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idfea1dc3c-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/510/dA/tXV/s1522"},"text":"Pub. L. 101–510, div. A, title XV, § 1522","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tX/s1052/a"},"text":"Pub. L. 104–201, div. A, title X, § 1052(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2649"},"text":"110 Stat. 2649","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/107/dA/tXIV/s1404/b/4"},"text":"Pub. L. 107–107, div. A, title XIV, § 1404(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-28"},"text":"Dec. 28, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/1260"},"text":"115 Stat. 1260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/dA/tV/s564/b/1"},"text":"Pub. L. 112–81, div. A, title V, § 564(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1424"},"text":"125 Stat. 1424","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfea1dc3d-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfea1dc3e-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idfea1dc3f-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" substituted “Administrator” for “Director” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1404/b/4/A"},"text":"Pub. L. 107–107, § 1404(b)(4)(A)","children":[],"tail":", substituted “Chief Operating Officer or the Director of a facility” for “Chairman of the Retirement Home Board or the Director of each establishment” and struck out “unless the acceptance of the voluntary services is disapproved by the Retirement Home Board” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1404/b/4/B"},"text":"Pub. L. 107–107, § 1404(b)(4)(B)","children":[],"tail":", substituted “Chief Operating Officer or the Director of a facility” for “Chairman of the Retirement Home Board or the Director of the establishment” and inserted “offering the services” after “notify the person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1404/b/4/C"},"text":"Pub. L. 107–107, § 1404(b)(4)(C)","children":[],"tail":", substituted “Chief Operating Officer” for “Chairman” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1404/b/4/D"},"text":"Pub. L. 107–107, § 1404(b)(4)(D)","children":[],"tail":", substituted “Chief Operating Officer or the Director of a facility” for “Chairman of the Retirement Home Board or the Director of an establishment”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/107/s1404/b/4/E"},"text":"Pub. L. 107–107, § 1404(b)(4)(E)","children":[],"tail":", substituted “Chief Operating Officer or the Director of a facility” for “Chairman of the Retirement Board or the Director of the establishment” and “Chief Operating Officer or Director” for “Chairman or Director”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
