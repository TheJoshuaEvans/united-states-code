{"tag":"section","attrib":{"id":"idfe8ec943-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s152"},"text":null,"children":[{"tag":"num","attrib":{"value":"152"},"text":"§ 152.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Name; control, rules and regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Said reserve shall be known as the Battle Mountain Sanitarium Reserve, and shall be under the exclusive control of the Secretary of Veterans Affairs in connection with the Battle Mountain Sanitarium at Hot Springs, South Dakota, whose duty it shall be to prescribe such rules and regulations and establish such service as the Secretary may consider necessary for the care and management of the same.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe8ec944-9d45-11f0-a0db-bff75580f504"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1906-03-22/ch1127/s2"},"text":"Mar. 22, 1906, ch. 1127, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/83"},"text":"34 Stat. 83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/54/s13/i/2"},"text":"Pub. L. 102–54, § 13(i)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-06-13"},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/276"},"text":"105 Stat. 276","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe8ec945-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe8ec946-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idfe8ec947-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/54"},"text":"Pub. L. 102–54","children":[],"tail":" substituted “Secretary of Veterans Affairs” for “Board of Managers of the National Home for Disabled Volunteer Soldiers” and “as the Secretary may consider necessary” for “as they may deem necessary”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
