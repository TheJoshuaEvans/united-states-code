{"tag":"section","attrib":{"id":"idfe8a0e30-9d45-11f0-a0db-bff75580f504","identifier":"/us/usc/t24/s16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"§ 16.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allowance of rations to Navy hospitals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"For every Navy officer, seaman, or marine admitted into a Navy hospital, the institution shall be allowed one ration per day during his continuance therein, to be deducted from the account of the United States with such officer, seaman, or marine.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idfe8a0e31-9d45-11f0-a0db-bff75580f504"},"text":"(R.S. § 4812.)","children":[],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idfe8a0e32-9d45-11f0-a0db-bff75580f504"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idfe8a0e33-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idfe8a0e34-9d45-11f0-a0db-bff75580f504"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"R.S. § 4812 derived from ","children":[{"tag":"ref","attrib":{"href":"/us/act/1811-02-26/ch26/s5"},"text":"act Feb. 26, 1811, ch. 26, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/2/650"},"text":"2 Stat. 650","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
