{"tag":"section","attrib":{"id":"id7497a798-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150415"},"text":null,"children":[{"tag":"num","attrib":{"value":"150415"},"text":"§ 150415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7497a799-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150415/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall submit to Congress an annual report describing the activities of the corporation during the preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7497a79a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150415/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submittal Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each annual report under this section shall be submitted at the same time as the report of the audit of the corporation required by section 10101(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7497a79b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150415/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Not Public Document","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No annual report under this section shall be printed as a public document.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7497a79c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLI/s5103/a"},"text":"Pub. L. 118–31, div. E, title LI, § 5103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/938"},"text":"137 Stat. 938","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
