{"tag":"section","attrib":{"id":"id744dcd9d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s136"},"text":null,"children":[{"tag":"num","attrib":{"value":"136"},"text":"§ 136.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Peace Officers Memorial Day","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President is requested to issue each year a proclamation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id744dcd9e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s136/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designating May 15 as Peace Officers Memorial Day in honor of Federal, State, and local officers killed or disabled in the line of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id744dcd9f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s136/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directing United States Government officials to display the flag of the United States at halfstaff on all Government buildings on Peace Officers Memorial Day, as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t4/s7/m"},"text":"section 7(m) of title 4","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id744dcda0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s136/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inviting State and local governments and the people of the United States to observe Peace Officers Memorial Day with appropriate ceremonies and activities, including the display of the flag at halfstaff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id744dcda1-3a