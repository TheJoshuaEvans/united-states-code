{"tag":"section","attrib":{"id":"id748e3264-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s120109"},"text":null,"children":[{"tag":"num","attrib":{"value":"120109"},"text":"§ 120109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation shall have a designated agent in the District of Columbia to receive service of process for the corporation. Notice to or service on the agent is notice to or service on the corporation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id748e3265-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/254/s1/a/2"},"text":"Pub. L. 110–254, § 1(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2421"},"text":"122 Stat. 2421","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
