{"tag":"section","attrib":{"id":"id746cc777-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22506"},"text":null,"children":[{"tag":"num","attrib":{"value":"22506"},"text":"§ 22506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746cc778-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall be nonprofit, nonpolitical, nonsectarian, and nonpartisan, and may not promote the candidacy of an individual seeking public office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746cc779-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ownership and Use of Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not accept, own, or hold, directly or indirectly, any property not reasonably necessary to carry out the purposes of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746cc77a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1305"},"text":"112 Stat. 1305","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746cc77b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n"