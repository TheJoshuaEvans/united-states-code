{"tag":"section","attrib":{"id":"id74b1e672-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501"},"text":null,"children":[{"tag":"num","attrib":{"value":"220501"},"text":"§ 220501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Short title and definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74b1e673-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Short Title","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter may be cited as the “Ted Stevens Olympic and Amateur Sports Act”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b1e674-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b1e675-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “amateur athlete” means an athlete who meets the eligibility standards established by the national governing body or paralympic sports organization for the sport in which the athlete competes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e676-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “amateur athletic competition” means a contest, game, meet, match, tournament, regatta, or other event in which amateur athletes compete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e677-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “amateur sports organization” means a not-for-profit corporation, association, or other group organized in the United States that sponsors or arranges an amateur athletic competition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e678-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “Athletes’ Advisory Council” means the entity established and maintained under section 220504(b)(2)(A) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74b1e679-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is composed of, and elected by, amateur athletes to ensure communication between the corporation and currently active amateur athletes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b1e67a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves as a source of amateur-athlete opinion and advice with respect to policies and proposed policies of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e67b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Center” means the United States Center for SafeSport designated under section 220541.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e67c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “child abuse” has the meaning given the term in section 212 of the Victims of Child Abuse Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20302"},"text":"34 U.S.C. 20302","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e67d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “corporation” means the United States Olympic and Paralympic Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e67e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “international amateur athletic competition” means an amateur athletic competition between one or more athletes representing the United States, individually or as a team, and one or more athletes representing a foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e67f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “national governing body” means an amateur sports organization, a high-performance management organization, or a paralympic sports organization that is certified by the corporation under section 220521.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e680-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “protected individual” means any amateur athlete, coach, trainer, manager, administrator, or official associated with the corporation or a national governing body.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e681-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “retaliation” means any adverse or discriminatory action, or the threat of an adverse or discriminatory action, including removal from a training facility, reduced coaching or training, reduced meals or housing, and removal from competition, carried out against a protected individual as a result of any communication, including the filing of a formal complaint, by the protected individual or a parent or legal guardian of the protected individual relating to the allegation of physical abuse, sexual harassment, or emotional abuse, with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74b1e682-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b1e683-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a coach, trainer, manager, administrator, or official associated with the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b1e684-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b1e685-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/11/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal or State law enforcement authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b1e686-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/11/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Equal Employment Opportunity Commission; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b1e687-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/11/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e688-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220501/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “sanction” means a certificate of approval issued by a national governing body.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74b1e689-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1466"},"text":"112 Stat. 1466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s142/b/2"},"text":"Pub. L. 105–277, div. C, title I, § 142(b)(2)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-603"},"text":"112 Stat. 2681–603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s5/13"},"text":"Pub. L. 109–284, § 5(13)","children":[],"tail":", (14), "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1212"},"text":"120 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/126/tII/s202/b"},"text":"Pub. L. 115–126, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-14"},"text":"Feb. 14, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/323"},"text":"132 Stat. 323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/189/s3"},"text":"Pub. L. 116–189, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/944"},"text":"134 Stat. 944","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74b1e68a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74b1e68b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74b1e68c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220501","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:373.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-21/ch975"},"text":"Sept. 21, 1950, ch. 975","children":[],"tail":", title I, § 103, as added "},{"tag":"html:span","attrib":{},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/606/s1/b"},"text":"Pub. L. 95–606, § 1(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/3045"},"text":"92 Stat. 3045","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3), the words “club, federation, union” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (5), the words “one or more athletes” are substituted for “any athlete or athletes” and for “any athletic or athletes” for clarity and to correct a grammatical error.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (6), a reference to section 220522 (restating 36:391(b) and (c)) is unnecessary because section 220521 incorporates the eligibility requirements of section 220522.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74b1e68d-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74b1e68e-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s3/6"},"text":"Pub. L. 116–189, § 3(6)","children":[],"tail":", added par. (4). Former par. (4) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s3/1"},"text":"Pub. L. 116–189, § 3(1)","children":[],"tail":", substituted “United States Center for SafeSport” for “United States Center for Safe Sport”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s3/5"},"text":"Pub. L. 116–189, § 3(5)","children":[],"tail":", redesignated par. (4) as (5). Former par. (5) redesignated (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s3/5"},"text":"Pub. L. 116–189, § 3(5)","children":[],"tail":", redesignated par. (5) as (6). Former par. (6) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s3/2"},"text":"Pub. L. 116–189, § 3(2)","children":[],"tail":", substituted “United States Olympic and Paralympic Committee” for “United States Olympic Committee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s3/5"},"text":"Pub. L. 116–189, § 3(5)","children":[],"tail":", redesignated par. (6) as (7). Former par. (7) redesignated (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s3/5"},"text":"Pub. L. 116–189, § 3(5)","children":[],"tail":", redesignated par. (7) as (8). Former par. (8) redesignated (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s3/3"},"text":"Pub. L. 116–189, § 3(3)","children":[],"tail":", amended par. (8) generally. Prior to amendment, par. (8) read as follows: “ ‘national governing body’ means an amateur sports organization that is recognized by the corporation under "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s220521"},"text":"section 220521 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s3/5"},"text":"Pub. L. 116–189, § 3(5)","children":[],"tail":", redesignated par. (8) as (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s3/4"},"text":"Pub. L. 116–189, § 3(4)","children":[],"tail":", struck out par. (9) which read as follows: “ ‘paralympic sports organization’ means an amateur sports organization which is recognized by the corporation under "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s220521"},"text":"section 220521 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(10), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s3/7"},"text":"Pub. L. 116–189, § 3(7)","children":[],"tail":", added pars. (10) and (11). Former par. (10) redesignated (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s3/5"},"text":"Pub. L. 116–189, § 3(5)","children":[],"tail":", redesignated par. (10) as (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(4) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/126"},"text":"Pub. L. 115–126","children":[],"tail":" added pars. (4) and (5) and redesignated former pars. (4) to (8) as (6) to (10), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284/s5/13"},"text":"Pub. L. 109–284, § 5(13)","children":[],"tail":", substituted “Short title and definitions” for “Title and Definitions” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284/s5/14"},"text":"Pub. L. 109–284, § 5(14)","children":[],"tail":", substituted “Short Title” for “Title” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/b/2/A"},"text":"Pub. L. 105–277, § 142(b)(2)(A)","children":[],"tail":", substituted “Title and Definitions” for “Definitions” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/b/2/B"},"text":"Pub. L. 105–277, § 142(b)(2)(B)","children":[],"tail":", added subsec. (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/b/2/C"},"text":"Pub. L. 105–277, § 142(b)(2)(C)","children":[],"tail":", designated existing provisions as subsec. (b) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/c/1"},"text":"Pub. L. 105–277, § 142(c)(1)","children":[],"tail":", inserted “or paralympic sports organization” after “national governing body”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(7), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/c/2"},"text":"Pub. L. 105–277, § 142(c)(2)","children":[],"tail":", (3), added par. (7) and redesignated former par. (7) as (8)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id74b1e68f-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"separability","id":"id74b1e690-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Severability","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s12"},"text":"Pub. L. 116–189, § 12","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/973"},"text":"134 Stat. 973","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/189/s12"},"text":"“If any provision of this Act [see Short Title of 2020 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s101"},"text":"section 101 of this title","children":[],"tail":"], or an amendment made by this Act, is determined to be unenforceable or invalid, the remaining provisions of this Act and the amendments made by this Act shall not be affected.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id74b1e691-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s2"},"text":"Pub. L. 116–189, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/943"},"text":"134 Stat. 943","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/189/s2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress makes the following findings:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The courageous voice of survivors is a call to action to end emotional, physical, and sexual abuse in the Olympic and Paralympic movement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Larry Nassar, the former national team doctor for USA Gymnastics, sexually abused over 300 athletes for over two decades because of ineffective oversight by USA Gymnastics and the United States Olympic Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" While the case of Larry Nassar is unprecedented in scale, the case is hardly the only recent incident of sexual abuse in amateur sports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Survivors of Larry Nassar’s abuse and all survivors of abuse in the Olympic and Paralympic movement deserve justice and redress for the wrongs the survivors have suffered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After a comprehensive congressional investigation, including interviews and statements from survivors, former and current organization officials, law enforcement, and advocates, Congress found that the United States Olympic Committee and USA Gymnastics fundamentally failed to uphold their existing statutory purposes and duty to protect amateur athletes from sexual, emotional, or physical abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" USA Gymnastics and the United States Olympic Committee knowingly concealed abuse by Larry Nassar, leading to the abuse of dozens of additional amateur athletes during the period beginning in the summer of 2015 and ending in September 2016.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ending abuse in the Olympic and Paralympic movement requires enhanced oversight to ensure that the Olympic and Paralympic movement does more to serve athletes and protect their voice and safety.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id74b1e692-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report to Congress on Effectiveness of Chapter and Proposed Changes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s142/q"},"text":"Pub. L. 105–277, div. C, title I, § 142(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-609"},"text":"112 Stat. 2681–609","children":[],"tail":", required the United States Olympic Committee to submit, five years from "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", a special report to Congress on the effectiveness of the provisions of this chapter, together with any additional proposed changes to this chapter the United States Olympic Committee determined to be appropriate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
