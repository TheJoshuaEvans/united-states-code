{"tag":"section","attrib":{"id":"id74c03f08-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s240103"},"text":null,"children":[{"tag":"num","attrib":{"value":"240103"},"text":"§ 240103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are as provided in its articles of incorporation and include a continuing commitment on a national basis—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74c03f09-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s240103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote the general welfare of all veterans, especially women veterans, who have served or are serving in the United States Army, the Army Reserve, and the Army National Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74c03f0a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s240103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recognize outstanding women in college ROTC units throughout the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74c03f0b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s240103/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide services and support to patients in medical facilities of the Department of Veterans Affairs throughout the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74c03f0c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attri