{"tag":"section","attrib":{"id":"id744dcdac-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s138"},"text":null,"children":[{"tag":"num","attrib":{"value":"138"},"text":"§ 138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Save Your Vision Week","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President is requested to issue each year a proclamation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id744dcdad-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s138/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designating the first week in March as Save Your Vision Week;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id744dcdae-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s138/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inviting the governors and mayors of State and local governments to issue proclamations designating the first week in March as Save Your Vision Week;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id744dcdaf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s138/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inviting the communications media, health care professions, and other agencies and individuals concerned with programs for the improvement of vision to unite during Save Your Vision Week in public activities to convince the people of the United States of the importance of vision to their welfare and the welfare of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id744dcdb0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s138/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" urging the media, health care professions, and other agencies and individuals to support programs to improve and protect the vision of the people of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id744dcdb1-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1261"},"text":"112 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id744dcdb2-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id744dcdb3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id744dcdb4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":nu