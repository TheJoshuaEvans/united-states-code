{"tag":"section","attrib":{"id":"id749ed4bf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152408"},"text":null,"children":[{"tag":"num","attrib":{"value":"152408"},"text":"§ 152408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation shall have a designated agent to receive service of process for the corporation. Notice to or service on the agent, or mailed to the business address of the agent, is notice to or service on the corporation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id749ed4c0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tII/s201/a"},"text":"Pub. L. 106–474, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2094"},"text":"114 Stat. 2094","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
