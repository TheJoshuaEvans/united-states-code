7"},"text":"Pub. L. 97–447","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2364"},"text":"96 Stat. 2364","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “or title 47, chapter 26 of the District of Columbia Code (1973)” (subsequently covered in chapter 20 of title 47 of the District of Columbia Code (1981)) are omitted as unnecessary. The words “in connection with activities conducted” are substituted for “applicable to taxable events occurring” for clarity. The words “occurring . . . on or after ","children":[{"tag":"date","attrib":{"date":"1964-01-01"},"text":"January 1, 1964","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
