{"tag":"section","attrib":{"id":"id748bc136-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s100102"},"text":null,"children":[{"tag":"num","attrib":{"value":"100102"},"text":"§ 100102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id748bc137-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s100102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Italian American War Veterans of the United States (in this chapter, the “corporation”), a nonprofit corporation incorporated in California, Connecticut, Florida, Massachusetts, New Jersey, New York, Ohio, Pennsylvania, and Rhode Island, is a federally chartered corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc138-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s100102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration of Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the corporation does not comply with any provision of this chapter, the charter granted by this chapter expires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id748bc139-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1364"},"text":"112 Stat. 1364","children":[],"tail":".)"}],"tail":"\n"},{"tag":"note