{"tag":"section","attrib":{"id":"id74955e84-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150409"},"text":null,"children":[{"tag":"num","attrib":{"value":"150409"},"text":"§ 150409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74955e85-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150409/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stock and Dividends","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74955e86-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150409/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue any shares of stock; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955e87-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150409/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" declare or pay any dividends.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74955e88-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150409/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Income or Assets","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74955e89-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150409/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The income or assets of the corporation may not—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74955e8a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150409/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inure to any person who is a member, officer, or director of the corporation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74955e8b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150409/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be distributed to any such person during the life of the charter granted by this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955e8c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150409/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection prevents the payment of reasonable compensation to the officers of the corporation, or reimbursement for actual and necessary expenses, in amounts approved by the board of directors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74955e8d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150409/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not make any loan to any officer, director, member, or employee of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74955e8e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150409/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Federal Endorsement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not claim congressional approval or Federal Government authority by virtue of the charter granted by this chapter for any of the activities of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74955e8f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLI/s5103/a"},"text":"Pub. L. 118–31, div. E, title LI, § 5103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/937"},"text":"137 Stat. 937","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
