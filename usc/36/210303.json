{"tag":"section","attrib":{"id":"id74ad2c3a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s210303"},"text":null,"children":[{"tag":"num","attrib":{"value":"210303"},"text":"§ 210303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are as provided in the articles of incorporation and include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74ad2c3b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s210303/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the principles of friendship and good will among its members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74ad2c3c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s210303/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaging in social and civic activities that tend to enhance the welfare of its members and inculcate the true principles of good citizenship in its members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74ad2c3d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s210303/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" memorializing, individually and collectively, the patriotic services of its members in the 369th antiaircraft artillery group and other units in the Armed Forces of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74ad2c3e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"t