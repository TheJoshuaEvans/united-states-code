{"tag":"section","attrib":{"id":"id7454f9dd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s903"},"text":null,"children":[{"tag":"num","attrib":{"value":"903"},"text":"§ 903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of Medal of Honor Flag","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7454f9de-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense shall design and designate a flag as the Medal of Honor Flag. In selecting the design for the flag, the Secretary shall consider designs submitted by the general public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7454f9df-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presentation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Medal of Honor Flag shall be presented as specified in sections 7285, 8307, and 9285 of title 10 and section 505 ","children":[{"tag":"ref","attrib":{"idref":"fn002005"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002005"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 14."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7454f9e0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/248/tVIII/s8143/b/1"},"text":"Pub. L. 107–248, title VIII, § 8143(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-23"},"text":"Oct. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1570"},"text":"116 Stat. 1570","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/dA/tVIII/s809"},"text":"Pub. L. 115–232, div. A, title VIII, § 809","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), "},{"tag":"date","attrib":{"date":"2018-08-13"},"text":"Aug. 13, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1843"},"text":"132 Stat. 1843","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7454f9e1-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7454f9e2-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7454f9e3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t14/s505"},"text":"Section 505 of title 14","children":[],"tail":", referred to in subsec. (b), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s2734"},"text":"section 2734 of title 14","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/tI/s116/b/2"},"text":"Pub. L. 115–282, title I, § 116(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4226"},"text":"132 Stat. 4226","children":[],"tail":", and references to "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s505"},"text":"section 505 of title 14","children":[],"tail":" deemed to refer to such redesignated section, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/282/s123/b/1"},"text":"section 123(b)(1) of Pub. L. 115–282","children":[],"tail":", set out as a References to Sections of Title 14 as Redesignated by "},{"tag":"ref","attrib":{"href":"/us/pl/115/282"},"text":"Pub. L. 115–282","children":[],"tail":" note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t14/s101"},"text":"section 101 of Title 14","children":[],"tail":", Coast Guard."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7454f9e4-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" substituted “sections 7285, 8307, and 9285 of title 10” for “sections 3755, 6257, and 8755 of title 10”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7454f9e5-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7454f9e6-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2019-02-01"},"text":"Feb. 1, 2019","children":[],"tail":", with provision for the coordination of amendments and special rule for certain redesignations, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/232/s800"},"text":"section 800 of Pub. L. 115–232","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3001"},"text":"section 3001 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7454f9e7-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/248/tVIII/s8143/a"},"text":"Pub. L. 107–248, title VIII, § 8143(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-23"},"text":"Oct. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1570"},"text":"116 Stat. 1570","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/248/tVIII/s8143/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Medal of Honor is the highest award for valor in action against an enemy force which can be bestowed upon an individual serving in the Armed Forces of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Medal of Honor was established by Congress during the Civil War to recognize soldiers who had distinguished themselves by gallantry in action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Medal of Honor was conceived by Senator James Grimes of the State of Iowa in 1861; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Medal of Honor is the Nation’s highest military honor, awarded for acts of personal bravery or self-sacrifice above and beyond the call of duty.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7454f9e8-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Presentation of Medal of Honor Flag","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/248/tVIII/s8143/d"},"text":"Pub. L. 107–248, title VIII, § 8143(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-23"},"text":"Oct. 23, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1571"},"text":"116 Stat. 1571","children":[],"tail":", required the President to provide for the expeditious presentation of the Medal of Honor Flag designated under this section to each person awarded the Medal of Honor before "},{"tag":"date","attrib":{"date":"2002-10-23"},"text":"Oct. 23, 2002","children":[],"tail":", who was living as of that date."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
