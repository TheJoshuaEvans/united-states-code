{"tag":"section","attrib":{"id":"id7457432b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2104"},"text":null,"children":[{"tag":"num","attrib":{"value":"2104"},"text":"§ 2104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Military cemeteries in foreign countries","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"When, as a result of combat operations, the Armed Forces establish military cemeteries in zones of operations outside the United States and the territories and possessions of the United States, the American Battle Monuments Commission and the Secretary of the Army, immediately on the cessation of hostilities, shall decide which of the cemeteries will become permanent cemeteries or, if they decide it is desirable, shall select new sites for the cemeteries at any other location. The Commission is solely responsible for the design and construction of the permanent cemeteries, and of all buildings, plantings, headstones, and other permanent improvements incidental to the cemeteries, except that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7457432c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2104/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Armed Forces are responsible for maintaining the permanent cemeteries until the Commission declares its readiness to assume the authorized administrative duties and powers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7457432d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2104/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all construction undertaken by the Armed Forces in establishing and maintaining the cemetery prior to its transfer to the Commission shall be nonpermanent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7457432e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2104/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" burials and reburials by the Armed Forces shall be carried out in accordance with plans prepared by the Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7457432f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2104/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Armed Forces have the right to re-enter a cemetery transferred to the Commission to exhume or re-inter a body if they decide it is necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74574330-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1271"},"text":"112 Stat. 1271","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74574331-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74574332-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74574333-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2104","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:122b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1923-03-04/ch283/s2"},"text":"Mar. 4, 1923, ch. 283, § 2","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/act/1956-07-25/ch721/s3/a"},"text":"July 25, 1956, ch. 721, § 3(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/640"},"text":"70 Stat. 640","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, before clause (1), the words “so established, if any” are omitted as unnecessary. In clause (1), the words “such time as” are omitted as unnecessary. The words “duties and powers” are substituted for “functions” for consistency in the revised title and with other titles of the United States Code. In clause (2), the words “in nature” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id74574334-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id74574335-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Restoration, Operation, and Maintenance of Clark Veterans Cemetery","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/260/tI/s106"},"text":"Pub. L. 112–260, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-10"},"text":"Jan. 10, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2421"},"text":"126 Stat. 2421","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/260/tI/s106"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After an agreement is made between the Government of the Republic of the Philippines and the United States Government, Clark Veterans Cemetery in the Republic of the Philippines shall be treated, for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s2104"},"text":"section 2104 of title 36","children":[],"tail":", United States Code, as a cemetery for which it was decided under such section that the cemetery will become a permanent cemetery and the American Battle Monuments Commission shall restore, operate, and maintain Clark Veterans Cemetery (to the degree the Commission considers appropriate) under such section in cooperation with the Government of the Republic of the Philippines."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Future Burials","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Burials at the cemetery described in subsection (a) after the date of the agreement described in such subsection shall be limited to eligible veterans, as determined by the Commission, whose burial does not incur any cost to the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Commission—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $5,000,000 for site preparation, design, planning, construction, and associated administrative costs for the restoration of the cemetery described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts necessary to operate and maintain the cemetery described in subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
