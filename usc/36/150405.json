{"tag":"section","attrib":{"id":"id74955e7a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150405"},"text":null,"children":[{"tag":"num","attrib":{"value":"150405"},"text":"§ 150405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Subject to section 150406, the officers of the corporation, and the election of such officers, shall be as provided in the constitution and bylaws of the corporation and in conformity with the laws of the jurisdiction under which the corporation is incorporated.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id74955e7b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLI/s5103/a"},"text":"Pub. L. 118–31, div. E, title LI, § 5103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/936"},"text":"137 Stat. 936","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
