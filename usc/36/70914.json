{"tag":"section","attrib":{"id":"id74894fea-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70914"},"text":null,"children":[{"tag":"num","attrib":{"value":"70914"},"text":"§ 70914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of assets on dissolution or final liquidation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On dissolution or final liquidation of the FFA, any assets remaining after the discharge of all liabilities shall be used by the board of directors for the benefit of students of agricultural education or be transferred to a recognized educational foundation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id74894feb-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1359"},"text":"112 Stat. 1359","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/7/s15"},"text":"Pub. L. 116–7, § 15","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-21"},"text":"Feb. 21, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/482"},"text":"133 Stat. 482","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74894fec-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74894fed-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74894fee-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag"