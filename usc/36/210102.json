{"tag":"section","attrib":{"id":"id74ad2bf8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s210102"},"text":null,"children":[{"tag":"num","attrib":{"value":"210102"},"text":"§ 210102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74ad2bf9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s210102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perpetuate the memory of Theodore Roosevelt for the benefit of the people of the United States and the world; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74ad2bfa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s210102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to solicit, receive, hold, and maintain funds, and to apply the principal of the funds and the income from those funds to the following objects, among others:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74ad2bfb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s210102/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the erection and maintenance of a suitable and adequate monumental memorial in the District of Columbia to the memory of Theodore Roosevelt;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74ad2bfc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s210102/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition, development, and maintenance of a public park in memory of Theodore Roosevelt in Oyster Bay, New York;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74ad2bfd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s210102/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the establishment and maintenance of an endowment fund to promote the development and application of the policies and ideals of Theodore Roosevelt for the benefit of the American people; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74ad2bfe-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s210102/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the donation of real and personal property, including part or all of its endowment fund, to a public agency for the purpose of preserving in public ownership historically significant property associated with the life of Theodore Roosevelt.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74ad2bff-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1455"},"text":"112 Stat. 1455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74ad2c00-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74ad2c01-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74ad2c02-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"210102","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:4703.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-05-31/ch216/s3"},"text":"May 31, 1920, ch. 216, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/41/693"},"text":"41 Stat. 693","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 25, 1962","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/547/s6"},"text":"Pub. L. 87–547, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/76/217"},"text":"76 Stat. 217","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), before subclause (A), the words “among others” are substituted for “and to that end, but without restriction to the objects enumerated below” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
