g":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 26, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/761/s6"},"text":"Pub. L. 85–761, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/857"},"text":"72 Stat. 857","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the text of 36:826(d) is omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “has received” are substituted for “who have received or who may hereafter receive”, and the words “as a member” are substituted for “are, have been, or may become members”, for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “may” is substituted for “shall have the power, moreover, to” for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7492ed4c-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7492ed4d-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/207"},"text":"Pub. L. 110–207","children":[],"tail":" substituted “the parents, spouse, siblings, and lineal descendants” for “parents and lineal descendants”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
