{"tag":"section","attrib":{"id":"id7492ed42-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140503"},"text":null,"children":[{"tag":"num","attrib":{"value":"140503"},"text":"§ 140503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7492ed43-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Active Members","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual is eligible for active membership in the corporation if the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7492ed44-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of good moral character; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ed45-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has received the Purple Heart for wounds received as a member, of any rank, of the Armed Forces of the United States or any foreign country during military or naval combat against an armed enemy of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7492ed46-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Associate Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may extend eligibility for membership as associate members to the parents, spouse, siblings, and lineal descendants of an individual described in subsection (a) of this section on terms provided in its constitution and bylaws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7492ed47-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member described in subsection (a) of this section has one vote on each matter submitted to a vote at a meeting of the members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7492ed48-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1382"},"text":"112 Stat. 1382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/207/s2"},"text":"Pub. L. 110–207, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-04-30"},"text":"Apr. 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/719"},"text":"122 Stat. 719","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7492ed49-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7492ed4a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id7492ed4b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup"