{"tag":"section","attrib":{"id":"id74528838-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s503"},"text":null,"children":[{"tag":"num","attrib":{"value":"503"},"text":"§ 503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of reservations, grounds, and public spaces","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74528839-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permit for Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With the approval of the officer having jurisdiction over any of the Federal reservations or grounds in the District of Columbia, the Secretary of the Interior may grant to the Inaugural Committee a permit to use the reservations or grounds during the inaugural period, including a reasonable time before and after the inaugural period. The Mayor of the District of Columbia may grant a similar permit to use public space under the Mayor’s jurisdiction. Each permit granted under this subsection is subject to conditions the grantor of the permit prescribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7452883a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reviewing Stands and Commercial Stands and Structures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A reviewing stand or a stand or structure for the sale of merchandise, food, or drink may be built on public grounds in the District of Columbia only if approved by the Inaugural Committee and by the Secretary or the Mayor, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7452883b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restoration After Inaugural Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After the inaugural period, the reservation, ground, or public space occupied by a stand or structure shall be restored promptly to its prior condition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7452883c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indemnification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inaugural Committee shall indemnify and save harmless the District of Columbia and the appropriate department, agency, or instrumentality of the United States Government against any loss or damage to, and against any liability arising from the use of, the reservation, ground, or public space, by the Inaugural Committee or a licensee of the Inaugural Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7452883d-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1264"},"text":"112 Stat. 1264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7452883e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7452883f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74528840-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"503(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:724 (1st, 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-08-06/ch974/s4"},"text":"Aug. 6, 1956, ch. 974, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/1049"},"text":"70 Stat. 1049","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:730.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-08-06/ch974/s10"},"text":"Aug. 6, 1956, ch. 974, § 10","children":[],"tail":", as added "},{"tag":"html:span","attrib":{},"text":"Jan. 30, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/251/s4"},"text":"Pub. L. 90–251, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/4"},"text":"82 Stat. 4","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"503(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:724 (3d sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"36:730.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"503(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:724 (4th sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"503(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:724 (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “restrictions, terms, and” are omitted as unnecessary. The word “prescribes” is substituted for “imposed” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “With respect to public space”, “goods, wares”, “sidewalk, street, park, reservation, or other”, and “depending on the location of such stand or structure” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “department, agency, or instrumentality” are substituted for “agency” for consistency in the revised title and with other titles of the United States Code. The words “or agencies” are omitted because of 1:1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
