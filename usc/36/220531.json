{"tag":"section","attrib":{"id":"id74b9129f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220531"},"text":null,"children":[{"tag":"num","attrib":{"value":"220531"},"text":"§ 220531.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant to protect young athletes from abuse","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74b912a0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220531/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General may award a grant to an eligible nonprofit nongovernmental entity in order to support oversight of the United States Olympic and Paralympic Committee and each national governing body with regard to safeguarding amateur athletes against abuse, including emotional, physical, and sexual abuse in sports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b912a1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220531/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this section, a nonprofit nongovernmental entity shall submit an application to the Attorney General at such time, in such manner, and containing such information as the Attorney General may require, including information that demonstrates that the entity has—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b912a2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220531/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nationally recognized expertise in preventing and investigating emotional, physical, and sexual abuse in the athletic programs of the United States Olympic and Paralympic Committee and each national governing body; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b912a3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220531/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capacity to oversee regular and random audits to ensure that the policies and procedures used by the United States Olympic and Paralympic Committee and each national governing body to prevent and identify the abuse of an amateur athlete are followed correctly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b912a4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220531/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Grant Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity that receives a grant under this section may use such funds—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b912a5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220531/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop and test new training materials for emotional, physical, and sexual abuse prevention and identification education in youth athletic programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b912a6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220531/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for staff salaries, travel expenses, equipment, printing, and other reasonable expenses necessary to develop, maintain, and disseminate to the United States Olympic and Paralympic Committee, each national governing body, and other amateur sports organizations information about safeguarding amateur athletes against abuse, including emotional, physical, and sexual abuse in sports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b912a7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220531/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to oversee the administration of the procedures described in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b912a8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220531/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b912a9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220531/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to carry out this section $2,500,000 for each of the fiscal years 2018 through 2022.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b912aa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220531/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of grant funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds appropriated under this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74b912ab-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/141/dS/tIII/s302/a"},"text":"Pub. L. 115–141, div. S, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1127"},"text":"132 Stat. 1127","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/189"},"text":"Pub. L. 116–189","children":[],"tail":", §§ 4(a)(11), 7(a)(2)(A)(vi), "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/946"},"text":"134 Stat. 946","children":[],"tail":", 957.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74b912ac-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74b912ad-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74b912ae-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s7/a/2/A/vi/I"},"text":"Pub. L. 116–189, § 7(a)(2)(A)(vi)(I)","children":[],"tail":", substituted “and each national governing body” for “, each national governing body, and each paralympic sports organization” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s4/a/11"},"text":"Pub. L. 116–189, § 4(a)(11)","children":[],"tail":", substituted “United States Olympic and Paralympic Committee” for “United States Olympic Committee” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s7/a/2/A/vi/II"},"text":"Pub. L. 116–189, § 7(a)(2)(A)(vi)(II)","children":[],"tail":", struck out “each paralympic sports organization,” after “each national governing body,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
