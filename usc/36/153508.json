{"tag":"section","attrib":{"id":"id74a38f7e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153508"},"text":null,"children":[{"tag":"num","attrib":{"value":"153508"},"text":"§ 153508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal office and location of activities and gardens","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74a38f7f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Principal Office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The principal office of the corporation shall be in the District of Columbia or another place decided by the board of trustees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74a38f80-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location of Activities and Gardens","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The activities of the corporation may be conducted anywhere. However, the corporation may establish tropical botanical gardens only in the United States and its territories and possessions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74a38f81-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1426"},"text":"112 Stat. 1426","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74a38f82-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74a38f83-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74a38f84-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"153508","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:4607(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 19, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/449/s7/a"},"text":"Pub. L. 88–449, § 7(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/498"},"text":"78 Stat. 498","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/539/s2"},"text":"Pub. L. 100–539, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2718"},"text":"102 Stat. 2718","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is substituted for “The corporation initially shall have its principal office in the District of Columbia and later at such place as may be determined by the board of trustees” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for “The corporation shall have the right to conduct its activities in the United States and elsewhere but shall establish a tropical botanical garden or gardens only in the United States. For purposes of this subsection, the term ‘United States’ includes any commonwealth, territory, or possession of the United States” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
