{"tag":"section","attrib":{"id":"id74a38fc4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153703"},"text":null,"children":[{"tag":"num","attrib":{"value":"153703"},"text":"§ 153703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except as provided in this chapter, eligibility for membership in the corporation and the rights, privileges, and designation of classes of members are as provided in the constitution and bylaws of the corporation. Eligibility for membership is limited to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74a38fc5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153703/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" women who are the wives, mothers, daughters, and sisters of Union soldiers, sailors, and marines; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a38fc6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153703/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other loyal women who have not given aid or comfort to the enemies of the United States of America.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74a38fc7-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1428"},"text":"112 Stat. 1428","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74a38fc8-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74a