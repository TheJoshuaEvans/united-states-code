{"tag":"section","attrib":{"id":"id74a60027-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153902"},"text":null,"children":[{"tag":"num","attrib":{"value":"153902"},"text":"§ 153902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are patriotic, historical, and educational and are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74a60028-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster and perpetuate the memory of the service of Yeomen (F) in the United States Naval Reserve Force of the United States Navy during World War I;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a60029-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve the memories and incidents of their association in World War I by the encouragement of historical research concerning the service of Yeomen (F);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a6002a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cherish, maintain, and extend the institutions of American freedom by the promotion of celebrations of all patriotic anniversaries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a6002b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster true patriotism and love of country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a6002c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153902/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to aid in securing for mankind all the blessings of liberty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74a6002d-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1431"},"text":"112 Stat. 1431","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/237/s3/c/8/C"},"text":"Pub. L. 113–237, § 3(c)(8)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2841"},"text":"128 Stat. 2841","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74a6002e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74a6002f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74a60030-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","chi