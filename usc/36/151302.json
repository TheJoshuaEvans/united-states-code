{"tag":"section","attrib":{"id":"id749a1917-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151302"},"text":null,"children":[{"tag":"num","attrib":{"value":"151302"},"text":"§ 151302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749a1918-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" primarily—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id749a1919-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151302/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage, accept, and administer private gifts of property for the benefit of the National Fallen Firefighters’ Memorial and the annual memorial service associated with the memorial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id749a191a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151302/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to, in coordination with the Federal Government and fire services (as that term is defined in section 4 of the Federal Fire Prevention and Control Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2203"},"text":"15 U.S.C. 2203","children":[],"tail":")), plan, direct, and manage the memorial service referred to in subparagraph (A);"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a191b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide financial assistance to families of fallen firefighters for transportation to and lodging at non-Federal and Federal facilities during the annual memorial service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a191c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist Federal, State, and local efforts to recognize firefighters who die in the line of duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a191d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide scholarships and other financial assistance for educational purposes and job training for the spouses and children of fallen firefighters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a191e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for a national program to assist families of fallen firefighters and fire departments in dealing with line-of-duty deaths of those firefighters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a191f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151302/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote national, State, and local initiatives to increase public awareness of fire and life safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749a1920-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1399"},"text":"112 Stat. 1399","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/503/tI/s113/a"},"text":"Pub. L. 106–503, title I, § 113(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2303"},"text":"114 Stat. 2303","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749a1921-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id749a1922-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id749a1923-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"151302","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:5201(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 26, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/522/tII/s202/b"},"text":"Pub. L. 102–522, title II, § 202(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/3417"},"text":"106 Stat. 3417","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id749a1924-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id749a1925-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5201(b) of former Title 36, from which this section was derived, was amended after the ","children":[{"tag":"date","attrib":{"date":"1997-08-15"},"text":"Aug. 15, 1997","children":[],"tail":", cutoff date by "},{"tag":"ref","attrib":{"href":"/us/pl/105/276/tIV/s427/a"},"text":"Pub. L. 105–276, title IV, § 427(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2510"},"text":"112 Stat. 2510","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/225/s5/a"},"text":"section 5(a) of Pub. L. 105–225","children":[],"tail":", set out as a Legislative Purpose and Construction note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s101"},"text":"section 101 of this title","children":[],"tail":". The subsequent amendment made directly to this section by "},{"tag":"ref","attrib":{"href":"/us/pl/106/503"},"text":"Pub. L. 106–503","children":[],"tail":" replicated the prior amendment made by "},{"tag":"ref","attrib":{"href":"/us/pl/105/276"},"text":"Pub. L. 105–276","children":[],"tail":", with the exception that in par. (1)(B), the words “plan, direct, and manage the memorial service referred to in subparagraph (A)” were used instead of “plan, direct, and manage the memorial service referred to in subparagraph (A) and related activities”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id749a1926-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/503/s113/a/1"},"text":"Pub. L. 106–503, § 113(a)(1)","children":[],"tail":" added par. (1) and struck out former par. (1) which read as follows: “primarily to encourage, accept, and administer private gifts of property for the benefit of the National Fallen Firefighters’ Memorial and the annual memorial service associated with it;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/503/s113/a/2"},"text":"Pub. L. 106–503, § 113(a)(2)","children":[],"tail":", inserted “and Federal” after “non-Federal”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/503/s113/a/3"},"text":"Pub. L. 106–503, § 113(a)(3)","children":[],"tail":", substituted “Federal, State, and local” for “State and local” and struck out “and” after semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/503/s113/a/4"},"text":"Pub. L. 106–503, § 113(a)(4)","children":[],"tail":", substituted semicolon for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (5), (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/503/s113/a/5"},"text":"Pub. L. 106–503, § 113(a)(5)","children":[],"tail":", added pars. (5) and (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id749a1927-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id749a1928-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Lowering of Flag in Honor of National Fallen Firefighters Memorial Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/51"},"text":"Pub. L. 107–51","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-16"},"text":"Oct. 16, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/267"},"text":"115 Stat. 267","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/51"},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“Whereas 1,200,000 men and women comprise the American fire and emergency services;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Whereas the fire and emergency services is considered one of the most dangerous jobs in the United States;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Whereas fire and emergency services personnel respond to over 16 million emergency calls annually, without reservation and with little regard for their personal safety;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Whereas fire and emergency services personnel are the first to respond to an emergency, whether it involves a fire, medical emergency, spill of hazardous materials, natural disaster, act of terrorism, or transportation accident;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Whereas approximately one-third of all active fire and emergency personnel suffer debilitating injuries annually; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Whereas approximately 100 fire and emergency services personnel die annually in the line of duty: Now, therefore, be it","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"i","attrib":{},"text":"“Resolved by the Senate and House of Representatives of the United States of America in Congress assembled","children":[],"tail":", That each year, the American flags on all Federal office buildings will be lowered to half-staff in honor of the National Fallen Firefighters Memorial Service in Emmitsburg, Maryland.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
