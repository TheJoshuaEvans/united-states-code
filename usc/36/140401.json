{"tag":"section","attrib":{"id":"id7492ecef-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140401"},"text":null,"children":[{"tag":"num","attrib":{"value":"140401"},"text":"§ 140401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7492ecf0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Military Officers Association of America (in this chapter, the “corporation”), a nonprofit organization that meets the requirements for a veterans service organization under section 501(c)(19) of the Internal Revenue Code of 1986 and is organized under the laws of the Commonwealth of Virginia, is a federally chartered corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7492ecf1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration of Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the corporation does not comply with the provisions of this chapter, the charter granted by subsection (a) shall expire.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7492ecf2-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/95/s1/a"},"text":"Pub. L. 111–95, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-06"},"text":"Nov. 6, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3001"},"text":"123 Stat. 3001","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7492ecf3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7492ecf4-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7492ecf5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 501 of the Internal Revenue Code of 1986, referred to in subsec. (a), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"section 501 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
