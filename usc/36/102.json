{"tag":"section","attrib":{"id":"id7446a1a1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s102"},"text":null,"children":[{"tag":"num","attrib":{"value":"102"},"text":"§ 102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Asian/Pacific American Heritage Month","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7446a1a2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"May is Asian/Pacific American Heritage Month.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7446a1a3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proclamations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President is requested to issue each year a proclamation calling on the people of the United States, and the chief executive officers of each State of the United States, the District of Columbia, the Virgin Islands, Puerto Rico, Guam, American Samoa, the Northern Mariana Islands, the Marshall Islands, Micronesia, and Palau are requested to issue each year proclamations calling on the people of their respective jurisdictions, to observe Asian/Pacific American Heritage Month with appropriate programs, ceremonies, and activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7446a1a4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"19