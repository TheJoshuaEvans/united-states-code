{"tag":"section","attrib":{"id":"id748e3258-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s120107"},"text":null,"children":[{"tag":"num","attrib":{"value":"120107"},"text":"§ 120107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax-exempt status required as condition of charter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the corporation fails to maintain its status as an organization exempt from taxation under the Internal Revenue Code of 1986, the charter granted under this chapter shall terminate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id748e3259-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/254/s1/a/2"},"text":"Pub. L. 110–254, § 1(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2421"},"text":"122 Stat. 2421","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id748e325a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id748e325b-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id748e325c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Internal Revenue Code of 1986, referred to in text, is classified generally to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
