{"tag":"section","attrib":{"id":"id74659c93-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21107"},"text":null,"children":[{"tag":"num","attrib":{"value":"21107"},"text":"§ 21107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74659c94-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stock and Dividends","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not issue stock or declare or pay a dividend.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74659c95-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Income or Assets","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The income or assets of the corporation may not inure to the benefit of, or be distributed to, a director, officer, or member during the life of the charter granted by this chapter. This subsection does not prevent the payment of reasonable compensation to an officer or reimbursement for actual necessary expenses in amounts approved by the board of directors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74659c96-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not make a loan to a director, officer, or employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74680c97-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claim of Governmental Approval or Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not claim congressional approval or the authority of the United States Government for any of its activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74680c98-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1293"},"text":"112 Stat. 1293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74680c99-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74680c9a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74680c9b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"