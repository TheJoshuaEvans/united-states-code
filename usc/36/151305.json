{"tag":"section","attrib":{"id":"id749a1953-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151305"},"text":null,"children":[{"tag":"num","attrib":{"value":"151305"},"text":"§ 151305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id749a1954-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749a1955-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt a constitution and bylaws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a1956-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt a seal which shall be judicially noticed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a1957-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151305/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do any other act necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749a1958-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers as Trustee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out its purposes, the corporation has the usual powers of a corporation acting as a trustee in Maryland, including the power—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749a1959-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept, receive, solicit, hold, administer, and use any gift, devise, or bequest, either absolutely or in trust, of property or any income from or other interest in the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a195a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise required by the instrument of transfer, to sell, donate, lease, invest, or otherwise dispose of any property or income from the property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a195b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151305/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make contracts and other arrangements with public agencies and private organizations and persons and to make payments necessary to carry out its functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a195c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151305/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sue and be sued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a195d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151305/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to do any other act necessary and proper to carry out the purposes of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749a195e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1400"},"text":"112 Stat. 1400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/354/s1/9"},"text":"Pub. L. 105–354, § 1(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-03"},"text":"Nov. 3, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3244"},"text":"112 Stat. 3244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749a195f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id749a1960-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id749a1961-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"