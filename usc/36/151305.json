ords “under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s5201"},"text":"section 5201 of this title","children":[],"tail":"” and “in addition to the powers otherwise given it under this chapter” are omitted as unnecessary. In clause (1), the words “real or personal” are omitted as unnecessary and for consistency in the revised title. In clause (4), the words “and complain and defend itself in any court of competent jurisdiction” are omitted as unnecessary. In clause (5), the words “any other act” are substituted for “any and all acts” to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id749a1962-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/354"},"text":"Pub. L. 105–354","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s151305/b"},"text":"section 151305(b) of title 36","children":[],"tail":" to correct an inconsistency in the revised title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id749a1963-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id749a1964-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/354"},"text":"Pub. L. 105–354","children":[],"tail":" struck out “the State of” before “Maryland” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
