{"tag":"section","attrib":{"id":"id74955ea0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150412"},"text":null,"children":[{"tag":"num","attrib":{"value":"150412"},"text":"§ 150412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"With respect to service of process, the corporation shall comply with the laws of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74955ea1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150412/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the jurisdiction under which the corporation is incorporated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955ea2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150412/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" those jurisdictions within the United States and its territories within which the corporation carries out activities in furtherance of the purposes of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74955ea3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLI/s5103/a"},"text":"Pub. L. 118–31, div. E, title LI, § 5103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/937"},"text":"137 Stat. 937","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
