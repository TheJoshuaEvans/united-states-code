{"tag":"section","attrib":{"id":"id74870676-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70903"},"text":null,"children":[{"tag":"num","attrib":{"value":"70903"},"text":"§ 70903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74870677-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this chapter, eligibility for membership in the FFA and the rights and privileges of members are as provided in the constitution or bylaws of the FFA.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74870678-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In matters of official business of a local chapter, each member has one vote. In matters of official business of a State association, each qualified delegate of a local chapter has one vote.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74870679-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1356"},"text":"112 Stat. 1356","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/7/s4"},"text":"Pub. L. 116–7, § 4","ch