{"tag":"section","attrib":{"id":"id7459b465-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108"},"text":null,"children":[{"tag":"num","attrib":{"value":"2108"},"text":"§ 2108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pacific War Memorial and other historical and memorial sites on Corregidor","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7459b466-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After an agreement is made between the Government of the Republic of the Philippines and the United States Government, the American Battle Monuments Commission shall restore, operate, and maintain the Pacific War Memorial and other historical and memorial sites on Corregidor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7459b467-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may employ necessary personnel to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7459b468-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Other Departments, Agencies, and Instrumentalities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Departments, agencies, and instrumentalities of the United States Government may assist the Commission, on a reimbursable basis, in carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7459b469-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Solicit Contributions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To carry out this section, the Commission may solicit and accept private contributions and shall deposit the contributions in the fund established by subsection (f) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7459b46a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Private Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall carry out this section with private amounts except to the extent amounts are appropriated under subsection (g) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7459b46b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fund","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7459b46c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is a fund in the Treasury that is available to the Commission only to carry out this section. The fund consists of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7459b46d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts deposited into, and interest and proceeds credited to, the fund under paragraph (2) of this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7459b46e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obligations obtained under paragraph (3) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7459b46f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chairman of the Commission shall deposit into the fund the amounts that are accepted under subsection (d) of this section. The Secretary of the Treasury shall credit to the fund the interest on, and the proceeds from the sale or redemption of, obligations held in the fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7459b470-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall invest any part of the fund that the Chairman decides is not required to meet current expenses. Each investment shall be made in an interest-bearing obligation of the United States Government, or an obligation that has its principal and interest guaranteed by the Government, that the Chairman decides has a maturity suitable for the fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7459b471-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the fund exceeding the cost of carrying out this section, as decided by the Chairman, shall be deposited in the Treasury as miscellaneous receipts to reimburse the United States Government for amounts appropriated under subsection (g) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7459b472-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7459b473-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $6,000,000 for site preparation, design, planning, construction, and associated administrative costs for the restoration of the Memorial and other historical and memorial sites referred to in subsection (a) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7459b474-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2108/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts necessary to operate and maintain the Memorial and those other historical and memorial sites.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7459b475-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1274"},"text":"112 Stat. 1274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7459b476-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7459b477-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id7459b478-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th",