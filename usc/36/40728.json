{"tag":"section","attrib":{"id":"id747b1f78-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728"},"text":null,"children":[{"tag":"num","attrib":{"value":"40728"},"text":"§ 40728.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of firearms, ammunition, and parts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id747b1f79-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Transfers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In accordance with subsection (b) of this section, the Secretary of the Army shall transfer to the corporation all firearms and ammunition that, on ","children":[{"tag":"date","attrib":{"date":"1996-02-09"},"text":"February 9, 1996","children":[],"tail":", were under the control of the director of civilian marksmanship (as that position existed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4307"},"text":"section 4307 of title 10","children":[],"tail":" on "},{"tag":"date","attrib":{"date":"1996-02-09"},"text":"February 9, 1996","children":[],"tail":"), including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1f7a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all firearms on loan to affiliated clubs and State associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f7b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all firearms in the possession of the Civilian Marksmanship Support Detachment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f7c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all M–1 Garand and caliber .22 rimfire rifles stored at Defense Distribution Depot, Anniston, Anniston, Alabama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f7d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for Transfers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall transfer firearms and ammunition under subsection (a) of this section as and when necessary to enable the corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1f7e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to issue or loan firearms or ammunition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40731"},"text":"section 40731 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f7f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sell firearms or ammunition under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40732"},"text":"section 40732 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f80-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vesting of Title in Transferred Items","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Title to an item transferred to the corporation under this section shall vest in the corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1f81-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the issuance of the item to an eligible recipient under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40731"},"text":"section 40731 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f82-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately before the corporation delivers the item to a purchaser in accordance with a contract for sale of the item that is authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40732"},"text":"section 40732 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f83-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Storage of Firearms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Firearms stored at Defense Distribution Depot, Anniston, Anniston, Alabama, before ","children":[{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":", and used for the Civilian Marksmanship Program (as that program existed under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s4308/e"},"text":"section 4308(e) of title 10","children":[],"tail":" before "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":"), shall remain at that facility or another storage facility designated by the Secretary, without cost to the corporation, until the firearms are issued, loaned, or sold by the corporation, or otherwise transferred to the corporation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f84-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretionary Transfer of Parts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may transfer from the inventory of the Department of the Army to the corporation any part from a rifle designated to be demilitarized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f85-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Demilitarization of","children":[],"tail":" M–1 "},{"tag":"inline","attrib":{},"text":"Rifles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":", the Secretary may not demilitarize an M–1 Garand rifle in the inventory of the Army unless the Defense Logistics Agency decides the rifle is unserviceable."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f86-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost of Transfers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A transfer of firearms, ammunition, or parts to the corporation under this section shall be made without cost to the corporation, except that the corporation shall assume the cost of preparation and transportation of firearms and ammunition transferred under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f87-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Transfers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1f88-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2), the Secretary may transfer to the corporation, in accordance with the procedure prescribed in this subchapter, surplus caliber .45 M1911/M1911A1 pistols and spare parts and related accessories for those pistols that, on the date of the enactment of this subsection, are under the control of the Secretary and are surplus to the requirements of the Department of the Army, and such material as may be recovered by the Secretary pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40728A/a"},"text":"section 40728A(a) of this title","children":[],"tail":". The Secretary shall determine a reasonable schedule for the transfer of such surplus pistols."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f89-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not transfer more than 10,000 surplus caliber .45 M1911/M1911A1 pistols to the corporation during any year and may only transfer such pistols as long as pistols described in paragraph (1) remain available for transfer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f8a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may conduct a one-time transfer to the corporation, in accordance with the procedure prescribed in this subchapter, of pump action shotguns, including any shotguns that are surplus to the requirements of the Center of Military History and the Army Museum Enterprise, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id747b1f8b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/h/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date of the enactment of this paragraph are under the control of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id747b1f8c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/h/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are surplus to the requirements of the Department of the Army at the time of the submission of the report required in subsection (k).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f8d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not transfer pursuant to paragraph (3) any shotgun that is a modular ancillary addition to a service rifle, or meets the definition of a “short-barreled shotgun” as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921/a/6"},"text":"section 921(a)(6) of title 18","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f8e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Navy Transfers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1f8f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding subsections (a) and (b), the Secretary of the Navy may transfer to the corporation, in accordance with the procedures prescribed in this subchapter, M–1 Garand and caliber .22 rimfire rifles held within the inventories of the United States Navy and the United States Marine Corps and stored at Defense Distribution Depot, Anniston, Alabama, or Naval Surface Warfare Center, Crane, Indiana, as of the date of the enactment of the National Defense Authorization Act for Fiscal Year 2018.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f90-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The items specified for transfer under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id747b1f91-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be used as awards for competitors in marksmanship competitions held by the United States Marine Corps or the United States Navy and may not be resold; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id747b1f92-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be rendered inoperable prior to award and transfer to marksmanship competitors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f93-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Navy may conduct a one-time transfer to the corporation, in accordance with the procedure prescribed in this subchapter, of surplus pump action shotguns that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id747b1f94-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date of the enactment of this paragraph are under the control of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id747b1f95-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are surplus to the requirements of the Department of the Navy at the time of the submission of the report required in subsection (k).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f96-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not transfer pursuant to paragraph (3) any shotgun that is a modular ancillary addition to a service rifle or meets the definition of a ‘short-barreled shotgun’ as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921/a/6"},"text":"section 921(a)(6) of title 18","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f97-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Air Force Transfers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1f98-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of the Air Force may conduct a one-time transfer to the corporation, in accordance with the procedures prescribed in this subchapter, of pump action shotguns that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id747b1f99-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the date of the enactment of this paragraph are under the control of the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id747b1f9a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are surplus to the requirements of the Department of the Air Force at the time of the submission of the report required in subsection (k).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f9b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may not transfer pursuant to paragraph (1) any shotgun that is a modular ancillary addition to a service rifle or meets the definition of a “short-barreled shotgun” as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921/a/6"},"text":"section 921(a)(6) of title 18","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f9c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report Required","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1f9d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary concerned authorized to transfer shotguns under subsection (h), (i), or (j) shall submit to the Committees on Armed Services of the Senate and House of Representatives a report that includes the following elements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id747b1f9e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/k/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of surplus shotguns, including the make and model of each such shotgun, that meet the criteria for transfer to the corporation under such subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id747b1f9f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/k/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of surplus shotguns, including the make and mode of each such shotgun, that the Secretary concerned intends to transfer to the corporation under such subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1fa0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, the term “Secretary concerned” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101/a/9"},"text":"section 101(a)(9) of title 10","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1fa1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":" Limitation on Transfer of Surplus Shotguns","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A Secretary may not transfer surplus shotguns described in subsections (h), (i), or (j), until the date that is 60 days after the date of the submittal of the report required under subsection (k).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1fa2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall provide to the Committees on Armed Services of the Senate and the House of Representatives a briefing on the results of the investigation by the Bureau of Alcohol, Tobacco, Firearms, and Explosives and the United States Army Criminal Investigation Division regarding unaccounted for pistols at the corporation. The briefing shall be provided after the investigation has concluded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id747b1fa3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1339"},"text":"112 Stat. 1339","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1087/a/1"},"text":"Pub. L. 114–92, div. A, title X, § 1087(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1012"},"text":"129 Stat. 1012","children":[],"tail":"; "},{"tag":"ref","a