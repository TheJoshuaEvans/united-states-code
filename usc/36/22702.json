{"tag":"section","attrib":{"id":"id746cc7a2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22702"},"text":null,"children":[{"tag":"num","attrib":{"value":"22702"},"text":"§ 22702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746cc7a3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve for ourselves and our posterity the great and basic truths and enduring principles upon which this Nation was founded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc7a4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain a continuing interest in the welfare and rehabilitation of the disabled veterans of World War II, the Korean conflict, and the Vietnam era and to establish facilities for the assistance of all veterans and to represent them in their claims before the Department of Veterans Affairs and other organizations without charge;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc7a5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to dedicate ourselves to the service and best interests of the community, State, and Nation to the end that our country shall be and remain forever a whole, strong, and free Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc7a6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to aid and encourage the abolition of prejudice, ignorance, and disease;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc7a7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage universal exercise of the voting franchise to the end that there shall be elected and maintained in public office men and women who hold public office as a public trust administered in the best interests of all the people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc7a8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22702/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advocate the development and means by which all Americans may become enlightened and informed citizens and thus participate fully in the functions of our democracy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc7a9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22702/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage and support an international organization of all peace-loving nations to the end that not again shall any nation be permitted to breach their national peace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc7aa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22702/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to continue to serve the best interests of our Nation in peace as in war;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc7ab-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22702/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop to the utmost the human, mental, spiritual, and economical resources of our Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc7ac-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22702/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perpetuate and preserve the friendships and comradeship born on the battle front and nurtured in the common experience of service to our Nation during time of war; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc7ad-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22702/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to honor the memory of those men and women who gave their lives that a free America and a free world might live by the creation of living memorials in the form of additional educational, cultural, and recreational facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746cc7ae-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1306"},"text":"112 Stat. 1306","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746cc7af-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id746cc7b0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id746cc7b1-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"tex