{"tag":"section","attrib":{"id":"id745017ec-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s148"},"text":null,"children":[{"tag":"num","attrib":{"value":"148"},"text":"§ 148.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" U.S. Hostage and Wrongful Detainee Day","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id745017ed-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s148/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"March 9 is U.S. Hostage and Wrongful Detainee Day.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id745017ee-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s148/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proclamation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President is requested to issue each year a proclamation calling on the people of the United States to observe U.S. Hostage and Wrongful Detainee Day with appropriate ceremonies and activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id745017ef-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVIII/s1804/a/1/A/ii"},"text":"Pub. L. 118–31, div. A, title XVIII, § 1804(a)(1)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/686"},"text":"137 Stat. 686","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
