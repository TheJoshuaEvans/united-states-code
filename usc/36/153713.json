{"tag":"section","attrib":{"id":"id74a60011-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153713"},"text":null,"children":[{"tag":"num","attrib":{"value":"153713"},"text":"§ 153713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of assets on dissolution or final liquidation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"On dissolution or final liquidation of the corporation, its assets shall be distributed as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74a60012-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153713/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All liabilities shall be paid and discharged, or adequate provision for payment and discharge shall be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a60013-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153713/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assets held on condition requiring return or transfer on dissolution of the corporation shall be returned or transferred as required by the condition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a60014-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153713/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assets received and held subject to a limitation permitting use only for charitable, religious, benevolent, educational, or similar purposes, but not held on a condition requiring return or transfer on dissolution of the corporation, shall be transferred to one or more appropriate domestic or foreign corporations, societies, or organizations under a plan of distribution adopted as provided in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a60015-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153713/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other assets shall be distributed as provided by the articles of incorporation or bylaws to the extent that the articles or bylaws provide the distributive rights of members, or any class of members, or provide for distribution to others.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a60016-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153713/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any remaining assets may be distributed to persons, societies, organizations, or domestic or foreign corporations engaged in activities not for profit, as provided in a plan of distribution adopted by the council of administration of the corporation and in compliance with the constitution and bylaws of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74a60017-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1430"},"text":"112 Stat. 1430","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74a60018-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74a60019-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74a6001a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"153713","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:1019.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 7, 1962","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/650/s19"},"text":"Pub. L. 87–650, § 19","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/76/506"},"text":"76 Stat. 506","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Before clause (1), the word “applied” is omitted as included in “distributed” and for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the word “obligations” is omitted as included in “liabilities”, and the word “satisfied” is omitted as included in “discharged”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clauses (2) and (3), the words “conveyance” and “conveyed” are omitted as included in “transfer” and “transferred”, respectively.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3), the word “eleemosynary” is omitted as included in “charitable”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (5), the words “and all Federal, State, and District of Columbia laws applicable thereto” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
