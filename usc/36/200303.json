{"tag":"section","attrib":{"id":"id74ad2b90-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s200303"},"text":null,"children":[{"tag":"num","attrib":{"value":"200303"},"text":"§ 200303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74ad2b91-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s200303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this chapter, eligibility for membership in the corporation and the rights, privileges, and designation of classes of members are as provided in the constitution and bylaws of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74ad2b92-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s200303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligibility for membership in the corporation is limited to male blood relatives of an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74ad2b93-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s200303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" served at any time during the period from ","children":[{"tag":"date","attrib":{"date":"1861-04-12"},"text":"April 12, 1861","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"1865-04-09"},"text":"April 9, 1865","children":[],"tail":", as a soldier or sailor 