{"tag":"section","attrib":{"id":"id7473f39f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s30504"},"text":null,"children":[{"tag":"num","attrib":{"value":"30504"},"text":"§ 30504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An individual is eligible for membership in the corporation if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7473f3a0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s30504/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" she is a mother (meaning a woman who filled the role of birthmother, adoptive mother, step-mother, foster-mother, grandmother, or legal guardian) of a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7473f3a1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s30504/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is serving in the Armed Forces; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7473f3a2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s30504/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has served in, or has been honorably discharged from, the Armed Forces; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7473f3a3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s30504/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" she is living in the United States or is a citizen of the United States living outside the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7473f3a4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1320"},"text":"112 Stat. 1320","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/65/s1"},"text":"Pub. L. 112–65, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-13"},"text":"Dec. 13, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/767"},"text":"125 Stat. 767","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7473f3a5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7473f3a6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id7473f3a7-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30504","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:945 (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 14, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/653/s5"},"text":"Pub. L. 86–653, § 5","children":[],"tail":" (1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/74/516"},"text":"74 Stat. 516","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), before subclause (A), the words “(who has given a mother’s care at least since the stepchild was age 13)” are substituted for “(a stepmother eligible for membership in the Blue Star Mothers of America, Inc., can claim that eligibility only if she has given a mother’s care to the stepchild from the age of thirteen or under)” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7473f3a8-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7473f3a9-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/65/s1/1/A"},"text":"Pub. L. 112–65, § 1(1)(A)","children":[],"tail":", substituted “she is a mother (meaning a woman who filled the role of birthmother, adoptive mother, step-mother, foster-mother, grandmother, or legal guardian) of a person who—” for “she is a mother, adoptive mother, or stepmother (who has given a mother’s care at least since the stepchild was age 13) of a son or daughter who—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/65/s1/1/B"},"text":"Pub. L. 112–65, § 1(1)(B)","children":[],"tail":", struck out “in World War II or the Korean hostilities” after “Armed Forces”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/65/s1/2"},"text":"Pub. L. 112–65, § 1(2)","children":[],"tail":", inserted “or is a citizen of the United States living outside the United States” before period at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
