l:p","attrib":{},"text":"36:138b (4th par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1923-03-04/ch283/s12"},"text":"Mar. 4, 1923, ch. 283, § 12","children":[],"tail":" (4th par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/42/1509"},"text":"42 Stat. 1509","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1946-06-26/ch502"},"text":"June 26, 1946, ch. 502","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/317"},"text":"60 Stat. 317","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1956-07-25/ch721"},"text":"July 25, 1956, ch. 721","children":[],"tail":", §§ 2(c), (d), 4(c)(3), "},{"tag":"html:a","attrib":{"href":"/us/stat/70/640"},"text":"70 Stat. 640","children":[],"tail":", 642."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2734"},"text":"section 2734 of title 10","children":[],"tail":"” and “section 2734” are substituted for “the first section of the Act entitled ‘An Act to provide for the prompt settlement of claims for damages occasioned by Army, Navy, and Marine Corps forces in foreign countries’, approved "},{"tag":"date","attrib":{"date":"1942-01-02"},"text":"January 2, 1942","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/55/880"},"text":"55 Stat. 880","children":[],"tail":", as amended; "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s224d"},"text":"31 U.S.C. 224d","children":[],"tail":")” and “such Act”, respectively, in section 12 (4th par.) of the Act of "},{"tag":"date","attrib":{"date":"1923-03-04"},"text":"March 4, 1923","children":[],"tail":" (ch. 283), as added by "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-25/s4/c/3"},"text":"section 4(c)(3) of the Act of July 25, 1956","children":[],"tail":" (ch. 721, "},{"tag":"ref","attrib":{"href":"/us/stat/70/642"},"text":"70 Stat. 642","children":[],"tail":"), because of "},{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/s49/b"},"text":"section 49(b) of the Act of August 10, 1956","children":[],"tail":" (ch. 1041, "},{"tag":"ref","attrib":{"href":"/us/stat/70A/640"},"text":"70A Stat. 640","children":[],"tail":"). The 1942 law enacted former 31:224d, 224h, and 224i. Those sections subsequently were codified as 10:2734 and repealed by the Act of "},{"tag":"date","attrib":{"date":"1956-08-10"},"text":"August 10, 1956","children":[],"tail":" (ch. 1041, "},{"tag":"ref","attrib":{"href":"/us/stat/70A/154"},"text":"70A Stat. 154","children":[],"tail":", 672). The words “both real and personal” are omitted as unnecessary. The words “on or after "},{"tag":"date","attrib":{"date":"1956-07-25"},"text":"July 25, 1956","children":[],"tail":"” are omitted as obsolete. The words “or commissions” are omitted because of 1:1. The words “settled, decided” are substituted for “considered, ascertained, adjusted, determined” to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
