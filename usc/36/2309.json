{"tag":"section","attrib":{"id":"id745e6f1c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2309"},"text":null,"children":[{"tag":"num","attrib":{"value":"2309"},"text":"§ 2309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audit of financial transactions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Financial transactions of the Museum, including those involving donated funds, shall be audited by the Comptroller General as requested by Congress, in accordance with generally accepted auditing standards. In conducting any audit pursuant to this section, appropriate representatives of the Comptroller General shall have access to all books, accounts, financial records, reports, files and other papers, items or property in use by the Museum, as necessary to facilitate such audit, and such representatives shall be afforded full facilities for verifying transactions with the balances.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id745e6f1d-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/292/s1"},"text":"Pub. L. 106–292, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-12"},"text":"Oct. 12, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1034"},"text":"114 Stat. 1034","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id745e6f1e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id745e6f1f-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id745e6f20-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2309, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1280"},"text":"112 Stat. 1280","children":[],"tail":", related to authorization of appropriations, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/292"},"text":"Pub. L. 106–292","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
