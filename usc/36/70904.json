{"tag":"section","attrib":{"id":"id7487067f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904"},"text":null,"children":[{"tag":"num","attrib":{"value":"70904"},"text":"§ 70904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74870680-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board of Directors","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74870681-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The board of directors is the governing body of the FFA. The board shall exercise the powers granted to the FFA.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74870682-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The board—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74870683-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall consist of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74870684-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Education, or the Secretary of Education’s designee who has experience in agricultural education, the FFA, or career and technical education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74870685-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" other individuals—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id74870686-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/a/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representing the fields of education, agriculture, food, and natural resources; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id74870687-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/a/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with experience working closely with the FFA; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74870688-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not include any individual who is a current employee of the National FFA Organization.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74870689-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of directors, terms of office of the directors, and the method of selecting the directors, are as provided in the constitution or bylaws of the FFA.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7487068a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The board shall meet at least annually at the time and place provided in the constitution or bylaws of the FFA. The annual report of the board shall be presented at that meeting. Special meetings of the board may be called at any time by the chair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7487068b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The officers of the FFA, the terms of officers, and the election of officers, are as provided in the constitution or bylaws of the FFA, except that such officers shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7487068c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national advisor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7487068d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an executive secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7487068e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a treasurer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7487068f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Governing Committee.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74870690-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The board may designate a governing committee. The terms and method of selecting the governing committee members are as provided in the constitution or bylaws of the FFA, except that all members of the governing committee shall be members of the board of directors and at all times the governing committee shall be comprised of not less than 3 individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74870691-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the board is not in session, the governing committee has the powers of the board subject to the board’s direction and may authorize the seal of the FFA to be affixed to all papers that require it.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74870692-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The board shall designate to such committee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74870693-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chair of the board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74870694-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the executive secretary of the board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74870695-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70904/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treasurer of the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74870696-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1357"},"text":"112 Stat. 1357","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/7/s5"},"text":"Pub. L. 116–7, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-21"},"text":"Feb. 21, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/479"},"text":"133 Stat. 479","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74870697-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74870698-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74870699-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70904(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:278(a)–(c), (e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-08-30/ch823/s8"},"text":"Aug. 30, 1950, ch. 823, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/565"},"text":"64 Stat. 565","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70904(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:278(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the text of 36:278(e) is omitted as obsolete. In paragraph (2), the words “Secretary of Education” and “Department of Education” are substituted for “Chief of the Agricultural Education Service, Office of Education, Federal Security Agency” and “Agricultural Education Service, Office of Education, Federal Security Agency”, respectively, in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1950-08-30/s8/a"},"text":"section 8(a) of the Act of August 30, 1950","children":[],"tail":" (ch. 823, "},{"tag":"ref","attrib":{"href":"/us/stat/64/565"},"text":"64 Stat. 565","children":[],"tail":"), because of sections 5 and 8 of Reorganization Plan No. 1 of 1953 (5 App. U.S.C.) and 20:3441 and 3507."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7487069a-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7487069b-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/7/s5/1/A"},"text":"Pub. L. 116–7, § 5(1)(A)","children":[],"tail":", substituted “FFA” for “corporation” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/7/s5/1/B"},"text":"Pub. L. 116–7, § 5(1)(B)","children":[],"tail":", added pars. (2) and (3) and struck out former pars. (2) and (3) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The board consists of the Secretary of Education, four staff members in the Department of Education, and four State supervisors of agriculture education. The Secretary is chairman of the board.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) The term of office of the directors and the method of selecting the directors (except ex officio directors) are as provided in the bylaws.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/7/s5/1/C"},"text":"Pub. L. 116–7, § 5(1)(C)","children":[],"tail":", substituted “constitution or bylaws of the FFA” for “bylaws” and “chair” for “chairman”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/7/s5/2"},"text":"Pub. L. 116–7, § 5(2)","children":[],"tail":", (3), added subsecs. (b) and (c) and struck out former subsec. (b) which read as follows: “"},{"tag":"inline","attrib":{},"text":"Governing Committee","children":[],"tail":".—The board may designate the chairman of the board and two members of the chairman’s staff as a governing committee. When the board is not in session, the governing committee has the powers of the board subject to the board’s direction and may authorize the seal of the corporation to be affixed to all papers that require it.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
