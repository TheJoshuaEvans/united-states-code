"},"text":"Pub. L. 95–98, § 1(b)(3)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/830"},"text":"91 Stat. 830","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/54/s13/n/1"},"text":"Pub. L. 102–54, § 13(n)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/278"},"text":"105 Stat. 278","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “Secretary of Veterans Affairs” are substituted for “Department of Veterans Affairs” because under 38:303 the Secretary is the head of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
