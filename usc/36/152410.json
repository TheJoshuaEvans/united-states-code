{"tag":"section","attrib":{"id":"id749ed4c5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152410"},"text":null,"children":[{"tag":"num","attrib":{"value":"152410"},"text":"§ 152410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity of United States Government","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Government is not liable for any debts, defaults, acts, or omissions of the corporation. The full faith and credit of the Government does not extend to any obligation of the corporation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id749ed4c6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tII/s201/a"},"text":"Pub. L. 106–474, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2094"},"text":"114 Stat. 2094","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
