{"tag":"section","attrib":{"id":"id74bb8390-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220552"},"text":null,"children":[{"tag":"num","attrib":{"value":"220552"},"text":"§ 220552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissolution of board of directors of corporation and termination of recognition of national governing bodies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74bb8391-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220552/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dissolution of Board of Directors of Corporation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Effective on the date of enactment of a joint resolution described in section 220551(2)(A) with respect to the board of directors of the corporation, such board of directors shall be dissolved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74bb8392-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220552/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Recognition of National Governing Body","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Effective on the date of enactment of a joint resolution described in section 220551(2)(B) with respect to a national governing body, the recognition of the applicable amateur sports organization as a national governing body shall cease to have force or effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74bb8393-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s5/a/2"},"text":"Pub. L. 116–189, § 5(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/947"},"text":"134 Stat. 947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74bb8394-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id74bb8395-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id74bb8396-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 year after ","children":[{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/116/189/s5/c"},"text":"section 5(c) of Pub. L. 116–189","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s220551"},"text":"section 220551 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
