{"tag":"section","attrib":{"id":"id749ed430-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152305"},"text":null,"children":[{"tag":"num","attrib":{"value":"152305"},"text":"§ 152305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The corporation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749ed431-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152305/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt and amend a constitution and bylaws for the management of its property and the regulation of its affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed432-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152305/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt and alter a corporate seal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed433-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152305/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" choose officers, managers, employees, and agents as the activities of the corporation require;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed434-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152305/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed435-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152305/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish a bulletin, magazine, and other publications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed436-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152305/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, own, lease, encumber, and transfer property as necessary to carry out the purposes of the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed437-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152305/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" borrow money, issue instruments of indebtedness, and secure its obligations by granting security interests in its property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed438-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152305/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use corporate funds to give prizes, awards, loans, scholarships, and grants to deserving composers, conductors, and others for the purposes stated in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s152302"},"text":"section 152302 of this title","children":[],"tail":" and for other purposes the board of directors considers proper;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed439-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152305/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sue and be sued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed43a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152305/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do any other act necessary and proper to carry out the purposes of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749ed43b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1413"},"text":"112 Stat. 1413","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749ed43c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id749ed43d-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id749ed43e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"152305","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:664.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1956-08-01/ch824"},"text":"Aug. 1, 1956, ch. 824","children":[],"tail":", §§ 4, 18, "},{"tag":"html:a","attrib":{"href":"/us/stat/70/795"},"text":"70 Stat. 795","children":[],"tail":", 797."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:678.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the text of 36:678 is omitted as executed and obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words “not inconsistent with the laws of the United States or any State in which the Corporation is to operate” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the word “use” is omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3), the word “activities” is substituted for “business” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (6) is substituted for “take and hold by lease, gift, purchase, grant, devise, or bequest any property, real or personal, necessary for attaining the objects or accomplishing the purposes of the Corporation” and “transfer and convey real or personal property” for consistency in the revised title and to eliminate unnecessary words. The words “subject to applicable provisions of law of any State (A) governing the amount or kind of real and personal property which may be held by, or (B) otherwise limiting or controlling the ownership of real and personal property by a corporation operating in such State” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (7), the words “for the purposes of the Corporation” are omitted as unnecessary. The words “issue instruments of indebtedness, and secure its obligations by granting security interests in its property” are substituted for “issue bonds therefor, and secure the same by mortgage” for consistency in the revised title. The words “subject to all applicable provisions of Federal or State law” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (8), the words “other purposes the board of directors considers proper” are substituted for “such other purpose as may be determined to be proper by the board of directors” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (9), the words “complain and defend in any court of competent jurisdiction” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (10), the words “any other act” are substituted for “any and all acts and things”, and the word “objects” is omitted, to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
