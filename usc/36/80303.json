{"tag":"section","attrib":{"id":"id7489502d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80303"},"text":null,"children":[{"tag":"num","attrib":{"value":"80303"},"text":"§ 80303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7489502e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Council","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7489502f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be a National Council of Girl Scouts. The number, qualifications, and term of office of members of the Council are as provided in the constitution of the corporation, except that members of the Council must be citizens of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74895030-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Council may adopt and amend a constitution and bylaws and elect a board of directors, officers, and agents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74895031-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80303/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The constitution may prescribe the number of members of the Council necessary for a quorum. That number may be less than a majority of the entire Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74895032-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80303/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Meetings of the Council shall be held as provided in the constitution to hold elections and receive reports of the officers and board of directors. Special meetings may be called as provided in the constitution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74895033-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board of Directors","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74895034-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent provided in the constitution and bylaws, the board of directors shall have the powers of the Council and manage the activities of the corporation between meetings of the Council. The number, qualifications, and term of office of directors are as provided in the constitution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74895035-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The constitution may prescribe the number of directors necessary for a quorum. That number shall be at least 20 or two-fifths of the entire board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74895036-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive and Other Committees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The bylaws may provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74895037-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an executive committee to carry out the powers of the board of directors between meetings of the board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74895038-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other committees to operate under the general supervision of the board of directors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74895039-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location of Meetings and Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council and the board of directors may hold meetings and keep the seal and records of the corporation in or outside the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7489503a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1361"},"text":"112 Stat. 1361","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7489503b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7489503c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id7489503d-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":