{"tag":"section","attrib":{"id":"id7492ed0c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140406"},"text":null,"children":[{"tag":"num","attrib":{"value":"140406"},"text":"§ 140406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7492ed0d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stock and Dividends","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not issue stock or declare or pay a dividend.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7492ed0e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Income or Assets","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The income or assets of the corporation may not inure to the benefit of, or be distributed to, a director, officer, or member of the corporation during the life of the charter granted by this chapter. This subsection does not prevent the payment of reasonable compensation to an officer or employee of the corporation or reimbursement for actual necessary expenses in amounts approved by the board of directors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7492ed0f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140406/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not make a loan to a director, officer, employee, or member of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7492ed10-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140406/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claim of Governmental Approval or Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not claim congressional approval or the authority of the United States Government for any of its activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7492ed11-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140406/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corporate Status","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall maintain its status as a corporation incorporated under the laws of the Commonwealth of Virginia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7492ed12-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/95/s1/a"},"text":"Pub. L. 111–95, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-06"},"text":"Nov. 6, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3002"},"text":"123 Stat. 3002","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
