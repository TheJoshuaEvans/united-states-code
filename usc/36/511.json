{"tag":"section","attrib":{"id":"id74528872-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s511"},"text":null,"children":[{"tag":"num","attrib":{"value":"511"},"text":"§ 511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74528873-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Necessary amounts are authorized to be appropriated—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74528874-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s511/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to enable the Mayor of the District of Columbia to provide additional municipal services in the District of Columbia during the inaugural period, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74528875-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s511/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employment of personal services without regard to chapters 33 and 51 and subchapter III of chapter 53 of title 5;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74528876-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s511/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel expenses of enforcement personnel, including sanitarians, from other jurisdictions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74528877-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s511/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hiring of the means of transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74528878-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s511/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meals for policemen, firemen, and other municipal employees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74528879-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s511/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of removing and relocating streetcar loading platforms, construction, rent, maintenance, and expenses incident to the operation of temporary public comfort stations, first-aid stations, and information booths; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7452887a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s511/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other incidental expenses in the discretion of the Mayor; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7452887b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s511/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable the Secretary of the Interior to provide meals for the members of the United States Park Police during the inaugural period.","childr