{"tag":"section","attrib":{"id":"id749ed47c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403"},"text":null,"children":[{"tag":"num","attrib":{"value":"152403"},"text":"§ 152403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id749ed47d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The board of directors is the governing body of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed47e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members and Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id749ed47f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Librarian of Congress (hereafter in this chapter referred to as the “Librarian”) is an ex officio nonvoting member of the board. Not later than 90 days after the date of the enactment of this chapter, the Librarian shall appoint the directors to the board in accordance with paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed480-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id749ed481-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The board consists of 12 directors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id749ed482-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each director shall be a United States citizen.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id749ed483-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 8 directors shall be knowledgeable or experienced in sound recording production, distribution, preservation, or restoration, including two who are sitting members of the National Recording Preservation Board. These 8 directors shall, to the extent practicable, represent diverse points of view from the sound recording community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed484-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A director is not an employee of the Library of Congress and appointment to the board does not constitute appointment as an officer or employee of the United States Government for the purpose of any law of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed485-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms of office of the directors are 4 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed486-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vacancy on the board shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed487-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chair","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Librarian shall appoint one of the directors as the initial chair of the board for a 2-year term. Thereafter, the chair shall be appointed and removed in accordance with the bylaws of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed488-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quorum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The number of directors constituting a quorum of the board shall be established under the bylaws of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed489-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The board shall meet at the call of the Librarian for regularly scheduled meetings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed48a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement of Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Directors shall serve without compensation but may receive travel expenses, including per diem in lieu of subsistence, in accordance with sections 5702 and 5703 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed48b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152403/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability of Directors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Directors are not personally liable, except for gross negligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749ed48c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tII/s201/a"},"text":"Pub. L. 106–474, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2092"},"text":"114 Stat. 2092","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/336/s2/b/2"},"text":"Pub. L. 110–336, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-02"},"text":"Oct. 2, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3727"},"text":"122 Stat. 3727","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/217/s2/b/2"},"text":"Pub. L. 114–217, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-29"},"text":"July 29, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/840"},"text":"130 Stat. 840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749ed48d-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id749ed48e-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id749ed48f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this chapter, referred to in subsec. (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474"},"text":"Pub. L. 106–474","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id749ed490-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/217/s2/b/2/A"},"text":"Pub. L. 114–217, § 2(b)(2)(A)","children":[],"tail":", substituted “12 directors” for “nine directors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/217/s2/b/2/B"},"text":"Pub. L. 114–217, § 2(b)(2)(B)","children":[],"tail":", substituted “8 directors” for “six directors” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/336"},"text":"Pub. L. 110–336","children":[],"tail":" struck out at end “An individual may not serve more than two consecutive terms.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
