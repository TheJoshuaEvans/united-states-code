{"tag":"section","attrib":{"id":"id749ed491-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152404"},"text":null,"children":[{"tag":"num","attrib":{"value":"152404"},"text":"§ 152404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id749ed492-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary of the Board","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id749ed493-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152404/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Librarian shall appoint a Secretary of the Board to serve as executive director of the corporation. The Librarian may remove the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed494-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152404/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall be knowledgeable and experienced in matters relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id749ed495-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152404/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sound recording preservation and restoration activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id749ed496-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152404/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" financial management; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id749ed497-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152404/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fundraising.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed498-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (a) of this section, the board of directors appoints, removes, and replaces officers of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed499-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152404/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (a) of this section, the Secretary appoints, removes, and replaces employees of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed49a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152404/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status and Compensation of Employees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Employees of the corporation (including the Secretary)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749ed49b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152404/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not employees of the Library of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed49c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152404/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be appointed and removed without regard to the provisions of title 5 governing appointments in the competitive service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed49d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152404/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be paid without regard to chapter 51 and subchapter III of chapter 53 of title 5, except that an employee may not be paid more than the annual rate of basic pay for level 15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5107"},"text":"section 5107 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749ed49e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tII/s201/a"},"text":"Pub. L. 106–474, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2093"},"text":"114 Stat. 2093","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749ed49f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id749ed4a0-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id749ed4a1-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The General Schedule, referred to in subsec. (d)(3), is set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
