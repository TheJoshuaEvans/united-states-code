{"tag":"section","attrib":{"id":"id74b1e69d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503"},"text":null,"children":[{"tag":"num","attrib":{"value":"220503"},"text":"§ 220503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b1e69e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish national goals for amateur athletic activities and encourage the attainment of those goals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e69f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate and develop amateur athletic activity in the United States, directly related to international amateur athletic competition, to foster productive working relationships among sports-related organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6a0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to exercise exclusive jurisdiction, directly or through constituent members of committees, over—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74b1e6a1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all matters pertaining to United States participation in the Olympic Games, the Paralympic Games, the Pan-American Games, and the Parapan American Games, including representation of the United States in the games; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b1e6a2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the organization of the Olympic Games, the Paralympic Games, the Pan-American Games, and the Parapan American Games when held in the United States;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6a3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain for the United States, directly or by delegation to the appropriate national governing body, the most competent amateur representation possible in each event of the Olympic Games, the Paralympic Games, the Pan-American Games, and the Parapan American Games;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6a4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote and support amateur athletic activities involving the United States and foreign nations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6a5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote and encourage physical fitness and public participation in amateur athletic activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6a6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist organizations and persons concerned with sports in the development of amateur athletic programs for amateur athletes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6a7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide swift resolution of conflicts and disputes involving amateur athletes, national governing bodies, and amateur sports organizations, and protect the opportunity of any amateur athlete, coach, trainer, manager, administrator, or official to participate in amateur athletic competition;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6a8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster the development of and access to amateur athletic facilities for use by amateur athletes and assist in making existing amateur athletic facilities available for use by amateur athletes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6a9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide and coordinate technical information on physical training, equipment design, coaching, and performance analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6aa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage and support research, development, and dissemination of information in the areas of sports medicine and sports safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6ab-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage and provide assistance to amateur athletic activities for women;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6ac-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage and provide assistance to amateur athletic programs and competition for amateur athletes with disabilities, including, where feasible, the expansion of opportunities for meaningful participation by such amateur athletes in programs of athletic competition for able-bodied amateur athletes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6ad-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage and provide assistance to amateur athletes of racial and ethnic minorities for the purpose of eliciting the participation of those minorities in amateur athletic activities in which they are underrepresented;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6ae-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote a safe environment in sports that is free from abuse, including emotional, physical, and sexual abuse, of any amateur athlete; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b1e6af-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220503/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to effectively oversee the national governing bodies with respect to compliance with and implementation of the policies and procedures of the corporation, including policies and procedures on the establishment of a safe environment in sports as described in paragraph (15).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74b1e6b0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1466"},"text":"112 Stat. 1466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s142/d"},"text":"Pub. L. 105–277, div. C, title I, § 142(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-603"},"text":"112 Stat. 2681–603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/126/tII/s201"},"text":"Pub. L. 115–126, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-14"},"text":"Feb. 14, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/320"},"text":"132 Stat. 320","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/189"},"text":"Pub. L. 116–189","children":[],"tail":", §§ 4(a)(3), 6(a), "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/945"},"text":"134 Stat. 945","children":[],"tail":", 947.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74b1e6b1-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74b1e6b2-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74b1e6b3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220503","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:374.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-21/ch975"},"text":"Sept. 21, 1950, ch. 975","children":[],"tail":", title I, § 104, as added "},{"tag":"html:span","attrib":{},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/606/s1/b"},"text":"Pub. L. 95–606, § 1(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/3046"},"text":"92 Stat. 3046","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Before clause (1), the word “objects” is omitted as included in “purposes”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (4), the word “competition” is omitted as included in “each event”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74b1e6b4-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74b1e6b5-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s4/a/3/A"},"text":"Pub. L. 116–189, § 4(a)(3)(A)","children":[],"tail":", substituted “the Pan-American Games, and the Parapan American Games” for “and the Pan-American Games” in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s4/a/3/B"},"text":"Pub. L. 116–189, § 4(a)(3)(B)","children":[],"tail":", substituted “the Pan-American Games, and the Parapan American Games” for “and Pan-American Games”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s6/a/1"},"text":"Pub. L. 116–189, § 6(a)(1)","children":[],"tail":", inserted “and access to” after “development of”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s6/a/2"},"text":"Pub. L. 116–189, § 6(a)(2)","children":[],"tail":"–(4), added par. (16)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Par. (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/126"},"text":"Pub. L. 115–126","children":[],"tail":" added par. (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/d/1"},"text":"Pub. L. 105–277, § 142(d)(1)","children":[],"tail":", substituted “Olympic Games, the Paralympic Games” for “Olympic Games” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/d/2"},"text":"Pub. L. 105–277, § 142(d)(2)","children":[],"tail":", added par. (13) and struck out former par. (13) which read as follows: “to encourage and provide assistance to amateur athletic programs and competition for individuals with disabilities, including, where feasible, the expansion of opportunities for meaningful participation by individuals with disabilities in programs of athletic competition for able-bodied individuals; and”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
