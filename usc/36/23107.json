2/s5/a"},"text":"Pub. L. 88–372, § 5(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/316"},"text":"78 Stat. 316","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “various” is omitted as unnecessary. The words “the Commonwealth of Puerto Rico” are omitted as included in “territories, and possessions of the United States”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7471829c-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7471829d-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/91"},"text":"Pub. L. 115–91","children":[],"tail":" substituted “Ohio” for “Dayton, Ohio, or another place decided by the board of trustees”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
