{"tag":"section","attrib":{"id":"id74b6a193-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220513"},"text":null,"children":[{"tag":"num","attrib":{"value":"220513"},"text":"§ 220513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual amateur athlete survey","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74b6a194-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than annually, the corporation shall cause an independent third-party organization, under contract, to conduct an anonymous survey of amateur athletes who are actively engaged in amateur athletic competition with respect to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b6a195-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220513/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" their satisfaction with the corporation and the applicable national governing body; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b6a196-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220513/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the behaviors, attitudes, and feelings within the corporation and the applicable national governing body relating to sexual harassment and abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b6a197-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract under subsection (a) shall require the independent third-party organization to develop the survey in consultation with the Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b6a198-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Interference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the corporation or a national governing body makes any effort to undermine the independence of, introduce bias into, or otherwise influence a survey under subsection (a), such activity shall be reported immediately to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b6a199-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220513/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":" The corporation shall make the results of each such survey available to the public on an internet website of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74b6a19a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s6/g/1"},"text":"Pub. L. 116–189, § 6(g)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/955"},"text":"134 Stat. 955","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
