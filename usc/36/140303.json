{"tag":"section","attrib":{"id":"id7492ecd2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140303"},"text":null,"children":[{"tag":"num","attrib":{"value":"140303"},"text":"§ 140303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The corporation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7492ecd3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140303/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make its own organization, including its constitution, bylaws, and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecd4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140303/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt and alter a corporate seal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecd5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140303/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain offices to conduct its activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecd6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140303/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint or elect officers and agents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecd7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140303/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the executive committee to conduct the business and exercise the powers of the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecd8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140303/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, own, lease, encumber, and transfer property as necessary or appropriate to carry out the purposes of the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecd9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140303/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish a magazine and other publications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecda-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140303/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charge and collect membership dues and subscription fees;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecdb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140303/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sue and be sued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecdc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140303/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do any other act necessary or appropriate to carry out the purposes of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7492ecdd-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1380"},"text":"112 Stat. 1380","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7492ecde-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7492ecdf-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id7492ece0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"140303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:314(b)–(k).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-20/ch956"},"text":"Sept. 20, 1950, ch. 956","children":[],"tail":", §§ 4(b)–(k), 5, "},{"tag":"html:a","attrib":{"href":"/us/stat/64/868"},"text":"64 Stat. 868","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:315.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the word “rules” is omitted as being the same as “regulations”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the words “at pleasure” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3), the words “and transaction” are omitted as unnecessary. The word “activities” is substituted for “business” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (6) is substituted for “acquire, by purchase, devise, bequest, gift, or otherwise, and hold, encumber, convey, or otherwise dispose of, such real and personal property as may be necessary or appropriate for its corporate purposes” for consistency in the revised title and to eliminate unnecessary words. The text of 36:315 is omitted as executed and obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (8), the words “and receive contributions of money or property to be devoted to the carrying out of the purposes of the organization” are omitted as unnecessary because of clause (6) of the revised section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
