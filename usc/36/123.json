{"tag":"section","attrib":{"id":"id744dcd3e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s123"},"text":null,"children":[{"tag":"num","attrib":{"value":"123"},"text":"§ 123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Forest Products Week","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id744dcd3f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The week beginning on the third Sunday in October is National Forest Products Week.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id744dcd40-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proclamation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President is requested to issue each year a proclamation calling on the people of the United States to observe National Forest Products Week with appropriate ceremonies and activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id744dcd41-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1259"},"text":"112 Stat. 1259","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id744dcd42-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id744dcd43-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id744dcd44-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"123(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:163 (words before comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 13, 1960","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/753"},"text":"Pub. L. 86–753","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/74/898"},"text":"74 Stat. 898","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"123(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:163 (words after comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"execDoc","id":"id744dcd45-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Executive Documents","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id744dcd46-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Proc. No. 8442. National Forest Products Week","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Proc. No. 8442, ","children":[{"tag":"date","attrib":{"date":"2009-10-23"},"text":"Oct. 23, 2009","children":[],"tail":", 74 F.R. 55437, provided:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"America’s forests have helped spur the growth and development that has been indispensable to our Nation’s success. They have provided timber and water, as well as habitat for wildlife and opportunities for recreational activities. As a repository for renewable natural resources, forests have supplied the raw materials that have sustained us throughout our history. During National Forest Products Week, we recognize the value of our woodlands and commit ourselves to good stewardship and conservation practices that help us to responsibly manage our Nation’s forests.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"As a renewable and recyclable resource, wood is one of our Nation’s most environmentally friendly building materials. Wood fiber is used throughout our daily lives, from the paper we write on to the offices where we work. We value the beauty of wood in our furniture, in our homes, and in artwork that surrounds us. Today, modern technology and stewardship practices by Federal, State, tribal, and private landowners have improved the way we manage our natural resources so that forests can meet the needs of current and future generations.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Forests are one of the foundations on which our Nation was formed; they are the backbone of our environment. This week, we recognize the value of forest products and the importance of their sustainable use to our lives.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"To recognize the importance of products from our forests, the Congress, by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/86/753"},"text":"Public Law 86–753","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t36/s123"},"text":"36 U.S.C. 123","children":[],"tail":"), as amended, has designated the week beginning on the third Sunday in October of each year as National Forest Products Week and has authorized and requested the President to issue a proclamation in observance of this week."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"NOW, THEREFORE, I, BARACK OBAMA, President of the United States of America, do hereby proclaim the week beginning on the third Sunday in October of each year as National Forest Products Week. I call on all Americans to celebrate the varied uses and products of our forested lands, as well as the people who carry on the tradition of careful stewardship of these precious natural resources for generations to come.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"IN WITNESS WHEREOF, I have hereunto set my hand this twenty-third day of October, in the year of our Lord two thousand nine, and of the Independence of the United States of America the two hundred and thirty-fourth.","children":[],"tail":"\n"},{"tag":"signature","attrib":{},"text":"\n","children":[{"tag":"name","attrib":{},"text":"Barack Obama.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
