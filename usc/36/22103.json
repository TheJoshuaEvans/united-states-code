{"tag":"section","attrib":{"id":"id746a56ac-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22103"},"text":null,"children":[{"tag":"num","attrib":{"value":"22103"},"text":"§ 22103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746a56ad-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive Council","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id746a56ae-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The executive council is the governing body of the corporation. However, the council is subject to the directions of the corporation at its annual meetings and at any other meeting called under the constitution, bylaws, or regulations of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746a56af-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The council consists of a president, an honorary president, a number of vice presidents and honorary vice presidents as provided in the constitution, a secretary, a treasurer, and at least 24 additional individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746a56b0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election and Terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The officers of the corporation and one-third of the other members of the council shall be elected at each annual meeting of the corporation. However, the constitution may authorize the council—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746a56b1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to elect the secretary and the treasurer of the corporation for specified terms; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746a56b2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to fill vacancies until the next annual meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746a56b3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1300"},"text":"112 Stat. 1300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746a56b4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id746a56b5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id746a56b6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"22103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:343.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-20/ch958/s3"},"text":"Sept. 20, 1950, ch. 958, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/64/870"},"text":"64 Stat. 870","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “The number of members of the executive council shall initially be forty-four, and the members of the said council shall initially be the persons whose names and addresses are set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s341"},"text":"section 341 of this title","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
