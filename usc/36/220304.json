{"tag":"section","attrib":{"id":"id74af9d1c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220304"},"text":null,"children":[{"tag":"num","attrib":{"value":"220304"},"text":"§ 220304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74af9d1d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board of Trustees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74af9d1e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The board of trustees is the governing body of the corporation. The board is responsible for the control of all funds and affairs of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9d1f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Exclusive of ex officio and honorary members, the board shall consist of at least 12 but not more than 40 trustees, one of whom shall be elected chairman. Trustees shall be elected by the board of trustees for a term of 4 years. A trustee may not be reelected as a trustee within one year of the expiration of the prior term, except by the unanimous vote of the trustees present and voting. A trustee may be removed at any time, with or without cause, by a two-thirds vote of the other trustees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9d20-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The officers of the corporation are ex officio members of the board with all the rights and privileges of trustees, including the right to vote.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9d21-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220304/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The board shall meet at least once a year in the Capitol of the United States. The board may meet at other times as decided by the chairman. A meeting may be held only at a time and place stated in the bylaws or on 30 days’ written notice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74af9d22-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74af9d23-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The officers of the corporation are a president, 5 vice presidents, a treasurer, and a secretary. The president is the chief executive officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9d24-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The officers shall be elected annually by the board of trustees and continue in office at the pleasure of the board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9d25-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The duties of the officers are the usual duties pertaining to their offices and any additional duties delegated by the board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9d26-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220304/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Officers may be compensated for their services, and reimbursed for actual expenses, in amounts decided by the board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74af9d27-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The board of trustees may employ an executive secretary and other personnel needed to assist the board and the officers to carry out the activities of the corporation. Employees serve at the pleasure of the board. The board shall prescribe the compensation and duties of employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74af9d28-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1463"},"text":"112 Stat. 1463","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74af9d29-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74af9d2a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74af9d2b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html