{"tag":"section","attrib":{"id":"id7478ae4b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40302"},"text":null,"children":[{"tag":"num","attrib":{"value":"40302"},"text":"§ 40302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7478ae4c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To provide an organization to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7478ae4d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40302/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage and aid citizens of the United States in contributing their efforts, services, and resources in developing aviation and in maintaining air supremacy; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7478ae4e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40302/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage and develop by example the voluntary contribution of private citizens to the public welfare.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7478ae4f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide aviation education and training especially to its senior and cadet members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7478ae50-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To encourage and foster civil aviation in local communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7478ae51-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To provide an organization of private citizens with adequate facilities to assist in meeting local and national emergencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7478ae52-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To assist the Department of the Air Force in fulfilling its noncombat programs and missions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7478ae53-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1331"},"text":"112 Stat. 1331","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1090(b)(1)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–299.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7478ae54-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children"