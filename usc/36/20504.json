{"tag":"section","attrib":{"id":"id74632b4d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20504"},"text":null,"children":[{"tag":"num","attrib":{"value":"20504"},"text":"§ 20504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cooperation with the military","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74632b4e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investigations, Examinations, Experiments, and Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When requested by the Secretary of the Army, Air Force, or Navy, the corporation shall investigate, examine, experiment, and report on any subject in pure or applied chemistry connected with the national defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74632b4f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The actual expense of those investigations, examinations, experiments, and reports shall be paid from amounts appropriated for those purposes, but the corporation may not receive compensation for any services performed for the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74632b50-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Title and License","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Title to inventions and discoveries made in the course of those investigations, examinations, and experiments that the appropriate Secretary believes involve the national defense vest in the Government. The Government shall have unlimited license under other inventions and discoveries made in the course of those investigations, examinations, and experiments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74632b51-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1288"},"text":"112 Stat. 1288","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74632b52-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74632b53-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74632b54-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20504","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:3204.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1937-08-25/ch762/s4"},"text":"Aug. 25, 1937, ch. 762, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/50/799"},"text":"50 Stat. 799","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “When requested by the Secretary of the Army, Air Force, or Navy, the corporation” are substituted for “The American Chemical Society shall, whenever called upon by the Army, Air Force, or Navy Department” because under 10:3013, 5013, and 8013 the Secretaries are the heads of the Departments. The Secretary of the Air Force is added because of section 207 of the National Security Act of 1947 (ch. 343, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/61/502"},"text":"61 Stat. 502","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “shall be paid from amounts appropriated for those purposes” are substituted for “to be paid from appropriations which may have been made for that purpose by Congress” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “that the appropriate Secretary believes” are substituted for “that, in the opinion of the Secretary of the Navy, the Secretary of the Air Force, or the Secretary of the Army” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
