{"tag":"section","attrib":{"id":"id74bdce9d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230502"},"text":null,"children":[{"tag":"num","attrib":{"value":"230502"},"text":"§ 230502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74bdce9e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Vietnam Veterans of America, Inc. (in this chapter, the “corporation”), a nonprofit corporation incorporated in New York, is a federally chartered corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74bdce9f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration of Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the corporation does not comply with any provision of this chapter, the charter granted by this chapter expires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74bdcea0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1486"},"text":"112 Stat. 1486","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74bdcea1-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","