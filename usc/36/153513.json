/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.) (known as the National Park Service Organic Act)” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t16/s1"},"text":"16 U.S.C. 1","children":[],"tail":" et seq.), known as the National Park Service Organic Act))”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
