{"tag":"section","attrib":{"id":"id74a38ee9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153102"},"text":null,"children":[{"tag":"num","attrib":{"value":"153102"},"text":"§ 153102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are patriotic, historical, and educational, and include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74a38eea-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" perpetuating the memory and spirit of the men and women who achieved American independence by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74a38eeb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153102/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquiring and protecting historical spots and erecting monuments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74a38eec-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153102/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging historical research in relation to the Revolution and publishing its results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74a38eed-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153102/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserving documents and relics and the records of the individual services of Revolutionary soldiers and patriots; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74a38eee-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153102/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting celebrations of all patriotic anniversaries;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a38eef-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying out the injunction of Washington, in his farewell address to the American people, “to promote, as an object of primary importance, institutions for the general diffusion of knowledge,” thus developing an enlightened public opinion and affording to young and old such advantages as shall develop in them the largest capacity for performing the duties of American citizens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a38ef0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cherishing, maintaining, and extending the institutions of American freedom;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a38ef1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fostering true patriotism and love of country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a38ef2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aiding in securing for mankind all the blessings of liberty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74a38ef3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1422"},"text":"112 Stat. 1422","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74a38ef4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74a38ef5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74a38ef6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":n