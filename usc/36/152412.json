{"tag":"section","attrib":{"id":"id74a144d1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152412"},"text":null,"children":[{"tag":"num","attrib":{"value":"152412"},"text":"§ 152412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As soon as practicable after the end of each fiscal year, the corporation shall submit a report to the Librarian for transmission to Congress on the activities of the corporation during the prior fiscal year, including a complete statement of its receipts, expenditures, and investments.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id74a144d2-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tII/s201/a"},"text":"Pub. L. 106–474, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2095"},"text":"114 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
