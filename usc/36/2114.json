{"tag":"section","attrib":{"id":"id745c25cd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2114"},"text":null,"children":[{"tag":"num","attrib":{"value":"2114"},"text":"§ 2114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intellectual property and related items","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id745c25ce-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Use and Register Intellectual Property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The American Battle Monuments Commission may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id745c25cf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt, use, register, and license trademarks, service marks, and other marks;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id745c25d0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain, use, register, and license the use of copyrights consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s105"},"text":"section 105 of title 17","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id745c25d1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2114/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain, use, and license patents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id745c25d2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2114/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept gifts of marks, copyrights, patents, and licenses for use by the Commission.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id745c25d3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Grant Licenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may grant exclusive and nonexclusive licenses in connection with any mark, copyright, patent, or license for the use of such mark, copyright or patent, except to the extent the grant of such license by the Commission would be contrary to any contract or license by which the use of the mark, copyright, or patent was obtained.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id745c25d4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may enforce any mark, copyright, or patent by an action in the district courts under any law providing for the protection of such marks, copyrights, or patents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id745c25d5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2114/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Legal Representation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General shall furnish the Commission with such legal representation as the Commission may require under subsection (c). The Secretary of Defense shall provide representation for the Commission in administrative proceedings before the Patent and Trademark Office and Copyright Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id745c25d6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2114/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Irrevocability of Transfers of Copyrights to Commission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t17/s203"},"text":"Section 203 of title 17","children":[],"tail":" shall not apply to any copyright transferred in any manner to the Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id745c25d7-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/tVI/s603/a"},"text":"Pub. L. 106–117, title VI, § 603(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-30"},"text":"Nov. 30, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1579"},"text":"113 Stat. 1579","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
