{"tag":"section","attrib":{"id":"id74bb83a5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220703"},"text":null,"children":[{"tag":"num","attrib":{"value":"220703"},"text":"§ 220703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are as provided in its articles of incorporation and include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74bb83a6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220703/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserving and promoting patriotism and loyalty to the United States of America;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb83a7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220703/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perpetuating and establishing memorials to the memory of shipmates who served aboard United States submarines and gave their lives in submarine warfare during World War II;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb83a8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220703/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting the spirit and unity that existed among the United States Navy submarine crewmen during World War II;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb83a9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220703/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fostering general public awareness of life aboard submarines during World War II, through securing, restoring, and displaying the submarines that were in service at that time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb83aa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220703/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsoring annual college scholarships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb83ab-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220703/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing acts of charity as provided in the constitution and bylaws of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74bb83ac-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1479"},"text":"112 Stat. 1479","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74bb83ad-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74bb83ae-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74bb83af-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"