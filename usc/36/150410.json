{"tag":"section","attrib":{"id":"id74955e90-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150410"},"text":null,"children":[{"tag":"num","attrib":{"value":"150410"},"text":"§ 150410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty to maintain tax-exempt status","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation shall maintain its status as an organization exempt from taxation under the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id74955e91-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLI/s5103/a"},"text":"Pub. L. 118–31, div. E, title LI, § 5103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/937"},"text":"137 Stat. 937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74955e92-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74955e93-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id74955e94-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Internal Revenue Code of 1986, referred to in text, is classified to Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
