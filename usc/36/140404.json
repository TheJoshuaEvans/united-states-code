{"tag":"section","attrib":{"id":"id7492ed06-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140404"},"text":null,"children":[{"tag":"num","attrib":{"value":"140404"},"text":"§ 140404.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7492ed07-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140404/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board of Directors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The composition of the board of directors of the corporation, and the responsibilities of the board, are as provided in the articles of incorporation and bylaws of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7492ed08-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140404/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The positions of officers of the corporation, and the election of the officers, are as provided in the articles of incorporation and bylaws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7492ed09-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/95/s1/a"},"text":"Pub. L. 111–95, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-06"},"text":"Nov. 6, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3002"},"text":"123 Stat. 3002","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
