{"tag":"section","attrib":{"id":"id748bc109-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90107"},"text":null,"children":[{"tag":"num","attrib":{"value":"90107"},"text":"§ 90107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The foundation shall have a designated agent to receive service of process for the foundation. Notice to or service on the agent, or mailed to the business address of the agent, is notice to or service on the foundation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id748bc10a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tVI/s601/a"},"text":"Pub. L. 107–252, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1721"},"text":"116 Stat. 1721","children":[],"tail":", § 152607; renumbered § 90107, "},{"tag":"ref","attrib":{"href":"/us/pl/113/237/s3/c/6/B"},"text":"Pub. L. 113–237, § 3(c)(6)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2840"},"text":"128 Stat. 2840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id748bc10b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id748bc10c-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id748bc10d-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib