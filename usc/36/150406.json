{"tag":"section","attrib":{"id":"id74955e7c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150406"},"text":null,"children":[{"tag":"num","attrib":{"value":"150406"},"text":"§ 150406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In establishing the conditions of membership in the corporation, and in determining the requirements for serving on the board of directors or as an officer of the corporation, the corporation may not discriminate on the basis of race, color, religion, sex, national origin, handicap, or age.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id74955e7d-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLI/s5103/a"},"text":"Pub. L. 118–31, div. E, title LI, § 5103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/936"},"text":"137 Stat. 936","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
