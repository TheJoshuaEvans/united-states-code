{"tag":"section","attrib":{"id":"id74b4582d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509"},"text":null,"children":[{"tag":"num","attrib":{"value":"220509"},"text":"§ 220509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resolution of disputes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74b4582e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall establish and maintain provisions in its constitution and bylaws for the swift and equitable resolution of disputes involving any of its members and relating to complaints of retaliation or the opportunity of an amateur athlete, coach, trainer, manager, administrator, or official to participate in the Olympic Games, the Paralympic Games, the Pan-American Games, the Parapan American Games, world championship competition, or other protected competition as defined in the constitution and bylaws of the corporation. In any lawsuit relating to the resolution of a dispute involving the opportunity of an amateur athlete to participate in the Olympic Games, the Paralympic Games, the Pan-American Games, or the Parapan American Games, a court shall not grant injunctive relief against the corporation within 21 days before the beginning of such games if the corporation, after consultation with the chair of the Athletes’ Advisory Council, has provided a sworn statement in writing executed by an officer of the corporation to such court that its constitution and bylaws cannot provide for the resolution of such dispute prior to the beginning of such games.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b4582f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Office of the Athlete Ombuds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b45830-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall hire and provide salary, benefits, and administrative expenses for an ombudsman and support staff for athletes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b45831-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of the Athlete Ombuds shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74b45832-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide independent advice to athletes at no cost about the applicable provisions of this chapter and the constitution and bylaws of the corporation, national governing bodies, international sports federations, the International Olympic Committee, the International Paralympic Committee, and the Pan-American Sports Organization, and with respect to the resolution of any dispute involving the opportunity of an amateur athlete to participate in the Olympic Games, the Paralympic Games, the Pan-American Games, the Parapan American Games, world championship competition or other protected competition as defined in the constitution and bylaws of the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45833-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the resolution of athlete concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45834-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide independent advice to athletes with respect to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74b45835-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the role, responsibility, authority, and jurisdiction of the Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b45836-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relative value of engaging legal counsel; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45837-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Athletes’ Advisory Council on a regular basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b45838-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hiring procedures; vacancy; termination.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74b45839-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hiring procedures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The procedure for hiring the ombudsman for athletes shall be as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74b4583a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Athletes’ Advisory Council shall provide the corporation’s executive director with the name of 1 qualified person to serve as ombudsman for athletes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b4583b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The corporation’s executive director shall immediately transmit the name of such person to the corporation’s executive committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b4583c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The corporation’s executive committee shall hire or not hire such person after fully considering the advice and counsel of the Athletes’ Advisory Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b4583d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If there is a vacancy in the position of the ombudsman for athletes, the nomination and hiring procedure set forth in this paragraph shall be followed in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b4583e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation may terminate the employment of an individual serving as ombudsman for athletes only if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74b4583f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination is carried out in accordance with the applicable policies and procedures of the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b45840-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination is initially recommended to the corporation’s executive committee by either the corporation’s executive director or by the Athletes’ Advisory Council; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b45841-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the corporation’s executive committee fully considers the advice and counsel of the Athletes’ Advisory Council prior to deciding whether or not to terminate the employment of such individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b45842-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Confidentiality.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74b45843-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of the Athlete Ombuds shall maintain as confidential any information communicated or provided to the Office of the Athlete Ombuds in confidence in any matter involving the exercise of the official duties of the Office of the Athlete Ombuds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45844-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of the Athlete Ombuds may disclose information described in subparagraph (A) as necessary to resolve or mediate a dispute, with the permission of the parties involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45845-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judicial and administrative proceedings.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id74b45846-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The ombudsman and the staff of the Office of the Athlete Ombuds shall not be compelled to testify or produce evidence in any judicial or administrative proceeding with respect to any matter involving the exercise of the duties of the Office of the Athlete Ombuds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b45847-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Work product","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any memorandum, work product, notes, or case file of the Office of the Athlete Ombuds—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id74b45848-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/C/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be confidential; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id74b45849-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/C/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not be—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id74b4584a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/C/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to discovery, subpoena, or any other means of legal compulsion; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id74b4584b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/C/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" admissible as evidence in a judicial or administrative proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b4584c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The confidentiality requirements under this paragraph shall not apply to information relating to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74b4584d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applicable federally mandated reporting requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b4584e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a felony personally witnessed by a member of the Office of the Athlete Ombuds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b4584f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a situation, communicated to the Office of the Athlete Ombuds, in which an individual is at imminent risk of serious harm; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b45850-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a congressional subpoena.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45851-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of policy.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id74b45852-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of the enactment of the Empowering Olympic, Paralympic, and Amateur Athletes Act of 2020, the Office of the Athlete Ombuds shall develop and publish in the Federal Register a confidentiality and privacy policy consistent with this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b45853-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of the Athlete Ombuds shall distribute a copy of the policy developed under clause (i) to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id74b45854-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/E/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees of the national governing bodies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id74b45855-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/E/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b45856-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication by national governing bodies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each national governing body shall—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id74b45857-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/E/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the policy developed under clause (i) on the internet website of the national governing body; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id74b45858-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/4/E/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicate to amateur athletes the availability of the policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b45859-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on retaliation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No employee, contractor, agent, volunteer, or member of the corporation shall take or threaten to take any action against an athlete as a reprisal for disclosing information to or seeking assistance from the Office of the Athlete Ombuds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b4585a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independence in carrying out duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The board of directors of the corporation or any other member or employee of the corporation shall not prevent or prohibit the Office of the Athlete Ombuds from carrying out any duty or responsibility under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b4585b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retaliation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b4585c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation, the national governing bodies, or any officer, employee, contractor, subcontractor, or agent of the corporation or a national governing body may not retaliate against any protected individual as a result of any communication, including the filing of a formal complaint, by a protected individual or a parent or legal guardian of the protected individual relating to an allegation of physical abuse, sexual harassment, or emotional abuse.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b4585d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disciplinary action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the corporation finds that an employee of the corporation or a national governing body has retaliated against a protected individual, the corporation or national governing body, as applicable, shall immediately terminate the employment of, or suspend without pay, such employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b4585e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Damages.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74b4585f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to a protected individual the corporation finds to have been subject to retaliation, the corporation may award damages, including damages for pain and suffering and reasonable attorney fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45860-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220509/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement from national governing body","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a national governing body found to have retaliated against a protected individual, the corporation may demand reimbursement from the national governing body for damages paid by the corporation under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74b45861-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1470"},"text":"112 Stat. 1470","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s142/h"},"text":"Pub. L. 105–277, div. C, title I, § 142(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-605"},"text":"112 Stat. 2681–605","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s5/17"},"text":"Pub. L. 109–284, § 5(17)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1212"},"text":"120 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/189"},"text":"Pub. L. 116–189","children":[],"tail":", §§ 4(a)(7), 6(e), "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/945"},"text":"134 Stat. 945","children":[],"tail":", 950.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74b45862-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74b45863-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74b45864-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220509","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:382b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-21/ch975"},"text":"Sept. 21, 1950, ch. 975","children":[],"tail":", title I, § 114, as added "},{"tag":"html:span","attrib":{},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/606/s1/b"},"text":"Pub. L. 95–606, § 1(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/3049"},"text":"92 Stat. 3049","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74b45865-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id74b45866-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Empowering Olympic, Paralympic, and Amateur Athletes Act of 2020, referred to in subsec. (b)(4)(E)(i), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189"},"text":"Pub. L. 116–189","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74b45867-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189"},"text":"Pub. L. 116–189","children":[],"tail":", §§ 4(a)(7), 6(e)(1), in first sentence, inserted “complaints of retaliation or” after “relating to” and “the Parapan American Games,” after “the Pan-American Games,” and, in second sentence, substituted “the Pan-American Games, or the Parapan American Games” for “or the Pan-American Games”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s6/e/2"},"text":"Pub. L. 116–189, § 6(e)(2)","children":[],"tail":", amended subsec. (b) generally. Prior to amendment, subsec. (b) provided for an ombudsman for athletes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s6/e/3"},"text":"Pub. L. 116–189, § 6(e)(3)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284"},"text":"Pub. L. 109–284","children":[],"tail":" struck out “a” before “paralympic sports organizations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/h/1"},"text":"Pub. L. 105–277, § 142(h)(1)","children":[],"tail":", designated existing provisions as subsec. (a), and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/h/2"},"text":"Pub. L. 105–277, § 142(h)(2)","children":[],"tail":", inserted “the Paralympic Games,” before “the Pan-American Games”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/h/3"},"text":"Pub. L. 105–277, § 142(h)(3)","children":[],"tail":", inserted at end “In any lawsuit relating to the resolution of a dispute involving the opportunity of an amateur athlete to participate in the Olympic Games, the Paralympic Games, or the Pan-American Games, a court shall not grant injunctive relief against the corporation within 21 days before the beginning of such games if the corporation, after consultation with the chair of the Athletes’ Advisory Council, has provided a sworn statement in writing executed by an officer of the corporation to such court that its constitution and bylaws cannot provide for the resolution of such dispute prior to the beginning of such games.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/h/4"},"text":"Pub. L. 105–277, § 142(h)(4)","children":[],"tail":", added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
