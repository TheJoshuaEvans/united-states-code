{"tag":"section","attrib":{"id":"id74894fa9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70907"},"text":null,"children":[{"tag":"num","attrib":{"value":"70907"},"text":"§ 70907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive right to name,","children":[{"tag":"ref","attrib":{"idref":"fn002010"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002010"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “names”."}],"tail":" seals, emblems, and badges"}],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The FFA and its authorized chapters and associations of chapters have the exclusive right to use the names “Future Farmers of America” and “National FFA Organization,” ","children":[{"tag":"ref","attrib":{"idref":"fn002011"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002011"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. The comma preceding the closing quotation marks probably should not appear."}],"tail":" and the initials FFA as representing an agricultural education membership organization and seals, emblems, and badges the FFA adopts."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id74894faa-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1358"},"text":"112 Stat. 1358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/7/s8"},"text":"Pub. L. 116–7, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-21"},"text":"Feb. 21, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":