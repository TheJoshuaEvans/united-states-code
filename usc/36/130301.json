:"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"130301(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:631 (related to place of incorporation and domicile).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"130301(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:631 (related to perpetual succession).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"36:634(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"130301(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:648.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"June 21, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/56/s1"},"text":"Pub. L. 87–56, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/95"},"text":"75 Stat. 95","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section is substituted for the source provisions for consistency in the revised title and to eliminate executed and unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the text of 36:632 is omitted as executed and obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “The corporation known as the Army and Navy Legion of Valor of the United States of America, Incorporated, which was incorporated by the Act entitled ‘An Act to Incorporate the Army and Navy Legion of Valor of the United States of America’, approved ","children":[{"tag":"date","attrib":{"date":"1955-08-04"},"text":"August 4, 1955","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/69/486"},"text":"69 Stat. 486","children":[],"tail":"), shall be known and designated on and after "},{"tag":"date","attrib":{"date":"1961-06-21"},"text":"June 21, 1961","children":[],"tail":" as the Legion of Valor of the United States of America, Incorporated, and” are omitted as executed. The words “such corporation under the name of” and “such corporation under and by the name of” are omitted as unnecessary. The words “is deemed” are substituted for “shall be held” for consistency in the revised title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
