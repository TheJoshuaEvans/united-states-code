{"tag":"section","attrib":{"id":"id74907bd6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130302"},"text":null,"children":[{"tag":"num","attrib":{"value":"130302"},"text":"§ 130302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principles and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74907bd7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Principles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The principles underlying the corporation are patriotic allegiance to the United States of America, fidelity to the constitution and laws of the United States, the security of civil liberty, and the permanence of free institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74907bd8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74907bd9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cherish the memories of the valiant deeds in arms for which the Congressional Medal of Honor, the Distinguished Service Cross, the Navy Cross, and the Air Force Cross are the insignia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74907bda-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote true fellowship among its members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74907bdb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130302/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance the best interests of members of the Armed Forces of the United States of America;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74907bdc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130302/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to extend all possible relief to needy members of the corporation and their widows and children; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74907bdd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130302/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to stimulate patriotism in the minds of our youth by encouraging the study of the patriotic, military, and naval history of our Nation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74907bde-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1374"},"text":"112 Stat. 1374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74907bdf-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74907be0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74907be1-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"130302","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:633.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1955-08-04/ch546/s3"},"text":"Aug. 4, 1955, ch. 546, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/69/487"},"text":"69 Stat. 487","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 21, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/56/s2"},"text":"Pub. L. 87–56, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/95"},"text":"75 Stat. 95","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “purposes” is substituted for “objects” for consistency in the revised title. The words “Navy Cross” are restated before “Air Force Cross” in accordance with the order preferred by the Legion of Valor of the United States of America, Incorporated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
