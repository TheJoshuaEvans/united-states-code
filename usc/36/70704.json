l":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:4404 (4th sentence related to adopting and altering seal).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70704(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:4404 (last sentence related to employment authority).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70704(4)–(6)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:4402 (words before last semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (1) is substituted for “by-laws which may be established for the government of said association” for clarity and consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (2) is substituted for “adopt a common seal, which they may alter at pleasure” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (3) is substituted for “such agents and employees as it may be deemed necessary to employ” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (4) is substituted for “be competent at law and in equity to take to themselves and their successors, for the use and behoof of said association, any estate whatsoever, in any messuage, lands, tenements, hereditaments, goods, chattels, moneys, and other effects, by gift, devise, grant, donation, bargain sale, conveyance, assurance, or will; and the same to grant, bargain, sell, transfer, assign, convey, assure, demise, declare to use, and farm let, and to place out on interest, for the use of said association, in such manner as to them, or a majority of them, shall be deemed most beneficial to said association; and to receive the same, their rents, issues, and profits, income, and interest, and to apply the same for the proper use and benefit of said association for the objects and purposes hereinbefore mentioned” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (5) is substituted for “and by the same name to sue and be sued, to implead and be impleaded in any court of law or equity in all manner of suits, actions, and proceedings whatsoever” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (6) is substituted for “and generally by and in the same name to do and transact all and every the business touching or concerning the premises” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
