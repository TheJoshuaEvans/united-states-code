{"tag":"section","attrib":{"id":"id747182f2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s30106"},"text":null,"children":[{"tag":"num","attrib":{"value":"30106"},"text":"§ 30106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive right to names, seals, emblems, and badges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation and its subordinate divisions have the exclusive right to use the names “The Big Brothers of America, Big Sisters International, Incorporated”, “Big Sisters of America”, “Big Brothers”, “Big Sisters”, “Big Brothers—Big Sisters of America”, and “Big Sisters—Big Brothers”, and to use and to allow others to use seals, emblems, and badges the corporation adopts.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id747182f3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1315"},"text":"112 Stat. 1315","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id747182f4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id747182f5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id747182f6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30106","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:895.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/870/s15"},"text":"Pub. L. 85–870, § 15","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/1694"},"text":"72 Stat. 1694","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 11, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/167/s1/e"},"text":"Pub. L. 95–167, § 1(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1347"},"text":"91 Stat. 1347","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “sole” is omitted as included in “exclusive”. The words “or refuse” are omitted as unnecessary. The words “the corporation adopts” are substituted for “as have heretofore been used by the predecessor New York corporation, Big Brothers of America, Incorporated, described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s896/a"},"text":"section 896(a) of this title","children":[],"tail":", and by the District of Columbia corporation, Big Sisters International, Incorporated, described in "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s896/b"},"text":"section 896(b) of this title","children":[],"tail":", and the right to which may be transferred to the corporation” for consistency in the revised title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
