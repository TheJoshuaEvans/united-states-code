{"tag":"section","attrib":{"id":"id744912b1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s104"},"text":null,"children":[{"tag":"num","attrib":{"value":"104"},"text":"§ 104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carl Garner Federal Lands Cleanup Day","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id744912b2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The first Saturday after Labor Day is Carl Garner Federal Lands Cleanup Day.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id744912b3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proclamation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall issue a proclamation calling on the people of the United States to observe Carl Garner Federal Lands Cleanup Day with appropriate programs, ceremonies, and activities. However, activities may be undertaken in individual States on a day other than the first Saturday after Labor Day if a manager of Federal land decides that an alternative date is more appropriate because of climatological or other factors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id744912b4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attr