{"tag":"section","attrib":{"id":"id749a18e1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151104"},"text":null,"children":[{"tag":"num","attrib":{"value":"151104"},"text":"§ 151104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id749a18e2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The officers of the corporation are a president, one or more vice presidents, a secretary, a treasurer, and the members of a board of directors, an executive committee, and any other boards, councils, and committees, and other officers, as provided in the bylaws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749a18e3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this chapter, the manner of selection, term of office, powers, and duties of the officers, boards, councils, and committees are as provided in the bylaws. The bylaws may provide other and different provisions as to the names and numbers of the officers, boards, councils, and committees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749a18e4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1398"},"text":"112 Stat. 1398","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749a18e5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id749a18e6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id749a18e7-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"151104","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:5302 (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1906-06-30/ch3929/s2"},"text":"June 30, 1906, ch. 3929, § 2","children":[],"tail":" (last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/34/805"},"text":"34 Stat. 805","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:5306.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1906-06-30/ch3929/s6"},"text":"June 30, 1906, ch. 3929, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/805"},"text":"34 Stat. 805","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1937-06-14/ch336/s2"},"text":"June 14, 1937, ch. 336, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/50/257"},"text":"50 Stat. 257","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 30, 1969","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/37/s1/b"},"text":"Pub. L. 91–37, § 1(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/83/43"},"text":"83 Stat. 43","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the text of 36:5302 (last sentence) is omitted as unnecessary and obsolete because it includes authority to change or abolish the departments specified in that provision.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “and the members of” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “manner of selection” are substituted for “manner of election or appointment” for consistency in the revised title and to eliminate unnecessary words. The words “are as provided in the bylaws” are substituted for “the bylaws of the corporation shall prescribe” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
