{"tag":"section","attrib":{"id":"id747b1f6e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40727"},"text":null,"children":[{"tag":"num","attrib":{"value":"40727"},"text":"§ 40727.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Army support","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id747b1f6f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40727/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Logistical Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army shall provide logistical support to the Civilian Marksmanship Program for competitions and other activities. The corporation shall reimburse the Secretary for incremental direct costs incurred in providing logistical support. The reimbursements shall be credited to the appropriations account of the Department of the Army that is charged to provide the logistical support.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f70-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40727/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Matches","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1f71-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40727/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Matches may be held at Department of Defense facilities where the National Matches were held before ","children":[{"tag":"date","attrib":{"date":"1996-02-10"},"text":"February 10, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f72-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40727/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall provide, without cost to the corporation, members of the National Guard and Army Reserve to support the National Matches as part of the annual training under title 10 and title 32.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f73-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40727/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id747b1f74-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1338"},"text":"112 Stat. 1338","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id747b1f75-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id747b1f76-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id747b1f77-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","at