{"tag":"section","attrib":{"id":"id74c2afbf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300105"},"text":null,"children":[{"tag":"num","attrib":{"value":"300105"},"text":"§ 300105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74c2afc0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74c2afc1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt policies and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74c2afc2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt, alter, and destroy a seal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74c2afc3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300105/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" own and dispose of property to carry out the purposes of the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74c2afc4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300105/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept gifts, devises, and bequests of property to carry out the purposes of the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74c2afc5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300105/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sue and be sued in courts of law and equity, State or Federal, within the jurisdiction of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74c2afc6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300105/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do any other act necessary to carry out this chapter and promote the purposes of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74c2afc7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation is designated as the organization authorized to act in matters of relief under the treaties of Geneva, ","children":[{"tag":"date","attrib":{"date":"1864-08-22"},"text":"August 22, 1864","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1929-07-27"},"text":"July 27, 1929","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1949-08-12"},"text":"August 12, 1949","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74c2afc8-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail