xt":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"300105","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:2 (1st sentence words between 2d comma and 3d semicolon and after 4th semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1905-01-05/ch23/s2"},"text":"Jan. 5, 1905, ch. 23, § 2","children":[],"tail":" (1st sentence words between 2d comma and 3d semicolon and after 4th semicolon), "},{"tag":"html:a","attrib":{"href":"/us/stat/33/600"},"text":"33 Stat. 600","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1947-05-08/ch50/s3"},"text":"May 8, 1947, ch. 50, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/81"},"text":"61 Stat. 81","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the word “adopt” is substituted for “ordain and establish” for consistency in the revised title. The words “not inconsistent with the laws of the United States of America or any State thereof” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “adopt, alter, and destroy a seal” are substituted for “adopt a seal and the same to alter and destroy at pleasure” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “own and dispose of property” are substituted for “to have and to hold such real and personal estate as shall be deemed advisable and to dispose of the same” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(4), the word “property” is substituted for “real and personal estate” for clarity and consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(6), the word “things” is omitted as included in “act”. The words “carry out this chapter” are substituted for “carry into effect the provisions of sections 1, 2 to 6, 8, and 9 of this title” for clarity and because under 36:1a the corporation existing under those sections continued under the source provisions restated in the revised chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “treaties of Geneva, ","children":[{"tag":"date","attrib":{"date":"1864-08-22"},"text":"August 22, 1864","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1929-07-27"},"text":"July 27, 1929","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1949-08-12"},"text":"August 12, 1949","children":[],"tail":"” are substituted for “said treaties” for clarity and consistency in the chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74c2afcc-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74c2afcd-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/26"},"text":"Pub. L. 110–26","children":[],"tail":" substituted “policies” for “bylaws”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
