{"tag":"section","attrib":{"id":"id74a60082-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154109"},"text":null,"children":[{"tag":"num","attrib":{"value":"154109"},"text":"§ 154109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and inspection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74a60083-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation shall keep—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74a60084-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154109/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correct and complete records of account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a60085-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154109/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minutes of the proceedings of its members, board of directors, and committees having any of the authority of its board of directors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a60086-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154109/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at its principal office, a record of the names and addresses of its members entitled to vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74a60087-3a70-11f1-9d9e-dfac6d46cab7"