{"tag":"section","attrib":{"id":"id749a190f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151301"},"text":null,"children":[{"tag":"num","attrib":{"value":"151301"},"text":"§ 151301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id749a1910-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"National Fallen Firefighters Foundation (in this chapter, the “corporation”) is a federally chartered corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749a1911-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nature of Corporation and Place of Incorporation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation is a charitable and nonprofit corporation incorporated under the laws of Maryland and is not an agency or establishment of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749a1912-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Perpetual Existence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided, the corporation has perpetual existence.","children":[],"tail":"\n"}],"tail