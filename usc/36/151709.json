},"text":"151709","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:5706(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/104/285/tII/s207/c"},"text":"Pub. L. 104–285, title II, § 207(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/110/3385"},"text":"110 Stat. 3385","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Before clause (1), the words “bring a civil action” are substituted for “file a petition” for consistency in the revised title and with other titles of the United States Code. The words “appropriate equitable relief” are substituted for “such equitable relief as may be necessary or appropriate” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
