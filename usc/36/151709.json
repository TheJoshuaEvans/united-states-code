{"tag":"section","attrib":{"id":"id749c8a4d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151709"},"text":null,"children":[{"tag":"num","attrib":{"value":"151709"},"text":"§ 151709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action by Attorney General for equitable relief","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General may bring a civil action in the United States District Court for the District of Columbia for appropriate equitable relief if the corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749c8a4e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151709/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages or threatens to engage in any act, practice, or policy that is inconsistent with the purposes in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s151702"},"text":"section 151702 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749c8a4f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151709/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuses, fails, or neglects to carry out its obligations under this chapter or threatens to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749c8a50-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1407"},"text":"112 Stat. 1407","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749c8a51-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","childr