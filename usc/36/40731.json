{"tag":"section","attrib":{"id":"id747d68cf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40731"},"text":null,"children":[{"tag":"num","attrib":{"value":"40731"},"text":"§ 40731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Issuance or loan of firearms and supplies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id747d68d0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40731/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance or Loan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of training and competition, the corporation may issue or loan, with or without charges to recover administrative costs, caliber .22 rimfire and caliber .30 surplus rifles, air rifles, caliber .22 and .30 ammunition, repair parts, and other supplies necessary for activities related to the Civilian Marksmanship Program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id747d68d1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40731/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizations affiliated with the corporation that provide firearms training to youth;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747d68d2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40731/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Boy Scouts of America;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747d68d3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40731/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4–H Clubs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747d68d4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40731/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Future Farmers of America; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747d68d5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40731/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other youth oriented organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747d68d6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40731/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security of Firearms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall ensure adequate oversight and accountability for firearms issued or loaned under this section. The corporation shall prescribe procedures for the security of issued or loaned firearms in accordance with United States, State, and local laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id747d68d7-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1340"},"text":"112 Stat. 1340","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id747d68d8-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{