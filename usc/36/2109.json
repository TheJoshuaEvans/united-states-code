{"tag":"section","attrib":{"id":"id7459b479-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2109"},"text":null,"children":[{"tag":"num","attrib":{"value":"2109"},"text":"§ 2109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Currency Fluctuations Account","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7459b47a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is an account in the Treasury known as the “Foreign Currency Fluctuations, American Battle Monuments Commission, Account”. The Account shall be used to provide amounts, in addition to amounts appropriated for salaries and expenses of the Commission, to pay the cost of salaries and expenses that exceeds the amount appropriated for salaries and expenses because of fluctuations in currency exchange rates of foreign countries occurring after a budget request for the Commission is submitted to Congress. The Account may not be used for any other purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7459b47b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Increase in Permissible Obligations of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A provision of law limiting the amounts the Commission may obligate in a fiscal year shall be increased to the extent necessary to reflect fluctuations in exchange rates from those used in preparing the budget submission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7459b47c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transferred Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7459b47d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2109/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the Account may be transferred to amounts appropriated for salaries and expenses of the Commission. Transferred amounts shall be merged with, and are available for the same time period as, the appropriation to which they are applied.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7459b47e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2109/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amounts transferred from the Account may be transferred back—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7459b47f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2109/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the amounts are not needed to pay obligations incurred because of fluctuations in currency exchange rates of foreign countries in the appropriation to which the amounts were originally transferred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7459b480-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2109/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of subsequent favorable fluctuations in the rates or because other amounts are, or become, available to pay the obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7459b481-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2109/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts transferred to an appropriation under this subsection may not be transferred back to the Account after the end of the 2d fiscal year after the fiscal year in which the appropriation was available for obligation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7459b482-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recording of Obligations and Fluctuations in Exchange Rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An obligation of the Commission payable in the currency of a foreign country may be recorded as an obligation based on exchange rates used in preparing a budget submission. A change reflecting fluctuations in exchange rates may be recorded as a disbursement is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7459b483-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2109/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unobligated Balances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The unobligated balance of an appropriation for salaries and expenses may be transferred to the Account not later than the end of the second fiscal year following the fiscal year for which the appropriation was made. The unobligated balance shall be merged with, and be available for the same period and purposes as, the Account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7459b484-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2109/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission each year shall submit to the appropriate committees of Congress a report on amounts transferred under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7459b485-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2109/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated $3,000,000 to the Account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7459b486-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1275"},"text":"112 Stat. 1275","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7459b487-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7459b488-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"ht