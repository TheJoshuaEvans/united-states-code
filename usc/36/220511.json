{"tag":"section","attrib":{"id":"id74b4586f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511"},"text":null,"children":[{"tag":"num","attrib":{"value":"220511"},"text":"§ 220511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74b45870-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b45871-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission to president and congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than annually, the corporation shall submit simultaneously to the President and to each House of Congress a detailed report on the operations of the corporation for the preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b45872-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters to be included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report required by paragraph (1) shall include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74b45873-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A comprehensive description of the activities and accomplishments of the corporation during such calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45874-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Data concerning the participation of women, disabled individuals, and racial and ethnic minorities in the amateur athletic activities and administration of the corporation and national governing bodies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45875-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the steps taken to encourage the participation of women, disabled individuals, and racial minorities in amateur athletic activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45876-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of any lawsuit or grievance filed against the corporation, including any dispute initiated under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45877-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The agenda and minutes of any meeting of the board of directors of the corporation that occurred during such calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45878-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A report by the compliance committee of the corporation that, with respect to such calendar year—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74b45879-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifies—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id74b4587a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/2/F/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the areas in which the corporation has met compliance standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id74b4587b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/2/F/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the areas in which the corporation has not met compliance standards; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b4587c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assesses the compliance of each member of the corporation and provides a plan for improvement, as necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b4587d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed description of any complaint of retaliation made during such calendar year, including the entity involved, the number of allegations of retaliation, and the outcome of such allegations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b4587e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall make each report under this subsection available to the public on an easily accessible internet website of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b4587f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Audit.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b45880-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than annually, the financial statements of the corporation for the preceding fiscal year shall be audited in accordance with generally accepted auditing standards by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74b45881-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independent certified public accountant; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45882-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independent licensed public accountant who is certified or licensed by the regulatory authority of a State or a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b45883-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An audit under paragraph (1) shall be conducted at the location at which the financial statements of the corporation normally are kept.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b45884-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual conducting an audit under paragraph (1) shall be given full access to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74b45885-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all records and property owned or used by the corporation, as necessary to facilitate the audit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45886-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any facility under audit for the purpose of verifying transactions, including any balance or security held by a depository, fiscal agent, or custodian.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b45887-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74b45888-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the end of the fiscal year for which an audit is carried out, the auditor shall submit a report on the audit to the Committee on Commerce, Science, and Transportation of the Senate, the Committee on the Judiciary of the House of Representatives, and the chair of the Athletes’ Advisory Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45889-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters to be included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each report under subparagraph (A) shall include the following for the applicable fiscal year:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74b4588a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any statement necessary to present fairly the assets, liabilities, and surplus or deficit of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b4588b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An analysis of the changes in the amounts of such assets, liabilities, and surplus or deficit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b4588c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed statement of the income and expenses of the corporation, including the results of any trading, manufacturing, publishing, or other commercial endeavor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b4588d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed statement of the amounts spent on stipends and services for athletes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b4588e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed statement of the amounts spent on compensation and services for executives and administration officials of the corporation, including the 20 employees of the corporation who receive the highest amounts of compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b4588f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A detailed statement of the amounts allocated to the national governing bodies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b45890-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/B/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such comments and information as the auditor considers necessary to inform Congress of the financial operations and condition of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b45891-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/B/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recommendations relating to the financial operations and condition of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b45892-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/B/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A description of any financial conflict of interest (including a description of any recusal or other mitigating action taken), evaluated in a manner consistent with the policies of the corporation, of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id74b45893-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/B/ix/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the board of directors of the corporation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id74b45894-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/B/ix/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any senior management personnel of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b45895-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public availability.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id74b45896-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall make each report under this paragraph available to the public on an easily accessible internet website of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74b45897-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220511/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personally identifiable information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A report made available under clause (i) shall not include the personally identifiable information of any individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74b45898-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1471"},"text":"112 Stat. 1471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s142/j/1"},"text":"Pub. L. 105–277, div. C, title I, § 142(j)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-606"},"text":"112 Stat. 2681–606","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s5/18"},"text":"Pub. L. 109–284, § 5(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1212"},"text":"120 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/189/s6/f/1"},"text":"Pub. L. 116–189, § 6(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/953"},"text":"134 Stat. 953","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type"