{"tag":"section","attrib":{"id":"id746f37f2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22709"},"text":null,"children":[{"tag":"num","attrib":{"value":"22709"},"text":"§ 22709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and inspection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746f37f3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation shall keep—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746f37f4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correct and complete records of account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746f37f5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minutes of the proceedings of its members, executive committee, and committees having any of the authority of its executive committee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746f37f6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22709/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at its registered or principal office, a record of the names and addresses of its members entitled to vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746f37f7-3a70-11f1-9d9e-dfac