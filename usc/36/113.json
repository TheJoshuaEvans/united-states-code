{"tag":"section","attrib":{"id":"id744912fc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s113"},"text":null,"children":[{"tag":"num","attrib":{"value":"113"},"text":"§ 113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Law Day, U.S.A.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id744912fd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"May 1 is Law Day, U.S.A.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id744912fe-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Law Day, U.S.A., is a special day of celebration by the people of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id744912ff-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in appreciation of their liberties and the reaffirmation of their loyalty to the United States and of their rededication to the ideals of equality and justice under law in their relations with each other and with other countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74491300-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for the cultivation of the respect for law that is so vital to the democratic way of life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74491301-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proclamation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President is requested to issue a proclamation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74491302-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s113/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" calling on all public officials to display the flag of the United States on all Government buildings on Law Day, U.S.A.; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74491303-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s113/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inviting the people of the United States to observe Law Day, U.S.A., with appropriate ceremonies and in other appropriate ways, through public entities and private organizations and in schools and other suitable places.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74491304-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1257"},"text":"112 Stat. 1257","children":[],"tail":".)"}],"tail":"\n"},{