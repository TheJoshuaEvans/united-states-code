ren":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1936-05-28/ch471/s5"},"text":"May 28, 1936, ch. 471, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/49/1391"},"text":"49 Stat. 1391","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-05-29/ch85/s2"},"text":"May 29, 1953, ch. 85, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/40"},"text":"67 Stat. 40","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Mar. 7, 1995","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/104/3"},"text":"Pub. L. 104–3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/109/47"},"text":"109 Stat. 47","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “is eligible for membership . . . only if” are substituted for “may not be a member . . . unless” for consistency in the revised title. The words “served honorably as a member of the armed forces of the United States” are substituted for “served honorably as a member of the Armed Forces of the United States” and “while a member of the Armed Forces of the United States, served honorably” to eliminate unnecessary words. In clause (2), the words “at least” are substituted for “not less than” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74bdce02-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74bdce03-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"201