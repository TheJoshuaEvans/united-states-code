{"tag":"section","attrib":{"id":"id74bdcdf8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230103"},"text":null,"children":[{"tag":"num","attrib":{"value":"230103"},"text":"§ 230103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An individual is eligible for membership in the corporation only if the individual served honorably as a member of the Armed Forces of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74bdcdf9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in a foreign war, insurrection, or expedition in service that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74bdcdfa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230103/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been recognized as campaign-medal service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74bdcdfb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230103/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is governed by the authorization of the award of a campaign badge by the United States Government;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bdcdfc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the Korean peninsula or in its territorial waters for at least 30 consecutive days, or a total of 60 days, after ","children":[{"tag":"date","attrib":{"date":"1949-06-30"},"text":"June 30, 1949","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bdcdfd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230103/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an area which entitled the individual to receive special pay for duty subject to hostile fire or imminent danger under section 310 or 351 of title 37.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74bdcdfe-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1481"},"text":"112 Stat. 1481","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/242/s1/a"},"text":"Pub. L. 107–242, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-16"},"text":"Oct. 16, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1497"},"text":"116 Stat. 1497","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tVI/s618/g"},"text":"Pub. L. 114–328, div. A, title VI, § 618(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2160"},"text":"130 Stat. 2160","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74bdcdff-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74bdce00-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74bdce01-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html