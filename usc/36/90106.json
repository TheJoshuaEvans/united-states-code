{"tag":"section","attrib":{"id":"id748bc104-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90106"},"text":null,"children":[{"tag":"num","attrib":{"value":"90106"},"text":"§ 90106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The principal office of the foundation shall be in the District of Columbia unless the board of directors determines otherwise. However, the foundation may conduct business throughout the States, territories, and possessions of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id748bc105-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tVI/s601/a"},"text":"Pub. L. 107–252, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1720"},"text":"116 Stat. 1720","children":[],"tail":", § 152606; renumbered § 90106, "},{"tag":"ref","attrib":{"href":"/us/pl/113/237/s3/c/6/B"},"text":"Pub. L. 113–237, § 3(c)(6)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2840"},"text":"128 Stat. 2840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id748bc106-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id748bc107-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id748bc108-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[