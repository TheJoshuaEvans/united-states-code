{"tag":"section","attrib":{"id":"id74aabacb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190107"},"text":null,"children":[{"tag":"num","attrib":{"value":"190107"},"text":"§ 190107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74aabacc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Profit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not engage in business for profit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74aabacd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stock","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not issue stock.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74aabace-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Political Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation or an officer or member as such may not contribute to, support, or assist a political party or candidate for public office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74aabacf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Income or Assets","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The income or assets of the corporation may not inure to the benefit of, or be distributed to, an officer or member except on dissolution or final liquidation of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74aabad0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190107/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not make a loan or advance to an officer or member of the national executive committee. Members of the national executive committee who vote for or assent to making a loan or advance to an officer, and officers who participate in making the loan or advance, are jointly and severally liable to the corporation for the amount of the loan or advance until it is repaid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74aabad1-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1448"},"text":"112 Stat. 1448","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74aabad2-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74aabad3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74aabad4-