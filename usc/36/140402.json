{"tag":"section","attrib":{"id":"id7492ecf6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140402"},"text":null,"children":[{"tag":"num","attrib":{"value":"140402"},"text":"§ 140402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are as provided in its bylaws and articles of incorporation and include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7492ecf7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to inculcate and stimulate love of the United States and the flag;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecf8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to defend the honor, integrity, and supremacy of the Constitution of the United States and the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecf9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140402/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advocate military forces adequate to the defense of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecfa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140402/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster the integrity and prestige of the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecfb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140402/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster fraternal relations between all branches of the various Armed Forces from which members are drawn;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecfc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140402/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to further the education of children of members of the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecfd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140402/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to aid members of the Armed Forces and their family members and survivors in every proper and legitimate manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecfe-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140402/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to present and support legislative proposals that provide for the fair and equitable treatment of members of the Armed Forces, including the National Guard and Reserves, military retirees, family members, survivors, and veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ecff-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140402/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage recruitment and appointment in the Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7492ed00-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/95/s1/a"},"text":"Pub. L. 111–95, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-06"},"text":"Nov. 6, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3001"},"text":"123 Stat. 3001","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/237/s3/c/4"},"text":"Pub. L. 113–237, § 3(c)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2840"},"text":"128 Stat. 2840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7492ed01-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7492ed02-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7492ed03-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/237"},"text":"Pub. L. 113–237","children":[],"tail":" struck out subsec. (a) designation and heading “"},{"tag":"inline","attrib":{},"text":"General","children":[],"tail":"” before “The purposes” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
