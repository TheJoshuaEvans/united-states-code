{"tag":"section","attrib":{"id":"id745c2606-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2304"},"text":null,"children":[{"tag":"num","attrib":{"value":"2304"},"text":"§ 2304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id745c2607-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Experts and Consultants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Museum may obtain the services of experts and consultants in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":", at rates not to exceed the daily equivalent of the annual rate of basic pay in effect for positions at level IV of the Executive Schedule under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id745c2608-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Museum may, in accordance with applicable law, enter into contracts and other arrangements with public agencies and with private organizations and persons and may make such payments as may be necessary to carry out its functions under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id745c2609-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance From Other Federal Departments and Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Smithsonian Institution, the Library of Congress, and the heads of all executive branch departments, agencies, and establishments of the United States may assist the Museum in the performance of its functions under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id745e6efa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Services and Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Interior may provide administrative services and support to the Museum on a reimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id745e6efb-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/292/s1"},"text":"Pub. L. 106–292, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-12"},"text":"Oct. 12, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1032"},"text":"114 Stat. 1032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id745e6efc-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id745e6efd-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id745e6efe-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2304, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1278"},"text":"112 Stat. 1278","children":[],"tail":", related to gifts, bequests, and devises of property to the Holocaust Memorial Council, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/292"},"text":"Pub. L. 106–292","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
