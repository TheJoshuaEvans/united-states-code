{"tag":"section","attrib":{"id":"id74a144dc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152502"},"text":null,"children":[{"tag":"num","attrib":{"value":"152502"},"text":"§ 152502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74a144dd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to further, encourage, and promote methods and procedures leading to increased safety, protection, and health among employees, employers, and children in industries, on farms, in schools and colleges, in homes, on streets and highways, in recreation, and in other public and private places;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a144de-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect, correlate, publish, and disseminate educational and informative reports and all other data related to safety methods and procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a144df-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152502/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to arouse and maintain the interest of the people of the United States and its territories and possessions in safety and accident prevention, and to encourage the adoption and institution of safety methods by all individuals, corporations, and other organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a144e0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152502/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to organize, establish, and conduct programs, lectures, conferences, and other activities for the education of all individuals, corporations, and other organizations in safety methods and procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a144e1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152502/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to organize and aid in organizing local safety chapters throughout the United States and its territories and possessions, and to provide organizational guidance and materials to promote the national safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a144e2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152502/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cooperate with, enlist, and develop the cooperation of and among all individuals, corporations, and other organizations and agencies, public and private, engaged in, interested in, or in any manner connected with, any of these purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a144e3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152502/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to do any lawful acts necessary, useful, suitable, desirable, and proper for the furtherance and accomplishment of any of these purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74a144e4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1415"},"text":"112 Stat. 1415","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74a144e5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74a144e6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74a144e7-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"152502","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:463.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1953-08-13/ch429/s3"},"text":"Aug. 13, 1953, ch. 429, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/569"},"text":"67 Stat. 569","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Before clause (1), the word “object” is omitted as included in “purposes”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the words “distribute” and “data” (the first time appearing) are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
