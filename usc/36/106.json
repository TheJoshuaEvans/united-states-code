{"tag":"section","attrib":{"id":"id744912bf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s106"},"text":null,"children":[{"tag":"num","attrib":{"value":"106"},"text":"§ 106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Constitution Day and Citizenship Day","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id744912c0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"September 17 is designated as Constitution Day and Citizenship Day.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id744912c1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Constitution Day and Citizenship Day commemorate the formation and signing on ","children":[{"tag":"date","attrib":{"date":"1787-09-17"},"text":"September 17, 1787","children":[],"tail":", of the Constitution and recognize all who, by coming of age or by naturalization, have become citizens."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id744912c2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proclamation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President may issue each year a proclamation calling on United States Government officials to display the flag of the United States on all Government buildings on Constitution Day and Citizenship Day and inviting the people of the United States to observe Constitution Day and Citizenship Day, in schools and churches, or other suitable places, with appropriate ceremonies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id744912c3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State and Local Observances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The civil and educational authorities of States, counties, cities, and towns are urged to make plans for the proper observance of Constitution Day and Citizenship Day and for the complete instruction of citizens in their responsibilities and opportunities as citizens of the United States and of the State and locality in which they reside.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id744912c4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1255"},"text":"112 Stat. 1255","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/447/dJ/tI/s111/c/1"},"text":"Pub. L. 108–447, div. J, title I, § 111(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3344"},"text":"118 Stat. 3344","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id744912c5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"no