{"tag":"section","attrib":{"id":"id746cc75b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22503"},"text":null,"children":[{"tag":"num","attrib":{"value":"22503"},"text":"§ 22503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Eligibility for membership in the corporation is limited to women—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746cc75c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22503/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who are citizens of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc75d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22503/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whose natural son or daughter, legally adopted son or daughter, or stepson or stepdaughter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id746cc75e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22503/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served in the Armed Forces of the United States or its allies in World War I, World War II, the Korean conflict, or any subsequent war or conflict involving the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id746cc75f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22503/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was honorably discharged from that service or continues in the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"s