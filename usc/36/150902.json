{"tag":"section","attrib":{"id":"id7497a870-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150902"},"text":null,"children":[{"tag":"num","attrib":{"value":"150902"},"text":"§ 150902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7497a871-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to collect, analyze, develop, and disseminate in the public interest information and recommendations about—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7497a872-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150902/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection against radiation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7497a873-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150902/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" radiation measurements, quantities, and units, particularly those concerned with protection against radiation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7497a874-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a means by which organizations concerned with the scientific and related aspects of protection against radiation and of radiation quantities, units, and measurements may cooperate for effective use of their combined resources, and to stimulate the work of those organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7497a875-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150902/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to develop basic concepts about—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7497a876-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150902/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" radiation quantities, units, and measurements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7497a877-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150902/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application of those concepts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7497a878-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150902/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection against radiation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7497a879-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150902/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cooperate with the International Commission on Radiological Protection, the Federal Radiation Council, the International Commission on Radiological Units and Measurements, and other national and international organizations, governmental and private, concerned with radiation quantities, units, and measurements and with protection against radiation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7497a87a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1395"},"text":"112 Stat. 1395","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7497a87b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7497a87c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id7497a87d-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"te