{"tag":"section","attrib":{"id":"id749ed4b4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152406"},"text":null,"children":[{"tag":"num","attrib":{"value":"152406"},"text":"§ 152406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principal office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The principal office of the corporation shall be in the District of Columbia or another place as determined by the Board of Directors. However, the corporation may conduct business throughout the States, territories, and possessions of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id749ed4b5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tII/s201/a"},"text":"Pub. L. 106–474, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2094"},"text":"114 Stat. 2094","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/336/s2/b/3/A"},"text":"Pub. L. 110–336, § 2(b)(3)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-02"},"text":"Oct. 2, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3727"},"text":"122 Stat. 3727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749ed4b6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id749ed4b7-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id749ed4b8-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/336"},"text":"Pub. L. 110–336","children":[],"tail":" substituted “District of Columbia or another place as determined by the Board of Directors” for “District of Columbia”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
