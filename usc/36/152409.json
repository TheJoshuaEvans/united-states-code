{"tag":"section","attrib":{"id":"id749ed4c1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152409"},"text":null,"children":[{"tag":"num","attrib":{"value":"152409"},"text":"§ 152409.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action by Attorney General for equitable relief","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General may bring a civil action in the United States District Court for the District of Columbia for appropriate equitable relief if the corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749ed4c2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152409/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages or threatens to engage in any act, practice, or policy that is inconsistent with the purposes in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s152402"},"text":"section 152402 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed4c3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152409/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuses, fails, or neglects to carry out its obligations under this chapter or threatens to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749ed4c4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tII/s201/a"},"text":"Pub. L. 106–474, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2094"},"text":"114 Stat. 2094","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
