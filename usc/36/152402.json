{"tag":"section","attrib":{"id":"id749ed475-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152402"},"text":null,"children":[{"tag":"num","attrib":{"value":"152402"},"text":"§ 152402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749ed476-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage, accept, and administer private gifts to promote and ensure the preservation and public accessibility of the nation’s sound recording heritage held at the Library of Congress and other public and nonprofit archives throughout the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed477-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further the goals of the Library of Congress and the National Recording Preservation Board in connection with their activities under the National Recording Preservation Act of 2000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749ed478-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tII/s201/a"},"text":"Pub. L. 106–474, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2092"},"text":"114 Stat. 2092","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749ed479-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id749ed47a-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id749ed47b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Recording Preservation Act of 2000, referred to in par. (2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474"},"text":"Pub. L. 106–474","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2085"},"text":"114 Stat. 2085","children":[],"tail":", which enacted this chapter and chapter 27 (§ 1701 et seq.) of Title 2, The Congress. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1701"},"text":"section 1701 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
