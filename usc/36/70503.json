"attrib":{},"text":"36:576(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70503(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:586.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “the persons listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s571"},"text":"section 571 of this title","children":[],"tail":"” and “hereafter” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “has one vote” are substituted for “may cast one vote” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74824bcf-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74824bd0-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/57"},"text":"Pub. L. 119–57","children":[],"tail":" added subsec. (a), redesignated subsec. (c) as (b), and struck out former subsecs. (a) and (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Members","children":[],"tail":".—The members of the corporation are—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) the members of the National Council of the Federal Bar Association, a nonprofit corporation incorporated in the District of Columbia, during their term of membership on that Council; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) other individuals the corporation provides for in the bylaws or otherwise.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Voting","children":[],"tail":".—Each member has one vote on each matter submitted to a vote of the members.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
