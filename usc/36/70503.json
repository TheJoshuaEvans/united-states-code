{"tag":"section","attrib":{"id":"id74824bc6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70503"},"text":null,"children":[{"tag":"num","attrib":{"value":"70503"},"text":"§ 70503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74824bc7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this chapter, eligibility for membership in the corporation and the rights and privileges of members are as provided in the bylaws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74824bc8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grounds for Disqualification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual may not be a member, director, or officer of the corporation if the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74824bc9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of, or advocates the principles of, an organization believing in, or working for, the overthrow of the United States Government by force or violence; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74824bca-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuses to uphold and defend the Constitution of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74824bcb-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1352"},"text":"112 Stat. 1352","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/57/s3"},"text":"Pub. L. 119–57, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-12"},"text":"Dec. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/711"},"text":"139 Stat. 711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74824bcc-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74824bcd-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74824bce-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"