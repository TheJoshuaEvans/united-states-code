{"tag":"section","attrib":{"id":"id74a38fab-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153514"},"text":null,"children":[{"tag":"num","attrib":{"value":"153514"},"text":"§ 153514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74a38fac-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153514/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b), there is authorized to be appropriated to the corporation for operation and maintenance expenses $500,000 for each of fiscal years 2008 through 2017.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74a38fad-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153514/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any Federal funds made available under subsection (a) shall be matched on a 1-to-1 basis by non-Federal funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74a38fae-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/11/tXIII/s13006"},"text":"Pub. L. 111–11, title XIII, § 13006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-03-30"},"text":"Mar. 30, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/1452"},"text":"123 Stat. 1452","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
