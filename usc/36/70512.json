"text":null,"children":[{"tag":"html:span","attrib":{},"text":"70512","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:585.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1954-08-24/ch911/s15"},"text":"Aug. 24, 1954, ch. 911, § 15","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/800"},"text":"68 Stat. 800","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “satisfaction” is omitted as included in “discharge”, and the word “obligations” is omitted as included in “liabilities”. The word “outstanding” is omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74824c27-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74824c28-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/57"},"text":"Pub. L. 119–57","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “On dissolution or final liquidation of the corporation, any assets remaining after the discharge of all liabilities shall be deposited in the Treasury of the United States as a miscellaneous receipt.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
