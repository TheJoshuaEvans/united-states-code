{"tag":"section","attrib":{"id":"id74824c20-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70512"},"text":null,"children":[{"tag":"num","attrib":{"value":"70512"},"text":"§ 70512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deposit of assets on dissolution or final liquidation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"On dissolution or final liquidation of the corporation, any assets of the corporation remaining after the discharge of all liabilities shall be distributed—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74824c21-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as provided by the board of directors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74824c22-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in compliance with the charter and bylaws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74824c23-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1354"},"text":"112 Stat. 1354","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/57/s8"},"text":"Pub. L. 119–57, § 8","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-12"},"text":"Dec. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/712"},"text":"139 Stat. 712","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74824