{"tag":"section","attrib":{"id":"id747b1f1d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40706"},"text":null,"children":[{"tag":"num","attrib":{"value":"40706"},"text":"§ 40706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of assets on dissolution","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id747b1f1e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary of the Army","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On dissolution of the corporation, title to the following items, and the right to possess the items, vest in the Secretary of the Army:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1f1f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Firearms stored at Defense Distribution Depot, Anniston, Anniston, Alabama on the date of dissolution.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f20-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" M–16 rifles under control of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f21-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40706/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Trophies received from the National Board for the Promotion of Rifle Practice through the date of dissolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f22-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tax-Exempt Organizations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1f23-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On dissolution of the corporation, an asset not described in subsection (a) of this section may be distributed to an organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id747b1f24-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40706/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is exempt from taxation under section 501(a) of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/a"},"text":"26 U.S.C. 501(a)","children":[],"tail":") as an organization described in section 501(c)(3) of that Code ("},{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/3"},"text":"26 U.S.C. 501(c)(3)","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id747b1f25-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40706/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs functions similar to the functions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40722"},"text":"section 40722 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f26-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An asset distributed under this subsection may not be distributed to an individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1f27-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treasury","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On dissolution of the corporation, any asset not distributed under subsection (a) or (b) of this section shall be sold and the proceeds shall be deposited in the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id747b1f28-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1336"},"text":"112 Stat. 1336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/237/s3/c/3"},"text":"Pub. L. 113–237, § 3(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2840"},"text":"128 Stat. 2840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id747b1f29-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id747b1f2a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id747b1f2b