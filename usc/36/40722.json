{"tag":"section","attrib":{"id":"id747b1f39-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40722"},"text":null,"children":[{"tag":"num","attrib":{"value":"40722"},"text":"§ 40722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The functions of the Civilian Marksmanship Program are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1f3a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40722/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to instruct citizens of the United States in marksmanship;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f3b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40722/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote practice and safety in the use of firearms;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f3c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40722/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct competitions in the use of firearms and to award trophies, prizes, badges, and other insignia to competitors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f3d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40722/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to secure and account for firearms, ammunition, and other equipment for which the corporation is responsible;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f3e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40722/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to issue, loan, or sell firearms, ammunition, repair parts, and other supplies under sections 40731 and 40732 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1f3f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40722/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to procure necessary supplies and services to carry out the Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id747b1f40-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1337"},"text":"112 Stat. 1337","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id747b1f41-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id747b1f42-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id747b1f43-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40722","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:5502(a) (less words before cl. (1)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/104/106/tXVI/s1612/a"},"text":"Pub. L. 104–106, title XVI, § 1612(a)","children":[],"tail":" (less words before cl. (1)), "},{"tag":"html:a","attrib":{"href":"/us/stat/110/516"},"text":"110 Stat. 516","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Before clause (1), the words “The functions of the Civilian Marksmanship Program are” are added because of the reorganization of the revised chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3), the word “matches” is omitted as included in “competitions”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (4), the words “to secure and account for” are substituted for “The provision of security and accountability for” for clarity and to eliminate unnecessary words. The words “for which the corporation is responsible” are substituted for “under the custody and control of the Corporation” for clarity and for consistency with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40731/b"},"text":"section 40731(b) of this title","children":[],"tail":" related to firearms that are not under the direct custody and control of the corporation because they have been issued or loaned."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (5), the words “ammunition, repair parts, and other supplies” are substituted for “ammunition, supplies, and appliances” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (6), the words “supplies and services” are substituted for “supplies, appliances, clerical services, other related services, and labor” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
