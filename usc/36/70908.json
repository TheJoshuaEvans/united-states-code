"},{"tag":"note","attrib":{"topic":"amendments","id":"id74894fbb-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/7/s9/1"},"text":"Pub. L. 116–7, § 9(1)","children":[],"tail":", substituted “FFA” for “corporation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/7/s9/2"},"text":"Pub. L. 116–7, § 9(2)","children":[],"tail":", substituted “FFA or a director, officer, or member acting on behalf of the FFA” for “corporation or a director, officer, or member as such”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/7/s9/3"},"text":"Pub. L. 116–7, § 9(3)","children":[],"tail":", substituted “FFA” for “corporation” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/7/s9/4"},"text":"Pub. L. 116–7, § 9(4)","children":[],"tail":", substituted “FFA” for “corporation” in first sentence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
