{"tag":"section","attrib":{"id":"id7492ed73-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140508"},"text":null,"children":[{"tag":"num","attrib":{"value":"140508"},"text":"§ 140508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and inspection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7492ed74-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation shall keep—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7492ed75-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correct and complete records of account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ed76-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minutes of the proceedings of its members, board of directors, and committees having any of the authority of its board of directors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ed77-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140508/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at its principal office, a record of the names and addresses of its members entitled to vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7492ed78-3a70-11f1-9d9e-dfac6d46cab7"