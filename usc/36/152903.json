{"tag":"section","attrib":{"id":"id74a1459d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152903"},"text":null,"children":[{"tag":"num","attrib":{"value":"152903"},"text":"§ 152903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are as provided in the articles of incorporation and include a continuing commitment, on a national basis—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74a1459e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152903/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct, record, and publish the results of research on the history and deeds of the American colonists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a1459f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152903/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to publish the memoirs of American colonists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a145a0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152903/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to erect memorials to commemorate the history and deeds of the American colonists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a145a1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152903/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote respect and admiration for the institutions, laws, and flag of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a145a2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152903/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage in mutual improvement and educational activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a145a3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152903/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish scholarships to assist needy and deserving students and to promote the improvement of educational institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a145a4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152903/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to engage in volunteer service and make contributions to veterans hospitals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a145a5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152903/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perform other charitable activities, including the national presidents’ projects, as may be provided in the articles of incorporation or bylaws of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74a145a6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1420"},"text":"112 Stat. 1420","children":[],"tail":"