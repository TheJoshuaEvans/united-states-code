{"tag":"section","attrib":{"id":"id74a6004b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154102"},"text":null,"children":[{"tag":"num","attrib":{"value":"154102"},"text":"§ 154102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are, through organization and cooperation with the Department of the Navy—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74a6004c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage and aid American young people to develop an interest and skill in basic seamanship and in its naval adaptations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a6004d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to train them in seagoing skills; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a6004e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to teach them patriotism, courage, self-reliance, and kindred virtues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74a6004f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1432"},"text":"112 Stat. 1432","children":[],"tail":".)"}],"tail":"\n"},{"tag"