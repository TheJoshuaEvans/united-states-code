{"tag":"section","attrib":{"id":"id74574310-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103"},"text":null,"children":[{"tag":"num","attrib":{"value":"2103"},"text":"§ 2103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74574311-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to appropriations made to carry out this chapter, the American Battle Monuments Commission may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74574312-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire land or an interest in land in a foreign country to carry out the purposes of this chapter, or an executive order conferring duties and powers on the Commission, without submission to the Attorney General under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s3111"},"text":"section 3111 of title 40","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74574313-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain, repair, and operate motor-propelled passenger-carrying vehicles and other property that another department, agency, or instrumentality of the United States Government provides to the Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74574314-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish offices in the District of Columbia and elsewhere in or outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74574315-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rent office and garage space, which may be paid for in advance, in foreign countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74574316-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procure printing, binding, engraving, lithographing, photographing, and typewriting, including the publication of information on United States activities, battlefields, memorials, and cemeteries with respect to which the Commission may exercise any duties and powers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74574317-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposition of Land","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under conditions and in the manner the Commission decides is proper, the Commission may dispose of land or an interest in land in a foreign country that the Commission acquires in connection with its work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74574318-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracting Out","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the requirements of existing laws or regulations, the Commission, under conditions the Commission decides are necessary and proper, may contract for work, supplies, materials, and equipment outside or for use outside the United States and engage the services of architects and other technical and professional personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74574319-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under conditions the Commission may prescribe, the Commission may delegate to its Chairman, secretary, or officials in charge of any of its offices any of its authority it considers necessary and proper.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7457431a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Solicitation and Receipt of Contributions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7457431b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission may solicit and receive funds and in-kind donations and gifts from any State, municipal, or private source to carry out the purposes of this chapter. The Commission shall deposit such funds in a separate account in the Treasury. Funds from that account shall be disbursed upon vouchers approved by the Chairman of the Commission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7457431c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Commission shall establish written guidelines setting forth the criteria to be used in determining whether the acceptance of funds and in-kind donations and gifts under paragraph (1) would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7457431d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect unfavorably on the ability of the Commission, or any member or employee of the Commission, to carry out the responsibilities or official duties of the Commission in a fair and objective manner; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7457431e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compromise the integrity or the appearance of the integrity of the programs of the Commission or any official involved in those programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7457431f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Use of Contributions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission may not obligate, withdraw, or expend amounts received as contributions before ","children":[{"tag":"date","attrib":{"date":"1998-03-01"},"text":"March 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74574320-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statements to President","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall transmit to the President on October 1 of each year a statement of all its financial and other transactions during the prior fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74574321-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial Statements and Audits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall have a system of financial controls to enable the Commission to comply with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3515"},"text":"section 3515 of title 31","children":[],"tail":" and with "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s2106/d/4"},"text":"section 2106(d)(4) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74574322-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposition of Records and Archives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When no longer required by the Commission, the records and archives of the Commission shall be deposited with the National Archives in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s2107"},"text":"section 2107 of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74574323-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Seal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall have a seal that shall be judicially noticed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74574324-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2103/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disbursements Outside Continental United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Disbursements for expenditures outside the continental United States may be made by a special disbursing agent designated by the Commission under regulations it prescribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74574325-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","childr