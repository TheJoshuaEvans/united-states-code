{"tag":"section","attrib":{"id":"id74b91283-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530"},"text":null,"children":[{"tag":"num","attrib":{"value":"220530"},"text":"§ 220530.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Other amateur sports organizations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74b91284-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An applicable amateur sports organization shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b91285-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with the reporting requirements of section 226 of the Victims of Child Abuse Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s20341"},"text":"34 U.S.C. 20341","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b91286-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish reasonable procedures to limit one-on-one interactions, including communications, between an amateur athlete who is a minor and an adult (who is not the minor’s legal guardian) at a facility under the jurisdiction of the applicable amateur sports organization without being in an observable and interruptible distance from another adult, except under emergency circumstances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b91287-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offer and provide consistent training to all adult members who are in regular contact with amateur athletes who are minors, and subject to parental consent, to members who are minors, regarding prevention and reporting of child abuse to allow a complainant to report easily an incident of child abuse to appropriate persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b91288-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prohibit retaliation, by the applicable amateur sports organization, against any individual who makes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74b91289-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a report under paragraph (1); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b9128a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other report relating to abuse of any amateur athlete, including emotional, physical, and sexual abuse.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b9128b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Applicable Amateur Sports Organization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “applicable amateur sports organization” means an amateur sports organization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b9128c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is not otherwise subject to the requirements under subchapter III;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b9128d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that participates in an interstate or international amateur athletic competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b9128e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose membership includes any adult who is in regular contact with an amateur athlete who is a minor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74b9128f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/126/tII/s204/a"},"text":"Pub. L. 115–126, title II, § 204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-14"},"text":"Feb. 14, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/324"},"text":"132 Stat. 324","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/189/s7/f"},"text":"Pub. L. 116–189, § 7(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/960"},"text":"134 Stat. 960","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74b91290-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74b91291-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74b91292-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s7/f/1"},"text":"Pub. L. 116–189, § 7(f)(1)","children":[],"tail":", inserted “, including communications,” after “interactions”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s7/f/2"},"text":"Pub. L. 116–189, § 7(f)(2)","children":[],"tail":", substituted “makes—” and subpars. (A) and (B) for “makes a report under paragraph (1).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
