{"tag":"section","attrib":{"id":"id74c03f70-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300102"},"text":null,"children":[{"tag":"num","attrib":{"value":"300102"},"text":"§ 300102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74c03f71-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to provide volunteer aid in time of war to the sick and wounded of the Armed Forces, in accordance with the spirit and conditions of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74c03f72-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300102/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conference of Geneva of October 1863;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74c03f73-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300102/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the treaties of the Red Cross, or the treaties of Geneva, ","children":[{"tag":"date","attrib":{"date":"1864-08-22"},"text":"August 22, 1864","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1929-07-27"},"text":"July 27, 1929","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1949-08-12"},"text":"August 12, 1949","children":[],"tail":", to which the United States of America has given its adhesion; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74c03f74-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300102/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other treaty, convention, or protocol similar in purpose to which the United States of America has given or may give its adhesion;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74c03f75-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out the purposes described in paragraph (1) of this section, to perform all the duties devolved on a national society by each nation that has acceded to any of those treaties, conventions, or protocols;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74c03f76-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to act in matters of voluntary relief and in accordance with the military authorities as a medium of communication between the people of the United States and the Armed Forces of the United States and to act in those matters between similar national societies of governments of other countries through the International Committee of the Red Cross and the Government, the people, and the Armed Forces of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74c03f77-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out a system of national and international relief in time of peace, and to apply that system in mitigating the suffering caused by pestilence, famine, fire, floods, and other great national calamities, and to devise and carry out measures for preventing those calamities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74c03f78-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct other activities consistent with the foregoing purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74c03f79-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1490"},"text":"112 Stat. 1490","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/26/s4"},"text":"Pub. L. 110–26, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-11"},"text":"May 11, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/105"},"text":"121 Stat. 105","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74c03f7a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74c03f7b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74c03f7c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"300102","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:3.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1905-01-05/ch23/s3"},"text":"Jan. 5, 1905, ch. 23, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/33/600"},"text":"33 Stat. 600","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1947-05-08/ch50/s4"},"text":"May 8, 1947, ch. 50, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/81"},"text":"61 Stat. 81","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-07-17/ch222/s4/a"},"text":"July 17, 1953, ch. 222, § 4(a)","children":[],"tail":", (b), "},{"tag":"html:a","attrib":{"href":"/us/stat/67/179"},"text":"67 Stat. 179","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the text of 36:3 (“Third” par.) is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1)(B), the date “","children":[{"tag":"date","attrib":{"date":"1949-08-12"},"text":"August 12, 1949","children":[],"tail":"” is added to include the reference to a subsequent treaty."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the words “in carrying out the purposes described in clause (1) of this section” are substituted for “And for said purposes” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3), the words “International Committee of the Red Cross” are substituted for “Comité International de Secours” because the name has been changed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (4), the word “continue” is omitted as included in “carry out”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74c03f7d-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74c03f7e-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/26"},"text":"Pub. L. 110–26","children":[],"tail":" added par. (5)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
