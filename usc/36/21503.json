{"tag":"section","attrib":{"id":"id74680cfb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503"},"text":null,"children":[{"tag":"num","attrib":{"value":"21503"},"text":"§ 21503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74680cfc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74680cfd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The board of governors is the governing body of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74680cfe-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The board shall have at least 12 governors, divided into 3 classes of equal numbers. One class of governors shall be elected each year for a term of 3 years or until their successors are elected. The corporation shall elect the governors at its annual meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74680cff-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quorum","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Five governors are a quorum for the transaction of business, except that a majority vote of the board is required for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74680d00-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale or alienation of any real or personal estate of the corporation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74680d01-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the leasing of real estate of the corporation for a term of more than one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74680d02-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The board may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74680d03-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" adopt and amend bylaws, as may be necessary and proper, related to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74680d04-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" elections and meetings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74680d05-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifications and duties of governors and officers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74680d06-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" admission and qualifications of members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74680d07-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" management and disposition of the property, business, and concerns of the corporation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74680d08-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct all business of the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74680d09-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fill, until the next annual election, a vacancy on the board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74680d0a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21503/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint attending and resident physicians and surgeons, agents, assistants, and attendants as may be necessary, set their compensation, and discharge them.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74680d0b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1295"},"text":"112 Stat. 1295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74680d0c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74680d0d-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74680d0e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail