{"tag":"section","attrib":{"id":"id74955df5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150103"},"text":null,"children":[{"tag":"num","attrib":{"value":"150103"},"text":"§ 150103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are as provided in the articles of incorporation and include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74955df6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating the structure, administration, operation, and program performance of Federal and other governments and government agencies, anticipating, identifying, and analyzing significant problems, and suggesting timely corrective action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955df7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foreseeing and examining critical emerging issues in governance, and formulating practical approaches to their resolution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955df8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150103/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the effectiveness, structure, administration, and implications for governance of present or proposed public programs, policies, and processes, and recommending specific changes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955df9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150103/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advising on the relationship of Federal, State, regional, and local governments, and increasing public officials’, citizens’, and scholars’ understanding of requirements and opportunities for sound governance and how these can be effectively met; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955dfa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150103/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrating by the conduct of its affairs a commitment to the highest professional standards of ethics and scholarship.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74955dfb-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1386"},"text":"112 Stat. 1386","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74955dfc-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74955dfd-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74955dfe-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{