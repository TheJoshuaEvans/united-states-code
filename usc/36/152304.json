t":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “and referred to” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “at another regular interval as provided” are substituted for “at such other regular intervals as may be specified” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “from time to time” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
