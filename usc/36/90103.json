{"tag":"section","attrib":{"id":"id748bc0cd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103"},"text":null,"children":[{"tag":"num","attrib":{"value":"90103"},"text":"§ 90103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id748bc0ce-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The board of directors is the governing body of the foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0cf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members and Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id748bc0d0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The board consists of 12 directors, who shall be appointed not later than 60 days after the date of the enactment of this chapter as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id748bc0d1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Four directors (of whom not more than two may be members of the same political party) shall be appointed by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id748bc0d2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two directors shall be appointed by the Speaker of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id748bc0d3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two directors shall be appointed by the Minority Leader of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id748bc0d4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two directors shall be appointed by the Majority Leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id748bc0d5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two directors shall be appointed by the Minority Leader of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0d6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the directors described in paragraph (1), the chair and ranking minority member of the Committee on House Administration of the House of Representatives (or their designees) and the chair and ranking minority member of the Committee on Rules and Administration of the Senate (or their designees) shall each serve as an ex officio nonvoting member of the board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0d7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A director is not an employee of the Federal Government and appointment to the board does not constitute appointment as an officer or employee of the United States Government for the purpose of any law of the United States (except as may otherwise be provided in this chapter).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0d8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms of office of the directors are 4 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0d9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vacancy on the board shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0da-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chair","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The directors shall select one of the directors as the chair of the board. The individual selected may not be a current or former holder of any partisan elected office or a current or former officer of any national committee of a political party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0db-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quorum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The number of directors constituting a quorum of the board shall be established under the bylaws of the foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0dc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The board shall meet at the call of the chair of the board for regularly scheduled meetings, except that the board shall meet not less often than annually.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0dd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement of Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Directors shall serve without compensation but may receive travel expenses, including per diem in lieu of subsistence, in accordance with sections 5702 and 5703 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0de-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90103/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability of Directors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Directors are not personally liable, except for gross negligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id748bc0df-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tVI/s601/a"},"text":"Pub. L. 107–252, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1718"},"text":"116 Stat. 1718","children":[],"tail":", § 152603; renumbered § 90103, "},{"tag":"ref","attrib":{"href":"/us/pl/113/237/s3/c/6/B"},"text":"Pub. L. 113–237, § 3(c)(6)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2840"},"text":"128 Stat. 2840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id748bc0e0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id748bc0e1-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id748bc0e2-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this chapter, referred to in subsec. (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252"},"text":"Pub. L. 107–252","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id748bc0e3-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/237"},"text":"Pub. L. 113–237","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s152603"},"text":"section 152603 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
