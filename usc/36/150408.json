{"tag":"section","attrib":{"id":"id74955e80-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150408"},"text":null,"children":[{"tag":"num","attrib":{"value":"150408"},"text":"§ 150408.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive right to name, seals, emblems, and badges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74955e81-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150408/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall have the sole and exclusive right to use the names “National American Indian Veterans, Incorporated” and “National American Indian Veterans”, and such seals, emblems, and badges as the corporation may lawfully adopt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74955e82-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150408/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section interferes or conflicts with any established or vested rights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74955e83-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLI/s5103/a"},"text":"Pub. L. 118–31, div. E, title LI, § 5103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/936"},"text":"137 Stat. 936","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
