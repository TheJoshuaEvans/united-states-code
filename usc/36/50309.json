{"tag":"section","attrib":{"id":"id747fda9e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50309"},"text":null,"children":[{"tag":"num","attrib":{"value":"50309"},"text":"§ 50309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dissolution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"On dissolution or final liquidation of the corporation, any assets remaining after the discharge or satisfactory provision for the discharge of all liabilities shall be transferred to the Secretary of Veterans Affairs for the care of disabled veterans.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id747fda9f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/135/s1/b"},"text":"Pub. L. 114–135, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-03-18"},"text":"Mar. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/300"},"text":"130 Stat. 300","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
