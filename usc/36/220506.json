{"tag":"section","attrib":{"id":"id74b457fb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506"},"text":null,"children":[{"tag":"num","attrib":{"value":"220506"},"text":"§ 220506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive right to name, seals, emblems, and badges","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74b457fc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusive Right of Corporation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d) of this section, the corporation has the exclusive right to use—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b457fd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name “United States Olympic and Paralympic Committee”;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b457fe-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the symbol of the International Olympic Committee, consisting of 5 interlocking rings, the symbol of the International Paralympic Committee, consisting of 3 Agitos, or the symbol of the Pan-American Sports Organization, consisting of a torch surrounded by concentric rings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b457ff-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the emblem of the corporation, consisting of an escutcheon having a blue chief and vertically extending red and white bars on the base with 5 interlocking rings displayed on the chief; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b45800-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the words “Olympic”, “Olympiad”, “Citius Altius Fortius”, “Paralympic”, “Paralympiad”, “Pan-American”, “Parapan American”, “America Espirito Sport Fraternite”, or any combination of those words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b45801-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contributors and Suppliers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may authorize contributors and suppliers of goods or services to use the trade name of the corporation or any trademark, symbol, insignia, or emblem of the International Olympic Committee, International Paralympic Committee, the Pan-American Sports Organization, or of the corporation to advertise that the contributions, goods, or services were donated or supplied to, or approved, selected, or used by, the corporation, the United States Olympic team, the Paralympic team, the Pan-American team, the Parapan American team, or team members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b45802-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Action for Unauthorized Use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d) of this section, the corporation may file a civil action against a person for the remedies provided in the Act of ","children":[{"tag":"date","attrib":{"date":"1946-07-05"},"text":"July 5, 1946","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"15 U.S.C. 1051","children":[],"tail":" et seq.) (popularly known as the Trademark Act of 1946) if the person, without the consent of the corporation, uses for the purpose of trade, to induce the sale of any goods or services, or to promote any theatrical exhibition, athletic performance, or competition—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b45803-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the symbol described in subsection (a)(2) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b45804-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the emblem described in subsection (a)(3) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b45805-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the words described in subsection (a)(4) of this section, or any combination or simulation of those words tending to cause confusion or mistake, to deceive, or to falsely suggest a connection with the corporation or any Olympic, Paralympic, Pan-American, or Parapan American Games activity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b45806-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any trademark, trade name, sign, symbol, or insignia falsely representing association with, or authorization by, the International Olympic Committee, the International Paralympic Committee, the Pan-American Sports Organization, or the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b45807-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pre-Existing and Geographic Reference Rights","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b45808-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who actually used the emblem described in subsection (a)(3) of this section, or the words or any combination of the words described in subsection (a)(4) of this section, for any lawful purpose before ","children":[{"tag":"date","attrib":{"date":"1950-09-21"},"text":"September 21, 1950","children":[],"tail":", is not prohibited by this section from continuing the lawful use for the same purpose and for the same goods or services."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b45809-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who actually used, or whose assignor actually used, the words or any combination of the words described in subsection (a)(4) of this section, or a trademark, trade name, sign, symbol, or insignia described in subsection (c)(4) of this section, for any lawful purpose before ","children":[{"tag":"date","attrib":{"date":"1950-09-21"},"text":"September 21, 1950","children":[],"tail":", is not prohibited by this section from continuing the lawful use for the same purpose and for the same goods or services."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b4580a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Use of the word “Olympic” to identify a business or goods or services is permitted by this section where—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74b4580b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such use is not combined with any of the intellectual properties referenced in subsection (a) or (c) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b4580c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is evident from the circumstances that such use of the word “Olympic” refers to the naturally occurring mountains or geographical region of the same name that were named prior to ","children":[{"tag":"date","attrib":{"date":"1998-02-06"},"text":"February 6, 1998","children":[],"tail":", and not to the corporation or any Olympic activity; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74b4580d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220506/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such business, goods, or services are operated, sold, and marketed in the State of Washington west of the Cascade Mountain range and operations, sales, and marketing outside of this area are not substantial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74b4580e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1469"},"text":"112 Stat. 1469","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s142/g"},"text":"Pub. L. 105–277, div. C, title I, § 142(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-604"},"text":"112 Stat. 2681–604","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s5/16"},"text":"Pub. L. 109–284, § 5(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1212"},"text":"120 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/189/s4/a/6"},"text":"Pub. L. 116–189, § 4(a)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/945"},"text":"134 Stat. 945","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74b4580f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74b45810-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74b45811-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220506(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:380(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-21/ch975"},"text":"Sept. 21, 1950, ch. 975","children":[],"tail":", title I, § 110, as added "},{"tag":"html:span","attrib":{},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/606/s1/b"},"text":"Pub. L. 95–606, § 1(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/3048"},"text":"92 Stat. 3048","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220506(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:380(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220506(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:380(a) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220506(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:380(a) (2d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(2) and (3) is substituted for “the symbol described in subsection (a)(1) of this section; the emblem described in subsection (a)(2) of this section” because of the reorganization of the section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “or any trademark” are substituted for “as well as any trademark” to eliminate unnecessary words. The words “furnished . . . or for the use of” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “the corporation may file a civil action against a person” are substituted for “any person . . . shall be subject to suit in a civil action by the Corporation” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), the words “the words or any combination of the words described in subsection (a)(4) of this section, or a trademark, trade name, sign, symbol, or insignia described in subsection (c)(4) of this section” are substituted for “any other trademark, trade name, sign, symbol, or insignia described in subsections (a)(3) and (4) of this section” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74b45812-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id74b45813-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Trademark Act of 1946, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-05/ch540"},"text":"act July 5, 1946, ch. 540","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/60/427"},"text":"60 Stat. 427","children":[],"tail":", also popularly known as the Lanham Act, which is classified generally to chapter 22 (§ 1051 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1051"},"text":"section 1051 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74b45814-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s4/a/6/A/i"},"text":"Pub. L. 116–189, § 4(a)(6)(A)(i)","children":[],"tail":", substituted “United States Olympic and Paralympic Committee” for “United States Olympic Committee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s4/a/6/A/ii"},"text":"Pub. L. 116–189, § 4(a)(6)(A)(ii)","children":[],"tail":", substituted “3 Agitos” for “3 TaiGeuks”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s4/a/6/A/iii"},"text":"Pub. L. 116–189, § 4(a)(6)(A)(iii)","children":[],"tail":", inserted “ ‘Parapan American’,” after “ ‘Pan-American’,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s4/a/6/B"},"text":"Pub. L. 116–189, § 4(a)(6)(B)","children":[],"tail":", inserted “the Parapan American team,” after “the Pan-American team,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s4/a/6/C"},"text":"Pub. L. 116–189, § 4(a)(6)(C)","children":[],"tail":", substituted “Pan-American, or Parapan American Games activity” for “or Pan-American Games activity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d)(3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284"},"text":"Pub. L. 109–284","children":[],"tail":" substituted “subsection” for “subsections”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/g/1"},"text":"Pub. L. 105–277, § 142(g)(1)","children":[],"tail":", substituted “rings, the symbol of the International Paralympic Committee, consisting of 3 TaiGeuks, or the symbol of the Pan-American Sports Organization, consisting of a torch surrounded by concentric rings;” for “rings;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/g/2"},"text":"Pub. L. 105–277, § 142(g)(2)","children":[],"tail":", inserted “ ‘Paralympic’, ‘Paralympiad’, ‘Pan-American’, ‘America Espirito Sport Fraternite’,” before “or any combination”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/g/3"},"text":"Pub. L. 105–277, § 142(g)(3)","children":[],"tail":", (4), inserted “, International Paralympic Committee, the Pan-American Sports Organization,” after “International Olympic Committee” and “the Paralympic team,” before “the Pan-American team”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/g/5"},"text":"Pub. L. 105–277, § 142(g)(5)","children":[],"tail":", inserted “, Paralympic, or Pan-American Games” after “any Olympic”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/g/6"},"text":"Pub. L. 105–277, § 142(g)(6)","children":[],"tail":", inserted “, the International Paralympic Committee, the Pan-American Sport Organization,” after “International Olympic Committee”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/g/7"},"text":"Pub. L. 105–277, § 142(g)(7)","children":[],"tail":", inserted “"},{"tag":"inline","attrib":{},"text":"and Geographic Reference","children":[],"tail":"” after “"},{"tag":"inline","attrib":{},"text":"Pre-Existing","children":[],"tail":"” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142/g/8"},"text":"Pub. L. 105–277, § 142(g)(8)","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
