{"tag":"section","attrib":{"id":"id74bb834c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543"},"text":null,"children":[{"tag":"num","attrib":{"value":"220543"},"text":"§ 220543.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records, audits, and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74bb834d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Center shall keep correct and complete records of account.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74bb834e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Audits and Transparency.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74bb834f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual audit.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74bb8350-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than annually, the financial statements of the Center for the preceding fiscal year shall be audited by an independent auditor in accordance with generally accepted accounting principles—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74bb8351-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the adequacy of the internal controls of the Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74bb8352-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prevent waste, fraud, or misuse of funds transferred to the Center by the corporation or the national governing bodies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74bb8353-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An audit under subparagraph (A) shall be conducted at the location at which the financial statements of the Center normally are kept.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74bb8354-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date on which an audit under subparagraph (A) is completed, the independent auditor shall issue an audit report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74bb8355-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corrective action plan.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id74bb8356-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On completion of the audit report under subparagraph (C) for a fiscal year, the Center shall prepare, in a separate document, a corrective action plan that responds to any corrective action recommended by the independent auditor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74bb8357-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters to be included","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A corrective action plan under clause (i) shall include the following for each such corrective action:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id74bb8358-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/1/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name of the person responsible for the corrective action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id74bb8359-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/1/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the planned corrective action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id74bb835a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/1/D/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The anticipated completion date of the corrective action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id74bb835b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/1/D/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a recommended corrective action based on a finding in the audit report with which the Center disagrees, or for which the Center determines that corrective action is not required, an explanation and a specific reason for noncompliance with the recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb835c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to records and personnel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to an audit under paragraph (1), the Center shall provide the independent auditor access to all records, documents, and personnel and financial statements of the Center necessary to carry out the audit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb835d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public availability.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74bb835e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall make available to the public on an easily accessible internet website of the Center—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74bb835f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each audit report under paragraph (1)(C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74bb8360-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Internal Revenue Service Form 990 of the Center for each year, filed under section 501(c) of the Internal Revenue Code of 1986; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74bb8361-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the minutes of the quarterly meetings of the board of directors of the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74bb8362-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personally identifiable information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An audit report or the minutes made available under subparagraph (A) shall not include the personally identifiable information of any individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb8363-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, the Center shall be considered a private entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74bb8364-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall submit an annual report to Congress, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74bb8365-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a strategic plan with respect to the manner in which the Center shall fulfill its duties under sections 220541 and 220542;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb8366-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed description of the efforts made by the Center to comply with such strategic plan during the preceding year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb8367-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any financial statement necessary to present fairly the assets, liabilities, and surplus or deficit of the Center for the preceding year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb8368-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the changes in the amounts of such assets, liabilities, and surplus or deficit during the preceding year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb8369-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a detailed description of Center activities, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74bb836a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and nature of misconduct complaints referred to the Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74bb836b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number and type of pending misconduct complaints under investigation by the Center;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74bb836c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of misconduct complaints for which an investigation was terminated or otherwise closed by the Center; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74bb836d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such misconduct complaints reported to law enforcement agencies by the Center for further investigation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb836e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a detailed description of any complaint of retaliation made during the preceding year by an officer or employee of the Center or a contractor or subcontractor of the Center that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74bb836f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of such complaints; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74bb8370-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the outcome of each such complaint;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb8371-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information relating to the educational activities and trainings conducted by the office of education and outreach of the Center during the preceding year, including the number of educational activities and trainings developed and provided; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb8372-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities of the Center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74bb8373-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74bb8374-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “audit report” means a report by an independent auditor that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74bb8375-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an opinion or a disclaimer of opinion that presents the assessment of the independent auditor with respect to the financial records of the Center, including whether such records are accurate and have been maintained in accordance with generally accepted accounting principles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74bb8376-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the internal controls used by the Center that describes the scope of testing of the internal controls and the results of such testing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74bb8377-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a compliance assessment that includes an opinion or a disclaimer of opinion as to whether the Center has complied with the terms and conditions of subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb8378-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220543/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “independent auditor” means an independent certified public accountant or independent licensed public accountant, certified or licensed by a regulatory authority of a State or a political subdivision of a State, who meets the standards specified in generally accepted accounting principles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74bb8379-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/126/tII/s202/a"},"text":"Pub. L. 115–126, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-02-14"},"text":"Feb. 14, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/323"},"text":"132 Stat. 323","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/189/s8/c"},"text":"Pub. L. 116–189, § 8(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/968"},"text":"134 Stat. 968","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74bb837a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74bb837b-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id74bb837c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 501(c) of the Internal Revenue Code of 1986, referred to in subsec. (b)(3)(A)(ii), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c"},"text":"section 501(c) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74bb837d-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189"},"text":"Pub. L. 116–189","children":[],"tail":" added subsecs. (b) to (d) and struck out former subsec. (b). Prior to amendment, text of subsec. (b) read as follows: “The Center shall submit an annual report to Congress, including—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) an audit conducted and submitted in accordance with section 10101; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) a description of the activities of the Center.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
