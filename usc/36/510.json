{"tag":"section","attrib":{"id":"id74528862-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s510"},"text":null,"children":[{"tag":"num","attrib":{"value":"510"},"text":"§ 510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of and prohibition on certain donations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74528863-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A committee shall not be considered to be the Inaugural Committee for purposes of this chapter unless the committee agrees to, and meets, the requirements of subsections (b) and (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74528864-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74528865-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s510/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than the date that is 90 days after the date of the Presidential inaugural ceremony, the committee shall file a report with the Federal Election Commission disclosing any donation of money or anything of value made to the committee in an aggregate amount equal to or greater than $200.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74528866-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s510/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report filed under paragraph (1) shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74528867-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s510/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the donation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74528868-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s510/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date the donation is received; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74528869-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s510/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the person making the donation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7452886a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s510/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The committee shall not accept any donation from a foreign national (as defined in section 319(b) of the Federal Election Campaign Act of 1971 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s441e/b"},"text":"2 U.S.C. 441e(b)","children":[],"tail":"))."},{"tag":"ref","attrib":{"idref":"fn002004"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002004"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7452886b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/155/tIII/s308/a/2"},"text":"Pub. L. 107–155, title III, § 308(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-03-27"},"text":"Mar. 27, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/103"},"text":"116 Stat. 103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7452886c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7452886d-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id7452886e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Election Campaign Act of 1971, referred to in subsec. (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/225"},"text":"Pub. L. 92–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-02-07"},"text":"Feb. 7, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/3"},"text":"86 Stat. 3","children":[],"tail":", which was formerly classified principally to chapter 14 (§ 431 et seq.) of Title 2, The Congress, prior to editorial reclassification and renumbering in Title 52, Voting and Elections, and is now classified principally to chapter 301 (§ 30101 et seq.) of Title 52. Section 319 of this Act is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30121"},"text":"section 30121 of Title 52","children":[],"tail":". For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id7452886f-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 510 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s511"},"text":"section 511 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id74528870-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id74528871-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2002-11-06"},"text":"Nov. 6, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/155/s402"},"text":"section 402 of Pub. L. 107–155","children":[],"tail":", set out as an Effective Date of 2002 Amendment; Regulations note under "},{"tag":"ref","attrib":{"href":"/us/usc/t52/s30101"},"text":"section 30101 of Title 52","children":[],"tail":", Voting and Elections."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
