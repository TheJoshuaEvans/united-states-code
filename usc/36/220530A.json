{"tag":"section","attrib":{"id":"id74b91293-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530A"},"text":null,"children":[{"tag":"num","attrib":{"value":"220530A"},"text":"§ 220530A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report on equal treatment of athletes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74b91294-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than annually, each national governing body shall submit to the corporation and Congress a report on the compliance of the national governing body with paragraphs (7) and (8) of section 220524(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b91295-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220530A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters To Be Included","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report required by subsection (a) shall include detailed information on the median, minimum, and maximum stipends and bonuses provided to athletes, disaggregated by gender, race, and, as applicable, status of participation on a professional sports team.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74b91296-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/340/s2/b/2/A"},"text":"Pub. L. 117–340, § 2(b)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-01-05"},"text":"Jan. 5, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6177"},"text":"136 Stat. 6177","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74b91297-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id74b91298-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id74b91299-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For construction of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/340"},"text":"Pub. L. 117–340","children":[],"tail":" as it pertains to certain rights of athletes, see "},{"tag":"ref","attrib":{"href":"/us/pl/117/340/s2/d"},"text":"section 2(d) of Pub. L. 117–340","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s220505"},"text":"section 220505 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
