{"tag":"section","attrib":{"id":"id74b4589e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220512"},"text":null,"children":[{"tag":"num","attrib":{"value":"220512"},"text":"§ 220512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Complete teams","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In obtaining representation for the United States in each competition and event of the Olympic Games, Paralympic Games, Pan-American Games, and Parapan American Games, the corporation, either directly or by delegation to the appropriate national governing body, may select, but is not obligated to select (even if not selecting will result in an incomplete team for an event), athletes who have not met the eligibility standard of the national governing body and the corporation when the number of athletes who have met the eligibility standards of such entities is insufficient to fill the roster for an event.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id74b6a18f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s142/k/1"},"text":"Pub. L. 105–277, div. C, title I, § 142(k)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-606"},"text":"112 Stat. 2681–606","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s5/19"},"text":"Pub. L. 109–284, § 5(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1212"},"text":"120 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/189"},"text":"Pub. L. 116–189","children":[],"tail":", §§ 4(a)(8), 7(a)(2)(A)(ii), "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/945"},"text":"134 Stat. 945","children":[],"tail":", 956.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74b6a190-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74b6a191-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74b6a192-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189"},"text":"Pub. L. 116–189","children":[],"tail":" substituted “Pan-American Games, and Parapan American Games” for “and Pan-American Games” and struck out “or paralympic sports organization” after “appropriate national governing body”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284"},"text":"Pub. L. 109–284","children":[],"tail":" substituted “and the corporation” for “and the Corporation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
