{"tag":"section","attrib":{"id":"id74aabb16-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190305"},"text":null,"children":[{"tag":"num","attrib":{"value":"190305"},"text":"§ 190305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74aabb17-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board of Directors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The board of directors and the responsibilities of the board are as provided in the articles of incorporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74aabb18-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The officers and the election of officers are as provided in the articles of incorporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74aabb19-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nondiscrimination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements for serving as a director or officer may not discriminate on the basis of race, color, religion, sex, disability, age, or national origin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","at