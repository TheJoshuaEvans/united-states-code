":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:5108 (related to directors and officers).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 23, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/484/tXVIII/s1828"},"text":"Pub. L. 102–484, title XVIII, § 1828","children":[],"tail":" (related to directors and officers), "},{"tag":"html:a","attrib":{"href":"/us/stat/106/2585"},"text":"106 Stat. 2585","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1993","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/103/160/tXI/s1182/c/6"},"text":"Pub. L. 103–160, title XI, § 1182(c)(6)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/107/1772"},"text":"107 Stat. 1772","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “and in conformity with the laws of the State in which it is incorporated” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “The requirements for serving as a director or officer” are substituted for “in determining the requirements for serving on the board of directors or as an officer of the corporation” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
