{"tag":"section","attrib":{"id":"id74894fda-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70912"},"text":null,"children":[{"tag":"num","attrib":{"value":"70912"},"text":"§ 70912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74894fdb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The FFA shall have a designated agent to receive service of process for the FFA..","children":[{"tag":"ref","attrib":{"idref":"fn002012"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" Notice to or service on the agent, or mailed to the business address of the agent, is notice to or service on the FFA."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74894fdc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"States, Territories, and Possessions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As a condition to the exercise of any power or privilege granted by this chapter, the FFA shall file, with the Secretary of State or other designated official of each State, territory, or possession of the United States in which a subordinate association or chapter of the FFA is organized, the name and address of an agent in that State, territory, or possession on whom legal process or demands against the FFA may be served.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74894fdd-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1359"},"text":"112 Stat. 1359","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s5/7"},"text":"Pub. L. 109–284, § 5(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1212"},"text":"120 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/7/s13"},"text":"Pub. L. 116–7, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-02-21"},"text":"Feb. 21, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/482"},"text":"133 Stat. 482","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74894fde-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74894fdf-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74894fe0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":