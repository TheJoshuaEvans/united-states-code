lerk of the United States District Court for the District of Columbia” before “. Notice”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/7/s13/2"},"text":"Pub. L. 116–7, § 13(2)","children":[],"tail":", substituted “FFA” for “corporation” in two places and inserted “of the FFA” after “association or chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284"},"text":"Pub. L. 109–284","children":[],"tail":" substituted “corporation shall” for “Corporation shall”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
