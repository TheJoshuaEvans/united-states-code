{"tag":"section","attrib":{"id":"id74af9ca4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220104"},"text":null,"children":[{"tag":"num","attrib":{"value":"220104"},"text":"§ 220104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74af9ca5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board of Governors","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74af9ca6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The board of governors is the governing body of the corporation. The board is responsible for the general policies and program of the corporation and for the control of the affairs and property of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9ca7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The board shall be elected by the members of the corporation for the term and in the classes provided in the bylaws of the corporation. The board includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74af9ca8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220104/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" six members appointed by the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74af9ca9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220104/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense or the Secretary’s designee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74af9caa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220104/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of the civilian organizations listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s220102/4"},"text":"section 220102(4) of this title","children":[],"tail":", and of the public at large, as provided in the bylaws."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9cab-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220104/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The corporation may have other governing bodies or committees as provided in the bylaws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74af9cac-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74af9cad-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The office of honorary chairman of the corporation shall be offered to the President. On acceptance, the honorary chairman shall be invited to preside at meetings of the corporation that the honorary chairman deems appropriate and convenient.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9cae-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The corporation may have other officers as provided in the bylaws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74af9caf-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1460"},"text":"112 Stat. 1460","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s5/11"},"text":"Pub. L. 109–284, § 5(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1212"},"text":"120 Stat. 1212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74af9cb0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74af9cb1-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74af9cb2-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"ht