{"tag":"section","attrib":{"id":"id746cc7b2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22703"},"text":null,"children":[{"tag":"num","attrib":{"value":"22703"},"text":"§ 22703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746cc7b3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this chapter, eligibility for membership in the corporation and the rights and privileges of members are as provided in the constitution and bylaws of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746cc7b4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member has one vote in the conduct of official business at the post level.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746cc7b5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nondiscrimination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms of membership may not discriminate on the basis of race, color, religion, sex, or national origin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","a