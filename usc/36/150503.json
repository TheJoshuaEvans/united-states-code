{"tag":"section","attrib":{"id":"id7497a7ab-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150503"},"text":null,"children":[{"tag":"num","attrib":{"value":"150503"},"text":"§ 150503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7497a7ac-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150503/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote friendly and cooperative relations between the State and territorial societies in the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7497a7ad-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150503/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster, participate in, and encourage educational, cultural, charitable, civic, and patriotic programs and activities in the District of Columbia and surrounding communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7497a7ae-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150503/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to act as contact agent with States for carrying out State and national programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7497a7af-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/