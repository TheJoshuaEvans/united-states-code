{"tag":"section","attrib":{"id":"id7452882e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s502"},"text":null,"children":[{"tag":"num","attrib":{"value":"502"},"text":"§ 502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regulations, licenses, and registration tags","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7452882f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations and Licenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each inaugural period, the Council of the District of Columbia shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74528830-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe reasonable regulations necessary to preserve public order and protect life, health, and property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74528831-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe special regulations related to the standing, movement, and operation of vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74528832-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant special licenses to peddlers and vendors to sell merchandise in places the Council considers proper, subject to conditions and fees for the licenses the Council considers proper.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74528833-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registration Tags","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Mayor of the District of Columbia may issue, for any motor vehicle made available for the use of the Inaugural Committee, special registration tags, valid for not more than 90 days, designed to celebrate the inauguration of the President and Vice President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74528834-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1264"},"text":"112 Stat. 1264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74528835-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74528836-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74528837-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":