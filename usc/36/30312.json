)(4)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/278"},"text":"105 Stat. 278","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “satisfaction” is omitted as included in “discharge”, and the word “obligations” is omitted as included in “liabilities”. The word “outstanding” is omitted as unnecessary. The words “Secretary of Veterans Affairs” are substituted for “Department of Veterans Affairs” because under 38:303 the Secretary is the head of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
