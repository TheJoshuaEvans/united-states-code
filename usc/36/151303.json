"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"151303(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:5202(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"151303(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:5202(a)(3), (4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"151303(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:5203(c)(2) (words after 2d comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is substituted for “The Foundation shall have a governing Board of Directors (hereafter in this chapter referred to as the ‘Board’)” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “(hereafter in this chapter referred to as the ‘Administrator’)” in 36:5202(a)(2) are omitted as unnecessary. The words “Within 3 months after ","children":[{"tag":"date","attrib":{"date":"1992-10-26"},"text":"October 26, 1992","children":[],"tail":"” in 36:5202(b) are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(3) is substituted for 36:5202(b) (last sentence) to eliminate obsolete and unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “for the transaction of business” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (f)(1) is substituted for “Appointment to the Board shall not constitute employment by, or the holding of an office of, the United States for the purposes of any Federal law” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id749a193f-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/354"},"text":"Pub. L. 105–354","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends subsections (f) and (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s151303"},"text":"section 151303 of title 36","children":[],"tail":", as enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/105/225/s1"},"text":"section 1 of Public Law 105–225","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1400"},"text":"112 Stat. 1400","children":[],"tail":"). The amendment clarifies the restatement of 36:5202(a)(3) by making it clear that appointment to the board of directors of the National Fallen Firefighters Foundation does not constitute appointment as an officer or employee of the United States Government for the purpose of any law of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id749a1940-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id749a1941-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284"},"text":"Pub. L. 109–284","children":[],"tail":" substituted “The chairman” for “The Chairman”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/169/s206/a/1"},"text":"Pub. L. 108–169, § 206(a)(1)","children":[],"tail":", (2), substituted “12” for “9” in introductory provisions and “nine” for “six” in subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/169/s206/a/3"},"text":"Pub. L. 108–169, § 206(a)(3)","children":[],"tail":", substituted “4 members” for “3 members”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/503/s113/b/1"},"text":"Pub. L. 106–503, § 113(b)(1)","children":[],"tail":", added subsec. (f) and struck out heading and text of former subsec. (f). Text read as follows: “Appointment to the board does not constitute appointment as an officer or employee of the United States Government for the purpose of any law of the United States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/503/s113/b"},"text":"Pub. L. 106–503, § 113(b)","children":[],"tail":", redesignated subsec. (h) as (g) and struck out heading and text of former subsec. (g). Text read as follows: “Members of the board serve without compensation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/354"},"text":"Pub. L. 105–354","children":[],"tail":" amended subsecs. (f) and (g) generally and added subsec. (h). Prior to amendment, subsecs. (f) and (g) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(f) ","children":[{"tag":"inline","attrib":{},"text":"Status and Compensation","children":[],"tail":".—Members of the board—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) are not officers or employees of the United States Government; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) serve without compensation.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(g) ","children":[{"tag":"inline","attrib":{},"text":"Liability of Directors","children":[],"tail":".—Members of the board are not personally liable, except for gross negligence.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id749a1942-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id749a1943-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/354/s3"},"text":"Pub. L. 105–354, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-03"},"text":"Nov. 3, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3245"},"text":"112 Stat. 3245","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/354/s3"},"text":"“The amendment made by section 1(8) of this Act [amending this section] shall take effect as if included in the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Public Law 105–225","children":[],"tail":", as of the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Public Law 105–225","children":[],"tail":" ["},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id749a1944-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of all functions, personnel, assets, components, authorities, grant programs, and liabilities of the Federal Emergency Management Agency, including the functions of the Under Secretary for Federal Emergency Management relating thereto, to the Federal Emergency Management Agency, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t6/s315/a/1"},"text":"section 315(a)(1) of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the Federal Emergency Management Agency, including the functions of the Director of the Federal Emergency Management Agency relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see former section 313(1) and sections 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
