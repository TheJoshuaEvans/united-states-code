{"tag":"section","attrib":{"id":"id749a1929-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303"},"text":null,"children":[{"tag":"num","attrib":{"value":"151303"},"text":"§ 151303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board of directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id749a192a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The board of directors is the governing body of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749a192b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members and Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id749a192c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the United States Fire Administration of the Federal Emergency Management Agency is an ex officio nonvoting member of the board. The Administrator appoints the voting members of the board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a192d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The board consists of the following 12 voting members:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id749a192e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one active volunteer firefighter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id749a192f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one active career firefighter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id749a1930-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one United States Government firefighter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id749a1931-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nine individuals who have a demonstrated interest in the fire service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a1932-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The terms of office of the voting members are 6 years (except for the initial members). The terms shall be staggered so that the terms of 4 members expire every 2 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a1933-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vacancy on the board shall be filled within 60 days in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749a1934-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The chairman shall be elected by the board from its voting members for a 2-year term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749a1935-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quorum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A majority of the current membership of the board is a quorum.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749a1936-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The board shall meet at the call of the chairman at least once a year. If a member of the board misses 3 consecutive meetings, that member may be removed from the board and that vacancy may be filled as provided in subsection (b)(4) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749a1937-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status and Compensation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id749a1938-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appointment to the board shall not constitute employment by or the holding of an office of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a1939-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the board shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749a193a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151303/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the board are not personally liable, except for gross negligence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749a193b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1399"},"text":"112 Stat. 