{"tag":"section","attrib":{"id":"id748e3266-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s120110"},"text":null,"children":[{"tag":"num","attrib":{"value":"120110"},"text":"§ 120110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for acts of officers and agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation is liable for any act of any officer or agent of the corporation acting within the scope of the authority of the corporation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id748e3267-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/254/s1/a/2"},"text":"Pub. L. 110–254, § 1(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2421"},"text":"122 Stat. 2421","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
