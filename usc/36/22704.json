{"tag":"section","attrib":{"id":"id746cc7ba-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22704"},"text":null,"children":[{"tag":"num","attrib":{"value":"22704"},"text":"§ 22704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746cc7bb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegates to National Conventions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each post may elect delegates to national conventions of the corporation. The delegates each have one vote in the conduct of business of the convention to which they are elected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746cc7bc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive Committee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The executive committee of the corporation consists of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746cc7bd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member elected to represent each department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc7be-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officers of the corporation as ex officio members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746cc7bf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id746cc7c0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The officers of the corporation are a national commander, two national vice commanders, a finance officer, a judge advocate, a chaplain, six national district commanders, and a provost marshal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc7c1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The officers shall be elected by the delegates at the annual national convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746cc7c2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22704/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nondiscrimination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements for holding office in the corporation may not discriminate on the basis of race, color, religion, sex, or national origin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746cc7c3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1307"},"text":"112 Stat. 1307","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/241/s1/b"},"text":"Pub. L. 107–241, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-16"},"text":"Oct. 16, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1496"},"text":"116 Stat. 1496","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746cc7c4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id746cc7c5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id746cc7c6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section