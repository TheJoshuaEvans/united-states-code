{"tag":"section","attrib":{"id":"id7492ed21-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140410"},"text":null,"children":[{"tag":"num","attrib":{"value":"140410"},"text":"§ 140410.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for acts of officers and agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation is liable for any act of any officer or agent of the corporation acting within the scope of the authority of the corporation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7492ed22-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/95/s1/a"},"text":"Pub. L. 111–95, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-11-06"},"text":"Nov. 6, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/3003"},"text":"123 Stat. 3003","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
