{"tag":"section","attrib":{"id":"id749ed4a2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405"},"text":null,"children":[{"tag":"num","attrib":{"value":"152405"},"text":"§ 152405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id749ed4a3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749ed4a4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt a constitution and bylaws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed4a5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt a seal which shall be judicially noticed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed4a6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do any other act necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed4a7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers as Trustee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out its purposes, the corporation has the usual powers of a corporation acting as a trustee in the jurisdiction in which the principal office of the corporation is located, including the power—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749ed4a8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept, receive, solicit, hold, administer, and use any gift, devise, or bequest, either absolutely or in trust, of property or any income from or other interest in property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed4a9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire property or an interest in property by purchase or exchange;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed4aa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise required by an instrument of transfer, to sell, donate, lease, invest, or otherwise dispose of any property or income from property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed4ab-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to borrow money and issue instruments of indebtedness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed4ac-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make contracts and other arrangements with public agencies and private organizations and persons and to make payments necessary to carry out its functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed4ad-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sue and be sued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed4ae-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to do any other act necessary and proper to carry out the purposes of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed4af-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152405/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Encumbered or Restricted Gifts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A gift, devise, or bequest may be accepted by the corporation even though it is encumbered, restricted, or subject to beneficial interests of private persons, if any current or future interest is for the benefit of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749ed4b0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tII/s201/a"},"text":"Pub. L. 106–474, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2093"},"text":"114 Stat. 2093","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/336/s2/b/3/B"},"text":"Pub. L. 110–336, § 2(b)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-02"},"text":"Oct. 2, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3727"},"text":"122 Stat. 3727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749ed4b1-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id749ed4b2-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id749ed4b3-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/336"},"text":"Pub. L. 110–336","children":[],"tail":" substituted “jurisdiction in which the principal office of the corporation is located,” for “District of Columbia,” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
