{"tag":"section","attrib":{"id":"id748e323b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s120101"},"text":null,"children":[{"tag":"num","attrib":{"value":"120101"},"text":"§ 120101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id748e323c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s120101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Korean War Veterans Association, Incorporated (in this chapter, the “corporation”), a nonprofit organization that meets the requirements for a veterans service organization under section 501(c)(19) of the Internal Revenue Code of 1986 and that is organized under the laws of the State of New York, is a federally chartered corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748e323d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s120101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration of Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the corporation does not comply with the provisions of this chapter, the charter granted by subsection (a) shall expire.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id748e323e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/254/s1/a/2"},"text":"Pub. L. 110–254, § 1(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2419"},"text":"122 Stat. 2419","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id748e323f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id748e3240-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id748e3241-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 501(c)(19) of the Internal Revenue Code of 1986, referred to in subsec. (a), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501/c/19"},"text":"section 501(c)(19) of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
