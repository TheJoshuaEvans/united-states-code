{"tag":"section","attrib":{"id":"id74c2aff7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300110"},"text":null,"children":[{"tag":"num","attrib":{"value":"300110"},"text":"§ 300110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report and audit","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74c2aff8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As soon as practicable after the end of the corporation’s fiscal year, which may be changed from time to time by the board of governors, the corporation shall submit a report to the Secretary of Defense on the activities of the corporation during such fiscal year, including a complete, itemized report of all receipts and expenditures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74c2aff9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Auditing of Report and Submission to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall audit the report and submit a copy of the audited report to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74c2affa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of Audit Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall reimburse the Secretary each year for auditing its accounts. The amount paid shall be deposited in the Treasury of the United States as a miscellaneous receipt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74c2affb-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1493"},"text":"112 Stat. 1493","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/26/s10"},"text":"Pub. L. 110–26, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-11"},"text":"May 11, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/109"},"text":"121 Stat. 109","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74c2affc-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74c2affd-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74c2affe-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"300110(a)–(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:6.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1905-01-05/ch23/s6"},"text":"Jan. 5, 1905, ch. 23, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/33/602"},"text":"33 Stat. 602","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1917-02-27/ch137"},"text":"Feb. 27, 1917, ch. 137","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/946"},"text":"39 Stat. 946","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-07-17/ch222/s4/c"},"text":"July 17, 1953, ch. 222, § 4(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/179"},"text":"67 Stat. 179","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:7.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1920-05-29/ch214/s1"},"text":"May 29, 1920, ch. 214, § 1","children":[],"tail":" (1st complete par. on p. 659), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/659"},"text":"41 Stat. 659","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-07-17/ch222/s5"},"text":"July 17, 1953, ch. 222, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/179"},"text":"67 Stat. 179","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “make and”, “next preceding”, and “full” are omitted as unnecessary. The word “activities” is substituted for “proceedings” for consistency in the revised title. The words “all receipts and expenditures” are substituted for “receipts and expenditures of whatever kind” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the word “Secretary” is substituted for “Department of Defense” for consistency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74c2afff-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74c2b000-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/26"},"text":"Pub. L. 110–26","children":[],"tail":" reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “As soon as practicable after July 1 of each year, the corporation shall submit a report to the Secretary of Defense on the activities of the corporation during the fiscal year ending June 30, including a complete, itemized report of all receipts and expenditures.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
