,"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id747fda6a-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id747fda6b-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/135/s1/a/1"},"text":"Pub. L. 114–135, § 1(a)(1)","children":[],"tail":", substituted “The corporation is organized exclusively for charitable and educational purposes. The purposes of the corporation shall include” for “The purposes of the corporation are” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (7) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/135/s1/a/2"},"text":"Pub. L. 114–135, § 1(a)(2)","children":[],"tail":"–(4), added pars. (7) and (8) and redesignated former par. (7) as (9)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
