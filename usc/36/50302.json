{"tag":"section","attrib":{"id":"id747d695c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50302"},"text":null,"children":[{"tag":"num","attrib":{"value":"50302"},"text":"§ 50302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The corporation is organized exclusively for charitable and educational purposes. The purposes of the corporation shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id747d695d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to uphold and maintain the Constitution and laws of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747d695e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to realize the true American ideals and aims for which those eligible to membership fought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747d695f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to advance the interests, and work for the betterment, of all wounded, injured, and disabled American veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747fda60-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cooperate with the Department of Veterans Affairs and all other public and private agencies devoted to the cause of improving and advancing the condition, health, and interests of all wounded, injured, and disabled veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747fda61-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50302/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to stimulate a feeling of mutual devotion, helpfulness, and comradeship among all wounded, injured, and disabled veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747fda62-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50302/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to serve our comrades, our communities, and our country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747fda63-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50302/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to educate the public about the sacrifices and needs of disabled veterans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747fda64-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50302/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to educate disabled veterans about the benefits and resources available to them; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747fda65-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50302/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage in all people that spirit of understanding which will guard against future wars.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id747fda66-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1343"},"text":"112 Stat. 1343","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/135/s1/a"},"text":"Pub. L. 114–135, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-03-18"},"text":"Mar. 18, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/300"},"text":"130 Stat. 300","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id747fda67-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id747fda68-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id747fda69-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":nul