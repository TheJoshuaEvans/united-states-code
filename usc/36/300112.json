{"tag":"section","attrib":{"id":"id74c2b006-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112"},"text":null,"children":[{"tag":"num","attrib":{"value":"300112"},"text":"§ 300112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of the Ombudsman","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74c2b007-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall establish an Office of the Ombudsman with such duties and responsibilities as may be provided in the bylaws or a resolution of the board of governors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74c2b008-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74c2b009-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of the Ombudsman shall submit annually to the appropriate Congressional committees a report concerning any trends and systemic matters that the Office of the Ombudsman has identified as confronting the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74c2b00a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate congressional committees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the appropriate Congressional committees are the following committees of Congress:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74c2b00b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Senate committees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriate Congressional committees of the Senate are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74c2b00c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Finance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74c2b00d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Relations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74c2b00e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Health, Education, Labor, and Pensions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74c2b00f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security and Governmental Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74c2b010-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on the Judiciary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74c2b011-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"House committees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The appropriate Congressional committees of the House of Representatives are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74c2b012-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74c2b013-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Foreign Affairs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74c2b014-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74c2b015-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on the Judiciary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74c2b016-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300112/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Ways and Means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74c2b017-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/26/s11/a"},"text":"Pub. L. 110–26, § 11(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-11"},"text":"May 11, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/110"},"text":"121 Stat. 110","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
