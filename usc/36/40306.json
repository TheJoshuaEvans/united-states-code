{"tag":"section","attrib":{"id":"id7478ae77-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40306"},"text":null,"children":[{"tag":"num","attrib":{"value":"40306"},"text":"§ 40306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exclusive right to name, insignia, copyrights, emblems, badges, marks, and words","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation has the exclusive right to use the name “Civil Air Patrol” and all insignia, copyrights, emblems, badges, descriptive or designating marks, words, and phrases the corporation adopts. This section does not affect any vested rights.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id7478ae78-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1332"},"text":"112 Stat. 1332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7478ae79-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7478ae7a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id7478ae7b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40306","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:206.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1946-07-01/ch527/s6"},"text":"July 1, 1946, ch. 527, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/347"},"text":"60 Stat. 347","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “sole” is omitted as included in “exclusive”. The words “right to use the name ‘Civil Air Patrol’ and all” are substituted for “right to the name ‘Civil Air Patrol’ and to have and to use, in carrying out its purposes, all” for consistency in the revised title and to eliminate unnecessary words. The words “the corporation adopts” are substituted for “now or heretofore used by the Civil Air Patrol” in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1946-07-01/s6"},"text":"section 6 of the Act of July 1, 1946","children":[],"tail":" (ch. 527, "},{"tag":"ref","attrib":{"href":"/us/stat/60/347"},"text":"60 Stat. 347","children":[],"tail":") for consistency in the revised title. The words “in carrying out its program” are omitted as unnecessary. The words “This section does not affect any vested rights” are substituted for “"},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That no powers or privileges herein granted shall interfere or conflict with established or vested rights” for consistency in the revised title and to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
