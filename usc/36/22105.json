{"tag":"section","attrib":{"id":"id746a56c5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22105"},"text":null,"children":[{"tag":"num","attrib":{"value":"22105"},"text":"§ 22105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746a56c6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Profit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not operate for profit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746a56c7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stock and Dividends","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not issue stock or declare or pay a dividend.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746a56c8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Political Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation or an officer or member of the executive council as such may not contribute to, support, or assist a political party or candidate for elective public office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746a56c9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Income or Assets","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The income or assets of the corporation may not inure to the benefit of, or be distributed to, a member of the corporation or an officer or member of the executive council, except on the dissolution or final liquidation of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746a56ca-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not make a loan or advance to an officer or member of the executive council. Members of the council who vote for or assent to making a loan or advance to an officer or member of the council, and officers who participate in making the loan or advance, are jointly and severally liable to the corporation for the amount of the loan or advance until it is repaid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746a56cb-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1301"},"text":"112 Stat. 1301","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746a56cc-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id746a56cd-3a7