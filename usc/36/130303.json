{"tag":"section","attrib":{"id":"id74907be2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130303"},"text":null,"children":[{"tag":"num","attrib":{"value":"130303"},"text":"§ 130303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74907be3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual is eligible for active membership in the corporation if the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74907be4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of good moral character; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74907be5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has received a Congressional Medal of Honor, a Distinguished Service Cross, a Navy Cross, or an Air Force Cross awarded for acts of extraordinary heroism in connection with military or naval operations against an armed enemy, or for heroism of a specially distinguished character, as a member of the Armed Forces of the United States or any foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74907be6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension of Eligibility to Parents and Descendants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may extend eligibility for membership, either active or associate, to parents and lineal descendants of an individual described in subsection (a) of this section on terms provided in its constitution and bylaws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74907be7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member (except an associate member) has one vote on each matter submitted to a vote at a meeting of the members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74907be8-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1374"},"text":"112 Stat. 1374","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74907be9-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74907bea-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74907beb-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"130303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:636.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1955-08-04/ch546/s6"},"text":"Aug. 4, 1955, ch. 546, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/69/488"},"text":"69 Stat. 488","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 21, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/56/s2"},"text":"Pub. L. 87–56, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/95"},"text":"75 Stat. 95","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “has received” are substituted for “who have received or who may hereafter receive” to eliminate unnecessary words. The words “Navy Cross” are restated before “Air Force Cross” in accordance with the order preferred by the Legion of Valor of the United States of America, Incorporated. The words “as a member” are substituted for “are, have been, or may become members . . . of whatever rank” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “on terms” are substituted for “under such conditions and upon such terms” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “the right to” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of 36:636(d) is omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
