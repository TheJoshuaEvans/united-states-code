{"tag":"section","attrib":{"id":"id748bc0e4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90104"},"text":null,"children":[{"tag":"num","attrib":{"value":"90104"},"text":"§ 90104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id748bc0e5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of Officers and Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The board of directors appoints, removes, and replaces officers and employees of the foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0e6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status and Compensation of Employees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id748bc0e7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Officers and employees of the foundation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id748bc0e8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90104/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not employees of the Federal Government (except as may otherwise be provided in this chapter);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id748bc0e9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90104/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be appointed and removed without regard to the provisions of title 5 governing appointments in the competitive service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id748bc0ea-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90104/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be paid without regard to chapter 51 and subchapter III of chapter 53 of title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0eb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of federal employee rates for travel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of any schedules of rates negotiated by the Administrator of General Services for the use of employees of the Federal Government who travel on official business, officers and employees of the foundation who travel while engaged in the performance of their duties under this chapter shall be deemed to be employees of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id748bc0ec-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tVI/s601/a"},"text":"Pub. L. 107–252, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1719"},"text":"116 Stat. 1719","children":[],"tail":", § 152604; renumbered § 90104, "},{"tag":"ref","attrib":{"href":"/us/pl/113/237/s3/c/6/B"},"text":"Pub. L. 113–237, § 3(c)(6)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2840"},"text":"128 Stat. 2840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id748bc0ed-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id748bc0ee-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id748bc0ef-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/237"},"text":"Pub. L. 113–237","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s152604"},"text":"section 152604 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
