{"tag":"section","attrib":{"id":"id747fda6c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50303"},"text":null,"children":[{"tag":"num","attrib":{"value":"50303"},"text":"§ 50303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id747fda6d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual is eligible for membership in the corporation if the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id747fda6e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id747fda6f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50303/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was wounded, gassed, injured, or disabled in the line of duty during time of war while in the service of the military or naval forces of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id747fda70-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50303/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was honorably discharged or separated from that service or is still in active service in the Armed Forces of the United States; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747fda71-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id747fda72-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50303/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was disabled while serving with any of the Armed Forces of a country associated with the United States as an ally during any of its war periods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id747fda73-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50303/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a citizen of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id747fda74-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50303/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was honorably discharged.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747fda75-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Honorary Memberships","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An honorary membership may not be granted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id747fda76-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text