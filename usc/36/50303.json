tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"50303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:90e.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1932-06-17/ch268/s5"},"text":"June 17, 1932, ch. 268, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/47/321"},"text":"47 Stat. 321","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1942-07-15/ch505/s3"},"text":"July 15, 1942, ch. 505, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/660"},"text":"56 Stat. 660","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “An individual” are substituted for “Any man or woman” and “Others” for consistency in the revised title and to eliminate unnecessary words. In clause (1), the words “either” and “of America” are omitted as unnecessary. In clause (2)(B), the words “citizen of the United States” are substituted for “American citizens” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
