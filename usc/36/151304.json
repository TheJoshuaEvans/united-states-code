{"tag":"section","attrib":{"id":"id749a1945-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151304"},"text":null,"children":[{"tag":"num","attrib":{"value":"151304"},"text":"§ 151304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers and employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id749a1946-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The board of directors may appoint officers or employees, but only after the corporation has sufficient funds to pay for their services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749a1947-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status and Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Officers and employees of the corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749a1948-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be considered employees of the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a1949-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be appointed without regard to the provisions of title 5 governing appointments in the competitive service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a194a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be paid without regard to chapter 51 and subchapter III of chapter 53 of title 5, except that an officer or employee may not be paid more than 15 percent above the annual rate of basic pay for level GS–15 of the General Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5107"},"text":"section 5107 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749a194b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1400"},"text":"112 Stat. 1400","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/503/tI/s113/c"},"text":"Pub. L. 106–503, title I, § 113(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-13"},"text":"Nov. 13, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2304"},"text":"114 Stat. 2304","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/169/tII/s206/b"},"text":"Pub. L. 108–169, title II, § 206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2040"},"text":"117 Stat. 2040","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749a194c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":