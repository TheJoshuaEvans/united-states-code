{"tag":"section","attrib":{"id":"id7489503e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80304"},"text":null,"children":[{"tag":"num","attrib":{"value":"80304"},"text":"§ 80304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The corporation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7489503f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80304/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt and amend a constitution, bylaws, and regulations, including regulations for the election of associates and successors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74895040-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80304/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt and alter a seal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74895041-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80304/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have offices and conduct its activities in the District of Columbia and in the States, territories, and possessions of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74895042-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80304/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, own, lease, encumber, and transfer property, and use any income from the property, as necessary to carry out the purposes of the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74895043-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80304/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sue and be sued within the jurisdiction of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74895044-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s80304/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do any other act necessary to carry out this chapter and the purposes of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74895045-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1362"},"text":"112 Stat. 1362","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74895046-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74895047-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74895048-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80304","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:32 (words after 2d comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-03-16/ch62"},"text":"Mar. 16, 1950, ch. 62","children":[],"tail":", §§ 2 (words after 2d comma), 8, "},{"tag":"html:a","attrib":{"href":"/us/stat/64/23"},"text":"64 Stat. 23","children":[],"tail":", 24."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:34 (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-03-16/ch62/s4"},"text":"Mar. 16, 1950, ch. 62, § 4","children":[],"tail":" (last sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/64/23"},"text":"64 Stat. 23","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-08-14/ch486/s1"},"text":"Aug. 14, 1953, ch. 486, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/582"},"text":"67 Stat. 582","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:38.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the text of 36:38 is omitted as executed and obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the word “amend” is substituted for “and from time to time to alter such constitution, bylaws, rules, and regulations” for consistency in the revised title and to eliminate unnecessary words. The word “rules” is omitted as included in “regulations”. The words “not inconsistent with the laws of the United States, or any State thereof” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the word “destroy” is omitted as unnecessary and for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3), the word “activities” is substituted for “business and affairs” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (4), the words “acquire, own, lease, encumber, and transfer property, and use any income from the property, as necessary to carry out the purposes of the corporation” are substituted for “take, receive, and hold, in trust or otherwise, and to sell and convey real and personal property necessary for its corporate purposes, and other real and personal property, the income from which shall be applied to its corporate purposes” in 36:32 and “authorize and cause to be executed leases, mortgages, and liens upon, and sales and conveyances of, any of the property of the corporation; and the proceeds arising therefrom shall be applied or invested for the use and benefit of the corporation” in 36:34 (last sentence) for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (5), the words “in courts of law and equity” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
