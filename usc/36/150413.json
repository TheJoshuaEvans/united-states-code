{"tag":"section","attrib":{"id":"id74955ea4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150413"},"text":null,"children":[{"tag":"num","attrib":{"value":"150413"},"text":"§ 150413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability for acts of officers and agents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation shall be liable for the acts of the officers and agents of the corporation acting within the scope of their authority.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id74955ea5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLI/s5103/a"},"text":"Pub. L. 118–31, div. E, title LI, § 5103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/938"},"text":"137 Stat. 938","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
