{"tag":"section","attrib":{"id":"id746cc72d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22309"},"text":null,"children":[{"tag":"num","attrib":{"value":"22309"},"text":"§ 22309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and inspection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746cc72e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation shall keep—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id746cc72f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22309/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correct and complete records of account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc730-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22309/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minutes of the proceedings of its members, board of directors, and committees having any of the authority of its board of directors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746cc731-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22309/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at its principal office, a record of the names and addresses of its members entitled to vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746cc732-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s22309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member entitled to vote, or an agent or attorney of the member, may inspect the records of the corporation for any proper purpose, at any reasonable time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746cc733-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1303"},"text":"112 Stat. 1303","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746cc734-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id746cc735-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id746cc736-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib"