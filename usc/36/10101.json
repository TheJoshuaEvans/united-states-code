{"tag":"section","attrib":{"id":"id745e6f3f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s10101"},"text":null,"children":[{"tag":"num","attrib":{"value":"10101"},"text":"§ 10101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id745e6f40-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s10101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided, the financial statements of each corporation in part B of this subtitle shall be audited annually in accordance with generally accepted auditing standards by an independent certified public accountant or independent licensed public accountant, certified or licensed by a regulatory authority of a State or other political subdivision of the United States. The audit shall be conducted where the financial statements of the corporation normally are kept. The person conducting the audit shall be given access to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id745e6f41-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s10101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all records and property owned or used by the corporation necessary to facilitate the audit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id745e6f42-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s10101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" full facilities for verifying transactions with the balances or securities held by depositories, fiscal agents, and custodians.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id745e6f43-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s10101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id745e6f44-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s10101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The corporation shall submit a report of the audit to Congress not later than 6 months after the close of the fiscal year for which the audit is made. The report shall describe the scope of the audit and include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id745e6f45-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s10101/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statements necessary to present fairly the corporation’s assets, liabilities, and surplus or deficit, and an analysis of the changes in those amounts during the year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id745e6f46-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s10101/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement in reasonable detail of the corporation’s income and expenses during the year including the results of any trading, manufacturing, publishing, or other commercial-type endeavor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id745e6f47-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s10101/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the independent auditor’s opinion of those statements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id745e6f48-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s10101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report may not be printed as a public document, except as part of proceedings authorized to be printed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s1332"},"text":"section 1332 of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id745e6f49-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1283"},"text":"112 Stat. 1283","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id745e6f4a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id745e6f4b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id745e6f4c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[