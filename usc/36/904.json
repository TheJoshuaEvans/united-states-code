{"tag":"section","attrib":{"id":"id7454f9e9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904"},"text":null,"children":[{"tag":"num","attrib":{"value":"904"},"text":"§ 904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hostage and Wrongful Detainee flag","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7454f9ea-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Hostage and Wrongful Detainee flag championed by the Bring Our Families Home Campaign is designated as the symbol of the commitment of the United States to recognizing, and prioritizing the freedom of, citizens and lawful permanent residents of the United States held as hostages or wrongfully detained abroad.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7454f9eb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Display","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id7454f9ec-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Hostage and Wrongful Detainee flag shall be displayed at the locations specified in paragraph (3) on the days specified in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7454f9ed-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Days specified","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The days specified in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7454f9ee-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" U.S. Hostage and Wrongful Detainee Day, March 9.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7454f9ef-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Flag Day, June 14.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7454f9f0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Independence Day, July 4.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7454f9f1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Any day on which a citizen or lawful permanent resident of the United States—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7454f9f2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" returns to the United States from being held hostage or wrongfully detained abroad; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7454f9f3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dies while being held hostage or wrongfully detained abroad.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7454f9f4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Locations specified","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The locations specified in this paragraph are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7454f9f5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Capitol.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7454f9f6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The White House.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7454f9f7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The buildings containing the official office of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id7454f9f8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id7454f9f9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7454f9fa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Display To Be in a Manner Visible to the Public","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Display of the Hostage and Wrongful Detainee flag pursuant to this section shall be in a manner designed to ensure visibility to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7454f9fb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section may not be construed or applied so as to require any employee to report to work solely for the purpose of providing for the display of the Hostage and Wrongful Detainee flag.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7454f9fc-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dA/tXVIII/s1804/a/2/A"},"text":"Pub. L. 118–31, div. A, title XVIII, § 1804(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/686"},"text":"137 Stat. 686","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
