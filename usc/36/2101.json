:[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/640"},"text":"70 Stat. 640","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 21, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/480"},"text":"Pub. L. 91–480","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1081"},"text":"84 Stat. 1081","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Apr. 1, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/256"},"text":"Pub. L. 94–256","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/301"},"text":"90 Stat. 301","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:121 (last par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1923-03-04/ch283/s1"},"text":"Mar. 4, 1923, ch. 283, § 1","children":[],"tail":" (last par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/42/1509"},"text":"42 Stat. 1509","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1946-06-26/ch502"},"text":"June 26, 1946, ch. 502","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/60/317"},"text":"60 Stat. 317","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1956-07-25/ch721/s1"},"text":"July 25, 1956, ch. 721, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/640"},"text":"70 Stat. 640","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"2101(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:122.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 26, 1996","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/104/204/tIII"},"text":"Pub. L. 104–204, title III","children":[],"tail":", (2d proviso in par. under heading “American Battle Monuments Commission”), "},{"tag":"html:a","attrib":{"href":"/us/stat/110/2907"},"text":"110 Stat. 2907","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “from time to time” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the text of 36:121 (last par.) is omitted as executed. In clauses (2) and (3), the word “same” is omitted as unnecessary. In clause (2), the words “authorized to be paid” are substituted for “prescribed” for consistency with clause (3) and 37:405.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is based on 36:122 which is from the 2d proviso in the paragraph under the heading “American Battle Monuments Commission” in title III of the Departments of Veterans Affairs and Housing and Urban Development, and Independent Agencies Appropriations Act, 1997 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/204"},"text":"Public Law 104–204","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2907"},"text":"110 Stat. 2907","children":[],"tail":"). The provision has been repeated each year in prior appropriations acts and therefore is restated as a permanent provision. For prior provisions, see citations under 36:122 (1994 ed.). In the restatement, the words “in the same way as” are substituted for “as provided for” for clarity and consistency in the revised title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7454fa0e-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7454fa0f-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" substituted “section 405” for “section 475”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/9"},"text":"Pub. L. 112–239, § 1076(a)(9)","children":[],"tail":", made technical amendment to directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/f/4/B"},"text":"Pub. L. 112–81, § 631(f)(4)(B)","children":[],"tail":". See 2011 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2011—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/81/s631/f/4/B"},"text":"Pub. L. 112–81, § 631(f)(4)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/112/239/s1076/a/9"},"text":"Pub. L. 112–239, § 1076(a)(9)","children":[],"tail":", substituted “475” for “405”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s604/1/A"},"text":"Pub. L. 106–117, § 604(1)(A)","children":[],"tail":", struck out “, United States Code,” after “title 37”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/117/s604/1/B"},"text":"Pub. L. 106–117, § 604(1)(B)","children":[],"tail":", struck out “, United States Code,” after “title 5”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7454fa10-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id7454fa11-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2013 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/239/dA/tX/s1076/a"},"text":"Pub. L. 112–239, div. A, title X, § 1076(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-02"},"text":"Jan. 2, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1947"},"text":"126 Stat. 1947","children":[],"tail":", provided that the amendment made by section 1076(a)(9) is effective "},{"tag":"date","attrib":{"date":"2011-12-31"},"text":"Dec. 31, 2011","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/112/81"},"text":"Pub. L. 112–81","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
