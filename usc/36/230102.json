{"tag":"section","attrib":{"id":"id74bdcdea-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230102"},"text":null,"children":[{"tag":"num","attrib":{"value":"230102"},"text":"§ 230102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are fraternal, patriotic, historical, charitable, and educational, and are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74bdcdeb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve and strengthen comradeship among its members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bdcdec-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist worthy comrades;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bdcded-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perpetuate the memory and history of our dead, and to assist their surviving spouses and orphans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bdcdee-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain true allegiance to the Government of the United States, and fidelity to its Constitution and laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bdcdef-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster true patriotism;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bdcdf0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain and extend the institutions of American freedom; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bdcdf1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve and defend the United States from all enemies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74bdcdf2-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1481"},"text":"112 Stat. 1481","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/242/s2"},"text":"Pub. L. 107–242, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-16"},"text":"Oct. 16, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1497"},"text":"116 Stat. 1497","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/199/s1/b"},"text":"Pub. L. 113–199, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-04"},"text":"Dec. 4, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2058"},"text":"128 Stat. 2058","children":[],"tail":".)"}],"tail":"\n"},{"tag"