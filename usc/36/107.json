{"tag":"section","attrib":{"id":"id744912cc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s107"},"text":null,"children":[{"tag":"num","attrib":{"value":"107"},"text":"§ 107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Columbus Day","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President is requested to issue each year a proclamation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id744912cd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s107/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designating the second Monday in October as Columbus Day;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id744912ce-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s107/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" calling on United States Government officials to display the flag of the United States on all Government buildings on Columbus Day; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id744912cf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s107/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inviting the people of the United States to observe Columbus Day, in schools and churches, or other suitable places, with appropriate ceremonies that express the public sentiment befitting the anniversary of the discovery of America.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id744912d0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"