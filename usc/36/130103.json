{"tag":"section","attrib":{"id":"id748e3285-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130103"},"text":null,"children":[{"tag":"num","attrib":{"value":"130103"},"text":"§ 130103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id748e3286-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id748e3287-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in this chapter, eligibility for membership in the corporation and the rights, privileges, and designation of classes of members are as provided in the constitution and bylaws of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748e3288-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Eligibility for membership is limited to female blood relatives of an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id748e3289-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130103/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" served at any time during the period ","children":[{"tag":"date","attrib":{"date":"1861-04-12"},"text":"April 12, 1861","children":[],"tail":", through "},{"tag":"date","attrib":{"date":"1865-04-09"},"text":"April 9, 1865","children":[],"tail":", as a soldier or sailor in—"}],"tail":null},{"tag":"clause","attrib":{"id":"id748e328a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130103/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Army, Navy, Marine Corps, or Revenue-Cutter Service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id748e328b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130103/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State regiment that was called into active service and was subject to orders of United States general officers during that period; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id748e328c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130103/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was honorably discharged from, or died in, that service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748e328d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s130103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member has one vote on each matter submitted to a vote at a meeting of the members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id748e328e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1371"},"text":"112 Stat. 1371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id748e328f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id748e3290-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id748e3291-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"130103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:78d.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"June 17, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/47/s5"},"text":"Pub. L. 86–47, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/78"},"text":"73 Stat. 78","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “are as provided in the constitution and bylaws of the corporation” are substituted for “shall . . . be determined as the constitution and bylaws of the corporation may provide” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(A), the words “at any time” are added for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
