{"tag":"section","attrib":{"id":"id74b91237-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220526"},"text":null,"children":[{"tag":"num","attrib":{"value":"220526"},"text":"§ 220526.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restricted amateur athletic competitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74b91238-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220526/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusive Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An amateur sports organization that conducts amateur athletic competition shall have exclusive jurisdiction over that competition if participation is restricted to a specific class of amateur athletes, such as high school students, college students, members of the Armed Forces, or similar groups or categories.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b91239-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220526/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sanctions for International Competition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An amateur sports organization under subsection (a) of this section shall obtain a sanction from the appropriate national governing body if the organization wishes to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b9123a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220526/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct international amateur athletic competition in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b9123b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220526/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sponsor international amateur athletic competition to be held outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74b9123c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1475"},"text":"112 Stat. 1475","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74b9123d-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74b9123e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74b9123f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"h