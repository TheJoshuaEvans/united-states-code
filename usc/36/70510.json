{"tag":"section","attrib":{"id":"id74824c14-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70510"},"text":null,"children":[{"tag":"num","attrib":{"value":"70510"},"text":"§ 70510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation shall comply with the law on service of process of the State or District in which it is incorporated.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id74824c15-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1354"},"text":"112 Stat. 1354","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/57/s7"},"text":"Pub. L. 119–57, § 7","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-12"},"text":"Dec. 12, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/712"},"text":"139 Stat. 712","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74824c16-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74824c17-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74824c18-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","childre