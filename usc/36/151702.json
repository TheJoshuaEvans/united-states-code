{"tag":"section","attrib":{"id":"id749c89f0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151702"},"text":null,"children":[{"tag":"num","attrib":{"value":"151702"},"text":"§ 151702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749c89f1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage, accept, and administer private gifts to promote and ensure the preservation and public accessibility of the nation’s film heritage held at the Library of Congress and other public and nonprofit archives throughout the United States and the repatriation of American films from foreign archives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749c89f2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" further the goals of the Library of Congress and the National Film Preservation Board in connection with their activities under the National Film Preservation Act of 1996 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s179"},"text":"2 U.S.C. 179","children":[],"tail":null},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"–179w); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749c89f3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct activities, alone or in cooperation with other film related institutions and organizations, to further the preservation and public accessibility of films made in the United States, particularly films not protected by private interests, for the benefit of present and future generations of Americans.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749c89f4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1404"},"text":"112 Stat. 1404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/336/s3/b/2"},"text":"Pub. L. 110–336, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-02"},"text":"Oct. 2, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3728"},"text":"122 Stat. 3728","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749c89f5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id749c89f6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id749c89f7-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n"