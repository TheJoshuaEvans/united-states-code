{"tag":"section","attrib":{"id":"id74680d49-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21704"},"text":null,"children":[{"tag":"num","attrib":{"value":"21704"},"text":"§ 21704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The corporation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74680d4a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21704/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt a constitution, bylaws, and regulations to carry out the purposes of the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74680d4b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21704/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt and alter a corporate seal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74680d4c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21704/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain offices to conduct its activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74680d4d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21704/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish State and territorial organizations and local chapter or post organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74680d4e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21704/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance and leadership to organizations and local chapters established under paragraph (4), but may not control or otherwise influence the specific activities and conduct of such organizations and local chapters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74680d4f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21704/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, own, lease, encumber, and transfer property as necessary to carry out the purposes of the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746a5640-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21704/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish a magazine and other publications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746a5641-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21704/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sue and be sued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id746a5642-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21704/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do any other act necessary and proper to carry out the purposes of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746a5643-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1297"},"text":"112 Stat. 1297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/66/s1"},"text":"Pub. L. 112–66, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-12-13"},"text":"Dec. 13, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/768"},"text":"125 Stat. 768","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746a5644-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id746a5645-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id746a5646-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21704","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:44 (words before 4th semicolon less perpetual succession, words after 5th semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1919-09-16/ch59/s4"},"text":"Sept. 16, 1919, ch. 59, § 4","children":[],"tail":" (words before 4th semicolon less perpetual succession, words after 5th semicolon), "},{"tag":"html:a","attrib":{"href":"/us/stat/41/285"},"text":"41 Stat. 285","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1953-06-26/ch153/s1"},"text":"June 26, 1953, ch. 153, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/82"},"text":"67 Stat. 82","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:47.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1919-09-16/ch59/s7"},"text":"Sept. 16, 1919, ch. 59, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/41/285"},"text":"41 Stat. 285","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the text of 36:47 is omitted as executed and obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words “not inconsistent with the laws of the United States or of any State” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the words “at pleasure” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3), the word “activities” is substituted for “business” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (5) is substituted for “to receive, hold, own, use, and dispose of such real estate and personal property as shall be necessary for its corporate purposes” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (7), the words “in courts of law and equity” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (8), the words “do any other act” are substituted for “generally to do any and all such acts and things” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id746a5647-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id746a5648-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Pars. (5) to (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/66"},"text":"Pub. L. 112–66","children":[],"tail":" added par. (5) and redesignated former pars. (5) to (8) as (6) to (9), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
