{"tag":"section","attrib":{"id":"id745e6f13-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2308"},"text":null,"children":[{"tag":"num","attrib":{"value":"2308"},"text":"§ 2308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director shall transmit to Congress an annual report on the Director’s stewardship of the authority to operate and maintain the memorial museum. Such report shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id745e6f14-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2308/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An accounting of all financial transactions involving donated funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id745e6f15-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2308/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the extent to which the objectives of this chapter are being met.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id745e6f16-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2308/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An examination of future major endeavors, initiatives, programs, or activities that the Museum proposes to undertake to better fulfill the objectives of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id745e6f17-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2308/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An examination of the Federal role in the funding of the Museum and its activities, and any changes that may be warranted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id745e6f18-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/292/s1"},"text":"Pub. L. 106–292, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-12"},"text":"Oct. 12, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1033"},"text":"114 Stat. 1033","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id745e6f19-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id745e6f1a-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id745e6f1b-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2308, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1280"},"text":"112 Stat. 1280","children":[],"tail":", required the Executive Director to submit an annual report to Congress, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/292"},"text":"Pub. L. 106–292","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
