{"tag":"section","attrib":{"id":"id745017d3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s145"},"text":null,"children":[{"tag":"num","attrib":{"value":"145"},"text":"§ 145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Veterans Day","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President shall issue each year a proclamation calling on the people of the United States to observe two minutes of silence on Veterans Day in honor of the service and sacrifice of veterans throughout the history of the Nation, beginning at—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id745017d4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s145/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3:11 p.m. Atlantic standard time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id745017d5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s145/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2:11 p.m. eastern standard time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id745017d6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s145/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1:11 p.m. central standard time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id745017d7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s145/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 12:11 p.m. mountain standard time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id745017d8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s14