70, ch. 264","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/16/277"},"text":"16 Stat. 277","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"150302(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:254.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1884-06-20/ch107"},"text":"June 20, 1884, ch. 107","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/23/50"},"text":"23 Stat. 50","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1914-05-27/ch101/s1"},"text":"May 27, 1914, ch. 101, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/38/383"},"text":"38 Stat. 383","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the word “rules” is omitted as included in “regulations”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “their division” are substituted for “the division” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “created by death, resignation, or otherwise” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(4), the words “its actions under this subsection” are substituted for “the same” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the word “may” is substituted for “be, and the same is, authorized and empowered to” for consistency in the revised title and to eliminate unnecessary words. In clause (A), the words “either real or personal” are omitted as unnecessary and for consistency in the revised title. In clause (C), the word “reinvest” is omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
