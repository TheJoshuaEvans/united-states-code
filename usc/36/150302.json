{"tag":"section","attrib":{"id":"id74955e48-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150302"},"text":null,"children":[{"tag":"num","attrib":{"value":"150302"},"text":"§ 150302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74955e49-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74955e4a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make its own organization, including adopting a constitution, bylaws, and regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955e4b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the election of domestic and foreign members, their division into classes, and other matters needful or usual in such an institution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955e4c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fill vacancies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955e4d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150302/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report its actions under this subsection to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74955e4e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Property","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74955e4f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The corporation may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74955e50-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150302/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive property by devise, bequest, donation, or otherwise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74955e51-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150302/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold the property absolutely or in trust;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74955e52-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150302/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage and invest the property as provided in the constitution of the corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74955e53-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150302/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the property and income from the property to carry out the purposes of the corporation, subject to instructions of donors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955e54-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Congress at any time may limit the amount of real estate the corporation may acquire and the amount of time it may be held.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74955e55-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1388"},"text":"112 Stat. 1388","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74955e56-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74955e57-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74955e58-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","chi