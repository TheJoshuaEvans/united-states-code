{"tag":"section","attrib":{"id":"id74bb8381-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220551"},"text":null,"children":[{"tag":"num","attrib":{"value":"220551"},"text":"§ 220551.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the term “joint resolution” means a joint resolution—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74bb8382-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220551/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which does not have a preamble; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bb8383-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220551/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74bb8384-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220551/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74bb8385-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220551/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the title is only as follows: “A joint resolution to dissolve the board of directors of the United States Olympic and Paralympic Committee”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74bb8386-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220551/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the matter after the resolving clause—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id74bb8387-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220551/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is as follows: “That Congress finds that dissolving the board of directors of the United States Olympic and Paralympic Committee would not unduly interfere with the operations of chapter 2205 of title 36, United States Code”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id74bb8388-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220551/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribes adequate procedures for forming a board of directors of the corporation as expeditiously as possible and in a manner that safeguards the membership and voting power of the representatives of amateur athletes at all times, consistent with the membership and voting power of amateur athletes under section 220504(b)(2); or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74bb8389-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220551/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id74bb838a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220551/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the title is only as follows: “A joint resolution relating to terminating the recognition of a national governing body”; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id74bb838b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220551/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the matter after the resolving clause is only as follows: “That Congress determines that _________, which is recognized as a national governing body under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s220521"},"text":"section 220521 of title 36","children":[],"tail":", United States Code, has failed to fulfill its duties, as described in "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s220524"},"text":"section 220524 of title 36","children":[],"tail":", United States Code”, the blank space being filled in with the name of the applicable national governing body."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74bb838c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s5/a/2"},"text":"Pub. L. 116–189, § 5(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/946"},"text":"134 Stat. 946","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74bb838d-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id74bb838e-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id74bb838f-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s5/c"},"text":"Pub. L. 116–189, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/947"},"text":"134 Stat. 947","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/189/s5/c"},"text":"“The amendments made by this section [enacting this subchapter and redesignating subchapter III relating to United States Center for SafeSport as subchapter IV] shall take effect on the date that is 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
