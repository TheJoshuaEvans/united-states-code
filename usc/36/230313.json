{"tag":"section","attrib":{"id":"id74bdce8a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230313"},"text":null,"children":[{"tag":"num","attrib":{"value":"230313"},"text":"§ 230313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Termination of existence and distribution of assets","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74bdce8b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Make Contingent Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The national convention, by resolution, may declare that the corporate existence will terminate on the occurrence of a specified event and provide for the disposition of any property remaining after the discharge of all liabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74bdce8c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure for Carrying Out Contingent Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74bdce8d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230313/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An authenticated copy of the national convention’s resolution must be filed in the office of the United States District Court for the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bdce8e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230313/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The court shall take jurisdiction when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74bdce8f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230313/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the declared event has occurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74bdce90-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230313/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a petition is filed with the court reciting the relevant facts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74bdce91-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s230313/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On proof of the facts, the court shall enter an order vesting title and ownership in accordance with the resolution of the national convention.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74bdce92-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1485"},"text":"112 Stat. 1485","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74bdce93-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74bdce94-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74bdce95-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"230313","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:779.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 18, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/530/s19"},"text":"Pub. L. 85–530, § 19","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/375"},"text":"72 Stat. 375","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “declare that the corporate existence will terminate on the occurrence of a specified event” are substituted for “declare the event upon which the corporate existence of the organization is to terminate” for clarity. The word “satisfaction” is omitted as included in “discharge”, and the word “obligations” is omitted as included in “liabilities”. The word “outstanding” is omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the word “duly” is omitted as unnecessary. The word “must” is substituted for “shall” for clarity because the filing is only required if the national convention decides to exercise its discretionary authority under subsection (a).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2)(B), the word “relevant” is substituted for “said” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the word “due” is omitted as unnecessary. The word “order” is substituted for “decree” for consistency in the revised title and with other titles of the United States Code. The word “vesting” is substituted for “which shall be effective to vest” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
