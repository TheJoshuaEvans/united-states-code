{"tag":"section","attrib":{"id":"id747b1fac-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728A"},"text":null,"children":[{"tag":"num","attrib":{"value":"40728A"},"text":"§ 40728A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of excess firearms, ammunition, and parts granted to foreign countries and transfer to corporation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id747b1fad-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Recover","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army may recover from any country to which surplus firearms, ammunition, repair parts, or other supplies described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40732/a"},"text":"section 40732(a) of this title","children":[],"tail":" are furnished on a grant basis under the conditions imposed by section 505 of the Foreign Assistance Act of 1961 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2314"},"text":"22 U.S.C. 2314","children":[],"tail":") any such surplus firearms, ammunition, repair parts, or supplies that become excess to the needs of such country."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1fae-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost of Recovery","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1faf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the cost of recovery of any surplus firearms, ammunition, repair parts, or supplies under subsection (a) shall be treated as incremental direct costs incurred in providing logistical support to the corporation for which reimbursement shall be required as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40727/a"},"text":"section 40727(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1fb0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may require the corporation to pay costs of recovery described in paragraph (1) in advance of incurring such costs. Amounts so paid shall not be subject to the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", but shall be administered in accordance with the last sentence of "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s40727/a"},"text":"section 40727(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1fb1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability for Transfer to Corporation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any surplus firearms, ammunition, repair parts, or supplies recovered under subsection (a) shall be available for transfer to the corporation in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40728"},"text":"section 40728 of this title","children":[],"tail":" under such additional terms and conditions as the Secretary shall prescribe for purposes of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id747b1fb2-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/364/dA/tIII/s354/a"},"text":"Pub. L. 109–364, div. A, title III, § 354(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-17"},"text":"Oct. 17, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/2162"},"text":"120 Stat. 2162","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/92/dA/tX/s1087/a/2/A"},"text":"Pub. L. 114–92, div. A, title X, § 1087(a)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-11-25"},"text":"Nov. 25, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1013"},"text":"129 Stat. 1013","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id747b1fb3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id747b1fb4-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id747b1fb5-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1087/a/2/A/i"},"text":"Pub. L. 114–92, § 1087(a)(2)(A)(i)","children":[],"tail":", substituted “surplus firearms” for “rifles” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/92/s1087/a/2/A/ii"},"text":"Pub. L. 114–92, § 1087(a)(2)(A)(ii)","children":[],"tail":", substituted “section 40732(a)” for “section 40731(a)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
