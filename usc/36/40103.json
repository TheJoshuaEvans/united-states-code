{"tag":"section","attrib":{"id":"id74763df1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103"},"text":null,"children":[{"tag":"num","attrib":{"value":"40103"},"text":"§ 40103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are as provided in the articles of incorporation and include a continuing commitment, on a national basis, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74763df2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve, protect, and defend the Constitution of the United States and the laws of the States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74763df3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commemorate the wars, campaigns, and military actions of the United States to reflect profound respect, high honor, and great tribute on the glorious dead and the surviving veterans of those wars, campaigns, and actions and to give all Americans a greater understanding of and appreciation for the sacrifices of those who participated in them for all Americans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74763df4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stimulate to the highest degree possible the interests of the entire Nation in the problems of veterans, their widows, and orphans;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74763df5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperate to the fullest extent and in a harmonious manner with all veterans’ organizations in common projects designed to serve the interests of all veterans of all wars in which the United States has participated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74763df6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collate, preserve, and encourage the study of historical episodes, chronicles, mementos, and events pertaining to the wars, campaigns, and military actions of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74763df7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inculcate an enduring love of country, a deep and abiding sense of patriotism, and a profound commitment to Americanism among all the people of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74763df8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage, among the youth of our Nation, respect for our national flag, our anthem, and the traditions of America;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74763df9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve the freedoms of all the people, national peace, prosperity, tranquility, good will, the permanence of free institutions, and the defense of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74763dfa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" foster the association of veterans of the Catholic faith who have served in the Armed Forces of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74763dfb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage morality in government, labor, management, economic, social, fraternal, and all other phases of American life;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74763dfc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the realization that the family is the basic unit of society;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74763dfd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase our love, honor, and service to God and to our fellow man without regard to race, creed, color, or national origin; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74763dfe-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40103/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" function as a veterans’ and patriotic organization as authorized by the laws of each State in which it is incorporated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74763dff-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1329"},"text":"112 Stat. 1329","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s5/6"},"text":"Pub. L. 109–284, § 5(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1212"},"text":"120 Stat. 1212","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74763e00-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74763e01-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74763e02-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"