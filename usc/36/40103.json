"topic":"editorialNotes","id":"id74763e03-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74763e04-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284"},"text":"Pub. L. 109–284","children":[],"tail":" substituted “laws of each State” for “laws of the each State”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
