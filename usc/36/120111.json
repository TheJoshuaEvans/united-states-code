{"tag":"section","attrib":{"id":"id748e3268-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s120111"},"text":null,"children":[{"tag":"num","attrib":{"value":"120111"},"text":"§ 120111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The corporation shall submit to Congress an annual report on the activities of the corporation during the preceding fiscal year. The report shall be submitted at the same time as the report of the audit required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s10101/b"},"text":"section 10101(b) of this title","children":[],"tail":". The report may not be printed as a public document."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id748e3269-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/254/s1/a/2"},"text":"Pub. L. 110–254, § 1(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2421"},"text":"122 Stat. 2421","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
