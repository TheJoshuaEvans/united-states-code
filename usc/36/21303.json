{"tag":"section","attrib":{"id":"id74680ccd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21303"},"text":null,"children":[{"tag":"num","attrib":{"value":"21303"},"text":"§ 21303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The corporation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74680cce-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21303/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt a constitution and bylaws; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74680ccf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21303/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold property in the District of Columbia necessary to carry out the purposes of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74680cd0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1295"},"text":"112 Stat. 1295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74680cd1-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74680cd2-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74680cd3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:20 (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1889-01-04/ch20"},"text":"Jan. 4, 1889, ch. 20","children":[],"tail":", (2d sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/25/640"},"text":"25 Stat. 640","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 3, 1957","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/83/s1"},"text":"Pub. L. 85–83, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/71/276"},"text":"71 Stat. 276","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words “not inconsistent with law” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the word “property” is substituted for “real and personal estate”, and the word “necessary” is substituted for “so far only as may be necessary”, to eliminate unnecessary words. The words “to carry out the purposes of the corporation” are substituted for “to its lawful ends” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id74680cd4-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id74680cd5-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Tax Exemption of Real Property","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/85/83/s2"},"text":"Pub. L. 85–83, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1957-07-03"},"text":"July 3, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/71/277"},"text":"71 Stat. 277","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/85/83/s2"},"text":"“The real property situated in Square 817, in the city of Washington, District of Columbia, described as lot 23, owned, occupied, and used by the American Historical Association, is exempt from all taxation so long as the same is so owned and occupied, and not used for commercial purposes, subject to the provisions of sections 2, 3, and 5 of the Act entitled ‘An Act to define the real property exempt from taxation in the District of Columbia’, approved ","children":[{"tag":"date","attrib":{"date":"1942-12-24"},"text":"December 24, 1942","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/56/1089"},"text":"56 Stat. 1089","children":[],"tail":"; D.C. Code, secs. 47–801b, 47–801c, and 47–801e).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
