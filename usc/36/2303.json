{"tag":"section","attrib":{"id":"id745c25ff-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2303"},"text":null,"children":[{"tag":"num","attrib":{"value":"2303"},"text":"§ 2303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation; travel expenses; full-time officers or employees of United States or Members of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id745c2600-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b) of this section, members of the Council are each authorized to be paid the daily equivalent of the annual rate of basic pay in effect for positions at level IV of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5315"},"text":"section 5315 of title 5","children":[],"tail":", for each day (including travel time) during which they are engaged in the actual performance of duties of the Council. While away from their homes or regular places of business in the performance of services for the Council, members of the Council shall be allowed travel expenses, including per diem in lieu of subsistence, in the same manner as persons employed intermittently in Government service are allowed expenses under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id745c2601-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s2303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the Council who are full-time officers or employees of the United States or Members of Congress shall receive no additional pay by reason of their service on the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id745c2602-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/292/s1"},"text":"Pub. L. 106–292, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-12"},"text":"Oct. 12, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1032"},"text":"114 Stat. 1032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id745c2603-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id745c2604-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id745c2605-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2303, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1278"},"text":"112 Stat. 1278","children":[],"tail":", related to the Executive Director of the Holocaust Memorial Council, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/106/292"},"text":"Pub. L. 106–292","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
