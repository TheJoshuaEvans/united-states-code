{"tag":"section","attrib":{"id":"id748e3251-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s120106"},"text":null,"children":[{"tag":"num","attrib":{"value":"120106"},"text":"§ 120106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id748e3252-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s120106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stock and Dividends","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not issue stock or declare or pay a dividend.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748e3253-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s120106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Political Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation, or a director or officer of the corporation as such, may not contribute to, support, or participate in any political activity or in any manner attempt to influence legislation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748e3254-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s120106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not make a loan to a director, officer, or employee of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748e3255-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s120106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claim of Governmental Approval or Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation may not claim congressional approval, or the authority of the United States, for any activity of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748e3256-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s120106/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corporate Status","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall maintain its status as a corporation incorporated under the laws of the State of New York.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id748e3257-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/254/s1/a/2"},"text":"Pub. L. 110–254, § 1(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-30"},"text":"June 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2420"},"text":"122 Stat. 2420","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
