{"tag":"section","attrib":{"id":"id74aabae6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190110"},"text":null,"children":[{"tag":"num","attrib":{"value":"190110"},"text":"§ 190110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74aabae7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"District of Columbia","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall have a designated agent in the District of Columbia to receive service of process for the corporation. Notice to or service on the agent is notice to or service on the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74aabae8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"States, Territories, and Possessions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As a condition to the exercise of any power or privilege granted by this chapter, the corporation shall file, with the secretary of state or other designated official of each State, territory, or possession of the United States in which a subordinate department or local chapter is organized, the name and address of an agent in that State, territory, or possession on whom legal process or demands against the corporation may be served.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74aabae9-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},