{"tag":"section","attrib":{"id":"id748bc113-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90109"},"text":null,"children":[{"tag":"num","attrib":{"value":"90109"},"text":"§ 90109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil action by Attorney General for equitable relief","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Attorney General may bring a civil action in the United States District Court for the District of Columbia for appropriate equitable relief if the foundation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id748bc114-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90109/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engages or threatens to engage in any act, practice, or policy that is inconsistent with the purposes in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s90102"},"text":"section 90102 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc115-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90109/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuses, fails, or neglects to carry out its obligations under this chapter or threatens to do so.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id748bc116-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tVI/s601/a"},"text":"Pub. L. 107–252, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1721"},"text":"116 Stat. 1721","children":[],"tail":", § 152609; renumbered § 90109 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/237/s3/c/6