{"tag":"section","attrib":{"id":"id749ed4b9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152407"},"text":null,"children":[{"tag":"num","attrib":{"value":"152407"},"text":"§ 152407.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Provision and acceptance of support by Librarian of Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id749ed4ba-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152407/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision by Librarian","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id749ed4bb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152407/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Librarian may provide personnel, facilities, and other administrative services to the corporation. Administrative services may include reimbursement of expenses under section 152403(f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749ed4bc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152407/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The corporation shall reimburse the Librarian for support provided under paragraph (1) of this subsection. Amounts reimbursed shall be deposited in the Treasury to the credit of the appropriations then current and chargeable for the cost of providing the support.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed4bd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152407/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance by Librarian","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Librarian may accept, without regard to chapters 33 and 51 and subchapter III of chapter 53 of title 5 and related regulations, the services of the corporation and its directors, officers, and employees as volunteers in performing functions authorized under this chapter, without compensation from the Library of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749ed4be-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tII/s201/a"},"text":"Pub. L. 106–474, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2094"},"text":"114 Stat. 2094","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
