{"tag":"section","attrib":{"id":"id74955e95-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150411"},"text":null,"children":[{"tag":"num","attrib":{"value":"150411"},"text":"§ 150411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and inspection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74955e96-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation shall keep—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74955e97-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150411/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correct and complete books and records of accounts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955e98-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150411/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minutes of any proceeding of the corporation involving any member of the corporation, the board of directors, or any committee having authority under the board of directors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955e99-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150411/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at the principal office of the corporation, a record of the names and addresses of all members of the corporation having the right to vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74955e9a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74955e9b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150411/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All books and records of the corporation may be inspected by any member having the right to vote, or by any agent or attorney of such a member, for any proper purpose, at any reasonable time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74955e9c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150411/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section contravenes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74955e9d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150411/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the laws of the jurisdiction under which the corporation is incorporated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74955e9e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150411/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the laws of those jurisdictions within the United States and its territories within which the corporation carries out activities in furtherance of the purposes of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74955e9f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/31/dE/tLI/s5103/a"},"text":"Pub. L. 118–31, div. E, title LI, § 5103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-22"},"text":"Dec. 22, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/937"},"text":"137 Stat. 937","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
