{"tag":"section","attrib":{"id":"id747d6907-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50103"},"text":null,"children":[{"tag":"num","attrib":{"value":"50103"},"text":"§ 50103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id747d6908-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provided in Articles of Incorporation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purposes of the corporation are as provided in the articles of incorporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747d6909-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Perpetuating Memories","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To perpetuate the memories of the fathers of the Daughters of Union Veterans of the Civil War 1861–1865, their loyalty to the Union, and their unselfish sacrifices for the preservation of the Union, the purposes of the corporation also include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id747d690a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging the preservation of historic sites and the construction and preservation of monuments commemorating any aspect of the Civil War;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747d690b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" building and maintaining a Museum of Civil War History, admission to which shall be free and open to the public, in the city of Springfield, Illinois, as a repository of Civil War documents, artifacts, and cultural relics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747d690c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining a library in connection with the Civil War museum, admission to which shall be open to the public, containing the official volumes of the War of the Rebellion Records, Civil War genealogical files, Adjutant General reports of the various States, military and biographical records and accounts of the individual service of Union soldiers, sailors, and marines, diaries, letters, relics, and other records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747d690d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promulgating and teaching American history, particularly the history of the Civil War period, through the establishment of scholarship programs at the national and State levels, the presentation of American flags to youth groups and newly naturalized citizens, and the sponsorship of contests of educational merit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747d690e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50103/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" caring for veterans of all wars through volunteer programs in Department of Veterans Affairs medical centers and in homes and other institutions maintained by the States for the welfare of American veterans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747d690f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50103/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating, in a spirit of cooperation and reciprocity, in programs with other societies devoted to American history, veterans’ affairs, or community interests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747d6910-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s50103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veterans’ and Patriotic Organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall function as a veterans’ and patriotic organization as authorized by the laws of each State in which it is incorporated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id747d6911-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1341"},"text":"112 Stat. 1341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id747d6912-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id747d6913-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id747d6914-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"50103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:3703.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Dec. 9, 1985","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/172/s3"},"text":"Pub. L. 99–172, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/99/1020"},"text":"99 Stat. 1020","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/54/s13/n/8"},"text":"Pub. L. 102–54, § 13(n)(8)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/278"},"text":"105 Stat. 278","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “objects” is omitted as included in “purposes” and for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
