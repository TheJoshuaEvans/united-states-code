{"tag":"section","attrib":{"id":"id749ed470-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152401"},"text":null,"children":[{"tag":"num","attrib":{"value":"152401"},"text":"§ 152401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id749ed471-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Recording Preservation Foundation (in this chapter, the “corporation”) is a federally chartered corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed472-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nature of Corporation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation is a charitable and nonprofit corporation and is not an agency or establishment of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749ed473-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s152401/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Perpetual Existence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided, the corporation has perpetual existence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749ed474-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/474/tII/s201/a"},"text":"Pub. L. 106–474, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-09"},"text":"Nov. 9, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2091"},"text":"114 Stat. 2091","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
