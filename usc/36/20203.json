{"tag":"section","attrib":{"id":"id74632ab6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20203"},"text":null,"children":[{"tag":"num","attrib":{"value":"20203"},"text":"§ 20203.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74632ab7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20203/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are as provided in its bylaws and articles of incorporation and include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74632ab8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20203/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" helping to maintain a highly dedicated and professional corps of enlisted personnel within the United States Air Force, including the United States Air Force Reserve, and the Air National Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74632ab9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20203/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supporting fair and equitable legislation and Department of the Air Force policies and influencing by lawful means departmental plans, programs, policies, and legislative proposals that affect enlisted personnel of the Regular Air Force, the Air Force Reserve, and the Air National Guard, its retirees, and other veterans of enlisted service in the Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74632aba-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20203/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actively publicizing the roles of enlisted personnel in the United States Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74632abb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20203/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participating in civil and military activities, youth programs, and fundraising campaigns that benefit the United States Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74632abc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20203/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the mutual welfare of members of the corporation and their families;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74632abd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20203/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting in recruiting for the United States Air Force;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74632abe-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20203/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assembling together for social activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74632abf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20203/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining an adequate Air Force for our beloved country;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74632ac0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20203/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fostering among the members of the corporation a devotion to fellow airmen; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74632ac1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20203/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving the United States and the United States Air Force loyally, and doing all else necessary to uphold and defend the Constitution of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74632ac2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s20203/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corporate Function","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall function as an educational, patriotic, civic, historical, and research organization under the laws of the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74632ac3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/354/s1/4/A"},"text":"Pub. L. 105–354, § 1(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-03"},"text":"Nov. 3, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3240"},"text":"112 Stat. 