{"tag":"section","attrib":{"id":"id749c89e8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151701"},"text":null,"children":[{"tag":"num","attrib":{"value":"151701"},"text":"§ 151701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id749c89e9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"National Film Preservation Foundation (in this chapter, the “corporation”) is a federally chartered corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749c89ea-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nature of Corporation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation is a charitable and nonprofit corporation and is not an agency or establishment of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749c89eb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Perpetual Existence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided, the corporation has perpetual existence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749c89ec-3a70-11f1-9d