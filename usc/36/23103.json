{"tag":"section","attrib":{"id":"id746f3879-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s23103"},"text":null,"children":[{"tag":"num","attrib":{"value":"23103"},"text":"§ 23103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id746f387a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s23103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this chapter, eligibility for membership in the corporation and the rights, privileges, and designation of classes of members are as provided in the bylaws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id746f387b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s23103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member given voting rights by the bylaws has one vote on each matter submitted to a vote at a meeting of the voting members. The vote may be cast in the manner provided in the bylaws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id746f387c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1312"},"text":"112 Stat. 1312","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746f387d-3a7