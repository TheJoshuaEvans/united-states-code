{"tag":"section","attrib":{"id":"id74b6a1a5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220521"},"text":null,"children":[{"tag":"num","attrib":{"value":"220521"},"text":"§ 220521.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification of national governing bodies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74b6a1a6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220521/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to each sport included on the program of the Olympic Games, the Paralympic Games, the Pan-American Games, or the Parapan American Games, the corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b6a1a7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220521/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may certify as a national governing body an amateur sports organization, a high-performance management organization, or a paralympic sports organization that files an application and is eligible for such certification under section 220522; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b6a1a8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220521/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not certify more than 1 national governing body.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b6a1a9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220521/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Hearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before certifying an organization as a national governing body, the corporation shall hold at least 2 public hearings on the application. The corporation shall publish notice of the time, place, and nature of the hearings. Publication shall be made in a regular issue of the corporation’s principal publication at least 30 days, but not more than 60 days, before the date of the hearings. The corporation shall send written notice, which shall include a copy of the application, at least 30 days prior to the date of any such public hearing to all amateur sports organizations known to the corporation in that sport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b6a1aa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220521/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendation to International Sports Federation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 61 days after certifying an organization as a national governing body, the corporation shall recommend and support in any appropriate manner the national governing body to the appropriate international sports federation as the representative of the United States for that sport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b6a1ab-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220521/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 8 years after the date of the enactment of the Empowering Olympic, Paralympic, and Amateur Athletes Act of 2020, and not less frequently than once every 4 years thereafter, the corporation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74b6a1ac-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220521/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall review all matters related to the continued certification of an organization as a national governing body;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b6a1ad-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220521/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may take action the corporation considers appropriate, including placing conditions on the continued certification of an organization as a national governing body;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b6a1ae-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220521/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall submit to Congress a summary report of each review under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74b6a1af-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220521/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall make each such summary report available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74b6a1b0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1471"},"text":"112 Stat. 1471","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s142"},"text":"Pub. L. 105–277, div. C, title I, § 142","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-607"},"text":"112 Stat. 2681–607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/284/s5/20"},"text":"Pub. L. 109–284, § 5(20)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-09-27"},"text":"Sept. 27, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1212"},"text":"120 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/189/s7/a/1"},"text":"Pub. L. 116–189, § 7(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/955"},"text":"134 Stat. 955","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74b6a1b1-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74b6a1b2-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74b6a1b3-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220521(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:391(a) (1st, 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-21/ch975"},"text":"Sept. 21, 1950, ch. 975","children":[],"tail":", title II, §§ 201(a), (d), 204, 205(b)(5), as added "},{"tag":"html:span","attrib":{},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/606/s2"},"text":"Pub. L. 95–606, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/3050"},"text":"92 Stat. 3050","children":[],"tail":", 3052, 3055, 3057."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220521(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:391(a) (3d–last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220521(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:391(d).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"36:395(b)(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220521(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:394.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “under the authority granted under this subchapter and in accordance with the procedures and requirements of this section” are omitted as unnecessary. The words “public hearing” are substituted for “hearing open to the public”, and the words “for such recognition” are omitted, to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “in accordance with subsection (a) of this section” in 36:391(d) and “in accordance with this subsection” in 36:395(b)(5) are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74b6a1b4-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id74b6a1b5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Empowering Olympic, Paralympic, and Amateur Athletes Act of 2020, referred to in subsec. (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189"},"text":"Pub. L. 116–189","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2020-10-30"},"text":"Oct. 30, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74b6a1b6-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s7/a/1/A"},"text":"Pub. L. 116–189, § 7(a)(1)(A)","children":[],"tail":", substituted “Certification of national governing bodies” for “Recognition of amateur sports organizations as national governing bodies” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s7/a/1/B"},"text":"Pub. L. 116–189, § 7(a)(1)(B)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) provided general authority for the corporation to recognize an eligible amateur sports organization as a national governing body."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s7/a/1/C"},"text":"Pub. L. 116–189, § 7(a)(1)(C)","children":[],"tail":", (D), substituted “certifying” for “recognizing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189/s7/a/1/E"},"text":"Pub. L. 116–189, § 7(a)(1)(E)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, text read as follows: “The corporation may review all matters related to the continued recognition of an organization as a national governing body and may take action it considers appropriate, including placing conditions on the continued recognition.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/284"},"text":"Pub. L. 109–284","children":[],"tail":" substituted “subsection” for “subsections”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142"},"text":"Pub. L. 105–277, § 142","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1), inserted first sentence and struck out former first sentence which read as follows: “For any sport that is included on the program of the Olympic Games or the Pan-American Games, the corporation may recognize as a national governing body an amateur sports organization that files an application and is eligible under "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s220522"},"text":"section 220522 of this title","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142"},"text":"Pub. L. 105–277, § 142","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), substituted “approved, except as provided in section 220522(b) with respect to a paralympic sports organization.” for “approved.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s142"},"text":"Pub. L. 105–277, § 142","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(3)–(5), substituted “hold at least 2 public hearings” for “hold a public hearing”, substituted “hearings.” for “hearing.” in two places, and inserted at end “The corporation shall send written notice, which shall include a copy of the application, at least 30 days prior to the date of any such public hearing to all amateur sports organizations known to the corporation in that sport.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
