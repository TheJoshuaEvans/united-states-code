{"tag":"section","attrib":{"id":"id7497a84e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150710"},"text":null,"children":[{"tag":"num","attrib":{"value":"150710"},"text":"§ 150710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and inspection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7497a84f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation shall keep—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7497a850-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150710/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correct and complete records of account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7497a851-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150710/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minutes of the proceedings of its annual national conference, board of directors, and committees having any of the authority of its board of directors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7497a852-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150710/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at its principal office, a record of the names and addresses of its members entitled to vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7497a853-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member entitled to vote, or an agent or attorney of the member, may inspect the records of the corporation for any proper purpose, at any reasonable time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7497a854-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1394"},"text":"112 Stat. 1394","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7497a855-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7497a856-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id7497a857-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children"