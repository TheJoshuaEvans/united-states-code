{"tag":"section","attrib":{"id":"id748bc0b9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90101"},"text":null,"children":[{"tag":"num","attrib":{"value":"90101"},"text":"§ 90101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id748bc0ba-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Help America Vote Foundation (in this chapter, the “foundation”) is a federally chartered corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0bb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nature of Foundation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The foundation is a charitable and nonprofit corporation and is not an agency or establishment of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0bc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Perpetual Existence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided, the foundation has perpetual existence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id748bc0bd-3a70-11f1-9d9e-dfac6d46cab7