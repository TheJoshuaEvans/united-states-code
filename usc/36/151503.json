{"tag":"section","attrib":{"id":"id749c899f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151503"},"text":null,"children":[{"tag":"num","attrib":{"value":"151503"},"text":"§ 151503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id749c89a0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are as provided in the articles of incorporation and include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749c89a1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bringing into working relations with one another, music clubs and other musical organizations and individuals associated with musical activity for the purpose of developing and maintaining high musical standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749c89a2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aiding and encouraging musical education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749c89a3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151503/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting American music and American artists throughout the United States and the world.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749c89a4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Patriotic, Civic, and Historical Organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall function as a patriotic, civic, and historical organization as authorized by the laws of each State in which it is incorporated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749c89a5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1402"},"text":"112 Stat. 1402","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749c89a6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id749c89a7-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id749c89a8-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Hi