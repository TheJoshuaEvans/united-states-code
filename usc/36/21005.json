","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36 App.:5908(g) (related to directors and officers).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s5908/g"},"text":"section 5908(g) of this title","children":[],"tail":"” and “and in conformity with the laws of the State of Texas” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “The requirements for serving as a director or officer” are substituted for “in determining the requirements for serving on the board of directors or as an officer of the association” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
