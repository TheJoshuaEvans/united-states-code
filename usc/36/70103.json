{"tag":"section","attrib":{"id":"id747fdb0e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70103"},"text":null,"children":[{"tag":"num","attrib":{"value":"70103"},"text":"§ 70103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id747fdb0f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are as provided in its articles of incorporation and bylaws and include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id747fdb10-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upholding and defending the Constitution of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747fdb11-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aiding and maintaining an adequate naval defense for the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747fdb12-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting the recruitment of the best personnel available for the United States Navy, United States Marine Corps, and United States Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747fdb13-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing for the welfare of the personnel who serve in the United States Navy, United States Marine Corps, and United States Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747fdb14-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70103/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing to loyally serve the United States Navy, United States Marine Corps, and United States Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747fdb15-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70103/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserving the spirit of shipmanship by providing assistance to shipmates and their families; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747fdb16-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70103/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instilling love of the United States and its flag, and promoting soundness of mind and body, in the youth of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747fdb17-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s70103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corporate Function","children":[],"tail":".—"}],"tail":nul