{"tag":"section","attrib":{"id":"id7497a81a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150704"},"text":null,"children":[{"tag":"num","attrib":{"value":"150704"},"text":"§ 150704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7497a81b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The national officers of the corporation are a president, a first vice president, a second vice president, a third vice president, a secretary, and a treasurer. The president is chairman of the board of directors and of the executive committee described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s150705/d"},"text":"section 150705(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7497a81c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s150704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The national officers are elected biennially from among the officers and members of the member agencies and organizations participating in the annual national conference on citizenship, by a majority vote of the agencies and organizations sending delegates to, and participating in, the conference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7497a81d-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1392"},"text":"112 Stat. 1392","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7497a81e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7497a81f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id7497a820-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"150704","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:437.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1953-08-13/ch427/s7"},"text":"Aug. 13, 1953, ch. 427, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/67/563"},"text":"67 Stat. 563","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “For the purposes of initiating the corporation, the national officers shall be elected within ten days of ","children":[{"tag":"date","attrib":{"date":"1953-08-13"},"text":"August 13, 1953","children":[],"tail":", by the persons named in "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s431"},"text":"section 431 of this title","children":[],"tail":", to serve until the final session of the next following annual conference. Thereafter” are omitted as obsolete. The words “one vote to each such agency and to each such organization” are omitted because section 150703(b) of the revised title already states that each of those agencies and organizations has one vote."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
