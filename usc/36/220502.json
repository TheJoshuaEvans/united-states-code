:null,"children":[{"tag":"html:p","attrib":{},"text":"36:372.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1950-09-21/ch975"},"text":"Sept. 21, 1950, ch. 975","children":[],"tail":", title I, §§ 102, 105(a) (words before cl. (1) related to perpetual succession), as added "},{"tag":"html:span","attrib":{},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/606/s1/b"},"text":"Pub. L. 95–606, § 1(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/3045"},"text":"92 Stat. 3045","children":[],"tail":", 3047."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220502(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:375(a) (words before cl. (1) related to perpetual succession).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220502(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:383.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 10, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/407"},"text":"Pub. L. 88–407","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/383"},"text":"78 Stat. 383","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is substituted for the source provisions for consistency in the revised title and to eliminate unnecessary and executed words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Except as otherwise provided” are added, the word “has” is substituted for “shall have”, and the word “existence” is substituted for “succession”, for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “The corporation known as the United States Olympic Association, which was incorporated by this chapter, shall be known and designated on and after ","children":[{"tag":"date","attrib":{"date":"1964-08-10"},"text":"August 10, 1964","children":[],"tail":", as the United States Olympic Committee and” are omitted as executed. The words “such corporation under the name of” are omitted as unnecessary. The words “is deemed to” are substituted for “shall be held to” for clarity. The words “such corporation under and by the name of” are omitted as unnecessary."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74b1e69b-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74b1e69c-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/189"},"text":"Pub. L. 116–189","children":[],"tail":" amended subsec. (c) generally. Prior to amendment, text read as follows: “Any reference to the United States Olympic Association is deemed to refer to the United States Olympic Committee.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
