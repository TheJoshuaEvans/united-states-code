{"tag":"section","attrib":{"id":"id74b1e693-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220502"},"text":null,"children":[{"tag":"num","attrib":{"value":"220502"},"text":"§ 220502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74b1e694-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation is a federally chartered corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b1e695-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Perpetual Existence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided, the corporation has perpetual existence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74b1e696-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References to United States Olympic Association and United States Olympic Committee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference to the United States Olympic Association or the United States Olympic Committee is deemed to refer to the United States Olympic and Paralympic Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredi