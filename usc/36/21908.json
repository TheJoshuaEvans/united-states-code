{"tag":"section","attrib":{"id":"id746a5697-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21908"},"text":null,"children":[{"tag":"num","attrib":{"value":"21908"},"text":"§ 21908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than January 1 of each year, the corporation shall submit a report to Congress on the activities of the corporation during the prior calendar year, including a complete report of its receipts and expenditures. The report may not be printed as a public document.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id746a5698-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1299"},"text":"112 Stat. 1299","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id746a5699-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id746a569a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id746a569b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{}