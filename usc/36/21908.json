8/636"},"text":"78 Stat. 636","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “submit” is substituted for “make and transmit”, and the word “activities” is substituted for “proceedings”, for consistency in the revised title. The word “full” is omitted as included in “complete”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
