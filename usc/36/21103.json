{"tag":"section","attrib":{"id":"id74659c70-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21103"},"text":null,"children":[{"tag":"num","attrib":{"value":"21103"},"text":"§ 21103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are as provided in the articles of incorporation and include a continuing commitment, on a national basis, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74659c71-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep alive and develop the spirit that promoted world services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c72-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain the ties of fellowship born of that service, and assist and further all patriotic work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c73-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21103/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inculcate a sense of individual obligation to the community, State, and Nation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c74-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21103/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist veterans of World War I, World War II, the Korean Conflict, Vietnam, and other strategic areas and their dependents in the presentation of claims to the Department of Veterans Affairs, and aid in any way in their power the men and women who served and died or were wounded or incapacitated during hostilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c75-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21103/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perpetuate the memory of those whose lives were sacrificed in our wars;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c76-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21103/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain true allegiance to the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c77-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21103/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inculcate lessons of patriotism and love of country in the communities in which we live;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c78-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21103/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspire respect for the Stars and Stripes in the youth of America;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c79-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21103/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend needful assistance to all Gold Star Mothers and, when possible, to their descendants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c7a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21103/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote peace and good will for the United States and all other Nations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74659c7b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1292"},"text":"112 Stat. 1292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74659c7c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74659c7d-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74659c7e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:2403.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"June 12, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/314/s3"},"text":"Pub. L. 98–314, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/237"},"text":"98 Stat. 237","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/54/s13/n/6"},"text":"Pub. L. 102–54, § 13(n)(6)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/278"},"text":"105 Stat. 278","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Before clause (1), the word “objects” is omitted as included in “purposes”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (6), the words “of America” are omitted for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
