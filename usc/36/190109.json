{"tag":"section","attrib":{"id":"id74aabada-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190109"},"text":null,"children":[{"tag":"num","attrib":{"value":"190109"},"text":"§ 190109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and inspection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74aabadb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation shall keep—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74aabadc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190109/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" correct and complete records of account;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74aabadd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190109/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minutes of the proceedings of its national conventions, national executive committee, and other national entities of the corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74aabade-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s190109/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at its principal office, a record of the names and addresses of its members entitled to vote.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74aabadf-3a70-11f1-9d9e-dfac6d46cab7