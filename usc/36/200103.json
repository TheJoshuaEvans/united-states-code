{"tag":"section","attrib":{"id":"id74aabb5f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s200103"},"text":null,"children":[{"tag":"num","attrib":{"value":"200103"},"text":"§ 200103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The corporation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74aabb60-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s200103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt a constitution and bylaws for the management of its property and the regulation of its affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74aabb61-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s200103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74aabb62-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s200103/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold property, in the District of Columbia or elsewhere, necessary to carry out the purposes of the corporation, in an amount not to exceed $1,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74aabb63-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s200103/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold other property donated or bequeathed in any State or territory of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74aabb64-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1451"},"text":"112 Stat. 1451","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74ad2b65-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74ad2b66-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74ad2b67-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"200103","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:5401 (2d sentence words before proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1901-03-03/ch876/s1"},"text":"Mar. 3, 1901, ch. 876, § 1","children":[],"tail":" (2d sentence words before proviso), "},{"tag":"html:a","attrib":{"href":"/us/stat/31/1453"},"text":"31 Stat. 1453","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1938-06-29/ch796"},"text":"June 29, 1938, ch. 796","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/52/1226"},"text":"52 Stat. 1226","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words “not inconsistent with law” are omitted as unnecessary. The words “for the management of its property and the regulation of its affairs” are added for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), subclause (A), the words “hold property” are substituted for “hold real and personal estate”, and the words “necessary to carry out the purposes of the corporation” are substituted for “so far only as may be necessary to its lawful ends”, for consistency in the revised title and to eliminate unnecessary words. In subclause (B), the word “hold” is added for clarity. The words “other property” are substituted for “such other estate” for consistency in the revised title. The words “of the United States” are added for clarity and for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
