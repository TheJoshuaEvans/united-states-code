{"tag":"section","attrib":{"id":"id7492ed31-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140502"},"text":null,"children":[{"tag":"num","attrib":{"value":"140502"},"text":"§ 140502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Principles and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7492ed32-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Principles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The principles underlying the corporation are patriotic allegiance to the United States, fidelity to the Constitution and laws of the United States, the security of civil liberty, and the permanence of free institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7492ed33-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are educational, fraternal, historical, and patriotic, perpetuating the principles of liberty and justice which have created the United States, by—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7492ed34-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commemorating all national patriotic holidays;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ed35-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintaining true allegiance to the Government of the United States and fidelity to its Constitution and laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ed36-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserving and strengthening comradeship and patriotism among its members;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ed37-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140502/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting, comforting, and aiding all needy and distressed members and their dependents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ed38-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140502/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" giving needed hospital and service work through its Department of Veterans Affairs certified service officers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ed39-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140502/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperating with other civic and patriotic organizations having worthy objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ed3a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140502/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keeping alive the achievements and memory of our country’s founders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ed3b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140502/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ever cherishing the memory of General George Washington, who founded the Purple Heart at his headquarters at Newburgh-on-the-Hudson on ","children":[{"tag":"date","attrib":{"date":"1782-08-07"},"text":"August 7, 1782","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ed3c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140502/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" influencing and teaching our citizenry, in a loyal appreciation of the heritages of American citizenship, with its responsibilities and privileges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7492ed3d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s140502/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserving and defending the United States from all enemies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7492ed3e-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1381"},"text":"112 Stat. 1381","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7492ed3f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7492ed40-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id7492ed41-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"140502","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:823.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 26, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/761/s3"},"text":"Pub. L. 85–761, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/856"},"text":"72 Stat. 856","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 13, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/54/s13/n/3"},"text":"Pub. L. 102–54, § 13(n)(3)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/278"},"text":"105 Stat. 278","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “of America” are omitted for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the word “among” is substituted for “amongst” to use more common terminology.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(10), the word “whomsoever” is omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
