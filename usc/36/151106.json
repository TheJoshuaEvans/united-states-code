{"tag":"section","attrib":{"id":"id749a18f3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151106"},"text":null,"children":[{"tag":"num","attrib":{"value":"151106"},"text":"§ 151106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax exemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id749a18f4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Real Property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Real property of the corporation is exempt from taxation if it is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749a18f5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" located in the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a18f6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used for the purposes provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s151102"},"text":"section 151102 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a18f7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not used to produce income.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749a18f8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personal Property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Personal property of the corporation is exempt from taxation if it is used for the purposes provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s151102"},"text":"section 151102 of this title","children":[],"tail":" or to produce income to be used for those purposes."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id749a18f9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The corporation shall submit annually to the Secretary of Education a written report stating in detail for the prior year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id749a18fa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the real and personal property held by the corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a18fb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the income from the property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id749a18fc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s151106/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the expenditure or other use or disposition of the property and income from the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id749a18fd-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1398"},"text":"112 Stat. 1398","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id749a18fe-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id749a18ff-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id749a1900-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"151106(a), (b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:5304 (words before last proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1906-06-30/ch3929/s4"},"text":"June 30, 1906, ch. 3929, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/805"},"text":"34 Stat. 805","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"151106(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:5304 (last proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “the purposes provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s151102"},"text":"section 151102 of this title","children":[],"tail":"” are substituted for “the educational or other purposes of the corporation as aforesaid” and “educational purposes aforesaid” for clarity. The words “"},{"tag":"i","attrib":{},"text":"Provided, however","children":[],"tail":", That this exemption shall not apply to any property of the corporation which shall not be used for or the income of which shall not be applied to the educational purposes of the corporation” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “and funds” are omitted as included in “personal property”. The words “held” and “invested” are omitted as included in “used . . . to produce income”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Secretary of Education” are substituted for “Commissioner of Education of the United States” because all functions of the Commissioner of Education have been transferred to the Secretary of Education as provided in 20:3441(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id749a1901-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id749a1902-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Taxation of Real Property of NEA in District of Columbia","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/c/s147"},"text":"Pub. L. 105–277, div. A, § 101(c) [§ 147]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-121"},"text":"112 Stat. 2681–121","children":[],"tail":", 2681–145, provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/277/dA/s101/c/s147"},"text":"“Notwithstanding any provision of any Federally-granted charter or any other provision of law, beginning with fiscal year 1999 and for each fiscal year hereafter, the real property of the National Education Association located in the District of Columbia shall be subject to taxation by the District of Columbia in the same manner as any similar organization.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
