{"tag":"section","attrib":{"id":"id74c03f7f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300103"},"text":null,"children":[{"tag":"num","attrib":{"value":"300103"},"text":"§ 300103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership and chapters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74c03f80-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Membership in the corporation is open to all the people of the United States and its territories and possessions, on payment of an amount specified, or as otherwise provided, in the bylaws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74c03f81-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chapters","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74c03f82-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The chapters of the corporation are the local units of the corporation. The corporation shall prescribe policies and regulations related to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id74c03f83-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" granting charters to the chapters and revoking those charters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74c03f84-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the territorial jurisdiction of the chapters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74c03f85-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300103/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship of the chapters to the corporation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id74c03f86-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300103/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance by the chapters with the policies and regulations of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74c03f87-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s300103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The policies and regulations shall require that each chapter adhere to the democratic principles of election specified in the bylaws in electing the governing body of the chapter and selecting delegates to the annual meeting of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74c03f88-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1491"},"text":"112 Stat. 1491","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/26/s5"},"text":"Pub. L. 110–26, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-05-11"},"text":"May 11, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/106"},"text":"121 Stat. 106","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74c03f89-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74c03f8a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74c03f8b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"300103(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:4a (1st par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1905-01-05/ch23/s4a"},"text":"Jan. 5, 1905, ch. 23, § 4a","children":[],"tail":", as added "},{"tag":"html:a","attrib":{"href":"/us/act/1947-05-08/ch50/s5"},"text":"May 8, 1947, ch. 50, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/81"},"text":"61 Stat. 81","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"300103(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:4a (last par.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “possessions” is substituted for “dependencies” for clarity and consistency in the revised title. The words “from time to time” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “within the States and Territories of the United States” are omitted as unnecessary. The words “The board of governors shall prescribe regulations related to” are substituted for “The regulations with respect to . . . shall be as determined from time to time by the Board of Governors” for consistency in the revised title. In clause (D), the word “regulations” is substituted for “rules” for clarity and consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74c03f8c-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74c03f8d-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/26/s5/1"},"text":"Pub. L. 110–26, § 5(1)","children":[],"tail":", inserted “, or as otherwise provided,” before “in the bylaws”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/26/s5/2"},"text":"Pub. L. 110–26, § 5(2)","children":[],"tail":", in introductory provisions, substituted “corporation shall” for “board of governors shall” and inserted “policies and” before “regulations related”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/26/s5/3"},"text":"Pub. L. 110–26, § 5(3)","children":[],"tail":", inserted “policies and” before “regulations shall require” and substituted “annual meeting” for “national convention”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
