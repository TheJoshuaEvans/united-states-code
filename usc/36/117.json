{"tag":"section","attrib":{"id":"id744b5c14-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s117"},"text":null,"children":[{"tag":"num","attrib":{"value":"117"},"text":"§ 117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mother’s Day","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id744b5c15-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The second Sunday in May is Mother’s Day.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id744b5c16-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proclamation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President is requested to issue a proclamation calling on United States Government officials to display the flag of the United States on all Government buildings, and on the people of the United States to display the flag at their homes or other suitable places, on Mother’s Day as a public expression of love and reverence for the mothers of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id744b5c17-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1258"},"text":"112 Stat. 1258","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":