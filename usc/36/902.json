{"tag":"section","attrib":{"id":"id7454f9be-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902"},"text":null,"children":[{"tag":"num","attrib":{"value":"902"},"text":"§ 902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National League of Families POW/MIA flag","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7454f9bf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National League of Families POW/MIA flag is designated as the symbol of our Nation’s concern and commitment to resolving as fully as possible the fates of Americans still prisoner, missing, and unaccounted for in Southeast Asia, thus ending the uncertainty for their families and the Nation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7454f9c0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Display","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The POW/MIA flag shall be displayed at the locations specified in subsection (d) of this section on POW/MIA flag display days. The display serves—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7454f9c1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the symbol of the Nation’s concern and commitment to achieving the fullest possible accounting of Americans who, having been prisoners of war or missing in action, still remain unaccounted for; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7454f9c2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the symbol of the Nation’s commitment to achieving the fullest possible accounting for Americans who in the future may become prisoners of war, missing in action, or otherwise unaccounted for as a result of hostile action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7454f9c3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Days for Flag Display","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of this section, POW/MIA flag display days are all days on which the flag of the United States is displayed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7454f9c4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Locations for Flag Display","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The locations for the display of the POW/MIA flag under subsection (b) of this section are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id7454f9c5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Capitol.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7454f9c6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The White House.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7454f9c7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The World War II Memorial, the Korean War Veterans Memorial, and the Vietnam Veterans Memorial.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7454f9c8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each national cemetery.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7454f9c9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The buildings containing the official office of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id7454f9ca-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7454f9cb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7454f9cc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/d/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Veterans Affairs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id7454f9cd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/d/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Selective Service System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7454f9ce-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each major military installation, as designated by the Secretary of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7454f9cf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each medical center of the Department of Veterans Affairs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id7454f9d0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each United States Postal Service post office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7454f9d1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Other Display Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Display of the POW/MIA flag at the Capitol pursuant to subsection (d)(1) of this section is in addition to the display of that flag in the Rotunda of the Capitol pursuant to Senate Concurrent Resolution 5 of the 101st Congress, agreed to on ","children":[{"tag":"date","attrib":{"date":"1989-02-22"},"text":"February 22, 1989","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/103/2533"},"text":"103 Stat. 2533","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7454f9d2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Display To Be in a Manner Visible to the Public","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Display of the POW/MIA flag pursuant to this section shall be in a manner designed to ensure visibility to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7454f9d3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s902/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section may not be construed or applied so as to require any employee to report to work solely for the purpose of providing for the display of the POW/MIA flag.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7454f9d4-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag