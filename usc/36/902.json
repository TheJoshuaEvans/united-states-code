90","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/355/s2"},"text":"Pub. L. 101–355, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/416"},"text":"104 Stat. 416","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"902(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:189 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/190/tX/s1084/a"},"text":"Pub. L. 102–190, title X, § 1084(a)","children":[],"tail":"–(c), (e), "},{"tag":"html:a","attrib":{"href":"/us/stat/105/1482"},"text":"105 Stat. 1482","children":[],"tail":", 1483."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"902(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:189 note.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Dec. 5, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/190/tX/s1084/d"},"text":"Pub. L. 102–190, title X, § 1084(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/1483"},"text":"105 Stat. 1483","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the text of section 1084(c) of the National Defense Authorization Act for Fiscal Years 1992 and 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190"},"text":"Public Law 102–190","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/1483"},"text":"105 Stat. 1483","children":[],"tail":") is omitted as executed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7454f9d8-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/354"},"text":"Pub. L. 105–354","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s902"},"text":"section 902 of title 36","children":[],"tail":" to reflect changes made by section 1082 of the National Defense Authorization Act for Fiscal Year 1998 ("},{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Public Law 105–85","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1917"},"text":"111 Stat. 1917","children":[],"tail":", 36 App. U.S.C. 189a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1082(g) of that Act, which defined “POW/MIA flag” as used in section 1082 by reference to ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/355/s2"},"text":"section 2 of Public Law 101–355","children":[],"tail":", is unnecessary because the two provisions are restated together in "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s902"},"text":"section 902 of title 36","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1082(h), which required that regulations be prescribed no later than 180 days after enactment of Public law 105–85, is repealed as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1082(i), which required that the Administrator of GSA procure and distribute POW/MIA flags no later than 30 days after enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/85"},"text":"Public Law 105–85","children":[],"tail":", is repealed as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1082(j), which repealed ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/190/s1084"},"text":"section 1084 of Public Law 102–190","children":[],"tail":" (previously restated as subsections (b) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s902"},"text":"section 902 of title 36","children":[],"tail":"), is repealed as executed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id7454f9d9-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id7454f9da-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/67"},"text":"Pub. L. 116–67","children":[],"tail":" added subsec. (c) and struck out former subsec. (c) which set out specific days for POW/MIA flag display."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/323/s2/b"},"text":"Pub. L. 107–323, § 2(b)","children":[],"tail":", added subpar. (A) and redesignated former subpars. (A) and (B) as (B) and (C), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/323/s2/a"},"text":"Pub. L. 107–323, § 2(a)","children":[],"tail":", substituted “The World War II Memorial, the Korean War Veterans Memorial, and the Vietnam Veterans Memorial” for “The Korean War Veterans Memorial and the Vietnam Veterans Memorial”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsecs. (b) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/354"},"text":"Pub. L. 105–354","children":[],"tail":" added subsecs. (b) to (g) and struck out former subsecs. (b) and (c) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Display","children":[],"tail":".—The flag shall be displayed—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) at each national cemetery and at the National Vietnam Veterans Memorial each year on Memorial Day and Veterans Day and on any day designated by law as National POW/MIA Recognition Day; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) on, or on the grounds of, the buildings containing the primary offices of the Secretaries of State, Defense, and Veterans Affairs, and the Director of the Selective Service System on any day designated by law as National POW/MIA Recognition Day.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(c) ","children":[{"tag":"inline","attrib":{},"text":"Termination of Flag Display Requirement","children":[],"tail":".—Subsection (b) of this section ceases to apply when the President decides that the fullest possible accounting has been made of all members of the Armed Forces and civilian employees of the United States Government who have been identified as prisoners of war or missing in action in Southeast Asia.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id7454f9db-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id7454f9dc-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Display on Existing Flagpole","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/323/s2/c"},"text":"Pub. L. 107–323, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-04"},"text":"Dec. 4, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2788"},"text":"116 Stat. 2788","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/323/s2/c"},"text":"“No element of the United States Government may construe the amendments made by this section [amending this section] as requiring the acquisition of [sic] erection of a new or additional flagpole for purposes of the display of the POW/MIA flag.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
