{"tag":"section","attrib":{"id":"id747fdabc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s60104"},"text":null,"children":[{"tag":"num","attrib":{"value":"60104"},"text":"§ 60104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id747fdabd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s60104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this chapter, eligibility for membership in the corporation and the rights and privileges of members are as provided in the constitution and bylaws of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747fdabe-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s60104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nondiscrimination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms of membership may not discriminate on the basis of race, color, religion, sex, disability, or national origin.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id747fdabf-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1346"},"text":"112 Stat. 1346","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id747fdac0-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","childr