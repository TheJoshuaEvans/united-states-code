{"tag":"section","attrib":{"id":"id748bc0c1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90102"},"text":null,"children":[{"tag":"num","attrib":{"value":"90102"},"text":"§ 90102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id748bc0c2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the foundation are to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id748bc0c3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mobilize secondary school students (including students educated in the home) in the United States to participate in the election process in a nonpartisan manner as poll workers or assistants (to the extent permitted under applicable State law);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0c4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" place secondary school students (including students educated in the home) as nonpartisan poll workers or assistants to local election officials in precinct polling places across the United States (to the extent permitted under applicable State law); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0c5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish cooperative efforts with State and local election officials, local educational agencies, superintendents and principals of public and private secondary schools, and other appropriate nonprofit charitable and educational organizations exempt from taxation under section 501(a) of the Internal Revenue Code of 1986 as an organization described in section 501(c)(3) of such Code to further the purposes of the foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0c6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requiring Activities To Be Carried Out on Nonpartisan Basis","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The foundation shall carry out its purposes without partisan bias or without promoting any particular point of view regarding any issue, and shall ensure that each participant in its activities is governed in a balanced manner which does not reflect any partisan bias.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0c7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation With State Election Officials","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The foundation shall carry out its purposes under this section in consultation with the chief election officials of the States, the District of Columbia, the Commonwealth of Puerto Rico, Guam, American Samoa, and the United States Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id748bc0c8-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tVI/s601/a"},"text":"Pub. L. 107–252, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1718"},"text":"116 Stat. 1718","children":[],"tail":", § 152602; renumbered § 90102, "},{"tag":"ref","attrib":{"href":"/us/pl/113/237/s3/c/6/B"},"text":"Pub. L. 113–237, § 3(c)(6)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2840"},"text":"128 Stat. 2840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id748bc0c9-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id748bc0ca-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id748bc0cb-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 501 of the Internal Revenue Code of 1986, referred to in subsec. (a)(3), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s501"},"text":"section 501 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id748bc0cc-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/237"},"text":"Pub. L. 113–237","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s152602"},"text":"section 152602 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
