{"tag":"section","attrib":{"id":"id748bc0f0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105"},"text":null,"children":[{"tag":"num","attrib":{"value":"90105"},"text":"§ 90105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id748bc0f1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The foundation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id748bc0f2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt a constitution and bylaws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0f3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopt a seal which shall be judicially noticed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0f4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" do any other act necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0f5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers as Trustee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out its purposes, the foundation has the usual powers of a corporation acting as a trustee in the District of Columbia, including the power—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id748bc0f6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept, receive, solicit, hold, administer, and use any gift, devise, or bequest, either absolutely or in trust, of property or any income from or other interest in property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0f7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire property or an interest in property by purchase or exchange;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0f8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unless otherwise required by an instrument of transfer, to sell, donate, lease, invest, or otherwise dispose of any property or income from property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0f9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to borrow money and issue instruments of indebtedness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0fa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make contracts and other arrangements with public agencies and private organizations and persons and to make payments necessary to carry out its functions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0fb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to sue and be sued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id748bc0fc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to do any other act necessary and proper to carry out the purposes of the foundation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0fd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Encumbered or Restricted Gifts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A gift, devise, or bequest may be accepted by the foundation even though it is encumbered, restricted, or subject to beneficial interests of private persons, if any current or future interest is for the benefit of the foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0fe-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The foundation may enter into such contracts with public and private entities as it considers appropriate to carry out its purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc0ff-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s90105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Conference in Washington Metropolitan Area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During each year (beginning with 2003), the foundation may sponsor a conference in the Washington, D.C. metropolitan area to honor secondary school students and other individuals who have served (or plan to serve) as poll workers and assistants and who have otherwise participated in the programs and activities of the foundation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id748bc100-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/252/tVI/s601/a"},"text":"Pub. L. 107–252, title VI, § 601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-10-29"},"text":"Oct. 29, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1720"},"text":"116 Stat. 1720","children":[],"tail":", § 152605; renumbered § 90105, "},{"tag":"ref","attrib":{"href":"/us/pl/113/237/s3/c/6/B"},"text":"Pub. L. 113–237, § 3(c)(6)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2840"},"text":"128 Stat. 2840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id748bc101-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id748bc102-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id748bc103-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/237"},"text":"Pub. L. 113–237","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s152605"},"text":"section 152605 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
