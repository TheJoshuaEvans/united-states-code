{"tag":"section","attrib":{"id":"id74a38fcb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153704"},"text":null,"children":[{"tag":"num","attrib":{"value":"153704"},"text":"§ 153704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74a38fcc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Convention","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74a38fcd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The national convention is the supreme governing authority of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a38fce-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The national convention is composed of officers and elected representatives from the States as provided by the regulations of the corporation. However, the form of government of the corporation must be representative of the membership at large and may not permit concentration of control in a limited number of members or in a self-perpetuating group not representative of the membership at large.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a38fcf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153704/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The meetings of the national convention may be held in the District of Columbia or in any State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a38fd0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153704/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the intervals between the convention, the executive officers are the governing board of the corporation and are responsible for the general policies, program, and activities of the corporation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74a38fd1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Council of Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The council of administration of the corporation shall consist of at least 7 members elected in the manner and for the term provided in the constitution and bylaws of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74a38fd2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153704/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74a38fd3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153704/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The officers of the corporation are a national president, senior vice national president, junior vice national president, secretary, treasurer, and other officers as provided in the constitution and bylaws. One individual may hold the offices of secretary and treasurer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a38fd4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s153704/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The titles, manner of election, term of office, and duties of the officers are as provided in the constitution and bylaws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74a38fd5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1428"},"text":"112 Stat. 1428","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74a38fd6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74a38fd7-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74a38fd8-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":nu