{"tag":"section","attrib":{"id":"id745017f7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s301"},"text":null,"children":[{"tag":"num","attrib":{"value":"301"},"text":"§ 301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National anthem","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id745017f8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The composition consisting of the words and music known as the Star-Spangled Banner is the national anthem.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id745017f9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conduct During Playing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"During a rendition of the national anthem—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id745017fa-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" when the flag is displayed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id745017fb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s301/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals in uniform should give the military salute at the first note of the anthem and maintain that position until the last note;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id745017fc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s301/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" members of the Armed Forces and veterans who are present but not in uniform may render the military salute in the manner provided for individuals in uniform; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id745017fd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s301/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all other persons present should face the flag and stand at attention with their right hand over the heart, and men not in uniform, if applicable, should remove their headdress with their right hand and hold it at the left shoulder, the hand being over the heart; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id745017fe-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the flag is not displayed, all present should face toward the music and act in the same manner they would if the flag were displayed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id745017ff-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1263"},"text":"112 Stat. 1263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title V, § 595, "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4475"},"text":"122 Stat. 4475","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74501800-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74501801-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74501802-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"301(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:170.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1931-03-03/ch436"},"text":"Mar. 3, 1931, ch. 436","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/46/1508"},"text":"46 Stat. 1508","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"301(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:171.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1942-06-22/ch435/s6"},"text":"June 22, 1942, ch. 435, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/380"},"text":"56 Stat. 380","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1942-12-22/ch806/s6"},"text":"Dec. 22, 1942, ch. 806, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/56/1077"},"text":"56 Stat. 1077","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 7, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/344/s1/18"},"text":"Pub. L. 94–344, § 1(18)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/812"},"text":"90 Stat. 812","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id74501803-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id74501804-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1)(A) to (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" added subpars. (A) to (C) and struck out former subpars. (A) to (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) all present except those in uniform should stand at attention facing the flag with the right hand over the heart;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) men not in uniform should remove their headdress with their right hand and hold the headdress at the left shoulder, the hand being over the heart; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) individuals in uniform should give the military salute at the first note of the anthem and maintain that position until the last note; and”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
