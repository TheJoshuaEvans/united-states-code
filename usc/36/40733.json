{"tag":"section","attrib":{"id":"id747d68ec-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40733"},"text":null,"children":[{"tag":"num","attrib":{"value":"40733"},"text":"§ 40733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other law","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id747d68ed-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), section 922(a)(1)–(3) and (5) of title 18 does not apply to the shipment, transportation, receipt, transfer, sale, issuance, loan, or delivery by the corporation, of an item that the corporation is authorized to issue, loan, sell, or receive under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747d68ee-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to firearms other than caliber .22 rimfire and caliber .30 rifles, the corporation shall obtain a license as a dealer in firearms and abide by all requirements imposed on persons licensed under chapter 44 of title 18, including maintaining acquisition and disposition records, and conducting background checks.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id747d68ef-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "}