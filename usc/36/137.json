{"tag":"section","attrib":{"id":"id744dcda5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s137"},"text":null,"children":[{"tag":"num","attrib":{"value":"137"},"text":"§ 137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Police Week","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The President is requested to issue each year a proclamation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id744dcda6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s137/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designating the week in which May 15 occurs as Police Week in recognition of the service given by men and women who stand guard to protect the people of the United States through law enforcement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id744dcda7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s137/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inviting State and local governments and the people of the United States to observe Police Week with appropriate ceremonies and activities, including the display of the flag at halfstaff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id744dcda8-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1261"},"text":"112 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id744dcda9-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id744dcdaa-3a70-11f1-9d9e-df