{"tag":"section","attrib":{"id":"id74659c17-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21003"},"text":null,"children":[{"tag":"num","attrib":{"value":"21003"},"text":"§ 21003.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74659c18-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21003/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are as provided in its bylaws and articles of incorporation and include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74659c19-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21003/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" securing the blessing of American democracy at every level of local, State, and national life for all United States citizens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c1a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21003/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upholding and defending the Constitution and the United States flag;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c1b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21003/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fostering and perpetuating the principles of American democracy based on religious and political freedom for the individual and equal opportunity for all;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c1c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21003/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fostering and enlarging equal educational opportunities, equal economic opportunities, equal justice under the law, and equal political opportunities for all United States citizens, regardless of race, color, religion, sex, or national origin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c1d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21003/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encouraging greater participation of the ethnic minority represented by the corporation in the policy-making and administrative activities of all departments, agencies, and other governmental units of local and State governments and the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c1e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21003/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" combating all practices of a prejudicial or discriminatory nature in local, State, or national life which curtail, hinder, or deny to any United States citizen an equal opportunity to develop full potential as an individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74659c1f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21003/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fostering and promoting the broader knowledge and appreciation by all United States citizens of their cultural heritage and language.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74659c20-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s21003/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corporate Function","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The corporation shall function as an educational, patriotic, civic, historical, and research organization under the laws of Texas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74659c21-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/354/s1/5/A"},"text":"Pub. L. 105–354, § 1(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-03"},"text":"Nov. 3, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3242"},"text":"112 Stat. 3242","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74659c22-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74659c23-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74659c24-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attri