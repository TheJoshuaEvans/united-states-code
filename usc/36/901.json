{"tag":"section","attrib":{"id":"id7454f9b5-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s901"},"text":null,"children":[{"tag":"num","attrib":{"value":"901"},"text":"§ 901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service flag and service lapel button","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id7454f9b6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individuals Entitled To Display Service Flag","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A service flag approved by the Secretary of Defense may be displayed in a window of the place of residence of individuals who are members of the immediate family of an individual serving in the Armed Forces of the United States during any period of war or hostilities in which the Armed Forces of the United States are engaged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7454f9b7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individuals Entitled To Display Service Lapel Button","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A service lapel button approved by the Secretary may be worn by members of the immediate family of an individual serving in the Armed Forces of the United States during any period of war or hostilities in which the Armed Forces of the United States are engaged.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7454f9b8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"License To Manufacture and Sell Service Flags and Service Lapel Buttons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person may apply to the Secretary for a license to manufacture and sell the approved service flag, or the approved service lapel button, or both. Any person that manufactures a service flag or service lapel button without having first obtained a license, or otherwise violates this section is liable to the United States Government for a civil penalty of not more than $1,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id7454f9b9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s901/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may prescribe regulations necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id7454f9ba-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1267"},"text":"112 Stat. 1267","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id7454f9bb-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id7454f9bc-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id7454f9bd-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":