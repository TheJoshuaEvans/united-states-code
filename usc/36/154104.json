{"tag":"section","attrib":{"id":"id74a60058-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154104"},"text":null,"children":[{"tag":"num","attrib":{"value":"154104"},"text":"§ 154104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Governing body","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id74a60059-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board of Directors","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74a6005a-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The board of directors is the governing body of the corporation. The board is responsible for the general policies and program of the corporation and the control of all funds of the corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a6005b-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of directors, their manner of selection (including the filling of vacancies), and their term of office are as provided in the constitution and bylaws. However, the board shall have at least 10 but not more than 25 directors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id74a6005c-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Officers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id74a6005d-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The officers of the corporation are a president, one or more vice presidents as provided in the constitution and bylaws, a secretary, a treasurer, and other officers as provided in the constitution and bylaws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74a6005e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s154104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manner of election, term of office, and duties of the officers are as provided in the constitution and bylaws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74a6005f-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1432"},"text":"112 Stat. 1432","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74a60060-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74a60061-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74a60062-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[