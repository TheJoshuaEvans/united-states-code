{"tag":"section","attrib":{"id":"id748bc18e-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s110102"},"text":null,"children":[{"tag":"num","attrib":{"value":"110102"},"text":"§ 110102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id748bc18f-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s110102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Jewish War Veterans of the United States of America, Incorporated (in this chapter, the “corporation”), a nonprofit corporation incorporated in New York, is a federally chartered corporation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id748bc190-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s110102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration of Charter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the corporation does not comply with any provision of this chapter, the charter granted by this chapter expires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id748bc191-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1367"},"text":"112 Stat. 1367","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id748bc192-3a70-11f1-9d9e-dfac6d46cab7"},"text":