{"tag":"section","attrib":{"id":"id74af9c92-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220102"},"text":null,"children":[{"tag":"num","attrib":{"value":"220102"},"text":"§ 220102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The purposes of the corporation are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id74af9c93-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a voluntary civilian agency through which the people of this Nation may, in peace or war, serve the religious, spiritual, social, welfare, educational, and entertainment needs of men and women in the Armed Forces, within or without the territorial limits of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9c94-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to contribute to the maintenance of morale of men and women in the Armed Forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9c95-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to solicit funds to maintain the organization and accomplish its responsibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9c96-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accept the cooperation of, and provide an organization and means through which, the National Board of Young Men’s Christian Associations, the National Board of Young Women’s Christian Associations, the National Catholic Community Service, the Salvation Army, the National Jewish Welfare Board, the Travelers Aid-International Social Service of America, and other civilian agencies experienced in specialized types of related work, which may be needed adequately to meet the particular needs of the members of the Armed Forces, may carry on their historic work of serving the religious, spiritual, social, welfare, educational, and entertainment needs of men and women in the Armed Forces and be afforded an appropriate means of participation and financial assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9c97-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to coordinate their programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id74af9c98-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s220102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other consonant purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id74af9c99-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1459"},"text":"112 Stat. 1459","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id74af9c9a-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id74af9c9b-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"id74af9c9c-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"220102","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"36:1302.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Dec. 29, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/165/s2"},"text":"Pub. L. 96–165, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/1268"},"text":"93 Stat. 1268","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Before clause (1), the word “objects” is omitted as included in “purposes”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (4), the words “and to accept the cooperation of individual citizens in accomplishing its purposes” are omitted as unnecessary because of clause (1) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
