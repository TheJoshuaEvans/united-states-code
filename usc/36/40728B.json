{"tag":"section","attrib":{"id":"id747b1fb6-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B"},"text":null,"children":[{"tag":"num","attrib":{"value":"40728B"},"text":"§ 40728B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recovery of excess rifles, ammunition, and parts granted to foreign countries and transfer to certain persons","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id747b1fb7-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Recover","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1fb8-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2) and subsection (b), the Secretary of the Army may acquire from any person any rifle, ammunition, repair parts, or other supplies described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40731/a"},"text":"section 40731(a) of this title","children":[],"tail":" which were—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id747b1fb9-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided to any country on a grant basis under the conditions imposed by section 505 of the Foreign Assistance Act of 1961 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2314"},"text":"22 U.S.C. 2314","children":[],"tail":") that became excess to the needs of such country; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id747b1fba-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lawfully acquired by such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1fbb-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army may not acquire anything under paragraph (1) except for transfer to a person in the United States under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1fbc-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army may accept rifles, ammunition, repair parts, or other supplies under paragraph (1) notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1fbd-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost of Recovery","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army may not acquire anything under subsection (a) if the United States would incur any cost for such acquisition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1fbe-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability for Transfer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any rifles, ammunition, repair parts, or supplies acquired under subsection (a) shall be available for transfer in the United States to the person from whom acquired if such person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id747b1fbf-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed as a manufacturer, importer, or dealer pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s923/a"},"text":"section 923(a) of title 18","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id747b1fc0-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses an ammunition depot of the Army that is an eligible facility for receipt of any rifles, ammunition, repair parts, or supplies under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1fc1-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Market Value","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of the Army may only transfer an item under subsection (c) if the Secretary receives fair market value for the item.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1fc2-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s3201/e"},"text":"section 3201(e) of title 10","children":[],"tail":", the Secretary may enter into such contracts or cooperative agreements on a sole source basis pursuant to paragraphs (4) and (5) of section 3204(a) "},{"tag":"ref","attrib":{"idref":"fn002006"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably means "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s3204/a"},"text":"section 3204(a) of title 10","children":[],"tail":"."}],"tail":" to carry out this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1fc3-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"AECA","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Transfers authorized under this section may only be made in accordance with applicable provisions of the Arms Export Control Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s2778"},"text":"22 U.S.C. 2778","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id747b1fc4-3a70-11f1-9d9e-dfac6d46cab7","identifier":"/us/usc/t36/s40728B/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rifle Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “rifle” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s921"},"text":"section 921 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id747d68b5-3a70-11f1-9d9e-dfac6d46cab7"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1096/a"},"text":"Pub. L. 114–328, div. A, title X, § 1096(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2440"},"text":"130 Stat. 2440","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tXVII/s1702"},"text":"Pub. L. 117–81, div. A, title XVII, § 1702","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(7), "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/2160"},"text":"135 Stat. 2160","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id747d68b6-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id747d68b7-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id747d68b8-3a70-11f1-9d9e-dfac6d46cab7"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Arms Export Control Act, referred to in subsec. (f), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/629"},"text":"Pub. L. 90–629","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1320"},"text":"82 Stat. 1320","children":[],"tail":", which is classified principally to chapter 39 (§ 2751 et seq.) of Title 22, Foreign Relations and Intercourse. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2751"},"text":"section 2751 of Title 22","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id747d68b9-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81"},"text":"Pub. L. 117–81","children":[],"tail":" substituted “section 3201(e)” for “subsection (k) of section 2304” and “section 3204(a)” for “subsection (c) of such section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id747d68ba-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id747d68bb-3a70-11f1-9d9e-dfac6d46cab7"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Report on Acquisition and Transfer","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/dA/tX/s1096/d"},"text":"Pub. L. 114–328, div. A, title X, § 1096(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2441"},"text":"130 Stat. 2441","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/328/dA/tX/s1096/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":"], the Secretary of the Army shall submit to the Committee on Armed Services and the Committee on Foreign Relations of the Senate and the Committee on Armed Services and the Committee on Foreign Affairs of the House of Representatives a report on the acquisition and transfer of excess rifles, ammunition, repair parts, and other supplies described in "},{"tag":"ref","attrib":{"href":"/us/usc/t36/s40731/a"},"text":"section 40731(a) of title 36","children":[],"tail":", United States Code, that were provided to a country on a grant basis under the conditions imposed by section 505 of the Foreign Assistance Act of 1961 ["},{"tag":"ref","attrib":{"href":"/us/usc/t22/s2314"},"text":"22 U.S.C. 2314","children":[],"tail":"]. The report shall include each of the following:"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A list of excess rifles, ammunition, repair parts, and other supplies known to the United States Army as eligible for transfer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40731/a"},"text":"section 40731(a) of title 36","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An assessment of whether and how the Secretary of the Army intends to use the authorities under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40728B"},"text":"section 40728B of title 36","children":[],"tail":", United States Code, as added by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other issue that the Secretary of the Army considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on transfers pending submittal of report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No rifle, ammunition, repair part, or supplies acquired under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t36/s40728B/a"},"text":"section 40728B(a) of title 36","children":[],"tail":", United States Code, may be transferred until the date that is 90 days after the date of the submittal of the report required under paragraph (1).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
