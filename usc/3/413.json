{"tag":"section","attrib":{"id":"id371ea512-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s413"},"text":null,"children":[{"tag":"num","attrib":{"value":"413"},"text":"§ 413.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections under the Fair Labor Standards Act of 1938","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id371ea513-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s413/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fair Labor Standards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea514-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s413/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The rights and protections established by subsections (a)(1) and (d) of section 6, section 7, and section 12(c) of the Fair Labor Standards Act of 1938 shall apply to covered employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea515-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s413/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interns and volunteers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of this section, the term “covered employee” does not include an intern or a volunteer as defined in regulations under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea516-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s413/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensatory time","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in regulations under subsection (c)(3), covered employees may not receive compensatory time in lieu of overtime compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea517-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s413/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The remedy for a violation of subsection (a) shall be such damages, including liquidated damages, as would be appropriate if awarded under section 16(b) of the Fair Labor Standards Act of 1938.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea518-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s413/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations To Implement Section.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea519-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s413/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President, or the designee of the President, shall issue regulations to implement this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea51a-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s413/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (3), the regulations issued under paragraph (1) shall be the same as substantive regulations promulgated by the Secretary of Labor to implement the statutory provisions referred to in subsections (a) and (b) except to the extent that the President or designee may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea51b-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s413/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Irregular work schedules","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President or designee shall issue regulations for covered employees whose work schedules directly depend on the schedule of the President or the Vice President that shall be comparable to the provisions in the Fair Labor Standards Act of 1938 that apply to employees who have irregular work schedules.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea51c-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s413/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (a) and (b) shall take effect on the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea51d-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s413/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of regulations issued under subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea51e-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s413/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id371ea51f-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/a"},"text":"Pub. L. 104–331, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4058"},"text":"110 Stat. 4058","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id371ea520-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id371ea521-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id371ea522-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Fair Labor Standards Act of 1938, referred to in subsecs. (a)(1), (b), and (c)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch676"},"text":"act June 25, 1938, ch. 676","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1060"},"text":"52 Stat. 1060","children":[],"tail":", which is classified generally to chapter 8 (§ 201 et seq.) of Title 29, Labor. Sections 6, 7, 12, and 16 of the Act are classified to sections 206, 207, 212, and 216, respectively, of Title 29. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s201"},"text":"section 201 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id371ea523-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id371ea524-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (c) of this section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s471/b"},"text":"section 471(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
