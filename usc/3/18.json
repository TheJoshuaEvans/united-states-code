{"tag":"section","attrib":{"id":"id3706d660-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"§ 18.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Same; parliamentary procedure at joint session","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"While the two Houses shall be in session as provided in this chapter, the President of the Senate shall have power to preserve order; and no debate shall be allowed and no question shall be put by the presiding officer except to either House on a motion to withdraw under section 15(d)(2)(C)(i).","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id3706d661-2930-11f1-b70e-e9fd6f164ed0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch644"},"text":"June 25, 1948, ch. 644","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/676"},"text":"62 Stat. 676","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s3"},"text":"Sept. 3, 1954, ch. 1263, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1227"},"text":"68 Stat. 1227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dP/tI/s110/b"},"text":"Pub. L. 117–328, div. P, title I, § 110(b)","children":[],"tail":", (c)(2), "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5240"},"text":"136 Stat. 5240","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id3706d662-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id3706d663-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id3706d664-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s110/c/2"},"text":"Pub. L. 117–328, § 110(c)(2)","children":[],"tail":", substituted “session” for “meeting” in section catchline and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/s110/b"},"text":"Pub. L. 117–328, § 110(b)","children":[],"tail":", inserted “under section 15(d)(2)(C)(i)” after “motion to withdraw”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":", substituted “chapter” for “subchapter”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
