attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/247"},"text":"120 Stat. 247","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id3706d674-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id3706d675-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id3706d676-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177"},"text":"Pub. L. 109–177","children":[],"tail":" inserted “, Secretary of Homeland Security” after “Secretary of Veterans Affairs”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527"},"text":"Pub. L. 100–527","children":[],"tail":" inserted reference to Secretary of Veterans Affairs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88"},"text":"Pub. L. 96–88","children":[],"tail":" substituted “Secretary of Health and Human Services” for “Secretary of Health, Education, and Welfare” and inserted reference to Secretary of Education."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/91"},"text":"Pub. L. 95–91","children":[],"tail":" inserted reference to Secretary of Energy."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1970—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" struck out “Postmaster General,” after “Attorney General,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1966—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/670"},"text":"Pub. L. 89–670","children":[],"tail":" inserted reference to Secretary of Transportation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1965—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/174"},"text":"Pub. L. 89–174","children":[],"tail":" inserted reference to Secretary of Health, Education, and Welfare and Secretary of Housing and Urban Development."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id3706d677-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id3706d678-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/527"},"text":"Pub. L. 100–527","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1989-03-15"},"text":"Mar. 15, 1989","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/100/527/s18/a"},"text":"section 18(a) of Pub. L. 100–527","children":[],"tail":", set out as a Department of Veterans Affairs Act note under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s301"},"text":"section 301 of Title 38","children":[],"tail":", Veterans’ Benefits."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id3706d679-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1979 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/88"},"text":"Pub. L. 96–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-05-04"},"text":"May 4, 1980","children":[],"tail":", with specified exceptions, see "},{"tag":"ref","attrib":{"href":"/us/pl/96/88/s601"},"text":"section 601 of Pub. L. 96–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t20/s3401"},"text":"section 3401 of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id3706d67a-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1970 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Pub. L. 91–375","children":[],"tail":" effective within 1 year after "},{"tag":"date","attrib":{"date":"1970-08-12"},"text":"Aug. 12, 1970","children":[],"tail":", on date established therefor by Board of Governors of United States Postal Service and published by it in Federal Register, see section 16(a), formerly "},{"tag":"ref","attrib":{"href":"/us/pl/91/375/s15/a"},"text":"section 15(a) of Pub. L. 91–375","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s101"},"text":"section 101 of Title 39","children":[],"tail":", Postal Service."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id3706d67b-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1966 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/670"},"text":"Pub. L. 89–670","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1967-04-01"},"text":"Apr. 1, 1967","children":[],"tail":", as prescribed by President and published in Federal Register, see section 16(a), formerly § 15(a), of "},{"tag":"ref","attrib":{"href":"/us/pl/89/670"},"text":"Pub. L. 89–670","children":[],"tail":", and Ex. Ord. No. 11340, "},{"tag":"date","attrib":{"date":"1967-03-30"},"text":"Mar. 30, 1967","children":[],"tail":", 32 F.R. 5453."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id3706d67c-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1965 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/174"},"text":"Pub. L. 89–174","children":[],"tail":" effective upon expiration of first period of sixty calendar days following "},{"tag":"date","attrib":{"date":"1965-09-09"},"text":"Sept. 9, 1965","children":[],"tail":" or on earlier date specified by Executive order, see "},{"tag":"ref","attrib":{"href":"/us/pl/89/174/s11/a"},"text":"section 11(a) of Pub. L. 89–174","children":[],"tail":" set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3531"},"text":"section 3531 of Title 42","children":[],"tail":", The Public Health and Welfare."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
