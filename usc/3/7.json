{"tag":"section","attrib":{"id":"id370465fc-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"§ 7.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meeting and vote of electors","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The electors of President and Vice President of each State shall meet and give their votes on the first Tuesday after the second Wednesday in December next following their appointment at such place in each State in accordance with the laws of the State enacted prior to election day.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id370465fd-2930-11f1-b70e-e9fd6f164ed0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch644"},"text":"June 25, 1948, ch. 644","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/673"},"text":"62 Stat. 673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dP/tI/s106/a"},"text":"Pub. L. 117–328, div. P, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5236"},"text":"136 Stat. 5236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id370465fe-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id370465ff-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id37046600-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “Tuesday” for “Monday” and “in accordance with the laws of the State enacted prior to election day” for “as the legislature of such State shall direct”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id37046601-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Constitutional Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Day of voting by electors, see Const. Art. II, § 1, cl. 3.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Voting by electors, see Const. Amend. XII.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
