{"tag":"section","attrib":{"id":"id371ea534-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415"},"text":null,"children":[{"tag":"num","attrib":{"value":"415"},"text":"§ 415.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections under the Worker Adjustment and Retraining Notification Act","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id371ea535-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Worker Adjustment and Retraining Notification Rights.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea536-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), no employing office shall be closed or mass layoff ordered within the meaning of section 3 of the Worker Adjustment and Retraining Notification Act until the end of a 60-day period after the employing office serves written notice of such prospective closing or layoff to representatives of covered employees or, if there are no representatives, to covered employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea537-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371ea538-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the event that a President (hereinafter in this paragraph referred to as the “previous President”) is not elected to a successive term in office as a result of the election of a new President—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id371ea539-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no notice or waiting period shall be required under paragraph (1) with respect to the separation of any individual described in subparagraph (B), if such separation occurs pursuant to a closure or mass layoff ordered after the term of the new President commences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id371ea53a-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if any individual is separated from service, or begins a period of leave under the Family and Medical Leave Act of 1993, before such term commences, nothing in this chapter shall require reinstatement or restoration to employment of the individual after such term commences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371ea53b-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of individuals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual described in this subparagraph is any covered employee serving pursuant to an appointment made during—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id371ea53c-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term of office of the previous President; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id371ea53d-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any term, earlier than the term referred to in clause (i), during which such previous President served as President or Vice President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea53e-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The remedy for a violation of subsection (a) shall be such damages as would be appropriate if awarded under paragraphs (1), (2), and (4) of section 5(a) of the Worker Adjustment and Retraining Notification Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea53f-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations To Implement Section.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea540-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President, or the designee of the President, shall issue regulations to implement this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea541-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations issued under paragraph (1) shall be the same as substantive regulations promulgated by the Secretary of Labor to implement the statutory provisions referred to in subsections (a) and (b) except to the extent that the President or designee may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea542-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (a) and (b) shall take effect on the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea543-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of regulations issued under subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea544-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s415/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id371ea545-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/a"},"text":"Pub. L. 104–331, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4059"},"text":"110 Stat. 4059","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id371ea546-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id371ea547-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id371ea548-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 3 and 5 of the Worker Adjustment and Retraining Notification Act, referred to in subsecs. (a)(1) and (b), are classified to sections 2102 and 2104, respectively, of Title 29, Labor.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Family and Medical Leave Act of 1993, referred to in subsec. (a)(2)(A)(ii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3"},"text":"Pub. L. 103–3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/6"},"text":"107 Stat. 6","children":[],"tail":", which enacted sections 60m and 60n of Title 2, The Congress, sections 6381 to 6387 of Title 5, Government Organization and Employees, and chapter 28 (§ 2601 et seq.) of Title 29, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of Title 5","children":[],"tail":", and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id371ea549-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id371ea54a-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (c) of this section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s471/b"},"text":"section 471(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
