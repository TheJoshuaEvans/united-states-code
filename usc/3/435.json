{"tag":"section","attrib":{"id":"id372115c5-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s435"},"text":null,"children":[{"tag":"num","attrib":{"value":"435"},"text":"§ 435.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Generally applicable remedies and limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id372115c6-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s435/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attorney’s Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a covered employee, with respect to any claim under this chapter, or a qualified person with a disability, with respect to any claim under section 421, is a prevailing party in any proceeding under section 453(1), the administrative agency may award attorney’s fees, expert fees, and any other costs as would be appropriate if awarded under section 706(k) of the Civil Rights Act of 1964.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id372115c7-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s435/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any proceeding under section 453(1), the same interest to compensate for delay in payment shall be made available as would be appropriate if awarded under section 717(d) of the Civil Rights Act of 1964.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id372115c8-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s435/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalties and Punitive Damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this chapter, no civil penalty or punitive damages may be awarded with respect to any claim under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id372115c9-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s435/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusive Procedure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id372115ca-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s435/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), no person may commence an administrative or judicial proceeding to seek a remedy for the rights and protections afforded by this chapter except as provided in this chapter and in sections 1296 and 1346(g) and chapter 179 of title 28.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id372115cb-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s435/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veterans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A covered employee under section 416 may also utilize any provisions of chapter 43 of title 38 that are applicable to that employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id372115cc-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s435/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope of Remedy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Only a covered employee who has undertaken and completed the procedures described in section 452 may be granted a remedy under part A of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id372115cd-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s435/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id372115ce-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s435/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions and exemptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except where inconsistent with definitions and exemptions provided in this chapter, the definitions and exemptions in the laws made applicable by this chapter shall apply under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id372115cf-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s435/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Size limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (1), provisions in the laws made applicable under this chapter (other than paragraphs (2) and (3) of section 2(a) of the Worker Adjustment and Retraining Notification Act) determining coverage based on size, whether expressed in terms of numbers of employees, amount of business transacted, or other measure, shall not apply in determining coverage under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id372115d0-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s435/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Political Affiliation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall not be a violation of any provision of this chapter to consider, or make any employment decision based on, the party affiliation, or political compatibility with the employing office, of an employee who is a covered employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id372115d1-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/a"},"text":"Pub. L. 104–331, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4066"},"text":"110 Stat. 4066","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id372115d2-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id372115d3-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id372115d4-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 706 and 717 of the Civil Rights Act of 1964, referred to in subsecs. (a) and (b), are classified to sections 2000e–5 and 2000e–16, respectively, of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 2 of the Worker Adjustment and Retraining Notification Act, referred to in subsec. (f)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2101"},"text":"section 2101 of Title 29","children":[],"tail":", Labor."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
