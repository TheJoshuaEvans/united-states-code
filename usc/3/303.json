{"tag":"section","attrib":{"id":"id371c33a0-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s303"},"text":null,"children":[{"tag":"num","attrib":{"value":"303"},"text":"§ 303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this chapter, the term “function” embraces any duty, power, responsibility, authority, or discretion vested in the President or other officer concerned, and the terms “perform” and “performance” may be construed to mean “exercise”.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id371c33a1-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch655/s10"},"text":"Oct. 31, 1951, ch. 655, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/712"},"text":"65 Stat. 712","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id371c33a2-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id371c33a3-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"similarProvisions","id":"id371c33a4-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Similar Provisions; Repeal; Saving Clause","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For similar provisions contained in prior law, and saving clause in connection therewith, see note preceding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
