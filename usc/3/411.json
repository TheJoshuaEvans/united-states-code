{"tag":"section","attrib":{"id":"id371c33cd-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411"},"text":null,"children":[{"tag":"num","attrib":{"value":"411"},"text":"§ 411.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections under title VII of the Civil Rights Act of 1964, the Age Discrimination in Employment Act of 1967, the Rehabilitation Act of 1973, and title I of the Americans with Disabilities Act of 1990","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id371c33ce-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discriminatory Practices Prohibited","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"All personnel actions affecting covered employees shall be made free from any discrimination based on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id371c33cf-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" race, color, religion, sex, or national origin, within the meaning of section 703 of the Civil Rights Act of 1964;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33d0-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" age, within the meaning of section 15 of the Age Discrimination in Employment Act of 1967; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33d1-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disability, within the meaning of section 501 of the Rehabilitation Act of 1973 and sections 102 through 104 of the Americans with Disabilities Act of 1990.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371c33d2-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371c33d3-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil rights","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The remedy for a violation of subsection (a)(1) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371c33d4-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such damages as would be appropriate if awarded under section 706(g) of the Civil Rights Act of 1964; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371c33d5-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such compensatory damages as would be appropriate if awarded under section 1977 of the Revised Statutes, or as would be appropriate if awarded under sections 1977A(a)(1), 1977A(b)(2), and, irrespective of the size of the employing office, 1977A(b)(3)(D) of the Revised Statutes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33d6-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Age discrimination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The remedy for a violation of subsection (a)(2) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371c33d7-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such damages as would be appropriate if awarded under section 15(c) of the Age Discrimination in Employment Act of 1967; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371c33d8-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such liquidated damages as would be appropriate if awarded under section 7(b) of such Act.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In addition, the waiver provisions of section 7(f) of such Act shall apply to covered employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33d9-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disabilities discrimination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The remedy for a violation of subsection (a)(3) shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371c33da-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such damages as would be appropriate if awarded under section 505(a)(1) of the Rehabilitation Act of 1973 or section 107(a) of the Americans with Disabilities Act of 1990; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371c33db-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such compensatory damages as would be appropriate if awarded under sections 1977A(a)(2), 1977A(a)(3), 1977A(b)(2), and, irrespective of the size of the employing office, 1977A(b)(3)(D) of the Revised Statutes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371c33dc-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise specifically provided in this section, as used in this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id371c33dd-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered employee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered employee” means any employee of a unit of the executive branch, including the Executive Office of the President, whether appointed by the President or by any other appointing authority in the executive branch, who is not otherwise entitled to bring an action under any of the statutes referred to in subsection (a), but does not include any individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371c33de-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose appointment is made by and with the advice and consent of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371c33df-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is appointed to an advisory committee, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1001"},"text":"section 1001 of title 5","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371c33e0-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is a member of the uniformed services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33e1-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employing office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “employing office”, with respect to a covered employee, means the office, agency, or other entity in which the covered employee is employed (or sought employment or was employed in the case of an applicant or former employee, respectively).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371c33e2-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations To Implement Section.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371c33e3-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President, or the designee of the President, shall issue regulations to implement paragraphs (1) and (3) of subsection (a) and paragraphs (1) and (3) of subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33e4-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations issued under paragraph (1) shall be the same as substantive regulations promulgated by the appropriate officer of an executive agency to implement the statutory provisions referred to in paragraphs (1) and (3) of subsection (a) and paragraphs (1) and (3) of subsection (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371c33e5-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except to the extent that the President or designee may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371c33e6-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except that the President or designee may, at the discretion of the President or designee, issue regulations to implement a provision of section 717 of the Civil Rights Act of 1964 or section 501 of the Rehabilitation Act of 1973 that applies to employees in the executive branch of the Federal Government in lieu of an analogous statutory provision referred to in paragraph (1) or (3) of subsection (a) or paragraph (1) or (3) of subsection (b), if the issuance of such regulations—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id371c33e7-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be equally effective for the implementation of the rights and protections under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id371c33e8-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would promote uniformity in the application of Federal law to employees in the executive branch of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371c33e9-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsections (a) through (c), and section 417 (to the extent that it relates to any matter under this section), shall apply with respect to violations occurring on or after the effective date of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371c33ea-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s411/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall take effect on ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id371c33eb-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/a"},"text":"Pub. L. 104–331, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4055"},"text":"110 Stat. 4055","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/3"},"text":"Pub. L. 117–286, § 4(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4305"},"text":"136 Stat. 4305","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id371c33ec-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id371c33ed-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id371c33ee-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 703, 706, and 717 of the Civil Rights Act of 1964, referred to in subsecs. (a)(1), (b)(1)(A), and (d)(2)(B), are classified to sections 2000e–2, 2000e–5, and 2000e–16, respectively, of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 7 and 15 of the Age Discrimination in Employment Act of 1967, referred to in subsecs. (a)(1) and (b)(2), are classified to sections 626 and 633a, respectively, of Title 29, Labor.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 501 and 505 of the Rehabilitation Act of 1973, referred to in subsecs. (a)(3), (b)(3)(A), and (d)(2)(B), are classified to sections 791 and 794a, respectively, of Title 29.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 102 to 104 and 107 of the Americans with Disabilities Act of 1990, referred to in subsecs. (a)(3) and (b)(3)(A), are classified to sections 12112 to 12114 and 12117, respectively, of Title 42, The Public Health and Welfare.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 1977 and 1977A of the Revised Statutes, referred to in subsec. (b)(1)(B), (3)(B), are classified to sections 1981 and 1981a, respectively, of Title 42.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The effective date of this chapter, referred to in subsec. (e), is ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", unless otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s471"},"text":"section 471 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id371c33ef-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1001"},"text":"section 1001 of title 5","children":[],"tail":";” for “section 3(2) of the Federal Advisory Committee Act;”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id371c33f0-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id371c33f1-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (d) of this section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s471/b"},"text":"section 471(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id371c33f2-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For provisions requiring that appropriate measures be taken to ensure that any regulations required to implement this section be in effect by ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/b/1"},"text":"section 2(b)(1) of Pub. L. 104–331","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s401"},"text":"section 401 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
