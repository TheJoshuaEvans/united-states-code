{"tag":"section","attrib":{"id":"id372115e5-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s453"},"text":null,"children":[{"tag":"num","attrib":{"value":"453"},"text":"§ 453.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Election of proceeding","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after a covered employee receives notice of the end of the period of mediation, but no sooner than 30 days after receipt of such notification, such covered employee may either—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id372115e6-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s453/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file a complaint with the appropriate agency, as determined under section 454; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id372115e7-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s453/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" file a civil action under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1346/g"},"text":"section 1346(g) of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id372115e8-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/a"},"text":"Pub. L. 104–331, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4067"},"text":"110 Stat. 4067","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
