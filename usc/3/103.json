{"tag":"section","attrib":{"id":"id370e02bd-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s103"},"text":null,"children":[{"tag":"num","attrib":{"value":"103"},"text":"§ 103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Traveling expenses","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There may be expended for or on account of the traveling expenses of the President of the United States such sum as Congress may from time to time appropriate, not exceeding $100,000 per annum, such sum when appropriated to be expended in the discretion of the President and accounted for on his certificate solely.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id370e02be-2930-11f1-b70e-e9fd6f164ed0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch644"},"text":"June 25, 1948, ch. 644","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/678"},"text":"62 Stat. 678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/570/s4"},"text":"Pub. L. 95–570, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2450"},"text":"92 Stat. 2450","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id370e02bf-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id370e02c0-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id370e02c1-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1978—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/570"},"text":"Pub. L. 95–570","children":[],"tail":" substituted “$100,000” for “$40,000”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id370e02c2-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id370e02c3-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1978 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/570"},"text":"Pub. L. 95–570","children":[],"tail":" applicable to any fiscal year beginning on or after "},{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/570/s6/a"},"text":"section 6(a) of Pub. L. 95–570","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s102"},"text":"section 102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
