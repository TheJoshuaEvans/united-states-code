{"tag":"section","attrib":{"id":"id37046604-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"§ 9.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificates of votes for President and Vice President","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The electors shall make and sign six certificates of all the votes given by them, each of which certificates shall contain two distinct lists, one of the votes for President and the other of the votes for Vice President, and shall annex to each of the certificates of votes one of the certificates of ascertainment of appointment of electors which shall have been furnished to them by direction of the executive of the State.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id37046605-2930-11f1-b70e-e9fd6f164ed0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch644"},"text":"June 25, 1948, ch. 644","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/674"},"text":"62 Stat. 674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dP/tI/s104/c/1"},"text":"Pub. L. 117–328, div. P, title I, § 104(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5236"},"text":"136 Stat. 5236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id37046606-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id37046607-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id37046608-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “annex to each of the certificates of votes one of the certificates of ascertainment of appointment of electors” for “annex to each of the certificates one of the lists of the electors”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
