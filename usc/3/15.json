{"tag":"section","attrib":{"id":"id3704662a-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"§ 15.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counting electoral votes in Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id3704662b-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Congress shall be in session on the sixth day of January succeeding every meeting of the electors. The Senate and House of Representatives shall meet in the Hall of the House of Representatives at the hour of 1 o’clock in the afternoon on that day, and the President of the Senate shall be their presiding officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id3704662c-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers of the President of Senate.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id3704662d-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ministerial in nature","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this chapter, the role of the President of the Senate while presiding over the joint session shall be limited to performing solely ministerial duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id3704662e-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Powers explicitly denied","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President of the Senate shall have no power to solely determine, accept, reject, or otherwise adjudicate or resolve disputes over the proper certificate of ascertainment of appointment of electors, the validity of electors, or the votes of electors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id3704662f-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of Tellers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the joint session of the Senate and House of Representatives described in subsection (a), there shall be present two tellers previously appointed on the part of the Senate and two tellers previously appointed on the part of the House of Representatives by the presiding officers of the respective chambers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id37046630-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure at Joint Session Generally.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id37046631-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President of the Senate shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id37046632-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" open the certificates and papers purporting to be certificates of the votes of electors appointed pursuant to a certificate of ascertainment of appointment of electors issued pursuant to section 5, in the alphabetical order of the States, beginning with the letter A; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id37046633-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon opening any certificate, hand the certificate and any accompanying papers to the tellers, who shall read the same in the presence and hearing of the two Houses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id37046634-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action on certificate.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id37046635-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the reading of each certificate or paper, the President of the Senate shall call for objections, if any.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id37046636-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for objections or questions.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id37046637-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objections","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No objection or other question arising in the matter shall be in order unless the objection or question—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id37046638-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is made in writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id37046639-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is signed by at least one-fifth of the Senators duly chosen and sworn and one-fifth of the Members of the House of Representatives duly chosen and sworn; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id3704663a-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2/B/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an objection, states clearly and concisely, without argument, one of the grounds listed under clause (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id3704663b-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grounds for objections","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The only grounds for objections shall be as follows:","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id3704663c-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The electors of the State were not lawfully certified under a certificate of ascertainment of appointment of electors according to section 5(a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id3704663d-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The vote of one or more electors has not been regularly given.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id3704663e-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration of objections and questions.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id3704663f-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When all objections so made to any vote or paper from a State, or other question arising in the matter, shall have been received and read, the Senate shall thereupon withdraw, and such objections and questions shall be submitted to the Senate for its decision; and the Speaker of the House of Representatives shall, in like manner, submit such objections and questions to the House of Representatives for its decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id37046640-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No objection or any other question arising in the matter may be sustained unless such objection or question is sustained by separate concurring votes of each House.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id37046641-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reconvening","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the two Houses have voted, they shall immediately again meet, and the presiding officer shall then announce the decision of the questions submitted. No vote or paper from any other State shall be acted upon until the objections previously made to any vote or paper from any State, and other questions arising in the matter, shall have been finally disposed of.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id37046642-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules for Tabulating Votes.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id37046643-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Counting of votes.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id37046644-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subparagraph (B)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id37046645-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only the votes of electors who have been appointed under a certificate of ascertainment of appointment of electors issued pursuant to section 5, or who have legally been appointed to fill a vacancy of any such elector pursuant to section 4, may be counted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id37046646-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no vote of an elector described in clause (i) which has been regularly given shall be rejected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id37046647-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The vote of an elector who has been appointed under a certificate of ascertainment of appointment of electors issued pursuant to section 5 shall not be counted if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id37046648-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is an objection which meets the requirements of subsection (d)(2)(B)(i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id37046649-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each House affirmatively sustains the objection as valid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id3704664a-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of majority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the number of electors lawfully appointed by any State pursuant to a certificate of ascertainment of appointment of electors that is issued under section 5 is fewer than the number of electors to which the State is entitled under section 3, or if an objection the grounds for which are described in subsection (d)(2)(B)(ii)(I) has been sustained, the total number of electors appointed for the purpose of determining a majority of the whole number of electors appointed as required by the Twelfth Amendment to the Constitution shall be reduced by the number of electors whom the State has failed to appoint or as to whom the objection was sustained.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id3704664b-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s15/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"List of votes by tellers; declaration of winner","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The tellers shall make a list of the votes as they shall appear from the said certificates; and the votes having been ascertained and counted according to the rules in this subchapter provided, the result of the same shall be delivered to the President of the Senate, who shall thereupon announce the state of the vote, which announcement shall be deemed a sufficient declaration of the persons, if any, elected President and Vice President of the United States, and, together with a list of the votes, be entered on the Journals of the two Houses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id3704664c-2930-11f1-b70e-e9fd6f164ed0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch644"},"text":"June 25, 1948, ch. 644","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/675"},"text":"62 Stat. 675","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dP/tI/s109/a"},"text":"Pub. L. 117–328, div. P, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5237"},"text":"136 Stat. 5237","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id3704664d-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id3704664e-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id3704664f-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" amended section generally. Prior to amendment, section related to counting electoral votes in Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id37046650-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id37046651-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Counting of Electoral Votes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/228/s1"},"text":"Pub. L. 112–228, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-12-28"},"text":"Dec. 28, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1610"},"text":"126 Stat. 1610","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/228/s1"},"text":"“The meeting of the Senate and House of Representatives to be held in January 2013 pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s15"},"text":"section 15 of title 3","children":[],"tail":", United States Code, to count the electoral votes for President and Vice President cast by the electors in December 2012 shall be held on "},{"tag":"date","attrib":{"date":"2013-01-04"},"text":"January 4, 2013","children":[],"tail":" (rather than on the date specified in the first sentence of that section).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2009—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/430/s2"},"text":"Pub. L. 110–430, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-15"},"text":"Oct. 15, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4846"},"text":"122 Stat. 4846","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/430/s2"},"text":"“The meeting of the Senate and House of Representatives to be held in January 2009 pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s15"},"text":"section 15 of title 3","children":[],"tail":", United States Code, to count the electoral votes for President and Vice President cast by the electors in December 2008 shall be held on "},{"tag":"date","attrib":{"date":"2009-01-08"},"text":"January 8, 2009","children":[],"tail":" (rather than on the date specified in the first sentence of that section).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/296/s2"},"text":"Pub. L. 104–296, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3558"},"text":"110 Stat. 3558","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/296/s2"},"text":"“The meeting of the Senate and House of Representatives to be held in January 1997 pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s15"},"text":"section 15 of title 3","children":[],"tail":", United States Code, to count the electoral votes for President and Vice President cast by the electors in December 1996 shall be held on "},{"tag":"date","attrib":{"date":"1997-01-09"},"text":"January 9, 1997","children":[],"tail":" (rather than on the date specified in the first sentence of that section).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/646"},"text":"Pub. L. 100–646","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-09"},"text":"Nov. 9, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/3341"},"text":"102 Stat. 3341","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/646"},"text":"“That in carrying out the procedure set forth in section 15 of title, 3, United States Code, for 1989, ‘the fourth day of January’ shall be substituted for ‘the sixth day of January’ in the first sentence of such section.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1985—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/456"},"text":"Pub. L. 98–456","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-09"},"text":"Oct. 9, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1748"},"text":"98 Stat. 1748","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/98/456"},"text":"“That, in carrying out the procedure set forth in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s15"},"text":"section 15 of title 3","children":[],"tail":", United States Code, for 1985, ‘the seventh day of January’ shall be substituted for ‘the sixth day of January’ in the first sentence of such section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
