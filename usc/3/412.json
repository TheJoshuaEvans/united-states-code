{"tag":"section","attrib":{"id":"id371c33f3-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412"},"text":null,"children":[{"tag":"num","attrib":{"value":"412"},"text":"§ 412.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections under the Family and Medical Leave Act of 1993","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id371c33f4-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Family and Medical Leave Rights and Protections Provided.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371c33f5-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The rights and protections established by sections 101 through 105 of the Family and Medical Leave Act of 1993 shall apply to covered employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33f6-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the application described in paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371c33f7-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employer” as used in the Family and Medical Leave Act of 1993 means any employing office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371c33f8-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “eligible employee” as used in the Family and Medical Leave Act of 1993 means a covered employee who has been employed in any employing office for 12 months and for at least 1,250 hours of employment during the previous 12 months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33f9-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 401(b)(2), the requirements of paragraph (2)(B) shall not apply with respect to leave under subparagraph (A) or (B) of section 102(a)(1) of the Family and Medical Leave Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1"},"text":"29 U.S.C. 2612(a)(1)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371c33fa-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The remedy for a violation of subsection (a) shall be such remedy, including liquidated damages, as would be appropriate if awarded under paragraph (1) of section 107(a) of the Family and Medical Leave Act of 1993.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371c33fb-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rules for Substitution of Paid Leave.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371c33fc-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Substitution of paid leave","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A covered employee may elect to substitute for any leave without pay under subparagraph (A) or (B) of section 102(a)(1) of the Family and Medical Leave Act of 1993 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t29/s2612/a/1"},"text":"29 U.S.C. 2612(a)(1)","children":[],"tail":") any paid leave which is available to such employee for that purpose."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33fd-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Available leave","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The paid leave that is available to a covered employee for purposes of paragraph (1) is leave of the type and in the amount available to an employee under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6382/d/2/B"},"text":"section 6382(d)(2)(B) of title 5","children":[],"tail":", United States Code, for substitution for leave without pay under subparagraph (A) or (B) of section 6382(a)(1) of such title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33fe-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consistency with title 5","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paid leave shall be substituted under this subsection in a manner that is consistent with the requirements in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s6382/d/2"},"text":"section 6382(d)(2) of title 5","children":[],"tail":", United States Code, except that a reference in that section to an employing agency shall be considered to be a reference to an employing office, and subparagraph (E) of that section shall not apply."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea4ff-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations To Implement Section.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea500-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President, or the designee of the President, shall issue regulations to implement this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea501-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations issued under paragraph (1) shall be the same as substantive regulations promulgated by the Secretary of Labor to implement the statutory provisions referred to in subsections (a) and (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371ea502-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except to the extent that the President or designee may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371ea503-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except that the President or designee may, at the discretion of the President or designee, issue regulations to implement a provision of subchapter V of chapter 63 of title 5, United States Code, that applies to employees in the executive branch of the Federal Government in lieu of an analogous statutory provision referred to in subsection (a) or (b), if the issuance of such regulations—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id371ea504-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be equally effective for the implementation of the rights and protections under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id371ea505-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would promote uniformity in the application of Federal law to employees in the executive branch of the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371ea506-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except that the President or designee shall issue regulations to implement subsection (c) in accordance with the requirements of that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea507-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (a) and (b) shall take effect on the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea508-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of regulations issued under subsection (c) (as in effect on the date of enactment of the Presidential and Executive Office Accountability Act); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea509-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s412/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id371ea50a-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/a"},"text":"Pub. L. 104–331, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4057"},"text":"110 Stat. 4057","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXI/s1103/e/1"},"text":"Pub. L. 116–283, div. A, title XI, § 1103(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3888"},"text":"134 Stat. 3888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id371ea50b-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id371ea50c-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id371ea50d-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Family and Medical Leave Act of 1993, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/3"},"text":"Pub. L. 103–3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-02-05"},"text":"Feb. 5, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/6"},"text":"107 Stat. 6","children":[],"tail":", which enacted sections 60m and 60n of Title 2, The Congress, sections 6381 to 6387 of Title 5, Government Organization and Employees, and chapter 28 (§ 2601 et seq.) of Title 29, Labor, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s2105"},"text":"section 2105 of Title 5","children":[],"tail":", and enacted provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":". Sections 101 to 105 and 107 of the Act are classified to sections 2611 to 2615 and 2617, respectively, of Title 29. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s2601"},"text":"section 2601 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of the Presidential and Executive Office Accountability Act, referred to in subsec. (e)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331"},"text":"Pub. L. 104–331","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id371ea50e-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1103/e/1/A"},"text":"Pub. L. 116–283, § 1103(e)(1)(A)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1103/e/1/B"},"text":"Pub. L. 116–283, § 1103(e)(1)(B)","children":[],"tail":", (C), added subsec. (c) and redesignated former subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1103/e/1/D"},"text":"Pub. L. 116–283, § 1103(e)(1)(D)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1103/e/1/B"},"text":"Pub. L. 116–283, § 1103(e)(1)(B)","children":[],"tail":", redesignated subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/s1103/e/1/E"},"text":"Pub. L. 116–283, § 1103(e)(1)(E)","children":[],"tail":", inserted “(as in effect on the date of enactment of the Presidential and Executive Office Accountability Act)” after “subsection (c)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id371ea50f-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id371ea510-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tXI/s1103/e/2"},"text":"Pub. L. 116–283, div. A, title XI, § 1103(e)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3889"},"text":"134 Stat. 3889","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tXI/s1103/e/2"},"text":"“The amendments made by this subsection [amending this section] shall apply with respect to any birth or placement occurring on or after ","children":[{"tag":"date","attrib":{"date":"2020-10-01"},"text":"October 1, 2020","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id371ea511-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (c) of this section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s471/b"},"text":"section 471(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
