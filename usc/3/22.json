{"tag":"section","attrib":{"id":"id3706d68c-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"§ 22.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Severability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If any provision of this chapter, or the application of a provision to any person or circumstance, is held to be unconstitutional, the remainder of this chapter, and the application of the provisions to any person or circumstance, shall not be affected by the holding.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id3706d68d-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dP/tI/s111/a"},"text":"Pub. L. 117–328, div. P, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5240"},"text":"136 Stat. 5240","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
