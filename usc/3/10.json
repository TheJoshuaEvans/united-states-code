{"tag":"section","attrib":{"id":"id37046609-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"§ 10.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sealing and endorsing certificates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The electors shall seal up the certificates of votes so made by them, together with the annexed certificates of ascertainment of appointment of electors, and certify upon each that the lists of all the votes of such State given for President, and of all the votes given for Vice President, are contained therein.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id3704660a-2930-11f1-b70e-e9fd6f164ed0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch644"},"text":"June 25, 1948, ch. 644","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/674"},"text":"62 Stat. 674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dP/tI/s106/b"},"text":"Pub. L. 117–328, div. P, title I, § 106(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5236"},"text":"136 Stat. 5236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id3704660b-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id3704660c-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id3704660d-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" substituted “the certificates of votes so made by them, together with the annexed certificates of ascertainment of appointment of electors” for “the certificates so made by them”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
