{"tag":"section","attrib":{"id":"id3701f4d4-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"§ 5.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificate of ascertainment of appointment of electors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id3701f4d5-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id3701f4d6-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than the date that is 6 days before the time fixed for the meeting of the electors, the executive of each State shall issue a certificate of ascertainment of appointment of electors, under and in pursuance of the laws of such State providing for such appointment and ascertainment enacted prior to election day.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id3701f4d7-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of certificate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each certificate of ascertainment of appointment of electors shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id3701f4d8-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the names of the electors appointed and the canvass or other determination under the laws of such State of the number of votes given or cast for each person for whose appointment any and all votes have been given or cast;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id3701f4d9-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bear the seal of the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id3701f4da-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain at least one security feature, as determined by the State, for purposes of verifying the authenticity of such certificate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id3701f4db-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transmission","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be the duty of the executive of each State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id3701f4dc-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to transmit to the Archivist of the United States, immediately after the issuance of a certificate of ascertainment of appointment of electors and by the most expeditious method available, such certificate of ascertainment of appointment of electors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id3701f4dd-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to transmit to the electors of such State, on or before the day on which the electors are required to meet under section 7, six duplicate-originals of the same certificate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id3701f4de-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of Certificate as Conclusive","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of section 15:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id3701f4df-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id3701f4e0-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certificate issued by executive","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), a certificate of ascertainment of appointment of electors issued pursuant to subsection (a)(1) shall be treated as conclusive in Congress with respect to the determination of electors appointed by the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id3701f4e1-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certificates issued pursuant to court orders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any certificate of ascertainment of appointment of electors required to be issued or revised by any State or Federal judicial relief granted prior to the date of the meeting of electors shall replace and supersede any other certificates submitted pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id3701f4e2-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of federal questions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The determination of Federal courts on questions arising under the Constitution or laws of the United States with respect to a certificate of ascertainment of appointment of electors shall be conclusive in Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id3701f4e3-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue and Expedited Procedure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id3701f4e4-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any action brought by an aggrieved candidate for President or Vice President that arises under the Constitution or laws of the United States with respect to the issuance of the certification required under section (a)(1), or the transmission of such certification as required under subsection (b), shall be subject to the following rules:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id3701f4e5-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The venue for such action shall be the Federal district court of the Federal district in which the State capital is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id3701f4e6-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" 3","children":[{"tag":"inline","attrib":{},"text":"-judge panel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Such action shall be heard by a district court of three judges, convened pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2284"},"text":"section 2284 of title 28","children":[],"tail":", United States Code, except that—"}],"tail":null},{"tag":"clause","attrib":{"id":"id3701f4e7-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the court shall be comprised of two judges of the circuit court of appeals in which the district court lies and one judge of the district court in which the action is brought; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id3701f4e8-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 2284(b)(2) of such title shall not apply.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id3701f4e9-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expedited procedure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be the duty of the court to advance on the docket and to expedite to the greatest possible extent the disposition of the action, consistent with all other relevant deadlines established by this chapter and the laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id3701f4ea-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1253"},"text":"section 1253 of title 28","children":[],"tail":", United States Code, the final judgment of the panel convened under subparagraph (B) may be reviewed directly by the Supreme Court, by writ of certiorari granted upon petition of any party to the case, on an expedited basis, so that a final order of the court on remand of the Supreme Court may occur on or before the day before the time fixed for the meeting of electors."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id3701f4eb-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id3701f4ec-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be construed solely to establish venue and expedited procedures in any action brought by an aggrieved candidate for President or Vice President as specified in this subsection that arises under the Constitution or laws of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id3701f4ed-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s5/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not be construed to preempt or displace any existing State or Federal cause of action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id3701f4ee-2930-11f1-b70e-e9fd6f164ed0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch644"},"text":"June 25, 1948, ch. 644","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/673"},"text":"62 Stat. 673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dP/tI/s104/a"},"text":"Pub. L. 117–328, div. P, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5234"},"text":"136 Stat. 5234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id370465ef-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id370465f0-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id370465f1-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “If any State shall have provided, by laws enacted prior to the day fixed for the appointment of the electors, for its final determination of any controversy or contest concerning the appointment of all or any of the electors of such State, by judicial or other methods or procedures, and such determination shall have been made at least six days before the time fixed for the meeting of the electors, such determination made pursuant to such law so existing on said day, and made at least six days prior to said time of meeting of the electors, shall be conclusive, and shall govern in the counting of the electoral votes as provided in the Constitution, and as hereinafter regulated, so far as the ascertainment of the electors appointed by such State is concerned.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
