{"tag":"section","attrib":{"id":"id3704660e-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"§ 11.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transmission of certificates by electors","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The electors shall immediately transmit at the same time and by the most expeditious method available the certificates of votes so made by them, together with the annexed certificates of ascertainment of appointment of electors, as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id3704660f-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s11/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One set shall be sent to the President of the Senate at the seat of government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id37046610-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s11/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two sets shall be sent to the chief election officer of the State, one of which shall be held subject to the order of the President of the Senate, the other to be preserved by such official for one year and shall be a part of the public records of such office and shall be open to public inspection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id37046611-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s11/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Two sets shall be sent to the Archivist of the United States at the seat of government, one of which shall be held subject to the order of the President of the Senate and the other of which shall be preserved by the Archivist of the United States for one year and shall be a part of the public records of such office and shall be open to public inspection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id37046612-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s11/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One set shall be sent to the judge of the district in which the electors shall have assembled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id37046613-2930-11f1-b70e-e9fd6f164ed0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch644"},"text":"June 25, 1948, ch. 644","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/674"},"text":"62 Stat. 674","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch655/s7"},"text":"Oct. 31, 1951, ch. 655, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/712"},"text":"65 Stat. 712","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/e/1"},"text":"Pub. L. 98–497, title I, § 107(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2291"},"text":"98 Stat. 2291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dP/tI/s107/a"},"text":"Pub. L. 117–328, div. P, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5236"},"text":"136 Stat. 5236","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id37046614-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id37046615-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id37046616-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" amended section generally. Prior to amendment, section related to disposition of certificates."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" substituted “Archivist of the United States” for “Administrator of General Services” two places in par. “Third”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1951—Act ","children":[{"tag":"date","attrib":{"date":"1951-10-31"},"text":"Oct. 31, 1951","children":[],"tail":", substituted “Administrator of General Services” for “Secretary of State” two places in par. “Third”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id37046617-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id37046618-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-04-01"},"text":