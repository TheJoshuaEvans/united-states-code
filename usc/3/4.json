{"tag":"section","attrib":{"id":"id3701f4cf-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"§ 4.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vacancies in electoral college","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each State may, by law enacted prior to election day, provide for the filling of any vacancies which may occur in its college of electors when such college meets to give its electoral vote.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id3701f4d0-2930-11f1-b70e-e9fd6f164ed0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch644"},"text":"June 25, 1948, ch. 644","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/673"},"text":"62 Stat. 673","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dP/tI/s103"},"text":"Pub. L. 117–328, div. P, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5234"},"text":"136 Stat. 5234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id3701f4d1-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id3701f4d2-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id3701f4d3-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" inserted “enacted prior to election day” after “by law”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
