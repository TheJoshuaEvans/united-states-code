{"tag":"section","attrib":{"id":"id371ea54b-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416"},"text":null,"children":[{"tag":"num","attrib":{"value":"416"},"text":"§ 416.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections relating to veterans’ employment and reemployment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id371ea54c-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employment and Reemployment Rights of Members of the Uniformed Services.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea54d-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It shall be unlawful for an employing office to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371ea54e-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discriminate, within the meaning of subsections (a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4311"},"text":"section 4311 of title 38","children":[],"tail":", against an eligible employee;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371ea54f-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny to an eligible employee reemployment rights within the meaning of sections 4312 and 4313 of title 38; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371ea550-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny to an eligible employee benefits within the meaning of sections 4316, 4317, and 4318 of title 38.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea551-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “eligible employee” means a covered employee performing service in the uniformed services, within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4303/13"},"text":"section 4303(13) of title 38","children":[],"tail":", whose service has not been terminated upon the occurrence of any of the events enumerated in section 4304 of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea552-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The remedy for a violation of subsection (a) shall be such damages as would be appropriate if awarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s4323/d"},"text":"section 4323(d) of title 38","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea553-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations To Implement Section.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea554-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President, or the designee of the President, shall issue regulations to implement this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea555-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations issued under paragraph (1) shall be the same as substantive regulations promulgated by the Secretary of Labor to implement the statutory provisions referred to in subsections (a) and (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371ea556-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except to the extent that the President or designee may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371ea557-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except that the President or designee may, at the discretion of the President or designee, issue regulations to implement a provision of section 4314 or 4324 of title 38, United States Code, that applies to employees in the executive branch of the Federal Government in lieu of an analogous statutory provision referred to in subsection (a) or (b), if the issuance of such regulations—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id371ea558-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be equally effective for the implementation of the rights and protections under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id371ea559-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would promote uniformity in the application of Federal law to employees in the executive branch of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea55a-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (a) and (b) shall take effect on the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea55b-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of regulations issued under subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea55c-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s416/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id371ea55d-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/a"},"text":"Pub. L. 104–331, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4060"},"text":"110 Stat. 4060","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/275/tVII/s703/c"},"text":"Pub. L. 111–275, title VII, § 703(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-13"},"text":"Oct. 13, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2888"},"text":"124 Stat. 2888","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id371ea55e-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id371ea55f-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id371ea560-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2010—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/275"},"text":"Pub. L. 111–275","children":[],"tail":" substituted “under "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4323/d"},"text":"section 4323(d) of title 38","children":[],"tail":"” for “under paragraphs (1) and (2)(A) of "},{"tag":"ref","attrib":{"href":"/us/usc/t38/s4323/c"},"text":"section 4323(c) of title 38","children":[],"tail":"”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id371ea561-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id371ea562-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (c) of this section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s471/b"},"text":"section 471(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
