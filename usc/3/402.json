{"tag":"section","attrib":{"id":"id371c33bb-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s402"},"text":null,"children":[{"tag":"num","attrib":{"value":"402"},"text":"§ 402.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of laws","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The following laws shall apply, as prescribed by this chapter, to all employing offices (including employing offices within the meaning of section 411, to the extent prescribed therein):","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id371c33bc-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s402/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Fair Labor Standards Act of 1938.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33bd-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s402/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Title VII of the Civil Rights Act of 1964.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33be-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s402/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Americans with Disabilities Act of 1990.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33bf-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s402/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Age Discrimination in Employment Act of 1967.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33c0-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s402/5"},"text":null