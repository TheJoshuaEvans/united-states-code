{"tag":"section","attrib":{"id":"id371ea525-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s414"},"text":null,"children":[{"tag":"num","attrib":{"value":"414"},"text":"§ 414.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections under the Employee Polygraph Protection Act of 1988","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id371ea526-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s414/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Polygraph Practices Prohibited","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No employing office may require a covered employee to take a lie detector test where such a test would be prohibited if required by an employer under paragraph (1), (2), or (3) of section 3 of the Employee Polygraph Protection Act of 1988. In addition, the waiver provisions of section 6(d) of such Act shall apply to covered employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea527-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s414/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The remedy for a violation of subsection (a) shall be such damages as would be appropriate if awarded under section 6(c)(1) of the Employee Polygraph Protection Act of 1988.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea528-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s414/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations To Implement Section.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea529-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s414/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President, or the designee of the President, shall issue regulations to implement this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea52a-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s414/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations issued under paragraph (1) shall be the same as substantive regulations promulgated by the Secretary of Labor to implement the statutory provisions referred to in subsections (a) and (b) except to the extent that the President or designee may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea52b-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s414/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (a) and (b) shall take effect on the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea52c-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s414/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of regulations issued under subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea52d-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s414/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id371ea52e-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/a"},"text":"Pub. L. 104–331, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4058"},"text":"110 Stat. 4058","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id371ea52f-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id371ea530-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id371ea531-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 3 and 6 of the Employee Polygraph Protection Act of 1988, referred to in subsecs. (a) and (b), are classified to sections 2002 and 2005, respectively, of Title 29, Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id371ea532-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id371ea533-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (c) of this section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s471/b"},"text":"section 471(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
