{"tag":"section","attrib":{"id":"id372115dc-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s452"},"text":null,"children":[{"tag":"num","attrib":{"value":"452"},"text":"§ 452.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Counseling and mediation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id372115dd-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s452/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President, or the designee of the President, shall by regulation establish procedures substantially similar to those under sections 402 and 403 of the Congressional Accountability Act of 1995 for the counseling and mediation of alleged violations of a law made applicable under part A of subchapter II.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id372115de-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s452/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exhaustion Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A covered employee who has not exhausted counseling and mediation under subsection (a) shall be ineligible to make any election under section 453 or otherwise pursue any further form of relief under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id372115df-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/a"},"text":"Pub. L. 104–331, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4067"},"text":"110 Stat. 4067","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id372115e0-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id372115e1-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id372115e2-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Sections 402 and 403 of the Congressional Accountability Act of 1995, referred to in subsec. (a), are classified to sections 1402 and 1403, respectively, of Title 2, The Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id372115e3-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id372115e4-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1997-10-01"},"text":"Oct. 1, 1997","children":[],"tail":", except that subsec. (a) of this section effective "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s471"},"text":"section 471 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
