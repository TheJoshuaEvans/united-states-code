{"tag":"section","attrib":{"id":"id37104d06-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107"},"text":null,"children":[{"tag":"num","attrib":{"value":"107"},"text":"§ 107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Domestic Policy Staff and Office of Administration; personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id37104d07-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to enable the Domestic Policy Staff to perform its functions, the President (or his designee) is authorized—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id37104d08-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" without regard to any other provision of law regulating the employment or compensation of persons in the Government service, to appoint and fix the pay of not more than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id37104d09-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 6 employees at rates not to exceed the rate of basic pay then currently paid for level III of the Executive Schedule of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"; and in addition"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id37104d0a-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 18 employees at rates not to exceed the maximum rate of basic pay then currently paid for GS–18 of the General Schedule of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"; and in addition"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id37104d0b-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such number of other employees as he may determine to be appropriate at rates not to exceed the minimum rate of basic pay then currently paid for GS–16 of the General Schedule of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id37104d0c-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to procure, as provided in appropriation Acts, temporary or intermittent services of experts and consultants, as described in and in accordance with the first two sentences of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":", at respective daily rates of pay for individuals which are not more than the daily equivalent of the rate of basic pay then currently paid for level III of the Executive Schedule of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id37104d0d-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id37104d0e-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In order to enable the Office of Administration to perform its functions, the President (or his designee) is authorized—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id37104d0f-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" without regard to such other provisions of law as the President may specify which regulate the employment and compensation of persons in the Government service, to appoint and fix the pay of not more than—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id37104d10-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 employees at rates not to exceed the rate of basic pay then currently paid for level III of the Executive Schedule of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"; and in addition"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id37104d11-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 employees at rates not to exceed the maximum rate of basic pay then currently paid for GS–18 of the General Schedule of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id37104d12-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to procure, as provided in appropriation Acts, temporary or intermittent services of experts and consultants, as described in and in accordance with the first two sentences of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109/b"},"text":"section 3109(b) of title 5","children":[],"tail":", at respective daily rates of pay for individuals which are not more than the daily equivalent of the maximum rate of basic pay then currently paid for GS–18 of the General Schedule of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id37104d13-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to any authority granted under paragraph (1) of this subsection, the President (or his designee) is authorized to employ individuals in the Office of Administration in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3101"},"text":"section 3101 of title 5","children":[],"tail":" and provisions relating thereto. Any individual so employed under the authority granted under such section 3101 shall be subject to the limitation specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s114"},"text":"section 114 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id37104d14-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated each fiscal year such sums as may be necessary for the official expenses of the Domestic Policy Staff and the Office of Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id37104d15-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/570/s2/a"},"text":"Pub. L. 95–570, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2448"},"text":"92 Stat. 2448","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id37104d16-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id37104d17-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id37104d18-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 107, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch644"},"text":"act June 25, 1948, ch. 644","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/679"},"text":"62 Stat. 679","children":[],"tail":", providing that employees of the executive departments and independent establishments of the executive branch of the Government might be detailed from time to time to the White House Office for temporary assistance, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/95/570/s2/a"},"text":"section 2(a) of Pub. L. 95–570","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s112"},"text":"section 112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id37104d19-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id37104d1a-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable to any fiscal year beginning on or after ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"Oct. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/570/s6/a"},"text":"section 6(a) of Pub. L. 95–570","children":[],"tail":", set out as an Effective Date of 1978 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s102"},"text":"section 102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id37104d1b-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"References in Other Laws to GS–16, 17, or 18 Pay Rates","children":[],"tail":null},{"tag":"p","attrib":{},"text":"References in laws to the rates of pay for GS–16, 17, or 18, or to maximum rates of pay under the General Schedule, to be considered references to rates payable under specified sections of Title 5, Government Organization and Employees, see section 529 [title I, § 101(c)(1)] of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Pub. L. 101–509","children":[],"tail":", set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of Title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id37104d1c-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of Subsec. (b) to Current Employees of Office of Administration","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/570/s6/b"},"text":"Pub. L. 95–570, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2451"},"text":"92 Stat. 2451","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/570/s6/b"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":""},"text":null,"children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":"“In the case of an individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is an employee of the Office of Administration as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1978-11-02"},"text":"Nov. 2, 1978","children":[],"tail":"], and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose position would be terminated or whose rate of basic pay would be reduced (but for this subsection) by reason of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s107/b"},"text":"section 107(b) of title 3","children":[],"tail":", United States Code (as amended by this Act) [subsec. (b) of this section],"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"such employee may be allowed to continue to hold such position and receive basic pay at the rate in effect on the effective date of this Act [see Effective Date of 1978 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s102"},"text":"section 102 of this title","children":[],"tail":"] during the period which begins on such date and ends 2 years after such date so long as such employee continues as an employee of the Office of Administration.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
