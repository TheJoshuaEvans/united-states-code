{"tag":"section","attrib":{"id":"id372115a2-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431"},"text":null,"children":[{"tag":"num","attrib":{"value":"431"},"text":"§ 431.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of chapter 71 of title 5, relating to Federal service labor-management relations; procedures for remedy of violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id372115a3-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Labor-Management Rights","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (d), chapter 71 of title 5 shall apply to employing offices and to covered employees and representatives of those employees, except that covered employees shall not have a right to reinstatement pursuant to section 7118(a)(7)(C) or 7123 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id372115a4-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of the application under this section of chapter 71 of title 5, the term “agency” as used in such chapter means an employing office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id372115a5-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations To Implement Section.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id372115a6-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal Labor Relations Authority shall issue regulations to implement this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id372115a7-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d), the regulations issued under paragraph (1) shall be the same as substantive regulations promulgated by the Authority to implement the statutory provisions referred to in subsection (a), except—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id372115a8-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent the Authority may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id372115a9-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as the Authority may determine that a modification of such regulations is necessary to avoid a conflict of interest or appearance of a conflict of interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id372115aa-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific Regulations Regarding Applications to Certain Employing Offices.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id372115ab-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Authority shall issue regulations on the manner and the extent to which the requirements and exemptions of chapter 71 of title 5 should apply to covered employees who are employed in the offices listed in paragraph (2). The regulations shall, to the greatest extent practicable, be consistent with the provisions and purposes of chapter 71 of title 5 and of this chapter, and shall be the same as the substantive regulations issued by the Authority under such chapter, except—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id372115ac-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent the Authority may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id372115ad-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the Authority shall exclude from coverage under this section any covered employees who are employed in offices listed in paragraph (2) if the Authority determines that such exclusion is required because of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id372115ae-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conflict of interest or appearance of a conflict of interest; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id372115af-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President’s or Vice President’s constitutional responsibilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id372115b0-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offices referred to","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The offices referred to in paragraph (1) include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id372115b1-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the White House Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id372115b2-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Executive Residence at the White House;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id372115b3-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of the Vice President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id372115b4-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Policy Development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id372115b5-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Council of Economic Advisers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id372115b6-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Security Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id372115b7-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of Management and Budget; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id372115b8-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/d/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Office of National Drug Control Policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id372115b9-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id372115ba-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), subsections (a) and (b) shall take effect on the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id372115bb-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of regulations issued under subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id372115bc-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id372115bd-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain employing offices","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (a) and (b) shall take effect, with respect to employing offices, and employees of employing offices, referred to in subsection (d)(2), on the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id372115be-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of regulations issued under subsection (d); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id372115bf-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s431/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id372115c0-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/a"},"text":"Pub. L. 104–331, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4064"},"text":"110 Stat. 4064","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id372115c1-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id372115c2-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id372115c3-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsecs. (c) and (d) of this section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s471/b"},"text":"section 471(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
