{"tag":"section","attrib":{"id":"id371c33a8-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401"},"text":null,"children":[{"tag":"num","attrib":{"value":"401"},"text":"§ 401.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id371c33a9-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise specifically provided in this chapter, as used in this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id371c33aa-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Board” means the Merit Systems Protection Board under chapter 12 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33ab-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered employee” means any employee of an employing office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33ac-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “employee” includes an applicant for employment and a former employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33ad-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employing office","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “employing office” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371c33ae-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each office, agency, or other component of the Executive Office of the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371c33af-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Executive Residence at the White House; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371c33b0-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the official residence (temporary or otherwise) of the Vice President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371c33b1-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions Relating to Certain Matters","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of applying this chapter with respect to any practice or other matter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id371c33b2-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which section 411 relates, the terms “employing office” and “covered employee” shall each be considered to have the meaning given to the term by such section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33b3-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which section 412 relates, the term “covered employee” means a covered employee described in section 412(a)(2)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33b4-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which section 413 relates, the term “covered employee” excludes interns and volunteers, as described in section 413(a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371c33b5-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s401/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to which section 416 relates, the term “covered employee” means a covered employee described in section 416(a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id371c33b6-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/a"},"text":"Pub. L. 104–331, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4054"},"text":"110 Stat. 4054","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id371c33b7-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id371c33b8-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id371c33b9-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/b"},"text":"Pub. L. 104–331, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4068"},"text":"110 Stat. 4068","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/331/s2/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Appropriate measures shall be taken to ensure that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any regulations required to implement ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t3/s411"},"text":"section 411 of title 3","children":[],"tail":", United States Code, shall be in effect by "},{"tag":"date","attrib":{"date":"1997-10-01"},"text":"October 1, 1997","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other regulations needed to implement chapter 5 of title 3, United States Code, shall be in effect as soon as practicable, but not later than ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id371c33ba-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Applicability of Future Employment Laws","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s4"},"text":"Pub. L. 104–331, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4071"},"text":"110 Stat. 4071","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/331/s4"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each provision of Federal law that is made applicable to the legislative branch under section 102 of the Congressional Accountability Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s1302"},"text":"2 U.S.C. 1302","children":[],"tail":"), and that is enacted later than 12 months after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":"], shall be deemed to apply with respect to ‘employing offices’ and ‘covered employees’ (within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s401"},"text":"section 401 of title 3","children":[],"tail":", United States Code, as added by this Act), unless such law specifically provides otherwise and expressly cites this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President, or the designee of the President, shall issue regulations to implement such provision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations issued under paragraph (1) to implement a provision shall be the same as substantive regulations promulgated by the head of the appropriate executive agency to implement the provision, except to the extent that the President or designee may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under the section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
