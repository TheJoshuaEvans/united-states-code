{"tag":"section","attrib":{"id":"id37046602-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"§ 8.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manner of voting","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The electors shall vote for President and Vice President, respectively, in the manner directed by the Constitution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id37046603-2930-11f1-b70e-e9fd6f164ed0"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1948-06-25/ch644"},"text":"June 25, 1948, ch. 644","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/62/674"},"text":"62 Stat. 674","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
