{"tag":"section","attrib":{"id":"id371ea57e-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425"},"text":null,"children":[{"tag":"num","attrib":{"value":"425"},"text":"§ 425.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and protections under the Occupational Safety and Health Act of 1970; procedures for remedy of violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id371ea57f-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Occupational Safety and Health Protections.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea580-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each employing office and each covered employee shall comply with the provisions of section 5 of the Occupational Safety and Health Act of 1970.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea581-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of the application under this section of the Occupational Safety and Health Act of 1970—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371ea582-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employer” as used in such Act means an employing office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371ea583-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “employee” as used in such Act means a covered employee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea584-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The remedy for a violation of subsection (a) shall be an order to correct the violation, including such order as would be appropriate if issued under section 13(a) of the Occupational Safety and Health Act of 1970.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea585-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea586-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requests for inspections","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon written request of any employing office or covered employee, the Secretary of Labor shall have the authority to inspect and investigate places of employment under the jurisdiction of employing offices in accordance with subsections (a), (d), (e), and (f) of section 8 of the Occupational Safety and Health Act of 1970.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea587-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Citations, notices, and notifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Labor shall have the authority, in accordance with sections 9 and 10 of the Occupational Safety and Health Act of 1970, to issue—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371ea588-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a citation or notice to any employing office responsible for correcting a violation of subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371ea589-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notification to any employing office that the Secretary of Labor believes has failed to correct a violation for which a citation has been issued within the period permitted for its correction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea58a-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hearings and review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If after issuing a citation or notification, the Secretary of Labor determines that a violation has not been corrected—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371ea58b-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the citation and notification shall be deemed a final order (within the meaning of section 10(b) of the Occupational Safety and Health Act of 1970) if the employer fails to notify the Secretary of Labor within 15 days (excluding Saturdays, Sundays, and Federal holidays) after receipt of the notice that the employer intends to contest the citation or notification; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371ea58c-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunity for a hearing before the Occupational Safety and Health Review Commission shall be afforded in accordance with section 10(c) of the Occupational Safety and Health Act of 1970, if the employer gives timely notice to the Secretary that he intends to contest the citation or notification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea58d-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Variance procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employing office may request from the Secretary of Labor an order granting a variance from a standard made applicable by this section, in accordance with sections 6(b)(6) and 6(d) of the Occupational Safety and Health Act of 1970.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea58e-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judicial review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person or employing office aggrieved by a final decision of the Occupational Safety and Health Review Commission under paragraph (3) or the Secretary of Labor under paragraph (4) may file a petition for review with the United States Court of Appeals for the Federal Circuit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1296"},"text":"section 1296 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea58f-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If new appropriated funds are necessary to correct a violation of subsection (a) for which a citation is issued, or to comply with an order requiring correction of such a violation, correction or compliance shall take place as soon as possible, but not later than the end of the fiscal year following the fiscal year in which the citation is issued or the order requiring correction becomes final and not subject to further review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id371ea590-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations To Implement Section.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id371ea591-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President, or the designee of the President, shall issue regulations to implement this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea592-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations issued under paragraph (1) shall be the same as substantive regulations promulgated by the Secretary of Labor to implement the statutory provisions referred to in subsections (a) and (b)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id371ea593-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except to the extent that the President or designee may determine, for good cause shown and stated together with the regulation, that a modification of such regulations would be more effective for the implementation of the rights and protections under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id371ea594-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except that the President or designee may, at the discretion of the President or designee, issue regulations to implement a provision of section 19 of the Occupational Safety and Health Act of 1970 that applies to agencies or employees of the executive branch of the Federal Government in lieu of an analogous statutory provision referred to in subsection (a) or (b), if the issuance of such regulations—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id371ea595-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be equally effective for the implementation of the rights and protections under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id371ea596-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would promote uniformity in the application of Federal law to employees in the executive branch of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id371ea597-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employing office responsible for correction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations issued under paragraph (1) shall include a method of identifying, for purposes of this section and for different categories of violations of subsection (a), the employing office responsible for correction of a particular violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id37211598-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (a) through (c) shall take effect on the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id37211599-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effective date of regulations issued under subsection (d); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id3721159a-2930-11f1-b70e-e9fd6f164ed0","identifier":"/us/usc/t3/s425/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id3721159b-2930-11f1-b70e-e9fd6f164ed0"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/331/s2/a"},"text":"Pub. L. 104–331, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/4062"},"text":"110 Stat. 4062","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id3721159c-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id3721159d-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id3721159e-2930-11f1-b70e-e9fd6f164ed0"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Occupational Safety and Health Act of 1970, referred to in subsecs. (a) to (c)(4) and (d)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/596"},"text":"Pub. L. 91–596","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-12-29"},"text":"Dec. 29, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1590"},"text":"84 Stat. 1590","children":[],"tail":", which is classified principally to chapter 15 (§ 651 et seq.) of Title 29, Labor. Sections 5, 6, 8 to 10, 13, and 19 of the Act are classified to sections 654, 655, 657 to 659, 662, and 668, respectively, of Title 29. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s651"},"text":"section 651 of Title 29","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id3721159f-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id372115a0-2930-11f1-b70e-e9fd6f164ed0"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsec. (d) of this section effective ","children":[{"tag":"date","attrib":{"date":"1996-10-26"},"text":"Oct. 26, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/usc/t3/s471/b"},"text":"section 471(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
