ildren":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “ruling, provision” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the word “imposes” is substituted for “assesses” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “the procedural requirements of” and “the substantive requirements of” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2)(A), the words “procedural requirements of the Federal standards established pursuant to” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “may bring a civil action for judicial review” are substituted for “may seek judicial review . . . only by filing a petition” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca95e870-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:5125(a) and (b)(1) to clarify the restatement of 49 App.:1804(a)(4) and 1811(a) by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1994-07-05/s1"},"text":"section 1 of the Act of July 5, 1994","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Public Law 103–272","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/781"},"text":"108 Stat. 781","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca95e871-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca95e872-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s33006/d"},"text":"Pub. L. 112–141, § 33006(d)","children":[],"tail":", inserted “and other written hazardous materials transportation incident reporting involving State or local emergency responders in the initial response to the incident” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s33013/b"},"text":"Pub. L. 112–141, § 33013(b)","children":[],"tail":", inserted “, and is published in the Department’s hazardous materials route registry under section 5112(c)” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s33011"},"text":"Pub. L. 112–141, § 33011","children":[],"tail":", substituted “biennially” for “, upon the Secretary’s request,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244/s302/c/1"},"text":"Pub. L. 110–244, § 302(c)(1)","children":[],"tail":", substituted “5119(f)” for “5119(e)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244/s302/c/2"},"text":"Pub. L. 110–244, § 302(c)(2)","children":[],"tail":", substituted “5119(f)” for “5119(b)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244/s302/c/2"},"text":"Pub. L. 110–244, § 302(c)(2)","children":[],"tail":", (3), substituted “(a), (b)(1), or (c)” for “(b), (c)(1), or (d)” and “5119(f)” for “5119(b)”."}],"ta