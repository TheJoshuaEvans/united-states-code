{"tag":"section","attrib":{"id":"idca95e849-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125"},"text":null,"children":[{"tag":"num","attrib":{"value":"5125"},"text":"§ 5125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca95e84a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsections (b), (c), and (e) of this section and unless authorized by another law of the United States, a requirement of a State, political subdivision of a State, or Indian tribe is preempted if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95e84b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complying with a requirement of the State, political subdivision, or tribe and a requirement of this chapter, a regulation prescribed under this chapter, or a hazardous materials transportation security regulation or directive issued by the Secretary of Homeland Security is not possible; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e84c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirement of the State, political subdivision, or tribe, as applied or enforced, is an obstacle to accomplishing and carrying out this chapter, a regulation prescribed under this chapter, or a hazardous materials transportation security regulation or directive issued by the Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e84d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Substantive Differences","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95e84e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (c) of this section and unless authorized by another law of the United States, a law, regulation, order, or other requirement of a State, political subdivision of a State, or Indian tribe about any of the following subjects, that is not substantively the same as a provision of this chapter, a regulation prescribed under this chapter, or a hazardous materials transportation security regulation or directive issued by the Secretary of Homeland Security, is preempted:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95e84f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designation, description, and classification of hazardous material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95e850-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the packing, repacking, handling, labeling, marking, and placarding of hazardous material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95e851-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preparation, execution, and use of shipping documents related to hazardous material and requirements related to the number, contents, and placement of those documents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95e852-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the written notification, recording, and reporting of the unintentional release in transportation of hazardous material and other written hazardous materials transportation incident reporting involving State or local emergency responders in the initial response to the incident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95e853-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designing, manufacturing, fabricating, inspecting, marking, maintaining, reconditioning, repairing, or testing a package, container, or packaging component that is represented, marked, certified, or sold as qualified for use in transporting hazardous material in commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e854-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary prescribes or has prescribed under section 5103(b), 5104, 5110, or 5112 of this title or prior comparable provision of law a regulation or standard related to a subject referred to in paragraph (1) of this subsection, a State, political subdivision of a State, or Indian tribe may prescribe, issue, maintain, and enforce only a law, regulation, standard, or order about the subject that is substantively the same as a provision of this chapter or a regulation prescribed or order issued under this chapter. The Secretary shall decide on and publish in the Federal Register the effective date of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5103/b"},"text":"section 5103(b) of this title","children":[],"tail":" for any regulation or standard about any of those subjects that the Secretary prescribes. The effective date may not be earlier than 90 days after the Secretary prescribes the regulation or standard nor later than the last day of the 2-year period beginning on the date the Secretary prescribes the regulation or standard."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e855-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If a State, political subdivision of a State, or Indian tribe imposes a fine or penalty the Secretary decides is appropriate for a violation related to a subject referred to in paragraph (1) of this subsection, an additional fine or penalty may not be imposed by any other authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e856-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Section","children":[],"tail":" 5112(b) "},{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95e857-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, after the last day of the 2-year period beginning on the date a regulation is prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5112/b"},"text":"section 5112(b) of this title","children":[],"tail":", a State or Indian tribe may establish, maintain, or enforce a highway routing designation over which hazardous material may or may not be transported by motor vehicles, or a limitation or requirement related to highway routing, only if the designation, limitation, or requirement complies with section 5112(b), and is published in the Department’s hazardous materials route registry under section 5112(c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e858-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95e859-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A highway routing designation, limitation, or requirement established before the date a regulation is prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5112/b"},"text":"section 5112(b) of this title","children":[],"tail":" does not have to comply with section 5112(b)(1)(B), (C), and (F)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95e85a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5112"},"text":"section 5112 of this title","children":[],"tail":" do not require a State or Indian tribe to comply with section 5112(b)(1)(I) if the highway routing designation, limitation, or requirement was established before "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95e85b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may allow a highway routing designation, limitation, or requirement to continue in effect until a dispute related to the designation, limitation, or requirement is resolved under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5112/d"},"text":"section 5112(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e85c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Decisions on Preemption","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95e85d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person (including a State, political subdivision of a State, or Indian tribe) directly affected by a requirement of a State, political subdivision, or tribe may apply to the Secretary, as provided by regulations prescribed by the Secretary, for a decision on whether the requirement is preempted by subsection (a), (b)(1), or (c) of this section or section 5119(f). The Secretary shall publish notice of the application in the Federal Register. The Secretary shall issue a decision on an application for a determination within 180 days after the date of the publication of the notice of having received such application, or the Secretary shall publish a statement in the Federal Register of the reason why the Secretary’s decision on the application is delayed, along with an estimate of the additional time necessary before the decision is made. After notice is published, an applicant may not seek judicial relief on the same or substantially the same issue until the Secretary takes final action on the application or until 180 days after the application is filed, whichever occurs first.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e85e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After consulting with States, political subdivisions of States, and Indian tribes, the Secretary shall prescribe regulations for carrying out paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e85f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsection (a) of this section does not prevent a State, political subdivision of a State, or Indian tribe, or another person directly affected by a requirement, from seeking a decision on preemption from a court of competent jurisdiction instead of applying to the Secretary under paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e860-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Preemption","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State, political subdivision of a State, or Indian tribe may apply to the Secretary for a waiver of preemption of a requirement the State, political subdivision, or tribe acknowledges is preempted by subsection (a), (b)(1), or (c) of this section or section 5119(f). Under a procedure the Secretary prescribes by regulation, the Secretary may waive preemption on deciding the requirement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95e861-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the public at least as much protection as do requirements of this chapter and regulations prescribed under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e862-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an unreasonable burden on commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e863-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95e864-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State, political subdivision of a State, or Indian tribe may impose a fee related to transporting hazardous material only if the fee is fair and used for a purpose related to transporting hazardous material, including enforcement and planning, developing, and maintaining a capability for emergency response.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e865-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A State or political subdivision thereof or Indian tribe that levies a fee in connection with the transportation of hazardous materials shall biennially report to the Secretary on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95e866-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the basis on which the fee is levied upon persons involved in such transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95e867-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes for which the revenues from the fee are used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95e868-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the annual total amount of the revenues collected from the fee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95e869-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other matters as the Secretary requests.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e86a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Each Preemption Standard","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each standard for preemption in subsection (a), (b)(1), or (c), and in section 5119(f), is independent in its application to a requirement of a State, political subdivision of a State, or Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e86b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5125/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-Federal Enforcement Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to any procedure, penalty, required mental state, or other standard utilized by a State, political subdivision of a State, or Indian tribe to enforce a requirement applicable to the transportation of hazardous material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca95e86c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl