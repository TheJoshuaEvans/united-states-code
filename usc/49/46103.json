{"tag":"section","attrib":{"id":"idcc373d32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103"},"text":null,"children":[{"tag":"num","attrib":{"value":"46103"},"text":"§ 46103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of notice, process, and actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc373d33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designating Agents","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc373d34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each air carrier and foreign air carrier shall designate an agent on whom service of notice and process in a proceeding before, and an action of, the Secretary of Transportation (or the Administrator of the Transportation Security Administration with respect to security duties and powers designated to be carried out by the Administrator of the Transportation Security Administration or the Administrator of the Federal Aviation Administration with respect to aviation safety duties and powers designated to be carried out by the Administrator of the Federal Aviation Administration) may be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373d35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The designation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc373d36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in writing and filed with the Secretary, Administrator of the Transportation Security Administration, or Administrator of the Federal Aviation Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373d37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be changed in the same way as originally made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373d38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc373d39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Service may be made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc373d3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by personal service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373d3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a designated agent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373d3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by certified or registered mail to the person to be served or the designated agent of the person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373d3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by electronic or facsimile transmission to the person to be served or the designated agent of the person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373d3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as designated by regulation or guidance published in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373d3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date of service made by certified or registered mail is the date of mailing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373d40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The date of service made by an electronic or facsimile method is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc373d41-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date an electronic or facsimile transmission is sent; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373d42-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date a notification is sent by an electronic or facsimile method that a notice, process, or action is immediately available and accessible in an electronic database.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373d43-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Serving Agents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Service on an agent designated under this section shall be made at the office or usual place of residence of the agent or at the electronic or facsimile address designated by the agent. If an air carrier or foreign air carrier does not have a designated agent, service may be made by posting the notice, process, or action in the office of the Secretary, Administrator of the Transportation Security Administration, or Administrator of the Federal Aviation Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc373d44-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail"