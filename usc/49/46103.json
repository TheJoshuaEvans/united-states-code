text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(b)(1)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(b)(1)(E); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/e"},"text":"Pub. L. 98–443, § 3(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s6/c/1"},"text":"Pub. L. 89–670, § 6(c)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/938"},"text":"80 Stat. 938","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/449/s7/b"},"text":"Pub. L. 97–449, § 7(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2444"},"text":"96 Stat. 2444","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46103(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1485(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s1005/c"},"text":"Pub. L. 85–726, § 1005(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/794"},"text":"72 Stat. 794","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Aug. 25, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/199"},"text":"Pub. L. 86–199","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/427"},"text":"73 Stat. 427","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46103(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1485(b) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(b)(1)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “in a proceeding before” are added for clarity. The word “action” is substituted for “orders, decisions, and requirements” to eliminate unnecessary words. The words “for and on behalf of said carrier” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(B), the words “from time to time” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(B), the words “in writing for the purpose” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(C), the word “addressed” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the word “date” is substituted for “time” for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “with like effect as if made personally upon such carrier” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc373d48-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc373d49-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(1)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s219/1/A"},"text":"Pub. L. 118–63, § 219(1)(A)","children":[],"tail":", added subpars. (D) and (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s219/1/B"},"text":"Pub. L. 118–63, § 219(1)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s219/2"},"text":"Pub. L. 118–63, § 219(2)","children":[],"tail":", substituted “Service on an agent designated under this section shall be made at the office or usual place of residence of the agent or at the electronic or facsimile address designated by the agent.” for “Service on an agent designated under this section shall be made at the office or usual place of residence of the agent.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/f/3"},"text":"Pub. L. 115–254, § 1991(f)(3)","children":[],"tail":", substituted “by the Administrator of the Federal Aviation Administration)” for “by the Administrator)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/f/1"},"text":"Pub. L. 115–254, § 1991(f)(1)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration with respect to security duties and powers designated to be carried out by the Administrator of the Transportation Security Administration” for “Under Secretary of Transportation for Security with respect to security duties and powers designated to be carried out by the Under Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/f/2"},"text":"Pub. L. 115–254, § 1991(f)(2)","children":[],"tail":", (4), substituted “Administrator of the Transportation Security Administration,” for “Under Secretary,” and “or Administrator of the Federal Aviation Administration” for “or Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/f/2"},"text":"Pub. L. 115–254, § 1991(f)(2)","children":[],"tail":", (4), substituted “Administrator of the Transportation Security Administration,” for “Under Secretary,” and “or Administrator of the Federal Aviation Administration” for “or Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s140/b/1"},"text":"Pub. L. 107–71, § 140(b)(1)","children":[],"tail":", inserted “the Under Secretary of Transportation for Security with respect to security duties and powers designated to be carried out by the Under Secretary or” after “(or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s140/b/2"},"text":"Pub. L. 107–71, § 140(b)(2)","children":[],"tail":", substituted “, Under Secretary, or Administrator” for “or Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s140/b/2"},"text":"Pub. L. 107–71, § 140(b)(2)","children":[],"tail":", substituted “, Under Secretary, or Administrator” for “or Administrator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
