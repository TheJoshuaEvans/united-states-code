{"tag":"section","attrib":{"id":"idcb48bd3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114"},"text":null,"children":[{"tag":"num","attrib":{"value":"30114"},"text":"§ 30114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special exemptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb48bd3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"inline","attrib":{},"text":" ","children":[],"tail":null},{"tag":"ref","attrib":{"idref":"fn002106"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002106"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “(a)”."}],"tail":null},{"tag":"inline","attrib":{},"text":" Vehicles Used for Particular Purposes","children":[],"tail":"."},{"tag":"ref","attrib":{"idref":"fn002107"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002107"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by a dash."}],"tail":" The Secretary of Transportation may exempt a motor vehicle or item of motor vehicle equipment from "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s30112/a"},"text":"section 30112(a) of this title","children":[],"tail":" on terms the Secretary decides are necessary for research, investigations, demonstrations, training, competitive racing events, show, or display."}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb48bd3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption for Low-volume Manufacturers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb48bd3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb48bd40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt from ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30112/a"},"text":"section 30112(a) of this title","children":[],"tail":" not more than 325 replica motor vehicles per year that are manufactured or imported by a low-volume manufacturer; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb48bd41-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraph (4) of this subsection, limit any such exemption to the Federal Motor Vehicle Safety Standards applicable to motor vehicles and not motor vehicle equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb48bd42-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registration requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To qualify for an exemption under paragraph (1), a low-volume manufacturer shall register with the Secretary at such time, in such manner, and under such terms that the Secretary determines appropriate. The Secretary shall establish terms that ensure that no person may register as a low-volume manufacturer if the person is registered as an importer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30141"},"text":"section 30141 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb48bd43-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permanent label requirement.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb48bd44-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require a low-volume manufacturer to affix a permanent label to a motor vehicle exempted under paragraph (1) that identifies the specified standards and regulations for which such vehicle is exempt from section 30112(a), states that the vehicle is a replica, and designates the model year such vehicle replicates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb48bd45-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written notice","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may require a low-volume manufacturer of a motor vehicle exempted under paragraph (1) to deliver written notice of the exemption to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb48bd46-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dealer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb48bd47-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first purchaser of the motor vehicle, if the first purchaser is not an individual that purchases the motor vehicle for resale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb48bd48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A low-volume manufacturer shall annually submit a report to the Secretary including the number and description of the motor vehicles exempted under paragraph (1) and a list of the exemptions described on the label affixed under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb48bd49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on other provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any motor vehicle exempted under this subsection shall also be exempted from sections 32304, 32502, and 32902 of this title and from section 3 of the Automobile Information Disclosure Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1232"},"text":"15 U.S.C. 1232","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb48bd4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation and public notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall have 90 days to review and approve or deny a registration submitted under paragraph (2). If the Secretary determines that any such registration submitted is incomplete, the Secretary shall have an additional 30 days for review. Any registration not approved or denied within 90 days after initial submission, or 120 days if the registration submitted is incomplete, shall be deemed approved. The Secretary shall have the authority to revoke an existing registration based on a failure to comply with requirements set forth in this subsection or a finding by the Secretary of a safety-related defect or unlawful conduct under this chapter that poses a significant safety risk. The registrant shall be provided a reasonable opportunity to correct all deficiencies, if such are correctable based on the sole discretion of the Secretary. An exemption granted by the Secretary to a low-volume manufacturer under this subsection may not be transferred to any other person, and shall expire at the end of the calendar year for which it was granted with respect to any volume authorized by the exemption that was not applied by the low-volume manufacturer to vehicles built during that calendar year. The Secretary shall maintain an up-to-date list of registrants and a list of the make and model of motor vehicles exempted under paragraph (1) on at least an annual basis and publish such list in the Federal Register or on a website operated by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb48bd4b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation of liability for original manufacturers, licensors or owners of product configuration, trade dress, or design patents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The original manufacturer, its successor or assignee, or current owner, who grants a license or otherwise transfers rights to a low-volume manufacturer shall incur no liability to any person or entity under Federal or State statute, regulation, local ordinance, or under any Federal or State common law for such license or assignment to a low-volume manufacturer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb48bd4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb48bd4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Low-volume manufacturer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “low-volume manufacturer” means a motor vehicle manufacturer, other than a person who is registered as an importer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30141"},"text":"section 30141 of this title","children":[],"tail":", whose annual worldwide production, including by a parent or subsidiary of the manufacturer, if applicable, is not more than 5,000 motor vehicles."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb48bd4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Replica motor vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “replica motor vehicle” means a motor vehicle produced by a low-volume manufacturer and that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb48bd4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/7/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is intended to resemble the body of another motor vehicle that was manufactured not less than 25 years before the manufacture of the replica motor vehicle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb48bd50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/7/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is manufactured under a license for the product configuration, trade dress, trademark, or patent, for the motor vehicle that is intended to be replicated from the original manufacturer, its successors or assignees, or current owner of such product configuration, trade dress, trademark, or patent rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb48bd51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraphs (1) and (4), a registrant shall be considered a motor vehicle manufacturer for purposes of parts A and C of subtitle VI of this title. Nothing shall be construed to exempt a registrant from complying with the requirements under sections 30116 through 30120A of this title if the motor vehicle excepted under paragraph (1) contains a defect related to motor vehicle safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb48bd52-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30114/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State registration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection shall be construed to preempt, affect, or supersede any State titling or registration law or regulation for a replica motor vehicle, or exempt a person from complying with such law or regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb48bd53-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/947"},"text":"108 Stat. 947","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tVII/s7107/a"},"text":"Pub. L. 105–178, title VII, § 7107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/469"},"text":"112 Stat. 469","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dB/tXXIV/s24405/a"},"text":"Pub. L. 114–94, div. B, title XXIV, § 24405(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1721"},"text":"129 Stat. 1721","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb48bd54-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb48bd55-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb48bd56-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30114","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(j).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563"},"text":"Pub. L. 89–563","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/718"},"text":"80 Stat. 718","children":[],"tail":", § 108(j); added "},{"tag":"html:span","attrib":{},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/562/s2/b"},"text":"Pub. L. 100–562, § 2(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2824"},"text":"102 Stat. 2824","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The word “conditions” is omitted as being included in “terms”, and the word “studies” is omitted as being included in “research”. The word “solely” is omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb48bd57-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb48bd58-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" designated existing provisions as subsec. “"},{"tag":"inline","attrib":{},"text":"(a)","children":[],"tail":"”, inserted heading, and added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" substituted “competitive racing events, show, or display” for “or competitive racing events”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb48bd59-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb48bd5a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transition Rule","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tVII/s7107/b"},"text":"Pub. L. 105–178, title VII, § 7107(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/469"},"text":"112 Stat. 469","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/178/tVII/s7107/b"},"text":"“A person who is the owner of a motor vehicle located in the United States on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":"] may seek an exemption under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s30114"},"text":"section 30114 of title 49","children":[],"tail":", United States Code, as amended by subsection (a) of this section, for a period of 6 months after the date regulations of the Secretary of Transportation promulgated in response to such amendment take effect.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
