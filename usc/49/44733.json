{"tag":"section","attrib":{"id":"idcc0779bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733"},"text":null,"children":[{"tag":"num","attrib":{"value":"44733"},"text":"§ 44733.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Oversight of repair stations located outside the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc0779c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Federal Aviation Administration shall establish and implement a safety assessment system for all part 145 repair stations based on the type, scope, and complexity of work being performed. The system shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0779c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that repair stations located outside the United States are subject to appropriate inspections based on identified risks and consistent with existing United States requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider inspection results and findings submitted by foreign civil aviation authorities operating under a maintenance safety or maintenance implementation agreement with the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require all maintenance safety or maintenance implementation agreements to provide an opportunity for the Administration to conduct independent inspections of part 145 repair stations when safety concerns warrant such inspections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0779c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Congress of Negotiations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall notify the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives not later than 30 days after initiating formal negotiations with foreign aviation authorities or other appropriate foreign government agencies on a new maintenance safety or maintenance implementation agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0779c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall publish an annual report on the Administration’s oversight of part 145 repair stations and implementation of the safety assessment system required under subsection (a). The report shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0779c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe in detail any improvements in the Administration’s ability to identify and track where part 121 air carrier repair work is performed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a staffing model to determine the best placement of inspectors and the number of inspectors needed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the training provided to inspectors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an assessment of the quality of monitoring and surveillance by the Administration of work performed by its inspectors and the inspectors of foreign authorities operating under a maintenance safety or maintenance implementation agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0779ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alcohol and Controlled Substances Testing Program Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0779cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of State and the Secretary of Transportation, acting jointly, shall request the governments of foreign countries that are members of the International Civil Aviation Organization to establish international standards for alcohol and controlled substances testing of persons that perform safety-sensitive maintenance functions on commercial air carrier aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to part 121 aircraft work","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, the Administrator shall promulgate a proposed rule requiring that all part 145 repair station employees responsible for safety-sensitive maintenance functions on part 121 air carrier aircraft are subject to an alcohol and controlled substances testing program determined acceptable by the Administrator and consistent with the applicable laws of the country in which the repair station is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0779cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Inspections","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall ensure that part 145 repair stations located outside the United States are inspected annually, without prior notice to such repair stations, by Federal Aviation Administration safety inspectors, without regard to where the station is located, in a manner consistent with United States obligations under international agreements and the applicable laws of the country in which the repair station is located. The Administrator may carry out announced or unannounced inspections in addition to the annual unannounced inspection required under this subsection based on identified risks and in a manner consistent with United States obligations under international agreements and the applicable laws of the country in which the part 145 repair station is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0779ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Risk-Based Oversight.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0779cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of enactment of the FAA Extension, Safety, and Security Act of 2016, the Administrator shall take measures to ensure that the safety assessment system established under subsection (a)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0779d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" places particular consideration on inspections of part 145 repair stations located outside the United States that conduct scheduled heavy maintenance work on part 121 air carrier aircraft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0779d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accounts for the frequency and seriousness of any corrective actions that part 121 air carriers must implement to aircraft following such work at such repair stations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"International agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall take the measures required under paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0779d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in accordance with United States obligations under applicable international agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0779d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a manner consistent with the applicable laws of the country in which a repair station is located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may access and review such information or data in the possession of a part 121 air carrier as the Administrator may require in carrying out paragraph (1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0779d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data Analysis.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0779d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each fiscal year in which a part 121 air carrier has had heavy maintenance work performed on an aircraft owned or operated by such carrier, such carrier shall provide to the Administrator, not later than the end of the following fiscal year, a report containing the information described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A report under paragraph (1) shall contain the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0779d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The location where any heavy maintenance work on aircraft was performed outside the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0779da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description of the work performed at each such location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0779db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The date of completion of the work performed at each such location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0779dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A list of all failures, malfunctions, or defects affecting the safe operation of such aircraft identified by the air carrier not later than 30 days after the date on which an aircraft is returned to service, organized by reference to aircraft registration number, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc0779dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires corrective action after the aircraft is approved for return to service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc0779de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" results from such work performed on such aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0779df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The certificate number of the person approving such aircraft or on-wing aircraft engine for return to service following completion of the work performed at each such location.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Analysis","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0779e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyze information provided under this subsection and sections 121.703, 121.705, 121.707, and 145.221 of title 14, Code of Federal Regulations, or any successor provisions of such title, to detect safety issues associated with heavy maintenance work on aircraft performed outside the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0779e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require appropriate actions by an air carrier or repair station in response to any safety issue identified by the analysis conducted under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Confidentiality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Information provided under this subsection shall be subject to the same protections given to voluntarily provided safety or security related information under section 40123.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0779e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications and Prohibition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0779e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may not approve any new application under part 145 of title 14, Code of Federal Regulations, from a person located or headquartered in a country that the Administration, through the International Aviation Safety Assessment program, has classified as Category 2.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall not apply to an application for the renewal of a certificate issued under part 145 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance implementation procedures agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may elect not to enter into a new maintenance implementation procedures agreement with a country classified as Category 2, for as long as the country remains classified as Category 2.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on continued heavy maintenance work","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No part 121 air carrier may enter into a new contract for heavy maintenance work with a person located or headquartered in a country that the Administrator, through the International Aviation Safety Assessment program, has classified as Category 2, for as long as such country remains classified as Category 2.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0779e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum Qualifications for Mechanics and Others Working on U.S. Registered Aircraft.—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0779ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after the date of enactment of this subsection, the Administrator shall require that, at each covered repair station—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0779eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all supervisory personnel of such station are appropriately certificated as a mechanic or repairman under part 65 of title 14, Code of Federal Regulations, or under an equivalent certification or licensing regime, as determined by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0779ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all personnel of such station authorized to approve an article for return to service are appropriately certificated as a mechanic or repairman under part 65 of such title, or under an equivalent certification or licensing regime, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Available for consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of enactment of this subsection, the Administrator shall require any individual who is responsible for approving an article for return to service or who is directly in charge of heavy maintenance work performed on aircraft operated by a part 121 air carrier be available for consultation while work is being performed at a covered repair station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0779ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0779ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered repair station","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered repair station” means a facility that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0779f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0779f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a part 145 repair station; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0779f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/j/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs heavy maintenance work on aircraft operated by a part 121 air carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Heavy maintenance work","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “heavy maintenance work” means a C-check, a D-check, or equivalent maintenance operation with respect to the airframe of a transport-category aircraft (including on-wing aircraft engines).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Part 121 air carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “part 121 air carrier” means an air carrier that holds a certificate issued under part 121 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0779f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44733/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Part 145 repair station","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “part 145 repair station” means a repair station that holds a certificate issued under part 145 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc0779f6-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIII/s308/a"},"text":"Pub. L. 112–95, title III, § 308(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/62"},"text":"126 Stat. 62","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/190/tII/s2112/a"},"text":"Pub. L. 114–190, title II, § 2112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/627"},"text":"130 Stat. 627","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIII/s302/a/1"},"text":"Pub. L. 118–63, title III, § 302(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1067"},"text":"138 Stat. 1067","children":[],"tail":", 1069.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc0779f7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc0779f8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc0779f9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (d)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of the FAA Extension, Safety, and Security Act of 2016, referred to in subsec. (f)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190"},"text":"Pub. L. 114–190","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to in subsec. (i), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc0779fa-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s302/a/1/A"},"text":"Pub. L. 118–63, § 302(a)(1)(A)","children":[],"tail":", substituted “Oversight” for “Inspection” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s302/a/1/B"},"text":"Pub. L. 118–63, § 302(a)(1)(B)","children":[],"tail":", substituted “The Administrator” for “Not later than 1 year after the date of enactment of this section, the Administrator” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s302/a/2/B"},"text":"Pub. L. 118–63, § 302(a)(2)(B)","children":[],"tail":", substituted “part 145 repair stations” for “covered part 145 repair stations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s302/a/1/C"},"text":"Pub. L. 118–63, § 302(a)(1)(C)","children":[],"tail":", inserted “, without prior notice to such repair stations,” after “annually” and “and the applicable laws of the country in which the repair station is located” after “international agreements” and substituted “The Administrator may carry out announced or unannounced inspections in addition to the annual unannounced inspection required under this subsection based on identified risks and in a manner consistent with United States obligations under international agreements and the applicable laws of the country in which the part 145 repair station is located.” for “The Administrator may carry out inspections in addition to the annual inspection required under this subsection based on identified risks.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s302/a/1/E"},"text":"Pub. L. 118–63, § 302(a)(1)(E)","children":[],"tail":", added subsecs. (g) to (i). Former subsec. (g) redesignated (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s302/a/1/D"},"text":"Pub. L. 118–63, § 302(a)(1)(D)","children":[],"tail":", redesignated subsec. (g) as (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s302/a/2/A/iii"},"text":"Pub. L. 118–63, § 302(a)(2)(A)(iii)","children":[],"tail":", added par. (1). Former par. (1) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s302/a/2/A/i"},"text":"Pub. L. 118–63, § 302(a)(2)(A)(i)","children":[],"tail":", substituted “aircraft (including on-wing aircraft engines)” for “aircraft”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s302/a/2/A/ii"},"text":"Pub. L. 118–63, § 302(a)(2)(A)(ii)","children":[],"tail":", redesignated pars. (1) to (3) as (2) to (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/s2112/a/2"},"text":"Pub. L. 114–190, § 2112(a)(2)","children":[],"tail":", added subsec. (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/s2112/a/3"},"text":"Pub. L. 114–190, § 2112(a)(3)","children":[],"tail":", added par. (1) and redesignated former pars. (1) and (2) as (2) and (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/s2112/a/1"},"text":"Pub. L. 114–190, § 2112(a)(1)","children":[],"tail":", redesignated subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc0779fb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc0779fc-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rulemaking on Security Threat Assessment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIII/s302/b/2"},"text":"Pub. L. 118–63, title III, § 302(b)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1069"},"text":"138 Stat. 1069","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tIII/s302/b/2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rulemaking on assessment requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to any employee not covered under the requirements of section 1554.101 of title 49, Code of Federal Regulations, the Administrator [of the Federal Aviation Administration] shall initiate a rulemaking (or request that the head of another Federal agency initiate a rulemaking) that requires a covered repair station to confirm that any such employee has successfully completed an assessment commensurate with a security threat assessment described in subpart C of part 1540 of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of covered repair station","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, the term ‘covered repair station’ means a facility that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located outside the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is certificated under part 145 of title 14, Code of Federal Regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performs heavy maintenance work on aircraft (including on-wing aircraft engines), operated under part 121 of title 14, Code of Federal Regulations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc0779fd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Alcohol and Controlled Substances Testing","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIII/s302/b/1"},"text":"Pub. L. 118–63, title III, § 302(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1069"},"text":"138 Stat. 1069","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tIII/s302/b/1"},"text":"“Not later than 18 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"], the Administrator [of the Federal Aviation Administration] shall issue a final rule carrying out the requirements of section 2112(b) of the FAA Extension, Safety, and Security Act of 2016 ["},{"tag":"ref","attrib":{"href":"/us/pl/114/190"},"text":"Pub. L. 114–190","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44733"},"text":"49 U.S.C. 44733","children":[],"tail":" note).”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/tII/s2112/b"},"text":"Pub. L. 114–190, title II, § 2112(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/628"},"text":"130 Stat. 628","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/190/tII/s2112/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The Administrator of the Federal Aviation Administration shall ensure that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":"], a notice of proposed rulemaking required pursuant to section 44733(d)(2) is published in the Federal Register; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 1 year after the date on which the notice of proposed rulemaking is published in the Federal Register, the rulemaking is finalized.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc0779fe-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Background Investigations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/tII/s2112/c"},"text":"Pub. L. 114–190, title II, § 2112(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/628"},"text":"130 Stat. 628","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/190/tII/s2112/c"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":"], the Administrator shall ensure that each employee of a repair station certificated under part 145 of title 14, Code of Federal Regulations, who performs a safety-sensitive function on an air carrier aircraft has undergone a pre-employment background investigation sufficient to determine whether the individual presents a threat to aviation safety, in a manner that is—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined acceptable by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the applicable laws of the country in which the repair station is located; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consistent with the United States obligations under international agreements.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
