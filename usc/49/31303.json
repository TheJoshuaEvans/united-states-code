{"tag":"section","attrib":{"id":"idcb715498-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31303"},"text":null,"children":[{"tag":"num","attrib":{"value":"31303"},"text":"§ 31303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notification requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb715499-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual operating a commercial motor vehicle, having a driver’s license issued by a State, and violating a State or local law on motor vehicle traffic control (except a parking violation) shall notify the individual’s employer of the violation. If the violation occurred in a State other than the issuing State, the individual also shall notify a State official designated by the issuing State. The notifications required by this subsection shall be made not later than 30 days after the date the individual is found to have committed the violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb71549a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocations, Suspensions, and Cancellations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employee who has a driver’s license revoked, suspended, or canceled by a State, who loses the right to operate a commercial motor vehicle in a State for any period, or who is disqualified from operating a commercial motor vehicle for any period, shall notify the employee’s employer of the action not later than 30 days after the date of the action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb71549b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Previous Employment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb71549c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to paragraph (2) of this subsection, an individual applying for employment as an operator of a commercial motor vehicle shall notify the prospective employer, at the time of the application, of any previous employment as an operator of a commercial motor vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb71549d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall prescribe by regulation the period for which notice of previous employment must be given under paragraph (1) of this subsection. However, the period may not be less than the 10-year period ending on the date of the application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb71549e-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1016"},"text":"108 Stat. 1016","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb71549f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb7154a0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb7154a1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2702.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/570/s12003"},"text":"Pub. L. 99–570, § 12003","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3207-171"},"text":"100 Stat. 3207–171","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “Effective ","children":[{"tag":"date","attrib":{"date":"1987-07-01"},"text":"July 1, 1987","children":[],"tail":"” are omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “operates a commercial motor vehicle and” and “with an employer” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
