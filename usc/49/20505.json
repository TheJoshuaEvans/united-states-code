":"24 Stat. 379","children":[],"tail":", § 25(f) (words before last semicolon); added "},{"tag":"html:a","attrib":{"href":"/us/act/1920-02-28/ch91/s441"},"text":"Feb. 28, 1920, ch. 91, § 441","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/41/498"},"text":"41 Stat. 498","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1937-08-26/ch818"},"text":"Aug. 26, 1937, ch. 818","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/50/836"},"text":"50 Stat. 836","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1940-09-18/ch722/s14/b"},"text":"Sept. 18, 1940, ch. 722, § 14(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/54/919"},"text":"54 Stat. 919","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s17/6"},"text":"Pub. L. 100–342, § 17(6)","children":[],"tail":", (8), "},{"tag":"html:a","attrib":{"href":"/us/stat/102/636"},"text":"102 Stat. 636","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(e)(6)(A).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s6/e/6/A"},"text":"Pub. L. 89–670, § 6(e)(6)(A)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/939"},"text":"80 Stat. 939","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “signal system” are substituted for “such systems, devices, or appliances” because of the definition of “signal system” in section 20501 of the revised title. The word “indicate” is omitted as being included in “function”. The words “or incident” are added for consistency in this part. The word “individual” is substituted for “person”, and the word “immediately” is substituted for “forthwith”, for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
