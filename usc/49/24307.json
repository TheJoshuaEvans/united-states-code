n":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24307(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:565(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/518"},"text":"Pub. L. 91–518","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1327"},"text":"84 Stat. 1327","children":[],"tail":", § 405(f); added "},{"tag":"html:span","attrib":{},"text":"June 22, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/316/s8"},"text":"Pub. L. 92–316, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/230"},"text":"86 Stat. 230","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/73/s120/a"},"text":"Pub. L. 96–73, § 120(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/547"},"text":"93 Stat. 547","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/35/s1184"},"text":"Pub. L. 97–35, § 1184","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/697"},"text":"95 Stat. 697","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the word “maintain” is substituted for “Within 90 days after ","children":[{"tag":"date","attrib":{"date":"1979-09-29"},"text":"September 29, 1979","children":[],"tail":"” and “establish” for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the word “act” is substituted for “take all steps necessary to” to eliminate unnecessary words. The words “access to” are added for clarity. In clause (1), the words “and devices” are omitted as surplus. In clause (4), the words “architectural and other” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1)(A), the words “period of” and “while on” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “take such action as may be necessary to”, “the terms of . . . policy or”, and “to such railroad employee” are omitted as surplus. The words “or group of railroads” are omitted because of 1:1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb30ef7e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb30ef7f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" substituted “Surface Transportation Board” for “Interstate Commerce Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134"},"text":"Pub. L. 105–134","children":[],"tail":" redesignated subsec. (c) as (b) and struck out former subsec. (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Actions To Ensure Access","children":[],"tail":".—Amtrak may act to ensure access to intercity transportation for elderly or handicapped individuals on passenger trains operated by or for Amtrak. That action may include—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) acquiring special equipment;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) conducting special training for employees;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) designing and acquiring new equipment and facilities;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) eliminating barriers in existing equipment and facilities to comply with the highest standards of design, construction, and alteration of property to accommodate elderly and handicapped individuals; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(5) providing special assistance to elderly and handicapped individuals when getting on and off trains and in terminal areas.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb30ef80-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb30ef81-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb30ef82-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Accessibility by Individuals With Disabilities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tII/s219"},"text":"Pub. L. 110–432, div. B, title II, § 219","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4931"},"text":"122 Stat. 4931","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/432/dB/tII/s219"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amtrak, in consultation with station owners and other railroads operating service through the existing stations that it serves, shall evaluate the improvements necessary to make these stations readily accessible to and usable by individuals with disabilities, as required by such section 242(e)(2) of the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12162/e/2"},"text":"42 U.S.C. 12162(e)(2)","children":[],"tail":"). The evaluation shall include, for each applicable station, improvements required to bring it into compliance with the applicable parts of such section 242(e)(2), any potential barriers to achieving compliance, including issues related to passenger rail station platforms, the estimated cost of the improvements necessary, the identification of the responsible person (as defined in section 241(5) of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12161/5"},"text":"42 U.S.C. 12161(5)","children":[],"tail":")), and the earliest practicable date when such improvements can be made. The evaluation shall also include a detailed plan and schedule for bringing all applicable stations into compliance with the applicable parts of section 242(e)(2) by the 2010 statutory deadline for station accessibility. Amtrak shall submit the evaluation to the Committee on Transportation and Infrastructure of the House of Representatives; the Committee on Commerce, Science, and Transportation of the Senate; the Department of Transportation; and the National Council on Disability by "},{"tag":"date","attrib":{"date":"2009-02-01"},"text":"February 1, 2009","children":[],"tail":", along with recommendations for funding the necessary improvements. Should the Department of Transportation issue any rule related to transportation for individuals with disabilities by intercity passenger rail after Amtrak submits its evaluation, Amtrak shall, within 120 days after the date that such rule is published, submit to the above parties a supplemental evaluation on any impact of the rule on its cost and schedule for achieving full compliance."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accessibility Improvements and Barrier Removal for People With Disabilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated to the Secretary [of Transportation] for the use of Amtrak such sums as may be necessary to improve the accessibility of facilities, including rail platforms, and services.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tII/s220"},"text":"Pub. L. 110–432, div. B, title II, § 220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4931"},"text":"122 Stat. 4931","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/432/dB/tII/s220"},"text":"“Using the funds authorized by section 103 of this division [","children":[{"tag":"ref","attrib":{"href":"/us/stat/122/4909"},"text":"122 Stat. 4909","children":[],"tail":"], the Federal Railroad Administration shall monitor and conduct periodic reviews of Amtrak’s compliance with applicable sections of the Americans with Disabilities Act of 1990 ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.] and the Rehabilitation Act of 1974 [probably means Rehabilitation Act of 1973, "},{"tag":"ref","attrib":{"href":"/us/usc/t29/s701"},"text":"29 U.S.C. 701","children":[],"tail":" et seq.] to ensure that Amtrak’s services and facilities are accessible to individuals with disabilities to the extent required by law.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134/tIV/s406/a"},"text":"Pub. L. 105–134, title IV, § 406(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2586"},"text":"111 Stat. 2586","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/134/tIV/s406/a"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access improvements at certain shared stations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amtrak is responsible for its share, if any, of the costs of accessibility improvements required by the Americans With Disabilities Act of 1990 [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.] at any station jointly used by Amtrak and a commuter authority."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain requirements not to apply until 1998","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amtrak shall not be subject to any requirement under subsection (a)(1), (a)(3), or (e)(2) of section 242 of the Americans With Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12162"},"text":"42 U.S.C. 12162","children":[],"tail":") until "},{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
