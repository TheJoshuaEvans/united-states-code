{"tag":"section","attrib":{"id":"idcc053019-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726"},"text":null,"children":[{"tag":"num","attrib":{"value":"44726"},"text":"§ 44726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Denial and revocation of certificate for counterfeit parts violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc05301a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Denial of Certificate.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc05301b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2) of this subsection and subsection (e)(2), the Administrator of the Federal Aviation Administration may not issue a certificate under this chapter to any person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc05301c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convicted in a court of law of a violation of a law of the United States relating to the installation, production, repair, or sale of a counterfeit or fraudulently-represented aviation part or material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc05301d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose certificate is revoked under subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc05301e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to a controlling or ownership interest of an individual described in subparagraph (A) or (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc05301f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (1), the Administrator may issue a certificate under this chapter to a person described in paragraph (1) if issuance of the certificate will facilitate law enforcement efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc053020-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation of Certificate.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc053021-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsections (f) and (g), the Administrator shall issue an order revoking a certificate issued under this chapter if the Administrator finds that the holder of the certificate or an individual who has a controlling or ownership interest in the holder—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc053022-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was convicted in a court of law of a violation of a law of the United States relating to the installation, production, repair, or sale of a counterfeit or fraudulently-represented aviation part or material; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc053023-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly, and with the intent to defraud, carried out or facilitated an activity punishable under a law described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc053024-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No authority to review violation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out paragraph (1), the Administrator may not review whether a person violated a law described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc053025-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the Administrator revokes a certificate under subsection (b), the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc053026-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the holder of the certificate of the reason for the revocation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc053027-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the holder of the certificate an opportunity to be heard on why the certificate should not be revoked.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc053028-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provisions of section 44710(d) apply to the appeal of a revocation order under subsection (b). For the purpose of applying that section to the appeal, “person” shall be substituted for “individual” each place it appears.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc053029-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquittal or Reversal.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc05302a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may not revoke, and the National Transportation Safety Board may not affirm a revocation of, a certificate under subsection (b)(1)(B) if the holder of the certificate or the individual referred to in subsection (b)(1) is acquitted of all charges directly related to the violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc05302b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reissuance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may reissue a certificate revoked under subsection (b) of this section to the former holder if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc05302c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former holder otherwise satisfies the requirements of this chapter for the certificate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc05302d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc05302e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the former holder or the individual referred to in subsection (b)(1), is acquitted of all charges related to the violation on which the revocation was based; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc05302f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conviction of the former holder or such individual of the violation on which the revocation was based is reversed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc053030-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may waive revocation of a certificate under subsection (b) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc053031-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement official of the United States Government requests a waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc053032-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver will facilitate law enforcement efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc053033-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amendment of Certificate","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the holder of a certificate issued under this chapter is other than an individual and the Administrator finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc053034-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who had a controlling or ownership interest in the holder committed a violation of a law for the violation of which a certificate may be revoked under this section or knowingly, and with intent to defraud, carried out or facilitated an activity punishable under such a law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc053035-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44726/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the holder satisfies the requirements for the certificate without regard to that individual,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"then the Administrator may amend the certificate to impose a limitation that the certificate will not be valid if that individual has a controlling or ownership interest in the holder. A decision by the Administrator under this subsection is not reviewable by the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc053036-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tV/s505/a/1"},"text":"Pub. L. 106–181, title V, § 505(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/134"},"text":"114 Stat. 134","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tV/s501"},"text":"Pub. L. 108–176, title V, § 501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2556"},"text":"117 Stat. 2556","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc053037-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc053038-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc053039-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" struck out “or” at end of subpar. (A), added subpar. (B), and redesignated former subpar. (B) as (C) and substituted “described in subparagraph (A) or (B)” for “convicted of such a violation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc05303a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc05303b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc05303c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as an Effective Date of 2000 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
