{"tag":"section","attrib":{"id":"idcad191ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5562"},"text":null,"children":[{"tag":"num","attrib":{"value":"5562"},"text":"§ 5562.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assistance projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad191cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5562/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements To Provide Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall provide financial, technical, and advisory assistance under this chapter to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad191d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5562/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote, on a feasibility demonstration basis, the conversion of at least 3 rail passenger terminals into intermodal transportation terminals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad191d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5562/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserve rail passenger terminals that reasonably are likely to be converted or maintained pending preparation of plans for their reuse;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad191d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5562/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire and use space in suitable buildings of historic or architectural significance but only if use of the space is feasible and prudent when compared to available alternatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad191d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5562/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage State and local governments, local and regional transportation authorities, common carriers, philanthropic organizations, and other responsible persons to develop plans to convert rail passenger terminals into intermodal transportation terminals and civic and cultural activity centers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad191d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5562/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter does not affect the eligibility of any rail passenger terminal for preservation or reuse assistance under another program or law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad191d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5562/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquiring Space","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may acquire space under subsection (a)(3) of this section only after consulting with the Advisory Council on Historic Preservation and the Chairman of the National Endowment for the Arts.","children":[