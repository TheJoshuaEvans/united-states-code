html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:438(c) (1st, 3d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458/s209/c"},"text":"Pub. L. 91–458, § 209(c)","children":[],"tail":" (1st, 3d, 5th–8th sentences), "},{"tag":"html:a","attrib":{"href":"/us/stat/84/975"},"text":"84 Stat. 975","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s3/a/3/A"},"text":"Pub. L. 100–342, § 3(a)(3)(A)","children":[],"tail":", (C), "},{"tag":"html:a","attrib":{"href":"/us/stat/102/624"},"text":"102 Stat. 624","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 3, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/365/s4/c/1"},"text":"Pub. L. 102–365, § 4(c)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/974"},"text":"106 Stat. 974","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21301(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:438(b) (related to rules, regulations, orders, or standards issued under this subchapter).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458/s209/b"},"text":"Pub. L. 91–458, § 209(b)","children":[],"tail":" (related to rules, regulations, orders, or standards issued under this title), "},{"tag":"html:a","attrib":{"href":"/us/stat/84/975"},"text":"84 Stat. 975","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633/s204/a"},"text":"Pub. L. 93–633, § 204(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2165"},"text":"88 Stat. 2165","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s3/a/2"},"text":"Pub. L. 100–342, § 3(a)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/624"},"text":"102 Stat. 624","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 3, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/365/s4/a/1"},"text":"Pub. L. 102–365, § 4(a)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/973"},"text":"106 Stat. 973","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21301(a)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:438(c) (5th, 6th sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21301(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:438(c) (7th sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21301(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:438(c) (8th sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “impose” and “imposed” are substituted for “assessed”, for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the first 2 sentences are substituted for 45:438(a) and (c) (1st sentence) for consistency in the revised title and to eliminate unnecessary words. The words “(including but not limited to a railroad; any manager, supervisor, official, or other employee or agent of a railroad; any owner, manufacturer, lessor, or lessee of railroad equipment, track, or facilities; any independent contractor providing goods or services to a railroad; and any employee of such owner, manufacturer, lessor, lessee, or independent contractor)” are omitted as surplus because of the definition of “person” in 1:1 and because the provision being violated indicates to whom it applies. The word “shall” in 45:438(c) (1st sentence) is retained from the source provisions. For a discussion of whether the authority of the Secretary of Transportation to impose a penalty is mandatory or permissive, see ","children":[{"tag":"i","attrib":{},"text":"Railway Labor Executives’ Ass’n","children":[],"tail":" v. "},{"tag":"i","attrib":{},"text":"Dole","children":[],"tail":", 760 F.2d 1021, 1024, 1025 (9th Cir. 1985); H.R. Conf. Rept. No. 100–637, 100th Cong., 2d Sess., p. 20; 134 Cong. Rec. H3470, "},{"tag":"date","attrib":{"date":"1988-05-23"},"text":"May 23, 1988","children":[],"tail":" (daily ed.); 134 Cong. Rec. S7510, "},{"tag":"date","attrib":{"date":"1988-06-09"},"text":"June 9, 1988","children":[],"tail":" (daily ed.). See also 134 Cong. Rec. E1946, "},{"tag":"date","attrib":{"date":"1988-06-10"},"text":"June 10, 1988","children":[],"tail":" (daily ed.). For an extended discussion of FRA’s prosecutorial discretion, see "},{"tag":"i","attrib":{},"text":"Nationwide Rail Safety: Hearing Before the Subcommittee on Transportation, Tourism, and Hazardous Materials of the House Energy and Commerce Committee","children":[],"tail":", 100th Cong., 1st Sess., pp. 54–65 (1987). See also section 6 of this bill that provides that this bill restates, without substantive change, the provisions of law replaced by this bill, and that this bill may not be construed as making a substantive change in the law restated. Therefore, the word “shall” in this subsection has the same meaning it has under existing law. The words “A separate violation” are substituted for “a separate offense” for consistency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “may compromise the amount . . . to not less than $500” are substituted for “may, however, be compromised . . . for any amount, but in no event for an amount less than the minimum provided in subsection (b) of this section” for clarity and to eliminate unnecessary words. In clause (B), the words “prior or subsequent” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “deposited in” are substituted for “covered into” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb1ddd23-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:21301(a)(1) to clarify the restatement of 45:438(a) by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1994-07-05/s1"},"text":"section 1 of the Act of July 5, 1994","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Public Law 103–272","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/891"},"text":"108 Stat. 891","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb1ddd24-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb1ddd25-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" added pars. (3) and (4) and struck out former par. (3). Prior to amendment, par. (3) read as follows: “The Secretary may compromise the amount of a civil penalty imposed under this subsection to not less than $500 before referring the matter to the Attorney General for collection. In determining the amount of a compromise, the Secretary shall consider—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the nature, circumstances, extent, and gravity of the violation;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) with respect to the violator, the degree of culpability, any history of violations, the ability to pay, and any effect on the ability to continue to do business; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) other matters that justice requires.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s204/d/1"},"text":"Pub. L. 110–432, § 204(d)(1)","children":[],"tail":", inserted “with section 20160 or” after “comply” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t49/s20160"},"text":"section 20160 of this title","children":[],"tail":" or” after “violating”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s302/a"},"text":"Pub. L. 110–432, § 302(a)","children":[],"tail":", substituted “$25,000.” for “$10,000.” and “$100,000.” for “$20,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s204/d/2"},"text":"Pub. L. 110–432, § 204(d)(2)","children":[],"tail":", inserted “The Secretary shall impose a civil penalty for a violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s20160"},"text":"section 20160 of this title","children":[],"tail":".” after first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/53/B"},"text":"Pub. L. 104–287, § 5(53)(B)","children":[],"tail":", substituted “Secretary under chapter 201 is liable” for “Secretary of Transportation under chapter 201 of this title is liable”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/53/A"},"text":"Pub. L. 104–287, § 5(53)(A)","children":[],"tail":", inserted “A person may not fail to comply with a regulation prescribed or order issued by the Secretary of Transportation under chapter 201 of this title.” before “Subject to”."}],"tail":"\n"}],"tail":"\n