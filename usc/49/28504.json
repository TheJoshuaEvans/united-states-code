{"tag":"section","attrib":{"id":"idcb419259-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28504"},"text":null,"children":[{"tag":"num","attrib":{"value":"28504"},"text":"§ 28504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applicability of other laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter shall be construed to limit a rail transportation provider’s right under section 28103(b) to enter into contracts that allocate financial responsibility for claims.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb41925a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tIV/s401/a"},"text":"Pub. L. 110–432, div. B, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4956"},"text":"122 Stat. 4956","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
