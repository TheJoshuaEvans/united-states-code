{"tag":"section","attrib":{"id":"idcba5aad4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105"},"text":null,"children":[{"tag":"num","attrib":{"value":"40105"},"text":"§ 40105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International negotiations, agreements, and obligations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcba5aad5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advice and Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of State shall advise the Administrator of the Federal Aviation Administration and the Secretaries of Transportation and Commerce, and consult with them as appropriate, about negotiations for an agreement with a government of a foreign country to establish or develop air navigation, including air routes and services. The Secretary of Transportation shall consult with the Secretary of State in carrying out this part to the extent this part is related to foreign air transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcba5aad6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions of Secretary and Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcba5aad7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out this part, the Secretary of Transportation and the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcba5aad8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall act consistently with obligations of the United States Government under an international agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcba5aad9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consider applicable laws and requirements of a foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcba5aada-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not limit compliance by an air carrier with obligations or liabilities imposed by the government of a foreign country when the Secretary takes any action related to a certificate of public convenience and necessity issued under chapter 411 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcba5aadb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not apply to an agreement between an air carrier or an officer or representative of an air carrier and the government of a foreign country, if the Secretary of Transportation disapproves the agreement because it is not in the public interest. ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40106/b/2"},"text":"Section 40106(b)(2) of this title","children":[],"tail":" applies to this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcba5aadc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation on International Air Transportation Policy","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40101/e"},"text":"section 40101(e) of this title","children":[],"tail":", the Secretaries of State and Transportation, to the maximum extent practicable, shall consult on broad policy goals and individual negotiations with—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcba5aadd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretaries of Commerce and Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcba5aade-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" airport operators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcba5aadf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scheduled air carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcba5aae0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charter air carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcba5aae1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" airline labor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcba5aae2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consumer interest groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcba5aae3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel agents and tour organizers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcba5aae4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other groups, institutions, and governmental authorities affected by international aviation policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcba5aae5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Observers at International Aviation Negotiations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall grant to at least one representative of each House of Congress the privilege of attending international aviation negotiations as an observer if the privilege is requested in advance in writing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcba5aae6-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1102"},"text":"108 Stat. 1102","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcba5aae7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcba5aae8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcba5aae9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"t