{"tag":"section","attrib":{"id":"idcc0c3507-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745"},"text":null,"children":[{"tag":"num","attrib":{"value":"44745"},"text":"§ 44745.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Don Young Alaska Aviation Safety Initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc0c3508-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Federal Aviation Administration shall redesignate the FAA Alaska Aviation Safety Initiative of the Administration as the Don Young Alaska Aviation Safety Initiative (in this section referred to as the “Initiative”), under which the Administrator shall carry out the provisions of this section and take such other actions as the Administrator determines appropriate to improve aviation safety in Alaska and covered locations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c3509-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objective","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The objective of the Initiative shall be to work cooperatively with aviation stakeholders and other stakeholders towards the goal of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c350a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the rate of fatal aircraft accidents in Alaska and covered locations by 90 percent from 2019 to 2033; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c350b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by ","children":[{"tag":"date","attrib":{"date":"2033-01-01"},"text":"January 1, 2033","children":[],"tail":", eliminating fatal accidents of aircraft operated by an air carrier that operates under part 135 of title 14, Code of Federal Regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c350c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leadership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c350d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall designate the Regional Administrator for the Alaskan Region of the Administration to serve as the Director of the Initiative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c350e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered locations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall select a designee within the Aviation Safety Organization to implement relevant requirements of this section in covered locations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c350f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting chain","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In all matters relating to the Initiative, the Director of the Initiative shall report directly to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3510-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Initiative shall coordinate with the heads of other offices and lines of business of the Administration, including the other regional administrators, to carry out the Initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c3511-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Automated Weather Systems.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c3512-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall ensure, to the greatest extent practicable, that a covered automated weather system is installed and operated at each covered airport not later than ","children":[{"tag":"date","attrib":{"date":"2030-12-31"},"text":"December 31, 2030","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3513-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In complying with the requirement under paragraph (1), the Administrator may waive any positive benefit-cost ratio requirement for the installation and operation of a covered automated weather system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3514-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prioritization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the installation timeline of a covered automated weather system at a covered airport pursuant to this subsection, the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c3515-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate and consult with the governments with jurisdiction over Alaska and covered locations, covered airports, air carriers operating in Alaska or covered locations, private pilots based in Alaska or a covered location, and such other members of the aviation community in Alaska or covered locations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c3516-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prioritize early installation at covered airports that would enable the greatest number of instrument flight rule operations by air carriers operating under part 121 or 135 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3517-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reliability.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c3518-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Pertaining to both Federal and non-Federal systems in Alaska, the Administrator shall be responsible for ensuring—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc0c3519-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reliability of covered automated weather systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc0c351a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of weather information from such systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c351b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall establish data availability and equipment reliability specifications for covered automated weather systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c351c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"System reliability and restoration plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of enactment of this section, the Administrator shall establish an automated weather system reliability and restoration plan for Alaska. Such plan shall document the Administrator’s strategy for ensuring covered automated weather system reliability, including the availability of weather information from such system, and for restoring service in as little time as possible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c351d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Telecommunications or other failures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a covered automated weather system in Alaska is unable to broadly disseminate weather information due to a telecommunications failure or a failure other than an equipment failure, the Administrator shall take such actions as may be necessary to restore the full functionality and connectivity of the covered automated weather system. The Administrator shall take actions under this subparagraph with the same urgency as the Administrator would take an action to repair a covered automated weather system equipment failure or data fidelity issue.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c351e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reliability data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In tabulating data relating to the operational status of covered automated weather systems (including individually or collectively), the Administrator may not consider a covered automated weather system that is functioning nominally but is unable to broadly disseminate weather information telecommunications failure or a failure other than an equipment failure as functioning reliably.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c351f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inventory.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c3520-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance improvements.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idcc0c3521-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of enactment of the FAA Reauthorization Act of 2024, the Administrator shall identify and implement reasonable alternative actions to improve maintenance of FAA-owned weather observing systems that experience frequent service outages, including associated surface communication outages, at covered airports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc0c3522-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Spare parts availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The actions identified by the Administrator in clause (i) shall improve spare parts availability, including consideration of storage of more spare parts in the region in which the systems are located.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c3523-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of outages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of enactment of the FAA Reauthorization Act of 2024, the Administrator shall update FAA Order 7930.2 Notices to Air Missions, or any successive order, to incorporate weather system outages for automated weather observing systems and automated surface observing systems associated with Service A Outages at covered airports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3524-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Visual weather observation system.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c3525-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deployment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after the date of enactment of the FAA Reauthorization Act of 2024, the Administrator shall take such actions as may be necessary to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc0c3526-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deploy visual weather observation systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc0c3527-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that such systems are capable of meeting the definition of a covered automated weather system in Alaska; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc0c3528-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/6/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop standard operation specifications for visual weather operation systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c3529-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/d/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modification of specifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the request of an aircraft operator, the Administrator shall issue or modify the standard operation specifications for visual weather observation systems developed under subparagraph (A) to allow such systems to be used to satisfy the requirements for supplemental noncertified local weather observations under section 322 of the FAA Reauthorization Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Public Law 115–254","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c352a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Weather Cameras.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c352b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall continuously assess the state of the weather camera systems in Alaska and covered locations to ensure the operational sufficiency and reliability of such systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c352c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c352d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept applications from persons to install weather cameras; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c352e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the governments with jurisdiction over Alaska and covered locations, covered airports, air carriers operating in Alaska or covered locations, private pilots based in Alaska or covered locations, and such other members of the aviation community in Alaska and covered locations as the Administrator determines appropriate to solicit additional locations at which to install and operate weather cameras.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c352f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presumption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless the Director has clear and compelling evidence to the contrary, the Director shall presume that the installation of a weather camera at a covered airport in Alaska, or that is recommended by a government with jurisdiction over a covered location, is cost beneficial and will improve aviation safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c3530-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation With Other Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this section, the Administrator shall cooperate with the heads of other Federal or State agencies with responsibilities affecting aviation safety in Alaska and covered locations, including the collection and dissemination of weather data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c3531-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Surveillance and Communication.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c3532-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall take such actions as may be necessary to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c3533-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage and incentivize the equipage of aircraft that operate under part 135 of title 14, Code of Federal Regulations, with automatic dependent surveillance and broadcast out equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c3534-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve aviation surveillance and communications in Alaska and covered locations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3535-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2030-12-31"},"text":"December 31, 2030","children":[],"tail":", the Administrator shall ensure that automatic dependent surveillance and broadcast coverage is available at 5,000 feet above ground level throughout each covered location and Alaska."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3536-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall waive any positive benefit-cost ratio requirement for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c3537-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the installation and operation of equipment and facilities necessary to implement the requirement under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c3538-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of additional ground-based transmitters for automatic dependent surveillance-broadcasts to provide a minimum operational network in Alaska along major flight routes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3539-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service areas","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall continuously identify additional automatic dependent surveillance–broadcast service areas in which the deployment of automatic dependent surveillance–broadcast receivers and equipment would improve aviation safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c353a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall continue to build upon other initiatives recommended in the reports of the FAA Alaska Aviation Safety Initiative of the Administration published before the date of enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c353b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c353c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning on the date that is 1 year after the date of enactment of the FAA Reauthorization Act of 2024, and annually thereafter, the Administrator shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a report on the Initiative, including an itemized description of how the Administration budget meets the goals of the Initiative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c353d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stakeholder comments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall append stakeholder comments, organized by topic, to each report submitted under paragraph (1) in the same manner as appendix 3 of the report titled “FAA Alaska Aviation Safety Initiative FY21 Final Report”, dated ","children":[{"tag":"date","attrib":{"date":"2021-09-30"},"text":"September 30, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c353e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c353f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, for each of fiscal years 2025 through 2028—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c3540-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator may, upon application from the government with jurisdiction over a covered airport and in coordination with the State or territory in which a covered airport is located, use amounts apportioned under subsection (d)(2)(B) or subsection (e) of section 47114 to carry out the Initiative; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c3541-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sponsor of a covered airport that receives an apportionment under subsection (d)(2)(A) or subsection (e) of section 47114 may use such apportionment for any purpose contained in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3542-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplemental funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Out of amounts made available under section 106(k) and section 48101, not more than a total of $25,000,000 for each of fiscal years 2025 through 2028 is authorized to be expended to carry out the Initiative.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c3543-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c3544-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered airport","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered airport” means an airport in Alaska or a covered location that is included in the national plan of integrated airport systems required under section 47103 and that has a status other than unclassified in such plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3545-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered automated weather system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered automated weather system” means an automated or visual weather reporting facility that enables a pilot to begin an instrument procedure approach to an airport under section 91.1039 or 135.225 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3546-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/k/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered location","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered location” means Hawaii, Puerto Rico, American Samoa, Guam, the Northern Mariana Islands, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c3547-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44745/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conformity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall conduct all activities required under this section in conformity with section 44720.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc0c3548-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIII/s342/a"},"text":"Pub. L. 118–63, title III, § 342(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1095"},"text":"138 Stat. 1095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc0c3549-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc0c354a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc0c354b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section and the date of enactment of the FAA Reauthorization Act of 2024, referred to in subsecs. (d)(4)(C), (5)(A)(i), (B), (6)(A), (h), and (i)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 322 of the FAA Reauthorization of 2018, referred to in subsec. (d)(6)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s322"},"text":"section 322 of Pub. L. 115–254","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44720"},"text":"section 44720 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
