{"tag":"section","attrib":{"id":"idcb62fd07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31114"},"text":null,"children":[{"tag":"num","attrib":{"value":"31114"},"text":"§ 31114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Access to the Interstate System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb62fd08-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Denying Access","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may not enact or enforce a law denying to a commercial motor vehicle subject to this subchapter or subchapter I of this chapter reasonable access between—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb62fd09-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Dwight D. Eisenhower System of Interstate and Defense Highways (except a segment exempted under section 31111(f) or 31113(e) of this title) and other qualifying Federal-aid Primary System highways designated by the Secretary of Transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb62fd0a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminals, facilities for food, fuel, repairs, and rest, and points of loading and unloading for household goods carriers, motor carriers of passengers, any towaway trailer transporter combination (as defined in section 31111(a)), or any truck tractor-semitrailer combination in which the semitrailer has a length of not more than 28.5 feet and that generally operates as part of a vehicle combination described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31111/c"},"text":"section 31111(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb62fd0b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not prevent a State or local government from imposing reasonable restrictions, based on safety considerations, on a truck tractor-semitrailer combination in which the semitrailer has a length of not more than 28.5 feet and that generally operates as part of a vehicle combination described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31111/c"},"text":"section 31111(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb62fd0c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/999"},"text":"108 Stat. 999","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV/s5523/c/2"},"text":"Pub. L. 114–94, div. A, title V, § 5523(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1560"},"text":"129 Stat. 1560","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb62fd0d-47c4-11f1