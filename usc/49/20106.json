{"tag":"section","attrib":{"id":"idcb0d145a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106"},"text":null,"children":[{"tag":"num","attrib":{"value":"20106"},"text":"§ 20106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb0d145b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Uniformity of Regulation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0d145c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Laws, regulations, and orders related to railroad safety and laws, regulations, and orders related to railroad security shall be nationally uniform to the extent practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0d145d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A State may adopt or continue in force a law, regulation, or order related to railroad safety or security until the Secretary of Transportation (with respect to railroad safety matters), or the Secretary of Homeland Security (with respect to railroad security matters), prescribes a regulation or issues an order covering the subject matter of the State requirement. A State may adopt or continue in force an additional or more stringent law, regulation, or order related to railroad safety or security when the law, regulation, or order—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0d145e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to eliminate or reduce an essentially local safety or security hazard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0d145f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not incompatible with a law, regulation, or order of the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0d1460-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not unreasonably burden interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0d1461-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clarification Regarding State Law Causes of Action","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0d1462-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Nothing in this section shall be construed to preempt an action under State law seeking damages for personal injury, death, or property damage alleging that a party—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0d1463-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has failed to comply with the Federal standard of care established by a regulation or order issued by the Secretary of Transportation (with respect to railroad safety matters), or the Secretary of Homeland Security (with respect to railroad security matters), covering the subject matter as provided in subsection (a) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0d1464-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has failed to comply with its own plan, rule, or standard that it created pursuant to a regulation or order issued by either of the Secretaries; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0d1465-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has failed to comply with a State law, regulation, or order that is not incompatible with subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0d1466-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection shall apply to all pending State law causes of action arising from events or activities occurring on or after ","children":[{"tag":"date","attrib":{"date":"2002-01-18"},"text":"January 18, 2002","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0d1467-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section creates a Federal cause of action on behalf of an injured party or confers Federal question jurisdiction for such State law causes of action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0d1468-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/866"},"text":"108 Stat. 866","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1710/c"},"text":"Pub. L. 107–296, title XVII, § 1710(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2319"},"text":"116 Stat. 2319","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXV/s1528"},"text":"Pub. L. 110–53, title XV, § 1528","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/453"},"text":"121 Stat. 453","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb0d1469-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb0d146a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb0d146b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20106","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:434.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458/s205"},"text":"Pub. L. 91–458, § 205","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/972"},"text":"84 Stat. 972","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, before clause (1), the words “The Congress declares that” are omitted as unnecessary. In clause (3), the word “unreasonably” is substituted for “undue” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb0d146c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb0d146d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2007—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53"},"text":"Pub. L. 110–53","children":[],"tail":" amended section generally. Prior to amendment, text of section read as follows: “Laws, regulations, and orders related to railroad safety and laws, regulations, and orders related to railroad security shall be nationally uniform to the extent practicable. A State may adopt or continue in force a law, regulation, or order related to railroad safety or security until the Secretary of Transportation (with respect to railroad safety matters), or the Secretary of Homeland Security (with respect to railroad security matters), prescribes a regulation or issues an order covering the subject matter of the State requirement. A State may adopt or continue in force an additional or more stringent law, regulation, or order related to railroad safety or security when the law, regulation, or order—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) is necessary to eliminate or reduce an essentially local safety or security hazard;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) is not incompatible with a law, regulation, or order of the United States Government; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) does not unreasonably burden interstate commerce.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1710/c"},"text":"Pub. L. 107–296, § 1710(c)","children":[],"tail":", in introductory provisions, in first sentence inserted “and laws, regulations, and orders related to railroad security” after “safety”, in second sentence substituted “Transportation (with respect to railroad safety matters), or the Secretary of Homeland Security (with respect to railroad security matters),” for “Transportation”, and in second and third sentences inserted “or security” after “order related to railroad safety”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1710/c/2"},"text":"Pub. L. 107–296, § 1710(c)(2)","children":[],"tail":", inserted “or security” after “safety”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb0d146e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb0d146f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
