{"tag":"section","attrib":{"id":"idcb4b2f3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30122"},"text":null,"children":[{"tag":"num","attrib":{"value":"30122"},"text":"§ 30122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Making safety devices and elements inoperative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb4b2f3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, “motor vehicle repair business” means a person holding itself out to the public to repair for compensation a motor vehicle or motor vehicle equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4b2f3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A manufacturer, distributor, dealer, rental company, or motor vehicle repair business may not knowingly make inoperative any part of a device or element of design installed on or in a motor vehicle or motor vehicle equipment in compliance with an applicable motor vehicle safety standard prescribed under this chapter unless the manufacturer, distributor, dealer, rental company, or repair business reasonably believes the vehicle or equipment will not be used (except for testing or a similar purpose during maintenance or repair) when the device or element is inoperative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4b2f40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may prescribe regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4b2f41-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30122/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exempt a person from this section if the Secretary decides the exemption is consistent with motor vehicle safety and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30101"},"text":"section 30101 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4b2f42-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30122/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to define “make inoperative”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb4b2f43-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/956"},"text":"108 Stat. 956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tI/s31202/a/1"},"text":"Pub. L. 112–141, div. C, title I, § 31202(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/757"},"text":"