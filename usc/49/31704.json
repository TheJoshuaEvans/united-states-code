{"tag":"section","attrib":{"id":"idcb7aca98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31704"},"text":null,"children":[{"tag":"num","attrib":{"value":"31704"},"text":"§ 31704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Vehicle registration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", a State that is not participating in the International Registration Plan may not establish, maintain, or enforce a commercial motor vehicle registration law, regulation, or agreement that limits the operation in that State of a commercial motor vehicle that is not registered under the laws of the State, if the vehicle is registered under the laws of a State participating in the Plan."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb7aca99-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1032"},"text":"108 Stat. 1032","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb7aca9a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb7aca9b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb7aca9c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead