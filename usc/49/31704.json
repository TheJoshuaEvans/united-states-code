attrib":{"href":"/us/stat/105/2154"},"text":"105 Stat. 2154","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “a State that is not participating in the International Registration Plan may not” are substituted for “no State (other than a State which is participating in the International Registration Plan) shall” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
