{"tag":"section","attrib":{"id":"idcbb8bd96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41103"},"text":null,"children":[{"tag":"num","attrib":{"value":"41103"},"text":"§ 41103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" All-cargo air transportation certificates of air carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbb8bd97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A citizen of the United States may apply to the Secretary of Transportation for a certificate authorizing the citizen to provide all-cargo air transportation. The application must contain information and be in the form the Secretary by regulation requires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb8bd98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after an application for a certificate is filed under this section, the Secretary shall issue the certificate to a citizen of the United States authorizing the citizen, as an air carrier, to provide any part of the all-cargo air transportation applied for unless the Secretary finds that the citizen is not fit, willing, and able to provide the all-cargo air transportation to be authorized by the certificate and to comply with regulations of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb8bd99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may impose terms the Secretary considers necessary when issuing a certificate under this section. However, the Secretary may not impose terms that restrict the places served or prices charged by the holder of the certificate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb8bd9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemptions and Status","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A citizen issued a certificate under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbb8bd9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41103/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is exempt in providing the transportation under the certificate from the requirements of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbb8bd9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41103/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41101/a/1"},"text":"section 41101(a)(1) of this title","children":[],"tail":" and regulations or procedures prescribed under section 41101(a)(1); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbb8bd9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41103/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other provisions of this part and regulations or procedures prescribed under those provisions when the Secretary finds under regulations of the Secretary that the exemption is appropriate; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8bd9e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41103/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an air carrier under this part except to the extent the carrier is exempt under this section from a requirement of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbb8bd9f-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1119"},"text":"108 Stat. 1119","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/49"},"text":"Pub. L. 103–429, § 6(49)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4384"},"text":"108 Stat. 4384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbb8bda0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbb8bda1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbb8bda2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"ta