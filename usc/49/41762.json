{"tag":"section","attrib":{"id":"idcbd0b294-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762"},"text":null,"children":[{"tag":"num","attrib":{"value":"41762"},"text":"§ 41762.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd0b295-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “air carrier” means any air carrier holding a certificate of public convenience and necessity issued by the Secretary of Transportation under section 41102.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b296-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aircraft purchase","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “aircraft purchase” means the purchase of commercial transport aircraft, including spare parts normally associated with the aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b297-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital reserve subsidy amount","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “capital reserve subsidy amount” means the amount of budget authority sufficient to cover estimated long-term cost to the United States Government of a Federal credit instrument, calculated on a net present value basis, excluding administrative costs and any incidental effects on Government receipts or outlays in accordance with provisions of the Federal Credit Reform Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s661"},"text":"2 U.S.C. 661","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b298-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commuter air carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “commuter air carrier” means an air carrier that primarily operates aircraft designed to have a maximum passenger seating capacity of 75 or less in accordance with published flight schedules.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b299-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal credit instrument","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal credit instrument” means a secured loan, loan guarantee, or line of credit authorized to be made under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b29a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial obligation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “financial obligation” means any note, bond, debenture, or other debt obligation issued by an obligor in connection with the financing of an aircraft purchase, other than a Federal credit instrument.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b29b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lender","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “lender” means any non-Federal qualified institutional buyer (as defined by section 230.144A(a) of title 17, Code of Federal Regulations (or any successor regulation) known as Rule 144A(a) of the Security and Exchange Commission and issued under the Security Act of 1933 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"15 U.S.C. 77a","children":[],"tail":" et seq.)), including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd0b29c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a qualified retirement plan (as defined in section 4974(c) of the Internal Revenue Code of 1986) that is a qualified institutional buyer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd0b29d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a governmental plan (as defined in section 414(d) of the Internal Revenue Code of 1986) that is a qualified institutional buyer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b29e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Line of credit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “line of credit” means an agreement entered into by the Secretary with an obligor under section 41763(d) to provide a direct loan at a future date upon the occurrence of certain events.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b29f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Loan guarantee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “loan guarantee” means any guarantee or other pledge by the Secretary under section 41763(c) to pay all or part of any of the principal of and interest on a loan or other debt obligation issued by an obligor and funded by a lender.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b2a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New entrant air carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “new entrant air carrier” means an air carrier that has been providing air transportation according to a published schedule for less than 5 years, including any person that has received authority from the Secretary to provide air transportation but is not providing air transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b2a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “obligor” means a party primarily liable for payment of the principal of or interest on a Federal credit instrument, which party may be a corporation, partnership, joint venture, trust, or governmental entity, agency, or instrumentality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b2a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regional jet aircraft","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “regional jet aircraft” means a civil aircraft—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd0b2a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" powered by jet propulsion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd0b2a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed to have a maximum passenger seating capacity of not less than 30 nor more than 75.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b2a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secured loan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “secured loan” means a direct loan funded by the Secretary in connection with the financing of an aircraft purchase under section 41763(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b2a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Underserved market","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “underserved market” means a passenger air transportation market (as defined by the Secretary) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd0b2a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/14/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is served (as determined by the Secretary) by a nonhub airport or a small hub airport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd0b2a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/14/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not within a 40-mile radius of an airport that each year has at least .25 percent of the total annual boardings in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd0b2a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41762/14/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines does not have sufficient air service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd0b2aa-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tII/s210/a"},"text":"Pub. L. 106–181, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/96"},"text":"114 Stat. 96","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tII/s225/b/5"},"text":"Pub. L. 108–176, title II, § 225(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2529"},"text":"117 Stat. 2529","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd0b2ab-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbd0b2ac-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbd0b2ad-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Federal Credit Reform Act of 1990, referred to in par. (3), is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/344"},"text":"Pub. L. 93–344","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/101/508/tXIII/s13201/a"},"text":"Pub. L. 101–508, title XIII, § 13201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-609"},"text":"104 Stat. 1388–609","children":[],"tail":", which is classified generally to subchapter III (§ 661 et seq.) of chapter 17A of Title 2, The Congress. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s621"},"text":"section 621 of Title 2","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Security Act of 1933, referred to in par. (7), probably means the Securities Act of 1933, title I of ","children":[{"tag":"ref","attrib":{"href":"/us/act/1933-05-27/ch38"},"text":"act May 27, 1933, ch. 38","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/74"},"text":"48 Stat. 74","children":[],"tail":", which is classified generally to subchapter I (§ 77a et seq.) of chapter 2A of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s77a"},"text":"section 77a of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 414(d) and 4974(c) of the Internal Revenue Code of 1986, referred to in par. (7), are classified to sections 414(d) and 4974(c), respectively, of Title 26, Internal Revenue Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbd0b2ae-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Pars. (11) to (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" redesignated pars. (12), (13), (14), and (16) as (11), (12), (13), and (14), respectively, and struck out former pars. (11) and (15), which defined “nonhub airport” and “small hub airport”, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbd0b2af-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbd0b2b0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcbd0b2b1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as an Effective Date of 2000 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
