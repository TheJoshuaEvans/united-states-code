{"tag":"section","attrib":{"id":"idcbd2fc48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41905"},"text":null,"children":[{"tag":"num","attrib":{"value":"41905"},"text":"§ 41905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency mail transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd2fc49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In an emergency caused by a flood, fire, or other disaster, the United States Postal Service may make a contract without advertising to transport mail by aircraft to or from a locality affected by the emergency when the available facilities of persons authorized to transport mail to or from the locality are inadequate to meet the requirements of the Postal Service during the emergency. The contract may be only for periods necessary to maintain mail service because of the inadequacy of the facilities. Payment for transportation provided under the contract shall be made at prices provided in the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd2fc4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation Not Air Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Transportation provided under a contract made under subsection (a) of this section is not air transportation within the meaning of this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd2fc4b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1155"},"text":"108 Stat. 1155","children":[],"tail":", § 41906; renumbered § 41905, "},{"tag":"ref","attrib":{"href":"/us/pl/110/405/s2/b/7/B"},"text":"Pub. L. 110–405, § 2(b)(7)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4289"},"text":"122 Stat. 4289","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd2fc4c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbd2fc4d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbd2fc4e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41906(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1375(h) (1st, 2d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s405/h"},"text":"Pub. L. 85–726, § 405(h)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/762"},"text":"72 Stat. 762","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41906(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1375(h) (3d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “disaster” is substituted for “calamitous visitation” for consistency in the revised title and with other titles of the United States Code. The words “any or all classes of” and “of compensation” are omitted as surplus. The words “from appropriations for the transportation of mail by the means normally used for transporting the mail transported under such contracts” are omitted as superseded by 39:chs. 20 and 24. The authority of the Postal Service under this section is in addition to the authority of the Postal Service under 39:5001.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Transportation provided” are substituted for “operation” for consistency in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbd2fc4f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcbd2fc50-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 41905, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1155"},"text":"108 Stat. 1155","children":[],"tail":", related to regulating air carrier transportation of foreign mail, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/110/405/s2/b/7/A"},"text":"Pub. L. 110–405, § 2(b)(7)(A)","children":[],"tail":", (c), "},{"tag":"da