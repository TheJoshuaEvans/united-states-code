{"tag":"section","attrib":{"id":"idcb7acaa8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31706"},"text":null,"children":[{"tag":"num","attrib":{"value":"31706"},"text":"§ 31706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb7acaa9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On request of the Secretary of Transportation, the Attorney General may bring a civil action in a court of competent jurisdiction to enforce compliance with sections 31704 and 31705 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7acaaa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An action under this section may be brought only in the State in which an order is required to enforce compliance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7acaab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relief","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1341"},"text":"section 1341 of title 28","children":[],"tail":", the court, on a proper showing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7acaac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall issue a temporary restraining order or a preliminary or permanent injunction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7acaad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may require by the injunction that the State or any person comply with sections 31704 and 31705 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb7acaae-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1033"},"text":"108 Stat. 1033","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb7acaaf-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb7acab0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb7acab1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31706","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:11506 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/240/s4008/h"},"text":"Pub. L. 102–240, § 4008(h)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/2155"},"text":"105 Stat. 2155","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “bring a civil action . . . to enforce compliance” are substituted for “commence . . . a civil action for such injunctive relief as may be appropriate to ensure compliance” for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “an order is required to enforce compliance” are substituted for “relief is required to ensure such compliance” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
