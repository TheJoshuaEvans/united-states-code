{"tag":"section","attrib":{"id":"idcaf2d5f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13504"},"text":null,"children":[{"tag":"num","attrib":{"value":"13504"},"text":"§ 13504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt motor carrier transportation entirely in one State","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Neither the Secretary nor the Board has jurisdiction under this subchapter over transportation, except transportation of household goods, by a motor carrier operating solely within the State of Hawaii. The State of Hawaii may regulate transportation exempt from jurisdiction under this section and, to the extent provided by a motor carrier operating solely within the State of Hawaii, transportation exempt under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s13503"},"text":"section 13503 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcaf2d5f3-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/860"},"text":"109 Stat. 860","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf2d5f4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf2d5f5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf2d5f6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"tex