ttrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:304(a)(3a) (last sentence) (related to “Sec. 322(g)”).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1887-02-04/ch104"},"text":"Feb. 4, 1887, ch. 104","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/24/379"},"text":"24 Stat. 379","children":[],"tail":", § 204(a)(3a) (last sentence) (related to “Sec. 222(g)”); added "},{"tag":"html:a","attrib":{"href":"/us/act/1956-08-03/ch905/s2"},"text":"Aug. 3, 1956, ch. 905, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/958"},"text":"70 Stat. 958","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The section is included because 49:1655(f)(2) gave the same administrative powers exercised by the Interstate Commerce Commission under certain sections of title 49 to the Secretary of Transportation to carry out duties transferred to the Secretary by 49:1655(e). See the revision notes for section 501 of the revised title for an explanation of the transfer under 49:1655(f)(2). The powers of the Commission have been codified in subtitle IV of the revised title. The comparable provisions of title 49 that are represented by the section may be found as follows:","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"dispositionOfSections","id":"idca793874-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca793875-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section 522","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"49 U.S. Code","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised Section","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"20(7)(b) (less proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"11909","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"322(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"11909","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"See the revision notes for the revised section for an explanation of changes made in the text. Changes not accounted for in those revision notes are as follows:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of 49:304(a)(3) (last sentence 1st–7th words) and (3a) (last sentence 1st–5th words) is omitted as executed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca793876-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca793877-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" struck out “(a)” before “A person required to make a report to the Secretary of Transportation” and struck out subsec. (b) which read as follows: “A person required to make a report to the Secretary, answer a question, or make, prepare, or preserve a record under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s504"},"text":"section 504 of this title","children":[],"tail":" about transportation by motor carrier, motor carrier of migrant workers, or motor private carrier, or an officer, agent, or employee of that person, that (1) willfully does not make that report, (2) willfully does not specifically, completely, and truthfully answer that question in 30 days from the date the Secretary requires the question to be answered, (3) willfully does not make, prepare, or preserve that record in the form and manner prescribed by the Secretary, (4) knowingly and willfully falsifies, destroys, mutilates, or changes that report or record, (5) knowingly and willfully files a false report or record with the Secretary, (6) knowingly and willfully makes a false or incomplete entry in that record about a business related fact or transaction, or (7) knowingly and willfully makes, prepares, or preserves a record in violation of a regulation or order of the Secretary, shall be fined not more than $5,000.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
