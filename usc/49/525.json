{"tag":"section","attrib":{"id":"idca793890-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s525"},"text":null,"children":[{"tag":"num","attrib":{"value":"525"},"text":"§ 525.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disobedience to subpoenas","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A motor carrier, motor carrier of migrant workers, or motor private carrier not obeying a subpoena or requirement of the Secretary of Transportation under this chapter to appear and testify or produce records shall be fined at least $1,000 but not more than $10,000, imprisoned for not more than one year, or both. The Secretary may withhold, suspend, amend, or revoke any part of the registration of a person required to register under chapter 139 for failing to obey a subpoena or requirement of the Secretary under this chapter to appear and testify or produce records.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca793891-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449/s1/b"},"text":"Pub. L. 97–449, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2437"},"text":"96 Stat. 2437","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32110"},"text":"Pub. L. 112–141, div. C, title II, § 32110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/782"},"text":"126 Stat. 782","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca793892-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca793893-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{