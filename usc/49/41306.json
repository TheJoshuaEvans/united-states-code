{"tag":"section","attrib":{"id":"idcbbb2eb9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41306"},"text":null,"children":[{"tag":"num","attrib":{"value":"41306"},"text":"§ 41306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplified procedure to apply for, amend, modify, and suspend permits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbbb2eba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall prescribe regulations that simplify the procedure for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbb2ebb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting on an application for a permit to provide foreign air transportation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41302"},"text":"section 41302 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbb2ebc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amending, modifying, or suspending any part of that permit under section 41304(a) or (b) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbb2ebd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice and Opportunity To Respond","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations under this section shall provide for notice and an opportunity for each interested person to file appropriate written evidence and argument. An oral evidentiary hearing is not required to be provided under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbbb2ebe-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1128"},"text":"108 Stat. 1128","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbbb2ebf-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbbb2ec0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbbb2ec1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":