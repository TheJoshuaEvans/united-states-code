{"tag":"section","attrib":{"id":"idcbe88014-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44517"},"text":null,"children":[{"tag":"num","attrib":{"value":"44517"},"text":"§ 44517.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Program to permit cost sharing of air traffic modernization projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbe88015-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44517/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the requirements of this section, the Secretary may carry out a program under which the Secretary may make grants to project sponsors for not more than 10 eligible projects per fiscal year for the purpose of improving aviation safety and enhancing mobility of the Nation’s air transportation system by encouraging non-Federal investment in critical air traffic control equipment and software.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe88016-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44517/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of an eligible project carried out under the program shall not exceed 33 percent. The non-Federal share of the cost of an eligible project shall be provided from non-Federal sources, including revenues collected pursuant to section 40117.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe88017-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44517/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Grant Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No eligible project may receive more than $5,000,000 in Federal funds under the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe88018-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44517/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall use amounts appropriated under section 48101(a) to carry out the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe88019-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44517/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbe8801a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44517/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible project","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible project” means a project to purchase equipment or software relating to the Nation’s air traffic control system that is certified or approved by the Administrator of the Federal Aviation Administration and that promotes safety, efficiency, or mobility. Such projects may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbe8801b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44517/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" airport-specific air traffic facilities and equipment, including local area augmentation systems, instrument landing systems, weather and wind shear detection equipment, and lighting improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe8801c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44517/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automation tools to effect improvements in airport capacity, including passive final approach spacing tools and traffic management advisory equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe8801d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44517/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment and software that enhance airspace control procedures or assist in en route surveillance, including oceanic and offshore flight tracking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe8801e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44517/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project sponsor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “project sponsor” means any major user of the national airspace system, as determined by the Secretary, including a public-use airport or a joint venture between a public-use airport and one or more air carriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe8801f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44517/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers of Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, and upon agreement by the Administrator, a project sponsor may transfer, without consideration, to the Federal Aviation Administration, facilities, equipment, or automation tools, the purchase of which was assisted by a grant made under this section, if such facilities, equipment or tools meet Federal Aviation Administration operation and maintenance criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe88020-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44517/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall issue advisory guidelines on the implementation of the program. The guidelines shall not be subject to administrative rulemaking requirements under subchapter II of chapter 5 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbe88021-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/tI/s183/a"},"text":"Pub. L. 108–176, title I, § 183(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2516"},"text":"117 Stat. 2516","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbe88022-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbe88023-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcbe88024-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
