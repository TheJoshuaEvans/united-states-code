{"tag":"section","attrib":{"id":"idcc70759a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50105"},"text":null,"children":[{"tag":"num","attrib":{"value":"50105"},"text":"§ 50105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fraudulent use of “Made in America” label","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If the Secretary of Transportation decides that a person intentionally affixed a “Made in America” label to goods sold in or shipped to the United States that are not made in the United States, the Secretary shall declare the person ineligible, for not less than 3 nor more than 5 years, to receive a contract or grant from the United States Government related to a contract made under section 106(k), 44502(a)(2), or 44509, subchapter I of chapter 471, or chapter 481 (except sections 48102(e), 48106, 48107, and 48110) of this title or subtitle B of title IX of the Omnibus Budget Reconciliation Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/508"},"text":"Public Law 101–508","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1388-353"},"text":"104 Stat. 1388–353","children":[],"tail":"). The Secretary may bring a civil action to enforce this section in any district court of the United States."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcc70759b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1300"},"text":"108 Stat. 1300","children":[],"tail":", § 49105; renumbered § 50105 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/88/D"},"text":"Pub. L. 104–287, § 5(88)(D)","children":[],"tail":", (89), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3398"},"text":"110 Stat. 3398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s768/b/3"},"text":"Pub. L. 118–63, title VII, § 768(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1295"},"text":"138 Stat. 1295","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc70759c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc70759d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc70759e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised",