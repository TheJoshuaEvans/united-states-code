{"tag":"section","attrib":{"id":"idcb7d3bad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304B"},"text":null,"children":[{"tag":"num","attrib":{"value":"32304B"},"text":"§ 32304B.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Child safety","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb7d3bae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304B/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3baf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304B/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Passenger motor vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “passenger motor vehicle” has the meaning given that term in section 32101.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3bb0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304B/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rear-designated seating position","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “rear-designated seating position” means designated seating positions that are rearward of the front seat.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3bb1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304B/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3bb2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304B/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rulemaking","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of enactment of this section, the Secretary shall issue a final rule requiring all new passenger motor vehicles weighing less than 10,000 pounds gross vehicle weight to be equipped with a system to alert the operator to check rear-designated seating positions after the vehicle engine or motor is deactivated by the operator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3bb3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304B/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Means","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The alert required under subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3bb4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304B/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include a distinct auditory and visual alert, which may be combined with a haptic alert; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3bb5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304B/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be activated when the vehicle motor is deactivated by the operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3bb6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304B/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Phase-in","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The rule issued pursuant to subsection (b) shall require full compliance with the rule beginning on September 1st of the first calendar year that begins 2 years after the date on which the final rule is issued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb7d3bb7-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tIV/s24222/a/1"},"text":"Pub. L. 117–58, div. B, title IV, § 24222(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/835"},"text":"135 Stat. 835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb7d3bb8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb7d3bb9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb7d3bba-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
