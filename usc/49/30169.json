{"tag":"section","attrib":{"id":"idcb525b20-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30169"},"text":null,"children":[{"tag":"num","attrib":{"value":"30169"},"text":"§ 30169.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb525b21-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30169/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall submit to the President to submit to Congress on July 1 of each year a report on the administration of this chapter for the prior calendar year. The report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb525b22-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30169/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a thorough statistical compilation of accidents and injuries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb525b23-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30169/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motor vehicle safety standards in effect or prescribed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb525b24-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30169/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree of observance of the standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb525b25-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30169/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of current research grants and contracts and a description of the problems to be considered under those grants and contracts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb525b26-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30169/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis and evaluation of research activities completed and technological progress achieved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb525b27-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30169/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enforcement actions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb525b28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30169/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which technical information was given the scientific community and consumer-oriented information was made available to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb525b29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30169/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations for legislation needed to promote cooperation among the States in improving traffic safety and strengthening the national traffic safety program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb525b2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30169/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report on Importing Motor Vehicles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after regulations are first prescribed under section 2(e)(1)(B) of the Imported Vehicle Safety Compliance Act of 1988, the Secretary shall submit to Congress a report of the actions taken to carry out subchapter III of this chapter and the effectiveness of those actions, including any testing by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30146/c/2"},"text":"section 30146(c)(2) of this title","children":[],"tail":". After the first report, the Secretary shall submit a report to Congress under this subsection not later than July 31 of each year."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb525b2b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/972"},"text":"108 Stat. 972","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb525b2c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb525b2d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb525b2e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"