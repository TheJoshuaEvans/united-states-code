ll}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32912(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2008(b)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 20, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/513"},"text":"Pub. L. 92–513","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/947"},"text":"86 Stat. 947","children":[],"tail":", § 508(b)(1)–(3) (1st sentence); added "},{"tag":"html:span","attrib":{},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/163/s301"},"text":"Pub. L. 94–163, § 301","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/89/913"},"text":"89 Stat. 913","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/425"},"text":"Pub. L. 96–425","children":[],"tail":", §§ 6(c)(1), (3), 8(f), "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1827"},"text":"94 Stat. 1827","children":[],"tail":", 1828, 1829."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32912(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2008(b)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32912(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2008(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 20, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/513"},"text":"Pub. L. 92–513","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/947"},"text":"86 Stat. 947","children":[],"tail":", § 508(d), (e)(1), (2), (4); added "},{"tag":"html:span","attrib":{},"text":"Nov. 9, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/619/s402"},"text":"Pub. L. 95–619, § 402","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/3255"},"text":"92 Stat. 3255","children":[],"tail":", 3256."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32912(c)(2), (3)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2008(e)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32912(c)(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2008(e)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32912(c)(5)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2008(e)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32912(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2008(b)(3) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “whom the Secretary determines under subsection (a) of this section” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1)(A), the words “Except as provided in subsection (c) of this section” are added for clarity. The words “that violates a standard prescribed for a model year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32902"},"text":"section 32902 of this title","children":[],"tail":"” are substituted for “to have violated a provision of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s2007/a/1"},"text":"section 2007(a)(1) of this title","children":[],"tail":" with respect to any model year” and “to have violated "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s2007/a/2"},"text":"section 2007(a)(2) of this title","children":[],"tail":"” to avoid referring, as in the source, to one provision that in turn refers to another provision. In clause (1), the words “calculated under” are substituted for “established under” for clarity. The reference to section 32904(a)(1)(A), which is a reference to the provision under which average fuel economy for nonpassenger automobiles is calculated, is added for clarity. The reference to section 32904(a)(1)(B), which is a reference to the provision under which average fuel economy for passenger automobiles is calculated, is substituted for the reference in the source to 15:2002(a) and (c), which is a reference to the provision under which the average fuel economy standard for those automobiles is established, for clarity. The words “in which the violation occurs” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1)(A), before clause (i), the words “shall prescribe by regulation” are substituted for “shall, by rule . . . substitute” for consistency in the revised title and because “rule” and “regulation” are synonymous. The words “in accordance with the provisions of this subsection and subsection (e)” are omitted as surplus. The words “be less than $5.00” are omitted as surplus because under the subsection the Secretary may only raise the amount imposed to $10, or a $5 increase. The words “in the absence of such rule” are omitted as surplus. The words “increase in the penalty” are substituted for “additional amount of the civil penalty” for clarity. In clause (ii), the words “subject to subparagraph (B)” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1)(C), the words “the later of” and the text of 15:2008(d)(3)(A) are omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), before clause (A), the words “After the Secretary of Transportation develops a proposed rule pursuant to subsection (d) of this section” are omitted as surplus. In clause (B), the words “written comments or an oral presentation” are substituted for “written or oral presentations” for consistency in the section. The text of 15:2008(e)(1)(B) (last sentence) and (C) is omitted as surplus because of 5:556(d).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(5), before clause (A), the words “department, agency, or instrumentality” are substituted for “department or agency” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb89225d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb89225e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s40006/a/1"},"text":"Pub. L. 119–21, § 40006(a)(1)","children":[],"tail":", substituted “$0.00” for “$5” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/s40006/a/2"},"text":"Pub. L. 119–21, § 40006(a)(2)","children":[],"tail":", substituted “$0.00” for “$10”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb89225f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb892260-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2025 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/119/21/tIV/s40006/b"},"text":"Pub. L. 119–21, title IV, § 40006(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/136"},"text":"139 Stat. 136","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/21/tIV/s40006/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendments made by subsection (a) [amending this section] shall—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take effect on the date of enactment of this section [","children":[{"tag":"date","attrib":{"date":"2025-07-04"},"text":"July 4, 2025","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" apply to all model years of a manufacturer for which the Secretary of Transportation has not provided a notification pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32903/b/2/B"},"text":"section 32903(b)(2)(B) of title 49","children":[],"tail":", United States Code, specifying the penalty due for the average fuel economy of that manufacturer being less than the applicable standard prescribed under section 32902 of that title.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb892261-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2007 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":" effective on the date that is 1 day after "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
