{"tag":"section","attrib":{"id":"idcb89223b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912"},"text":null,"children":[{"tag":"num","attrib":{"value":"32912"},"text":"§ 32912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb89223c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person that violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32911/a"},"text":"section 32911(a) of this title","children":[],"tail":" is liable to the United States Government for a civil penalty of not more than $10,000 for each violation. A separate violation occurs for each day the violation continues."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb89223d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty for Manufacturer Violations of Fuel Economy Standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c) of this section, a manufacturer that violates a standard prescribed for a model year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32902"},"text":"section 32902 of this title","children":[],"tail":" is liable to the Government for a civil penalty of $0.00 multiplied by each .1 of a mile a gallon by which the applicable average fuel economy standard under that section exceeds the average fuel economy—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb89223e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" calculated under section 32904(a)(1)(A) or (B) of this title for automobiles to which the standard applies manufactured by the manufacturer during the model year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb89223f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiplied by the number of those automobiles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb892240-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduced by the credits available to the manufacturer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32903"},"text":"section 32903 of this title","children":[],"tail":" for the model year."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb892241-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Higher Penalty Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb892242-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb892243-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation shall prescribe by regulation a higher amount for each .1 of a mile a gallon to be used in calculating a civil penalty under subsection (b) of this section, if the Secretary decides that the increase in the penalty—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb892244-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will result in, or substantially further, substantial energy conservation for automobiles in model years in which the increased penalty may be imposed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb892245-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not have a substantial deleterious impact on the economy of the United States, a State, or a region of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb892246-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount prescribed under subparagraph (A) of this paragraph may not be more than $0.00 for each .1 of a mile a gallon.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb892247-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may make a decision under subparagraph (A)(ii) of this paragraph only when the Secretary decides that it is likely that the increase in the penalty will not—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb892248-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cause a significant increase in unemployment in a State or a region of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb892249-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adversely affect competition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb89224a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/1/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cause a significant increase in automobile imports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb89224b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A higher amount prescribed under subparagraph (A) of this paragraph is effective for the model year beginning at least 18 months after the regulation stating the higher amount becomes final.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb89224c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall publish in the Federal Register a proposed regulation under this subsection and a statement of the basis for the regulation and provide each manufacturer of automobiles a copy of the proposed regulation and the statement. The Secretary shall provide a period of at least 45 days for written public comments on the proposed regulation. The Secretary shall submit a copy of the proposed regulation to the Federal Trade Commission and request the Commission to comment on the proposed regulation within that period. After that period, the Secretary shall give interested persons and the Commission an opportunity at a public hearing to present oral information, views, and arguments and to direct questions about disputed issues of material fact to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb89224d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other interested persons making oral presentations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb89224e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employees and contractors of the Government that made written comments or an oral presentation or participated in the development or consideration of the proposed regulation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb89224f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experts and consultants that provided information to a person that the person includes, or refers to, in an oral presentation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb892250-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may restrict the questions of an interested person and the Commission when the Secretary decides that the questions are duplicative or not likely to result in a timely and effective resolution of the issues. A transcript shall be kept of a public hearing under this subsection. A copy of the transcript and written comments shall be available to the public at the cost of reproduction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb892251-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall publish a regulation prescribed under this subsection in the Federal Register with the decisions required under paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb892252-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An officer or employee of a department, agency, or instrumentality of the Government violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":" by disclosing, except in an in camera proceeding by the Secretary or a court, information—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb892253-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided to the Secretary or the court during consideration or review of a regulation prescribed under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb892254-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decided by the Secretary to be confidential under section 11(d) of the Energy Supply and Environmental Coordination Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s796/d"},"text":"15 U.S.C. 796(d)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb892255-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Notice Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall impose a penalty under this section by written notice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb892256-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Civil Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For fiscal year 2008 and each fiscal year thereafter, from the total amount deposited in the general fund of the Treasury during the preceding fiscal year from fines, penalties, and other funds obtained through enforcement actions conducted pursuant to this section (including funds obtained under consent decrees), the Secretary of the Treasury, subject to the availability of appropriations, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb892257-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer 50 percent of such total amount to the account providing appropriations to the Secretary of Transportation for the administration of this chapter, which shall be used by the Secretary to support rulemaking under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb892258-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32912/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer 50 percent of such total amount to the account providing appropriations to the Secretary of Transportation for the administration of this chapter, which shall be used by the Secretary to carry out a program to make grants to manufacturers for retooling, reequipping, or expanding existing manufacturing facilities in the United States to produce advanced technology vehicles and components.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb892259-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1072"},"text":"108 Stat. 1072","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tI/s112"},"text":"Pub. L. 110–140, title I, § 112","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"