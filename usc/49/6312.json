{"tag":"section","attrib":{"id":"idcad8bdf2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6312"},"text":null,"children":[{"tag":"num","attrib":{"value":"6312"},"text":"§ 6312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation statistics annual report","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Director shall submit to the President and Congress a transportation statistics annual report, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8bdf3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6312/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the progress of the Director in carrying out the duties described in section 6302(b)(3)(B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bdf4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6312/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" documentation of the methods used to obtain and ensure the quality of the statistics presented in the report; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bdf5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6312/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations of the Director for improving transportation statistical information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad8bdf6-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tII/s52011/a"},"text":"Pub. L. 112–141, div. E, title II, § 52011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/894"},"text":"126 Stat. 894","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad8bdf7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcad8bdf8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcad8bdf9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
