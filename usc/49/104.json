{"tag":"section","attrib":{"id":"idca499d8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s104"},"text":null,"children":[{"tag":"num","attrib":{"value":"104"},"text":"§ 104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Highway Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca499d8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Highway Administration is an administration in the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca499d8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca499d8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the Administration is the Administrator who is appointed by the President, by and with the advice and consent of the Senate. The Administrator reports directly to the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca499d8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administration has a Deputy Federal Highway Administrator who is appointed by the Secretary, with the approval of the President. The Deputy Administrator shall carry out duties and powers prescribed by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca499d8f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s104/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administration has an Assistant Federal Highway Administrator appointed in the competitive service by the Secretary, with the approval of the President. The Assistant Administrator is the chief engineer of the Administration. The Assistant Administrator shall carry out duties and powers prescribed by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca499d90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall carry out—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca499d91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s104/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" duties and powers vested in the Secretary by chapter 4 of title 23 for highway safety programs, research, and development related to highway design, construction and maintenance, traffic control devices, identification and surveillance of accident locations, and highway-related aspects of pedestrian safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca499d92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s104/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional duties and powers prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca499d93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of sections 101(d) and 144 of title 23, highway bridges determined to be unreasonable obstructions to navigation under the Truman-Hobbs Act may be funded from amounts set aside from the discretionary bridge program. The Secretary shall transfer these allocations and the responsibility for administration of these funds to the United States Coast Guard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca499d94-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449/s1/b"},"text":"Pub. L. 97–449, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2415"},"text":"96 Stat. 2415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":", §§ 4(j)(2), 5(m)(2), "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1365"},"text":"108 Stat. 1365","children":[],"tail":", 1375; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tI/s101/b/1"},"text":"Pub. L. 104–324, title I, § 101(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3905"},"text":"110 Stat. 3905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/159/tI/s101/c/2"},"text":"Pub. L. 106–159, title I, § 101(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1751"},"text":"113 Stat. 1751","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca499d95-47c4-11f1-9671-b5c725212f70