g":"html:span","attrib":{},"text":"104(b)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"23:303(a)(1) (last sentence), (b), (c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"104(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1655(f)(3)(B).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s6/f/3/B"},"text":"Pub. L. 89–670, § 6(f)(3)(B)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/940"},"text":"80 Stat. 940","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633/s113/e/2"},"text":"Pub. L. 93–633, § 113(e)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2163"},"text":"88 Stat. 2163","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"23:401 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/564/s201/b/1"},"text":"Pub. L. 89–564, § 201(b)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/735"},"text":"80 Stat. 735","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s8/h"},"text":"Pub. L. 89–670, § 8(h)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/943"},"text":"80 Stat. 943","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/605/s202/a"},"text":"Pub. L. 91–605, § 202(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1740"},"text":"84 Stat. 1740","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1652(e)(3) (related to FHWA) (less last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"104(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1652(e)(4) (related to FHWA).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1655(f)(3)(C) (related to FHWA).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “Each of these components” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “In addition to the Administrator of the Federal Highway Administration authorized by section 3(e) of the Department of Transportation Act” in 23:303(a)(1) (1st sentence) are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the words “in the competitive service” are substituted for “under the classified civil service” to conform to 5:2102. The text of 23:303(b), (c) is omitted as unnecessary because sections 322 and 323 of the revised title restate the authority of the Secretary of Transportation.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the source provisions are consolidated. The words “The Administrator shall carry out duties and powers” are substituted for “The Secretary shall carry out through the Federal Highway Administration those provisions of the Highway Safety Act of 1966 . . . for” in 23:401 (note) and “carry out the functions, powers, and duties of the Secretary” in 49:1655(f)(3)(B) as being more precise, to eliminate unnecessary words, and for consistency. The words “vested in the Secretary” are substituted for “as set forth in the statutes transferred to the Secretary” in 49:1655(f)(3)(B) for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “law” is substituted for “statute” in 49:1652(e)(4) for consistency. The words after “administratively final” in 49:1655(f)(3)(C) are omitted as unnecessary because of the restatement of the revised title and those laws giving the right to appeal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca499d98-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca499d99-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Truman-Hobbs Act, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-21/ch409"},"text":"act June 21, 1940, ch. 409","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/497"},"text":"54 Stat. 497","children":[],"tail":", also known as the Hobbs Bridge Act, which is classified generally to subchapter II (§ 511 et seq.) of chapter 11 of Title 33, Navigation and Navigable Waters. For complete classification of this Act to the Code, see Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca499d9a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/s101/c/2/A"},"text":"Pub. L. 106–159, § 101(c)(2)(A)","children":[],"tail":", substituted “; and” for the semicolon at end of par. (1), redesignated par. (3) as (2), and struck out former par. (2) which read as follows: “duties and powers related to motor carrier safety vested in the Secretary by chapters 5 and 315 of this title; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/s101/c/2/B"},"text":"Pub. L. 106–159, § 101(c)(2)(B)","children":[],"tail":", (C), redesignated subsec. (e) as (d) and struck out former subsec. (d) which read as follows: “A duty or power specified by subsection (c)(2) of this section may be transferred to another part of the Department only when specifically provided by law or a reorganization plan submitted under chapter 9 of title 5. A decision of the Administrator in carrying out those duties or powers and involving notice and hearing required by law is administratively final.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/j/2"},"text":"Pub. L. 103–272, § 4(j)(2)","children":[],"tail":", substituted “Administrator” for “Admininstrator” before “who is”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/m/2"},"text":"Pub. L. 103–272, § 5(m)(2)","children":[],"tail":", substituted “315” for “31”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca499d9b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca499d9c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/tI/s107/a"},"text":"Pub. L. 106–159, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1758"},"text":"113 Stat. 1758","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/159/tI/s107/a"},"text":"“This Act [see Tables for classification] shall take effect on the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":"]; except that the amendments made by section 101 [enacting "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s113"},"text":"section 113 of this title","children":[],"tail":" and amending this section, sections 5314 and 5316 of Title 5, Government Organization and Employees, and "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s104"},"text":"section 104 of Title 23","children":[],"tail":", Highways] shall take effect on "},{"tag":"date","attrib":{"date":"2000-01-01"},"text":"January 1, 2000","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idca499d9d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of authorities, functions, personnel, and assets of the Coast Guard, including the authorities and functions of the Secretary of Transportation relating thereto, to the Department of Homeland Security, and for treatment of related references, see sections 468(b), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca499d9e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Elimination of Regional Office Responsibilities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tI/s1220"},"text":"Pub. L. 105–178, title I, § 1220","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/221"},"text":"112 Stat. 221","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/178/tI/s1220"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elimination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of Transportation] shall eliminate any programmatic decisionmaking responsibility of the regional offices of the Federal Highway Administration for the Federal-aid highway program as part of the Administration’s efforts to restructure its field organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out paragraph (1), the Secretary shall eliminate regional offices, create technical resource centers, and, to the maximum extent practicable, delegate authority to State offices of the Federal Highway Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In locating the technical resource centers, the Secretary shall give preference to cities that house, on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":"], the Federal Highway Administration regional offices and are in locations that minimize the travel distance between the technical resource centers and the Federal Highway Administration division offices that will be served by the new technical resource centers."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall transmit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate a detailed implementation plan to carry out this section not later than ","children":[{"tag":"date","attrib":{"date":"1998-09-30"},"text":"September 30, 1998","children":[],"tail":", and thereafter provide periodic progress reports on carrying out this section to such Committees."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall begin implementation of the plan transmitted under subsection (c) not later than ","children":[{"tag":"date","attrib":{"date":"1998-12-31"},"text":"December 31, 1998","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
