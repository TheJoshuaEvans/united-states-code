{"tag":"section","attrib":{"id":"idcad8be82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502"},"text":null,"children":[{"tag":"num","attrib":{"value":"6502"},"text":"§ 6502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consolidated research database","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad8be83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research Abstract Database.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8be84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than September 1 of each year, the head of each modal administration and joint program office of the Department of Transportation shall submit to the Assistant Secretary, for review and public posting, a description of each proposed research project to be carried out during the following fiscal year, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8be85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed funding for any new projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposed additional funding for any existing projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less frequently than annually, after receiving the descriptions under paragraph (1), the Assistant Secretary shall publish on a public website a comprehensive database including a description of all research projects conducted by the Department of Transportation, including research funded through university transportation centers under section 5505.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The database published under paragraph (2) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8be89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be delimited by research project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a description of, with respect to each research project—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcad8be8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress made with respect to the project, including whether the project is ongoing or complete;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any outcomes of the project, including potential implications for policy, regulations, or guidance issued by a modal administration or the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any findings of the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be8f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funds allocated for the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as the Assistant Secretary determines to be necessary to address Departmental priorities and statutory mandates;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify research projects with multimodal applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify how relevant modal administrations have assisted, will contribute to, or plan to use the findings from the research projects identified under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify areas in which more than 1 modal administration is conducting research on a similar subject or a subject that has a bearing on more than 1 mode;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate how the findings of research are being disseminated to improve the efficiency, effectiveness, and safety of transportation systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the public and stakeholder input to the research plans submitted under section 6501(a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8be96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conjunction with each of the annual budget requests submitted by the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", the Secretary shall annually publish on a public website and submit to the appropriate committees of Congress a report that describes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8be97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount spent in the last full fiscal year on transportation research and development with specific descriptions of projects funded at $5,000,000 or more; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount proposed in the current budget for transportation research and development with specific descriptions of projects funded at $5,000,000 or more.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8be99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Plans and Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the plans and reports submitted under sections 1115 and 1116 of title 31, the Secretary shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8be9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the Federal transportation research and development activities for the previous fiscal year in each topic area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount spent in each topic area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the extent to which the research and development is meeting the expectations described in section 6503(c)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6502/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any amendments to the strategic plan developed under section 6503.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad8be9e-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVI/s6019/b/1"},"text":"Pub. L. 114–94, div. A, title VI, § 6019(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1579"},"text":"129 Stat. 1579","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tV/s25015/b"},"text":"Pub. L. 117–58, div. B, title V, § 25015(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/871"},"text":"135 Stat. 871","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad8be9f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad8bea0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcad8bea1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" inserted subsec. (a) heading and added pars. (1) and (2) and heading, introductory provisions, and subpars. (A) and (B) of par. (3), and struck out former subsec. (a) heading, former par. (1), which related to publication of research abstract database in general, and former par. (2) heading and subpars. (A) and (B), which related to contents of database. Subpars. (C) to (G) of former par. (2) effectively redesignated subpars. (C) to (G) of par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcad8bea2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcad8bea3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
