{"tag":"section","attrib":{"id":"idcb7f85e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32704"},"text":null,"children":[{"tag":"num","attrib":{"value":"32704"},"text":"§ 32704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service, repair, and replacement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb7f85ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjusting Mileage","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may service, repair, or replace an odometer of a motor vehicle if the mileage registered by the odometer remains the same as before the service, repair, or replacement. If the mileage cannot remain the same—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7f85eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person shall adjust the odometer to read zero; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner of the vehicle or agent of the owner shall attach a written notice to the left door frame of the vehicle specifying the mileage before the service, repair, or replacement and the date of the service, repair, or replacement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7f85ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Removing or Altering Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may not, with intent to defraud, remove or alter a notice attached to a motor vehicle as required by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb7f85ee-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1049"},"text":"108 Stat. 1049","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb7f85ef-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb7f85f0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb7f85f1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32704","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1987.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 20, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/513/s407"},"text":"Pub. L. 92–513, § 407","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/962"},"text":"86 Stat. 962","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 14, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/364/s405"},"text":"Pub. L. 94–364, § 405","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/983"},"text":"90 Stat. 983","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the text of 15:1987(b)(1) is omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
