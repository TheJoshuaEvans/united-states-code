{"tag":"section","attrib":{"id":"idcae95fd5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11122"},"text":null,"children":[{"tag":"num","attrib":{"value":"11122"},"text":"§ 11122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation and practice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcae95fd6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The regulations of the Board on car service shall encourage the purchase, acquisition, and efficient use of freight cars. The regulations may include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcae95fd7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11122/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the compensation to be paid for the use of a locomotive, freight car, or other vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae95fd8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11122/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the other terms of any arrangement for the use by a rail carrier of a locomotive, freight car, or other vehicle not owned by the rail carrier using the locomotive, freight car, or other vehicle, whether or not owned by another carrier, shipper, or third person; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae95fd9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11122/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sanctions for nonobservance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae95fda-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The rate of compensation to be paid for each type of freight car shall be determined by the expense of owning and maintaining that type of freight car, including a fair return on its cost giving consideration to current costs of capital, repairs, materials, parts, and labor. In determining the rate of compensation, the Board shall consider the transportation use of each type of freight car, the national level of ownership of each type of freight car, and other factors that affect the adequacy of the national freight car supply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcae95fdb-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/832"},"text":"109 Stat. 832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcae95fdc-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcae95fdd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcae95fde-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11122, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1421"},"text":"92 Stat. 1421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/tII/s224/a"},"text":"Pub. L. 96–448, title II, § 224(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1929"},"text":"94 Stat. 1929","children":[],"tail":", related to use of and compensation for freight cars, prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcae95fdf-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcae95fe0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
