{"tag":"section","attrib":{"id":"idcb7f85db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32703"},"text":null,"children":[{"tag":"num","attrib":{"value":"32703"},"text":"§ 32703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preventing tampering","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A person may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7f85dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32703/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advertise for sale, sell, use, install, or have installed, a device that makes an odometer of a motor vehicle register a mileage different from the mileage the vehicle was driven, as registered by the odometer within the designed tolerance of the manufacturer of the odometer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32703/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disconnect, reset, alter, or have disconnected, reset, or altered, an odometer of a motor vehicle intending to change the mileage registered by the odometer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32703/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with intent to defraud, operate a motor vehicle on a street, road, or highway if the person knows that the odometer of the vehicle is disconnected or not operating; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32703/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conspire to violate this section or section 32704 or 32705 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb7f85e0-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1049"},"text":"108 Stat. 1049","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/33"},"text":"Pub. L. 103–429, § 6(33)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4380"},"text":"108 Stat. 4380","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb7f85e1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb7f85e2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb7f85e3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"