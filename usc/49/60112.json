l,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the word “reasonable” and the text of 49 App.:1679b(b)(1) (last sentence) and 2008(b)(1) (last sentence) are omitted as surplus. Clauses (1) and (2) are substituted for “that any pipeline facility is hazardous to life or property” and 49 App.:1679b(b)(2) and 2008(b)(2) to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “involved” and “(including its resistance to corrosion and deterioration)” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(5), the words “in connection with any investigation conducted by the Board” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “responsible for pipeline safety” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the text of 49 App.:1679b(b)(4) and 2008(b)(4) is omitted because of 28:516 and 1331.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc7c5c67-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:60112(d) to clarify the restatement of 49 App.:1679b(b)(1) and 2008(b)(1) by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1994-07-05/s1"},"text":"section 1 of the Act of July 5, 1994","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Public Law 103–272","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1317"},"text":"108 Stat. 1317","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc7c5c68-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc7c5c69-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s8/a/1"},"text":"Pub. L. 107–355, § 8(a)(1)","children":[],"tail":", reenacted heading without change and amended text generally. Prior to amendment, text read as follows: “After notice and an opportunity for a hearing, the Secretary of Transportation may decide a pipeline facility is hazardous if the Secretary decides the facility is—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) hazardous to life, property, or the environment; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) constructed or operated, or a component of the facility is constructed or operated, with equipment, material, or a technique the Secretary decides is hazardous to life, property, or the environment.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s10/b"},"text":"Pub. L. 107–355, § 10(b)","children":[],"tail":", designated existing provisions as par. (1), inserted heading, realigned margins, and added pars. (2) and (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s8/a/2"},"text":"Pub. L. 107–355, § 8(a)(2)","children":[],"tail":", substituted “is or would be hazardous” for “is hazardous”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" inserted before period at end “, including suspended or restricted use of the facility, physical inspection, testing, repair, replacement, or other appropriate action”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc7c5c6a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc7c5c6b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s9"},"text":"section 9 of Pub. L. 103–429","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
