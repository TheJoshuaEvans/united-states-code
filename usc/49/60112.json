,"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2008(b)(1) (1st sentence words before 3d comma), (2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/129/s209/b/1"},"text":"Pub. L. 96–129, § 209(b)(1)","children":[],"tail":"–(5), "},{"tag":"html:a","attrib":{"href":"/us/stat/93/1010"},"text":"93 Stat. 1010","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/508/s201/b"},"text":"Pub. L. 102–508, § 201(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/3300"},"text":"106 Stat. 3300","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60112(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1679b(b)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2008(b)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":