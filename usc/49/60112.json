{"tag":"section","attrib":{"id":"idcc7c5c4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112"},"text":null,"children":[{"tag":"num","attrib":{"value":"60112"},"text":"§ 60112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pipeline facilities hazardous to life and property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc7c5c50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"After notice and an opportunity for a hearing, the Secretary of Transportation may decide that a pipeline facility is hazardous if the Secretary decides that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc7c5c51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation of the facility is or would be hazardous to life, property, or the environment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c52-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the facility is or would be constructed or operated, or a component of the facility is or would be constructed or operated, with equipment, material, or a technique that the Secretary decides is hazardous to life, property, or the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c53-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In making a decision under subsection (a) of this section, the Secretary shall consider, if relevant—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc7c5c54-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the characteristics of the pipe and other equipment used in the pipeline facility, including the age, manufacture, physical properties, and method of manufacturing, constructing, or assembling the equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c55-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature of the material the pipeline facility transports, the corrosive and deteriorative qualities of the material, the sequence in which the material are ","children":[{"tag":"ref","attrib":{"idref":"fn002192"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002192"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “is”."}],"tail":" transported, and the pressure required for transporting the material;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c56-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aspects of the area in which the pipeline facility is located, including climatic and geologic conditions and soil characteristics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c57-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proximity of the area in which the hazardous liquid pipeline facility is located to environmentally sensitive areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c58-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population density and population and growth patterns of the area in which the pipeline facility is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c59-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendation of the National Transportation Safety Board made under another law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c5a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c5b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Opportunity for State Comment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide, to any appropriate official of a State in which a pipeline facility is located and about which a proceeding has begun under this section, notice and an opportunity to comment on an agreement the Secretary proposes to make to resolve the proceeding. State comment shall incorporate comments of affected local officials.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c5c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corrective Action Orders.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc7c5c5d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary decides under subsection (a) of this section that a pipeline facility is or would be hazardous, the Secretary shall order the operator of the facility to take necessary corrective action, including suspended or restricted use of the facility, physical inspection, testing, repair, replacement, or other appropriate action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions attributable to an employee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, in the case of a corrective action order issued following an accident, the Secretary determines that the actions of an employee carrying out an activity regulated under this chapter, including duties under section 60102(a), may have contributed substantially to the cause of the accident, the Secretary shall direct the operator to relieve the employee from performing those activities, reassign the employee, or place the employee on leave until the earlier of the date on which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc7c5c5f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, after notice and an opportunity for a hearing, determines that the employee’s actions did not contribute substantially to the cause of the accident; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc7c5c60-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines the employee has been re-qualified or re-trained as provided for in section 60131 and can safely perform those activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c61-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of collective bargaining agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An action taken by an operator under paragraph (2) shall be in accordance with the terms and conditions of any applicable collective bargaining agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c62-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60112/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Notice and Hearing in Emergency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may waive the requirements for notice and an opportunity for a hearing under this section and issue expeditiously an order under this section if the Secretary decides failure to issue the order expeditiously will result in likely serious harm to life, property, or the environment. An order under this subsection shall provide an opportunity for a hearing as soon as practicable after the order is issued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc7c5c63-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1317"},"text":"108 Stat. 1317","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/76"},"text":"Pub. L. 103–429, § 6(76)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4388"},"text":"108 Stat. 4388","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/355"},"text":"Pub. L. 107–355","children":[],"tail":", §§ 8(a), 10(b), "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2993"},"text":"116 Stat. 2993","children":[],"tail":", 2995.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc7c5c64-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc7c5c65-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc7c5c66-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text"