{"tag":"section","attrib":{"id":"idcbd7de82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42308"},"text":null,"children":[{"tag":"num","attrib":{"value":"42308"},"text":"§ 42308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" DOT airline customer service dashboards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd7de83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement To Establish and Maintain Publicly Available Dashboards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall establish, maintain, and make publicly available the following online dashboards for purposes of keeping aviation consumers informed with respect to certain policies of, and services provided by, large air carriers (as such term is defined by the Secretary) to the extent that such policies or services exceed what is required by Federal law:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7de84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42308/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delay and cancellation dashboard","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A dashboard that displays information regarding the services and compensation provided by each large air carrier to mitigate any passenger inconvenience caused by a delay or cancellation due to circumstances in the control of such carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7de85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42308/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Explanation of circumstances","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The website on which such dashboard is displayed shall explain the circumstances under which a delay or cancellation is not due to circumstances in the control of the large air carrier (such as a delay or cancellation due to a weather event or an instruction from the Federal Aviation Administration Air Traffic Control System Command Center) consistent with section 234.4 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7de86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42308/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Family seating dashboard","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A dashboard that displays information regarding which large air carriers guarantee that each child shall be seated adjacent to an adult accompanying the child without charging any additional fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7de87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42308/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Seat size dashboard","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A dashboard that displays information regarding aircraft seat size for each large air carrier, including the pitch, width, and length of a seat in economy class for the aircraft models and configurations most commonly flown by such carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7de88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42308/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Family seating sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement in subsection (a)(3) shall cease to be effective on the date on which the rule in section 516 of the FAA Reauthorization Act of 2024 is effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7de89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accessibility Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing the dashboards required in subsection (a), the Secretary shall, in order to ensure the dashboards are accessible and contain pertinent information for passengers with disabilities, consult with the Air Carrier Access Act Advisory Committee, the Architectural and Transportation Barriers Compliance Board, any other relevant department or agency to determine appropriate accessibility standards, and disability organizations, including advocacy and nonprofit organizations that represent or provide services to individuals with disabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7de8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Dashboards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After the rule required in section 516 of the FAA Reauthorization Act of 2024 is effective, the Secretary may not establish or maintain more than 4 different customer service dashboards at any given time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7de8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42308/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each large air carrier shall provide to the Secretary such information as the Secretary requires to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7de8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42308/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall cease to be effective on ","children":[{"tag":"date","attrib":{"date":"2028-10-01"},"text":"October 1, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd7de8d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tV/s506/a/1"},"text":"Pub. L. 118–63, title V, § 506(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1192"},"text":"138 Stat. 1192","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd7de8e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbd7de8f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbd7de90-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 516 of the FAA Reauthorization Act of 2024, referred to in subsecs. (a)(5) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s516"},"text":"section 516 of Pub. L. 118–63","children":[],"tail":", which is set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s42301"},"text":"section 42301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbd7de91-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbd7de92-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Establishment of Online Dashboards","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tV/s506/a/2"},"text":"Pub. L. 118–63, title V, § 506(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1193"},"text":"138 Stat. 1193","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tV/s506/a/2"},"text":"“The Secretary [of Transportation] shall establish each of the online dashboards required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s42308/a"},"text":"section 42308(a) of title 49","children":[],"tail":", United States Code, not later than 30 days after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
