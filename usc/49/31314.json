{"tag":"section","attrib":{"id":"idcb760fd4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31314"},"text":null,"children":[{"tag":"num","attrib":{"value":"31314"},"text":"§ 31314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding amounts for State noncompliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb760fd5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"First Fiscal Year","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall withhold up to 5 percent of the amount required to be apportioned to a State under section 104(b)(1), (3), and (4) ","children":[{"tag":"ref","attrib":{"idref":"fn002126"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002126"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 23 on the first day of the fiscal year after the first fiscal year beginning after "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":", throughout which the State does not comply substantially with a requirement of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31311/a"},"text":"section 31311(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb760fd6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Second Fiscal Year","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall withhold up to 10 percent of the amount required to be apportioned to a State under section 104(b)(1), (3), and (4) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of title 23 on the first day of each fiscal year after the 2d fiscal year beginning after "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":", throughout which the State does not comply substantially with a requirement of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31311/a"},"text":"section 31311(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb760fd7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties Imposed in Fiscal Year ","children":[],"tail":"2012"},{"tag":"inline","attrib":{},"text":" and Thereafter","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Effective beginning on ","children":[{"tag":"date","attrib":{"date":"2011-10-01"},"text":"October 1, 2011","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb760fd8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31314/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the penalty for the first instance of noncompliance by a State under this section shall be not more than an amount equal to 4 percent of funds required to be apportioned to the noncompliant State under paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s104/b"},"text":"section 104(b) of title 23","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb760fd9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31314/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the penalty for subsequent instances of noncompliance shall be not more than an amount equal to 8 percent of funds required to be apportioned to the noncompliant State under paragraphs (1) and (2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s104/b"},"text":"section 104(b) of title 23","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb760fda-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability for Apportionment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts withheld under this section from apportionment to a State after ","children":[{"tag":"date","attrib":{"date":"1995-09-30"},"text":"September 30, 1995","children":[],"tail":", are not available for apportionment to the State."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb760fdb-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1028"},"text":"108 Stat. 1028","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4011/g"},"text":"Pub. L. 105–178, title IV, § 4011(g)","children":[],"tail":", (h), "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/408"},"text":"112 Stat. 408","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIX/s9010"},"text":"