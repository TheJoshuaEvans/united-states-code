","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2710(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31314(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2710(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31314(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2710(c)(2), (3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31314(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2710(c)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the word “amounts” is substituted for “funds” and “sums” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “by the Secretary” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb760fdf-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb760fe0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 104(b)(1), (3), and (4) of title 23, referred to in subsecs. (a) and (b), probably refers to section 104(b)(1), (3), and (4) of title 23 prior to the general amendment of section 104 by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1105/a"},"text":"Pub. L. 112–141, div. A, title I, § 1105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/427"},"text":"126 Stat. 427","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb760fe1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" inserted “up to” after “withhold”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4011/h/1"},"text":"Pub. L. 105–178, § 4011(h)(1)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":", substituted “section 104(b)(1), (3), and (4) of title 23” for “section 104(b)(1), (3), and (5) of title 23”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4011/g/1"},"text":"Pub. L. 105–178, § 4011(g)(1)","children":[],"tail":", substituted “section 104(b)(1), (3), and (5) of title 23” for “section 104(b)(1), (2), (5), and (6) of title 23”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4011/g/2"},"text":"Pub. L. 105–178, § 4011(g)(2)","children":[],"tail":", struck out par. (2) designation and struck out par. (1) which read as follows: “Amounts withheld under this section from apportionment to a State before "},{"tag":"date","attrib":{"date":"1995-10-01"},"text":"October 1, 1995","children":[],"tail":", remain available for apportionment to the State as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) If the amounts would have been apportioned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s104/b/5/B"},"text":"section 104(b)(5)(B) of title 23","children":[],"tail":" but for this section, the amounts remain available until the end of the 2d fiscal year following the fiscal year for which the amounts are authorized to be appropriated."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) If the amounts would have been apportioned under section 104(b)(1), (2), or (6) of title 23 but for this section, the amounts remain available until the end of the 3d fiscal year following the fiscal year for which the amounts are authorized to be appropriated.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4011/h/2"},"text":"Pub. L. 105–178, § 4011(h)(2)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":", struck out heading and text of subsec. (d). Text read as follows: “If, at the end of the period for which amounts withheld under this section from apportionment are available for apportionment to a State under subsection (c)(1) of this section, the State has not substantially complied with all of the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31311/a"},"text":"section 31311(a) of this title","children":[],"tail":" for a 365-day period, the amounts lapse or, for amounts withheld from apportionment under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s104/b/5"},"text":"section 104(b)(5) of title 23","children":[],"tail":", the amounts lapse and are available for projects under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s118/b"},"text":"section 118(b) of title 23","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4011/g/3"},"text":"Pub. L. 105–178, § 4011(g)(3)","children":[],"tail":", (4), redesignated subsec. (e) as (d) and struck out heading and text of former subsec. (d). Text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) If, before the last day of the period for which amounts withheld under this section from apportionment are to remain available for apportionment to a State under subsection (c)(1) of this section, the State substantially complies with all of the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31311/a"},"text":"section 31311(a) of this title","children":[],"tail":" for a period of 365 days, the Secretary, on the day following the last day of that period, shall apportion to the State the withheld amounts remaining available for apportionment to that State."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) Amounts apportioned under paragraph (1) of this subsection remain available for expenditure until the end of the 3d fiscal year following the fiscal year in which the amounts are apportioned. Amounts not obligated at the end of that period lapse or, for amounts apportioned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s104/b/5"},"text":"section 104(b)(5) of title 23","children":[],"tail":", lapse and are available for projects under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s118/b"},"text":"section 118(b) of title 23","children":[],"tail":".”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4011/g/4"},"text":"Pub. L. 105–178, § 4011(g)(4)","children":[],"tail":", redesignated subsec. (e) as (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb760fe2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb760fe3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb760fe4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Title IX of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" effective simultaneously with enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" and to be treated as included in "},{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" at time of enactment, and provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":", as in effect on day before "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", that are amended by title IX of "},{"tag":"ref","attrib":{"href":"/us/pl/105/206"},"text":"Pub. L. 105–206","children":[],"tail":" to be treated as not enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/s9016"},"text":"section 9016 of Pub. L. 105–206","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
