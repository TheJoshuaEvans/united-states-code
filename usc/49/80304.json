l},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:783 (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1939-08-09/ch618"},"text":"Aug. 9, 1939, ch. 618","children":[],"tail":", §§ 3 (1st sentence), 4 (proviso), 8, "},{"tag":"html:a","attrib":{"href":"/us/stat/53/1292"},"text":"53 Stat. 1292","children":[],"tail":", 1293."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:788.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80304(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:789.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1939-08-03/ch618"},"text":"Aug. 3, 1939, ch. 618","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/53/1291"},"text":"53 Stat. 1291","children":[],"tail":", § 9; added "},{"tag":"html:a","attrib":{"href":"/us/act/1956-08-01/ch852/s22"},"text":"Aug. 1, 1956, ch. 852, § 22","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/911"},"text":"70 Stat. 911","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80304(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(no source).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80304(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:784 (proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “may designate” are substituted for “is empowered to authorize, or designate” in 49 App.:783 (1st sentence) to eliminate unnecessary words. The word “employees” is added for clarity and consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a)(2) and (b)(3), the word “regulations” is substituted for “such rules and regulations as may be necessary” in 49 App.:788 and 789 for consistency in the revised title and with other titles of the Code and because “rules” and “regulations” are synonymous.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “shall carry out this chapter in Guam” are substituted for “In Guam the enforcement and administration of this chapter shall be performed” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is added because, under section 502(a)(2) of the Covenant to Establish a Commonwealth of the Northern Mariana Islands in Political Union with the United States of America, as enacted by the Act of ","children":[{"tag":"date","attrib":{"date":"1976-03-24"},"text":"March 24, 1976","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/94/241"},"text":"Public Law 94–241","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/263"},"text":"90 Stat. 263","children":[],"tail":"), and proclaimed to be in effect by the President on "},{"tag":"date","attrib":{"date":"1978-01-09"},"text":"January 9, 1978","children":[],"tail":" (Proc. No. 4534, "},{"tag":"date","attrib":{"date":"1977-10-24"},"text":"Oct. 24, 1977","children":[],"tail":", 42 F.R. 56593, "},{"tag":"ref","attrib":{"href":"/us/usc/t48/s1681"},"text":"48 U.S.C. 1681","children":[],"tail":" (note)), the Commonwealth was given the same authority as Guam when a law applies to Guam and the States of the United States generally."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “Secretary” is substituted for “by such officers, agents, or other persons as may be authorized or designated for that purpose by the Secretary of the Treasury” because of subsection (a)(1) of this section. The words “or the Governor of Guam or of the Northern Mariana Islands as provided in subsections (b) and (c) of this section” are added because under 49 App.:789 the Governor of Guam enforces 49 App.:ch. 11 in Guam and because of section 502(a)(2) of the Covenant referred to in the revision note for subsection (c) of this section. The words “the customs laws” are substituted for “That such duties as are imposed upon the collector of customs or any other person with respect to the seizure and forfeiture of vessels and vehicles under the customs laws” because of the restatement and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc8cfd6d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc8cfd6e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1112/r/1"},"text":"Pub. L. 107–296, § 1112(r)(1)","children":[],"tail":", substituted “(b), (c), and (d)” for “(b) and (c)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1112/r/2"},"text":"Pub. L. 107–296, § 1112(r)(2)","children":[],"tail":", (3), added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc8cfd6f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc8cfd70-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
