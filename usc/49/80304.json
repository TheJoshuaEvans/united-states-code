{"tag":"section","attrib":{"id":"idcc8cfd5b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304"},"text":null,"children":[{"tag":"num","attrib":{"value":"80304"},"text":"§ 80304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc8cfd5c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsections (b), (c), and (d) of this section, the Secretary of the Treasury—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8cfd5d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may designate officers, employees, agents, or other persons to carry out this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall prescribe regulations to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8cfd5f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In Guam","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Governor of Guam—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8cfd60-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" or officers of the government of Guam designated by the Governor shall carry out this chapter in Guam;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd61-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may carry out laws referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s80306/b"},"text":"section 80306(b) of this title","children":[],"tail":" with modifications the Governor decides are necessary to meet conditions in Guam; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd62-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may prescribe regulations to carry out this chapter in Guam.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8cfd63-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In Northern Mariana Islands","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Governor of the Northern Mariana Islands—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8cfd64-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" or officers of the government of the Northern Mariana Islands designated by the Governor shall carry out this chapter in the Northern Mariana Islands;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd65-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may carry out laws referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s80306/b"},"text":"section 80306(b) of this title","children":[],"tail":" with modifications the Governor decides are necessary to meet conditions in the Northern Mariana Islands; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd66-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may prescribe regulations to carry out this chapter in the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8cfd67-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attorney General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General, or officers, employees, or agents of the Bureau of Alcohol, Tobacco, Firearms, and Explosives, Department of Justice ","children":[{"tag":"ref","attrib":{"idref":"fn002193"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002193"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be followed by a comma."}],"tail":" designated by the Attorney General, shall carry out the laws referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s80306/b"},"text":"section 80306(b) of this title","children":[],"tail":" to the extent that the violation of this chapter involves contraband described in section 80302(a)(2) or (a)(5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8cfd68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80304/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Customs Laws on Seizure and Forfeiture","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, or the Governor of Guam or of the Northern Mariana Islands as provided in subsections (b) and (c) of this section, shall carry out the customs laws on the seizure and forfeiture of aircraft, vehicles, and vessels under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc8cfd69-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1354"},"text":"108 Stat. 1354","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXI/s1112/r"},"text":"Pub. L. 107–296, title XI, § 1112(r)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2278"},"text":"116 Stat. 2278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc8cfd6a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc8