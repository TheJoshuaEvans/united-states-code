{"tag":"section","attrib":{"id":"idcb0f8544-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117"},"text":null,"children":[{"tag":"num","attrib":{"value":"20117"},"text":"§ 20117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb0f8545-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0f8546-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There are authorized to be appropriated to the Secretary of Transportation to carry out this part and to carry out responsibilities under chapter 51 as delegated or authorized by the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0f8547-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $225,000,000 for fiscal year 2009;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f8548-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $245,000,000 for fiscal year 2010;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f8549-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $266,000,000 for fiscal year 2011;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f854a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $289,000,000 for fiscal year 2012; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f854b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $293,000,000 for fiscal year 2013.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f854c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" With amounts appropriated pursuant to paragraph (1), the Secretary shall purchase Gage Restraint Measurement System vehicles and track geometry vehicles or other comparable technology as needed to assess track safety consistent with the results of the track inspection study required by section 403 of the Rail Safety Improvement Act of 2008.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f854d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There are authorized to be appropriated to the Secretary $18,000,000 for the period encompassing fiscal years 2009 through 2013 to design, develop, and construct the Facility for Underground Rail Station and Tunnel at the Transportation Technology Center in Pueblo, Colorado. The facility shall be used to test and evaluate the vulnerabilities of above-ground and underground rail tunnels to prevent accidents and incidents in such tunnels, to mitigate and remediate the consequences of any such accidents or incidents, and to provide a realistic scenario for training emergency responders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f854e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such sums as may be necessary from the amount appropriated pursuant to paragraph (1) for each of the fiscal years 2009 through 2013 shall be made available to the Secretary for personnel in regional offices and in Washington, D.C., whose duties primarily involve rail security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0f854f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade Crossing Safety","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than $1,000,000 may be appropriated to the Secretary for improvements in grade crossing safety, except demonstration projects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20134/c"},"text":"section 20134(c) of this title","children":[],"tail":". Amounts appropriated under this subsection remain available until expended."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0f8550-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research and Development, Automated Track Inspection, and State Participation Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts appropriated under this section for research and development, automated track inspection, and grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20105/e"},"text":"section 20105(e) of this title","children":[],"tail":" remain available until expended."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0f8551-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Available for Certain Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At least 50 percent of the amounts appropriated to the Secretary for a fiscal year to carry out railroad research and development programs under this chapter or another law shall be available for safety research, improved track inspection and information acquisition technology, improved railroad freight transportation, and improved railroad passenger systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0f8552-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20117/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation Lifesaver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to amounts otherwise authorized by law, there are authorized to be appropriated for railroad research and development $300,000 for fiscal year 1995, $500,000 for fiscal year 1996, and $750,000 for fiscal year 1997, to support Operation Lifesaver, Inc.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0f8553-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/872"},"text":"108 Stat. 872","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/440/tII"},"text":"Pub. L. 103–440, title II","children":[],"tail":", §§ 202, 218, "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4619"},"text":"108 Stat. 4619","children":[],"tail":", 4625; "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/s3"},"text":"Pub. L. 110–432, div. A, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4850"},"text":"122 Stat. 4850","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb0f8554-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb0f8555-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb0f8556-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historic