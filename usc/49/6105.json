{"tag":"section","attrib":{"id":"idcad3dceb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6105"},"text":null,"children":[{"tag":"num","attrib":{"value":"6105"},"text":"§ 6105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of best practices guidelines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad3dcec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adoption of Best Practices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall encourage States, operators of one-call notification programs, excavators (including all government and contract excavators), and underground facility operators to adopt and implement practices identified in the best practices report entitled “Common Ground”, as periodically updated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad3dced-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide technical assistance to and participate in programs sponsored by a non-profit organization specifically established for the purpose of reducing construction-related damage to underground facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad3dcee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad3dcef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make grants to a non-profit organization described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dcf0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to amounts authorized under section 6107, there is authorized to be appropriated for making grants under this subsection $500,000 for each of fiscal years 2003 through 2006. Such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dcf1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6105/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General revenue funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any sums appropriated under this subsection shall be derived from general revenues and may not be derived from amounts collected under section 60301.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad3dcf2-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tVII/s7302/a"},"text":"Pub. L. 105–178, title VII, § 7302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/480"},"text":"112 Stat. 480","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/355/s2/c/1"},"text":"Pub. L. 107–355, § 2(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2985"},"text":"116 Stat. 2985","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad3dcf3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad3dcf4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcad3dcf5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355"},"text":"Pub. L. 107–355","children":[],"tail":" amended section generally. Prior to amendment, section related to study of existing one-call systems, purpose and considerations of study, report by Secretary within one year of "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", and discretion of Secretary as to whether to carry out study."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
