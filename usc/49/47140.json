{"tag":"section","attrib":{"id":"idcc5fac62-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140"},"text":null,"children":[{"tag":"num","attrib":{"value":"47140"},"text":"§ 47140.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Meeting current and future energy power demand","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc5fac63-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall establish a program under which the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5fac64-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" encourage the sponsor of each public-use airport to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc5fac65-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct airport planning that assesses the airport’s—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc5fac66-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" current and future energy power requirements, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcc5fac67-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" heating and cooling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc5fac68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on-road airport vehicles and ground support equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc5fac69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gate electrification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc5fac6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a/1/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" electric aircraft charging; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc5fac6b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a/1/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" vehicles and equipment used to transport passengers and employees between the airport and—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idcc5fac6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a/1/A/i/V/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nearby facilities owned or controlled by the airport or which otherwise directly support the functions or services provided by the airport; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idcc5fac6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a/1/A/i/V/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intermodal surface transportation facility adjacent to the airport; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc5fac6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" existing energy infrastructure condition, location, and capacity, including base load and backup power, to meet the current and future electrical power demand as identified in this subparagraph; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5fac6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct airport development to improve energy efficiency, increase peak load savings at the airport, and meet future electrical power demands as identified in subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5fac70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimburse the airport sponsor for the costs incurred in conducting the assessment under paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5fac71-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make grants to airport sponsors from amounts made available under section 48103 to assist such sponsors that have completed the assessment described in subsection (a)(1)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5fac72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire or construct equipment that will improve energy efficiency at the airport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5fac73-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pursue an airport development project described in subsection (a)(1)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5fac74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47140/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible for a grant under paragraph (1),","children":[{"tag":"ref","attrib":{"idref":"fn002185"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002185"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subsection (b)”."}],"tail":" the sponsor of a public-use airport shall submit an application, including a certification that no safety projects are being deferred by requesting a grant under this section, to the Secretary at such time, in such manner, and containing such information as the Secretary may require."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc5fac75-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tV/s512/a"},"text":"Pub. L. 112–95, title V, § 512(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/109"},"text":"126 Stat. 109","children":[],"tail":", § 47140a; renumbered § 47140 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tI"},"text":"Pub. L. 115–254, div. B, title I","children":[],"tail":", §§ 166(b)(1), 171, "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3226"},"text":"132 Stat. 3226","children":[],"tail":", 3227; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s742/a"},"text":"Pub. L. 118–63, title VII, § 742(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1278"},"text":"138 Stat. 1278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc5fac76-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc5fac77-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcc5fac78-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 47140, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/tI/s159/a/1"},"text":"Pub. L. 108–176, title I, § 159(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2509"},"text":"117 Stat. 2509","children":[],"tail":", related to airport ground support equipment emissions retrofit pilot program, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tI/s166/a"},"text":"Pub. L. 115–254, div. B, title I, § 166(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3226"},"text":"132 Stat. 3226","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc5fac79-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" amended section generally. Prior to amendment, section related to increasing the energy efficiency of airport power sources."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s166/b/1"},"text":"Pub. L. 115–254, § 166(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s47140a"},"text":"section 47140a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s171/a"},"text":"Pub. L. 115–254, § 171(a)","children":[],"tail":", inserted “, and to reimburse the airport sponsor for the costs incurred in conducting the assessment” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s171/b"},"text":"Pub. L. 115–254, § 171(b)","children":[],"tail":", inserted “, including a certification that no safety projects are being be deferred by requesting a grant under this section,” after “an application”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
