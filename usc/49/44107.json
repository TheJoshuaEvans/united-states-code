{"tag":"section","attrib":{"id":"idcbd7df07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107"},"text":null,"children":[{"tag":"num","attrib":{"value":"44107"},"text":"§ 44107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordation of conveyances, leases, and security instruments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd7df08-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of System","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Federal Aviation Administration shall establish a system for recording—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7df09-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conveyances that affect an interest in civil aircraft of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7df0a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" leases and instruments executed for security purposes, including conditional sales contracts, assignments, and amendments, that affect an interest in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7df0b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specifically identified aircraft engine having at least 550 rated takeoff horsepower or its equivalent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7df0c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a specifically identified aircraft propeller capable of absorbing at least 750 rated takeoff shaft horsepower;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7df0d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an aircraft engine, propeller, or appliance maintained for installation or use in an aircraft, aircraft engine, or propeller, by or for an air carrier holding a certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44705"},"text":"section 44705 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7df0e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" spare parts maintained by or for an air carrier holding a certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44705"},"text":"section 44705 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7df0f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" releases, cancellations, discharges, and satisfactions related to a conveyance, lease, or instrument recorded under paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7df10-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Description Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A lease or instrument recorded under subsection (a)(2)(C) or (D) of this section only has to describe generally the engine, propeller, appliance, or spare part by type and designate its location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7df11-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acknowledgment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as the Administrator otherwise may provide, a conveyance, lease, or instrument may be recorded under subsection (a) of this section only after it has been acknowledged before—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7df12-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a notary public; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7df13-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another officer authorized under the laws of the United States, a State, the District of Columbia, or a territory or possession of the United States to acknowledge deeds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7df14-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records and Indexes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7df15-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep a record of the time and date that each conveyance, lease, and instrument is filed and recorded with the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7df16-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" record each conveyance, lease, and instrument filed with the Administrator, in the order of their receipt, and index them by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7df17-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identifying description of the aircraft, aircraft engine, or propeller, or location specified in a lease or instrument recorded under subsection (a)(2)(C) or (D) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7df18-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names of the parties to each conveyance, lease, and instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7df19-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"International Registry.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7df1a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of united states entry point","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As permitted under the Cape Town Treaty, the Federal Aviation Administration Civil Aviation Registry is designated as the United States Entry Point to the International Registry relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7df1b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civil aircraft of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7df1c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an aircraft for which a United States identification number has been assigned but only with regard to a notice filed under paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7df1d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft engines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7df1e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"System for filing notice of prospective interests.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7df1f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall establish a system for filing notices of prospective assignments and prospective international interests in, and prospective sales of, aircraft or aircraft engines described in paragraph (1) under the Cape Town Treaty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7df20-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of validity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A filing of a notice of prospective assignment, interest, or sale under this paragraph and the registration with the International Registry relating to such assignment, interest, or sale shall not be valid after the 60th day following the date of the filing unless documents eligible for recording under subsection (a) relating to such notice are filed for recordation on or before such 60th day.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7df21-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44107/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization for registration of aircraft","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A registration with the International Registry relating to an aircraft described in paragraph (1) (other than subparagraph (C)) is valid only if (A) the person seeking the registration first files documents eligible for recording under subsection (a) and relating to the registration with the United States Entry Point, and (B) the United States Entry Point authorizes the registration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd7df22-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1164"},"text":"108 Stat. 1164","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/297/s3"},"text":"Pub. L. 108–297, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1096"},"text":"118 Stat. 1096","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd7df23-47c4-11f1-9671-b5c725