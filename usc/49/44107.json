us/stat/72/773"},"text":"72 Stat. 773","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 8, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/81/s4"},"text":"Pub. L. 86–81, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/181"},"text":"73 Stat. 181","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1) and (2), the words “title to” are omitted as being included in “interest in”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), before subclause (A), the word “instruments” is substituted for “any mortgage, equipment trust . . . or other instrument” because it is inclusive. The word “supplement” is omitted as being included in “amendments”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “The Secretary of Transportation shall also record under the system” are omitted as unnecessary because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a)(3) and (c), the words “lease, or instrument” are substituted for “other instrument” for clarity and consistency in this subchapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (d), the words “or locations” are omitted because of 1:1.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “recorded under subsection (a)(2)(C) or (D) of this section” are added for clarity. The words “lease or instrument” are substituted for “instrument” for clarity and consistency in this subchapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), before clause (1), the words “by regulation” are omitted because of 49:322(a). In clause (2), the words “possession of the United States” are substituted for “possession thereof” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “lease, and instrument” are substituted for “other instruments” for clarity and consistency in this subchapter. In clause (1), the words “of the time and date of” before “recordation” are omitted as unnecessary because of the restatement. In clause (2), before subclause (A), the words “in files to be kept for that purpose” are omitted as unnecessary. In subclause (A), the words “location specified in a lease or instrument recorded under subsection (a)(2)(C) or (D) of this section” are substituted for “in the case of an instrument referred to in subsection (a)(3) of this section, the location or locations specified therein” for clarity and consistency in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbd7df26-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbd7df27-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/297/s3/a/1"},"text":"Pub. L. 108–297, § 3(a)(1)","children":[],"tail":", substituted “550” for “750”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/297/s3/a/2"},"text":"Pub. L. 108–297, § 3(a)(2)","children":[],"tail":", substituted “paragraph (1) or (2)” for “clause (1) or (2) of this subsection”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/297/s3/b"},"text":"Pub. L. 108–297, § 3(b)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbd7df28-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbd7df29-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/297"},"text":"Pub. L. 108–297","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-03-01"},"text":"Mar. 1, 2006","children":[],"tail":", and not applicable to any registration or recordation that was made before such date under this chapter or any legal rights relating to such registration or recordation, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/297/s7"},"text":"section 7 of Pub. L. 108–297","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44101"},"text":"section 44101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
