{"tag":"section","attrib":{"id":"idcbbfe94f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41502"},"text":null,"children":[{"tag":"num","attrib":{"value":"41502"},"text":"§ 41502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishing joint prices for through routes with other carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbbfe950-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint Prices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier may establish reasonable joint prices and through service with another carrier. However, an air carrier not directly operating aircraft in air transportation (except an air express company) may not establish under this section a joint price for the transportation of property with a carrier subject to subtitle IV of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbfe951-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prices, Classifications, Rules, and Practices and Divisions of Joint Prices","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For through service by an air carrier and a carrier subject to subtitle IV of this title, the participating carriers shall establish—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbfe952-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable prices and reasonable classifications, rules, and practices affecting those prices or the value of the transportation provided under those prices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbfe953-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for joint prices established for the through service, reasonable divisions of those joint prices among the participating carriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbfe954-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statements Included in Tariffs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier and a carrier subject to subtitle IV of this title that are participating in through service and joint prices shall include in their tariffs, filed with the Secretary of Transportation, a statement showing the through service and joint prices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbbfe955-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1132"},"text":"108 Stat. 1132","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s308"},"text":"Pub. L. 104–88, title III, § 308","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/948"},"text":"109 Stat. 948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/22"},"text":"Pub. L. 105–102, § 2(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2205"},"text":"111 Stat. 2205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbbfe956-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbbfe957-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbbfe958-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L. ","children":[],"tail":"103–272"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"ta