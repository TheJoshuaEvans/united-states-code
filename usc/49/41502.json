ds “participating carriers” are substituted for “carriers parties thereto” and “carriers participating therein” for consistency in this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “or the Interstate Commerce Commission, as the case may be” are omitted because of 49:10526(a)(8)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbbfe959-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends the catchline for 49:41502 to make a technical and conforming amendment necessary because section 308(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") of the ICC Termination Act ("},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Public Law 104–88","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/948"},"text":"109 Stat. 948","children":[],"tail":") struck “common” from the text of 49:41502."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbbfe95a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbbfe95b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" struck out “common” before “carriers” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" substituted “another carrier” for “another common carrier” in subsec. (a) and “a carrier” for “a common carrier” in subsecs. (a), (b), and (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbbfe95c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbbfe95d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
