{"tag":"section","attrib":{"id":"idcc8843a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202"},"text":null,"children":[{"tag":"num","attrib":{"value":"70202"},"text":"§ 70202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State freight plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc8843a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each State that receives funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s167"},"text":"section 167 of title 23","children":[],"tail":" shall develop a freight plan that provides a comprehensive plan for the immediate and long-range planning activities and investments of the State with respect to freight."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8843a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State freight plan described in subsection (a) shall include, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8843aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of significant freight system trends, needs, and issues with respect to the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the freight policies, strategies, and performance measures that will guide the freight-related transportation investment decisions of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" when applicable, a listing of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8843ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multimodal critical rural freight facilities and corridors designated within the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s70103"},"text":"section 70103 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8843ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" critical rural and urban freight corridors designated within the State under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s167"},"text":"section 167 of title 23","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how the plan will improve the ability of the State to meet the national multimodal freight policy goals described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s70101/b"},"text":"section 70101(b) of this title","children":[],"tail":" and the national highway freight program goals described in "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s167"},"text":"section 167 of title 23","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of how innovative technologies and operational strategies, including freight intelligent transportation systems, that improve the safety and efficiency of freight movement, were considered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of roadways on which travel by heavy vehicles (including mining, agricultural, energy cargo or equipment, and timber vehicles) is projected to substantially deteriorate the condition of the roadways, a description of improvements that may be required to reduce or impede the deterioration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an inventory of facilities with freight mobility issues, such as bottlenecks, within the State, and for those facilities that are State owned or operated, a description of the strategies the State is employing to address the freight mobility issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of any significant congestion or delay caused by freight movements and any strategies to mitigate that congestion or delay;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a freight investment plan that, subject to subsection (c)(2), includes a list of priority projects and describes how funds made available to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s167"},"text":"section 167 of title 23","children":[],"tail":" would be invested and matched;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recent commercial motor vehicle parking facilities assessment conducted by the State under subsection (f);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recent supply chain cargo flows in the State, expressed by mode of transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an inventory of commercial ports in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, consideration of the findings or recommendations made by any multi-State freight compact to which the State is a party under section 70204;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impacts of e-commerce on freight infrastructure in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considerations of military freight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" strategies and goals to decrease—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8843bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the severity of impacts of extreme weather and natural disasters on freight mobility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8843bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impacts of freight movement on local air pollution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8843be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/16/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impacts of freight movement on flooding and stormwater runoff; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8843bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/16/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impacts of freight movement on wildlife habitat loss; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/b/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consultation with the State freight advisory committee, if applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8843c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Long-Range Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8843c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incorporation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State freight plan described in subsection (a) may be developed separately from or incorporated into the statewide strategic long-range transportation plan required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s135"},"text":"section 135 of title 23","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8843c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fiscal constraint","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The freight investment plan component of a freight plan shall include a project, or an identified phase of a project, only if funding for completion of the project can reasonably be anticipated to be available for the project within the time period identified in the freight investment plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8843c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State freight plan described in subsection (a) shall address a 8-year forecast period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8ab3c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8ab3c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State shall update a State freight plan described in subsection (a) not less frequently than once every 4 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab3c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Freight investment plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State may update a freight investment plan described in subsection (b)(9) more frequently than is required under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8ab3c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commercial Motor Vehicle Parking Facilities Assessments","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the development or updating, as applicable, of a State freight plan under this section, each State that receives funding under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s167"},"text":"section 167 of title 23","children":[],"tail":", in consultation with relevant State motor carrier safety personnel, shall conduct an assessment of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8ab3c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the capability of the State, together with the private sector in the State, to provide adequate parking facilities and rest facilities for commercial motor vehicles engaged in interstate transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab3ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the volume of commercial motor vehicle traffic in the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab3cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether there exist any areas within the State with a shortage of adequate commercial motor vehicle parking facilities, including an analysis (economic or otherwise, as the State determines to be appropriate) of the underlying causes of such a shortage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8ab3cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State freight plan under this section shall include a requirement that the State, in carrying out activities under the State freight plan—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8ab3cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance reliability or redundancy of freight transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab3ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate the ability to rapidly restore access and reliability with respect to freight transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8ab3cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8ab3d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall approve a State freight plan described in subsection (a) if the plan achieves compliance with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab3d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70202/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings provision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection establishes new procedural requirements for the approval of a State freight plan described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc8ab3d2-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVIII/s8001/a"},"text":"Pub. L. 114–94, div. A, title VIII, § 8001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1610"},"text":"129 Stat. 1610","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI/s21104/a"},"text":"Pub. L. 117–58, div. B, title I, § 21104(a)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/658"},"text":"135 Stat. 658","children":[],"tail":", 659.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc8ab3d3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc8ab3d4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc8ab3d5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (b)(10) to (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21104/a/1"},"text":"Pub. L. 117–58, § 21104(a)(1)","children":[],"tail":", added pars. (10) to (16) and redesignated former par. (10) as (17)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21104/c/1"},"text":"Pub. L. 117–58, § 21104(c)(1)","children":[],"tail":", substituted “8-year” for “5-year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21104/c/2"},"text":"Pub. L. 117–58, § 21104(c)(2)","children":[],"tail":", substituted “4 years” for “5 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21104/a/2"},"text":"Pub. L. 117–58, § 21104(a)(2)","children":[],"tail":", added subsecs. (f) to (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc8ab3d6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc8ab3d7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
