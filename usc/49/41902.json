{"tag":"section","attrib":{"id":"idcbd0b327-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41902"},"text":null,"children":[{"tag":"num","attrib":{"value":"41902"},"text":"§ 41902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schedules for certain transportation of mail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd0b328-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41905"},"text":"section 41905 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t39/s5402"},"text":"section 5402 of title 39","children":[],"tail":", an air carrier may transport mail by aircraft between places in Alaska only under a schedule designated or required to be established under subsection (c) of this section for the transportation of mail."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd0b329-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statements on Places and Schedules","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Every air carrier shall file with the United States Postal Service a statement showing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd0b32a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the places between which the carrier is authorized to transport mail in Alaska;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b32b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every schedule of aircraft regularly operated by the carrier between places described in paragraph (1) and every change in each schedule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b32c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41902/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each schedule, the places served by the carrier and the time of arrival at, and departure from, each such place.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd0b32d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41902/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designating and Additional Schedules","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Postal Service may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd0b32e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41902/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate any schedule of an air carrier filed under subsection (b)(2) of this section for the transportation of mail between the places between which the carrier is authorized by its certificate to transport mail; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b32f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41902/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the carrier to establish additional schedules for the transportation of mail between those places.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd0b330-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41902/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Changing Schedules","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A schedule designated or required to be established for the transportation of mail under subsection (c) of this section may be changed only after 10 days’ notice of the change is filed as provided in subsection (b)(2) of this section. The Postal Service may disapprove a proposed change in a schedule or amend or modify the schedule or proposed change.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd0b331-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":", §§ 1(e), 4(k)(1), (3), "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1153"},"text":"108 Stat. 1153","children":[],"tail":", 1370; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s7/a/3/D"},"text":"Pub. L. 103–429, § 7(a)(3)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4389"},"text":"108 Stat. 4389","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/31/tVI/s6003"},"text":"Pub. L. 106–31