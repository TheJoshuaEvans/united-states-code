"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1809(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633/s110/b"},"text":"Pub. L. 93–633, § 110(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2161"},"text":"88 Stat. 2161","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/615/s12/b"},"text":"Pub. L. 101–615, § 12(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3259"},"text":"104 Stat. 3259","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca95e847-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca95e848-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" reenacted section catchline without change and amended text generally. Prior to amendment, text read as follows: “A person knowingly violating "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5104/b"},"text":"section 5104(b) of this title","children":[],"tail":" or willfully violating this chapter or a regulation prescribed or order issued under this chapter shall be fined under title 18, imprisoned for not more than 5 years, or both.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
