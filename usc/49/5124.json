{"tag":"section","attrib":{"id":"idca95e838-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5124"},"text":null,"children":[{"tag":"num","attrib":{"value":"5124"},"text":"§ 5124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca95e839-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person knowingly violating section 5104(b) or willfully or recklessly violating this chapter or a regulation, order, special permit, or approval issued under this chapter shall be fined under title 18, imprisoned for not more than 5 years, or both; except that the maximum amount of imprisonment shall be 10 years in any case in which the violation involves the release of a hazardous material that results in death or bodily injury to any person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e83a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Knowing Violations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95e83b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5124/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person acts knowingly when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca95e83c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5124/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person has actual knowledge of the facts giving rise to the violation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca95e83d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5124/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable person acting in the circumstances and exercising reasonable care would have that knowledge; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e83e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5124/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowledge of the existence of a statutory provision, or a regulation or a requirement required by the Secretary, is not an element of an offense under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e83f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5124/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Willful Violations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, a person acts willfully when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95e840-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5124/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person has knowledge of the facts giving rise to the violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e841-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5124/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person has knowledge that the conduct was unlawful.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e842-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5124/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reckless Violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, a person acts recklessly when the person displays a deliberate indifference or conscious disregard to the consequences of that person’s conduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca95e843-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/781"},"text":"108 Stat. 781","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII/s7121"},"text":"Pub. L. 109–59, title VII, § 7121","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1906"},"text":"119 Stat. 1906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca95e844-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca95e845-47c4-11f1-9671-b5c7252