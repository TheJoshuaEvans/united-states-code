{"tag":"section","attrib":{"id":"idcab752d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5321"},"text":null,"children":[{"tag":"num","attrib":{"value":"5321"},"text":"§ 5321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crime prevention and security","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation may make capital grants from amounts available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5338"},"text":"section 5338 of this title","children":[],"tail":" to public transportation systems for crime prevention and security. This chapter does not prevent the financing of a project under this section when a local governmental authority other than the grant applicant has law enforcement responsibilities."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcab752d6-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/820"},"text":"108 Stat. 820","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIII/s3002/b/4"},"text":"Pub. L. 109–59, title III, § 3002(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1545"},"text":"119 Stat. 1545","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcab752d7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcab752d8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcab752d9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag