us/stat/80/931"},"text":"80 Stat. 931","children":[],"tail":", § 4(i)(2); added "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/496"},"text":"Pub. L. 93–496","children":[],"tail":", §§ 6, 15, "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1528"},"text":"88 Stat. 1528","children":[],"tail":", 1533; "},{"tag":"html:span","attrib":{},"text":"May 26, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/25/s13"},"text":"Pub. L. 94–25, § 13","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/89/93"},"text":"89 Stat. 93","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 5, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/421/s14"},"text":"Pub. L. 95–421, § 14","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/929"},"text":"92 Stat. 929","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5563(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1653(i)(2) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “to convert a rail passenger terminal to an intermodal transportation terminal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5562/a/1"},"text":"section 5562(a)(1) of this title","children":[],"tail":"” are substituted for “for the purpose set forth in paragraph (1)(A) of this subsection” for clarity and because of the restatement. In clause (5), the word “prescribed” is substituted for “develop and promulgate” for consistency in the revised title and with other titles of the United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for “and such judgment is concurred in by consultants recommended by the Chairman of the National Endowment of [sic] the Arts and the Advisory Council on Historic Preservation and retained for this purpose by the Secretary” for clarity and consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
