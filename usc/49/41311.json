{"tag":"section","attrib":{"id":"idcbbda013-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41311"},"text":null,"children":[{"tag":"num","attrib":{"value":"41311"},"text":"§ 41311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gambling restrictions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbbda014-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier or foreign air carrier may not install, transport, or operate, or permit the use of, any gambling device on board an aircraft in foreign air transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbda015-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “gambling device” means any machine or mechanical device (including gambling applications on electronic interactive video systems installed on board aircraft for passenger use)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbda016-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which when operated may deliver, as the result of the application of an element of chance, any money or property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda017-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by the operation of which a person may become entitled to receive, as the result of the application of an element of chance, any money or property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbbda018-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/tII/s205/a/1"},"text":"Pub. L. 103–305, title II, § 205(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1583"},"text":"108 Stat. 1583","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbbda019-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbbda01a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbbda01b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Gambling on Commercial Aircraft","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/tII/s205/b"},"text":"Pub. L. 103–305, title II, § 205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1583"},"text":"108 Stat. 1583","children":[],"tail":", provided that the Secretary, not later than 1 year after "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", was to complete a study of the aviation safety effects of gambling applications on electronic interactive video systems installed on board aircraft for passenger use and the competitive implications of permitting foreign air carriers only, but not United States air carriers, to install, transport, and operate gambling applications on electronic interactive video systems on board aircraft on flights over international waters, and provided that the Secretary, within 5 days after the completion of the study, would submit a report to Congress on the results of the study."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
