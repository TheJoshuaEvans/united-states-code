ef":"/us/stat/72/747"},"text":"72 Stat. 747","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1657(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the word “pay” is substituted for “compensation” for consistency with title 5.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “In addition to the authority contained in any other Act which is transferred to and vested in the Secretary, the National Transportation Safety Board, or any other officer in the Department” before “the Secretary” and “subject to the civil service and classification laws” before “to select” in 49:1657(a) are omitted as unnecessary because of title 5, especially sections 3301, 5101, and 5331. The word “appoint” is substituted for “select, employ, appoint” because it is inclusive. The words “attorneys, and agents” after “employees” in 49:1343(d) and “including investigators, attorneys, and administrative law judges” after “employees” in 49:1657(a) are omitted as included in “officers and employees”. The words “of the Department of Transportation” are substituted for “as are necessary to carry out the provisions of this chapter” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of 49:1343(d) (words after 1st comma) is omitted because of section 414(a)(1)(B) of the Civil Service Reform Act of 1978 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/454"},"text":"Pub. L. 95–454","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1177"},"text":"92 Stat. 1177","children":[],"tail":"). The text of 49:1343(f) is omitted because of section 414(a)(2)(A) of that Act."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “procure” is substituted for “obtain” to conform to 5:3109. The words “unless otherwise specified in an appropriation Act” after “individuals” in 49:1657(b) are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca6fc35e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca6fc35f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Post-Employment Policy Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tI/s31308/b"},"text":"Pub. L. 112–141, div. C, title I, § 31308(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/770"},"text":"126 Stat. 770","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/141/dC/tI/s31308/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspector General of the Department of Transportation shall conduct a study of the Department’s policies relating to post-employment restrictions on employees who perform functions related to transportation safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [see section 3(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", set out as Effective and Termination Dates of 2012 Amendment notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways], the Inspector General shall submit a report containing the results of the study conducted under paragraph (1) to—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Energy and Commerce of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of results","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall review the results of the study conducted under paragraph (1) and take whatever action the Secretary determines to be appropriate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
