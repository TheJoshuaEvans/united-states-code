{"tag":"section","attrib":{"id":"idca6fc357-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s323"},"text":null,"children":[{"tag":"num","attrib":{"value":"323"},"text":"§ 323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca6fc358-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation may appoint and fix the pay of officers and employees of the Department of Transportation and may prescribe their duties and powers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6fc359-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may procure services under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":". However, an individual may be paid not more than $100 a day for services."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca6fc35a-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449/s1/b"},"text":"Pub. L. 97–449, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2423"},"text":"96 Stat. 2423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca6fc35b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca6fc35c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca6fc35d-47c4-11f1-9671-b5c7