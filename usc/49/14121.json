{"tag":"section","attrib":{"id":"idcafee35f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14121"},"text":null,"children":[{"tag":"num","attrib":{"value":"14121"},"text":"§ 14121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafee360-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14121/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Carrier and broker","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The terms “carrier” and “broker” include a receiver or trustee of a carrier and broker, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee361-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14121/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Association","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “association” means an organization maintained by or in the interest of a group of carriers or brokers providing transportation or service subject to jurisdiction under chapter 135 that performs a service, or engages in activities, related to transportation under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcafee362-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"t