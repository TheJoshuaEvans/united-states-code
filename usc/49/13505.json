{"tag":"section","attrib":{"id":"idcaf2d5f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13505"},"text":null,"children":[{"tag":"num","attrib":{"value":"13505"},"text":"§ 13505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation furthering a primary business","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf2d5fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Neither the Secretary nor the Board has jurisdiction under this part over the transportation of property by motor vehicle when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d5fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property is transported by a person engaged in a business other than transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d5fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation is within the scope of, and furthers a primary business (other than transportation) of the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d5fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corporate Families.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d5fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Neither the Secretary nor the Board has jurisdiction under this part over transportation of property by motor vehicle for compensation provided by a person who is a member of a corporate family for other members of such corporate family.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d5ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, “corporate family” means a group of corporations consisting of a parent corporation and all subsidiaries in which the parent corporation owns directly or indirectly a 100 percent interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf2d600-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/861"},"text":"109 Stat. 861","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf2d601-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf2d602-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf2d603-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10524"},"text":"section 10524 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaf2d604-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcaf2d605-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
