{"tag":"section","attrib":{"id":"idcbbda02a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313"},"text":null,"children":[{"tag":"num","attrib":{"value":"41313"},"text":"§ 41313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Plans to address needs of families of passengers involved in foreign air carrier accidents","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbbda02b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbda02c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aircraft accident","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “aircraft accident” means any aviation disaster, regardless of its cause or suspected cause, that occurs within the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda02d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Passenger","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “passenger” has the meaning given such term by section 1136.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbda02e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Plans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A foreign air carrier providing foreign air transportation under this chapter shall transmit to the Secretary of Transportation and the Chairman of the National Transportation Safety Board a plan for addressing the needs of the families of passengers involved in an aircraft accident that involves an aircraft under the control of the foreign air carrier and results in any loss of life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbda02f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Plans","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent permitted by foreign law which was in effect on the date of the enactment of this section, a plan submitted by a foreign air carrier under subsection (b) shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbda030-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Telephone number","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A plan for publicizing a reliable, toll-free telephone number and staff to take calls to such number from families of passengers involved in an aircraft accident that involves an aircraft under the control of the foreign air carrier and results in any loss of life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda031-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of families","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A process for notifying, in person to the extent practicable, the families of passengers involved in an aircraft accident that involves an aircraft under the control of the foreign air carrier and results in any loss of life before providing any public notice of the names of such passengers. Such notice shall be provided by using the services of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbbda032-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the organization designated for the accident under section 1136(a)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbda033-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other suitably trained individuals.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda034-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice provided as soon as possible","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that the notice required by paragraph (2) shall be provided as soon as practicable after the foreign air carrier has verified the identity of a passenger on the foreign aircraft, whether or not the names of all of the passengers have been verified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda035-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"List of passengers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An assurance that the foreign air carrier shall provide, immediately upon request, and update a list (based on the best available information at the time of the request) of the names of the passengers aboard the aircraft (whether or not such names have been verified), to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbbda036-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the director of family support services designated for the accident under section 1136(a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbda037-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the organization designated for the accident under section 1136(a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda038-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation regarding disposition of remains and effects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that the family of each passenger will be consulted about the disposition of any remains and personal effects of the passenger that are within the control of the foreign air carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda039-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Return of possessions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that, if requested by the family of a passenger, any possession (regardless of its condition) of that passenger that is within the control of the foreign air carrier will be returned to the family unless the possession is needed for the accident investigation or a criminal investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda03a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unclaimed possessions retained","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that any unclaimed possession of a passenger within the control of the foreign air carrier will be retained by the foreign air carrier for not less than 18 months after the date of the accident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda03b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monuments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that the family of each passenger will be consulted about construction by the foreign air carrier of any monument to the passengers built in the United States, including any inscription on the monument.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda03c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Equal treatment of passengers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that the treatment of the families of nonrevenue passengers (and any other victim of the accident, including any victim on the ground) will be the same as the treatment of the families of revenue passengers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda03d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service and assistance to families of passengers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that the foreign air carrier will work with any organization designated under section 1136(a)(2) on an ongoing basis to ensure that families of passengers receive an appropriate level of services and assistance following an accident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda03e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation to service organizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that the foreign air carrier will provide reasonable compensation to any organization designated under section 1136(a)(2) for services and assistance provided by the organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda03f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Travel and care expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that the foreign air carrier will assist the family of any passenger in traveling to the location of the accident and provide for the physical care of the family while the family is staying at such location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda040-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resources for plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that the foreign air carrier will commit sufficient resources to carry out the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda041-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Substitute measures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a foreign air carrier does not wish to comply with paragraph (10), (11), or (12), a description of proposed adequate substitute measures for the requirements of each paragraph with which the foreign air carrier does not wish to comply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda042-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training of employees and agents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that the foreign air carrier will provide adequate training to the employees and agents of the carrier to meet the needs of survivors and family members following an accident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda043-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation on carrier response not covered by plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that, in the event that the foreign air carrier volunteers assistance to United States citizens within the United States with respect to an aircraft accident outside the United States involving any loss of life, the foreign air carrier shall consult with the Board and the Department of State on the provision of the assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda044-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice concerning liability for manmade structures.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbbda045-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/17/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that, in the case of an accident that results in any damage to a manmade structure or other property on the ground that is not government-owned, the foreign air carrier will promptly provide notice, in writing, to the extent practicable, directly to the owner of the structure or other property about liability for any property damage and means for obtaining compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbda046-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/17/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum contents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At a minimum, the written notice shall advise an owner (i) to contact the insurer of the property as the authoritative source for information about coverage and compensation; (ii) to not rely on unofficial information offered by foreign air carrier representatives about compensation by the foreign air carrier for accident-site property damage; and (iii) to obtain photographic or other detailed evidence of property damage as soon as possible after the accident, consistent with restrictions on access to the accident site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda047-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/c/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Simultaneous electronic transmission of ntsb hearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An assurance that, in the case of an accident in which the National Transportation Safety Board conducts a public hearing or comparable proceeding at a location greater than 80 miles from the accident site, the foreign air carrier will ensure that the proceeding is made available simultaneously by electronic means at a location open to the public at both the origin city and destination city of the foreign air carrier’s flight if that city is located in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbda048-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Permit and Exemption Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not approve an application for a permit under section 41302 unless the applicant has included as part of the application or request for exemption a plan that meets the requirements of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbda049-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41313/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Liability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A foreign air carrier shall not be liable for damages in any action brought in a Federal or State court arising out of the performance of the foreign air carrier in preparing or providing a passenger list pursuant to a plan submitted by the foreign air carrier under subsection (c), unless the liability was caused by conduct of the foreign air carrier which was grossly negligent or which constituted intentional misconduct.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbbda04a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/148/s1/a"},"text":"Pub. L. 105–148, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-16"},"text":"Dec. 16, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2681"},"text":"111 Stat. 2681","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tIV/s403/a"},"text":"Pub. L. 106–181, title IV, § 403(a)","children":[],"tail":"–(c)(1), "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/130"},"text":"114 Stat. 130","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tVIII/s809/b"},"text":"Pub. L. 108–176, title VIII, § 809(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2589"},"text":"117 Stat. 2589","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tV/s539/d"},"text":"Pub. L. 115–254, div. B, title V, § 539(d)","children":[],"tail":", div. C, § 1109(b), "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3370"},"text":"132 Stat. 3370","children":[],"tail":", 3434; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tXI/s1101/i"},"text":"Pub. L. 118–63, title XI, § 1101(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1413"},"text":"138 Stat. 1413","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbbda04b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbbda04c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbbda04d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (c), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/148"},"text":"Pub. L. 105–148","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1997-12-16"},"text":"Dec. 16, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbbda04e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c)(16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" substituted “the foreign air carrier shall consult” for “will consult”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1109/b/1"},"text":"Pub. L. 115–254, § 1109(b)(1)","children":[],"tail":", substituted “any loss of life” for “a major loss of life”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1109/b/2/A"},"text":"Pub. L. 115–254, § 1109(b)(2)(A)","children":[],"tail":", substituted “any loss of life” for “a significant loss of life”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1109/b/2/B"},"text":"Pub. L. 115–254, § 1109(b)(2)(B)","children":[],"tail":", substituted “any loss of life” for “a significant loss of life” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1109/b/2/C"},"text":"Pub. L. 115–254, § 1109(b)(2)(C)","children":[],"tail":", amended par. (9) generally. Prior to amendment, text read as follows: “An assurance that the treatment of the families of nonrevenue passengers will be the same as the treatment of the families of revenue passengers.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1109/b/2/D"},"text":"Pub. L. 115–254, § 1109(b)(2)(D)","children":[],"tail":", substituted “any loss of life” for “major loss of life” and “will consult” for “the foreign air carrier will consult”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s539/d"},"text":"Pub. L. 115–254, § 539(d)","children":[],"tail":", substituted “An assurance that” for “An assurance that the foreign air carrier”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(17)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1109/b/2/E"},"text":"Pub. L. 115–254, § 1109(b)(2)(E)","children":[],"tail":", substituted “any damage” for “significant damage”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (c)(17), (18). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" added pars. (17) and (18)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s403/a"},"text":"Pub. L. 106–181, § 403(a)","children":[],"tail":", amended heading and text of par. (2) generally. Prior to amendment, text read as follows: “The term ‘passenger’ includes an employee of a foreign air carrier or air carrier aboard an aircraft.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s403/b"},"text":"Pub. L. 106–181, § 403(b)","children":[],"tail":", substituted “major” for “significant”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(15), (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s403/c/1"},"text":"Pub. L. 106–181, § 403(c)(1)","children":[],"tail":", added pars. (15) and (16)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbbda04f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbbda050-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbbda051-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by section 403(a) and (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tIV/s403/c/2"},"text":"Pub. L. 106–181, title IV, § 403(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/131"},"text":"114 Stat. 131","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/181/tIV/s403/c/2"},"text":"“The amendment made by paragraph (1) [amending this section] shall take effect on the 180th day following the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":"]. On or before such 180th day, each foreign air carrier providing foreign air transportation under chapter 413 of title 49, United States Code, shall submit to the Secretary [of Transporta