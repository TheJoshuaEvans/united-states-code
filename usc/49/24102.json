{"tag":"section","attrib":{"id":"idcb2c0e5b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102"},"text":null,"children":[{"tag":"num","attrib":{"value":"24102"},"text":"§ 24102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb2c0e5c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “auto-ferry transportation” means intercity rail passenger transportation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb2c0e5d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of automobiles or recreational vehicles and their occupants; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2c0e5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when space is available, of used unoccupied vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2c0e5f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “commuter authority” means a State, local, or regional entity established to provide, or make a contract providing for, commuter rail passenger transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2c0e60-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “commuter rail passenger transportation” means short-haul rail passenger transportation in metropolitan and suburban areas usually having reduced fare, multiple-ride, and commuter tickets and morning and evening peak period operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2c0e61-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “intercity rail passenger transportation” means rail passenger transportation, except commuter rail passenger transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2c0e62-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “long-distance route” means a route described in subparagraph (C) of paragraph (7).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2c0e63-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “National Network” includes long-distance routes and State-supported routes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2c0e64-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “national rail passenger transportation system” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb2c0e65-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the segment of the continuous Northeast Corridor railroad line between Boston, Massachusetts, and Washington, District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2c0e66-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rail corridors that have been designated by the Secretary of Transportation as high-speed rail corridors (other than corridors described in subparagraph (A)), but only after regularly scheduled intercity service over a corridor has been established;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2c0e67-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" long-distance routes of more than 750 miles between endpoints operated by Amtrak as of the date of enactment of the Passenger Rail Investment and Improvement Act of 2008; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2c0e68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" short-distance corridors, or routes of not more than 750 miles between endpoints, operated by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb2c0e69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/7/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amtrak; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb2c0e6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/7/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another rail carrier that receives funds under chapter 229.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2c0e6b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Northeast Corridor” means Connecticut, Delaware, the District of Columbia, Maryland, Massachusetts, New Jersey, New York, Pennsylvania, and Rhode Island.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2c0e6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “rail carrier” means a person, including a unit of State or local government, providing rail transportation for compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2c0e6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “rate” means a rate, fare, or charge for rail transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2c0e6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “regional transportation authority” means an entity established to provide passenger transportation in a region.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2c0e6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “state-of-good-repair” means a condition in which physical assets, both individually and as a system, are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb2c0e70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing at a level at least equal to that called for in their as-built or as-modified design specification during any period when the life cycle cost of maintaining the assets is lower than the cost of replacing them; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2c0e71-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sustained through regular maintenance and replacement programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2c0e72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24102/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State-supported route” means a route described in subparagraph (B) or (D) of paragraph (7), or in section 24702, that is operated by Amtrak, excluding those trains operated by Amtrak on the routes described in paragraph (7)(A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb2c0e73-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref",