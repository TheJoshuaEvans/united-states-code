{"tag":"section","attrib":{"id":"idcbaa8c90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111"},"text":null,"children":[{"tag":"num","attrib":{"value":"40111"},"text":"§ 40111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multiyear procurement contracts for services and related items","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbaa8c91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1341/a/1/B"},"text":"section 1341(a)(1)(B) of title 31","children":[],"tail":", the Administrator of the Federal Aviation Administration may make a contract of not more than 5 years for the following types of services and items of supply related to those services for which amounts otherwise would be available for obligation only in the fiscal year for which appropriated:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbaa8c92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation, maintenance, and support of facilities and installations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaa8c93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operation, maintenance, and modification of aircraft, vehicles, and other highly complex equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaa8c94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specialized training requiring high quality instructor skills, including training of pilots and aircrew members and foreign language training.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaa8c95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" base services, including ground maintenance, aircraft refueling, bus transportation, and refuse collection and disposal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbaa8c96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may make a contract under this section only if the Administrator finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbaa8c97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there will be a continuing requirement for the service consistent with current plans for the proposed contract period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaa8c98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the service will require a substantial initial investment in plant or equipment, or will incur a substantial contingent liability for assembling, training, or transporting a specialized workforce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaa8c99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contract will promote the best interests of the United States by encouraging effective competition and promoting economies in operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbaa8c9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When making a contract under this section, the Administrator shall be guided by the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbaa8c9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The part of the cost of a plant or equipment amortized as a cost of contract performance may not be more than the ratio between the period of contract performance and the anticipated useful commercial life (instead of physical life) of the plant or equipment, considering the location and specialized nature of the plant or equipment, obsolescence, and other similar factors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaa8c9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall consider the desirability of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbaa8c9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtaining an option to renew the contract for a reasonable period of not more than 3 years, at a price that does not include charges for nonrecurring costs already amortized; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbaa8c9e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reserving in the Administrator the right, on payment of the unamortized part of the cost of the plant or equipment, to take title to the plant or equipment under appropriate circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbaa8c9f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ending Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A contract made under this section shall be ended if amounts are not made available to continue the contract into a subsequent fiscal year. The cost of ending the contract may be paid from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbaa8ca0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriation originally available for carrying out the contract;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaa8ca1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriation currently available for procuring the type of service concerned and not otherwise obligated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaa8ca2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40111/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts appropriated for payments to end the contract.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbaa8ca3-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1107"},"text":"108 Stat. 1107","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbaa8ca4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbaa8ca5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbaa8ca6-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40111(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1344(e)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s303/e"},"text":"Pub. L. 85–726, § 303(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/747"},"text":"72 Stat. 747","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/258/s51/a/1"},"text":"Pub. L. 91–258, § 51(a)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/234"},"text":"84 Stat. 234","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 12, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/353/s16"},"text":"Pub. L. 94–353, § 16","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/882"},"text":"90 Stat. 882","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 19, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/470/s112/e"},"text":"Pub. L. 96–470, § 112(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/2240"},"text":"94 Stat. 2240","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/449/s7/b"},"text":"Pub. L. 97–449, § 7(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2444"},"text":"96 Stat. 2444","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/508/s9118/a"},"text":"Pub. L. 101–508, § 9118(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/1388-366"},"text":"104 Stat. 1388–366","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40111(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1344(e)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40111(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1344(e)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40111(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1344(e)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the word “Administrator” in section 303(e) of the Federal Aviation Act of 1958 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/747"},"text":"72 Stat. 747","children":[],"tail":") is retained on authority of 49:106(g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “periods of” are omitted as surplus. In clause (3), the words “training of” are added for clarity. In clause (4), the word “aircraft” is substituted for “in-plane” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2)(A), the words “plant, equipment, and other” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “canceled or” and “cancellation or” are omitted as being included in “ended” and “ending”, respectively.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
