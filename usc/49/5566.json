{"tag":"section","attrib":{"id":"idcad19210-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5566"},"text":null,"children":[{"tag":"num","attrib":{"value":"5566"},"text":"§ 5566.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad19211-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5566/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Record Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient of financial assistance under this chapter shall keep records required by the Secretary of Transportation. The records shall disclose—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad19212-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5566/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount, and disposition by the recipient, of the proceeds of the assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad19213-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5566/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of the project for which the assistance was given or used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad19214-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5566/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of that part of the cost of the project supplied by other sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad19215-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5566/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other records that will make an effective audit easier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad19216-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5566/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Audits and Inspections","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For 3 years after a project is completed, the Secretary and the Comptroller General may audit and inspect records of a recipient that the Secretary or Comptroller General decides may be related or pertinent to the financial assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad19217-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/853"},"text":"108 Stat. 853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad19218-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcad19219-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcad1921a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5566(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1653(i)(8) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670"},"text":"Pub. L. 89–670","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/931"},"text":"80 Stat. 931","children":[],"tail":", § 4(i)(8); added "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/496"},"text":"Pub. L. 93–496","children":[],"tail":", §§ 6, 15, "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1530"},"text":"88 Stat. 1530","children":[],"tail":", 1533; "},{"tag":"html:span","attrib":{},"text":"Feb. 5, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/210/s707/3"},"text":"Pub. L. 94–210, § 707(3)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/125"},"text":"90 Stat. 125","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/254/s206/a"},"text":"Pub. L. 96–254, § 206(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/412"},"text":"94 Stat. 412","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5566(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1653(i)(8) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the word “undertaking” is omitted as being included in “project”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the word “fully” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “the expiration of” and “of the United States” are omitted as surplus. The words “or any of their duly authorized representatives” are omitted as unnecessary because of 49:322(b) and 31:711(2). The words “may audit and inspect” are substituted for “shall have access for the purpose of audit and examination” for consistency in the revised title and with other titles of the United States Code. The word “recipient” is substituted for “such receipts” to correct an error in the underlying source provisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
