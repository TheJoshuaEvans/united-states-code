{"tag":"section","attrib":{"id":"idcc373c9f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303"},"text":null,"children":[{"tag":"num","attrib":{"value":"45303"},"text":"§ 45303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc373ca0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees Payable to Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All fees imposed and amounts collected under this chapter for services performed, or materials furnished, by the Federal Aviation Administration are payable to the Administrator of the Federal Aviation Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373ca1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Refunds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may refund any fee paid by mistake or any amount paid in excess of that required.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373ca2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Receipts Credited to Account","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", all fees and amounts collected by the Administration, except insurance premiums and other fees charged for the provision of insurance and deposited in the Aviation Insurance Revolving Fund and interest earned on investments of such Fund, and except amounts which on "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"September 30, 1996","children":[],"tail":", are required to be credited to the general fund of the Treasury (whether imposed under this section or not)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc373ca3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited to a separate account established in the Treasury and made available for Administration activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373ca4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be available immediately for expenditure but only for congressionally authorized and intended purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373ca5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373ca6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Budget Report by Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall, on the same day each year as the President submits the annual budget to Congress, provide to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc373ca7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of fee collections by the Administration during the preceding fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373ca8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of activities by the Administration during the preceding fiscal year that were supported by fee expenditures and appropriations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373ca9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" budget plans for significant programs, projects, and activities of the Administration, including out-year funding estimates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373caa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any proposed disposition of surplus fees by the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other information as those committees consider necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373cac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of Cost Accounting System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administration shall develop a cost accounting system that adequately and accurately reflects the investments, operating and overhead costs, revenues, and other financial measurement and reporting aspects of its operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373cad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation to Carriers for Acting as Collection Agents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administration shall prescribe regulations to ensure that any air carrier required, pursuant to the Air Traffic Management System Performance Improvement Act of 1996 or any amendments made by that Act, to collect a fee imposed on another party by the Administrator may collect from such other party an additional uniform amount that the Administrator determines reflects the necessary and reasonable expenses (net of interest accruing to the carrier after collection and before remittance) incurred in collecting and handling the fee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373cae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data Transparency.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc373caf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air traffic services initial data report.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc373cb0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after the date of enactment of the FAA Reauthorization Act of 2018, the Administrator and the Chief Operating Officer of the Air Traffic Organization shall, based upon the most recently available full fiscal year data, complete the following calculations for each segment of air traffic services users:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc373cb1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total costs allocable to the use of air traffic services for that segment during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cb2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total revenues received from that segment during such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373cb3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Validation of model.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idcc373cb4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review and determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 3 months after completion of the initial report required under subparagraph (A), the inspector general of the Department of Transportation shall review and determine the validity of the model used by the Administrator and the Chief Operating Officer to complete the calculations required under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cb5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Validation process","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the event that the inspector general determines that the model used by the Administrator and the Chief Operating Officer to complete the calculations required by subparagraph (A) is not valid—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcc373cb6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inspector general shall provide the Administrator and Chief Operating Officer recommendations on how to revise the model;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc373cb7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator and the Chief Operating Officer shall complete the calculations required by subparagraph (A) utilizing the revised model and resubmit the revised initial report required under subparagraph (A) to the inspector general; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc373cb8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/1/B/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 3 months after completion of the revised initial report required under subparagraph (A), the inspector general shall review and determine the validity of the revised model used by the Administrator and the Chief Operating Officer to complete the calculations required by subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cb9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator and the Chief Operating Officer shall provide the inspector general of the Department of Transportation with unfettered access to all data produced by the cost accounting system operated and maintained pursuant to subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373cba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after completion of the review and receiving a determination that the model used is valid under subparagraph (B), the Administrator and the Chief Operating Officer shall submit to the Committee on Transportation and Infrastructure, the Committee on Appropriations, and the Committee on Ways and Means of the House of Representatives, and the Committee on Commerce, Science, and Transportation, the Committee on Appropriations, and the Committee on Finance of the Senate a report describing the results of the calculations completed under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373cbb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after submission of the report required under subparagraph (C), the Administrator and Chief Operating Officer shall publish the initial report, including any revision thereto if required as a result of the validation process for the model.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cbc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air traffic services biennial data reporting.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc373cbd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biennial data reporting","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2019-03-31"},"text":"March 31, 2019","children":[],"tail":", and biennially thereafter for 14 years, the Administrator and the Chief Operating Officer shall, using the validated model, complete the following calculations for each segment of air traffic services users for the most recent full fiscal year:"}],"tail":null},{"tag":"clause","attrib":{"id":"idcc373cbe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total costs allocable to the use of the air traffic services for that segment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cbf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total revenues received from that segment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373cc0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 15 days after completing the calculations under subparagraph (A), the Administrator and the Chief Operating Officer shall complete and submit to the Committee on Transportation and Infrastructure, the Committee on Appropriations, and the Committee on Ways and Means of the House of Representatives, and the Committee on Commerce, Science, and Transportation, the Committee on Appropriations, and the Committee on Finance of the Senate a report containing the results of such calculations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373cc1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after completing the calculations pursuant to subparagraph (A), the Administrator and the Chief Operating Officer shall publish the results of such calculations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cc2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Segments of air traffic services users.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc373cc3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection, each of the following shall constitute a separate segment of air traffic services users:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc373cc4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Passenger air carriers conducting operations under part 121 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cc5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" All-cargo air carriers conducting operations under part 121 of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cc6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operators covered by part 125 of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cc7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Air carriers and operators of piston-engine aircraft operating under part 135 of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cc8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Air carriers and operators of turbine-engine aircraft operating under part 135 of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cc9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Foreign air carriers providing passenger air transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Foreign air carriers providing all-cargo air transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373ccb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operators of turbine-engine aircraft operating under part 91 of such title, excluding those operating under subpart (K) of such part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373ccc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operators of piston-engine aircraft operating under part 91 of such title, excluding those operating under subpart (K) of such part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373ccd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operators covered by subpart (K) of part 91 of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operators covered by part 133 of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373ccf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/xii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xii"},"text":"(xii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operators covered by part 136 of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cd0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/xiii"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiii"},"text":"(xiii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operators covered by part 137 of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cd1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/xiv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xiv"},"text":"(xiv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operators of public aircraft that qualify under section 40125.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cd2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/A/xv"},"text":null,"children":[{"tag":"num","attrib":{"value":"xv"},"text":"(xv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Operators of aircraft that neither take off from, nor land in, the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373cd3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional segments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may identify and include additional segments of air traffic users under subparagraph (A) as revenue and air traffic services cost data become available for that additional segment of air traffic services users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cd4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc373cd5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air traffic services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “air traffic services” means services—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc373cd6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used for the monitoring, directing, control, and guidance of aircraft or flows of aircraft and for the safe conduct of flight, including communications, navigation, and surveillance services and provision of aeronautical information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc373cd7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provided directly, or contracted for, by the Federal Aviation Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373cd8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45303/g/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air traffic services user","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “air traffic services user” means any individual or entity using air traffic services provided directly, or contracted for, by the Federal Aviation Administration within United States airspace or international airspace delegated to the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc373cd9-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264/tII/s276/a/2"},"text":"Pub. L. 104–264, title II, § 276(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3247"},"text":"110 Stat. 3247","children"