","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60115(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1673(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/481/s4/c"},"text":"Pub. L. 90–481, § 4(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/722"},"text":"82 Stat. 722","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/129/s102/c"},"text":"Pub. L. 96–129, § 102(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/991"},"text":"93 Stat. 991","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2003(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Not later than 12 months after ","children":[{"tag":"date","attrib":{"date":"1979-11-30"},"text":"November 30, 1979","children":[],"tail":"” and “and appoint the initial members of the Committee” in 49 App.:2003(a) (1st sentence) are omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3)(A)–(C), the word “individuals” is substituted for “members” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3)(A), the words “departments, agencies, and instrumentalities of the United States Government and of the States” are substituted for “governmental agencies, including State and Federal Governments” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3)(B), the words “as appropriate” are added because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(4), the words “representatives of” are omitted as surplus. The words “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10344/f"},"text":"section 10344(f) of this title","children":[],"tail":"” are substituted for “subchapter III of chapter 103 of title 49” for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1)(A) and (B), the words “or any proposed amendment to a standard under this chapter, for its consideration” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1)(B), the words “After the Committee has been established and its members appointed” in 49 App.:2003(b) are omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “or amendment”, “by the Committee”, “of the majority”, and “for rejection thereof” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “final . . . or a final amendment to a standard at any time” are omitted as surplus. The words “the end of the 90-day period” are substituted for “the 90th day after its submission to the Committee, whether or not the Committee has reported on such standard or amendment” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “for his consideration” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “(or his designee)” are omitted as surplus because of 49:322(b). The words “at least” are substituted for “not less frequently than” to eliminate unnecessary words. The word “calendar” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “The Secretary may establish the pay” are substituted for “may be compensated at a rate to be fixed by the Secretary” for consistency and to eliminate unnecessary words. The words “of the Committee” after “Members”, “actual”, and “then currently” are omitted as surplus. The reference to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":" is substituted for the reference to "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5332"},"text":"section 5332 of title 5","children":[],"tail":" because of section 529 of the Treasury, Postal Service and General Government Appropriations Act, 1991 ("},{"tag":"ref","attrib":{"href":"/us/pl/101/509"},"text":"Public Law 101–509","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1442"},"text":"104 Stat. 1442","children":[],"tail":"). The words “A member is entitled to expenses under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"” are substituted for 49 App.:1673(c) (2d sentence) and 2003(c) (2d sentence) to eliminate unnecessary words. The words “for any purpose” are omitted as surplus. The words “This subsection does not apply to members regularly employed by the Government” are substituted for “other than Federal employees” for clarity."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc7eccb7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc7eccb8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Accountable Pipeline Safety and Partnership Act of 1996, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304"},"text":"Pub. L. 104–304","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of the PIPES Act of 2016, referred to in subsec. (b)(5), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/183"},"text":"Pub. L. 114–183","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc7eccb9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/183/s6/a"},"text":"Pub. L. 114–183, § 6(a)","children":[],"tail":", substituted “State officials. The Secretary shall consult with national organizations representing State commissioners or utility regulators before making a selection under this subparagraph.” for “State commissioners. The Secretary shall consult with the national organization of State commissions before selecting those 2 individuals.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/183/s6/b"},"text":"Pub. L. 114–183, § 6(b)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (b)(4)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355"},"text":"Pub. L. 107–355","children":[],"tail":" added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s10/a"},"text":"Pub. L. 104–304, § 10(a)","children":[],"tail":", inserted at end “The committees referred to in the preceding sentence shall serve as peer review committees for carrying out this chapter. Peer reviews conducted by the committees shall be treated for purposes of all Federal laws relating to risk assessment and peer review (including laws that take effect after the date of the enactment of the Accountable Pipeline Safety and Partnership Act of 1996) as meeting any peer review requirements of such laws.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s10/b/1"},"text":"Pub. L. 104–304, § 10(b)(1)","children":[],"tail":", (2), inserted before period at end “or risk management principles”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s10/b/3"},"text":"Pub. L. 104–304, § 10(b)(3)","children":[],"tail":", substituted “5” for “4”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s10/b/4"},"text":"Pub. L. 104–304, § 10(b)(4)","children":[],"tail":", substituted “5” for “6”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s10/b/5"},"text":"Pub. L. 104–304, § 10(b)(5)","children":[],"tail":", inserted at end “At least 1 of the individuals selected for each committee under paragraph (3)(B) shall have education, background, or experience in risk assessment and cost-benefit analysis. The Secretary shall consult with the national organizations representing the owners and operators of pipeline facilities before selecting individuals under paragraph (3)(B).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s10/b/6"},"text":"Pub. L. 104–304, § 10(b)(6)","children":[],"tail":", inserted after first sentence “At least 1 of the individuals selected for each committee under paragraph (3)(C) shall have education, background, or experience in risk assessment and cost-benefit analysis.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s10/c/1"},"text":"Pub. L. 104–304, § 10(c)(1)","children":[],"tail":", inserted before semicolon “including the risk assessment information and other analyses supporting each proposed standard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s10/c/2"},"text":"Pub. L. 104–304, § 10(c)(2)","children":[],"tail":", inserted before period at end “including the risk assessment information and other analyses supporting each proposed standard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s10/c/3"},"text":"Pub. L. 104–304, § 10(c)(3)","children":[],"tail":"–(6), inserted “and supporting analyses” after “receiving the proposed standard”, “and submit to the Secretary” after “prepare”, “cost-effectiveness,” after “reasonableness,”, “and include in the report recommended actions” after “practicability of the proposed standard”, and “any recommended actions and” after “including”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s10/d"},"text":"Pub. L. 104–304, § 10(d)","children":[],"tail":", substituted “up to 4 times” for “twice”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s10/e"},"text":"Pub. L. 104–304, § 10(e)","children":[],"tail":", substituted “"},{"tag":"inline","attrib":{},"text":"Expenses","children":[],"tail":"” for “"},{"tag":"inline","attrib":{},"text":"Pay and Expenses","children":[],"tail":"” in heading, struck out “The Secretary may establish the pay for each member of a committee for each day (including travel time) when performing duties of the committee. However, a member may not be paid more than the daily equivalent of the maximum annual rate of basic pay payable under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":".” after heading, and inserted “of a committee under this section” after “A member”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (b)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" struck out “(referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s10344/f"},"text":"section 10344(f) of this title","children":[],"tail":")” after “commissions”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc7eccba-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc7eccbb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01