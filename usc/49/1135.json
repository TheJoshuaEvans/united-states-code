{"tag":"section","attrib":{"id":"idca80644f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135"},"text":null,"children":[{"tag":"num","attrib":{"value":"1135"},"text":"§ 1135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Secretary of Transportation’s responses to safety recommendations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca806450-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When the National Transportation Safety Board submits a recommendation about transportation safety to the Secretary of Transportation, the Secretary shall give to the Board a formal written response to each recommendation not later than 90 days after receiving the recommendation. The response shall indicate whether the Secretary intends—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca806451-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out procedures to adopt the complete recommendation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca806452-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out procedures to adopt a part of the recommendation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca806453-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to refuse to carry out procedures to adopt the recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca806454-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timetable for Completing Procedures and Reasons for Refusals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A response under subsection (a)(1) or (2) of this section shall include a copy of a proposed timetable for completing the procedures. A response under subsection (a)(2) of this section shall detail the reasons for the refusal to carry out procedures on the remainder of the recommendation. A response under subsection (a)(3) of this section shall detail the reasons for the refusal to carry out procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca806455-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Availability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall make a copy of each recommendation and response available to the public—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca806456-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in electronic form at no cost in a publicly accessible database on a website of the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca806457-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the electronic form required in paragraph (1) is not printable, in printed form upon a reasonable request at a reasonable cost.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca806458-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report on Air Carrier Safety Recommendations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca806459-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall submit to Congress and the Board, on an annual basis, a report on the recommendations made by the Board to the Secretary regarding air carrier operations conducted under part 121 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca80645a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations to be covered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall cover—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca80645b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendation for which the Secretary has developed, or intends to develop, procedures to adopt the recommendation or part of the recommendation, but has yet to complete the procedures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca80645c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendation for which the Secretary, in the preceding year, has issued a response under subsection (a)(2) or (a)(3) refusing to carry out all or part of the procedures to adopt the recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca80645d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca80645e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plans to adopt recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each recommendation of the Board described in paragraph (2)(A), the report shall contain—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca80645f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the recommendation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca806460-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the procedures planned for adopting the recommendation or part of the recommendation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca806461-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed date for completing the procedures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca806462-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary has not met a deadline contained in a proposed timeline developed in connection with the recommendation under subsection (b), an explanation for not meeting the deadline.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca806463-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Refusals to adopt recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each recommendation of the Board described in paragraph (2)(B), the report shall contain—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca806464-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the recommendation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca806465-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1135/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the reasons for the refusal to carry out all or part of the procedures to adopt the recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca806466-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/755"},"text":"108 Stat. 755","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/168/s6"},"text":"Pub. L. 108–168, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2034"},"text":"117 Stat. 2034","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/443/s2/b"},"text":"Pub. L. 109–443, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-21"},"text":"Dec. 21, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3298"},"text":"120 Stat. 3298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/216/tII/s202"},"text":"Pub. L. 111–216, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-08-01"},"text":"Aug. 1, 2010","children":[],"tail"