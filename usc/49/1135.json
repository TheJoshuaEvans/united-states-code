ll}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1135(a), (b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1906(a) (less last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633/s307/a"},"text":"Pub. L. 93–633, § 307(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2172"},"text":"88 Stat. 2172","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 3, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/74/s6"},"text":"Pub. L. 97–74, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/1066"},"text":"95 Stat. 1066","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 19, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/372/s3/b"},"text":"Pub. L. 100–372, § 3(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/876"},"text":"102 Stat. 876","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1135(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1906(a) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1135(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1906(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633"},"text":"Pub. L. 93–633","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2156"},"text":"88 Stat. 2156","children":[],"tail":", § 307(b); added "},{"tag":"html:span","attrib":{},"text":"Nov. 3, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/74/s6"},"text":"Pub. L. 97–74, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/1066"},"text":"95 Stat. 1066","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (b), the words “carry out” are substituted for “initiate and conduct” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the word “complete” is substituted for “in full” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca80646a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca80646b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s1214"},"text":"Pub. L. 118–63, § 1214","children":[],"tail":", substituted “public—” and pars. (1) and (2) for “public at reasonable cost.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s1220/a"},"text":"Pub. L. 118–63, § 1220(a)","children":[],"tail":", struck out subsec. (e) which required the Secretary to annually submit regulatory status reports to Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/216/s202/a"},"text":"Pub. L. 111–216, § 202(a)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/249/s6/1"},"text":"Pub. L. 111–249, § 6(1)","children":[],"tail":", inserted “to the Board” after “shall give” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/216/s202/b"},"text":"Pub. L. 111–216, § 202(b)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/111/249/s6/2"},"text":"Pub. L. 111–249, § 6(2)","children":[],"tail":", added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/443"},"text":"Pub. L. 109–443","children":[],"tail":" amended heading and text of par. (3) generally. Prior to amendment, text read as follows: “This subsection shall cease to be in effect after the report required to be filed on "},{"tag":"date","attrib":{"date":"2008-02-01"},"text":"February 1, 2008","children":[],"tail":", is filed.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/168"},"text":"Pub. L. 108–168","children":[],"tail":" amended heading and text of subsec. (d) generally. Prior to amendment, text read as follows: “The Secretary shall submit to Congress on January 1 of each year a report containing each recommendation on transportation safety made by the Board to the Secretary during the prior year and a copy of the Secretary’s response to each recommendation.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca80646c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca80646d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2010 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/111/249/s6"},"text":"Pub. L. 111–249, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"Sept. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2628"},"text":"124 Stat. 2628","children":[],"tail":", provided that the amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/111/249/s6"},"text":"section 6 of Pub. L. 111–249","children":[],"tail":" are effective as of "},{"tag":"date","attrib":{"date":"2010-08-01"},"text":"Aug. 1, 2010","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/111/216"},"text":"Pub. L. 111–216","children":[],"tail":" as enacted."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca80646e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reports on Certain Open Safety Recommendations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/168/s9"},"text":"Pub. L. 108–168, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2035"},"text":"117 Stat. 2035","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/168/s9"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":"], the Secretary of Transportation shall submit a report to Congress and the National Transportation Safety Board containing the regulatory status of each open safety recommendation made by the Board to the Secretary concerning—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 15-passenger van safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" railroad grade crossing safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical certifications for a commercial driver’s license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biennial Updates","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall continue to report on the regulatory status of each such recommendation (and any subsequent recommendation made by the Board to the Secretary concerning a matter described in paragraph (1), (2), or (3) of subsection (a)) at 2-year intervals until—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" final regulatory action has been taken on the recommendation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines, and states in the report, that no action should be taken on that recommendation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the report, if any, required to be submitted in 2008 is submitted.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure To Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Board has not received a report required to be submitted under subsection (a) or (b) within 30 days after the date on which that report is required to be submitted, the Board shall notify the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca80646f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"NTSB Safety Recommendations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s19"},"text":"Pub. L. 107–355, § 19","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3009"},"text":"116 Stat. 3009","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/426/s2/c/3"},"text":"Pub. L. 108–426, § 2(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-11-30"},"text":"Nov. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2424"},"text":"118 Stat. 2424","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/426/s2/c/3"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation, the Administrator of Pipeline and Hazardous Materials Safety Administration, and the Director of the Office of Pipeline Safety shall fully comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s1135"},"text":"section 1135 of title 49","children":[],"tail":", United States Code, to ensure timely responsiveness to National Transportation Safety Board recommendations about pipeline safety."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, Administrator, or Director, respectively, shall make a copy of each recommendation on pipeline safety and response, as described in subsections (a) and (b) of section 1135, title 49, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, Administrator, or Director, respectively, shall submit to Congress by January 1 of each year a report containing each recommendation on pipeline safety made by the Board during the prior year and a copy of the response to each such recommendation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
