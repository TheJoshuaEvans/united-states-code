{"tag":"section","attrib":{"id":"idcbc71591-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719"},"text":null,"children":[{"tag":"num","attrib":{"value":"41719"},"text":"§ 41719.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air service termination notice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbc71592-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier may not terminate interstate air transportation from a nonhub airport included on the Secretary of Transportation’s latest published list of such airports, unless such air carrier has given the Secretary at least 45 days’ notice before such termination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc71593-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of subsection (a) shall not apply when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc71594-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carrier involved is experiencing a sudden or unforeseen financial emergency, including natural weather related emergencies, equipment-related emergencies, and strikes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc71595-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the termination of transportation is made for seasonal purposes only;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc71596-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carrier involved has operated at the affected nonhub airport for 180 days or less;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc71597-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carrier involved provides other transportation by jet from another airport serving the same community as the affected nonhub airport; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc71598-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carrier involved makes alternative arrangements, such as a change of aircraft size, or other types of arrangements with a part 121 or part 135 air carrier, that continues uninterrupted service from the affected nonhub airport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc71599-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waivers for Regional/Commuter Carriers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":", the Secretary shall establish terms and conditions under which regional/commuter carriers can be excluded from the termination notice requirement."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc7159a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc7159b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Part 121 air carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “part 121 air carrier” means an air carrier to which part 121 of title 14, Code of Federal Regulations, applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc7159c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Part 135 air carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “part 135 air carrier” means an air carrier to which part 135 of title 14, Code of Federal Regulations, applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc7159d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regional/commuter carriers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “regional/commuter carrier” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbc7159e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a part 135 air carrier; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc7159f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a part 121 air carrier that provides air transportation exclusively with aircraft having a seating capacity of no more than 70 passengers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc715a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41719/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “termination” means the cessation of all service at an airport by an air carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbc715a1-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/tII/s207/a"},"text":"Pub. L. 103–305, title II, § 207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1587"},"text":"108 Stat. 1587","children":[],"tail":", § 41715; amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/53"},"text":"Pub. L. 103–429, § 6(53)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4385"},"text":"108 Stat. 4385","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/73"},"text":"Pub. L. 104–287, § 5(73)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3396"},"text":"110 Stat. 3396","children":[],"tail":"; renumbered § 41719, "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tII/s231/b/1"},"text":"Pub. L. 106–181, title II, § 231(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/108"},"text":"114 Stat. 108","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tII/s225/b/1"},"text":"Pub. L. 108–176, title II, § 225(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2528"},"text":"117 Stat. 2528","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbc715a2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbc715a3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:41715(a) to conform to the style of title 49.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbc715a4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbc715a5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" redesignated pars. (2) to (5) as (1) to (4), respectively, and struck out former par. (1) which defined “nonhub airport”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s41715"},"text":"section 41715 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" substituted “Secretary of Transportation’s” for “Secretary’s”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" substituted “41731(a)(4)” for “41731(a)(3)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbc715a6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbc715a7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcbc715a8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/tII/s207/d"},"text":"Pub. L. 103–305, title II, § 207(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1588"},"text":"108 Stat. 1588","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/305/tII/s207/d"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s46301"},"text":"section 46301 of this title","children":[],"tail":"] shall take effect on "},{"tag":"date","attrib":{"date":"1995-02-01"},"text":"February 1, 1995","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
