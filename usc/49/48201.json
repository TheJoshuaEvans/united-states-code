{"tag":"section","attrib":{"id":"idcc6e0447-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48201"},"text":null,"children":[{"tag":"num","attrib":{"value":"48201"},"text":"§ 48201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advance appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc6e0448-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiyear Authorizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning with fiscal year 1999, any authorization of appropriations for an activity for which amounts are to be appropriated from the Airport and Airway Trust Fund established under section 9502 of the Internal Revenue Code of 1986 shall provide funds for a period of not less than 3 fiscal years unless the activity for which appropriations are authorized is to be concluded before the end of that period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6e0449-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiyear Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning with fiscal year 1999, amounts appropriated from the Airport and Airway Trust Fund shall be appropriated for periods of 3 fiscal years rather than annually.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc6e044a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264/tII/s277/a"},"text":"Pub. L. 104–264, title II, § 277(a)","children":[]