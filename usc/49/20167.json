{"tag":"section","attrib":{"id":"idcb16b1f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167"},"text":null,"children":[{"tag":"num","attrib":{"value":"20167"},"text":"§ 20167.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports on highway-rail grade crossing safety","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb16b1f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after the date by which States are required to submit State highway-rail grade crossing action plans under section 11401(b) of the Fixing America’s Surface Transportation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s22907"},"text":"49 U.S.C. 22907","children":[],"tail":" note), the Administrator of the Federal Railroad Administration, in consultation with the Administrator of the Federal Highway Administration, shall submit a report to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives that summarizes the State highway-rail grade crossing action plans, including—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb16b1f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an analysis and evaluation of each State railway-highway crossings program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s130"},"text":"section 130 of title 23","children":[],"tail":", including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb16b1f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with section 11401 of the Fixing America’s Surface Transportation Act and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s130/g"},"text":"section 130(g) of title 23","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb16b1fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific strategies identified by each State to improve safety at highway-rail grade crossings, including crossings with multiple accidents or incidents;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b1fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the progress of each State in implementing its State highway-rail grade crossings action plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b1fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of highway-rail grade crossing projects undertaken pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s130"},"text":"section 130 of title 23","children":[],"tail":", including the distribution of such projects by cost range, road system, nature of treatment, and subsequent accident experience at improved locations;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b1fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" which States are not in compliance with their schedule of projects under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s130/d"},"text":"section 130(d) of title 23","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b1fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for future implementation of the railway-highway crossings program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s130"},"text":"section 130 of title 23","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb16b1ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after the submission of the report required under subsection (a), the Administrator of the Federal Railroad Administration, in consultation with the Administrator of the Federal Highway Administration, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb16b200-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the report based on the State annual reports submitted pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s130/g"},"text":"section 130(g) of title 23","children":[],"tail":" and any other information obtained by or available to the Administrator of the Federal Railroad Administration; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b201-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit the updated report to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb16b202-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb16b203-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Highway-rail grade crossing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “highway-rail grade crossing” means a location within a State, other than a location at which 1 or more railroad tracks cross 1 or more railroad tracks at grade, at which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb16b204-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public highway, road, or street, or a private roadway, including associated sidewalks and pathways, crosses 1 or more railroad tracks, either at grade or grade-separated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb16b205-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a pathway explicitly authorized by a public authority or a railroad carrier that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb16b206-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is dedicated for the use of nonvehicular traffic, including pedestrians, bicyclists, and others;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb16b207-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not associated with a public highway, road, or street, or a private roadway; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb16b208-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crosses 1 or more railroad tracks, either at grade or grade-separated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b209-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20167/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means a State of the United States or the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb16b20a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22403/b/1"},"text":"Pub. L. 117–58, div. B, title II, § 22403(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/735"},"text":"135 Stat. 735","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb16b20b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb16b20c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb16b20d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 11401 of the Fixing America’s Surface Transportation Act, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11401"},"text":"section 11401 of title XI of div. A of Pub. L. 114–94","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s22907"},"text":"section 22907 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb16b20e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 20167, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tIV/s418/a"},"text":"Pub. L. 110–432, div. A, title IV, § 418(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4891"},"text":"122 Stat. 4891","children":[],"tail":", related to railroad safety infrastructure improvement grants, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11301/c/1"},"text":"Pub. L. 114–94, div. A, title XI, § 11301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1648"},"text":"129 Stat. 1648","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
