{"tag":"section","attrib":{"id":"idcaf2d695-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701"},"text":null,"children":[{"tag":"num","attrib":{"value":"13701"},"text":"§ 13701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for reasonable rates, classifications, through routes, rules, and practices for certain transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf2d696-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reasonableness.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d697-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain household goods transportation; joint rates involving water transportation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A rate, classification, rule, or practice related to transportation or service provided by a carrier subject to jurisdiction under chapter 135 for transportation or service involving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf2d698-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a movement of household goods,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d699-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rate for a movement by or with a water carrier in noncontiguous domestic trade, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d69a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rates, rules, and classifications made collectively by motor carriers under agreements approved pursuant to section 13703,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"must be reasonable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d69b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Through routes and divisions of joint rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Through routes and divisions of joint rates for such transportation or service must be reasonable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d69c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prescription by Board for Violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Board finds it necessary to stop or prevent a violation of subsection (a), the Board shall prescribe the rate, classification, rule, practice, through route, or division of joint rates to be applied for such transportation or service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d69d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing of Complaint","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A complaint that a rate, classification, rule, or practice in noncontiguous domestic trade violates subsection (a) may be filed with the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d69e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Zone of Reasonableness.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d69f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, a rate or division of a motor carrier for service in noncontiguous domestic trade or water carrier for port-to-port service in that trade is reasonable if the aggregate of increases and decreases in any such rate or division is not more than 7.5 percent above, or more than 10 percent below, the rate or division in effect 1 year before the effective date of the proposed rate or division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d6a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustments to the zone","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The percentage specified in paragraph (1) shall be increased or decreased, as the case may be, by the percentage change in the Producers Price Index, as published by the Department of Labor, that has occurred during the most recent 1-year period before the date the rate or division in question first took effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d6a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determinations after complaint","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall determine whether any rate or division of a carrier or service in noncontiguous domestic trade which is not within the range described in paragraph (1) is reasonable if a complaint is filed under subsection (c) or section 13702(b)(6).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d6a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13701/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reparations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon a finding of violation of subsection (a), the Board shall award reparations to the complaining shipper or shippers in an amount equal to all sums assessed and collected that exceed the determined reasonable rate, division, rate structure, or tariff. Upon complaint from any governmental agency or authority and upon a finding or violation of subsection (a), the Board shall make such orders as are just and shall require the carrier to return, to the extent practicable, to shippers all amounts plus interest, which the Board finds to have been assessed and collected in violation of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf2d6a3-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/867"},"text":"109 Stat. 867","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf546a4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf546a5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf546a6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 10701, 10704, and 10705 of this title prior to the general amendment of this subtitle by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaf546a7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcaf546a8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
