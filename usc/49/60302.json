{"tag":"section","attrib":{"id":"idcc8842ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60302"},"text":null,"children":[{"tag":"num","attrib":{"value":"60302"},"text":"§ 60302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User fees for underground natural gas storage facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc8842cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fee shall be imposed on an entity operating an underground natural gas storage facility subject to section 60141. Any such fee imposed shall be collected before the end of the fiscal year to which it applies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8842cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Means of Collection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall prescribe procedures to collect fees under this section. The Secretary may use a department, agency, or instrumentality of the United States Government or of a State or local government to collect the fee and may reimburse the department, agency, or instrumentality a reasonable amount for its services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8842cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Fees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8842ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established an Underground Natural Gas Storage Facility Safety Account in the Pipeline Safety Fund established in the Treasury of the United States under section 60301.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8842cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of fees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A fee collected under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8842d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60302/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be deposited in the Underground Natural Gas Storage Facility Safety Account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8842d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60302/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the fee is related to an underground natural gas storage facility subject to section 60141, the amount of the fee may be used only for an activity related to underground natural gas storage facility safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8842d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60302/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No fee may be collected under this section, except to the extent that the expenditure of such fee to pay the costs of an activity related to underground natural gas storage facility safety for which such fee is imposed is provided in advance in an appropriations Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc8842d3-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/183/s12/c"},"text":"Pub. L. 114–183, § 12(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/523"},"text":"130 Stat. 523","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
