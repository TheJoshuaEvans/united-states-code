{"tag":"section","attrib":{"id":"idcaf546fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13704"},"text":null,"children":[{"tag":"num","attrib":{"value":"13704"},"text":"§ 13704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Household goods rates—estimates; guarantees of service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf546ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13704/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf54700-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13704/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the provisions of paragraph (2) of this subsection, a motor carrier providing transportation of household goods subject to jurisdiction under subchapter I of chapter 135 may establish a rate for the transportation of household goods which is based on the carrier’s written, binding estimate of charges for providing such transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf54701-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13704/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonpreferential; nonpredatory","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any rate established under this subsection must be available on a nonpreferential basis to shippers and must not result in charges to shippers which are predatory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf54702-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13704/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rates for Guaranteed Service.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf54703-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13704/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the provisions of paragraph (2) of this subsection, a motor carrier providing transportation of household goods subject to jurisdiction under subchapter I of chapter 135 may establish rates for the transportation of household goods which guarantee that the carrier will pick up and deliver such household goods at the times specified in the contract for such services and provide a penalty or per diem payment in the event the carrier fails to pick up or deliver such household goods at the specified time. The charges, if any, for such guarantee and penalty provision may vary to reflect one or more options available to meet a particular shipper’s needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf54704-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13704/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of secretary to require nonguaranteed service rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before a carrier may establish a rate for any service under paragraph (1) of this subsection, the Secretary may require such carrier to have in effect and keep in effect, during any period such rate is in effect under paragraph (1), a rate for such service which does not guarantee the pick up and delivery of household goods at the times specified in the contract for such services and which does not provide a penalty or per diem payment in the event the carrier fails to pick up or deliver household goods at the specified time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf54705-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/872"},"text":"109 Stat. 872","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf54706-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf54707-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf54708-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10735"},"text":"section 10735 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaf54709-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcaf5470a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
