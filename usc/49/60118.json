81, § 10(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/725"},"text":"82 Stat. 725","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/129"},"text":"Pub. L. 96–129","children":[],"tail":", §[§] 105(b), 109(h)(4), 152(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/93/994"},"text":"93 Stat. 994","children":[],"tail":", 996, 999."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2006(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/129"},"text":"Pub. L. 96–129","children":[],"tail":", §§ 203(h), 207(a), (b)(1), "},{"tag":"html:a","attrib":{"href":"/us/stat/93/1005"},"text":"93 Stat. 1005","children":[],"tail":", 1009."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60118(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1677(b)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/481"},"text":"Pub. L. 90–481","children":[],"tail":"