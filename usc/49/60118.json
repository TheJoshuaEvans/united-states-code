{"tag":"section","attrib":{"id":"idcc811639-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118"},"text":null,"children":[{"tag":"num","attrib":{"value":"60118"},"text":"§ 60118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compliance and waivers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc81163a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person owning or operating a pipeline facility shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc81163b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with applicable safety standards prescribed under this chapter, except as provided in this section or in section 60126;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc81163c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepare and carry out a plan for inspection and maintenance required under section 60108(a) and (b) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc81163d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow access to or copying of records, make reports and provide information, and allow entry or inspection required under subsections (a) through (e) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s60117"},"text":"section 60117 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc81163e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a risk analysis, and adopt and implement an integrity management program, for pipeline facilities as required under section 60109(c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc81163f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance Orders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may issue orders directing compliance with this chapter, an order under section 60126, or a regulation prescribed under this chapter. An order shall state clearly the action a person must take to comply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc811640-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waivers by Secretary.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc811641-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonemergency waivers.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc811642-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On application of an owner or operator of a pipeline facility, the Secretary by order may waive compliance with any part of an applicable standard prescribed under this chapter with respect to such facility on terms the Secretary considers appropriate if the Secretary determines that the waiver is not inconsistent with pipeline safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc811643-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may act on a waiver under this paragraph only after notice and an opportunity for a hearing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc811644-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emergency waivers.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc811645-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary by order may waive compliance with any part of an applicable standard prescribed under this chapter on terms the Secretary considers appropriate without prior notice and comment if the Secretary determines that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc811646-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is in the public interest to grant the waiver;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc811647-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver is not inconsistent with pipeline safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc811648-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver is necessary to address an actual or impending emergency involving pipeline transportation, including an emergency caused by a natural or manmade disaster.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc811649-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of waiver","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A waiver under this paragraph may be issued for a period of not more than 60 days and may be renewed upon application to the Secretary only after notice and an opportunity for a hearing on the waiver. The Secretary shall immediately revoke the waiver if continuation of the waiver would not be consistent with the goals and objectives of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc81164a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statement of reasons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall state in an order issued under this subsection the reasons for granting the waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc81164b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waivers by State Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s60105"},"text":"section 60105 of this title","children":[],"tail":" or an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s60106"},"text":"section 60106 of this title","children":[],"tail":" is in effect, the State authority may waive compliance with a safety standard to which the certification or agreement applies in the same way and to the same extent the Secretary may waive compliance under subsection (c) of this section. However, the authority must give the Secretary written notice of the waiver at least 60 days before its effective date. If the Secretary makes a written objection before the effective date of the waiver, the waiver is stayed. After notifying the authority of the objection, the Secretary shall provide a prompt opportunity for a hearing. The Secretary shall make the final decision on granting the waiver."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc81164c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operator Assistance in Investigations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc81164d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance and access","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary or the National Transportation Safety Board investigates an accident or incident involving a pipeline facility, the operator of the facility shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc81164e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make available to the Secretary or the Board all records and information that in any way pertain to the accident or incident, including integrity management plans and test results; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc81164f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" afford all reasonable assistance in the investigation of the accident or incident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc811650-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operator assistance in investigations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc811651-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may impose a civil penalty under section 60122 on a person who obstructs or prevents the Secretary from carrying out inspections or investigations under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc811652-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obstructs defined.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idcc811653-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this paragraph, the term “obstructs” includes actions that were known, or reasonably should have been known, to prevent, hinder, or impede an investigation without good cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc811654-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Good cause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In clause (i), the term “good cause” may include actions such as restricting access to facilities that are not secure or safe for nonpipeline personnel or visitors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc811655-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60118/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Statutory Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to infringe upon the constitutional rights of an operator or its employees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc811656-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1322"},"text":"108 Stat. 1322","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/304/s13"},"text":"Pub. L. 104–304, § 13","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3802"},"text":"110 Stat. 3802","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/355"},"text":"Pub. L. 107–355","children":[],"tail":", §§ 10(a), (c), 14(c), "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2995"},"text":"116 Stat. 2995","children":[],"tail":", 2996, 3005; "},{"tag":"ref","attrib":{"href":"/us/pl/109/468/s10"},"text":"Pub. L. 109–468, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3494"},"text":"120 Stat. 3494","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/90/s2/b"},"text":"Pub. L. 112–90, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1905"},"text":"125 Stat. 1905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dR/tI/s108/b/3"},"text":"Pub. L. 116–260, div. R, title I, § 108(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2223"},"text":"134 Stat. 2223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc811657-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc811658-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc811659-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null