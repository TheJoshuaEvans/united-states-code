{"tag":"section","attrib":{"id":"idcae95fc6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11121"},"text":null,"children":[{"tag":"num","attrib":{"value":"11121"},"text":"§ 11121.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criteria","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcae95fc7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11121/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcae95fc8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11121/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A rail carrier providing transportation subject to the jurisdiction of the Board under this part shall furnish safe and adequate car service and establish, observe, and enforce reasonable rules and practices on car service. The Board may require a rail carrier to provide facilities and equipment that are reasonably necessary to furnish safe and adequate car service if the Board decides that the rail carrier has materially failed to furnish that service. The Board may begin a proceeding under this paragraph when an interested person files an application with it. The Board may act only after a hearing on the record and an affirmative finding, based on the evidence presented, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcae95fc9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11121/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the facilities or equipment will not materially and adversely affect the ability of the rail carrier to provide safe and adequate transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcae95fca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11121/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount spent for the facilities or equipment, including a return equal to the rail carrier’s current cost of capital, will be recovered; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcae95fcb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11121/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing the facilities or equipment will not impair the ability of the rail carrier to attract adequate capital.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae95fcc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11121/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may require a rail carrier to file its car service rules with the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae95fcd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11121/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may designate and appoint agents and agencies to make and carry out its directions related to car service and matters under sections 11123 and 11124(a)(1) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae95fce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11121/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall consult, as it considers necessary, with the National Grain Car Council on matters within the charter of that body.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcae95fcf-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/832"},"text":"109 Stat. 832","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcae95fd0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcae95fd1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcae95fd2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11121, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1421"},"text":"92 Stat. 1421","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/258/s1/11"},"text":"Pub. L. 96–258, § 1(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-06-03"},"text":"June 3, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/426"},"text":"94 Stat. 426","children":[],"tail":", related to criteria of rail carriers to furnish safe and adequate car service, prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcae95fd3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcae95fd4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
