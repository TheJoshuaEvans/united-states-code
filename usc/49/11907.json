{"tag":"section","attrib":{"id":"idcaf08c0f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11907"},"text":null,"children":[{"tag":"num","attrib":{"value":"11907"},"text":"§ 11907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Punishment of corporation for violations committed by certain individuals","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An act or omission that would be a violation of this part if committed by a director, officer, receiver, trustee, lessee, agent, or employee of a rail carrier providing transportation or service subject to the jurisdiction of the Board under this part that is a corporation is also a violation of this part by that corporation. The penalties of this chapter apply to that violation. When acting in the scope of their employment, the actions and omissions of individuals acting for or employed by that rail carrier are considered to be the actions and omissions of that rail carrier as well as that individual.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcaf08c10-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/852"},"text":"109 Stat. 852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf08c11-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf08c12-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","i