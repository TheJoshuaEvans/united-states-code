{"tag":"section","attrib":{"id":"idcbc715de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41723"},"text":null,"children":[{"tag":"num","attrib":{"value":"41723"},"text":"§ 41723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Notice concerning aircraft assembly","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation shall require, beginning after the last day of the 18-month period following the date of enactment of this section, an air carrier using an aircraft to provide scheduled passenger air transportation to display a notice, on an information placard available to each passenger on the aircraft, that informs the passengers of the nation in which the aircraft was finally assembled.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcbc715df-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/tVIII/s810/a"},"text":"Pub. L. 108–176, title VIII, § 810(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2590"},"text":"117 Stat. 2590","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbc715e0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbc715e1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbc715e2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in text, is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbc715e3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcbc715e4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
