{"tag":"section","attrib":{"id":"idcab4e28e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315"},"text":null,"children":[{"tag":"num","attrib":{"value":"5315"},"text":"§ 5315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private sector participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcab4e28f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the interest of fulfilling the general purposes of this chapter under section 5301(b), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcab4e290-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" better coordinate public and private sector-provided public transportation services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab4e291-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote more effective utilization of private sector expertise, financing, and operational capacity to deliver costly and complex new fixed guideway capital projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab4e292-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote transparency and public understanding of public-private partnerships affecting public transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcab4e293-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions to Promote Better Coordination Between Public and Private Sector Providers of Public Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcab4e294-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide technical assistance to recipients of Federal transit grant assistance, at the request of a recipient, on practices and methods to best utilize private providers of public transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab4e295-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" educate recipients of Federal transit grant assistance on laws and regulations under this chapter that impact private providers of public transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcab4e296-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions to Provide Technical Assistance for Alternative Project Delivery Methods","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon request by a sponsor of a new fixed guideway capital project, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcab4e297-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify best practices for public-private partnerships models in the United States and in other countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab4e298-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop standard public-private partnership transaction model contracts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab4e299-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perform financial assessments that include the calculation of public and private benefits of a proposed public-private partnership transaction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcab4e29a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall be construed to alter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcab4e29b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibilities, requirements, or priorities for assistance provided under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab4e29c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5315/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of section 5306(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcab4e29d-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/813"},"text":"108 Stat. 813","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/13"},"text":"Pub. L. 104–287, § 5(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3390"},"text":"110 Stat. 3390","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIII/s3017/a"},"text":"Pub. L. 105–178, title III, § 3017(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/361"},"text":"112 Stat. 361","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIX/s9009"},"text":"Pub. L. 105–206, title IX, § 9009","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"1998-07-22"},"text":"July 22, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/857"},"text":"112 S