{"tag":"section","attrib":{"id":"idcc8cfd30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302"},"text":null,"children":[{"tag":"num","attrib":{"value":"80302"},"text":"§ 80302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc8cfd31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, “contraband” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8cfd32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a narcotic drug (as defined in section 102 of the Comprehensive Drug Abuse Prevention and Control Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":")), including marihuana (as defined in section 102 of that Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":")), that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8cfd33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is possessed with intent to sell or offer for sale in violation of the laws and regulations of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8cfd34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is acquired, possessed, sold, transferred, or offered for sale in violation of those laws;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8cfd35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is acquired by theft, robbery, or burglary and transported—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc8cfd36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the District of Columbia or a territory or possession of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8cfd37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from a place in a State, the District of Columbia, or a territory or possession of the United States, to a place in another State, the District of Columbia, or a territory or possession; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8cfd38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not bear tax-paid internal revenue stamps required by those laws or regulations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a firearm involved in a violation of chapter 53 of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s5801"},"text":"26 U.S.C. 5801","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a forged, altered, or counterfeit—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8cfd3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coin or an obligation or other security of the United States Government (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s8"},"text":"section 8 of title 18","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8cfd3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coin, obligation, or other security of the government of a foreign country;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" material or equipment used, or intended to be used, in making a coin, obligation, or other security referred to in clause (3) of this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cigarette involved in a violation of chapter 114 of title 18 or a regulation prescribed under chapter 114; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8cfd40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a counterfeit label for a phonorecord, copy of a computer program or computer program documentation or packaging, or copy of a motion picture or other audiovisual work (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2318"},"text":"section 2318 of title 18","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8cfd41-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a phonorecord or copy in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2319"},"text":"section 2319 of title 18","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8cfd42-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fixation of a sound recording or music video of a live musical performance in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2319A"},"text":"section 2319A of title 18","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8cfd43-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any good bearing a counterfeit mark (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2320"},"text":"section 2320 of title 18","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8cfd44-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8cfd45-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transport contraband in an aircraft, vehicle, or vessel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd46-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conceal or possess contraband on an aircraft, vehicle, or vessel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd47-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80302/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag"