"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/316/s1/a"},"text":"Pub. L. 92–316, § 1(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/227"},"text":"86 Stat. 227","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"May 26, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/25/s2"},"text":"Pub. L. 94–25, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/89/90"},"text":"89 Stat. 90","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 18, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/216/s101"},"text":"Pub. L. 97–216, § 101","children":[],"tail":" (par. under heading “Grants to the National Railroad Passenger Corporation”), "},{"tag":"html:a","attrib":{"href":"/us/stat/96/187"},"text":"96 Stat. 187","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s18/c"},"text":"Pub. L. 100–342, § 18(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/636"},"text":"102 Stat. 636","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24303(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:543(d) (2d, 3d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24303(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:543(d) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “of directors of Amtrak” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “rates of”, “president and other”, and “at a level” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “direct or indirect” are omitted as surplus. The word “another” is substituted for “any” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb2e7f1f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb2e7f20-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134"},"text":"Pub. L. 105–134","children":[],"tail":" inserted at end “The preceding sentence shall not apply for any fiscal year for which no Federal assistance is provided to Amtrak.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
