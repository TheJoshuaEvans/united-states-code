{"tag":"section","attrib":{"id":"idcb3cd73d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909"},"text":null,"children":[{"tag":"num","attrib":{"value":"24909"},"text":"§ 24909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb3cd73e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3cd73f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not more than $2,313,000,000 may be appropriated to the Secretary of Transportation to achieve the goals of section 24902(a)(1) ","children":[{"tag":"ref","attrib":{"idref":"fn002094"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002094"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title. From this amount, the following amounts shall be expended by Amtrak:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb3cd740-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least $27,000,000 for equipment modification and replacement that a State or a local or regional transportation authority must bear because of the electrification conversion system of the Northeast Corridor under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3cd741-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" $30,000,000—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb3cd742-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the main line track between the Northeast Corridor main line and Atlantic City, New Jersey, to ensure that the track, consistent with a plan New Jersey developed in consultation with Amtrak to provide rail passenger transportation between the Northeast Corridor main line and Atlantic City, New Jersey, would be of sufficient quality to allow safe rail passenger transportation at a minimum of 79 miles an hour not later than ","children":[{"tag":"date","attrib":{"date":"1985-09-30"},"text":"September 30, 1985","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3cd743-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote rail passenger use of the track.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3cd744-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" necessary amounts to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb3cd745-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909/a/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"