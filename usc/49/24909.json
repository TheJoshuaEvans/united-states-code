},"text":" rehabilitate bridges between the District of Columbia and New York, New York (including Hi line);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3cd74b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909/a/1/C/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a maintenance of way equipment repair facility between the District of Columbia and New York, New York, and build maintenance of way bases at Philadelphia, Pennsylvania, Sunnyside, New York, and Cedar Hill, Connecticut;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3cd74c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909/a/1/C/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stabilize the roadbed between the District of Columbia and New York, New York;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3cd74d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909/a/1/C/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automate the Bush River Drawbridge at milepost 72.14;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3cd74e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909/a/1/C/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the New York Service Facility to develop rolling stock repair capability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3cd74f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24909/a/1/C/xi"},"text":null,"children":[{"tag":"num","attrib":{"value":"xi"},"text":"(xi)","children":[],"ta