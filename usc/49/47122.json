{"tag":"section","attrib":{"id":"idcc588068-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47122"},"text":null,"children":[{"tag":"num","attrib":{"value":"47122"},"text":"§ 47122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc588069-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may take action the Secretary considers necessary to carry out this subchapter, including conducting investigations and public hearings, prescribing regulations and procedures, and issuing orders.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc58806a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conducting Investigations and Public Hearings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In conducting an investigation or public hearing under this subchapter, the Secretary has the same authority the Secretary has under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s46104"},"text":"section 46104 of this title","children":[],"tail":". An action of the Secretary in exercising that authority is governed by the procedures specified in section 46104 and shall be enforced as provided in section 46104."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc58806b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":