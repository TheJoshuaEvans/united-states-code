{"tag":"section","attrib":{"id":"idca82d5a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1137"},"text":null,"children":[{"tag":"num","attrib":{"value":"1137"},"text":"§ 1137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of the Inspector General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca82d5a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1137/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspector General of the Department of Transportation, in accordance with the mission of the Inspector General to prevent and detect fraud and abuse, shall have authority to review only the financial management, property management, and business operations of the National Transportation Safety Board, including internal accounting and administrative control systems, to determine compliance with applicable Federal laws, rules, and regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca82d5a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1137/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Inspector General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca82d5a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1137/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep the Chairman of the Board and Congress fully and currently informed about problems relating to administration of the internal accounting and administrative control systems of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d5a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1137/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue findings and recommendations for actions to address such problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d5a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1137/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report periodically to Congress on any progress made in implementing actions to address such problems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca82d5a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1137/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this section, the Inspector General may exercise authorities granted to the Inspector General under subsections (a) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s406"},"text":"section 406 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca82d5a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1137/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorizations of Appropriations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca82d5a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1137/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Transportation for use by the Inspector General of the Department of Transportation such sums as may be necessary to cover expenses associated with activities pursuant to the authority exercised under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d5a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1137/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursable agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the absence of an appropriation under this subsection for an expense referred to in paragraph (1), the Inspector General and the Board shall have a reimbursable agreement to cover such expense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca82d5aa-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/424/s12/a"},"text":"Pub. L. 106–424, § 12(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1887"},"text":"114 Stat. 1887","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/443/s4"},"text":"Pub. L. 109–443, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-21"},"text":"Dec. 21, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3299"},"text":"120 Stat. 3299","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/96"},"text":"Pub. L. 117–286, § 4(b)(96)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4353"},"text":"136 Stat. 4353","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca82d5ab-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca82d5ac-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca82d5ad-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “subsections (a) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s406"},"text":"section 406 of title 5","children":[],"tail":".” for “subsections (a) and (b) of section 6 of the Inspector General Act of 1978 (5 U.S.C. App.).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/443"},"text":"Pub. L. 109–443","children":[],"tail":" amended heading and text of subsec. (d) generally. Prior to amendment, text read as follows: “The Inspector General shall be reimbursed by the Board for the costs associated with carrying out activities under this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
