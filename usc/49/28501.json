{"tag":"section","attrib":{"id":"idcb419243-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28501"},"text":null,"children":[{"tag":"num","attrib":{"value":"28501"},"text":"§ 28501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb419244-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Board” means the Surface Transportation Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb419245-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “capital work” means maintenance, restoration, reconstruction, capacity enhancement, or rehabilitation work on trackage that would be treated, in accordance with generally accepted accounting principles, as a capital item rather than an expense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb419246-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “commuter rail passenger transportation” has the meaning given that term in section 24102;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb419247-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “public transportation authority” means a local governmental authority (as defined in section 5302) established to provide, or make a contract providing for, commuter rail passenger transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb419248-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “rail carrier” means a person, other than a governmental authority, providing common carrier railroad transportation for compensation subject to the jurisdiction of the Board under chapter 105;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb419249-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “segregated fixed guideway facility” means a fixed guideway facility constructed within the railroad right-of-way of a rail carrier but physically separate from trackage, including relocated trackage, within the right-of-way used by a rail carrier for freight transportation purposes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb41924a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28501/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “trackage” means a railroad line of a rail carrier, including a spur, industrial, team, switching, side, yard, or station track, and a facility of a rail carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb41924b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tIV/s401/a"},"text":"Pub. L. 110–432, div. B, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4955"},"text":"122 Stat. 4955","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dC/s30001/b/4"},"text":"Pub. L. 117–58, div. C, § 30001(b)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/890"},"text":"135 Stat. 890","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb41924c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb41924d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb41924e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" substituted “section 5302” for “section 5302(a)(6)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
