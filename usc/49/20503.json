{"tag":"section","attrib":{"id":"idcb18fbdd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20503"},"text":null,"children":[{"tag":"num","attrib":{"value":"20503"},"text":"§ 20503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amending regulations and changing requirements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may amend a regulation or change a requirement applicable to a railroad carrier for installing, maintaining, inspecting, or repairing a signal system under this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb18fbde-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20503/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the carrier files with the Secretary a request for the amendment or change and the Secretary approves the request; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fbdf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20503/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the Secretary’s own initiative for good cause shown.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb18fbe0-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/884"},"text":"108 Stat. 884","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb18fbe1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb18fbe2-47c4-11f1-9671-b5c725212f70"},"