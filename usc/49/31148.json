{"tag":"section","attrib":{"id":"idcb6c72de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31148"},"text":null,"children":[{"tag":"num","attrib":{"value":"31148"},"text":"§ 31148.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certified motor carrier safety auditors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb6c72df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31148/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of the enactment of this section, the Secretary of Transportation shall complete a rulemaking to improve training and provide for the certification of motor carrier safety auditors, including private contractors, to conduct safety inspection audits and reviews described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6c72e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31148/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certified Inspection Audit Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after completion of the rulemaking required by subsection (a), any safety inspection audit or review required by, or based on the authority of, this chapter or chapter 5, 313, or 315 of this title and performed after ","children":[{"tag":"date","attrib":{"date":"2002-12-31"},"text":"December 31, 2002","children":[],"tail":", shall be conducted by—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6ee2e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31148/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor carrier safety auditor certified under subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6ee2e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31148/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Federal or State employee who, on the date of the enactment of this section, was qualified to perform such an audit or review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6ee2e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31148/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary determines that subsection (b) cannot be implemented within the 1-year period established by that subsection and notifies the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives of the determination and the reasons therefor, the Secretary may extend the deadline for compliance with subsection (b) by not more than 12 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6ee2e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31148/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application With Other Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not delegate the Secretary’s authority to private contractors to issue ratings or operating authority, and nothing in this section authorizes any private contractor to issue ratings or operating authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6ee2e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31148/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight Responsibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall have authority over any motor carrier safety auditor certified under subsection (a), including the authority to decertify a motor carrier safety auditor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb6ee2e6-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/tII/s211/a"},"text":"Pub. L. 106–159, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1765"},"text":"113 Stat. 1765","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb6ee2e7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb6ee2e8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb6ee2e9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsecs. (a) and (b)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159"},"text":"Pub. L. 106–159","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb6ee2ea-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb6ee2eb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Inspector Standards","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV/s5205"},"text":"Pub. L. 114–94, div. A, title V, § 5205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1537"},"text":"129 Stat. 1537","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tV/s5205"},"text":"“Not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"], the Administrator of the Federal Motor Carrier Safety Administration shall revise the regulations under part 385 of title 49, Code of Federal Regulations, as necessary, to incorporate by reference the certification standards for roadside inspectors issued by the Commercial Vehicle Safety Alliance.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
