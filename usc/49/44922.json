{"tag":"section","attrib":{"id":"idcc2d9fa7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44922"},"text":null,"children":[{"tag":"num","attrib":{"value":"44922"},"text":"§ 44922.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Deputization of State and local law enforcement officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc2d9fa8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44922/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deputization Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Transportation Security Administration may deputize a State or local law enforcement officer to carry out Federal airport security duties under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2d9fa9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44922/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fulfillment of Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State or local law enforcement officer who is deputized under this section shall be treated as a Federal law enforcement officer for purposes of meeting the requirements of this chapter and other provisions of law to provide Federal law enforcement officers to carry out Federal airport security duties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2d9faa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44922/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To deputize a State or local law enforcement officer under this section, the Administrator of the Transportation Security Administration shall enter into a voluntary agreement with the appropriate State or local law enforcement agency that employs the State or local law enforcement officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2d9fab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44922/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc2d9fac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44922/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Transportation Security Administration shall reimburse a State or local law enforcement agency for all reasonable, allowable, and allocable costs incurred by the State or local law enforcement agency with respect to a law enforcement officer deputized under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2d9fad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44922/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated such sums as may be necessary to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2d9fae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44922/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Tort Claims Act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State or local law enforcement officer who is deputized under this section shall be treated as an “employee of the Government” for purposes of sections 1346(b), 2401(b), and chapter 171 of title 28, United States Code, while carrying out Federal airport security duties within the course and scope of the officer’s employment, subject to Federal supervision and control, and in accordance with the terms of such deputization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2d9faf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44922/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stationing of Officers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Transportation Security Administration may allow law enforcement personnel to be stationed other than at the airport security screening location if that would be preferable for law enforcement purposes and if such personnel would still be able to provide prompt responsiveness to problems occurring at the screening location.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc2d9fb0-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7/dI/tIII/s351/a"},"text":"Pub. L. 108–7, div. I, title III, § 351(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/419"},"text":"117 Stat. 419","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/d/18"},"text":"Pub. L. 115–254, div. K, title I, § 1991(d)(18)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3636"},"text":"132 Stat. 3636","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc2d9fb1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"amendments","id":"idcc2d9fb2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/18/D"},"text":"Pub. L. 115–254, § 1991(d)(18)(D)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration” for “Under Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/18/A"},"text":"Pub. L. 115–254, § 1991(d)(18)(A)","children":[],"tail":", substituted “Deputization” for “Deputation” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/18/B"},"text":"Pub. L. 115–254, § 1991(d)(18)(B)","children":[],"tail":", in heading, substituted “Deputization” for “Deputation” and, in text, substituted “Administrator of the Transportation Security Administration” for “Under Secretary of Transportation for Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/18/C"},"text":"Pub. L. 115–254, § 1991(d)(18)(C)","children":[],"tail":", substituted “deputization” for “deputation”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
