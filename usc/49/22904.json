{"tag":"section","attrib":{"id":"idcb2509f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22904"},"text":null,"children":[{"tag":"num","attrib":{"value":"22904"},"text":"§ 22904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of capital grants to finance first-dollar liability of grant project","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding the requirements of section 22902 of this chapter, the Secretary of Transportation may approve the use of a capital assistance grant under this chapter to fund self-insured retention of risk for the first tier of liability insurance coverage for rail passenger service associated with the grant, but the coverage may not exceed $20,000,000 per occurrence or $20,000,000 in aggregate per year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb2509f1-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tIII/s301/a"},"text":"Pub. L. 110–432, div. B, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4942"},"text":"122 Stat. 4942","children":[],"tail":", § 24404; renumbered § 22904 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/420/s7/a/1"},"text":"Pub. L. 115–420, § 7(a)(1)","children":[],"tail":", (b)(2)(B), "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5445"},"text":"132 Stat. 5445","children":[],"tail":", 5446.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb2509f2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb2509f3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb2509f4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/420"},"text":"Pub. L. 115–420","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s24404"},"text":"section 24404 of this title","children":[],"tail":" as this section and substituted “section 22902” for “section 24402”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
