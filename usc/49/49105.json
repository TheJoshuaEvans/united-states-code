{"tag":"section","attrib":{"id":"idcc6e04b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49105"},"text":null,"children":[{"tag":"num","attrib":{"value":"49105"},"text":"§ 49105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital improvements, construction, and rehabilitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc6e04b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"It is the sense of Congress that the Metropolitan Washington Airports Authority—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc6e04b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should pursue the improvement, construction, and rehabilitation of the facilities at Washington Dulles International Airport and Ronald Reagan Washington National Airport simultaneously; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e04b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, should cause the improvement, construction, and rehabilitation proposed by the Secretary of Transportation to be completed at Washington Dulles International Airport and Ronald Reagan Washington National Airport within 5 years after ","children":[{"tag":"date","attrib":{"date":"1988-03-30"},"text":"March 30, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6e04ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary’s Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall assist the 3 airports serving the District of Columbia metropolitan area in planning for operational and capital improvements at those airports and shall accelerate consideration of applications for United States Government financial assistance by whichever of the 3 airports is most in need of increasing airside capacity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc6e04bb-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/26"},"text":"Pub. L. 105–102, § 2(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2210"},"text":"111 Stat. 2210","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/154/s2/a/1/D"},"text":"Pub. L. 105–154, § 2(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-06"},"text":"Feb. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3"},"text":"112 Stat. 3","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc6e04bc-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc6e04bd-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc6e04be-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"childr