{"tag":"section","attrib":{"id":"idcbda28cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44302a"},"text":null,"children":[{"tag":"num","attrib":{"value":"44302a"},"text":"§ 44302a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary insurance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbda28cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44302a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide insurance or reinsurance under this section to or for an air carrier for 1 coverage period not to exceed 90 days. Except as otherwise provided in this section, such insurance or reinsurance shall be subject to the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbda28cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44302a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restrictions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A policy for insurance or reinsurance issued under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbda28ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44302a/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may not be issued unless the insurance carrier of the air carrier has unilaterally terminated the air carrier’s war risk liability coverage pursuant to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbda28cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44302a/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice under the policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbda28d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44302a/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an endorsement to the policy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbdc98d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44302a/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an automatic termination provision in the policy or any endorsement thereto; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbdc98d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44302a/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may cover hull, comprehensive, and third party liability risks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbdc98d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44302a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Premium","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A premium for insurance or reinsurance provided under this section shall be calculated based on a prorated amount equivalent to the premium that was in effect under the terminated insurance carrier policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbdc98d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44302a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A policy for insurance or reinsurance provided under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbdc98d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44302a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be exempt from the requirements of section 44302(c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbdc98d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44302a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may provide coverage to the extent allowed under section 44303, as determined by the Secretary, notwithstanding any determination by the President in subsection (a)(1) of such section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbdc98d7-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dQ/s103/a"},"text":"Pub. L. 117–328, div. Q, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5252"},"text":"136 Stat. 5252","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
