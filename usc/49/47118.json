{"tag":"section","attrib":{"id":"idcc5635fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118"},"text":null,"children":[{"tag":"num","attrib":{"value":"47118"},"text":"§ 47118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designating current and former military airports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc5635ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall designate current or former military airports for which grants may be made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47117/e/1/B"},"text":"section 47117(e)(1)(B) of this title","children":[],"tail":". The maximum number of airports bearing such designation at any time is 15. The Secretary may only so designate an airport (other than an airport so designated before "},{"tag":"date","attrib":{"date":"1994-08-24"},"text":"August 24, 1994","children":[],"tail":") if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc563600-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the airport is a former military installation closed or realigned under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc563601-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"section 2687 of title 10","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc563602-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 201 of the Defense Authorization Amendments and Base Closure and Realignment Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"10 U.S.C. 2687","children":[],"tail":" note); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc563603-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 2905 of the Defense Base Closure and Realignment Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"10 U.S.C. 2687","children":[],"tail":" note);"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc563604-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the airport is a military installation with both military and civil aircraft operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc563605-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the airport is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc563606-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a former military installation that, at any time after ","children":[{"tag":"date","attrib":{"date":"1965-12-31"},"text":"December 31, 1965","children":[],"tail":", was owned and operated by the Department of Defense; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc563607-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonhub primary airport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc563608-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Survey","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":", the Secretary shall complete a survey of current and former military airports to identify which airports have the greatest potential to improve the capacity of the national air transportation system. The survey shall identify the capital development needs of those airports to make them part of the system and which of those qualify for grants under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s47104"},"text":"section 47104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc563609-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall consider only current or former military airports for designation under this section if a grant under section 47117(e)(1)(B) would—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc56360a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce delays at an airport with more than 20,000 hours of annual delays in commercial passenger aircraft takeoffs and landings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc56360b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhance airport and air traffic control system capacity in a metropolitan area or reduce current and projected flight delays; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc56360c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" preserve or enhance minimum airfield infrastructure facilities at former military airports to support emergency diversionary operations for transoceanic flights in locations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc56360d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within United States jurisdiction or control; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc56360e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" where there is a demonstrable lack of diversionary airports within the distance or flight-time required by regulations governing transoceanic flights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc56360f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47117/e/1/B"},"text":"section 47117(e)(1)(B) of this title","children":[],"tail":" may be made for an airport designated under subsection (a) of this section for the 5 fiscal years following the designation, and for subsequent periods, each not to exceed 5 fiscal years, if the Secretary determines that the airport satisfies the designation criteria under subsection (a) at the beginning of each such subsequent period."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc563610-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terminal Building Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"From amounts the Secretary distributes to an airport under section 47115, $10,000,000 for each of fiscal years 2004 and 2005, and $7,000,000 for each fiscal year thereafter, is available to the sponsor of a current or former military airport the Secretary designates under this section to construct, improve, or repair a terminal building facility, including terminal gates used for revenue passengers getting on or off aircraft. A gate constructed, improved, or repaired under this subsection—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc563611-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be leased for more than 10 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc563612-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not subject to majority in interest clauses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc563613-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Parking Lots, Fuel Farms, Utilities, Hangars, and Air Cargo Terminals.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc563614-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From amounts the Secretary distributes to an airport under section 47115, $10,000,000 for each of fiscal years 2004 and 2005, and $7,000,000 for each fiscal year thereafter, is available to the sponsor of a current or former military airport the Secretary designates under this section to construct, improve, or repair airport surface parking lots, fuel farms, utilities, and hangars and air cargo terminals of an area that is 50,000 square feet or less.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc563615-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon approval of the Secretary, the sponsor of a current or former military airport the Secretary designates under this section may use an amount apportioned under section 47114, or made available under section 47115 or 47117(e)(1)(B), to the airport for reimbursement of costs incurred by the airport in fiscal years 2003 and 2004 for construction, improvement, or repair described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc563616-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of General Aviation Airports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this section, 3 of the airports bearing designations under subsection (a) may be general aviation airports that were former military installations closed or realigned under a section referred to in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc563617-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety-Critical Airports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of this chapter, a grant under section 47117(e)(1)(B) may be made for a federally owned airport designated under subsection (a) if the grant is for a project that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc563618-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to preserve or enhance minimum airfield infrastructure facilities described in subsection (c)(3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc563619-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47118/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary to meet the minimum safety and emergency operational requirements established under part 139 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc56361a-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1273"},"text":"108 Stat. 1273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/305/tI/s116/b"},"text":"Pub. L. 103–305, title I, § 116(b)","children":[],"tail":"–(d), "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1579"},"text":"108 Stat. 1579","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/tI/s124/a"},"text":"Pub. L. 104–264, title I, § 124(a)","children":[],"tail":"–(c), "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3219"},"text":"110 Stat. 3219","children":[],"tail":", 3220; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/83"},"text":"Pub. L. 104–287, § 5(83)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3397"},"text":"110 Stat. 3397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tI/s130"},"text":"Pub. L. 106–181, title I, § 130","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/78"},"text":"114 Stat. 78","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tI/s153"},"text":"Pub. L. 108–176, title I, § 153","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2507"},"text":"117 Stat. 2507","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tI/s146"},"text":"Pub. L. 112–95, title I, § 146","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/30"},"text":"126 Stat. 30","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tI/s137"},"text":"Pub. L. 115–254, div. B, title I, § 137","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3210"},"text":"132 Stat. 3210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc56361b-47c4-11f1-9671-b5c725212f70"},"text":"\n",