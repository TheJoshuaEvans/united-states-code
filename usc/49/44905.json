{"tag":"section","attrib":{"id":"idcc2673a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905"},"text":null,"children":[{"tag":"num","attrib":{"value":"44905"},"text":"§ 44905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information about threats to civil aviation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc2673a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Providing Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under guidelines the Administrator of the Transportation Security Administration prescribes, an air carrier, airport operator, ticket agent, or individual employed by an air carrier, airport operator, or ticket agent, receiving information (except a communication directed by the United States Government) about a threat to civil aviation shall provide the information promptly to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2673a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Flight Cancellation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a decision is made that a particular threat cannot be addressed in a way adequate to ensure, to the extent feasible, the safety of passengers and crew of a particular flight or series of flights, the Administrator of the Transportation Security Administration shall cancel the flight or series of flights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2673aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines on Public Notice","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc2673ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President shall develop guidelines for ensuring that public notice is provided in appropriate cases about threats to civil aviation. The guidelines shall identify officials responsible for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc2673ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deciding, on a case-by-case basis, if public notice of a threat is in the best interest of the United States and the traveling public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that public notice is provided in a timely and effective way, including the use of a toll-free telephone number; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" canceling the departure of a flight or series of flights under subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2673af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The guidelines shall provide for consideration of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc2673b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specificity of the threat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the credibility of intelligence information related to the threat;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability to counter the threat effectively;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of intelligence information sources and methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cancellation, by an air carrier or the Administrator of the Transportation Security Administration, of a flight or series of flights instead of public notice;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of passengers and crew to take steps to reduce the risk to their safety after receiving public notice of a threat; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors the Administrator of the Transportation Security Administration considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2673b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines on Notice to Crews","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Transportation Security Administration shall develop guidelines for ensuring that notice in appropriate cases of threats to the security of an air carrier flight is provided to the flight crew and cabin crew of that flight.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2673b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Notice to Selective Travelers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notice of a threat to civil aviation may be provided to selective potential travelers only if the threat applies only to those travelers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2673b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restricting Access to Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In cooperation with the departments, agencies, and instrumentalities of the Government that collect, receive, and analyze intelligence information related to aviation security, the Administrator of the Transportation Security Administration shall develop procedures to minimize the number of individuals who have access to information about threats. However, a restriction on access to that information may be imposed only if the restriction does not diminish the ability of the Government to carry out its duties and powers related to aviation security effectively, including providing notice to the public and flight and cabin crews under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2673ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44905/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The guidelines developed under this section shall be distributed for use by appropriate officials of the Department of Transportation, the Department of State, the Department of Justice, and air carriers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc2673bb-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1207"},"text":"108 Stat. 1207","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s101/f/7"},"text":"Pub. L. 107–71, title I, § 101(f)(7)","children":[],"tail":", (9), "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/603"},"text":"115 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/d/5"},"text":"Pub. L. 115–254, div. K, title I, § 1991(d)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3632"},"text":"132 Stat. 3632","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc2673bc-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc2673bd-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc2673be-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44905(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358d(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 321; added "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/604/s109/a"},"text":"Pub. L. 101–604, § 109(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3078"},"text":"104 Stat. 3078","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44905(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358d(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44905(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358d(c)(1), (d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44905(c)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358d(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44905(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358d(c)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44905(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358d(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44905(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358d(h).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44905(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358d(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “employed by an air carrier, airport operator, or ticket agent” are substituted for “employed by such an entity” for clarity. The words “or a designee of the Secretary” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (c)(1), before clause (A), and (d), the words “Not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1)(B), the words “when considered appropriate” are omitted as unnecessary because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “selective potential travelers” are substituted for “only selective potential travelers” to eliminate an unnecessary word.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “departments, agencies, and instrumentalities of the Government” are substituted for “agencies” for clarity and consistency in the revised title and with other titles of the United States Code. The words “However, a restriction on access to that information may be imposed only if the restriction does not diminish” are substituted for “Any restriction adopted pursuant to this subsection shall not diminish” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc2673bf-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc2673c0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/5/A"},"text":"Pub. L. 115–254, § 1991(d)(5)(A)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration” for “Secretary of Transportation” and “Administrator.” for “Secretary.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/5/B"},"text":"Pub. L. 115–254, § 1991(d)(5)(B)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration” for “Under Secretary of Transportation for Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c)(2)(E), (G), (d), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/5/C"},"text":"Pub. L. 115–254, § 1991(d)(5)(C)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration” for “Under Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s101/f/7"},"text":"Pub. L. 107–71, § 101(f)(7)","children":[],"tail":", (9), substituted “Under Secretary of Transportation for Security” for “Administrator of the Federal Aviation Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c)(2)(E), (G), (d), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s101/f/7"},"text":"Pub. L. 107–71, § 101(f)(7)","children":[],"tail":", substituted “Under Secretary” for “Administrator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
