{"tag":"section","attrib":{"id":"idcb05e900-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14906"},"text":null,"children":[{"tag":"num","attrib":{"value":"14906"},"text":"§ 14906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evasion of regulation of carriers and brokers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person, or an officer, employee, or agent of that person, that by any means tries to evade regulation provided under this part for carriers or brokers is liable to the United States for a civil penalty of at least $2,000 for the first violation and at least $5,000 for a subsequent violation, and may be subject to criminal penalties.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb05e901-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/916"},"text":"109 Stat. 916","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32505/b"},"text":"Pub. L. 112–141, div. C, title II, § 32505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/804"},"text":"126 Stat. 804","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb05e902-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb05e903-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"no