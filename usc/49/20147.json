{"tag":"section","attrib":{"id":"idcb11f673-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20147"},"text":null,"children":[{"tag":"num","attrib":{"value":"20147"},"text":"§ 20147.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Warning of civil liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation shall encourage railroad carriers to warn the public about potential liability for violation of regulations related to vandalism of railroad signs, devices, and equipment and to trespassing on railroad property.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb11f674-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/440/tII/s211/a"},"text":"Pub. L. 103–440, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4622"},"text":"108 Stat. 4622","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
