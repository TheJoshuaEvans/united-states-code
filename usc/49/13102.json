{"tag":"section","attrib":{"id":"idcaf08c48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102"},"text":null,"children":[{"tag":"num","attrib":{"value":"13102"},"text":"§ 13102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part, the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf08c49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Board” means the Surface Transportation Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Broker","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “broker” means a person, other than a motor carrier or an employee or agent of a motor carrier, that as a principal or agent sells, offers for sale, negotiates for, or holds itself out by solicitation, advertisement, or otherwise as selling, providing, or arranging for, transportation by motor carrier for compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c4b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “carrier” means a motor carrier, a water carrier, and a freight forwarder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contract carriage","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “contract carriage” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for transportation provided before ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":", service provided pursuant to a permit issued under section 10923, as in effect on "},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for transportation provided after ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":", service provided under an agreement entered into under section 14101(b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Control","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “control”, when referring to a relationship between persons, includes actual control, legal control, and the power to exercise control, through or by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" common directors, officers, stockholders, a voting trust, or a holding or investment company, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c52-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign motor carrier","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign motor carrier” means a person (including a motor carrier of property but excluding a motor private carrier)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c53-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcaf08c54-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is domiciled in a contiguous foreign country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf08c55-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is owned or controlled by persons of a contiguous foreign country; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c56-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a person that is not a motor carrier of property, that provides interstate transportation of property by motor vehicle under an agreement or contract entered into with a motor carrier of property (other than a motor private carrier or a motor carrier of property described in subparagraph (A)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c57-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign motor private carrier","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “foreign motor private carrier” means a person (including a motor private carrier but excluding a motor carrier of property)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c58-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcaf08c59-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/7/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is domiciled in a contiguous foreign country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf08c5a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/7/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is owned or controlled by persons of a contiguous foreign country; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c5b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a person that is not a motor private carrier, that provides interstate transportation of property by motor vehicle under an agreement or contract entered into with a person (other than a motor carrier of property or a motor private carrier described in subparagraph (A)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c5c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Freight forwarder","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “freight forwarder” means a person holding itself out to the general public (other than as a pipeline, rail, motor, or water carrier) to provide transportation of property for compensation and in the ordinary course of its business—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c5d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assembles and consolidates, or provides for assembling and consolidating, shipments and performs or provides for break-bulk and distribution operations of the shipments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assumes responsibility for the transportation from the place of receipt to the place of destination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c5f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses for any part of the transportation a carrier subject to jurisdiction under this subtitle.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The term does not include a person using transportation of an air carrier subject to part A of subtitle VII.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c60-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Highway","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “highway” means a road, highway, street, and way in a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c61-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Household goods","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “household goods”, as used in connection with transportation, means personal effects and property used or to be used in a dwelling, when a part of the equipment or supply of such dwelling, and similar property if the transportation of such effects or property is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c62-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arranged and paid for by the householder, except such term does not include property moving from a factory or store, other than property that the householder has purchased with the intent to use in his or her dwelling and is transported at the request of, and the transportation charges are paid to the carrier by, the householder; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c63-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arranged and paid for by another party.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c64-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Household goods freight forwarder","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “household goods freight forwarder” means a freight forwarder of one or more of the following items: household goods, unaccompanied baggage, or used automobiles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c65-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Household goods motor carrier.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c66-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “household goods motor carrier” means a motor carrier that, in the ordinary course of its business of providing transportation of household goods, offers some or all of the following additional services:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcaf08c67-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/12/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Binding and nonbinding estimates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf08c68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/12/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inventorying.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf08c69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/12/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Protective packing and unpacking of individual items at personal residences.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf08c6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/12/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Loading and unloading at personal residences.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c6b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term includes any person that is considered to be a household goods motor carrier under regulations, determinations, and decisions of the Federal Motor Carrier Safety Administration that are in effect on the date of enactment of the Household Goods Mover Oversight Enforcement and Reform Act of 2005.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/12/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limited service exclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term does not include a motor carrier when the motor carrier provides transportation of household goods in containers or trailers that are entirely loaded and unloaded by an individual (other than an employee or agent of the motor carrier).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individual shipper","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “individual shipper” means any person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the shipper, consignor, or consignee of a household goods shipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is identified as the shipper, consignor, or consignee on the face of the bill of lading;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" owns the goods being transported; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c71-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/13/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pays his or her own tariff transportation charges.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motor carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “motor carrier” means a person providing motor vehicle transportation for compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c73-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motor private carrier","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “motor private carrier” means a person, other than a motor carrier, transporting property by motor vehicle when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/15/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation is as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s13501"},"text":"section 13501 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c75-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/15/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person is the owner, lessee, or bailee of the property being transported; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c76-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/15/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property is being transported for sale, lease, rent, or bailment or to further a commercial enterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c77-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motor vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “motor vehicle” means a vehicle, machine, tractor, trailer, or semitrailer propelled or drawn by mechanical power and used on a highway in transportation, or a combination determined by the Secretary, but does not include a vehicle, locomotive, or car operated only on a rail, or a trolley bus operated by electric power from a fixed overhead wire, and providing local passenger transportation similar to street-railway service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Noncontiguous domestic trade","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “noncontiguous domestic trade” means transportation subject to jurisdiction under chapter 135 involving traffic originating in or destined to Alaska, Hawaii, or a territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Person","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “person”, in addition to its meaning under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":", includes a trustee, receiver, assignee, or personal representative of a person."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pre-arranged ground transportation service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “pre-arranged ground transportation service” means transportation for a passenger (or a group of passengers) that is arranged in advance (or is operated on a regular route or between specified points) and is provided in a motor vehicle with a seating capacity not exceeding 15 passengers (including the driver).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means the 50 States of the United States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Taxicab service","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “taxicab service” means passenger transportation in a motor vehicle having a capacity of not more than 8 passengers (including the driver), not operated on a regular route or between specified places, and that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/22/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed as a taxicab by a State or a local jurisdiction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c7f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/22/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is offered by a person that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcaf08c80-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/22/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides local transportation for a fare determined (except with respect to transportation to or from airports) primarily on the basis of the distance traveled; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf08c81-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/22/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not primarily provide transportation to or from airports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “transportation” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/23/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor vehicle, vessel, warehouse, wharf, pier, dock, yard, property, facility, instrumentality, or equipment of any kind related to the movement of passengers or property, or both, regardless of ownership or an agreement concerning use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/23/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services related to that movement, including arranging for, receipt, delivery, elevation, transfer in transit, refrigeration, icing, ventilation, storage, handling, packing, unpacking, and interchange of passengers and property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/24"},"text":null,"children":[{"tag":"num","attrib":{"value":"24"},"text":"(24)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"United states","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “United States” means the States of the United States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/25"},"text":null,"children":[{"tag":"num","attrib":{"value":"25"},"text":"(25)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vessel","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “vessel” means a watercraft or other artificial contrivance that is used, is capable of being used, or is intended to be used, as a means of transportation by water.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/26"},"text":null,"children":[{"tag":"num","attrib":{"value":"26"},"text":"(26)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Water carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “water carrier” means a person providing water transportation for compensation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13102/27"},"text":null,"children":[{"tag":"num","attrib":{"value":"27"},"text":"(27)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Over-the-road bus","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “over-the-road bus” means a bus characterized by an elevated passenger deck located over a baggage compartment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf08c89-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/854"},"text":"109 Stat. 854","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/27"},"text":"Pub. L. 104–287, § 5(27)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3390"},"text":"110 Stat. 3390","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/159/tII/s209/a"},"text":"Pub. L. 106–159, title II, § 209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1764"},"text":"113 Stat. 1764","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/298/s3/a"},"text":"Pub. L. 107–298, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-26"},"text":"Nov. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2343"},"text":"116 Stat. 2343","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV"},"text":"Pub. L. 109–59, title IV","children":[],"tail":", §§ 4142(a), 4202(b), "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1747"},"text":"119 Stat. 1747","children":[],"tail":", 1751; "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/tIII/s305/c"},"text":"Pub. L. 110–244, title III, § 305(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1620"},"text":"122 Stat. 1620","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/291/s3"},"text":"Pub. L. 110–291, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2915"},"text":"122 Stat. 2915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf08c8a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcaf08c8b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcaf08c8c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/27/A"},"text":"Pub. L. 104–287, § 5(27)(A)","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:13102(4)(A) by setting out the effective date of the ICC Termination Act of 1995 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Public Law 104–88","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/803"},"text":"109 Stat. 803","children":[],"tail":") and the day before that date."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcaf08c8d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/27/B"},"text":"Pub. L. 104–287, § 5(27)(B)","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:13102(4)(B) for clarity and consistency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf08c8e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcaf08c8f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 10923, referred to in par. (4)(A), was omitted in the general amendment of this subtitle by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/804"},"text":"109 Stat. 804","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of the Household Goods Mover Oversight Enforcement and Reform Act of 2005, referred to in par. (12)(B), is the date of enactment of subtitle B of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf08c90-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10102"},"text":"section 10102 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcaf08c91-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Pars. (6)(B), (7)(B), (14), (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" substituted “motor vehicle” for “commercial motor vehicle (as defined in section 31132)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (27). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/291"},"text":"Pub. L. 110–291","children":[],"tail":" added par. (27)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Pars. (6)(B), (7)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4142/a"},"text":"Pub. L. 109–59, § 4142(a)","children":[],"tail":", substituted “commercial motor vehicle (as defined in section 31132)” for “motor vehicle”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4202/b"},"text":"Pub. L. 109–59, § 4202(b)","children":[],"tail":", added par. (12). Former par. (12) redesignated (14)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4142/a"},"text":"Pub. L. 109–59, § 4142(a)","children":[],"tail":", substituted “commercial motor vehicle (as defined in section 31132)” for “motor vehicle”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4202/b"},"text":"Pub. L. 109–59, § 4202(b)","children":[],"tail":", added par. (13). Former par. (13) redesignated (15)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4142/a"},"text":"Pub. L. 109–59, § 4142(a)","children":[],"tail":", substituted “commercial motor vehicle (as defined in section 31132)” for “motor vehicle” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (14) to (26). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4202/b"},"text":"Pub. L. 109–59, § 4202(b)","children":[],"tail":", redesignated pars. (12) to (24) as (14) to (26), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Pars. (17) to (24). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/298"},"text":"Pub. L. 107–298","children":[],"tail":" added pars. (17) and (20) and redesignated former pars. (17), (18), (19), (20), (21), and (22) as pars. (18), (19), (21), (22), (23), and (24), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Par. (10)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159"},"text":"Pub. L. 106–159","children":[],"tail":" substituted “, except such term does not include property moving from a factory or store, other than property that the householder has purchased with the intent to use in his or her dwelling and is transported at the request of, and the transportation charges are paid to the carrier by, the householder;” for “, including transportation of property from a factory or store when the property is purchased by the householder with intent to use in his or her dwelling,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/27/A"},"text":"Pub. L. 104–287, § 5(27)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"” for “the effective date of this section” and “"},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","child