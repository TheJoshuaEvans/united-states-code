{"tag":"section","attrib":{"id":"idcad19247-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5901"},"text":null,"children":[{"tag":"num","attrib":{"value":"5901"},"text":"§ 5901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad19248-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise provided in this chapter, the definitions in sections 10102 and 13102 of this title apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad19249-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “beneficial owner” means a person not having title to property but having ownership rights in the property, including a trustee of property in transit from an overseas place of origin that is domiciled or doing business in the United States, except that a carrier, agent of a carrier, broker, customs broker, freight forwarder, warehouser, or terminal operator is not a beneficial owner only because of providing or arranging for any part of the intermodal transportation of property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad1924a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “carrier” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad1924b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5901/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor carrier, water carrier, and rail carrier providing transportation of property in commerce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad1924c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5901/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an ocean common carrier (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s40102"},"text":"section 40102 of title 46","children":[],"tail":") providing transportation of property in commerce."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad1924d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “container” has the meaning given the term “freight container” by the International Standards Organization in Series 1, Freight Containers, 3d Edition (reference number ISO668–1979(E)), including successive revisions, and similar containers that are used in providing transportation in interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dc3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5901/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “first carrier” means the first carrier transporting a loaded container or trailer in intermodal transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dc3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5901/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “gross cargo weight” means the weight of the cargo, packaging materials (including ice), pallets, and dunnage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dc40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5901/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “intermodal transportation” means the successive transportation of a loaded container or trailer from its place of origin to its place of destination by more than one mode of transportation in interstate or foreign commerce, whether under a single bill of lading or under separate bills of lading.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dc41-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5901/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “trailer” means a nonpower, property-carrying, trailing unit that is designed for use in combination with a truck tractor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad3dc42-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/859"},"text":"108 Stat. 859","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/291/tII/s203"},"text":"Pub. L. 104–291, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3453"},"text":"110 Stat. 3453","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s17/h/2"},"text":"Pub. L. 109–304, § 17(h)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1709"},"text":"120 Stat. 1709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad3dc43-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcad3dc44-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcad3dc45-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5901(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:501(a)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5901(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:501(a)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5901(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:501(a)(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5901(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:501(a)(6).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5901(5)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:501(a)(7).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5901(6)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:501(a)(8).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5901(7)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:501(a)(9).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This chapter restates 49:508 and the relevant definitions in 49:501 because the subject matter more appropriately belongs in subtitle III of title 49. The text of 49:501(a)(1) is restated to incorporate the definitions in 49:10102. The terms defined in 49:501(a)(2) and (3) are not used in this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the word “including” is substituted for “For purposes of this paragraph . . . shall be treated as a beneficial owner of such property” for consistency and to eliminate unnecessary words. The words “is not a beneficial owner only because of providing or arranging for any part of the intermodal transportation of property” are substituted for “providing or arranging for any portion of intermodal transportation of property shall in no case be a beneficial owner of such property, for purposes of this paragraph, solely by reason of providing or arranging for such transportation” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3)(A), the words “(as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10102"},"text":"section 10102 of this title","children":[],"tail":")” are omitted as unnecessary because of clause (1) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (7), the words “property-carrying” are substituted for “cargo carrying” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad3dc46-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcad3dc47-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Par. (3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t46/s40102"},"text":"section 40102 of title 46","children":[],"tail":"” for “section 3 of the Shipping Act of 1984 (46 App. U.S.C. 1702)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/291/s203/1"},"text":"Pub. L. 104–291, § 203(1)","children":[],"tail":", added par. (1) and struck out former par. (1) which read as follows: “the definitions in "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s10102"},"text":"section 10102 of this title","children":[],"tail":" apply.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6) to (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/291/s203/2"},"text":"Pub. L. 104–291, § 203(2)","children":[],"tail":", (3), added par. (6) and redesignated former pars. (6) and (7) as (7) and (8), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
