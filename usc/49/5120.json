{"tag":"section","attrib":{"id":"idca9377ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5120"},"text":null,"children":[{"tag":"num","attrib":{"value":"5120"},"text":"§ 5120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" International uniformity of standards and requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca9377ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5120/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation in International Forums","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to guidance and direction from the Secretary of State, the Secretary of Transportation shall participate in international forums that establish or recommend mandatory standards and requirements for transporting hazardous material in international commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9377ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5120/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may consult with interested authorities to ensure that, to the extent practicable, regulations the Secretary prescribes under sections 5103(b), 5104, 5110, and 5112 of this title are consistent with standards and requirements related to transporting hazardous material that international authorities adopt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca9377af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5120/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Differences With International Standards and Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca9377b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5120/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not require the Secretary to prescribe a standard or requirement identical to a standard or requirement adopted by an international authority if the Secretary decides the standard or requirement is unnecessary or unsafe; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca9377b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5120/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not prohibit the Secretary from prescribing a safety standard or requirement more stringent than a standard or requirement adopted by an international authority if the Secretary decides the standard or requirement is necessary in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca9377b2-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/778"},"text":"108 Stat. 778","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII"},"text":"Pub. L. 109–59, title VII","children":[],"tail":", §§ 7117, 7126, "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1902"},"text":"119 Stat. 1902","children":[],"tail":", 1909.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca9377b3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca9377b4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca9377b5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{