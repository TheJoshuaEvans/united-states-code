{"tag":"section","attrib":{"id":"idcc47de74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105"},"text":null,"children":[{"tag":"num","attrib":{"value":"47105"},"text":"§ 47105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project grant applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc47de75-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission and Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc47de76-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An application for a project grant under this subchapter may be submitted to the Secretary of Transportation by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc47de77-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a sponsor; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc47de78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a State, as the only sponsor, for an airport development project benefitting 1 or more airports in the State or for airport planning for projects for 1 or more airports in the State if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc47de79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sponsor of each airport gives written consent that the State be the applicant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc47de7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary is satisfied there is administrative merit and aeronautical benefit in the State being the sponsor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc47de7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an acceptable agreement exists that ensures that the State will comply with appropriate grant conditions and other assurances the Secretary requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc47de7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before deciding to undertake an airport development project at an airport under this subchapter, a sponsor shall consult with the airport users that will be affected by the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc47de7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not authorize a public agency that is subject to the laws of a State to apply for a project grant in violation of a law of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc47de7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents and Form","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An application for a project grant under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc47de7f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall describe the project proposed to be undertaken;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc47de80-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may propose a project only for a public-use airport included in the current national plan of integrated airport systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc47de81-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may propose airport development only if the development complies with standards the Secretary prescribes or approves, including standards for site location, airport layout, site preparation, paving, lighting, and safety of approaches; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc47de82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in the form and contain other information the Secretary prescribes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc47de83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Standards for Airport Development.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc47de84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may approve standards (except standards for safety of approaches) that a State prescribes for airport development at nonprimary public-use airports in the State. On approval under this subsection, a State’s standards apply to the nonprimary public-use airports in the State instead of the comparable standards prescribed by the Secretary under subsection (b)(3) of this section. The Secretary, or the State with the approval of the Secretary, may revise standards approved under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc47de85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pavement standards.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc47de86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the request of a State, the Secretary shall, not later than 30 days after the date of the request, provide technical assistance to the State in developing standards, acceptable to the Secretary under subparagraph (B), for pavement on nonprimary public-use airports in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc47de87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc47de88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue to provide technical assistance under subparagraph (A) until the standards are approved under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc47de89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clearly indicate to the State the standards that are acceptable to the Secretary, considering, at a minimum, local conditions and locally available materials.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc47de8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification of Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require a sponsor to certify that the sponsor will comply with this subchapter in carrying out the project. The Secretary may rescind the acceptance of a certification at any time. This subsection does not affect an obligation or responsibility of the Secretary under another law of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc47de8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preventive Maintenance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":", the Secretary may approve an application under this subchapter for the replacement or reconstruction of pavement at an airport only if the sponsor has provided such assurances or certifications as the Secretary may determine appropriate that such airport has implemented an effective airport pavement maintenance-management program. The Secretary may require such reports on pavement condition and pavement management programs as the Secretary determines may be useful."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc47de8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47105/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The sponsor of an airport for which an amount is apportioned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47114/c"},"text":"section 47114(c) of this title","children":[],"tail":" shall notify the Secretary of the fiscal year in which the sponsor intends to submit a project grant application for the apportioned amount. The notification shall be given by the time and contain the information the Secretary prescribes."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc47de8d-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1253"},"text":"108 Stat. 1253","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/305/tI"},"text":"Pub. L. 103–305, title I","children":[],"tail":", §§ 106, 107(a), "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1572"},"text":"108 Stat. 1572","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tI/s183"},"text":"Pub. L. 115–254, div. B, title I, § 183","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3233"},"text":"132 Stat. 3233","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc47de8e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc47de8f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"