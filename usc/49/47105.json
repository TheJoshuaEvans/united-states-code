ed to authority to submit applications).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":", §§ 509(a)(1), (c), (d), 511(c), "},{"tag":"html:a","attrib":{"href":"/us/stat/96/682"},"text":"96 Stat. 682","children":[],"tail":", 685, 688."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"47105(a) (1)(B)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2208(a)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/324"},"text":"96 Stat. 324","children":[],"tail":", § 509(a)(3); added "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/223/s108"},"text":"Pub. L. 100–223, § 108","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1498"},"text":"101 Stat. 1498","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47105(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2210(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47105(a)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2208(a)(1) (3d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47105(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2208(a)(1) (1st sentence related to form and contents, 2d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47105(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2208(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47105(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2208(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47105(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2208(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/248/s509/e"},"text":"Pub. L. 97–248, § 509(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/685"},"text":"96 Stat. 685","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/223/s106/b/3/B"},"text":"Pub. L. 100–223, § 106(b)(3)(B)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1498"},"text":"101 Stat. 1498","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the words “Subject to the provisions of this subsection” are omitted as surplus. The words “for one or more projects” are omitted as surplus because of the definition of “project grant” in section 47102 of the revised title. Clause (A) is substituted for “(A) any public agency, or two or more public agencies acting jointly, or (B) any sponsor of a public-use airport, or two or more such sponsors, acting jointly” because of the definition of “sponsor” in section 47102 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the word “Before” is substituted for “In” as the more appropriate word. The words “at an airport” are substituted for “at which such project is proposed” to eliminate unnecessary words. The words “airport users that will be affected by the project” are substituted for “affected parties” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(3) is substituted for 49 App.:2208(a)(1) (3d sentence) to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “shall describe” are substituted for “setting forth” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the word “project” is substituted for “airport development or airport planning” because of the definition of “project” in section 47102 of the revised title. The words “prepared pursuant to section 2203 of the Appendix” are eliminated as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “from time to time” are eliminated as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “in connection with any project” are omitted as surplus. The words “that the sponsor will comply with this subchapter in carrying out the project” are substituted for “that such sponsor will comply with all of the statutory and administrative requirements imposed on such sponsor under this chapter in connection with such project” to eliminate unnecessary words. The words “or discharge” are omitted as included in “affect”. The words “including, but not limited to, the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.), "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s303"},"text":"section 303 of title 49","children":[],"tail":", title VI of the Civil Rights Act of 1964 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000b"},"text":"42 U.S.C. 2000b","children":[],"tail":") ["},{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.], title VIII of the Act of "},{"tag":"date","attrib":{"date":"1968-04-11"},"text":"April 11, 1968","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s3601"},"text":"42 U.S.C. 3601","children":[],"tail":" et seq.), and the Uniform Relocation Assistance and Real Property Acquisition Policies Act of 1970 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4601"},"text":"42 U.S.C. 4601","children":[],"tail":" et seq.)” are omitted as included in “another law of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “of an airport for which” are substituted for “to which” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc47de91-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc47de92-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/s106"},"text":"Pub. L. 103–305, § 106","children":[],"tail":", in introductory provisions, substituted “1 or more airports” for “at least 2 airports” in two places and struck out “similar” before “projects”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/s107/a"},"text":"Pub. L. 103–305, § 107(a)","children":[],"tail":", added subsec. (e) and redesignated former subsec. (e) as (f)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
