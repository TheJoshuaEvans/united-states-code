{"tag":"section","attrib":{"id":"idcc077a0d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735"},"text":null,"children":[{"tag":"num","attrib":{"value":"44735"},"text":"§ 44735.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on disclosure of safety information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc077a0e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided by subsection (c), a report, data, or other information described in subsection (b) shall not be disclosed to the public by the Administrator of the Federal Aviation Administration pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/3/B"},"text":"section 552(b)(3)(B) of title 5","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc077a0f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the report, data, or other information is submitted to the Federal Aviation Administration voluntarily and is not required to be submitted to the Administrator under any other provision of law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077a10-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the report, data, or other information is submitted to the Federal Aviation Administration pursuant to section 102(e) of the Aircraft Certification, Safety, and Accountability Act; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077a11-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the report, data, or other information is submitted for any purpose relating to the development and implementation of a safety management system, including a system required by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc077a12-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The limitation established by subsection (a) shall apply to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc077a13-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reports, data, or other information developed under the Aviation Safety Action Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077a14-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reports, data, or other information produced or collected under the Flight Operational Quality Assurance Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077a15-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reports, data, or other information developed under the Line Operations Safety Audit Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077a16-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reports, data, or other information produced or collected for purposes of developing and implementing a safety management system acceptable to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077a17-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reports, analyses, and directed studies, based in whole or in part on reports, data, or other information described in paragraphs (1) through (4), including those prepared under the Aviation Safety Information Analysis and Sharing Program (or any successor program).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc077a18-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception for De-identified Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc077a19-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitation established by subsection (a) shall not apply to a report, data, or other information if the information contained in the report, data, or other information has been de-identified.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077a1a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"De-identified defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “de-identified” means the process by which all information that is likely to establish the identity of the specific persons or entities submitting reports, data, or other information is removed from the reports, data, or other information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc077a1b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Agencies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc077a1c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitation established under subsection (a) shall apply to the head of any other Federal agency who receives reports, data, or other information described in such subsection from the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077a1d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44735/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall not be construed to limit the accident or incident investigation authority of the National Transportation Safety Board under chapter 11, including the requirement to not disclose voluntarily provided safety-related information under section 1114.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc077a1e-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIII/s310/a"},"text":"Pub. L. 112–95, title III, § 310(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/64"},"text":"126 Stat. 64","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dV/tI/s102/g"},"text":"Pub. L. 116–260, div. V, title I, § 102(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2311"},"text":"134 Stat. 2311","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIII/s305"},"text":"Pub. L. 118–63, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1071"},"text":"138 Stat. 1071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc077a1f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc077a20-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc077a21-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 102(e) of the Aircraft Certification, Safety, and Accountability Act, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/tI/s102/e"},"text":"section 102(e) of title I of Pub. L. 116–260","children":[],"tail":", div. V, "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2310"},"text":"134 Stat. 2310","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44701"},"text":"section 44701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc077a22-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s305/1"},"text":"Pub. L. 118–63, § 305(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s305/2"},"text":"Pub. L. 118–63, § 305(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" inserted “—” after “title 5”, designated remaining existing provisions as par. (1), and added par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
