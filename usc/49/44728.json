{"tag":"section","attrib":{"id":"idcc053048-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728"},"text":null,"children":[{"tag":"num","attrib":{"value":"44728"},"text":"§ 44728.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flight attendant certification","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc053049-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certificate Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc05304a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person may serve as a flight attendant aboard an aircraft of an air carrier unless that person holds a certificate of demonstrated proficiency from the Administrator of the Federal Aviation Administration. Upon the request of the Administrator or an authorized representative of the National Transportation Safety Board or another Federal agency, a person who holds such a certificate shall present the certificate for inspection within a reasonable period of time after the date of the request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc05304b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rule for current flight attendants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual serving as a flight attendant on the effective date of this section may continue to serve aboard an aircraft as a flight attendant until completion by that individual of the required recurrent or requalification training and subsequent certification under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc05304c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of flight attendant after notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On the date that the Administrator is notified by an air carrier that an individual has the demonstrated proficiency to be a flight attendant, the individual shall be treated for purposes of this section as holding a certificate issued under the section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc05304d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance of Certificate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall issue a certificate of demonstrated proficiency under this section to an individual after the Administrator is notified by the air carrier that the individual has successfully completed all the training requirements for flight attendants approved by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc05304e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Person To Determine Successful Completion of Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accordance with part 183 of title 14, Code of Federal Regulations, the director of operations of an air carrier is designated to determine that an individual has successfully completed the training requirements approved by the Administrator for such individual to serve as a flight attendant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc05304f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specifications Relating to Certificates","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each certificate issued under this section shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc053050-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be numbered and recorded by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc053051-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain the name, address, and description of the individual to whom the certificate is issued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc053052-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be similar in size and appearance to certificates issued to airmen;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc053053-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contain the airplane group for which the certificate is issued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc053054-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be issued not later than 120 days after the Administrator receives notification from the air carrier of demonstrated proficiency and, in the case of an individual serving as flight attendant on the effective date of this section, not later than 1 year after such effective date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc053055-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval of Training Programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Air carrier flight attendant training programs shall be subject to approval by the Administrator. All flight attendant training programs approved by the Administrator in the 1-year period ending on the date of enactment of this section shall be treated as providing a demonstrated proficiency for purposes of meeting the certification requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc053056-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Language Skills.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc053057-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person may serve as a flight attendant aboard an aircraft of an air carrier, unless that person has demonstrated to an individual qualified to determine proficiency the ability to read, speak, and write English well enough to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc053058-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" read material written in English and comprehend the information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc053059-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" speak and understand English sufficiently to provide direction to, and understand and answer questions from, English-speaking individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc05305a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" write incident reports and statements and log entries and statements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc05305b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out written and oral instructions regarding the proper performance of their duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc05305c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign flights","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements of paragraph (1) do not apply to a flight attendant serving solely between points outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc05305d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44728/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Flight Attendant Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “flight attendant” means an individual working as a flight attendant in the cabin of an aircraft that has 20 or more seats and is being used by an air carrier to provide air transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc05305e-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/tVIII/s814/a"},"text":"Pub. L. 108–176, title VIII, § 814(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2590"},"text":"117 Stat. 2590","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIII/s304/a"},"text":"Pub. L. 112–95, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/58"},"text":"126 Stat. 58","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tV/s539/i"},"text":"Pub. L. 115–254, div. B, title V, § 539(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3371"},"text":"132 Stat. 3371","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tXI/s1101/p"},"text":"Pub. L. 118–63, title XI, § 1101(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1414"},"text":"138 Stat. 1414","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc05305f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc053060-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc053061-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For effective date of this section, referred to in subsecs. (a)(2) and (d)(5), see Effective Date note below.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (e), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc053062-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" substituted “Regulations,” for “Regulation,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s539/i/1"},"text":"Pub. L. 115–254, § 539(i)(1)","children":[],"tail":", substituted “title 14” for “chapter 14”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s539/i/2"},"text":"Pub. L. 115–254, § 539(i)(2)","children":[],"tail":", substituted “be” for “is”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":" added subsec. (f) and redesignated former subsec. (f) as (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc053063-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc053064-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/tVIII/s814/c"},"text":"Pub. L. 108–176, title VIII, § 814(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2592"},"text":"117 Stat. 2592","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/176/tVIII/s814/c"},"text":"“The amendments made by subsections (a) and (b) [enacting this section and amending the analysis to this chapter] shall take effect on the 365th day following the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc053065-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Facilitation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIII/s304/b"},"text":"Pub. L. 112–95, title III, § 304(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/58"},"text":"126 Stat. 58","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/95/tIII/s304/b"},"text":"“The Administrator of the Federal Aviation Administration shall work with air carriers to facilitate compliance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44728/f"},"text":"section 44728(f) of title 49","children":[],"tail":", United States Code (as amended by this section).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
