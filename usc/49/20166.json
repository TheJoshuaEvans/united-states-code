{"tag":"section","attrib":{"id":"idcb16b1ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20166"},"text":null,"children":[{"tag":"num","attrib":{"value":"20166"},"text":"§ 20166.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency escape breathing apparatus","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after the date of enactment of the Rail Safety Improvement Act of 2008, the Secretary of Transportation shall prescribe regulations that require railroad carriers—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb16b1ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20166/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide emergency escape breathing apparatus suitable to provide head and neck coverage with respiratory protection for all crewmembers in locomotive cabs on freight trains carrying hazardous materials that would pose an inhalation hazard in the event of release;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b1ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20166/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide convenient storage in each freight train locomotive to enable crewmembers to access such apparatus quickly;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b1f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20166/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain such equipment in proper working condition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b1f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20166/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide their crewmembers with appropriate training for using the breathing apparatus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb16b1f2-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tIV/s413/a"},"text":"Pub. L. 110–432, div. A, title IV, § 413(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4889"},"text":"122 Stat. 4889","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb16b1f3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb16b1f4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb16b1f5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Rail Safety Improvement Act of 2008, referred to in text, is the date of enactment of div. A. of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
