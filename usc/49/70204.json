{"tag":"section","attrib":{"id":"idcc8ab3e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204"},"text":null,"children":[{"tag":"num","attrib":{"value":"70204"},"text":"§ 70204.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Multi-State freight corridor planning","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc8ab3ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consent to Multi-State Freight Mobility Compacts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress recognizes the right of States, cities, regional planning organizations, federally recognized Indian Tribes, and local public authorities (including public port authorities) that are regionally linked with an interest in a specific nationally or regionally significant multi-State freight corridor to enter into multi-State compacts to promote the improved mobility of goods, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8ab3eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying projects along the corridor that benefit multiple States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab3ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assembling rights-of-way; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab3ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performing capital improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8ab3ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A multi-State freight compact established by entities under subsection (a) may provide that, in order to carry out the compact, the relevant States or other entities may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8ab3ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept contributions from a unit of State or local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab3f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use any Federal or State funds made available for freight mobility infrastructure planning or construction, including applying for grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab3f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to such terms and conditions as the States consider to be advisable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8ab3f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" borrow money on a short-term basis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab3f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" issue—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc8ab3f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notes for borrowing under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8ab3f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bonds; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab3f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain financing by other means permitted under applicable Federal or State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8ab3f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory Committees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8ab3f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A multi-State freight compact under this section may establish a multi-State freight corridor advisory committee, which shall include representatives of State departments of transportation and other public and private sector entities with an interest in freight mobility, such as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8ab3f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab3fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" freight railroads;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab3fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shippers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab3fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab3fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" freight-related associations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab3fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" third-party logistics providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab3ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the freight industry workforce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab400-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab401-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab402-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" units of local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab403-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An advisory committee established under paragraph (1) may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8ab404-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" advise the parties to the applicable multi-State freight compact with respect to freight-related priorities, issues, projects, and funding needs that impact multi-State—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc8ab405-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" freight mobility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8ab406-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supply chains;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab407-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a forum for States, Indian Tribes, and other public entities to discuss decisions affecting freight mobility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab408-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" communicate and coordinate multi-State freight priorities with other organizations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab409-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote the sharing of information between the private and public sectors with respect to freight issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab40a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide information for consideration in the development of State freight plans under section 70202.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8ab40b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8ab40c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation (referred to in this section as the “Secretary”) shall establish a program under which the Secretary shall provide grants to multi-State freight compacts, or States seeking to form a multi-State freight compact, that seek to improve a route or corridor that is a part of the National Multimodal Freight Network established under section 70103.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab40d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New compacts.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8ab40e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To incentivize the establishment of multi-State freight compacts, the Secretary may award a grant for operations costs in an amount of not more than $2,000,000 to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc8ab40f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multi-State freight compact established under subsection (a) during the 2-year period beginning on the date of establishment of the multi-State freight compact; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8ab410-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States seeking to form a multi-State freight compact described in that subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab411-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idcc8ab412-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"New multi-state freight compacts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A multi-State freight compact shall be eligible for a grant under this paragraph only during the initial 2 years of operation of the compact.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8ab413-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"States seeking to form a compact","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"States seeking to form a multi-State freight compact shall be eligible for a grant under this paragraph during—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcc8ab414-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2-year period beginning on the date on which an application for a grant under this paragraph with respect to the proposed compact is submitted to the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc8ab415-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the compact is formed before the date on which a grant under this paragraph is awarded in accordance with subclause (I), the initial 2 years of operation of the compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab416-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this paragraph, a multi-State freight compact or the applicable States seeking to form a multi-State freight compact shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc8ab417-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8ab418-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a non-Federal match equal to not less than 25 percent of the operating costs of the multi-State freight compact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8ab419-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commit to establishing a multi-State freight corridor advisory committee under subsection (c)(1) during the initial 2-year period of operation of the compact.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab41a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing compacts.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8ab41b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may award a grant to multi-State freight compacts that are not eligible to receive a grant under paragraph (2) for operations costs in an amount of not more than $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab41c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under this paragraph, a multi-State freight compact shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc8ab41d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary an application at such time, in such manner, and containing such information as the Secretary may require;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8ab41e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a non-Federal match of not less than 50 percent of the operating costs of the compact; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8ab41f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate that the compact has established a multi-State freight corridor advisory committee under subsection (c)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab420-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70204/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary $5,000,000 for each fiscal year to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc8ab421-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI/s21106/a/2"},"text":"Pub. L. 117–58, div. B, title I, § 21106(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/659"},"text":"135 Stat. 659","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc8ab422-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc8ab423-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcc8ab424-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 70204 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s70206"},"text":"section 70206 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
