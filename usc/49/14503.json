{"tag":"section","attrib":{"id":"idcafee42a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14503"},"text":null,"children":[{"tag":"num","attrib":{"value":"14503"},"text":"§ 14503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding State and local income tax by certain carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcafee42b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Single State Tax Withholding.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafee42c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No part of the compensation paid by a motor carrier providing transportation subject to jurisdiction under subchapter I of chapter 135 or by a motor private carrier to an employee who performs regularly assigned duties in 2 or more States as such an employee with respect to a motor vehicle shall be subject to the income tax laws of any State or subdivision of that State, other than the State or subdivision thereof of the employee’s residence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee42d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “employee” has the meaning given such term in section 31132.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee42e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rules.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafee42f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Calculation of earnings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, an employee is deemed to have earned more than 50 percent of pay in a State or subdivision of that State in which the time worked by the employee in the State or subdivision is more than 50 percent of the total time worked by the employee while employed during the calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb012d20-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Water carriers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A water carrier providing transportation subject to jurisdiction under subchapter II of chapter 135 shall file income tax information returns and other reports only with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb012d21-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14503/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State and subdivision of residence of the employee (as shown on the employment records of the carrier); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb012d22-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14503/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State and subdivision in which the employee earned more than 50 percent of the pay received by the employee from the carrier during the preceding calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb012d23-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to sailors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection applies to pay of a master, officer, or sailor who is a member of the crew on a vessel engaged in foreign, coastwise, intercoastal, or noncontiguous trade or in the fisheries of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb012d24-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing of Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A motor and motor private carrier withholding pay from an employee under subsection (a) of this section shall file income tax information returns and other reports only with the State and subdivision of residence of the employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb012d25-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/901"},"text":"109 Stat. 901","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb012d26-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb012d27-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb012d28-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11504"},"text":"section 11504 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb012d29-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb012d2a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
