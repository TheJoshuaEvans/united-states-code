{"tag":"section","attrib":{"id":"idcab99d65-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324"},"text":null,"children":[{"tag":"num","attrib":{"value":"5324"},"text":"§ 5324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public transportation emergency relief program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcab99d66-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section the following definitions shall apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcab99d67-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible operating costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible operating costs” means costs relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcab99d68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evacuation services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcab99d69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rescue operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcab99d6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" temporary public transportation service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcab99d6b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reestablishing, expanding, or relocating public transportation route service before, during, or after an emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab99d6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emergency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “emergency” means a natural disaster affecting a wide area (such as a flood, hurricane, tidal wave, earthquake, severe storm, or landslide) or a catastrophic failure from any external cause, as a result of which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcab99d6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Governor of a State has declared an emergency and the Secretary has concurred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcab99d6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President has declared a major disaster under section 401 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"42 U.S.C. 5170","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcab99d6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants and enter into contracts and other agreements (including agreements with departments, agencies, and instrumentalities of the Government) for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcab99d70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital projects to protect, repair, reconstruct, or replace equipment and facilities of a public transportation system operating in the United States or on an Indian reservation that the Secretary determines is in danger of suffering serious damage, or has suffered serious damage, as a result of an emergency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab99d71-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" eligible operating costs of public transportation equipment and facilities in an area directly affected by an emergency during—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcab99d72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 1-year period beginning on the date of a declaration described in subsection (a)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcab99d73-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary determines there is a compelling need, the 2-year period beginning on the date of a declaration described in subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcab99d74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination of Emergency Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcab99d75-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds appropriated to carry out this section shall be in addition to any other funds available under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab99d76-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No effect on other government activity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provision of funds under this section shall not affect the ability of any other agency of the Government, including the Federal Emergency Management Agency, or a State agency, a local governmental entity, organization, or person, to provide any other funds otherwise authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab99d77-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall notify the Secretary of Homeland Security of the purpose and amount of any grant made or contract or other agreement entered into under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcab99d78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant awarded under this section or under section 5307 or 5311 that is made to address an emergency defined under subsection (a)(2) shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcab99d79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to the terms and conditions the Secretary determines are necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab99d7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made only for expenses that are not reimbursed under the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcab99d7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Government Share of Costs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcab99d7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital projects and operating assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant, contract, or other agreement for a capital project or eligible operating costs under this section shall be, at the option of the recipient, for not more than 80 percent of the net project cost, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab99d7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The remainder of the net project cost may be provided from an undistributed cash surplus, a replacement or depreciation cash fund or reserve, or new capital.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab99d7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive, in whole or part, the non-Federal share required under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcab99d7f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcab99d80-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 5307 or 5311, in the case of a grant made available under section 5307 or 5311, respectively, to address an emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcab99d81-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Insurance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before receiving a grant under this section following an emergency, an applicant shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcab99d82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Secretary documentation demonstrating proof of insurance required under Federal law for all structures related to the grant application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab99d83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5324/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certify to the Secretary that the applicant has insurance required under State law for all structures related to the grant application.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcab99d84-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/824"},"text":"108 Stat. 824","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIII/s3024/a"},"text":"Pub. L. 109–59, title III, § 3024(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1619"},"text":"119 Stat. 1619","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dB/s20017/a"},"text":"Pub. L. 112–141, div. B, § 20017(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/703"},"text":"126 Stat. 703","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dC/s30011"},"text":"Pub. L. 117–58, div. C, § 30011","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/904"},"text":"135 Stat. 904","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcab99d85-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcab99d86-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcab99d87-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5324(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1606(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 9, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/365/s7/a"},"text":"Pub. L. 88–365, § 7(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/305"},"text":"78 Stat. 305","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/19/s20/a"},"text":"Pub. L. 90–19, § 20(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/25"},"text":"81 Stat. 25","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5324(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1610(a) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 9, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/365/s14/a"},"text":"Pub. L. 88–365, § 14(a)","children":[],"tail":" (last sentence)–(c), "},{"tag":"html:a","attrib":{"href":"/us/stat/78/308"},"text":"78 Stat. 308","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 8, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/562/s2/a/1"},"text":"Pub. L. 89–562, § 2(a)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/715"},"text":"80 Stat. 715","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/19/s20/a"},"text":"Pub. L. 90–19, § 20(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/25"},"text":"81 Stat. 25","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/453/s6"},"text":"Pub. L. 91–453, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/966"},"text":"84 Stat. 966","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5324(b)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1610(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5324(b)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1610(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5324(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1608(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 9, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/365/s12/d"},"text":"Pub. L. 88–365, § 12(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/307"},"text":"78 Stat. 307","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 10, 1965","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/117/s1109"},"text":"Pub. L. 89–117, § 1109","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/79/507"},"text":"79 Stat. 507","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 8, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/562/s2/a/1"},"text":"Pub. L. 89–562, § 2(a)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/715"},"text":"80 Stat. 715","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/19/s20/a"},"text":"Pub. L. 90–19, § 20(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/25"},"text":"81 Stat. 25","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 6, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/599/s308/c"},"text":"Pub. L. 95–599, § 308(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2747"},"text":"92 Stat. 2747","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the word “provided” is substituted for “extended” for clarity. The words “to any project” are omitted as surplus. In clause (2), the words “available . . . displaced” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “Health and Human Services” are substituted for “Health, Education, and Welfare” in section 14(a) (last sentence) of the Urban Mass Transportation Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/365"},"text":"Public Law 88–365","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/308"},"text":"78 Stat. 308","children":[],"tail":") [subsequently changed to the Federal Transit Act by section 3003(a) of the Intermodal Surface Transportation Efficiency Act of 1991 ("},{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Public Law 102–240","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2087"},"text":"105 Stat. 2087","children":[],"tail":")] because of 20:3508(b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), before clause (A), the words “In carrying out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5306"},"text":"section 5306 of this title","children":[],"tail":"” are added for clarity and consistency with subsections (b)(3) and (c) of this section. The word “detailed” is omitted as surplus. In clause (B), the words “should the proposal be implemented” are omitted as surplus. In clause (D), the words “which may be involved in the proposed project should it be implemented” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3)(A), before clause (i), the word “financial” is added for clarity. The words “full and complete” are omitted as surplus. In clause (ii), the word “fair” is omitted as surplus. In clause (iii), the word “either” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3)(B), the words “before the State or local agency pursuant to section 1602(d) of this Appendix” and “before the State or local public agency . . . to permit him” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “The Secretary of Transportation may not” are substituted for “None of the provisions of this chapter shall be construed to authorize the Secretary to” to eliminate unnecessary words. The words “in any manner . . . mode of” and “rates, fares, tolls, rentals, or other . . . fixed or prescribed . . . by any local public or private transit agency” are omitted as surplus. The words “However, the Secretary may” are substituted for “but nothing in this subsection shall prevent the Secretary from taking such actions as may be necessary to” to eliminate unnecessary words. The words “local governmental authority, corporation, or association” are substituted for “agency or agencies” for consistency with sections 5309 and 5310 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcab99d88-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcab99d89-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Robert T. Stafford Disaster Relief and Emergency Assistance Act, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/288"},"text":"Pub. L. 93–288","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-05-22"},"text":"May 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/143"},"text":"88 Stat. 143","children":[],"tail":", which is classified principally to chapter 68 (§ 5121 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"section 5121 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcab99d8a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" amended section generally. Prior to amendment, section related to special provisions for capital projects."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" amended section generally. Prior to amendment, section consisted of subsecs. (a) to (c) relating to requirements of a relocation program for families displaced by a project, consideration of economic, social, and environmental interests, and prohibition against regulating the operation of a mass transportation system for which a grant is made under section 5309 and regulating any charge for the system after a grant is made."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcab99d8b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcab99d8c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcab99d8d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Memorandum of Agreement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dB/s20017/b"},"text":"Pub. L. 112–141, div. B, § 20017(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/705"},"text":"126 Stat. 705","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/141/dB/s20017/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this subsection are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve coordination between the Department of Transportation and the Department of Homeland Security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expedite the provision of Federal assistance for public transportation systems for activities relating to a major disaster or emergency declared by the President under the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.) (referred to in this subsection as a ‘major disaster or emergency’)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of enactment of this Act [see section 3(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", set out as Effective and Termination Dates of 2012 Amendment notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways], the Secretary of Transportation and the Secretary of Homeland Security shall enter into a memorandum of agreement to coordinate the roles and responsibilities of the Department of Transportation and the Department of Homeland Security in providing assistance for public transportation, including the provision of public transportation services and the repair and restoration of public transportation systems in areas for which the President has declared a major disaster or emergency."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The memorandum of agreement required under paragraph (2) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for improved coordination and expeditious use of public transportation, as appropriate, in response to and recovery from a major disaster or emergency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish procedures to address—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issues that have contributed to delays in the reimbursement of eligible transportation-related expenses relating to a major disaster or emergency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any challenges identified in the review under paragraph (4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the coordination of assistance for public transportation provided under the Robert T. Stafford Disaster Relief and Emergency Assistance Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5121"},"text":"42 U.S.C. 5121","children":[],"tail":" et seq.] and "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5324"},"text":"section 5324 of title 49","children":[],"tail":", United States Code, as amended by this Act, as appropriate; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide for the development and distribution of clear guidelines for State, local, and tribal governments, including public transportation systems, relating to—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assistance available for public transportation systems for activities relating to a major disaster or emergency—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the Robert T. Stafford Disaster Relief and Emergency Assistance Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5324"},"text":"section 5324 of title 49","children":[],"tail":", United States Code, as amended by this Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"“(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from other sources, including other Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reimbursement procedures that speed the process of—","children":[],"tail":null},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"“(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applying for assistance under the Robert T. Stafford Disaster Relief and Emergency Assistance Act and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5324"},"text":"section 5324 of title 49","children":[],"tail":", United States Code, as amended by this Act; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"“(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distributing assistance for public transportation systems under the Robert T. Stafford Disaster Relief and Emergency Assistance Act and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5324"},"text":"section 5324 of title 49","children":[],"tail":", United States Code, as amended by this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"After action review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before entering into a memorandum of agreement under paragraph (2), the Secretary of Transportation and the Secretary of Homeland Security (acting through the Administrator of the Federal Emergency Management Agency), in consultation with State, local, and tribal governments (including public transportation systems) that have experienced a major disaster or emergency, shall review after action reports relating to major disasters, emergencies, and exercises, to identify areas where coordination between the Department of Transportation and the Department of Homeland Security and the provision of public transportation services should be improved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors for declarations of major disasters and emergencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Federal Emergency Management Agency shall make available to State, local, and tribal governments, including public transportation systems, a description of the factors that the President considers in declaring a major disaster or emergency, including any pre-disaster emergency declaration policies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefings.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial briefing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of enactment of this Act, the Secretary of Transportation and the Secretary of Homeland Security shall jointly brief the Committee on Banking, Housing, and Urban Affairs and the Committee on Homeland Security and Governmental Affairs of the Senate on the memorandum of agreement required under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly briefings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each quarter of the 1-year period beginning on the date on which the Secretary of Transportation and the Secretary of Homeland Security enter into the memorandum of agreement required under paragraph (2), the Secretary of Transportation and the Secretary of Homeland Security shall jointly brief the Committee on Banking, Housing, and Urban Affairs and the Committee on Homeland Security and Governmental Affairs of the Senate on the implementation of the memorandum of agreement.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
