{"tag":"section","attrib":{"id":"idcc648e2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47173"},"text":null,"children":[{"tag":"num","attrib":{"value":"47173"},"text":"§ 47173.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Airport funding of FAA staff","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc648e30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47173/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acceptance of Sponsor-Provided Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, the Administrator of the Federal Aviation Administration may accept funds from an airport sponsor, including funds provided to the sponsor under section 47114(c), to hire additional staff or obtain the services of consultants—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc648e31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47173/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the timely processing, review, and completion of environmental activities associated with an airport development project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47173/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct special environmental studies related to an airport project funded with Federal funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47173/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct special studies or reviews to support approved noise compatibility measures described in part 150 of title 14, Code of Federal Regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47173/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct special studies or reviews to support environmental mitigation in a record of decision or finding of no significant impact by the Federal Aviation Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47173/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the timely processing, review, and completion of environmental activities associated with new or amended flight procedures, including performance-based navigation procedures, such as required navigation performance procedures and area navigation procedures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc648e36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47173/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Provision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Instead of payment from an airport sponsor from funds apportioned to the sponsor under section 47114, the Administrator, with agreement of the sponsor, may transfer funds that would otherwise be apportioned to the sponsor under section 47114 to the account used by the Administrator for activities described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc648e37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47173/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Receipts Credited as Offsetting Collections","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", any funds accepted under this section, except funds transferred pursuant to subsection (b)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc648e38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47173/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited as offsetting collections to the account that finances the activities and services for which the funds are accepted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47173/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be available for expenditure only to pay the costs of activities and services for which the funds are accepted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47173/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc648e3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47173/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of Effort","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No funds may be accepted pursuant to subsection (a), or transferred pursuant to subsection (b), in any fiscal year in which the Federal Aviation Administration does not allocate at least the amount it expended in fiscal year 2002 (excluding amounts accepted pursuant to section 337 of the Department of Transportation and Related Agencies Appropriations Act, 2002 (","children":[{"tag":"ref","attrib":{"href":"/us/stat/115/862"},"text":"115 Stat. 862","children":[],"tail":")) for the activities described in subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc648e3c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/tIII/s304/a"},"text":"Pub. L. 108–176, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2537"},"text":"117 Stat. 2537","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tV/s503"},"text":"Pub. L. 112–95, title V, § 503","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/103"},"text":"126 Stat. 103","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc648e3d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc648e3e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc648e3f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 337 of the Department of Transportation and Related Agencies Appropriations Act, 2002, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/87/s337"},"text":"section 337 of Pub. L. 107–87","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-12-18"},"text":"Dec. 18, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/862"},"text":"115 Stat. 862","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc648e40-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":" substituted “services of consultants—” for “services of consultants in order to facilitate the timely processing, review, and completion of environmental activities associated with an airport development project.” and added pars. (1) to (5)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc648e41-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc648e42-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
