{"tag":"section","attrib":{"id":"idcb250973-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22901"},"text":null,"children":[{"tag":"num","attrib":{"value":"22901"},"text":"§ 22901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb250974-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “applicant” means a State (including the District of Columbia), a group of States, an Interstate Compact, or a public agency established by one or more States and having responsibility for providing intercity passenger rail service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb250975-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital project","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “capital project” means a project or program in a State rail plan developed under chapter 227 of this title for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb250976-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22901/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquiring, constructing, improving, or inspecting equipment, track and track structures, or a facility for use in or for the primary benefit of intercity passenger rail service, expenses incidental to the acquisition or construction (including designing, engineering, location surveying, mapping, environmental studies, and acquiring rights-of-way), payments for the capital portions of rail trackage rights agreements, highway-rail grade crossing improvements related to intercity passenger rail service, mitigating environmental impacts, communication and signalization improvements, relocation assistance, acquiring replacement housing sites, and acquiring, constructing, relocating, and rehabilitating replacement housing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb250977-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22901/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rehabilitating, remanufacturing or overhauling rail rolling stock and facilities used primarily in intercity passenger rail service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb250978-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22901/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs associated with developing State rail plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb250979-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22901/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first-dollar liability costs for insurance related to the provision of intercity passenger rail service under section 22904.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb25097a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intercity passenger rail service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “intercity passenger rail service” means intercity rail passenger transportation, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24102"},"text":"section 24102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb25097b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tIII/s301/a"},"text":"Pub. L. 110–432, div. B, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4935"},"text":"122 Stat. 4935","children":[],"tail":", § 24401; renumbered § 22901 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/420/s7/a/1"},"text":"Pub. L. 115–420, § 7(a)(1)","children":[],"tail":", (b)(2)(A), "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5445"},"text":"132 Stat. 5445","children":[],"tail":", 5446.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb25097c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb25097d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb25097e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/420/s7/a/1"},"text":"Pub. L. 115–420, § 7(a)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s24401"},"text":"section 24401 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/420/s7/b/2/A"},"text":"Pub. L. 115–420, § 7(b)(2)(A)","children":[],"tail":", substituted “22904” for “24404”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
