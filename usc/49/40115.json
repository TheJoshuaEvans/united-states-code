{"tag":"section","attrib":{"id":"idcbacd6ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40115"},"text":null,"children":[{"tag":"num","attrib":{"value":"40115"},"text":"§ 40115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbacd6ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objections to Disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbacd6ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person may object to the public disclosure of information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbacd6f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40115/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a record filed under this part; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbacd6f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40115/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtained under this part by the Secretary of Transportation or State or the United States Postal Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbacd6f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An objection must be in writing and must state the reasons for the objection. The Secretary of Transportation or State or the Postal Service shall order the information withheld from public disclosure when the appropriate Secretary or the Postal Service decides that disclosure of the information would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbacd6f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40115/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prejudice the United States Government in preparing and presenting its position in international negotiations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbacd6f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40115/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have an adverse effect on the competitive position of an air carrier in foreign air transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbacd6f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withholding Information From Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not authorize information to be withheld from a committee of Congress authorized to have the information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbacd6f6-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1111"},"text":"108 Stat. 1111","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbacd6f7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbacd6f8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbacd6f9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40115","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1504.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s1104"},"text":"Pub. L. 85–726, § 1104","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/797"},"text":"72 Stat. 797","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/504/s39"},"text":"Pub. L. 95–504, § 39","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1743"},"text":"92 Stat. 1743","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Feb. 15, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/192/s19"},"text":"Pub. L. 96–192, § 19","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/43"},"text":"94 Stat. 43","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(B), the words “the Secretary of Transportation or State or the United States Postal Service” are substituted for “the Board, the Secretary of State, or the Secretary of Transportation” because under 49 App.:1551 the duties of the Civil Aeronautics Board were transferred to the Secretary of Transportation and the Postal Service.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “shall order the information withheld from public disclosure when the appropriate Secretary or the Postal Service decides that disclosure of the information” are substituted for “shall be withheld from public disclosure by the Board, the Secretary of State or the Secretary of Transportation” for clarity and because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “The Board, the Secretary of State, or the Secretary of Transportation, as the case may be, shall be responsible for classified information in accordance with appropriate law” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
