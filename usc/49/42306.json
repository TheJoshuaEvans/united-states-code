{"tag":"section","attrib":{"id":"idcbd56d68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42306"},"text":null,"children":[{"tag":"num","attrib":{"value":"42306"},"text":"§ 42306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Know Your Rights posters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd56d69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each large hub airport, medium hub airport, and small hub airport with scheduled passenger service shall prominently display posters that clearly and concisely outline the rights of airline passengers under Federal law with respect to, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flight delays and cancellations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d6b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refunds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" bumping of passengers from flights and the oversale of flights; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42306/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lost, delayed, or damaged baggage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Location","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Posters described in subsection (a) shall be displayed in conspicuous locations throughout the airport, including ticket counters, security checkpoints, and boarding gates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accessibility Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each large hub airport, medium hub airport, and small hub airport with scheduled passenger service shall ensure that passengers with a disability (as such term is defined in section 382.3 of title 14, Code of Federal Regulations) who identify themselves as having such a disability are notified of the availability of accessibility assistance and shall assist such passengers in connecting to the appropriate entities to obtain the same information required in this section that is provided to other passengers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd56d70-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tV/s504/a"},"text":"Pub. L. 118–63, title V, § 504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1190"},"text":"138 Stat. 1190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd56d71-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbd56d72-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcbd56d73-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tV/s504/d"},"text":"Pub. L. 118–63, title V, § 504(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1191"},"text":"138 Stat. 1191","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tV/s504/d"},"text":"“The amendments made by this section [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s46301"},"text":"section 46301 of this title","children":[],"tail":"] shall take effect on the date that is 1 year after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
