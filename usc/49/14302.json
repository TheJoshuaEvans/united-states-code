{"tag":"section","attrib":{"id":"idcafee3a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302"},"text":null,"children":[{"tag":"num","attrib":{"value":"14302"},"text":"§ 14302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pooling and division of transportation or earnings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcafee3a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier providing transportation subject to jurisdiction under subchapter I of chapter 135 may not agree or combine with another such carrier to pool or divide traffic or services or any part of their earnings without the approval of the Board under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee3a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards for Approval","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may approve and authorize an agreement or combination between or among motor carriers of passengers, or between a motor carrier of passengers and a rail carrier of passengers if the carriers involved assent to the pooling or division and the Board finds that a pooling or division of traffic, services, or earnings—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafee3a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be in the interest of better service to the public or of economy of operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee3a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not unreasonably restrain competition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee3aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafee3ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any motor carrier of property may apply to the Board for approval of an agreement or combination with another such carrier to pool or divide traffic or any services or any part of their earnings by filing such agreement or combination with the Board not less than 50 days before its effective date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee3ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of importance and restraint on competition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prior to the effective date of the agreement or combination, the Board shall determine whether the agreement or combination is of major transportation importance and whether there is substantial likelihood that the agreement or combination will unduly restrain competition. If the Board determines that neither of these 2 factors exists, it shall, prior to such effective date and without a hearing, approve and authorize the agreement or combination, under such rules and regulations as the Board may issue, and for such consideration between such carriers and upon such terms and conditions as shall be found by the Board to be just and reasonable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee3ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Board determines either that the agreement or combination is of major transportation importance or that there is substantial likelihood that the agreement or combination will unduly restrain competition, the Board shall hold a hearing concerning whether the agreement or combination will be in the interest of better service to the public or of economy in operation and whether it will unduly restrain competition and shall suspend operation of such agreement or combination pending such hearing and final decision thereon. After such hearing, the Board shall indicate to what extent it finds that the agreement or combination will be in the interest of better service to the public or of economy in operation and will not unduly restrain competition and if assented to by all the carriers involved, shall to that extent, approve and authorize the agreement or combination, under such rules and regulations as the Board may issue, and for such consideration between such carriers and upon such terms and conditions as shall be found by the Board to be just and reasonable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee3ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special rules for household goods carriers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of an application for Board approval of an agreement or combination between a motor carrier providing transportation of household goods and its agents to pool or divide traffic or services or any part of their earnings, such agreement or combination shall be presumed to be in the interest of better service to the public and of economy in operation and not to restrain competition unduly if the practices proposed to be carried out under such agreement or combination are the same as or similar to practices carried out under agreements and combinations between motor carriers providing transportation of household goods to pool or divide traffic or service of any part of their earnings approved by the Interstate Commerce Commission before ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee3af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Streamlining and simplifying","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall streamline, simplify, and expedite, to the maximum extent practicable, the process (including any paperwork) for submission and approval of applications under this section for agreements and combinations between motor carriers providing transportation of household goods and their agents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee3b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may impose conditions governing the pooling or division and may approve and authorize payment of a reasonable consideration between the carriers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee3b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initiation of Proceeding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may begin a proceeding under this section on its own initiative or on application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee3b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier may participate in an arrangement approved by or exempted by the Board under this section without the approval of any other Federal, State, or municipal body. A carrier participating in an approved or exempted arrangement is exempt from the antitrust laws and from all other law, including State and municipal law, as necessary to let that person carry out the arrangement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee3b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation of Existing Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any agreements in operation under the provisions of this title on ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":", that are succeeded by this section shall remain in effect until further order of the Board."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee3b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafee3b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Household goods","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “household goods” has the meaning such term had under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10102/11"},"text":"section 10102(11) of this title","children":[],"tail":", as in effect on "},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee3b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14302/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “transportation” means transportation that would be subject to the jurisdiction of the Interstate Commerce Commission under subchapter II of chapter 105 of this title, as in effect on ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":", if such subchapter were still in effect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcafee3b7-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/895"},"text":"109 Stat. 895","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/37"},"text":"Pub. L. 104–287, § 5(37)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3392"},"text":"110 Stat. 3392","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcafee3b8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcafee3b9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcafee3ba-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/37/A"},"text":"Pub. L. 104–287, § 5(37)(A)","children":[],"tail":", (B)"}],"tail":null},{"tag":"p","attrib":{},"text":"This sets out the effective date of 49:14302.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcafee3bb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/37/C"},"text":"Pub. L. 104–287, § 5(37)(C)","children":[],"tail":", (D)"}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:14302(h)(1) and (2) for clarity and consistency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcafee3bc-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcafee3bd-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10102/11"},"text":"Section 10102(11) of this title","children":[],"tail":", referred to in subsec. (h)(1), was omitted and a new section 10102 enacted in the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-20"},"text":"Dec. 20, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/804"},"text":"109 Stat. 804","children":[],"tail":", 806, effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subchapter II of chapter 105 of this title, referred to in subsec. (h)(2), was omitted in the general amendment of this subtitle by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/804"},"text":"109 Stat. 804","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcafee3be-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 11341 and 11342 of this title prior to the general amendment of this subtitle by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcafee3bf-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/37/A"},"text":"Pub. L. 104–287, § 5(37)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"” for “the effective date of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/37/B"},"text":"Pub. L. 104–287, § 5(37)(B)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":",” for “the effective date of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/37/C"},"text":"Pub. L. 104–287, § 5(37)(C)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"” for “the day before the effective date of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/37/D"},"text":"Pub. L. 104–287, § 5(37)(D)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"” for “the day before such effective date”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcafee3c0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcafee3c1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcafee3c2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Interstate Commerce Commission","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Interstate Commerce Commission abolished by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s101"},"text":"section 101 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
