{"tag":"section","attrib":{"id":"idcb3cd721-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24906"},"text":null,"children":[{"tag":"num","attrib":{"value":"24906"},"text":"§ 24906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Eliminating highway at-grade crossings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb3cd722-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In consultation with the States on the main line of the Northeast Corridor, the Secretary of Transportation shall develop a plan not later than ","children":[{"tag":"date","attrib":{"date":"1993-09-30"},"text":"September 30, 1993","children":[],"tail":", to eliminate all highway at-grade crossings of the main line by not later than "},{"tag":"date","attrib":{"date":"1997-12-31"},"text":"December 31, 1997","children":[],"tail":". The plan may provide that eliminating a crossing is not required if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3cd723-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impracticable or unnecessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd724-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using the crossing is consistent with conditions the Secretary considers appropriate to ensure safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3cd725-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amtrak’s Share of Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amtrak shall pay 20 percent of the cost of eliminating each highway at-grade crossing under the plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb3cd726-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/936"},"text":"108 Stat. 936","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb3cd727-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb3cd728-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb3cd729-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"htm