{"tag":"section","attrib":{"id":"idcc6bba05-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48108"},"text":null,"children":[{"tag":"num","attrib":{"value":"48108"},"text":"§ 48108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Availability and uses of amounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc6bba06-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts equal to the amounts authorized under sections 48101–48105 of this title remain in the Airport and Airway Trust Fund established under section 9502 of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9502"},"text":"26 U.S.C. 9502","children":[],"tail":") until appropriated for the purposes of sections 48101–48105."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6bba07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Uses","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc6bba08-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the Fund may be appropriated only to carry out a program or activity referred to in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6bba09-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amounts in the Fund may be appropriated for administrative expenses of the Department of Transportation or a component of the Department only to the extent authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s48104"},"text":"section 48104 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6bba0a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Obligating or Expending Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a fiscal year beginning after ","children":[{"tag":"date","attrib":{"date":"1998-09-30"},"text":"September 30, 1998","children":[],"tail":", the Secretary of Transportation may obligate or expend an amount appropriated out of the Fund under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s48104"},"text":"section 48104 of this title","children":[],"tail":" only if a law expressly amends section 48104."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc6bba0b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1297"},"text":"108 Stat. 1297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/305/tI/s102/c"},"text":"Pub. L. 103–305, title I, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"hre