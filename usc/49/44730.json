{"tag":"section","attrib":{"id":"idcc077977-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730"},"text":null,"children":[{"tag":"num","attrib":{"value":"44730"},"text":"§ 44730.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Helicopter air ambulance operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc077978-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc077979-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), a part 135 certificate holder providing air ambulance services shall comply, whenever medical personnel are onboard the aircraft, with regulations pertaining to weather minimums and flight and duty time under part 135.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc07797a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a certificate holder described in paragraph (1) is operating, or carrying out training, under instrument flight rules, the weather reporting requirement at the destination shall not apply if authorized by the Administrator of the Federal Aviation Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc07797b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final Rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2012-06-01"},"text":"June 1, 2012","children":[],"tail":", the Administrator shall issue a final rule, with respect to the notice of proposed rulemaking published in the Federal Register on "},{"tag":"date","attrib":{"date":"2010-10-12"},"text":"October 12, 2010","children":[],"tail":" (75 Fed. Reg. 62640), to improve the safety of flight crewmembers, medical personnel, and passengers onboard helicopters providing air ambulance services under part 135."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc07797c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters To Be Addressed","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the rulemaking proceeding under subsection (b), the Administrator shall consider, or address through other means, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc07797d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Flight request and dispatch procedures, including performance-based flight dispatch procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc07797e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Pilot training standards, including establishment of training standards in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc07797f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing controlled flight into terrain; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc077980-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recovery from inadvertent flight into instrument meteorological conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077981-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Safety-enhancing technology and equipment, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc077982-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" helicopter terrain awareness and warning systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc077983-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" radar altimeters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc077984-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" devices that perform the function of flight data recorders and cockpit voice recorders, to the extent feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077985-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other matters as the Administrator considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc077986-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In issuing a final rule under subsection (b), the Administrator, at a minimum, shall consider, or address through other means, the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc077987-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Flight risk evaluation program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall ensure that a part 135 certificate holder providing helicopter air ambulance services—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc077988-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishes a flight risk evaluation program, based on FAA Notice 8000.301 issued by the Administration on ","children":[{"tag":"date","attrib":{"date":"2005-08-01"},"text":"August 1, 2005","children":[],"tail":", including any updates thereto;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc077989-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as part of the flight risk evaluation program, develops a checklist for use by pilots in determining whether a flight request should be accepted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc07798a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires the pilots of the certificate holder to use the checklist.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc07798b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operational control center","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall ensure that a part 135 certificate holder providing helicopter air ambulance services using 10 or more helicopters has an operational control center that meets such requirements as the Administrator may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc07798c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent Actions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc07798d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon completion of the rulemaking required under subsection (b), the Administrator shall address through a follow-on rulemaking, or through such other means that the Administrator considers appropriate, the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc07798e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Pilot training standards, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc07798f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mandatory training requirements, including a minimum time for completing the training requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc077990-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training subject areas, such as communications procedures and appropriate technology use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc077991-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/e/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishment of training standards in—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcc077992-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/e/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crew resource management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc077993-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/e/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flight risk evaluation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc077994-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/e/1/A/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operational control of the pilot in command; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc077995-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/e/1/A/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use of flight simulation training devices and line-oriented flight training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc077996-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of safety equipment that should be worn or used by flight crewmembers and medical personnel on a flight, including the possible use of shoulder harnesses, helmets, seatbelts, and fire resistant clothing to enhance crash survivability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077997-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection shall be construed to require the Administrator to propose or finalize any rule that would derogate or supersede the rule required to be finalized under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc077998-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc077999-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Part 135","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “part 135” means part 135 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc07799a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44730/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Part 135 certificate holder","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “part 135 certificate holder” means a person holding an operating certificate issued under part 119 of title 14, Code of Federal Regulations, that is authorized to conduct civil helicopter air ambulance operations under part 135.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc07799b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIII/s306/a"},"text":"Pub. L. 112–95, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/58"},"text":"126 Stat. 58","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIII/s301/a"},"text":"Pub. L. 118–63, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1066"},"text":"138 Stat. 1066","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc07799c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc07799d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc07799e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s301/a/1"},"text":"Pub. L. 118–63, § 301(a)(1)","children":[],"tail":", struck out “not later than 180 days after the date of enactment of this section,” after “paragraph (2),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s301/a/2"},"text":"Pub. L. 118–63, § 301(a)(2)","children":[],"tail":", substituted “consider, or address through other means, the following” for “address the following” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s301/a/3"},"text":"Pub. L. 118–63, § 301(a)(3)","children":[],"tail":", substituted “consider, or address through other means, the following” for “provide for the following” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s301/a/4/A"},"text":"Pub. L. 118–63, § 301(a)(4)(A)","children":[],"tail":", substituted “Subsequent Actions” for “Subsequent Rulemaking” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s301/a/4/B"},"text":"Pub. L. 118–63, § 301(a)(4)(B)","children":[],"tail":", substituted “shall address through a follow-on rulemaking, or through such other means that the Administrator considers appropriate, the following:” for “shall conduct a follow-on rulemaking to address the following:” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s301/a/4/C"},"text":"Pub. L. 118–63, § 301(a)(4)(C)","children":[],"tail":", (D), redesignated par. (3) as (2) and struck out former par. (2). Prior to amendment, text of par. (2) read as follows: “Not later than 180 days after the date of issuance of a final rule under subsection (b), the Administrator shall initiate the rulemaking under this subsection.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
