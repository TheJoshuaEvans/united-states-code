{"tag":"section","attrib":{"id":"idcbe60f73-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44507"},"text":null,"children":[{"tag":"num","attrib":{"value":"44507"},"text":"§ 44507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regions and centers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Civil Aeromedical Institute established by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s106/j"},"text":"section 106(j) of this title","children":[],"tail":" may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbe60f74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44507/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct civil aeromedical research, including research related to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbe60f75-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44507/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection and survival of aircraft occupants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe60f76-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44507/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical accident investigation and airman medical certification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe60f77-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44507/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" toxicology and the effects of drugs on human performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe60f78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44507/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of disease and disability on human performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe60f79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44507/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vision and its relationship to human performance and equipment design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe60f7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44507/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human factors of flight crews, air traffic controllers, mechanics, inspectors, airway facility technicians, and other individuals involved in operating and maintaining aircraft and air traffic control equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe60f7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44507/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agency work force optimization, including training, equipment design, reduction of errors, and identification of candidate tasks for automation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe60f7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44507/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make comments to the Administrator of the Federal Aviation Administration on human factors aspects of proposed air safety regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe60f7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44507/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make comments to the Administrator on human factors aspects of proposed training programs, equipment requirements, standards, and procedures for aviation personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe60f7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44507/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise, assist, and represent the Federal Aviation Administration in the human factors aspects of joint projects between the Administration and the National Aeronautics and Space Administration, other departments, agencies, and instrumentalities of the United States Government, industry, and governments of foreign countries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe60f7f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44507/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide medical consultation services to the Administrator about medical certification of airmen.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbe60f80-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1179"},"text":"108 Stat. 1179","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tV/s5