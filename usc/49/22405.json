{"tag":"section","attrib":{"id":"idcb250904-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22405"},"text":null,"children":[{"tag":"num","attrib":{"value":"22405"},"text":"§ 22405.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Substantive criteria and standards","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb250905-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22405/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish in the Federal Register and post on a website of the Department of Transportation the substantive criteria and standards used by the Secretary to determine whether to approve or disapprove applications submitted under section 22402; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb250906-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22405/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that adequate procedures and guidelines are in place to permit the filing of complete applications not later than 30 days after the publication referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb250907-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI/s21301/g"},"text":"Pub. L. 117–58, div. B, title I, § 21301(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/690"},"text":"135 Stat. 690","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
