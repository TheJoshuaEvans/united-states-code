{"tag":"section","attrib":{"id":"idcad19186-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506"},"text":null,"children":[{"tag":"num","attrib":{"value":"5506"},"text":"§ 5506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advanced transportation research initiative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad19187-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Eligible Entity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “eligible entity” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad19188-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad19189-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local government agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad1918a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an institution of higher education (as defined in section 102 of the Higher Education Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s1002"},"text":"20 U.S.C. 1002","children":[],"tail":")), including a university transportation center established under section 5505;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad1918b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization, including a nonprofit research organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad1918c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a private sector organization working in collaboration with an entity described in any of paragraphs (1) through (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad1918d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation (referred to in this section as the “Secretary”) shall establish an advanced transportation research pilot program under which the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad1918e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish a process for eligible entities to submit to the Secretary unsolicited research proposals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad1918f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enter into arrangements with 1 or more eligible entities to fund research proposed under paragraph (1), in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad19190-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Research","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may enter into an arrangement with an eligible entity under this section to fund research that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad19191-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" addresses—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad19192-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a research need identified by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcad19193-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad19194-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of a modal administration of the Department of Transportation; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad19195-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an issue that the Secretary determines to be important; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad19196-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is not duplicative of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad19197-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal research project; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad19198-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any project for which funding is provided by another Federal agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad19199-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad1919a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review each research proposal submitted under the pilot program established under subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad1919b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad1919c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if funding is denied for the research proposal—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcad1919d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide to the eligible entity that submitted the proposal a written notice of the denial that, as applicable—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcad1919e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/d/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explains why the research proposal was not selected, including whether the research proposal fails to cover an area of need; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcad1919f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/d/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommends that the research proposal be submitted to another research program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad191a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the Secretary recommends that the research proposal be submitted to another research program under clause (i)(II), provide guidance and direction to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcad191a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/d/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligible entity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcad191a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/d/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed research program office; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad191a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the research proposal is selected for funding—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcad191a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the eligible entity that submitted the proposal a written notice of the selection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad191a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seek to enter into an arrangement with the eligible entity to provide funding for the proposed research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad191a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad191a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that the activities carried out under subsection (c) are coordinated with, and do not duplicate the efforts of, programs of the Department of Transportation and other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad191a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intraagency coordination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall coordinate the research carried out under this section with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad191a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research, education, and technology transfer activities carried out by grant recipients under section 5505; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad191aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research, development, demonstration, and commercial application activities of other relevant programs of the Department of Transportation, including all modal administrations of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad191ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interagency collaboration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall coordinate, as appropriate, regarding fundamental research with the potential for application in the transportation sector with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad191ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the Office of Science and Technology Policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad191ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Science Foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad191ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Energy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad191af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director of the National Institute of Standards and Technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad191b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Homeland Security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad191b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the National Oceanic and Atmospheric Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad191b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Defense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad191b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/e/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the heads of other appropriate Federal agencies, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad191b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review, Evaluation, and Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than biennially, in accordance with the plan developed under section 6503, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad191b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and evaluate the pilot program established under subsection (b), including the research carried out under that pilot program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad191b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make public on a website of the Department of Transportation a report describing the review and evaluation under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad191b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad191b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of an activity carried out under this section shall not exceed 80 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad191b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All costs directly incurred by the non-Federal partners (including personnel, travel, facility, and hardware development costs) shall be credited toward the non-Federal share of the cost of an activity carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad191ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Certain Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of any amounts made available to carry out this section for a fiscal year, the Secretary may use not more than 1.5 percent for coordination, evaluation, and oversight activities under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad191bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5506/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary to carry out this section $50,000,000 for each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad191bc-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tV/s25013/a"},"text":"Pub. L. 117–58, div. B, title V, § 25013(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/867"},"text":"135 Stat. 867","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad191bd-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad191be-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcad191bf-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5506, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tV/s5111/a"},"text":"Pub. L. 105–178, title V, § 5111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/444"},"text":"112 Stat. 444","children":[],"tail":"; amended "},{"tag"