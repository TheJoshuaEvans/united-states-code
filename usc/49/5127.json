{"tag":"section","attrib":{"id":"idca95e884-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5127"},"text":null,"children":[{"tag":"num","attrib":{"value":"5127"},"text":"§ 5127.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca95e885-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5127/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing and Venue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in section 20114(c), a person adversely affected or aggrieved by a final action of the Secretary under this chapter may petition for review of the final action in the United States Court of Appeals for the District of Columbia or in the court of appeals for the United States for the circuit in which the person resides or has its principal place of business. The petition must be filed not more than 60 days after the Secretary’s action becomes final.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e886-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5127/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judicial Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When a petition is filed under subsection (a), the clerk of the court immediately shall send a copy of the petition to the Secretary. The Secretary shall file with the court a record of any proceeding in which the final action was issued, as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s2112"},"text":"section 2112 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e887-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5127/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Court","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court has exclusive jurisdiction, as provided in subchapter II of chapter 5 of title 5, to affirm or set aside any part of the Secretary’s final action and may order the Secretary to conduct further proceedings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e888-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5127/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement for Prior Objection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In reviewing a final action under this section, the court may consider an objection to a final action of the Secretary only if the objection was made in the course of a proceeding or review conducted by the Secretary or if there was a reasonable ground for not making the objection in the proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca95e889-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII/s7123/b"},"text":"Pub. L. 109–59, title VII, § 7123(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1907"},"text":"119 Stat. 1907","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca95e88a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca95e88b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idca95e88c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 5127 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5128"},"text":"section 5128 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
