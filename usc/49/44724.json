{"tag":"section","attrib":{"id":"idcc052ffd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44724"},"text":null,"children":[{"tag":"num","attrib":{"value":"44724"},"text":"§ 44724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manipulation of flight controls","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc052ffe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No pilot in command of an aircraft may allow an individual who does not hold—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc052fff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44724/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a valid private pilots certificate issued by the Administrator of the Federal Aviation Administration under part 61 of title 14, Code of Federal Regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc053000-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44724/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the appropriate medical certificate issued by the Administrator under part 67 of such title,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"to manipulate the controls of an aircraft if the pilot knows or should have known that the individual is attempting to set a record or engage in an aeronautical competition or aeronautical feat, as defined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc053001-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation of Airmen Certificates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall issue an order revoking a certificate issued to an airman under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44703"},"text":"section 44703 of this title","children":[],"tail":" if the Administrator finds that while acting as a pilot in command of an aircraft, the airman has permitted another individual to manipulate the controls of the aircraft in violation of subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc053002-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44724/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pilot in Command Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “pilot in command” has the meaning given such term by section 1.1 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc053003-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264/tVI/s602/a/1"},"text":"Pub. L. 104–264, title VI, § 602(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3263"},"text":"110 Stat. 3263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc053004-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc053005-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc053006-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided, section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", and not to be construed as affecting funds made available for a fiscal year ending before "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/s3"},"text":"section 3 of Pub. L. 104–264","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
