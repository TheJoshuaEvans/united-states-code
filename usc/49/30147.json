{"tag":"section","attrib":{"id":"idcb4fea42-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30147"},"text":null,"children":[{"tag":"num","attrib":{"value":"30147"},"text":"§ 30147.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Responsibility for defects and noncompliance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb4fea43-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30147/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deeming Defect or Noncompliance to Certain Vehicles and Importer as Manufacturer","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4fea44-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30147/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out sections 30117(b), 30118–30121, and 30166(f) of this title—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb4fea45-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30147/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a defect or noncompliance with an applicable motor vehicle safety standard prescribed under this chapter for a motor vehicle originally manufactured for import into the United States, an imported motor vehicle having a valid certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30146/a/1"},"text":"section 30146(a)(1) of this title","children":[],"tail":" and decided to be substantially similar to that motor vehicle shall be deemed as having the same defect or as not complying with the same standard unless the manufacturer or importer registered under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s30141/c"},"text":"section 30141(c) of this title","children":[],"tail":" demonstrates otherwise to the Secretary of Transportation; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4fea46-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30147/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the registered importer shall be deemed to be the manufacturer of any motor vehicle that the importer imports or brings into compliance with the standards for an individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30142"},"text":"section 30142 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea47-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30147/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall publish in the Federal Register notice of any defect or noncompliance under paragraph (1)(A) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fea48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30147/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial Responsibility Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require by regulation each registered importer (including any successor in interest) to provide and maintain evidence, satisfactory to the Secretary, of sufficient financial responsibility to meet its obligations under sections 30117(b), 30118–30121, and 30166(f) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb4fea49-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/966"},"text":"108 Stat. 966","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb4fea4a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb4fea4b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb4fea4c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30147(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(d)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563"},"text":"Pub. L. 89–563","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/718"},"text":"80 Stat. 718","children":[],"tail":", § 108(d); added "},{"tag":"html:span","attrib":{},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/562/s2/b"},"text":"Pub. L. 100–562, § 2(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2821"},"text":"102 Stat. 2821","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30147(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(d)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “(relating to discovery, notification, and remedy of motor vehicle defects)” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(A), the words “for a motor vehicle” are substituted for “in, or regarding, any motor vehicle” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(B), the word “compliance” is substituted for “conformity” for consistency in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
