{"tag":"section","attrib":{"id":"idcad64d74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304"},"text":null,"children":[{"tag":"num","attrib":{"value":"6304"},"text":"§ 6304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Transportation Library","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad64d75-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose and Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To support the information management and decisionmaking needs of transportation officials at the Federal, State, and local levels, there is established in the Bureau a National Transportation Library which shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad64d76-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be headed by an individual who is highly qualified in library and information science;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d77-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, preserve, and manage transportation information and information products and services for use by the Department, other Federal agencies, and the general public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide reference and research assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as a central depository for research results and technical publications of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a central clearinghouse for transportation data and information of the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as coordinator and policy lead for transportation information access;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide transportation information and information products and services to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad64d7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad64d7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad64d7f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public and private organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad64d80-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals, within the United States and internationally;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d81-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate efforts among, and cooperate with, transportation libraries, information providers, and technical assistance centers, in conjunction with private industry and other transportation library and information centers, with the goal of developing a comprehensive transportation information and knowledge network that supports the activities described in section 6302(b)(3)(B)(vi); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage in such other activities as the Director determines to be necessary and as the resources of the Library permit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad64d83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall publicize, facilitate, and promote access to the information products and services described in subsection (a), to improve the ability of the transportation community to share information and the ability of the Director to make statistics and other information readily accessible as required under section 6302(b)(3)(B)(x).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad64d84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad64d85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out this section, the Director may enter into agreements with, award grants to, and receive amounts from, any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad64d86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State or local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad64d87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad64d88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" business; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad64d89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts, grants, and agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Library may initiate and support specific information and data management, access, and exchange activities in connection with matters relating to the Department’s strategic goals, knowledge networking, and national and international cooperation, by entering into contracts or other agreements or awarding grants for the conduct of such activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amounts received by the Library as payment for library products and services or other activities shall be made available to the Director to carry out this section, deposited in the Office of the Assistant Secretary for Research and Technology of the Department of Transportation’s general fund account, and remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad64d8c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tII/s52011/a"},"text":"Pub. L. 112–141, div. E, title II, § 52011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/890"},"text":"126 Stat. 890","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/76/dL/tI"},"text":"Pub. L. 113–76, div. L, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/574"},"text":"128 Stat. 574","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad64d8d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcad64d8e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcad64d8f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Office of the Assistant Secretary for Research and Technology of the Department of Transportation’s” substituted for “Research and Innovative Technology Administration’s” in subsec. (c)(3) on authority of title I of div. L of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76"},"text":"Pub. L. 113–76","children":[],"tail":", set out in part as a Transfer of Duties and Powers note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s112"},"text":"section 112 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcad64d90-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
