{"tag":"section","attrib":{"id":"idcb3f2189-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26103"},"text":null,"children":[{"tag":"num","attrib":{"value":"26103"},"text":"§ 26103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety regulations and evaluation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3f218a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26103/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall promulgate such safety regulations as may be necessary for high-speed rail services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f218b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26103/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall, before promulgating such regulations, consult with developers of new high-speed rail technologies to develop a method for evaluating safety performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f218c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26103/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may solicit feedback from relevant safety experts or representatives of rail employees who perform work on similar technology or who may be expected to perform work on new technology, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb3f218d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/440/tI/s103/a/2"},"text":"Pub. L. 103–440, title I, § 103(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4618"},"text":"108 Stat. 4618","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22419/a"},"text":"Pub. L. 117–58, div. B, title II, § 22419(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/749"},"text":"135 Stat. 749","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb3f218e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb3f218f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb3f2190-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" amended section generally. Prior to amendment, text read as follows: “The Secretary shall promulgate such safety regulations as may be necessary for high-speed rail services.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
