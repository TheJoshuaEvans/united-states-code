{"tag":"section","attrib":{"id":"idcc28e4a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44915"},"text":null,"children":[{"tag":"num","attrib":{"value":"44915"},"text":"§ 44915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemptions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Transportation Security Administration may exempt from sections 44901, 44903(a)–(c) and (e), 44906, 44935, and 44936 of this title airports in Alaska served only by air carriers that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc28e4a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44915/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hold certificates issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc28e4a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44915/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate aircraft with certificates for a maximum gross takeoff weight of less than 12,500 pounds; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc28e4a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44915/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" board passengers, or load property intended to be carried in an aircraft cabin, that will be screened under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44901"},"text":"section 44901 of this title","children":[],"tail":" at another airport in Alaska before the passengers board, or the property is loaded on, an aircraft for a place outside Alaska."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc28e4a4-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1215"},"text":"108 Stat. 1215","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s101/f/7"},"text":"Pub. L. 107–71, title I, § 101(f)(7)","children":[],"tail":", (9), "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/603"},"text":"115 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/d/13"},"text":"Pub. L. 115–254, div. K, title I, § 1991(d)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3635"},"text":"132 Stat. 3635","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc28e4a5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc28e4a6-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc28e4a7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"child