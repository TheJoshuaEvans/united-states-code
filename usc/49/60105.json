"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2004(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “applicable to same” are omitted as surplus. The words “for the facilities and transportation that complies with subsections (b) and (c) of this section” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the words “to which the certification applies” and “to whom the certification applies” are added because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “Federal safety” and “pursuant to State law” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(7), the words “injunctive relief and civil penalties” are substituted for “injunctive and monetary sanctions” for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), before clause (A), the word “annual” is omitted as surplus. The words “in such form as the Secretary may by regulation provide” are omitted as surplus because of 49:322(a). In clause (B), the words “or loss” are added for consistency in the revised title and with other titles of the United States Code. In clause (C), the words “a detail of” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “with respect” and “new or amended Federal” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “conduct whatever . . . may be necessary” and “fully” are omitted as surplus. The words “with the Secretary” are substituted for “in any monitoring of their programs” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “prescribed under this chapter” are added for clarity. The word “reasonable” is omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc77a128-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc77a129-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (b)(8), (9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" added pars. (8) and (9)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/468"},"text":"Pub. L. 109–468","children":[],"tail":" amended par. (4) generally. Prior to amendment, par. (4) read as follows: “is encouraging and promoting programs designed to prevent damage by demolition, excavation, tunneling, or construction activity to the pipeline facilities to which the certification applies;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304"},"text":"Pub. L. 104–304","children":[],"tail":" substituted “State pipeline safety program certifications” for “State certifications” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc77a12a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc77a12b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dR/tII/s202/b/2"},"text":"Pub. L. 116–260, div. R, title II, § 202(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2239"},"text":"134 Stat. 2239","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dR/tII/s202/b/2"},"text":"“The Secretary [of Transportation] shall promulgate regulations to require that a State authority with a certification in effect under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s60105"},"text":"section 60105 of title 49","children":[],"tail":", United States Code, has a sufficient number of qualified inspectors to ensure safe operations, as determined by the State Inspection Calculation Tool and other factors determined to be appropriate by the Secretary.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dR/tII/s202/b/3"},"text":"Pub. L. 116–260, div. R, title II, § 202(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2239"},"text":"134 Stat. 2239","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dR/tII/s202/b/3"},"text":"“Not later than 2 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"], the Secretary [of Transportation] shall promulgate regulations to implement the amendments made by this subsection [amending this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
