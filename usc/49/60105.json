{"tag":"section","attrib":{"id":"idcc77a10a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105"},"text":null,"children":[{"tag":"num","attrib":{"value":"60105"},"text":"§ 60105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State pipeline safety program certifications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc77a10b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements and Submission","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this section and sections 60114 and 60121 of this title, the Secretary of Transportation may not prescribe or enforce safety standards and practices for an intrastate pipeline facility or intrastate pipeline transportation to the extent that the safety standards and practices are regulated by a State authority (including a municipality if the standards and practices apply to intrastate gas pipeline transportation) that submits to the Secretary annually a certification for the facilities and transportation that complies with subsections (b) and (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc77a10c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each certification submitted under subsection (a) of this section shall state that the State authority—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc77a10d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has regulatory jurisdiction over the standards and practices to which the certification applies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc77a10e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has adopted, by the date of certification, each applicable standard prescribed under this chapter or, if a standard under this chapter was prescribed not later than 120 days before certification, is taking steps to adopt that standard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc77a10f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is enforcing each adopted standard through ways that include inspections conducted by State employees meeting the qualifications the Secretary prescribes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s60107/d/1/C"},"text":"section 60107(d)(1)(C) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc77a110-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is encouraging and promoting the establishment of a program designed to prevent damage by demolition, excavation, tunneling, or construction activity to the pipeline facilities to which the certification applies that subjects persons who violate the applicable requirements of that program to civil penalties and other enforcement actions that are substantially the same as are provided under this chapter, and addresses the elements in section 60134(b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc77a111-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may require record maintenance, reporting, and inspection substantially the same as provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s60117"},"text":"section 60117 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc77a112-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may require that plans for inspection and maintenance under section 60108 (a) and (b) of this title be filed for approval;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc77a113-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may enforce safety standards of the authority under a law of the State by injunctive relief and civil penalties substantially the same as provided under sections 60120 and 60122(a)(1) and (b)–(f) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc77a114-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the capability to sufficiently review and evaluate the adequacy of the plans and manuals described in section 60109(e)(7)(C)(i); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc77a115-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has a sufficient number of employees described in paragraph (3) to ensure safe operations of pipeline facilities, updating the State Inspection Calculation Tool to take into account factors including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc77a116-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of miles of natural gas and hazardous liquid pipelines in the State, including the number of miles of cast iron and bare steel pipelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc77a117-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of services in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc77a118-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the age of the gas distribution system in the State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc77a119-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/b/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental factors that could impact the integrity of the pipeline, including relevant geological issues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc77a11a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc77a11b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each certification submitted under subsection (a) of this section shall include a report that contains—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc77a11c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of each person to whom the certification applies that is subject to the safety jurisdiction of the State authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc77a11d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each accident or incident reported during the prior 12 months by that person involving a fatality, personal injury requiring hospitalization, or property damage or loss of more than an amount the Secretary establishes (even if the person sustaining the fatality, personal injury, or property damage or loss is not subject to the safety jurisdiction of the authority), any other accident the authority considers significant, and a summary of the investigation by the authority of the cause and circumstances surrounding the accident or incident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc77a11e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the record maintenance, reporting, and inspection practices conducted by the authority to enforce compliance with safety standards prescribed under this chapter to which the certification applies, including the number of inspections of pipeline facilities the authority made during the prior 12 months; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc77a11f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information the Secretary requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc77a120-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The report included in the first certification submitted under subsection (a) of this section is only required to state information available at the time of certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc77a121-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A certification in effect under this section does not apply to safety standards prescribed under this chapter after the date of certification. This chapter applies to each applicable safety standard prescribed after the date of certification until the State authority adopts the standard and submits the appropriate certification to the Secretary under subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc77a122-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may monitor a safety program established under this section to ensure that the program complies with the certification. A State authority shall cooperate with the Secretary under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc77a123-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60105/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rejections of Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If after receiving a certification the Secretary decides the State authority is not enforcing satisfactorily compliance with applicable safety standards prescribed under this chapter, the Secretary may reject the certification, assert United States Government jurisdiction, or take other appropriate action to achieve adequate enforcement. The Secretary shall give the authority notice and an opportunity for a hearing before taking final action under this subsection. When notice is given, the burden of proof is on the authority to demonstrate that it is enforcing satisfactorily compliance with the prescribed standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc77a124-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1309"},"text":"108 Stat. 1309","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/304/s20/a"},"text":"Pub. L. 104–304, § 20(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3804"},"text":"110 Stat. 3804","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/468/s2/b/1"},"text":"Pub. L. 109–468, § 2(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3487"},"text":"120 Stat. 3487","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dR/tII/s202/b/1"},"text":"Pub. L. 116–260, div. R, title II, § 202(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2239"},"text":"134 Stat. 2239","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc77a125-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc77a126-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc77a127-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60105(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1674(a) (1st sentence words before “that such State agency”).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 12,