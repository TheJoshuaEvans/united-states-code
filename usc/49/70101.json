{"tag":"section","attrib":{"id":"idcc8842ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101"},"text":null,"children":[{"tag":"num","attrib":{"value":"70101"},"text":"§ 70101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National multimodal freight policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc884300-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the policy of the United States to maintain and improve the condition and performance of the National Multimodal Freight Network established under section 70103 to ensure that the Network provides a foundation for the United States to compete in the global economy and achieve the goals described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc884301-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the national multimodal freight policy are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc884302-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to identify infrastructure improvements, policies, and operational innovations that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc884303-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strengthen the contribution of the National Multimodal Freight Network to the economic competitiveness of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884304-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce congestion and eliminate bottlenecks on the National Multimodal Freight Network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884305-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase productivity, particularly for domestic industries and businesses that create high-value jobs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884306-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the safety, security, efficiency, and resiliency of multimodal freight transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884307-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to achieve and maintain a state of good repair on the National Multimodal Freight Network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884308-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to use innovation and advanced technology to improve the safety, efficiency, and reliability of the National Multimodal Freight Network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884309-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the economic efficiency and productivity of the National Multimodal Freight Network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88430a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the reliability of freight transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88430b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to improve the short- and long-distance movement of goods that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc88430c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel across rural areas between population centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc88430d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel between rural areas and population centers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc88430e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" travel from the Nation’s ports, airports, and gateways to the National Multimodal Freight Network;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88430f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the flexibility of States to support multi-State corridor planning and the creation of multi-State organizations to increase the ability of States to address multimodal freight connectivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884310-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the adverse environmental impacts of freight movement on the National Multimodal Freight Network; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884311-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pursue the goals described in this subsection in a manner that is not burdensome to State and local governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc884312-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary for Multimodal Freight, who shall be responsible for the oversight and implementation of the national multimodal freight policy, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc884313-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out sections 70102 and 70103;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884314-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist with the coordination of modal freight planning; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884315-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70101/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify interagency data sharing opportunities to promote freight planning and coordination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc884316-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVIII/s8001/a"},"text":"Pub. L. 114–94, div. A, title VIII, § 8001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1605"},"text":"129 Stat. 1605","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI/s21101/d/1"},"text":"Pub. L. 117–58, div. B, title I, § 21101(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/656"},"text":"135 Stat. 656","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc884317-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc884318-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcc884319-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 70101 was transferred and renumbered as ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50901"},"text":"section 50901 of Title 51","children":[],"tail":", National and Commercial Space Programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc88431a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" substituted “Assistant Secretary for Multimodal Freight” for “Under Secretary of Transportation for Policy” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc88431b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc88431c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
