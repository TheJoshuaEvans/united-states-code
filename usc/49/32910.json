{"tag":"section","attrib":{"id":"idcb89221e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32910"},"text":null,"children":[{"tag":"num","attrib":{"value":"32910"},"text":"§ 32910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb89221f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Powers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb892220-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32910/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out this chapter, the Secretary of Transportation or the Administrator of the Environmental Protection Agency may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb892221-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32910/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspect and copy records of any person at reasonable times;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb892222-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32910/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" order a person to file written reports or answers to specific questions, including reports or answers under oath; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb892223-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32910/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct hearings, administer oaths, take testimony, and subpena witnesses and records the Secretary or Administrator considers advisable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb892224-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32910/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A witness summoned under paragraph (1)(C) of this subsection is entitled to the same fee and mileage the witness would have been paid in a court of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb892225-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions To Enforce","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A civil action to enforce a subpena or order of the Secretary or Administrator under subsection (a) of this section may be brought in the district court of the United States for any judicial district in which the proceeding by the Secretary or Administrator is conducted. The court may punish a failure to obey an order of the court to comply with the subpena or order of the Secretary or Administrator as a contempt of court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb892226-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32910/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure of Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary and the Administrator each shall disclose information obtained under this chapter (except information obtained under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32904/c"},"text":"section 32904(c) of this title","children":[],"tail":") under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":". However, the Secretary or Administrator may withhold information under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":" only if the Secretary or Administrator decides that disclosure of the information would cause significant competitive damage. A matter referred to in section 552(b)(4) and relevant to an administrative or judicial proceeding under this chapter may be disclosed in that proceeding. A measurement or calculation under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s32904/c"},"text":"section 32904(c) of this title","children":[],"tail":" shall be disclosed under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" without regard to section 552(b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb892227-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32910/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may prescribe regulations to carry out duties of the Administrator under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb892228-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1070"},"text":"108 Stat. 1070","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/39"},"text":"Pub. L. 103–429, § 6(39)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4382"},"text":"108 Stat. 4382","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb892229-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb89222a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb89222b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32910(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2005(b)(1), (3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 20, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/513"},"text":"Pub. L. 92–513","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/947"},"text":"86 Stat. 947","children":[],"tail":", § 505(b), (d); added "},{"tag":"html:span","attrib":{},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/163/s301"},"text":"Pub. L. 94–163, § 301","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/89/909"},"text":"89 Stat. 909","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32910(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2005(b)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32910(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2005(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32910(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(no source).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the words “or their duly designated agents” are omitted as surplus because of 49:322(b) and section 3 of Reorganization Plan No. 3 of 1970 (eff. ","children":[{"tag":"date","attrib":{"date":"1970-12-02"},"text":"Dec. 2, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/2089"},"text":"84 Stat. 2089","children":[],"tail":"). In clause (A), the words “inspect and copy records of any person” are substituted for “require, by general or special orders, that any person . . . (B) provide . . . access to (and for the purpose of examination, the right to copy) any documentary evidence of such person” to eliminate unnecessary words. The words “which is relevant to any functions of the Secretary or the EPA Administrator under this subchapter” are omitted as covered by “In carrying out this chapter”. In clause (B), the word “order” is substituted for “require, by general or special orders”, and the words “including reports or answers under oath” are substituted for “Such reports and answers shall be made under oath or otherwise”, to eliminate unnecessary words. The words “in such form as the Secretary or EPA Administrator may prescribe” and “shall be filed with the Secretary or the EPA Administrator within such reasonable period as either may prescribe” are omitted as surplus because of subsection (d) of this section and 49:322(a). The words “relating to any function of the Secretary or the EPA Administrator under this subchapter” are omitted as surplus. In clause (C), the words “sit and act at such times and places” are omitted as being included in “conduct hearings”. The words “subpena witnesses” are substituted for “require, by subpena, the attendance and testimony of such witnesses” to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “A civil action to enforce a subpena or order of the Secretary or Administrator under subsection (a) of this section may be brought in the district court of the United States for the judicial district in which the proceeding by the Secretary or Administrator was conducted” are substituted for 15:2005(b)(2) (1st sentence) for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “to the public” are omitted as surplus. The words “However, the Secretary or the Administrator may withhold information” are substituted for “except that information may be withheld from disclosure” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (d) is added for convenience because throughout the chapter the Administrator is given authority to prescribe regulations to carry out duties of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb89222c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:32910(b) to clarify the restatement of 15:2005(b)(2) by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1994-07-05/s1"},"text":"section 1 of the Act of July 5, 1994","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Public Law 103–272","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1071"},"text":"108 Stat. 1071","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb89222d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb89222e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" substituted “any judicial district in which the proceeding by the Secretary or Administrator is conducted” for “the judicial district in which the proceeding by the Secretary or Administrator was conducted”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb89222f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb892230-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s9"},"text":"section 9 of Pub. L. 103–429","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
