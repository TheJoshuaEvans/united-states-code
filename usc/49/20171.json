{"tag":"section","attrib":{"id":"idcb18fb43-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171"},"text":null,"children":[{"tag":"num","attrib":{"value":"20171"},"text":"§ 20171.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for railroad freight cars placed into service in the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb18fb44-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb18fb45-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Component","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “component” means a part or subassembly of a railroad freight car.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb46-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Control","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “control” means the power, whether direct or indirect and whether or not exercised, through the ownership of a majority or a dominant minority of the total outstanding voting interest in an entity, representation on the board of directors of an entity, proxy voting on the board of directors of an entity, a special share in the entity, a contractual arrangement with the entity, a formal or informal arrangement to act in concert with an entity, or any other means, to determine, direct, make decisions, or cause decisions to be made for the entity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb47-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost of sensitive technology","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “cost of sensitive technology” means the aggregate cost of the sensitive technology located on a railroad freight car.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Country of concern","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “country of concern” means a country that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb18fb49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is identified by the Department of Commerce as a nonmarket economy country (as defined in section 771(18) of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677/18"},"text":"19 U.S.C. 1677(18)","children":[],"tail":")) as of the date of enactment of the Passenger Rail Expansion and Rail Safety Act of 2021;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was identified by the United States Trade Representative in the most recent report required by section 182 of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2242"},"text":"19 U.S.C. 2242","children":[],"tail":") as a foreign country included on the priority watch list (as defined in subsection (g)(3) of such section); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb4b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to monitoring by the Trade Representative under section 306 of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2416"},"text":"19 U.S.C. 2416","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Net cost","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “net cost” has the meaning given such term in chapter 4 of the USMCA or any subsequent free trade agreement between the United States, Mexico, and Canada.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified facility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “qualified facility” means a facility that is not owned or under the control of a state-owned enterprise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified manufacturer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “qualified manufacturer” means a railroad freight car manufacturer that is not owned or under the control of a state-owned enterprise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Railroad freight car","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “railroad freight car” means a car designed to carry freight or railroad personnel by rail, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb18fb50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a box car;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a refrigerator car;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb52-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a ventilator car;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb53-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intermodal well car;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb54-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/8/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a gondola car;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb55-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/8/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hopper car;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb56-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/8/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an auto rack car;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb57-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/8/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a flat car;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb58-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/8/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special car;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb59-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/8/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a caboose car;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb5a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/8/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a tank car; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb5b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/8/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a yard car.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb5c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sensitive technology","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “sensitive technology” means any device embedded with electronics, software, sensors, or other connectivity, that enables the device to connect to, collect data from, or exchange data with another device, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb18fb5d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" onboard telematics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remote monitoring software;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb5f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" firmware;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb60-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analytics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb61-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" global positioning system satellite and cellular location tracking systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb62-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/9/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" event status sensors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb63-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/9/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" predictive component condition and performance monitoring sensors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb64-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/9/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" similar sensitive technologies embedded into freight railcar components and sub-assemblies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb65-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State-owned enterprise","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “state-owned enterprise” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb18fb66-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity that is owned by, or under the control of, a national, provincial, or local government of a country of concern, or an agency of such government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb67-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual acting under the direction or influence of a government or agency described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Substantially transformed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “substantially transformed” means a component of a railroad freight car that undergoes an applicable change in tariff classification as a result of the manufacturing process, as described in chapter 4 and related annexes of the USMCA or any subsequent free trade agreement between the United States, Mexico, and Canada.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"USMCA","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “USMCA” has the meaning given the term in section 3 of the United States-Mexico-Canada Agreement Implementation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4502"},"text":"19 U.S.C. 4502","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb18fb6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Railroad Freight Cars.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb18fb6b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on railroad freight cars","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A railroad freight car wholly manufactured on or after the date that is 1 year after the date of issuance of the regulations required under subsection (c)(1) may only operate on the United States general railroad system of transportation if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb18fb6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the railroad freight car is manufactured, assembled, and substantially transformed, as applicable, by a qualified manufacturer in a qualified facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" none of the sensitive technology located on the railroad freight car, including components necessary to the functionality of the sensitive technology, originates from a country of concern or is sourced from a state-owned enterprise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" none of the content of the railroad freight car, excluding sensitive technology, originates from a country of concern or is sourced from a state-owned enterprise that has been determined by a recognized court or administrative agency of competent jurisdiction and legal authority to have violated or infringed valid United States intellectual property rights of another including such a finding by a Federal district court under title 35 or the U.S. International Trade Commission under section 337 of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1337"},"text":"19 U.S.C. 1337","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on railroad freight car content.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb18fb70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Percentage limitation.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idcb18fb71-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of issuance of the regulations required under subsection (c)(1), a railroad freight car described in paragraph (1) may operate on the United States general railroad system of transportation only if not more than 20 percent of the content of the railroad freight car, calculated by the net cost of all components of the car and excluding the cost of sensitive technology, originates from a country of concern or is sourced from a state-owned enterprise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb18fb72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Effective beginning on the date that is 3 years after the date of issuance of the regulations required under subsection (c)(1), a railroad freight car described in paragraph (1) may operate on the United States general railroad system of transportation only if not more than 15 percent of the content of the railroad freight car, calculated by the net cost of all components of the car and excluding the cost of sensitive technology, originates from a country of concern or is sourced from a state-owned enterprise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb73-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conflict","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The percentages specified in clauses (i) and (ii) of subparagraph (A), as applicable, shall apply notwithstanding any apparent conflict with provisions of chapter 4 of the USMCA.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb18fb74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations and Penalties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb18fb75-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of enactment of the Passenger Rail Expansion and Rail Safety Act of 2021, the Secretary of Transportation shall issue such regulations as are necessary to carry out this section, including for the monitoring and sensitive technology requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb76-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to provide a railroad freight car for operation on the United States general railroad system of transportation, the manufacturer of such car shall annually certify to the Secretary of Transportation that any railroad freight cars to be so provided meet the requirements under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb77-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb18fb78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Valid certification required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the time a railroad freight car begins operation on the United States general railroad system of transportation, the manufacturer of such railroad freight car shall have valid certification described in paragraph (2) for the year in which such car begins operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registration of noncompliant cars prohibited","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A railroad freight car manufacturer may not register, or cause to be registered, a railroad freight car that does not comply with the requirements under this section in the Association of American Railroad’s ","children":[{"tag":"ref","attrib":{"idref":"fn002075"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002075"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Association of American Railroads’ ”."}],"tail":" Umler system."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil penalties.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb18fb7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Pursuant to section 21301, the Secretary of Transportation may assess a civil penalty of not less than $100,000, but not more than $250,000, for each violation of this section for each railroad freight car.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on operation for violations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may prohibit a railroad freight car manufacturer with respect to which the Secretary has assessed more than 3 violations under subparagraph (A) from providing additional railroad freight cars for operation on the United States general railroad system of transportation until the Secretary determines—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb18fb7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/c/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such manufacturer is in compliance with this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb18fb7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20171/c/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all civil penalties assessed to such manufacturer pursuant to subparagraph (A) have been paid in full.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb18fb7f-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22425/a"},"text":"Pub. L. 117–58, div. B, title II, § 22425(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/753"},"text":"135 Stat. 753","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb18fb80-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb18fb81-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb18fb82-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Passenger Rail Expansion and Rail Safety Act of 2021, referred to in subsecs. (a)(4)(A) and (c)(1), is the date of enactment of title II of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
