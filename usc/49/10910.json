{"tag":"section","attrib":{"id":"idcae6ee92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10910"},"text":null,"children":[{"tag":"num","attrib":{"value":"10910"},"text":"§ 10910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other statutes and authorities","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in section 10908 or 10909 is intended to affect the traditional police powers of the State to require a rail carrier to comply with State and local environmental, public health, and public safety standards that are not unreasonably burdensome to interstate commerce and do not discriminate against rail carriers.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcae6ee93-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tVI/s605/a"},"text":"Pub. L. 110–432, div. A, title VI, § 605(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4905"},"text":"122 Stat. 4905","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcae6ee94-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcae6ee95-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcae6ee96-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For prior section 10910, see note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10907"},"text":"section 10907 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
