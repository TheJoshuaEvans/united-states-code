{"tag":"section","attrib":{"id":"idcb525b33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30170"},"text":null,"children":[{"tag":"num","attrib":{"value":"30170"},"text":"§ 30170.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal Penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb525b34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30170/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Liability for Falsifying or Withholding Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb525b35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30170/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person who violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1001"},"text":"section 1001 of title 18","children":[],"tail":" with respect to the reporting requirements of section 30166, with the specific intention of misleading the Secretary with respect to motor vehicle or motor vehicle equipment safety related defects that have caused death or serious bodily injury to an individual (as defined in section 1365(g)(3) "},{"tag":"ref","attrib":{"idref":"fn002111"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002111"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of title 18), shall be subject to criminal penalties of a fine under title 18, or imprisoned for not more than 15 years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb525b36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30170/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safe harbor to encourage reporting and for whistle blowers.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb525b37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30170/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Correction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person described in paragraph (1) shall not be subject to criminal penalties under this subsection if: (1) at the time of the violation, such person does not know that the violation would result in an accident causing death or serious bodily injury; and (2) the person corrects any improper reports or failure to report within a reasonable time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb525b38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30170/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reasonable time and sufficiency of correction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish by regulation what constitutes a reasonable time for the purposes of subparagraph (A) and what manner of correction is sufficient for purposes of subparagraph (A). The Secretary shall issue a final rule under this subparagraph within 90 days of the date of the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb525b39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30170/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not take effect before the final rule under subparagraph (B) takes effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb525b3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30170/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination with Department of Justice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General may bring an action, or initiate grand jury proceedings, for a violation of subsection (a) only at the request of the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb525b3b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/414/s5/b/1"},"text":"Pub. L. 106–414, § 5(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1803"},"text":"114 Stat. 1803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb525b3c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb525b3d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb525b3e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1365/g/3"},"text":"Section 1365(g)(3) of title 18","children":[],"tail":", referred to in subsec. (a)(1), was redesignated "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1365/h/3"},"text":"section 1365(h)(3) of title 18","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/107/307/s2/1"},"text":"Pub. L. 107–307, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2445"},"text":"116 Stat. 2445","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (a)(2)(B), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/414"},"text":"Pub. L. 106–414","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
