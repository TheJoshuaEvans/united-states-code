{"tag":"section","attrib":{"id":"idcb202743-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21311"},"text":null,"children":[{"tag":"num","attrib":{"value":"21311"},"text":"§ 21311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records and reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb202744-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records and Reports Under Chapter","children":[],"tail":" 201.—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person shall be fined under title 18, imprisoned for not more than 2 years, or both, if the person knowingly and willfully—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb202745-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21311/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes a false entry in a record or report required to be made or preserved under chapter 201 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb202746-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21311/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destroys, mutilates, changes, or by another means falsifies such a record or report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb202747-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21311/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not enter required specified facts and transactions in such a record or report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb202748-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21311/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes or preserves such a record or report in violation of a regulation prescribed or order issued under chapter 201 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb202749-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21311/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files a false record or report with the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb20274a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accident and Incident Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A railroad carrier not filing a report in violation of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20901"},"text":"section 20901 of this title","children":[],"tail":" shall be fined not more than $2,500. A separate violation occurs for each day the violation continues."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb20274b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/893"},"text":"108 Stat. 893","children":[],"tail":"; "},{"tag":"ref","attrib":{"hr