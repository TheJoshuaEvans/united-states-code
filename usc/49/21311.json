ml:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21311(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:438(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458"},"text":"Pub. L. 91–458","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/971"},"text":"84 Stat. 971","children":[],"tail":", § 209(e); added "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/423/s7"},"text":"Pub. L. 96–423, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1814"},"text":"94 Stat. 1814","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21311(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:39 (related to fine).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1910-05-06/ch208/s2"},"text":"May 6, 1910, ch. 208, § 2","children":[],"tail":" (related to fine), "},{"tag":"html:a","attrib":{"href":"/us/stat/36/351"},"text":"36 Stat. 351","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633/s204/b"},"text":"Pub. L. 93–633, § 204(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2166"},"text":"88 Stat. 2166","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s15/2"},"text":"Pub. L. 100–342, § 15(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/634"},"text":"102 Stat. 634","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 3, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/365/s4/a/3"},"text":"Pub. L. 102–365, § 4(a)(3)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/973"},"text":"106 Stat. 973","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “fined under title 18” are substituted for “fined not more than $5,000” for consistency with title 18. In clause (1), the word “prepared” is omitted as surplus. In clause (4), the word “prepares” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “shall be deemed guilty of a misdemeanor” are omitted for consistency with title 18. The words “upon conviction thereof by a court of competent jurisdiction” and “punished by a” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb20274f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb202750-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":" amended subsec. (b) generally. Prior to amendment, text read as follows: “A railroad carrier not filing the report required by "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s20901"},"text":"section 20901 of this title","children":[],"tail":" shall be fined not more than $500 for each violation and not more than $500 for each day during which the report is overdue.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
