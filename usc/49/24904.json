{"tag":"section","attrib":{"id":"idcb3a65a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904"},"text":null,"children":[{"tag":"num","attrib":{"value":"24904"},"text":"§ 24904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Northeast Corridor planning","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb3a65a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Northeast Corridor Service Development Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3a65a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2022-03-31"},"text":"March 31, 2022","children":[],"tail":", the Northeast Corridor Commission established under section 24905 (referred to in this section as the “Commission”) shall submit a service development plan to Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3a65a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan required under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb3a65a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify key state-of-good-repair, capacity expansion, and capital improvement projects planned for the Northeast Corridor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3a65a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a coordinated and consensus-based plan covering a 15-year period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3a65a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify service objectives and the capital investments required to meet such objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3a65a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide a delivery-constrained strategy that identifies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb3a65a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capital investment phasing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3a65a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an evaluation of workforce needs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3a65aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies for managing resources and mitigating construction impacts on operations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3a65ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a financial strategy that identifies funding needs and potential funding sources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3a65ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall update the service development plan not less frequently than once every 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3a65ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Northeast Corridor Capital Investment Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3a65ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than November 1 of each year, the Commission shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb3a65af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop an annual capital investment plan for the Northeast Corridor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3a65b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" submit the capital investment plan to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb3a65b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3a65b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3a65b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3a65b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The plan required under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb3a65b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect coordination across the entire Northeast Corridor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3a65b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrate the individual capital plans developed by Amtrak, States, and commuter authorities in accordance with the cost allocation policy developed and approved under section 24905(c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3a65b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cover a period of 5 fiscal years, beginning with the fiscal year during which the plan is submitted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3a65b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notwithstanding section 24902(b), document the projects and programs being undertaken to advance the service objectives and capital investments identified in the Northeast Corridor service development plan developed under subsection (a), and the asset condition needs identified in the Northeast Corridor asset management plans, after considering—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb3a65b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the benefits and costs of capital investments in the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3a65ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project and program readiness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3a65bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operational impacts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3a65bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal and non-Federal funding availability;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3a65bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" categorize capital projects and programs as primarily associated with 1 of the categories listed under section 24319(c)(2)(C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3a65be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify capital projects and programs that are associated with more than 1 category described in subparagraph (E); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3a65bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include a financial plan that identifies—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb3a65c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding sources and financing methods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3a65c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of cost sharing agreements pursuant to the cost allocation policy developed under section 24905(c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3a65c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/G/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projects and programs that the Commission expects will receive Federal financial assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3a65c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/G/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the eligible entity or entities that the Commission expects—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcb3a65c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/G/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive the Federal financial assistance referred to in clause (iii); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcb3a65c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/2/G/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to implement each capital project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3a65c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review and coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Commission shall require that the information described in paragraph (2) be submitted in a timely manner to allow for a reasonable period of review by, and coordination with, affected agencies before the Commission submits the capital investment plan pursuant to paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3a65c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure To Develop a Capital Investment Plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a capital investment plan has not been developed by the Commission for a given fiscal year, then the funds assigned to the Northeast Corridor account established under section 24317(b) for that fiscal year may be spent only on capital projects and programs contained in the Commission’s capital investment plan for the prior fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3a65c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Northeast Corridor Capital Asset Management System.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3a65c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amtrak and other infrastructure owners that provide or support intercity rail passenger transportation along the Northeast Corridor shall develop an asset management system and use and update such system, as necessary, to develop submissions to the Northeast Corridor capital investment plan described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3a65ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Features","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The system required under paragraph (1) shall develop submissions that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb3a65cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with the transit asset management system (as defined in section 5326(a)(3)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3a65cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb3a65cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an inventory of all capital assets owned by the developer of the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3a65ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of condition of such capital assets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3a65cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the resources and processes that will be necessary to bring or to maintain such capital assets in a state of good repair; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb3a65d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/d/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of changes in the condition of such capital assets since the submission of the prior version of the plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3a65d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24904/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Northeast Corridor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “Northeast Corridor” means the main line between Boston, Massachusetts, and the District of Columbia, and the Northeast Corridor branch lines connecting to Harrisburg, Pennsylvania, Springfield, Massachusetts, and Spuyten Duyvil, New York, including the facilities and services used to operate and maintain those lines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb3a65d2-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11306/a/2"},"text":"Pub. L. 114–94, div. A, title XI, § 11306(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1658"},"text":"129 Stat. 1658","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22301"},"text":"Pub. L. 117–58, div. B, title II, § 22301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/714"},"text":"135 Stat. 714","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb3a65d3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb3a65d4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb3a65d5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 24904 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24903"},"text":"section 24903 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb3a65d6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22301/1"},"text":"Pub. L. 117–58, § 22301(1)","children":[],"tail":", (3), added subsec. (a) and struck out former subsec. (a), which required Northeast Corridor Commission to develop Northeast Corridor capital investment and financial plans."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22301/3"},"text":"Pub. L. 117–58, § 22301(3)","children":[],"tail":", added subsec. (b). Former subsec. (b) redesignated (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22301/2"},"text":"Pub. L. 117–58, § 22301(2)","children":[],"tail":", (4), redesignated subsec. (b) as (c) and substituted “spent only on capital projects and programs contained in the Commission’s capital investment plan for the prior fiscal year.” for “spent only on—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) capital projects described in clause (i) or (iii) of subsection (a)(2)(E) of this section; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) capital projects described in subsection (a)(2)(E)(iv) or (v) of this section that are for the sole benefit of Amtrak.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Former subsec. (c) redesignated (d).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22301/5"},"text":"Pub. L. 117–58, § 22301(5)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, subsec. (d) related to development of Northeast Corridor asset management system and Northeast Corridor asset management plan for each service territory."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22301/1"},"text":"Pub. L. 117–58, § 22301(1)","children":[],"tail":", (2), redesignated subsec. (c) as (d) and struck out former subsec. (d). Prior to amendment, text of subsec. (d) read as follows: “Not less frequently than once every 10 years, the Commission shall update the Northeast Corridor service development plan.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb3a65d7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb3a65d8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
