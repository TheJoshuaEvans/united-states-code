{"tag":"section","attrib":{"id":"idca6d5202-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313"},"text":null,"children":[{"tag":"num","attrib":{"value":"313"},"text":"§ 313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nontraditional and Emerging Transportation Technology Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca6d5203-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of enactment of this section, the Secretary of Transportation (referred to in this section as the “Secretary”) shall establish a council, to be known as the “Nontraditional and Emerging Transportation Technology Council” (referred to in this section as the “Council”), to address coordination on emerging technology issues across all modes of transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6d5204-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6d5205-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca6d5206-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, who shall serve as an ex officio member of the Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d5207-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Deputy Secretary of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d5208-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Under Secretary of Transportation for Policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d5209-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Research and Technology of the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d520a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary for Budget and Programs of the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d520b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Counsel of the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d520c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Chief Information Officer of the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d520d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Federal Aviation Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d520e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Federal Highway Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d520f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Federal Motor Carrier Safety Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d5210-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Federal Railroad Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d5211-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Federal Transit Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d5212-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Maritime Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d5213-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the National Highway Traffic Safety Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d5214-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Pipeline and Hazardous Materials Safety Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d5215-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/1/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other official of the Department of Transportation, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d5216-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chair and vice chair.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca6d5217-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chair","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Deputy Secretary of Transportation (or a designee) shall serve as Chair of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d5218-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vice chair","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary of Transportation for Policy (or a designee) shall serve as Vice Chair of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6d5219-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6d521a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identify and resolve jurisdictional and regulatory gaps or inconsistencies associated with nontraditional and emerging transportation technologies, modes, or projects pending or brought before the Department of Transportation to reduce, to the maximum extent practicable, impediments to the prompt and safe deployment of new and innovative transportation technology, including with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca6d521b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety oversight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d521c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d521d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding and financing issues;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d521e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate the response of the Department of Transportation to nontraditional and emerging transportation technology projects;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d521f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage with stakeholders in nontraditional and emerging transportation technology projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d5220-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop and establish Department of Transportation-wide processes, solutions, and best practices for identifying and managing nontraditional and emerging transportation technology projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6d5221-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Best Practices","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, the Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6d5222-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish initial guidelines to achieve the purposes described in subsection (c)(4); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d5223-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote each modal administration within the Department of Transportation to further test and support the advancement of nontraditional and emerging transportation technologies not specifically considered by the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6d5224-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Office of the Secretary shall provide support for the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6d5225-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall meet not less frequently than 4 times per year, at the call of the Chair.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6d5226-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lead Modal Administration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each nontraditional or emerging transportation technology, mode, or project associated with a jurisdictional or regulatory gap or inconsistency identified under subsection (c)(1), the Chair of the Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6d5227-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate a lead modal administration of the Department of Transportation for review of the technology, mode, or project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d5228-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for the detailing of staff between modal administrations or offices of the Department of Transportation as needed to maximize the sharing of experience and expertise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6d5229-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s313/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transparency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of establishment of the Council, and not less frequently than annually thereafter until ","children":[{"tag":"date","attrib":{"date":"2026-12-31"},"text":"December 31, 2026","children":[],"tail":", the Council shall post on a publicly accessible website a report describing the activities of the Council during the preceding calendar year."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca6d522a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tV/s25008/a"},"text":"Pub. L. 117–58, div. B, title V, § 25008(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/850"},"text":"135 Stat. 850","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca6d522b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca6d522c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca6d522d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (a) and (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
