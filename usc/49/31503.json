{"tag":"section","attrib":{"id":"idcb78807a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31503"},"text":null,"children":[{"tag":"num","attrib":{"value":"31503"},"text":"§ 31503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research, investigation, and testing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb78807b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may investigate and report on the need for regulation by the United States Government of sizes, weight, and combinations of motor vehicles and qualifications and maximum hours of service of employees of a motor carrier subject to subchapter I of chapter 135 of this title and a motor private carrier. The Secretary shall use the services of each department, agency, or instrumentality of the Government and each organization of motor carriers having special knowledge of a matter being investigated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb78807c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this chapter, the Secretary may use the services of a department, agency, or instrumentality of the Government having special knowledge about safety, to conduct scientific and technical research, investigation, and testing when necessary to promote safety of operation and equipment of motor vehicles. The Secretary may reimburse the department, agency, or instrumentality for the services provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb78807d-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449"},"text":"Pub. L. 97–449","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2439"},"text":"96 Stat. 2439","children":[],"tail":", § 3103; renumbered § 31503 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/c"},"text":"Pub. L. 103–272, § 1(c)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/745"},"text":"108 Stat. 745","children":[],"tail":", 1030; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s308/k/4"},"text":"Pub. L. 104–88, title III, § 308(k)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/948"},"text":"109 Stat. 948","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb78807e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb78807f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb788080-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html: