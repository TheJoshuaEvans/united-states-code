{"tag":"section","attrib":{"id":"idcb4fea78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164"},"text":null,"children":[{"tag":"num","attrib":{"value":"30164"},"text":"§ 30164.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process; conditions on importation of vehicles and equipment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb4fea79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designating Agents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A manufacturer offering a motor vehicle or motor vehicle equipment for import shall designate an agent on whom service of notices and process in administrative and judicial proceedings may be made. The designation shall be in writing and filed with the Secretary of Transportation. The designation may be changed in the same way as originally made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fea7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agent may be served at the agent’s office or usual place of residence. Service on the agent is deemed to be service on the manufacturer. If a manufacturer does not designate an agent, service may be made by posting the notice or process in the office of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fea7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Identifying Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A manufacturer (including an importer) offering a motor vehicle or motor vehicle equipment for import shall provide, upon request, such information that is necessary to identify and track the products as the Secretary, by rule, may specify, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4fea7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the product by name and the manufacturer’s address; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each retailer or distributor to which the manufacturer directly supplied motor vehicles or motor vehicle equipment over which the Secretary has jurisdiction under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fea7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations on the Import of a Motor Vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may issue regulations that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4fea7f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" condition the import of a motor vehicle or motor vehicle equipment on the manufacturer’s compliance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb4fea80-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4fea81-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paragraph (1) or (3) of section 30112(a) with respect to such motor vehicle or motor vehicle equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4fea82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the provision of reports and records required to be maintained with respect to such motor vehicle or motor vehicle equipment under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4fea83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a request for inspection of premises, vehicle, or equipment under section 30166;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4fea84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an order or voluntary agreement to remedy such vehicle or equipment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4fea85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/d/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rules implementing the requirements described in this subsection;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an opportunity for the manufacturer to present information before the Secretary’s determination as to whether the manufacturer’s imports should be restricted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a process by which a manufacturer may petition for reinstatement of its ability to import motor vehicles or motor vehicle equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fea88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirements of subsections (c) and (d) shall not apply to original manufacturers (or wholly owned subsidiaries) of motor vehicles that, prior to the date of enactment of the Motor Vehicle and Highway Safety Improvement Act of 2012—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4fea89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have imported motor vehicles into the United States that are certified to comply with all applicable Federal motor vehicle safety standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have submitted to the Secretary appropriate manufacturer identification information under part 566 of title 49, Code of Federal Regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, have identified a current agent for service of process in accordance with part 551 of title 49, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fea8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30164/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rulemaking","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In issuing regulations under this section, the Secretary shall seek to reduce duplicative requirements by coordinating with the Department of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb4fea8d-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/968"},"text":"108 Stat. 968","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tI/s31208/2"},"text":"Pub. L. 112–141, div. C, title I, § 31208(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/761"},"text":"126 Stat. 761","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb4fea8e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb4fea8f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb4fea90-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30164(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1399(e) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563/s110/e"},"text":"Pub. L. 89–563, § 110(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/724"},"text":"80 Stat. 724","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30164(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1399(e) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “A manufacturer offering . . . shall” are substituted for “It shall be the duty of every manufacturer offering . . . to” to eliminate unnecessary words. The words “into the United States”, “all . . . orders, decisions and requirements”, and “for and on behalf of said manufacturer” are omitted as surplus. The words “The designation may be changed in the same way as originally made” are substituted for “which designation may from time to time be changed by like writing, similarly filed” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “An agent may be served” are substituted for “Service of all administrative and judicial processes, notices, orders, decisions and requirements may be made upon said manufacturer by service upon such designated agent” to eliminate unnecessary words. The words “Service on the agent is deemed to be service on the manufacturer” are substituted for “with like effects as if made personally upon said manufacturer”, and the words “If a manufacturer does not designate an agent” are substituted for “and in default of such designation of such agent”, for clarity. The words “of process, notice, order, requirement or decision in any proceeding before the Secretary or in any judicial proceeding for enforcement of this subchapter or any standards prescribed pursuant to this subchapter” and “order, requirement or decision” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb4fea91-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb4fea92-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Motor Vehicle and Highway Safety Improvement Act of 2012, referred to in subsec. (e), is the date of enactment of title I of div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb4fea93-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s31208/2/A"},"text":"Pub. L. 112–141, § 31208(2)(A)","children":[],"tail":", inserted “; conditions on importation of vehicles and equipment” after “process” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s31208/2/B"},"text":"Pub. L. 112–141, § 31208(2)(B)","children":[],"tail":", added subsecs. (c) to (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb4fea94-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb4fea95-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
