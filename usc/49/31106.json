{"tag":"section","attrib":{"id":"idcb608b17-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106"},"text":null,"children":[{"tag":"num","attrib":{"value":"31106"},"text":"§ 31106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb608b18-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Systems and Data Analysis.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb608b19-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the provisions of this section, the Secretary shall establish and operate motor carrier, commercial motor vehicle, and driver information systems and data analysis programs to support safety regulatory and enforcement activities required under this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b1a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Network coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In cooperation with the States, the information systems under this section shall be coordinated into a network providing accurate identification of motor carriers and drivers, commercial motor vehicle registration and license tracking, and motor carrier, commercial motor vehicle, and driver safety performance data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b1b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data analysis capacity and programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall develop and maintain under this section data analysis capacity and programs that provide the means to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb608b1c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and collect necessary motor carrier, commercial motor vehicle, and driver data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b1d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the safety fitness of motor carriers and drivers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b1e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop strategies to mitigate safety problems and to use data analysis to address and measure the effectiveness of such strategies and related programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b1f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the cost-effectiveness of Federal and State safety compliance and enforcement programs and other countermeasures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b20-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adapt, improve, and incorporate other information and information systems as the Secretary determines appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b21-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure, to the maximum extent practical, all the data is complete, timely, and accurate across all information systems and initiatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b22-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and implement a national motor carrier safety data correction system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b23-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether a person or employer is or was related, through common ownership, common management, common control, or common familial relationship, to any other person, employer, or any other applicant for registration under section 13902 or 31134.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b24-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To implement this section, the Secretary shall prescribe technical and operational standards to ensure—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb608b25-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uniform, timely, and accurate information collection and reporting by the States and other entities as determined appropriate by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b26-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uniform Federal, State, and local policies and procedures necessary to operate the information system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b27-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reliability and availability of the information to the Secretary and States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb608b28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance and Registration Information Systems Management.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb608b29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information clearinghouse","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall include, as part of the motor carrier information system authorized by this section, a program to establish and maintain a clearinghouse and repository of information related to State registration and licensing of commercial motor vehicles, the registrants of such vehicles, and the motor carriers operating such vehicles. The clearinghouse and repository may include information on the safety fitness of each of the motor carriers and registrants and other information the Secretary considers appropriate, including information on motor carrier, commercial motor vehicle, and driver safety performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Design","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program shall link Federal motor carrier safety information systems with State commercial vehicle registration and licensing systems and shall be designed to enable a State to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb608b2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the safety fitness of a motor carrier or registrant when licensing or registering the registrant or motor carrier or while the license or registration is in effect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deny, suspend, or revoke the commercial motor vehicle registrations of a motor carrier or registrant that has been issued an operations out-of-service order by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions for participation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall require States, as a condition of participation in the program, to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb608b2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with the uniform policies, procedures, and technical and operational standards prescribed by the Secretary under subsection (a)(4);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possess or seek the authority to possess for a time period no longer than determined reasonable by the Secretary, to impose sanctions relating to commercial motor vehicle registration on the basis of a Federal safety fitness determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish and implement a process—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb608b31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cancel the motor vehicle registration and seize the registration plates of a vehicle when an employer is found liable under section 31310(i)(2)(C) for knowingly allowing or requiring an employee to operate such a commercial motor vehicle in violation of an out-of-service order; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb608b32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reinstate the vehicle registration or return the registration plates of the commercial motor vehicle, subject to sanctions under clause (i), if the Secretary permits such carrier to resume operations after the date of issuance of such order.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb608b33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb608b34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In coordination with the information system under section 31309, the Secretary is authorized to establish a program to improve commercial motor vehicle driver safety. The objectives of the program shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb608b35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing the exchange of driver licensing information among the States, the Federal Government, and foreign countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing information to the judicial system on commercial motor vehicle drivers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluating any aspect of driver performance that the Secretary determines appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing appropriate strategies and countermeasures to improve driver safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require a State, as a condition of an award of grant money under this section, to provide the Secretary access to all State licensing status and driver history records via an electronic information system, subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s2721"},"text":"section 2721 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb608b3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Agreements, Grants, and Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may carry out this section either independently or in cooperation with other Federal departments, agencies, and instrumentalities, or by making grants to, and entering into contracts and cooperative agreements with, States, local governments, associations, institutions, corporations, and other persons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb608b3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb608b3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Availability and Privacy Protection Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall develop a policy on making information available from the information systems authorized by this section and section 31309. The policy shall be consistent with existing Federal information laws, including regulations, and shall provide for review and correction of such information in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31106/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any prohibition on disclosure of information in section 31105(h) or 31143(b) of this title or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":", the Secretary may disclose information maintained by the Secretary pursuant to chapters 51, 135, 311, or 313 of this title to appropriate personnel of a State agency or instrumentality authorized to carry out State commercial motor vehicle safety activities and commercial driver’s license laws, or appropriate personnel of a local law enforcement agency, in accordance with standards, conditions, and procedures as determined by the Secretary. Disclosure under this section shall not operate as a waiver by the Secretary of any applicable privilege against disclosure under common law or as a basis for compelling disclosure under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb608b3e-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/991"},"text":"108 Stat. 991","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4004/a"},"text":"Pub. L. 105–178, title IV, § 4004(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/398"},"text":"112 Stat. 398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV"},"text":"Pub. L. 109–59, title IV","children":[],"tail":", §§ 4108(a), 4109(a), "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1720"},"text":"119 Stat. 1720","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII"},"text":"Pub. L. 112–141, div. C, title II","children":[],"tail":", §§ 32103(b), 32306, 32508, 32602, "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/780"},"text":"126 Stat. 780","children":[],"tail":", 793, 805, 807; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV"},"text":"Pub. L. 114–94, div. A, title V","children":[],"tail":", §§ 5101(e)(2), 5102, "},{"tag":"date","attrib":{"date":"2015-12