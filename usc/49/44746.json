{"tag":"section","attrib":{"id":"idcc0c354c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44746"},"text":null,"children":[{"tag":"num","attrib":{"value":"44746"},"text":"§ 44746.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flight data recovery from overwater operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc0c354d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44746/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 18 months after the date of enactment of this section, the Administrator of the Federal Aviation Administration shall complete a rulemaking proceeding to require that, not later than 5 years after the date of enactment of this section, all applicable aircraft are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c354e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44746/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fitted with a means, in the event of an accident, to recover mandatory flight data parameters in a manner that does not require the underwater retrieval of the cockpit voice recorder or flight data recorder;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c354f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44746/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipped with a tamper-resistant method to broadcast sufficient information to a ground station to establish the location where an applicable aircraft terminates flight as the result of such an event; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3550-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44746/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipped with an airframe low-frequency underwater locating device that functions for at least 90 days and that can be detected by appropriate equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c3551-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44746/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable Aircraft Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “applicable aircraft” means an aircraft manufactured on or after ","children":[{"tag":"date","attrib":{"date":"2028-01-01"},"text":"January 1, 2028","children":[],"tail":", that is—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c3552-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44746/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated under part 121 of title 14, Code of Federal Regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3553-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44746/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required by regulation to have a cockpit voice recorder and a flight data recorder; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3554-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44746/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used in extended overwater operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc0c3555-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIII/s352/a"},"text":"Pub. L. 118–63, title III, § 352(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1112"},"text":"138 Stat. 1112","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc0c3556-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc0c3557-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc0c3558-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
