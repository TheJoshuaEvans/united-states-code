{"tag":"section","attrib":{"id":"idcb25091e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22701"},"text":null,"children":[{"tag":"num","attrib":{"value":"22701"},"text":"§ 22701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter: ","children":[{"tag":"ref","attrib":{"idref":"fn002080"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002080"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “chapter:”."}],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb25091f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22701/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Private benefit.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb250920-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22701/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “private benefit”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb250921-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22701/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a benefit accrued to a person or private entity, other than Amtrak, that directly improves the economic and competitive condition of that person or entity through improved assets, cost reductions, service improvements, or any other means as defined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb250922-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22701/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be determined on a project-by-project basis, based upon an agreement between the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb250923-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22701/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may seek the advice of the States and rail carriers in further defining this term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb250924-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22701/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public benefit.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb250925-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22701/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “public benefit”—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb250926-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22701/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a benefit accrued to the public, including Amtrak, in the form of enhanced mobility of people or goods, environmental protection or enhancement, congestion mitigation, enhanced trade and economic development, improved air quality or land use, more efficient energy use, enhanced public safety or security, reduction of public expenditures due to improved transportation efficiency or infrastructure preservation, and any other positive community effects as defined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb250927-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22701/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be determined on a project-by-project basis, based upon an agreement between the parties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb250928-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22701/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may seek the advice of the States and rail carriers in further defining this term.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb250929-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22701/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means any of the 50 States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb25092a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22701/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State rail transportation authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State rail transportation authority” means the State agency or official responsible under the direction of the Governor of the State or a State law for preparation, maintenance, coordination, and administration of the State rail plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb25092b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tIII/s303/a"},"text":"Pub. L. 110–432, div. B, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4947"},"text":"122 Stat. 4947","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
