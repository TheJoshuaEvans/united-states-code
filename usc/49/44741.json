{"tag":"section","attrib":{"id":"idcc09eaa5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741"},"text":null,"children":[{"tag":"num","attrib":{"value":"44741"},"text":"§ 44741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of organization designation authorization unit members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc09eaa6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning ","children":[{"tag":"date","attrib":{"date":"2022-01-01"},"text":"January 1, 2022","children":[],"tail":", each individual who is selected on or after such date to become an ODA unit member by an ODA holder engaged in the design of an aircraft, aircraft engine, propeller, or appliance and performs an authorized function pursuant to a delegation by the Administrator of the Federal Aviation Administration under section 44702(d)—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc09eaa7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc09eaa8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee, a contractor, or a consultant of the ODA holder; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09eaa9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee of a supplier of the ODA holder; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09eaaa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not become a member of such unit unless approved by the Administrator pursuant to this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09eaab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Process and Timeline.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc09eaac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall maintain an efficient process for the review and approval of an individual to become an ODA unit member under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09eaad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An ODA holder described in subsection (a) may submit to the Administrator an application for an individual to be approved to become an ODA unit member under this section. The application shall be submitted in such form and manner as the Administrator determines appropriate. The Administrator shall require an ODA holder to submit with such an application information sufficient to demonstrate an individual’s qualifications under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09eaae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timeline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall approve or reject an individual that is selected by an ODA holder to become an ODA unit member under this section not later than 30 days after the receipt of an application by an ODA holder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09eaaf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documentation of approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon approval of an individual to become an ODA unit member under this section, the Administrator shall provide such individual a letter confirming that such individual has been approved by the Administrator under this section to be an ODA unit member.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09eab0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reapplication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An ODA holder may submit an application under this subsection for an individual to become an ODA unit member under this section regardless of whether an application for such individual was previously rejected by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09eab1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc09eab2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall issue minimum qualifications for an individual to become an ODA unit member under this section. In issuing such qualifications, the Administrator shall consider existing qualifications for Administration employees with similar duties and whether such individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc09eab3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is technically proficient and qualified to perform the authorized functions sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09eab4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has no recent record of serious enforcement action, as determined by the Administrator, taken by the Administrator with respect to any certificate, approval, or authorization held by such individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09eab5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is of good moral character (as such qualification is applied to an applicant for an airline transport pilot certificate issued under section 44703);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09eab6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possesses the knowledge of applicable design or production requirements in this chapter and in title 14, Code of Federal Regulations, necessary for performance of the authorized functions sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09eab7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possesses a high degree of knowledge of applicable design or production principles, system safety principles, or safety risk management processes appropriate for the authorized functions sought; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09eab8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets such testing, examination, training, or other qualification standards as the Administrator determines are necessary to ensure the individual is competent and capable of performing the authorized functions sought.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09eab9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Previously rejected application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In reviewing an application for an individual to become an ODA unit member under this section, if an application for such individual was previously rejected, the Administrator shall ensure that the reasons for the prior rejection have been resolved or mitigated to the Administrator’s satisfaction before making a determination on the individual’s reapplication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09eaba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rescission of Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may rescind an approval of an individual as an ODA unit member granted pursuant to this section at any time and for any reason the Administrator considers appropriate. The Administrator shall develop procedures to provide for notice and opportunity to appeal rescission decisions made by the Administrator. Such decisions by the Administrator are not subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09eabb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditional Selections.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc09eabc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the requirements of this subsection, the Administrator may authorize an ODA holder to conditionally designate an individual to perform the functions of an ODA unit member for a period of not more than 30 days (beginning on the date an application for such individual is submitted under subsection (b)(2)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09eabd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required determination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may not make an authorization under paragraph (1) unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc09eabe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ODA holder has instituted, to the Administrator’s satisfaction, systems and processes to ensure the integrity and reliability of determinations by conditionally-designated ODA unit members; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09eabf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ODA holder has instituted a safety management system in accordance with regulations issued by the Administrator under section 102 of the Aircraft Certification, Safety, and Accountability Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09eac0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall approve or reject the application for an individual designated under paragraph (1) in accordance with the timeline and procedures described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09eac1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rejection and review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Administrator rejects the application submitted under subsection (b)(2) for an individual conditionally designated under paragraph (1), the Administrator shall review and approve or disapprove any decision pursuant to any authorized function performed by such individual during the period such individual served as a conditional designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09eac2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding the requirements of paragraph (2), the Administrator may prohibit an ODA holder from making conditional designations of individuals as ODA unit members under this subsection at any time for any reason the Administrator considers appropriate. The Administrator may prohibit any conditionally designated individual from performing an authorized function at any time for any reason the Administrator considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09eac3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records and Briefings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc09eac4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on the date described in subsection (a), an ODA holder shall maintain, for a period to be determined by the Administrator and with proper protections to ensure the security of sensitive and personal information—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc09eac5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any data, applications, records, or manuals required by the ODA holder’s approved procedures manual, as determined by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09eac6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the names, responsibilities, qualifications, and example signature of each member of the ODA unit who performs an authorized function pursuant to a delegation by the Administrator under section 44702(d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09eac7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training records for ODA unit members and ODA administrators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09eac8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other data, applications, records, or manuals determined appropriate by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09eac9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional briefing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall provide biannual briefings each fiscal year through ","children":[{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":" to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate on the implementation and effects of this section, including—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc09eaca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administration’s performance in completing reviews of individuals and approving or denying such individuals within the timeline required under subsection (b)(3);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09eacb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for any individual rejected by the Administrator under subsection (b) during the preceding 6-month period, the reasoning or basis for such rejection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09eacc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any resource, staffing, or other challenges within the Administration associated with implementation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09eacd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Review of Qualifications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc09eace-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after the issuance of minimum qualifications under subsection (c), the Administrator shall initiate a review of the qualifications of each individual who on the date on which such minimum qualifications are issued is an ODA unit member of a holder of a type certificate for a transport airplane to ensure such individual meets the minimum qualifications issued by the Administrator under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09eacf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unqualified individual","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any individual who is determined by the Administrator not to meet such minimum qualifications pursuant to the review conducted under paragraph (1), the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc09ead0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall determine whether the lack of qualification may be remedied and, if so, provide such individual with an action plan or schedule for such individual to meet such qualifications; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09ead1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, if the Administrator determines the lack of qualification may not be remedied, take appropriate action, including prohibiting such individual from performing an authorized function.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09ead2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall complete the review required under paragraph (1) not later than 18 months after the date on which such review was initiated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09ead3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual approved to become an ODA unit member of a holder of a type certificate for a transport airplane under subsection (a) shall not be subject to the review under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09ead4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may not authorize an organization or ODA holder to approve an individual selected by an ODA holder to become an ODA unit member under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09ead5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc09ead6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The definitions contained in section 44736(c) shall apply to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09ead7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transport airplane","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “transport airplane” means a transport category airplane designed for operation by an air carrier or foreign air carrier type-certificated with a passenger seating capacity of 30 or more or an all-cargo or combi derivative of such an airplane.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09ead8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44741/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to carry out this section $3,000,000 for each of fiscal years 2021 through 2028.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc09ead9-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dV/tI/s107/a"},"text":"Pub. L. 116–260, div. V, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2320"},"text":"134 Stat. 2320","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIII/s306/a"},"text":"Pub. L. 118–63, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1071"},"text":"138 Stat. 1071","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc09eada-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc09eadb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc0c34cc-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 102 of the Aircraft Certification, Safety, and Accountability Act, referred to in subsec. (e)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/tI/s102"},"text":"section 102 of title I of Pub. L. 116–260","children":[],"tail":", div. V, "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2309"},"text":"134 Stat. 2309","children":[],"tail":". Section 102(a)–(f) of "},{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44701"},"text":"section 44701 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/s102/g"},"text":"section 102(g) of Pub. L. 116–260","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44735"},"text":"section 44735 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc0c34cd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s306/a/1/A"},"text":"Pub. L. 118–63, § 306(a)(1)(A)","children":[],"tail":", substituted “The Administrator shall provide biannual briefings each fiscal year through "},{"tag":"date","attrib":{"date":"2028-09-30"},"text":"September 30, 2028","children":[],"tail":"” for “Not later than 90 days after the date of enactment of this section, and every 90 days thereafter through "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"September 30, 2023","children":[],"tail":", the Administrator shall provide a briefing” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s306/a/1/B"},"text":"Pub. L. 118–63, § 306(a)(1)(B)","children":[],"tail":", substituted “6-month period” for “90-day period”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s306/a/2"},"text":"Pub. L. 118–63, § 306(a)(2)","children":[],"tail":", substituted “2028” for “2023”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
