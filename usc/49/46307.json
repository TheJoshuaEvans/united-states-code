{"tag":"section","attrib":{"id":"idcc3e687f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46307"},"text":null,"children":[{"tag":"num","attrib":{"value":"46307"},"text":"§ 46307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Violation of national defense airspace","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A person that knowingly or willfully violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40103/b/3"},"text":"section 40103(b)(3) of this title","children":[],"tail":" or a regulation prescribed or order issued under section 40103(b)(3) shall be fined under title 18, imprisoned for not more than one year, or both. If a person is convicted of a second or subsequent offense under this section, the punishment shall be imprisonment for not more than 5 years, a fine under title 18, or both."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcc3e6880-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1237"},"text":"108 Stat. 1237","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/119/60/dH/tLXXXVI/s8605/b"},"text":"Pub. L. 119–60, div. H, title LXXXVI, § 8605(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-12-18"},"text":"Dec. 18, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/139/1943"},"text":"139 Stat. 1943","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc3e6881-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc3e6882-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id