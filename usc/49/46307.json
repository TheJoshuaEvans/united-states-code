ildren":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s1203"},"text":"Pub. L. 85–726, § 1203","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/800"},"text":"72 Stat. 800","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “In addition to the penalties otherwise provided for by this chapter” are omitted as surplus. The word “prescribed” is added for consistency in the revised title. The words “fined under title 18” are substituted for “a fine of not exceeding $10,000”, and the words “shall be deemed guilty of a misdemeanor” are omitted, for consistency with title 18. The words “and upon conviction thereof” and “such fine and imprisonment” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc3e6884-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc3e6885-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" inserted at end “If a person is convicted of a second or subsequent offense under this section, the punishment shall be imprisonment for not more than 5 years, a fine under title 18, or both.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
