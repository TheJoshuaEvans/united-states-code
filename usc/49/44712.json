{"tag":"section","attrib":{"id":"idcc004db7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712"},"text":null,"children":[{"tag":"num","attrib":{"value":"44712"},"text":"§ 44712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency locator transmitters","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc004db8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Installation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An emergency locator transmitter must be installed on a fixed-wing powered civil aircraft for use in air commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc004db9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Prior to ","children":[{"tag":"date","attrib":{"date":"2002-01-01"},"text":"January 1, 2002","children":[],"tail":", subsection (a) does not apply to—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc004dba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" turbojet-powered aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc004dbb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft when used in scheduled flights by scheduled air carriers holding certificates issued by the Secretary of Transportation under subpart II of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc004dbc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft when used in training operations conducted entirely within a 50 mile radius of the airport from which the training operations begin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc004dbd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft when used in flight operations related to design and testing, the manufacture, preparation, and delivery of the aircraft, or the aerial application of a substance for an agricultural purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc004dbe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft holding certificates from the Administrator of the Federal Aviation Administration for research and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc004dbf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft when used for showing compliance with regulations, crew training, exhibition, air racing, or market surveys; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc004dc0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft equipped to carry only one individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc004dc1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication Beginning on January","children":[],"tail":" 1, 2002.—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc004dc2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), on and after ","children":[{"tag":"date","attrib":{"date":"2002-01-01"},"text":"January 1, 2002","children":[],"tail":", subsection (a) does not apply to—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc004dc3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft when used in scheduled flights by scheduled air carriers holding certificates issued by the Secretary of Transportation under subpart II of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc004dc4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft when used in training operations conducted entirely within a 50-mile radius of the airport from which the training operations begin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc004dc5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft when used in flight operations related to the design and testing, manufacture, preparation, and delivery of aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc004dc6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft when used in research and development if the aircraft holds a certificate from the Administrator of the Federal Aviation Administration to carry out such research and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc004dc7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft when used in showing compliance with regulations, crew training, exhibition, air racing, or market surveys;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc004dc8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft when used in the aerial application of a substance for an agricultural purpose;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc004dc9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft with a maximum payload capacity of more than 18,000 pounds when used in air transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc004dca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/c/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aircraft equipped to carry only one individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc004dcb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delay in implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Federal Aviation Administration may continue to implement subsection (b) rather than subsection (c) for a period not to exceed 2 years after ","children":[{"tag":"date","attrib":{"date":"2002-01-01"},"text":"January 1, 2002","children":[],"tail":", if the Administrator finds such action is necessary to promote—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc004dcc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a safe and orderly transition to the operation of civil aircraft equipped with an emergency locator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc004dcd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other safety objectives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc004dce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An aircraft meets the requirement of subsection (a) if it is equipped with an emergency locator transmitter that transmits on the 121.5/243 megahertz frequency or the 406 megahertz frequency or with other equipment approved by the Secretary for meeting the requirement of subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc004dcf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44712/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Removal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall prescribe regulations specifying the conditions under which an aircraft subject to subsection (a) of this section may operate when its emergency locator transmitter has been removed for inspection, repair, alteration, or replacement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc004dd0-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1194"},"text":"108 Stat. 1194","children":[],"