,"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(b)(1)(E); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/e"},"text":"Pub. L. 98–443, § 3(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44712(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1421(d)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 601(d)(3); added "},{"tag":"html:span","attrib":{},"text":"Nov. 9, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/163/s15/a/2"},"text":"Pub. L. 95–163, § 15(a)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1283"},"text":"91 Stat. 1283","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Except with respect to aircraft described in paragraph (2) of this subsection and except as provided in paragraph (3) of this subsection” are omitted as surplus. The words “minimum standards pursuant to this section shall include a requirement that”, the text of 49 App.:1421(d)(1)(A), and the words “after three years and six months following such date” are omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “used” is substituted for “engaged” for consistency. In clause (3), the word “training” is substituted for “local flight” for consistency. In clause (4), the words “chemicals and other” are omitted as surplus. In clause (5), the word “purposes” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “prescribe regulations” are substituted for “shall issue regulations . . . as he prescribes in such regulations” to eliminate unnecessary words. The words “such limitations and” and “from such aircraft” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc004dd4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc004dd5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s501/a/1"},"text":"Pub. L. 106–181, § 501(a)(1)","children":[],"tail":", substituted “Prior to "},{"tag":"date","attrib":{"date":"2002-01-01"},"text":"January 1, 2002","children":[],"tail":", subsection (a)” for “Subsection (a) of this section” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s501/a/2"},"text":"Pub. L. 106–181, § 501(a)(2)","children":[],"tail":", (3), added subsecs. (c) and (d) and redesignated former subsec. (c) as (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc004dd6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc004dd7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc004dd8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tV/s501/b"},"text":"Pub. L. 106–181, title V, § 501(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/132"},"text":"114 Stat. 132","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/181/tV/s501/b"},"text":"“The Secretary [of Transportation] shall issue regulations to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44712/c"},"text":"section 44712(c) of title 49","children":[],"tail":", United States Code, as amended by this section, not later than "},{"tag":"date","attrib":{"date":"2001-01-01"},"text":"January 1, 2001","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc004dd9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Emergency Locator Transmitters on General Aviation Aircraft","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIII/s347"},"text":"Pub. L. 112–95, title III, § 347","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/82"},"text":"126 Stat. 82","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/95/tIII/s347"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As part of the annual inspection of general aviation aircraft, the Administrator of the Federal Aviation Administration shall require a detailed inspection of each emergency locator transmitter (in this section referred to as an ‘ELT’) installed in general aviation aircraft operating in the United States to ensure that the ELT is mounted and retained in accordance with the manufacturer’s specifications.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mounting and Retention.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":"], the Administrator shall determine if the ELT mounting requirements and retention tests specified by Technical Standard Orders C91a and C126 are adequate to assess retention capabilities in ELT designs."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Based on the determination under paragraph (1), the Administrator shall make any necessary revisions to the requirements and retention tests referred to in paragraph (1) to ensure that ELTs are properly retained in the event of an aircraft accident.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the completion of any revisions under subsection (b)(2), the Administrator shall submit a report on the implementation of this section to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
