{"tag":"section","attrib":{"id":"idcc373ce6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305"},"text":null,"children":[{"tag":"num","attrib":{"value":"45305"},"text":"§ 45305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration, certification, and related fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc373ce7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority and Fees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), the Administrator of the Federal Aviation Administration shall establish and collect a fee for each of the following services and activities of the Administration that does not exceed the estimated costs of the service or activity:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc373ce8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Registering an aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373ce9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reregistering, replacing, or renewing an aircraft registration certificate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issuing an original dealer’s aircraft registration certificate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373ceb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issuing an additional dealer’s aircraft registration certificate (other than the original).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issuing a special registration number.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373ced-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issuing a renewal of a special registration number reservation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recording a security interest in an aircraft or aircraft part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issuing an airman certificate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cf0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issuing a replacement airman certificate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cf1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Issuing an airman medical certificate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cf2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Providing a legal opinion pertaining to aircraft registration or recordation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373cf3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c), and notwithstanding section 45301(a), the Administrator may establish and collect a fee from a foreign government or entity for services related to certification, regardless of where the services are provided, if the fee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc373cf4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is established and collected in a manner consistent with aviation safety agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cf5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not exceed the estimated costs of the services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373cf6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Collection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No fee may be collected under this section unless the expenditure of the fee to pay the costs of activities and services for which the fee is imposed is provided for in advance in an appropriations Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373cf7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees Credited as Offsetting Collections.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc373cf8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", any fee authorized to be collected under this section shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc373cf9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be credited as offsetting collections to the account that finances the activities and services for which the fee is imposed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373cfa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be available for expenditure only to pay the costs of activities and services for which the fee is imposed, including all costs associated with collecting the fee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc373cfb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cfc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may continue to assess, collect, and spend fees established under this section during any period in which the funding for the Federal Aviation Administration is provided under an Act providing continuing appropriations in lieu of the Administration’s regular appropriations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373cfd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45305/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall adjust a fee established under subsection (a) for a service or activity if the Administrator determines that the actual cost of the service or activity is higher or lower than was indicated by the cost data used to establish such fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc373cfe-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tI/s122/a"},"text":"Pub. L. 112–95, title I, § 122(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/19"},"text":"126 Stat. 19","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tII/s244"},"text":"Pub. L. 115–254, div. B, title II, § 244","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3260"},"text":"132 Stat. 3260","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc373cff-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc373d00-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc373d01-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s244/1"},"text":"Pub. L. 115–254, § 244(1)","children":[],"tail":", substituted “Subject to subsection (c)” for “Subject to subsection (b)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s244/2"},"text":"Pub. L. 115–254, § 244(2)","children":[],"tail":", (3), added subsec. (b) and redesignated former subsecs. (b) and (c) as (c) and (d), respectively."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
