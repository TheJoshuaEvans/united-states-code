{"tag":"section","attrib":{"id":"idca689672-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302"},"text":null,"children":[{"tag":"num","attrib":{"value":"302"},"text":"§ 302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Policy standards for transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca689673-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation is governed by the transportation policy of sections 10101 and 13101 of this title in addition to other laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca689674-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subtitle and chapters 221 and 315 of this title do not authorize, without appropriate action by Congress, the adoption, revision, or implementation of a transportation policy or investment standards or criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca689675-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall consider the needs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca689676-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for effectiveness and safety in transportation systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca689677-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of national defense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca689678-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca689679-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" It is the policy of the United States to promote the construction and commercialization of high-speed ground transportation systems by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca68967a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducting economic and technological research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca68967b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrating advancements in high-speed ground transportation technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca68967c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a comprehensive policy for the development of such systems and the effective integration of the various high-speed ground transportation technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca68967d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimizing the long-term risks of investors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca68967e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" It is the policy of the United States to establish in the shortest time practicable a United States designed and constructed magnetic levitation transportation technology capable of operating along Federal-aid highway rights-of-way, as part of a national transportation system of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca68967f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intermodal Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is the policy of the United States Government to encourage and promote development of a national intermodal transportation system in the United States to move people and goods in an energy-efficient manner, provide the foundation for improved productivity growth, strengthen the Nation’s ability to compete in the global economy, and obtain the optimum yield from the Nation’s transportation resources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca689680-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"hr