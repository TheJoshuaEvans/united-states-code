"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"302(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1653(b)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s4/b"},"text":"Pub. L. 89–670, § 4(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/933"},"text":"80 Stat. 933","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"302(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1653(b)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"302(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1653(b)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “In carrying out his duties and responsibilities under this chapter” before “Secretary of Transportation” are omitted as surplus. The words “the transportation policy of sections 10101 and 10101a of this title in addition to other laws” are substituted for “all applicable statutes including the policy standards set forth in the Federal Aviation Act of 1958, as amended [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"49 U.S.C. 1301","children":[],"tail":" et seq.]; the national transportation policy of the Interstate Commerce Act, as amended; title 23, relating to Federal-aid highways; and title 14, titles 52 and 53 of the Revised Statutes, the Act of "},{"tag":"date","attrib":{"date":"1940-04-25"},"text":"April 25, 1940","children":[],"tail":", as amended, and the Act of "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"September 2, 1958","children":[],"tail":", as amended, relating to the United States Coast Guard” because each of the omitted laws is now applicable to the Secretary of Transportation and the Department of Transportation as the result of the restatement of those laws, and the Secretary is therefore bound to follow those laws by their own terms."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “In exercising the functions, powers, and duties conferred on and transferred to the Secretary by this chapter” before “Secretary” are omitted as surplus. The word “consider” is substituted for “give full consideration to” to eliminate surplus words. The words “for operational continuity of the functions transferred” after “the needs” are omitted as executed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca689684-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca689685-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" substituted “13101” for “10101a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":" substituted “This subtitle and chapters 221 and 315 of this title” for “Subtitle I and chapter 31 of subtitle II of this title and the Department of Transportation Act (49 App. U.S.C. 1651 et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1991—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240/s1036/a"},"text":"Pub. L. 102–240, § 1036(a)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240/s5001"},"text":"Pub. L. 102–240, § 5001","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/216"},"text":"Pub. L. 98–216","children":[],"tail":" substituted “49 App. U.S.C.” for “49 U.S.C.”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca689686-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca689687-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca689688-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1991 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240/s1036/a"},"text":"section 1036(a) of Pub. L. 102–240","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", and applicable to funds authorized to be appropriated or made available after "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"Sept. 30, 1991","children":[],"tail":", and, with certain exceptions, not applicable to funds appropriated or made available on or before "},{"tag":"date","attrib":{"date":"1991-09-30"},"text":"Sept. 30, 1991","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/102/240/s1100"},"text":"section 1100 of Pub. L. 102–240","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s104"},"text":"section 104 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
