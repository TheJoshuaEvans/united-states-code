{"tag":"section","attrib":{"id":"idcb6c7281-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31143"},"text":null,"children":[{"tag":"num","attrib":{"value":"31143"},"text":"§ 31143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigating complaints and protecting complainants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb6c7282-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investigating Complaints","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall conduct a timely investigation of a nonfrivolous written complaint alleging that a substantial violation of a regulation prescribed under this subchapter is occurring or has occurred within the prior 60 days. The Secretary shall give the complainant timely notice of the findings of the investigation. The Secretary is not required to conduct separate investigations of duplicative complaints.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6c7283-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protecting Complainants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", the Secretary may disclose the identity of a complainant only if disclosure is necessary to prosecute a violation. If disclosure becomes necessary, the Secretary shall take every practical means within the Secretary’s authority to ensure that the complainant is not subject to harassment, intimidation, disciplinary action, discrimination, or financial loss because of the disclosure."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb6c7284-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1012"},"text":"108 Stat. 1012","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb6c7285-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb6c7286-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb6c7287-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31143(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2511(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/554/s212"},"text":"Pub. L. 98–554, § 212","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2841"},"text":"98 Stat. 2841","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31143(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2511(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb6c7288-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb6c7289-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Telephone Hotline for Reporting Safety Violations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4017"},"text":"Pub. L. 105–178, title IV, § 4017","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/413"},"text":"112 Stat. 413","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/159/tII/s213"},"text":"Pub. L. 106–159, title II, § 213","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1766"},"text":"113 Stat. 1766","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/159/tII/s213"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For a period of not less than 2 years beginning on or before the 90th day following the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":"], the Secretary [of Transportation] shall establish, maintain, and promote the use of a nationwide toll-free telephone system to be used by drivers of commercial motor vehicles and others to report potential violations of Federal motor carrier safety regulations."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall monitor reports received by the telephone system and may consider nonfrivolous information provided by such reports in setting priorities for motor carrier safety audits and other enforcement activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staffing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The toll-free telephone system shall be staffed 24 hours a day 7 days a week by individuals knowledgeable about Federal motor carrier safety regulations and procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection of Persons Reporting Violations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person reporting a potential violation to the telephone system while acting in good faith may not be discharged, disciplined, or discriminated against regarding pay, terms, or privileges of employment because of the reporting of such violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31105"},"text":"section 31105 of title 49","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31105"},"text":"section 31105 of title 49","children":[],"tail":", United States Code, a violation or alleged violation of paragraph (1) shall be treated as a violation of section 31105(a) of such title."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"From amounts set aside under [former] ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s104/a/1/B"},"text":"section 104(a)(1)(B) of title 23","children":[],"tail":", United States Code, the Secretary may use not more than $250,000 for fiscal year 1999 and $375,000 for each of fiscal years 2000 through 2003 to carry out this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
