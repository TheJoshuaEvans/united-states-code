a","attrib":{"href":"/us/pl/98/443/s9/r"},"text":"Pub. L. 98–443, § 9(r)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1708"},"text":"98 Stat. 1708","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/223/s202/a/1"},"text":"Pub. L. 100–223, § 202(a)(1)","children":[],"tail":", (2), (b)(1), "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1507"},"text":"101 Stat. 1507","children":[],"tail":", 1508, 1509, 1511."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41733(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1389(b)(1)(A) (last sentence last 24 words), (B).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41733(b)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1389(b)(9).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41733(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1389(b)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41733(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1389(b)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41733(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1389(b)(1)(D).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “the level of basic essential air service for that place shall be the level established by the Secretary of Transportation for that place” are substituted for “Such determination shall be made” because the determinations for those places have been made. The words “by not later than ","children":[{"tag":"date","attrib":{"date":"1988-12-29"},"text":"December 29, 1988","children":[],"tail":"” are substituted for “no later than the last day of the 1-year period beginning on "},{"tag":"date","attrib":{"date":"1987-12-30"},"text":"December 30, 1987","children":[],"tail":"” for clarity. The words “and only after consideration of the views of any interested community and the State agency of the State in which such community is located” and 49 App.:1389(b)(1)(C) are omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b)(1) and (e), the words “appropriate State authority” are substituted for “State agency” for clarity and consistency with the source provisions restated in section 41734(a) of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In section (b)(2), the words “that appears to deprive” are substituted for “which reasonably appears to deprive” to eliminate an unnecessary word.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), before clause (A), the words “an air carrier may apply to provide basic essential air service to the place for compensation” are substituted for “applications may be submitted by any air carrier that is willing to provide such service to such point for compensation” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbcbd0a0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbcbd0a1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 419 of the Federal Aviation Act of 1958, referred to in subsec. (a), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/726/s419"},"text":"section 419 of Pub. L. 85–726","children":[],"tail":", which was classified to section 1389 of former Title 49, Transportation, and was repealed and reenacted as this subchapter by "},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":", §§ 1(e), 7(b), "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1143"},"text":"108 Stat. 1143","children":[],"tail":", 1379."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to in subsec. (g)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbcbd0a2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s565/a/1"},"text":"Pub. L. 118–63, § 565(a)(1)","children":[],"tail":", inserted “, as defined by the Secretary” after “appropriate representative of the place”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s561/d/1/A"},"text":"Pub. L. 118–63, § 561(d)(1)(A)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “the contractual and marketing arrangements the applicant has made with a larger carrier to ensure service beyond the hub airport;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s561/d/1/C"},"text":"Pub. L. 118–63, § 561(d)(1)(C)","children":[],"tail":", (D), redesignated subpar. (D) as (C) and substituted “including” for “giving substantial weight to”. Former subpar. (C) struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s561/d/1/B"},"text":"Pub. L. 118–63, § 561(d)(1)(B)","children":[],"tail":", struck out subpar. (C) which read as follows: “the interline arrangements that the applicant has made with a larger carrier to allow passengers and cargo of the applicant at the hub airport to be transported by the larger carrier through one reservation, ticket, and baggage check-in;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s561/d/1/C"},"text":"Pub. L. 118–63, § 561(d)(1)(C)","children":[],"tail":", redesignated subpars. (E) and (F) as (D) and (E), respectively. Former subpar. (D) redesignated (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s561/d/1/E"},"text":"Pub. L. 118–63, § 561(d)(1)(E)","children":[],"tail":"–(G), added subpar. (F). Former subpar. (F) redesignated (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s561/d/1/C"},"text":"Pub. L. 118–63, § 561(d)(1)(C)","children":[],"tail":", redesignated subpar. (F) as (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s561/d/2"},"text":"Pub. L. 118–63, § 561(d)(2)","children":[],"tail":", substituted “under section 41731(a)(1)(C)” for “by section 332 of the Department of Transportation and Related Agencies Appropriations Act, 2000 ("},{"tag":"ref","attrib":{"href":"/us/pl/106/69"},"text":"Public Law 106–69","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/113/1022"},"text":"113 Stat. 1022","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s565/a/2"},"text":"Pub. L. 118–63, § 565(a)(2)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (c)(1)(E), (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s423"},"text":"Pub. L. 112–95, § 423","children":[],"tail":", added subpar. (E) and redesignated former subpar. (E) as (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s424"},"text":"Pub. L. 112–95, § 424","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s425"},"text":"Pub. L. 112–95, § 425","children":[],"tail":", added subsecs. (g) and (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" inserted before period at end “, to the extent such adjustments are to a level not less than the basic essential air service level established under subsection (a) for the airport that serves the community”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbcbd0a3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbcbd0a4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbcbd0a5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Seasonal Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIV/s451/b"},"text":"Pub. L. 115–254, div. B, title IV, § 451(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3347"},"text":"132 Stat. 3347","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dB/tIV/s451/b"},"text":"“The Secretary of Transportation may consider the flexibility of current operational dates and airport accessibility to meet local community needs when issuing requests for proposal of essential air service at seasonal airports.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbcbd0a6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effect on Certain Orders","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tII/s209/c"},"text":"Pub. L. 106–181, title II, § 209(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/95"},"text":"114 Stat. 95","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/181/tII/s209/c"},"text":"“All orders issued by the Secretary [of Transportation] after ","children":[{"tag":"date","attrib":{"date":"1999-09-30"},"text":"September 30, 1999","children":[],"tail":", and before the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":"] establishing, modifying, or revoking essential air service levels shall be null and void beginning on the 90th day following such date of enactment. During the 90-day period, the Secretary shall reconsider such orders and shall issue new orders consistent with the amendments made by this section [amending this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s41742"},"text":"section 41742 of this title","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
