{"tag":"section","attrib":{"id":"idcbfe045a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709"},"text":null,"children":[{"tag":"num","attrib":{"value":"44709"},"text":"§ 44709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Amendments, modifications, suspensions, and revocations of certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbfe045b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reinspection and Reexamination.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbfe045c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Federal Aviation Administration may reinspect at any time a civil aircraft, aircraft engine, propeller, appliance, design organization, production certificate holder, air navigation facility, or air agency, or reexamine an airman holding a certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44703"},"text":"section 44703 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe045d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of reexamination of airman","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before taking any action to reexamine an airman under paragraph (1) the Administrator shall provide to the airman—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbfe045e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable basis, described in detail, for requesting the reexamination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbfe045f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information gathered by the Federal Aviation Administration, that the Administrator determines is appropriate to provide, such as the scope and nature of the requested reexamination, that formed the basis for that justification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbfe0460-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions of the Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may issue an order amending, modifying, suspending, or revoking—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbfe0461-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any part of a certificate issued under this chapter if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbfe0462-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator decides after conducting a reinspection, reexamination, or other investigation that safety in air commerce or air transportation and the public interest require that action; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbfe0463-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the holder of the certificate has violated an aircraft noise or sonic boom standard or regulation prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44715/a"},"text":"section 44715(a) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe0464-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an airman certificate when the holder of the certificate is convicted of violating section 13(a) of the Fish and Wildlife Act of 1956 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s742j–1/a"},"text":"16 U.S.C. 742j–1(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbfe0465-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advice to Certificate Holders and Opportunity To Answer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before acting under subsection (b) of this section, the Administrator shall advise the holder of the certificate of the charges or other reasons on which the Administrator relies for the proposed action. Except in an emergency, the Administrator shall provide the holder an opportunity to answer the charges and be heard why the certificate should not be amended, modified, suspended, or revoked.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbfe0466-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeals","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbfe0467-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person adversely affected by an order of the Administrator under this section may appeal the order to the National Transportation Safety Board. After notice and an opportunity for a hearing, the Board may amend, modify, or reverse the order when the Board finds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbfe0468-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the order was issued under subsection (b)(1)(A) of this section, that safety in air commerce or air transportation and the public interest do not require affirmation of the order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbfe0469-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the order was issued under subsection (b)(1)(B) of this section—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbfe046a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that control or abatement of aircraft noise or sonic boom and the public health and welfare do not require affirmation of the order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbfe046b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the order, as it is related to a violation of aircraft noise or sonic boom standards and regulations, is not consistent with safety in air commerce or air transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe046c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may modify a suspension or revocation of a certificate to imposition of a civil penalty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe046d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When conducting a hearing under this subsection, the Board is not bound by findings of fact of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbfe046e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effectiveness of Orders Pending Appeal.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbfe046f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When a person files an appeal with the Board under subsection (d), the order of the Administrator is stayed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe0470-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (1), the order of the Administrator is effective immediately if the Administrator advises the Board that an emergency exists and safety in air commerce or air transportation requires the order to be effective immediately.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe0471-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of emergency order","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person affected by the immediate effectiveness of the Administrator’s order under paragraph (2) may petition for a review by the Board, under procedures promulgated by the Board, of the Administrator’s determination that an emergency exists. Any such review shall be requested not later than 48 hours after the order is received by the person. If the Board finds that an emergency does not exist that requires the immediate application of the order in the interest of safety in air commerce or air transportation, the order shall be stayed, notwithstanding paragraph (2). The Board shall dispose of a review request under this paragraph not later than 5 days after the date on which the request is filed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe0472-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final disposition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall make a final disposition of an appeal under subsection (d) not later than 60 days after the date on which the appeal is filed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbfe0473-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44709/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judicial Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person substantially affected by an order of the Board under this section, or the Administrator when the Administrator decides that an order of the Board under this section will have a significant adverse impact on carrying out this part, may obtain judicial review of the order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s46110"},"text":"section 46110 of this title","children":[],"tail":". The Administrator shall be made a party to the judicial review proceedings. Findings of fact of the Board are conclusive if supported by substantial evidence."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbfe0474-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1190"},"text":"108 Stat. 1190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tVII/s716"},"text":"Pub. L. 106–181, title VII, § 716","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/162"},"text":"114 Stat. 162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tII/s227/c"},"text":"Pub. L. 108–176, title II, § 227(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2532"},"text":"117 Stat. 2532","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/153/s2/c/2"},"text":"Pub. L. 112–153, § 2(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-03"},"text":"Aug. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1161"},"text":"126 Stat. 1161","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIII/s393/a"},"text":"Pub. L. 115–254, div. B, title III, § 393(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3325"},"text":"132 Stat. 3325","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbfe0475-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbfe0476-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbfe0477-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"t