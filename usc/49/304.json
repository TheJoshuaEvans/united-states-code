{"tag":"section","attrib":{"id":"idca6896dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304"},"text":null,"children":[{"tag":"num","attrib":{"value":"304"},"text":"§ 304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of categorical exclusions for multimodal projects","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca6896de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6896df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperating authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “cooperating authority” means a Department of Transportation operating administration or secretarial office that has expertise but is not the lead authority with respect to a proposed multimodal project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6896e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lead authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “lead authority” means a Department of Transportation operating administration or secretarial office that has the lead responsibility for compliance with the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) with respect to a proposed multimodal project."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6896e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multimodal project","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “multimodal project” has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s139/a"},"text":"section 139(a) of title 23","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6896e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exercise of Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authorities granted in this section may be exercised for a multimodal project, class of projects, or program of projects that are carried out under this title or title 23.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6896e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Categorical Exclusions for Multimodal Projects","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In considering the environmental impacts of a proposed multimodal project, a lead authority may apply categorical exclusions designated under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) in implementing regulations or procedures of a cooperating authority for a proposed multimodal project, subject to the conditions that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6896e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lead authority makes a determination, with the concurrence of the cooperating authority—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca6896e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the applicability of a categorical exclusion to a proposed multimodal project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6896e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the project satisfies the conditions for a categorical exclusion under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) and this section;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6896e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the lead authority follows the implementing regulations of the cooperating authority or procedures under that Act; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6896e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the lead authority determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca6896e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed multimodal project does not individually or cumulatively have a significant impact on the environment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6896ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extraordinary circumstances do not exist that merit additional analysis and documentation in an environmental impact statement or environmental assessment required under that Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6896eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperating Authority Expertise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A cooperating authority shall provide expertise to the lead authority on aspects of the multimodal project in which the cooperating authority has expertise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca6896ec-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449/s1/b"},"text":"Pub. L. 97–449, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2419"},"text":"96 Stat. 2419","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dA/tI/s1314/a"},"text":"Pub. L. 112–141, div. A, title I, § 1314(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/547"},"text":"126 Stat. 547","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tI/s1310"},"text":"Pub. L. 114–94, div. A, title I, § 1310","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1397"},"text":"129 Stat. 1397","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca6896ed-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca6896ee-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca6896ef-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"304(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1653(g) (less 3d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s4/g"},"text":"Pub. L. 89–670, § 4(g)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/934"},"text":"80 Stat. 934","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"304(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1653(g) (3d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the text of 49:1653(g) (last sentence) is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(4), the word “ensure” is substituted for “assure” as being more precise. The words “of the United States Government” are substituted for “Federal”, and the words “United States” are substituted for “national”, for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “The Secretaries shall report on April 1 of each year” are substituted for “They shall, within one year after the effective date of the Act, and annually thereafter, report” to omit executed words and to specify the date of April 1 because the President prescribed ","children":[{"tag":"date","attrib":{"date":"1967-04-01"},"text":"April 1, 1967","children":[],"tail":", as the effective date of the Department of Transportation Act ("},{"tag":"ref","attrib":{"href":"/us/pl/89/670"},"text":"Pub. L. 89–670","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/931"},"text":"80 Stat. 931","children":[],"tail":") by Executive Order No. 11340, "},{"tag":"date","attrib":{"date":"1967-03-30"},"text":"March 30, 1967","children":[],"tail":" (32 F.R. 5443). The word “consider” is substituted for “determine” for consistency."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca6896f0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca6896f1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The National Environmental Policy Act of 1969, referred to in subsecs. (a)(2) and (c), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/190"},"text":"Pub. L. 91–190","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-01-01"},"text":"Jan. 1, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/852"},"text":"83 Stat. 852","children":[],"tail":", which is classified generally to chapter 55 (§ 4321 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"section 4321 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca6896f2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1310/1/A"},"text":"Pub. L. 114–94, § 1310(1)(A)","children":[],"tail":", substituted “operating administration or secretarial office that has expertise but” for “operating authority that” and inserted “proposed multimodal” after “with respect to a”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1310/1/B"},"text":"Pub. L. 114–94, § 1310(1)(B)","children":[],"tail":", added par. (2) and struck out former par. (2). Prior to amendment, text read as follows: “The term ‘lead authority’ means a Department of Transportation operating administration or secretarial office that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) is the lead authority over a proposed multimodal project; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) has determined that the components of the project that fall under the modal expertise of the lead authority—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) satisfy the conditions for a categorical exclusion under implementing regulations or procedures of the lead authority under the National Environmental Policy Act of 1969 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.); and"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) do not require the preparation of an environmental assessment or environmental impact statement under that Act.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1310/2"},"text":"Pub. L. 114–94, § 1310(2)","children":[],"tail":", inserted “or title 23” after “under this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1310/3"},"text":"Pub. L. 114–94, § 1310(3)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c) which related to application of categorical exclusions for multimodal projects."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1310/3"},"text":"Pub. L. 114–94, § 1310(3)","children":[],"tail":", added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—A cooperating authority shall provide modal expertise to the lead authority on such aspects of the multimodal project in which the cooperating authority has expertise."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Use of categorical exclusion","children":[],"tail":".—In a case described in paragraph (1), the 1 or more categorical exclusions of a cooperating authority may be applied by the lead authority once the cooperating authority reviews the project on behalf of the lead authority and determines the project satisfies the conditions for a categorical exclusion under the implementing regulations or procedures of the cooperating authority under the National Environmental Policy Act of 1969 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4321"},"text":"42 U.S.C. 4321","children":[],"tail":" et seq.) and this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012–","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" amended section generally. Prior to amendment, section related to joint activities with the Secretary of Housing and Urban Development."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca6b07f3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca6b07f4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca6b07f5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
