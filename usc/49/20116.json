{"tag":"section","attrib":{"id":"idcb0f853a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20116"},"text":null,"children":[{"tag":"num","attrib":{"value":"20116"},"text":"§ 20116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rulemaking process","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"No rule or order issued by the Secretary under this part shall be effective if it incorporates by reference a code, rule, standard, requirement, or practice issued by an association or other entity that is not an agency of the Federal Government, unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0f853b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20116/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the code, rule, standard, requirement, or practice was adopted is specifically cited in the rule or order; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f853c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20116/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the code, rule, standard, requirement, or practice has been subject to notice and comment under a rule or order issued under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0f853d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tI/s107/a"},"text":"Pub. L. 110–432, div. A, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4859"},"text":"122 Stat. 4859","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11316/c"},"text":"Pub. L