{"tag":"section","attrib":{"id":"idcb6a2818-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139"},"text":null,"children":[{"tag":"num","attrib":{"value":"31139"},"text":"§ 31139.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum financial responsibility for transporting property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb6a2819-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6a281a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “farm vehicle” means a vehicle—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb6a281b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designed or adapted and used only for agriculture;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a281c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated by a motor private carrier (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10102"},"text":"section 10102 of this title","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a281d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated only incidentally on highways.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a281e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “interstate commerce” includes transportation between a place in a State and a place outside the United States, to the extent the transportation is in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a281f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State of the United States, the District of Columbia, Puerto Rico, the Virgin Islands, American Samoa, Guam, and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6a2820-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirement and Minimum Amount","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6a2821-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation shall prescribe regulations to require minimum levels of financial responsibility sufficient to satisfy liability amounts established by the Secretary covering public liability, property damage, and environmental restoration for the transportation of property by motor carrier or motor private carrier (as such terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s13102"},"text":"section 13102 of this title","children":[],"tail":") in the United States between a place in a State and—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb6a2822-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a place in another State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a2823-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another place in the same State through a place outside of that State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a2824-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a place outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a2825-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The level of financial responsibility established under paragraph (1) of this subsection shall be at least $750,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6a2826-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing of Evidence of Financial Responsibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require a motor private carrier (as defined in section 13102) to file with the Secretary the evidence of financial responsibility specified in subsection (b) in an amount not less than the greater of the minimum amount required by this section or the amount required for such motor private carrier to transport property under the laws of the State or States in which the motor private carrier is operating; except that the amount of the financial responsibility must be sufficient to pay not more than the amount of the financial responsibility for each final judgment against the motor private carrier for bodily injury to, or death of, an individual resulting from negligent operation, maintenance, or use of the motor vehicle, or for loss or damage to property, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6a2827-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Hazardous Matter and Oil","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6a2828-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation shall prescribe regulations to require minimum levels of financial responsibility sufficient to satisfy liability amounts established by the Secretary covering public liability, property damage, and environmental restoration for the transportation by motor vehicle in interstate or intrastate commerce of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb6a2829-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hazardous material (as defined by the Secretary);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a282a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oil or hazardous substances (as defined by the Administrator of the Environmental Protection Agency); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a282b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hazardous wastes (as defined by the Administrator).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a282c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb6a282d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subparagraph (B) of this paragraph, the level of financial responsibility established under paragraph (1) of this subsection shall be at least $5,000,000 for the transportation—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb6a282e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of hazardous substances (as defined by the Administrator) in cargo tanks, portable tanks, or hopper-type vehicles, with capacities of more than 3,500 water gallons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb6a282f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in bulk of class A explosives, poison gas, liquefied gas, or compressed gas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb6a2830-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of large quantities of radioactive material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a2831-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation by regulation may reduce the minimum level in subparagraph (A) of this paragraph (to an amount not less than $1,000,000) for transportation described in subparagraph (A) in any of the territories of Puerto Rico, the Virgin Islands, American Samoa, Guam, and the Northern Mariana Islands if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb6a2832-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the chief executive officer of the territory requests the reduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb6a2833-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reduction will prevent a serious disruption in transportation service and will not adversely affect public safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb6a2834-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insurance of $5,000,000 is not readily available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a2835-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The level of financial responsibility established under paragraph (1) of this subsection for the transportation of a material, oil, substance, or waste not subject to paragraph (2) of this subsection shall be at least $1,000,000. However, if the Secretary of Transportation finds it will not adversely affect public safety, the Secretary by regulation may reduce the amount for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb6a2836-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a class of vehicles transporting such a material, oil, substance, or waste in intrastate commerce (except in bulk); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a2837-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a farm vehicle transporting such a material or substance in interstate commerce (except in bulk).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6a2838-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Motor Carriers and Private Carriers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations prescribed under this section may allow foreign motor carriers and foreign motor private carriers (as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10530"},"text":"section 10530 of this title","children":[],"tail":") providing transportation of property under a certificate of registration issued under section 10530 to meet the minimum levels of financial responsibility under this section only when those carriers are providing transportation for property in the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6a2839-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidence of Financial Responsibility","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6a283a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2) of this subsection, financial responsibility may be established by evidence of one or a combination of the following if acceptable to the Secretary of Transportation:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb6a283b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a283c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a guarantee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a283d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a surety bond issued by a bonding company authorized to do business in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a283e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualification as a self-insurer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a283f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person domiciled in a country contiguous to the United States and providing transportation to which a minimum level of financial responsibility under this section applies shall have evidence of financial responsibility in the motor vehicle when the person is providing the transportation. If evidence of financial responsibility is not in the vehicle, the Secretary of Transportation and the Secretary of the Treasury shall deny entry of the vehicle into the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a2840-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A motor carrier may obtain the required amount of financial responsibility from more than one source provided the cumulative amount is equal to the minimum requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6a2841-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6a2842-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, after notice and an opportunity for a hearing, the Secretary of Transportation finds that a person (except an employee acting without knowledge) has knowingly violated this section or a regulation prescribed under this section, the person is liable to the United States Government for a civil penalty of not more than $10,000 for each violation. A separate violation occurs for each day the violation continues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a2843-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation shall impose the penalty by written notice. In determining the amount of the penalty, the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb6a2844-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, circumstances, extent, and gravity of the violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a2845-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the violator, the degree of culpability, any history of prior violations, the ability to pay, and any effect on the ability to continue doing business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a2846-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other matters that justice requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a2847-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation may compromise the penalty before referring the matter to the Attorney General for collection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a2848-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall bring a civil action in an appropriate district court of the United States to collect a penalty referred to the Attorney General for collection under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a2849-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the penalty may be deducted from amounts the Government owes the person. An amount collected under this section shall be deposited in the Highway Trust Fund (other than the Mass Transit Account).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6a284a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to a motor vehicle having a gross vehicle weight rating of less than 10,000 pounds if the vehicle is not used to transport in interstate or foreign commerce—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6a284b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" class A or B explosives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a284c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" poison gas; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a284d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31139/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a large quantity of radioactive material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb6a284e-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1006"},"text":"108 Stat. 1006","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s104/e"},"text":"Pub. L. 104–88, title I, § 104(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/919"},"text":"109 Stat. 919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV"},"text":"Pub. L. 109–59, title IV","children":[],"tail":", §§ 4120(b), 4121, "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1733"},"text":"119 Stat. 1733","children":[],"tail":", 1734; "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/tIII"},"text":"Pub. L. 110–244, title III","children":[],"tail":", §§ 301(f), 305(b), "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1616"},"text":"122 Stat. 1616","children":[],"tail":", 1620.)"}],"tail":"\n"},{"tag":"notes","a