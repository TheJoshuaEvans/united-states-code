927 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 1, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/296/s30/d"},"text":"Pub. L. 96–296, § 30(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/822"},"text":"94 Stat. 822","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31139(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:10927 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 1, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/296/s30/f"},"text":"Pub. L. 96–296, § 30(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/823"},"text":"94 Stat. 823","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/424/s406/d"},"text":"Pub. L. 97–424, § 406(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2159"},"text":"96 Stat. 2159","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the text of section 30(h)(3) of the Motor Carrier Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/296"},"text":"Public Law 96–296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/823"},"text":"94 Stat. 823","children":[],"tail":") is omitted as surplus because the complete name of the Secretary of Transportation is used the first time the term appears in a section. In clause (3), the words “(including its use in the terms ‘interstate’ and ‘intrastate’)” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b)(2) and (c)(2) and (3), the word “minimal” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “for any vehicle” are omitted as surplus. The words beginning with “except” are omitted as expired. The text of section 30(a)(3) of the Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/296"},"text":"Public Law 96–296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/821"},"text":"94 Stat. 821","children":[],"tail":") is omitted because the regulations have been issued. See 49 C.F.R. part 387."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the text of section 30(b)(2)(B) of the Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/296"},"text":"Public Law 96–296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/821"},"text":"94 Stat. 821","children":[],"tail":") is omitted as expired."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), before clause (A), the text of section 30(b)(3)(A) of the Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/296"},"text":"Public Law 96–296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/821"},"text":"94 Stat. 821","children":[],"tail":") is omitted as expired. The text of section 30(b)(4) of the Act ("},{"tag":"ref","attrib":{"href":"/us/pl/96/296"},"text":"Public Law 96–296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/822"},"text":"94 Stat. 822","children":[],"tail":") is omitted because the regulations have been issued. See 49 C.F.R. part 387. The words “for any vehicle . . . in interstate or intrastate commerce” are omitted as unnecessary because of the reference to paragraph (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(1), the words “The Secretary shall establish, by regulation, methods and procedures to assure compliance with this section” are omitted as surplus. The text of section 30(e) of the Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/296"},"text":"Public Law 96–296","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/822"},"text":"94 Stat. 822","children":[],"tail":") is omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(4), the words “The Attorney General shall bring a civil action . . . to collect a penalty referred to the Attorney General for collection under this subsection” are substituted for “Such civil penalty may be recovered in an action brought by the Attorney General on behalf of the United States” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(5), the words “when finally determined (or agreed upon in compromise)” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g)(1) and (2), the words “any quantity of” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb6a2852-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb6a2853-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244/s305/b/1"},"text":"Pub. L. 110–244, § 305(b)(1)","children":[],"tail"