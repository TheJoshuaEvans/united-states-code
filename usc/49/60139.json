{"tag":"section","attrib":{"id":"idcc85d217-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139"},"text":null,"children":[{"tag":"num","attrib":{"value":"60139"},"text":"§ 60139.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum allowable operating pressure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc85d218-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Verification of Records.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d219-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall require each owner or operator of a pipeline facility to conduct, not later than 6 months after the date of enactment of this section, a verification of the records of the owner or operator relating to the interstate and intrastate gas transmission pipelines of the owner or operator in class 3 and class 4 locations and class 1 and class 2 high-consequence areas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d21a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of the verification shall be to ensure that the records accurately reflect the physical and operational characteristics of the pipelines described in paragraph (1) and confirm the established maximum allowable operating pressure of the pipelines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d21b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The verification process under this subsection shall include such elements as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d21c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d21d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documentation of certain pipelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of enactment of this section, each owner or operator of a pipeline facility shall identify and submit to the Secretary documentation relating to each pipeline segment of the owner or operator described in subsection (a)(1) for which the records of the owner or operator are insufficient to confirm the established maximum allowable operating pressure of the segment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d21e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceedances of maximum allowable operating pressure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If there is an exceedance of the maximum allowable operating pressure with respect to a gas transmission pipeline of an owner or operator of a pipeline facility that exceeds the build-up allowed for operation of pressure-limiting or control devices, the owner or operator shall report the exceedance to the Secretary and appropriate State authorities on or before the 5th day following the date on which the exceedance occurs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d21f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Maximum Allowable Operating Pressure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d220-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a transmission line of an owner or operator of a pipeline facility identified under subsection (b)(1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc85d221-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the owner or operator to reconfirm a maximum allowable operating pressure as expeditiously as economically feasible; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d222-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine what actions are appropriate for the pipeline owner or operator to take to maintain safety until a maximum allowable operating pressure is confirmed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d223-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interim actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In determining the actions for an owner or operator of a pipeline facility to take under paragraph (1)(B), the Secretary shall take into account potential consequences to public safety and the environment, potential impacts on pipeline system reliability and deliverability, and other factors, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d224-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Testing Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d225-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of enactment of this section, the Secretary shall issue regulations for conducting tests to confirm the material strength of previously untested natural gas transmission pipelines located in high-consequence areas and operating at a pressure greater than 30 percent of specified minimum yield strength.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d226-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the regulations, the Secretary shall consider safety testing methodologies, including, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc85d227-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pressure testing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d228-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other alternative methods, including in-line inspections, determined by the Secretary to be of equal or greater effectiveness.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d229-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Completion of testing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in consultation with the Chairman of the Federal Energy Regulatory Commission and State regulators, as appropriate, shall establish timeframes for the completion of such testing that take into account potential consequences to public safety and the environment and that minimize costs and service disruptions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d22a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60139/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"High-consequence Area Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “high-consequence area” means an area described in section 60109(a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc85d22b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90/s23/a"},"text":"Pub. L. 112–90, § 23(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1918"},"text":"125 Stat. 1918","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc85d22c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc85d22d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc85d22e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (a)(1), (b)(1), and (d)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90"},"text":"Pub. L. 112–90","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
