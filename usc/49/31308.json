{"tag":"section","attrib":{"id":"idcb739ec3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31308"},"text":null,"children":[{"tag":"num","attrib":{"value":"31308"},"text":"§ 31308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial driver’s license","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"After consultation with the States, the Secretary of Transportation shall prescribe regulations on minimum uniform standards for the issuance of commercial drivers’ licenses and learner’s permits by the States and for information to be contained on each of the licenses and permits. The standards shall require at a minimum that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb739ec4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31308/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an individual issued a commercial driver’s license—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb739ec5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31308/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pass written and driving tests for the operation of a commercial motor vehicle that comply with the minimum standards prescribed by the Secretary under section 31305(a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739ec6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31308/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" present certification of completion of driver training that meets the requirements established by the Secretary under section 31305(c);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb739ec7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31308/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" before a commercial driver’s license learner’s permit may be issued to an individual, the individual must pass a written test, that complies with the minimum standards prescribed by the Secretary under section 31305(a), on the operation of the commercial motor vehicle that the individual will be operating under the permit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb739ec8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31308/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the license or learner’s permit be tamperproof to the maximum extent practicable and each license or learner’s permit issued after ","children":[{"tag":"date","attrib":{"date":"2001-01-01"},"text":"January 1, 2001","children":[],"tail":", include unique identifiers (which may include biometric identifiers) to minimize fraud and duplication; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb739ec9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31308/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the license or learner’s permit contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb739eca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31308/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of the individual issued the license or learner’s permit and a physical description of the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739ecb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31308/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the social security account number or other number or information the Secretary decides is appropriate to identify the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739ecc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31308/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the class or type of commercial motor vehicle the individual is authorized to operate under the license or learner’s permit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739ecd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31308/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the State that issued the license or learner’s permit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739ece-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31308/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the dates between which the license or learner’s permit is valid.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb739ecf-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1020"},"text":"108 Stat. 1020","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4011/c/1"},"text":"Pub. L. 105–178, title IV, § 4011(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/407"},"text":"112 Stat. 407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4122/2"},"text":"Pub. L. 109–59, title IV, § 4122(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1734"},"text":"119 Stat. 1734","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/tIII/s301/g"},"text":"Pub. L. 110–244, title III, § 301(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1616"},"text":"122 Stat. 1616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32304/b"},"text":"Pub. L. 112–141, div. C, title II, § 32304(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/791"},"text":"126 Stat. 791","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb739ed0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb739ed1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb739ed2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31308","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2705.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/570/s12006"},"text":"Pub. L. 99–570, § 12006","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3207-175"},"text":"100 Stat. 3207–175","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “Not later than ","children":[{"tag":"date","attrib":{"date":"1988-07-15"},"text":"July 15, 1988","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb739ed3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb739ed4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" amended par. (1) generally. Prior to amendment, par. (1) read as follows: “an individual issued a commercial driver’s license pass written and driving tests for the operation of a commercial motor vehicle that comply with the minimum standards prescribed by the Secretary under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31305/a"},"text":"section 31305(a) of this title","children":[],"tail":";”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4122/2/A"},"text":"Pub. L. 109–59, § 4122(2)(A)","children":[],"tail":". See 2005 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4122/2/B"},"text":"Pub. L. 109–59, § 4122(2)(B)","children":[],"tail":", substituted “the licenses and permits” for “the licenses” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4122/2/A"},"text":"Pub. L. 109–59, § 4122(2)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":", inserted “and learner’s permits” after “licenses” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4122/2/D"},"text":"Pub. L. 109–59, § 4122(2)(D)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (3), (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4122/2/C"},"text":"Pub. L. 109–59, § 4122(2)(C)","children":[],"tail":", (E), redesignated pars. (2) and (3) as (3) and (4), respectively, and inserted “or learner’s permit” after “license” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" inserted before semicolon “and each license issued after "},{"tag":"date","attrib":{"date":"2001-01-01"},"text":"January 1, 2001","children":[],"tail":", include unique identifiers (which may include biometric identifiers) to minimize fraud and duplication”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb739ed5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb739ed6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb739ed7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" effective as of the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":") and to be treated as included in "},{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" as of that date, and provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", as in effect on the day before "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", that are amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" to be treated as not enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/s121/b"},"text":"section 121(b) of Pub. L. 110–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb739ed8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Issuance of Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4011/c/2"},"text":"Pub. L. 105–178, title IV, § 4011(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/407"},"text":"112 Stat. 407","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/178/tIV/s4011/c/2"},"text":"“Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":"], the Secretary [of Transportation] shall issue regulations to carry out the amendment made by paragraph (1) [amending this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb739ed9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Commercial Learner’s Permit for Individuals Under Age 18","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/dL/tI/s132"},"text":"Pub. L. 114–113, div. L, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2850"},"text":"129 Stat. 2850","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/113/dL/tI/s132"},"text":"“None of the funds limited or otherwise made available under this Act, or any other Act, hereafter, shall be used by the Secretary to enforce any regulation prohibiting a State from issuing a commercial learner’s permit to individuals under the age of eighteen if the State had a law authorizing the issuance of commercial learner’s permits to individuals under eighteen years of age as of ","children":[{"tag":"date","attrib":{"date":"2011-05-09"},"text":"May 9, 2011","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
