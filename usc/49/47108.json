tml:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47108(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2211(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/248/s512/a"},"text":"Pub. L. 97–248, § 512(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/688"},"text":"96 Stat. 688","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/223"},"text":"Pub. L. 100–223","children":[],"tail":", §§ 106(b)(4), 110(c), "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1498"},"text":"101 Stat. 1498","children":[],"tail":", 1502."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47108(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2211(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/248/s512/b"},"text":"Pub. L. 97–248, § 512(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/688"},"text":"96 Stat. 688","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/223/s110/a"},"text":"Pub. L. 100–223, § 110(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1502"},"text":"101 Stat. 1502","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 31, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/581/s109"},"text":"Pub. L. 102–581, § 109","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4879"},"text":"106 Stat. 4879","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47108(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2211(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47108(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2211(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/324"},"text":"96 Stat. 324","children":[],"tail":", § 512(d); added "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/223/s110/b"},"text":"Pub. L. 100–223, § 110(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1502"},"text":"101 Stat. 1502","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “on behalf of the United States” are omitted as surplus. The words “or sponsors” are omitted because of 1:1. The words “of the application” are omitted as surplus. The words “under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47110"},"text":"section 47110 of this title","children":[],"tail":"” are added for clarity. The words “and conditions” are omitted as being included in “terms”. The words “for the project” are added for clarity. The words “an offer of a grant for a project” are substituted for “In any case where the Secretary approves a project grant application for a project . . . the offer” to eliminate unnecessary words. The words “(including future fiscal years)” are omitted as surplus. The words “An offer that is accepted in writing by the sponsor is an agreement binding on the Government and the sponsor” are substituted for “If and when an offer is accepted in writing by the sponsor, the offer and acceptance shall comprise an agreement constituting an obligation of the United States and of the sponsor” to eliminate unnecessary words. The words “which have been or may be incurred” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “by a sponsor” are omitted as surplus. The words “amount the Government will pay” are substituted for “obligation of the United States” for clarity and consistency in this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the text of 49 App.:2211(b)(2) (last sentence) is restated to apply only to 49 App.:2211(b)(2) (1st sentence) to carry out the probable intent of Congress.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3)(B), the words “for fiscal year 1993 and thereafter” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Notwithstanding any other provision of law” are omitted as surplus. The words “a project receiving assistance under” are added for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “sponsor” is substituted for “grant recipient” for clarity. The words “amount the Government may pay” are substituted for “obligation of the United States authorized” for clarity and consistency in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc4c9920-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc4c9921-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Airport and Airway Improvement Act of 1982, referred to in subsec. (b)(2)(A), (3), is title V of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/671"},"text":"96 Stat. 671","children":[],"tail":", which was classified principally to chapter 31 (§ 2201 et seq.) of former Title 49, Transportation, and was substantially repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s7/b"},"text":"Pub. L. 103–272, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1379"},"text":"108 Stat. 1379","children":[],"tail":", and reenacted by the first section thereof as this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc4f0a22-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s707/1"},"text":"Pub. L. 118–63, § 707(1)","children":[],"tail":", substituted “47114(d)(2)(A)” for “47114(d)(3)(A) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s707/2"},"text":"Pub. L. 118–63, § 707(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which allowed increasing Government’s share after an offer has been accepted in writing in certain circumstances."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s707/3"},"text":"Pub. L. 118–63, § 707(3)","children":[],"tail":", (4), redesignated subsecs. (d) and (e) as (c) and (d), respectively, and struck out former subsec. (c). Prior to amendment, text of subsec. (c) read as follows: “For a project receiving assistance under a grant made under the Airport and Airway Development Act of 1970, the maximum amount the Government will pay may be increased by not more than 10 percent. An increase under this subsection may be paid only from amounts the Government recovers from other grants made under the Act.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":" substituted “accordance with section 47119(a)” for “accordance with section 47110(d)(2)” and “allowable under section 47119(a)” for “allowable under section 47110(d)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/115"},"text":"Pub. L. 109–115","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" inserted “or 47114(d)(3)(A)” after “under section 47114(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc4f0a23-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc4f0a24-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc4f0a25-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc4f0a26-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Land Acquisition Costs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s143"},"text":"Pub. L. 107–71, title I, § 143","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/644"},"text":"115 Stat. 644","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/71/tI/s143"},"text":"“In the case of a grant for land acquisition issued to an airport under chapter 471 of title 49, United States Code, prior to ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":", the Secretary of Transportation may waive the provisions of section 47108 of such title and provide an upward adjustment in the maximum obligation of the United States under that chapter to assist the airport in funding land acquisition costs (and associated eligible costs) that increased as a result of a judicial order.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “airport” and “United States” used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s143"},"text":"section 143 of Pub. L. 107–71","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/s133"},"text":"section 133 of Pub. L. 107–71","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102"},"text":"section 40102 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
