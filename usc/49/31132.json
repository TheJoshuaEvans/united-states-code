.:2503(9) is omitted as surplus because the complete name of the Secretary of Transportation is used the first time the term appears in a section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb62fd45-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb62fd46-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31140"},"text":"Section 31140 of this title","children":[],"tail":", referred to in par. (8), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4008/d"},"text":"Pub. L. 105–178, title IV, § 4008(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/404"},"text":"112 Stat. 404","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb62fd47-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Pars. (6) to (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" added par. (6) and redesignated former pars. (6) to (10) as (7) to (11), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4008/a/1"},"text":"Pub. L. 105–178, § 4008(a)(1)","children":[],"tail":", inserted “or gross vehicle weight” after “rating” and “, whichever is greater” after “pounds”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4008/a/2"},"text":"Pub. L. 105–178, § 4008(a)(2)","children":[],"tail":", which directed substitution of “more than 8 passengers (including the driver) for compensation;” for “passengers” and all that follows through semicolon at end, was executed by making the substitution for “passengers for compensation, but excluding vehicles providing taxicab service and having a capacity of not more than 6 passengers and not operated on a regular route or between specified places;” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Par. (1)(B) to (D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" added subpars. (B) and (C), redesignated former subpar. (C) as (D), and struck out former subpar. (B) which read as follows: “is designed to transport more than 15 passengers including the driver; or”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb62fd48-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb62fd49-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
