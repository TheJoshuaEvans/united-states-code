{"tag":"section","attrib":{"id":"idcb62fd2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132"},"text":null,"children":[{"tag":"num","attrib":{"value":"31132"},"text":"§ 31132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb62fd2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “commercial motor vehicle” means a self-propelled or towed vehicle used on the highways in interstate commerce to transport passengers or property, if the vehicle—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb62fd2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a gross vehicle weight rating or gross vehicle weight of at least 10,001 pounds, whichever is greater;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb62fd2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed or used to transport more than 8 passengers (including the driver) for compensation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb62fd2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed or used to transport more than 15 passengers, including the driver, and is not used to transport passengers for compensation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb62fd30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is used in transporting material found by the Secretary of Transportation to be hazardous under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5103"},"text":"section 5103 of this title","children":[],"tail":" and transported in a quantity requiring placarding under regulations prescribed by the Secretary under section 5103."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb62fd31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee” means an operator of a commercial motor vehicle (including an independent contractor when operating a commercial motor vehicle), a mechanic, a freight handler, or an individual not an employer, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb62fd32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly affects commercial motor vehicle safety in the course of employment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb62fd33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an employee of the United States Government, a State, or a political subdivision of a State acting in the course of the employment by the Government, a State, or a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb62fd34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employer”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb62fd35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a person engaged in a business affecting interstate commerce that owns or leases a commercial motor vehicle in connection with that business, or assigns an employee to operate it; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb62fd36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the Government, a State, or a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb62fd37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “interstate commerce” means trade, traffic, or transportation in the United States between a place in a State and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb62fd38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a place outside that State (including a place outside the United States); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb62fd39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another place in the same State through another State or through a place outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb62fd3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “intrastate commerce” means trade, traffic, or transportation in a State that is not interstate commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb62fd3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “medical examiner” means an individual licensed, certified, or registered in accordance with regulations issued by the Federal Motor Carrier Safety Administration as a medical examiner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb62fd3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “regulation” includes a standard or order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb62fd3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State of the United States, the District of Columbia, and, in sections 31136 and 31140–31142 ","children":[{"tag":"ref","attrib":{"idref":"fn002118"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002118"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, a political subdivision of a State."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb62fd3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State law” includes a law enacted by a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb62fd3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State regulation” includes a regulation prescribed by a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb62fd40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31132/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States” means the States of the United States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb62fd41-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1000"},"text":"108 Stat. 1000","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s104/f"},"text":"Pub. L. 104–88, title I, § 104(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/919"},"text":"109 Stat. 919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4008/a"},"text":"Pub. L. 105–178, title IV, § 4008(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/404"},"text":"112 Stat. 404","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4116/c"},"text":"Pub. L. 109–59, title IV, § 4116(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1728"},"text":"119 Stat. 1728","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb62fd42-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb62fd43-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb62fd44-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{