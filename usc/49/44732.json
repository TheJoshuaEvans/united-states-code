{"tag":"section","attrib":{"id":"idcc0779b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44732"},"text":null,"children":[{"tag":"num","attrib":{"value":"44732"},"text":"§ 44732.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on personal use of electronic devices on flight deck","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc0779b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44732/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It is unlawful for a flight crewmember of an aircraft used to provide air transportation under part 121 of title 14, Code of Federal Regulations, to use a personal wireless communications device or laptop computer while at the flight crewmember’s duty station on the flight deck of such an aircraft while the aircraft is being operated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0779b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44732/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not apply to the use of a personal wireless communications device or laptop computer for a purpose directly related to operation of the aircraft, or for emergency, safety-related, or employment-related communications, in accordance with procedures established by the air carrier and the Administrator of the Federal Aviation Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0779b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44732/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to the penalties provided under section 46301 applicable to any violation of this section, the Administrator of the Federal Aviation Administration may enforce compliance with this section under section 44709 by amending, modifying, suspending, or revoking a certificate under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0779ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44732/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Personal Wireless Communications Device Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “personal wireless communications device” means a device through which personal wireless services (as defined in section 332(c)(7)(C)(i) of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s332/c/7/C/i"},"text":"47 U.S.C. 332(c)(7)(C)(i)","children":[],"tail":")) are transmitted."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc0779bb-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIII/s307/a"},"text":"Pub. L. 112–95, title III, § 307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/61"},"text":"126 Stat. 61","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc0779bc-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc0779bd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc0779be-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIII/s307/d"},"text":"Pub. L. 112–95, title III, § 307(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/62"},"text":"126 Stat. 62","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/95/tIII/s307/d"},"text":"“Not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":"], the Administrator of the Federal Aviation Administration shall initiate a rulemaking procedure for regulations to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44732"},"text":"section 44732 of title 49","children":[],"tail":", United States Code (as added by this section), and shall issue a final rule thereunder not later than 2 years after the date of enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
