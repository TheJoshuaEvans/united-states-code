{"tag":"section","attrib":{"id":"idcb8b9381-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32916"},"text":null,"children":[{"tag":"num","attrib":{"value":"32916"},"text":"§ 32916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb8b9382-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32916/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than January 15 of each year, the Secretary of Transportation shall submit to each House of Congress, and publish in the Federal Register, a report on the review by the Secretary of average fuel economy standards prescribed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8b9383-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32916/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint Examinations After Granting Exemptions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8b9384-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32916/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After an exemption has been granted under section 32904(b)(6) ","children":[{"tag":"ref","attrib":{"idref":"fn002136"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002136"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title, the Secretaries of Transportation and Labor shall conduct annually a joint examination of the extent to which section 32904(b)(6)—"},{"tag":"ref","attrib":{"idref":"fn002136"},"text":"1","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8b9385-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32916/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" achieves the purposes of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b9386-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32916/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves fuel efficiency (thereby facilitating conservation of petroleum and reducing petroleum imports);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b9387-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32916/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has promoted employment in the United States related to automobile manufacturing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b9388-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32916/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not caused unreasonable harm to the automobile manufacturing sector in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b9389-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32916/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has permitted manufacturers that have assembled passenger automobiles deemed to be manufactured domestically under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32904/b/2"},"text":"section 32904(b)(2) of this title","children":[],"tail":" thereafter to assemble in the United States passenger automobiles of the same model that have less than 75 percent of their value added in the United States or Canada, together with the reasons."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8b938a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32916/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall include the results of the examination under paragraph (1) of this subsection in each report submitted under subsection (a) of this section more than 180 days after an exemption has been granted under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32904/b/6"},"text":"section 32904(b)(6) of this title","children":[],"tail":", or submit the results of the examination directly to Congress before the report is submitted when circumstances warrant."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb8b938b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1074"},"text":"108 Stat. 1074","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/42"},"text":"Pub. L. 103–429, § 6(42)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4382"},"text":"108 Stat. 4382","children":[],"tail":