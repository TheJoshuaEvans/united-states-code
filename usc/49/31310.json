{"tag":"section","attrib":{"id":"idcb739f13-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310"},"text":null,"children":[{"tag":"num","attrib":{"value":"31310"},"text":"§ 31310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disqualifications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb739f14-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Blood Alcohol Concentration Level","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the blood alcohol concentration level at or above which an individual when operating a commercial motor vehicle is deemed to be driving under the influence of alcohol is .04 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb739f15-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"First Violation or Committing Felony","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb739f16-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2) of this subsection and subsection (c) of this section, the Secretary of Transportation shall disqualify from operating a commercial motor vehicle for at least one year an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb739f17-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committing a first violation of driving a commercial motor vehicle under the influence of alcohol or a controlled substance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739f18-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committing a first violation of leaving the scene of an accident involving a commercial motor vehicle operated by the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739f19-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using a commercial motor vehicle in committing a felony (except a felony described in subsection (d) of this section);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739f1a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committing a first violation of driving a commercial motor vehicle when the individual’s commercial driver’s license is revoked, suspended, or canceled based on the individual’s operation of a commercial motor vehicle or when the individual is disqualified from operating a commercial motor vehicle based on the individual’s operation of a commercial motor vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739f1b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convicted of causing a fatality through negligent or criminal operation of a commercial motor vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb739f1c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the vehicle involved in a violation referred to in paragraph (1) of this subsection is transporting hazardous material required to be placarded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5103"},"text":"section 5103 of this title","children":[],"tail":", the Secretary shall disqualify the individual for at least 3 years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb739f1d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Second and Multiple Violations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb739f1e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2) of this subsection, the Secretary shall disqualify from operating a commercial motor vehicle for life an individual—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb739f1f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committing more than one violation of driving a commercial motor vehicle under the influence of alcohol or a controlled substance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739f20-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committing more than one violation of leaving the scene of an accident involving a commercial motor vehicle operated by the individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739f21-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using a commercial motor vehicle in committing more than one felony arising out of different criminal episodes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739f22-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committing more than one violation of driving a commercial motor vehicle when the individual’s commercial driver’s license is revoked, suspended, or canceled based on the individual’s operation of a commercial motor vehicle or when the individual is disqualified from operating a commercial motor vehicle based on the individual’s operation of a commercial motor vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739f23-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" convicted of more than one offense of causing a fatality through negligent or criminal operation of a commercial motor vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb739f24-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" committing any combination of single violations or use described in subparagraphs (A) through (E).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb739f25-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may prescribe regulations establishing guidelines (including conditions) under which a disqualification for life under paragraph (1) of this subsection may be reduced to a period of not less than 10 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb739f26-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Lifetime Disqualification Without Reinstatement","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb739f27-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Controlled substance violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall disqualify from operating a commercial motor vehicle for life an individual who uses a commercial motor vehicle in committing a felony involving manufacturing, distributing, or dispensing a controlled substance, or possession with intent to manufacture, distribute, or dispense a controlled substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb739f28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Human trafficking violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall disqualify from operating a commercial motor vehicle for life an individual who uses a commercial motor vehicle in committing a felony involving an act or practice described in paragraph (9) ","children":[{"tag":"ref","attrib":{"idref":"fn002123"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002123"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of section 103 of the Trafficking Victims Protection Act of 2000 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/9"},"text":"22 U.S.C. 7102(9)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb739f29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Serious Traffic Violations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb739f2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall disqualify from operating a commercial motor vehicle for at least 60 days an individual who, in a 3-year period, commits 2 serious traffic violations involving a commercial motor vehicle operated by the individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb739f2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall disqualify from operating a commercial motor vehicle for at least 120 days an individual who, in a 3-year period, commits 3 serious traffic violations involving a commercial motor vehicle operated by the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb760f2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emergency Disqualification.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb760f2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limited duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall disqualify an individual from operating a commercial motor vehicle for not to exceed 30 days if the Secretary determines that allowing the individual to continue to operate a commercial motor vehicle would create an imminent hazard (as such term is defined in section 521 or section 5102).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb760f2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"After notice and hearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall disqualify an individual from operating a commercial motor vehicle for more than 30 days if the Secretary determines, after notice and an opportunity for a hearing, that allowing the individual to continue to operate a commercial motor vehicle would create an imminent hazard (as such term is defined in section 521 or section 5102).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb760f2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Noncommercial Motor Vehicle Convictions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb760f30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance of regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue regulations providing for the disqualification by the Secretary from operating a commercial motor vehicle of an individual who holds a commercial driver’s license and who has been convicted of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb760f31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a serious offense involving a motor vehicle (other than a commercial motor vehicle) that has resulted in the revocation, cancellation, or suspension of the individual’s license; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb760f32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a drug or alcohol related offense involving a motor vehicle (other than a commercial motor vehicle).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb760f33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations issued under paragraph (1) shall establish the minimum periods for which the disqualifications shall be in effect, but in no case shall the time periods for disqualification for noncommercial motor vehicle violations be more stringent than those for offenses or violations involving a commercial motor vehicle. The Secretary shall determine such periods based on the seriousness of the offenses on which the convictions are based.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb760f34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Disqualification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsections (b) through (g) of this section, the Secretary does not have to disqualify an individual from operating a commercial motor vehicle if the State that issued the individual a license authorizing the operation has disqualified the individual from operating a commercial motor vehicle under subsections (b) through (g). Revocation, suspension, or cancellation of the license is deemed to be disqualification under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb760f35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Out-of-Service Orders","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb760f36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb760f37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To enforce section 392.5 of title 49, Code of Federal Regulations, the Secretary shall prescribe regulations establishing and enforcing an out-of-service period of 24 hours for an individual who violates section 392.5. An individual may not violate an out-of-service order issued under those regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb760f38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe regulations establishing and enforcing requirements for reporting out-of-service orders issued under regulations prescribed under subparagraph (A) of this paragraph. Regulations prescribed under this subparagraph shall require at least that an operator of a commercial motor vehicle who is issued an out-of-service order to report the issuance to the individual’s employer and to the State that issued the operator a driver’s license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb760f39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall prescribe regulations establishing sanctions and penalties related to violations of out-of-service orders by individuals operating commercial motor vehicles. The regulations shall require at least that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb760f3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an operator of a commercial motor vehicle found to have committed a first violation of an out-of-service order shall be disqualified from operating such a vehicle for at least 180 days and liable for a civil penalty of at least $2,500;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb760f3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an operator of a commercial motor vehicle found to have committed a 2d violation of an out-of-service order shall be disqualified from operating such a vehicle for at least 2 years and not more than 5 years and liable for a civil penalty of at least $5,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb760f3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employer that knowingly allows or requires an employee to operate a commercial motor vehicle in violation of an out-of-service order shall be liable for a civil penalty of not more than $25,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb760f3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/i/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employer that knowingly and willfully allows or requires an employee to operate a commercial motor vehicle in violation of an out-of-service order shall, upon conviction, be subject for each offense to imprisonment for a term not to exceed one year or a fine under title 18, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb760f3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grade-Crossing Violations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb760f3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sanctions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall issue regulations establishing sanctions and penalties relating to violations, by persons operating commercial motor vehicles, of laws and regulations pertaining to railroad-highway grade crossings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb760f40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations issued under paragraph (1) shall, at a minimum, require that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb760f41-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the penalty for a single violation is not less than a 60-day disqualification of the driver’s commercial driver’s license; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb760f42-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employer that knowingly allows, permits, authorizes, or requires an employee to operate a commercial motor vehicle in violation of such a law or regulation shall be subject to a civil penalty of not more than $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb760f43-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31310/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Commercial Drivers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A foreign commercial driver shall be subject to disqualification under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb760f44-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1022"},"text":"108 Stat. 1022","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIV/s403/a"},"text":"Pub. L. 104–88, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/956"},"text":"109 Stat. 956","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/159/tII/s201/a/1"},"text":"Pub. L. 106–159, title II, § 201(a)(1)","children":[],"tail":", (2), (b), "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1758"},"text":"113 Stat. 1758","children":[],"tail":", 1759; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4102/b"},"text":"Pub. L. 109–59, title IV, § 4102(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1715"},"text":"119 Stat. 1715","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII"},"text":"Pub. L. 112–141, div. C, title II","children":[],"tail":", §§ 32204, 32507, 32931(d), "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/785"},"text":"126 Stat. 785","children":[],"tail":", 804, 829; "},{"tag":"ref","attrib":{"href":"/us/pl/115/106/s2"},"text":"Pub. L. 115–106, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-08"},"text":"Ja