hildren":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31310(g)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2718.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/570"},"text":"Pub. L. 99–570","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3207-170"},"text":"100 Stat. 3207–170","children":[],"tail":", § 12020; added "},{"tag":"html:span","attrib":{},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/240/s4009/a"},"text":"Pub. L. 102–240, § 4009(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/2156"},"text":"105 Stat. 2156","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the text of 49 App.:2707(f)(1)–(4) (words before 2d comma) is omitted as executed and obsolete. The words “and section 2708 of the Appendix” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “involved in a violation” are substituted for “operated or used in connection with the violation or the commission of the felony” to eliminate unnecessary words. The words “by the Secretary” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c)(1)(D) is substituted for 49 App.:2707(a)(2)(A)(iv) for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g)(1)(A), the words “Not later than 1 year after ","children":[{"tag":"date","attrib":{"date":"1986-10-27"},"text":"October 27, 1986","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g)(2), before clause (A), the words “Not later than ","children":[{"tag":"date","attrib":{"date":"1992-12-18"},"text":"December 18, 1992","children":[],"tail":", the Secretary shall prescribe regulations” are substituted for “The Secretary shall issue regulations” and 49 App.:2718(c) to eliminate executed words. The word “individuals” is substituted for “persons” for clarity and consistency in the revised title and with other titles of the United States Code. In clause (C), the words “permits, authorizes” are omitted as being included in “allows”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb760f48-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb760f49-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Paragraph (9) of section 103 of the Trafficking Victims Protection Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/9"},"text":"22 U.S.C. 7102(9)","children":[],"tail":"), referred to in subsec. (d)(2), was redesignated par. (11) of section 103 of that Act by "},{"tag":"ref","attrib":{"href":"/us/pl/115/427/s2/1"},"text":"Pub. L. 115–427, § 2(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5503"},"text":"132 Stat. 5503","children":[],"tail":", and is classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102/11"},"text":"section 7102(11) of Title 22","children":[],"tail":", Foreign Relations and Intercourse."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb760f4a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/106"},"text":"Pub. L. 115–106","children":[],"tail":" substituted “Lifetime Disqualification Without Reinstatement” for “Controlled Substance Violations” in heading, inserted par. (1) designation and heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32507"},"text":"Pub. L. 112–141, § 32507","children":[],"tail":", inserted “section 521 or” before “section 5102” in pars. (1) and (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32931/d"},"text":"Pub. L. 112–141, § 32931(d)","children":[],"tail":", which directed substitution of “The” for “Not later than 1 year after the date of enactment of this Act, the”, was executed by making the substitution for “Not later than 1 year after the date of the enactment of this Act, the”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32204"},"text":"Pub. L. 112–141, § 32204","children":[],"tail":", added subsec. (k)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (i)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4102/b/1"},"text":"Pub. L. 109–59, § 4102(b)(1)","children":[],"tail":", substituted “The Secretary” for “Not later than "},{"tag":"date","attrib":{"date":"1992-12-18"},"text":"December 18, 1992","children":[],"tail":", the Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4102/b/2"},"text":"Pub. L. 109–59, § 4102(b)(2)","children":[],"tail":", substituted “180 days” for “90 days” and “$2,500” for “$1,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4102/b/3"},"text":"Pub. L. 109–59, § 4102(b)(3)","children":[],"tail":", substituted “2 years” for “one year” and “$5,000;” for “$1,000; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4102/b/4"},"text":"Pub. L. 109–59, § 4102(b)(4)","children":[],"tail":", substituted “$25,000; and” for “$10,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4102/b/5"},"text":"Pub. L. 109–59, § 4102(b)(5)","children":[],"tail":", added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (b)(1)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/s201/a/1"},"text":"Pub. L. 106–159, § 201(a)(1)","children":[],"tail":", added subpars. (D) and (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/s201/a/2/A"},"text":"Pub. L. 106–159, § 201(a)(2)(A)","children":[],"tail":", (C), added subpars. (D) and (E). Former subpar. (D) redesignated (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/s201/a/2/B"},"text":"Pub. L. 106–159, § 201(a)(2)(B)","children":[],"tail":", (D), redesignated subpar. (D) as (F) and substituted “subparagraphs (A) through (E)” for “clauses (A)–(C) of this paragraph”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/s201/b/2"},"text":"Pub. L. 106–159, § 201(b)(2)","children":[],"tail":", added subsecs. (f) and (g). Former subsecs. (f) and (g) redesignated (h)