{"tag":"section","attrib":{"id":"idcbce4135-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743"},"text":null,"children":[{"tag":"num","attrib":{"value":"41743"},"text":"§ 41743.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Airports not receiving sufficient service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbce4136-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Small Community Air Service Development Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall establish a program that meets the requirements of this section for improving air carrier service to airports not receiving sufficient air carrier service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbce4137-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to participate in the program established under subsection (a), a community or consortium of communities shall submit an application to the Secretary in such form, at such time, and containing such information as the Secretary may require, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbce4138-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the need of the community or consortium for access, or improved access, to the national air transportation system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4139-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the application of the criteria in subsection (c) to that community or consortium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbce413a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Participation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting communities, or consortia of communities, for participation in the program established under subsection (a), the Secretary shall apply the following criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbce413b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Size","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the date of submission of the relevant application under subsection (b), the airport serving the community or consortium—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbce413c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not larger than a small hub airport, as determined using the Department of Transportation’s most recently published classification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce413d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbce413e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insufficient air carrier service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbce413f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unreasonably high air fares.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4140-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Characteristics","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The airport presents characteristics, such as geographic diversity or unique circumstances, that will demonstrate the need for, and feasibility of, the program established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4141-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State limit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than 4 communities or consortia of communities, or a combination thereof, from the same State may be selected to participate in the program in any fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4142-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Overall limit.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbce4143-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No more than 40 communities or consortia of communities, or a combination thereof, may be selected to participate in the program in each year for which funds are appropriated for the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce4144-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Same projects","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (C), no community, consortia of communities, or combination thereof may participate in the program in support of the same project more than once in a 5-year period, but any community, consortia of communities, or combination thereof may apply, subsequent to such participation, to participate in the program in support of a different project at any time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce4145-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may waive the limitation under subparagraph (B) related to projects that are the same if the Secretary determines that the community or consortium spent little or no money on its previous project or encountered industry or environmental challenges, due to circumstances that were reasonably beyond the control of the community or consortium.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4146-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall give priority to communities or consortia of communities where—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbce4147-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" air fares are higher than the average air fares for all communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce4148-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the community has demonstrated support from at least 1 air carrier to provide service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce4149-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the community or consortium will provide a portion of the cost of the activity to be assisted under the program from local sources other than airport revenues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce414a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the community or consortium has established, or will establish, a public-private partnership to facilitate air carrier service to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce414b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assistance will provide material benefits to a broad segment of the travelling public, including business, educational institutions, and other enterprises, whose access to the national air transportation system is limited;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce414c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/5/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assistance will be used to help restore scheduled passenger air service that has been terminated or substantially reduced (as measured by enplanements, capacity (seats), schedule, connections, or routes);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce414d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/5/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assistance will be used in a timely fashion; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce414e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/c/5/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple communities cooperate to submit a regional or multistate application to consolidate air service into one regional airport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbce414f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Types of Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may use amounts made available under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbce4150-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance to an air carrier to subsidize service to and from an underserved airport for a period not to exceed 3 years, which shall begin with each new grant, including same-project new grants, and which shall be calculated on a non-consecutive basis for air carriers that provide air service that is seasonal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4151-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance to an underserved airport, or an airport where air service has been terminated or substantially reduced, to obtain service to and from the underserved airport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4152-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide assistance to an underserved airport to implement such other measures as the Secretary, in consultation with such airport, considers appropriate to improve air service both in terms of the cost of such service to consumers and the availability of such service, including improving air service through marketing and promotion of air service and enhanced utilization of airport facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbce4153-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Make Agreements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbce4154-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make agreements to provide assistance under this section. The Secretary may amend the scope of a grant agreement at the request of the community or consortium and any participating air carrier, and may limit the scope of a grant agreement to only the elements using grant assistance or to only the elements achieved, if the Secretary determines that the amendment is reasonably consistent with the original purpose of the project or the community’s current air service needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4155-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary $15,000,000 for each of fiscal years 2024 through 2028, to carry out this section. Such sums shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbce4156-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Responsible Official","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall designate an employee of the Department of Transportation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbce4157-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to function as a facilitator between small communities and air carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4158-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4159-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that the Bureau of Transportation Statistics collects data on passenger information to assess the service needs of small communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce415a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to work with and coordinate efforts with other Federal, State, and local agencies to increase the viability of service to small communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce415b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41743/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide policy recommendations to the Secretary and Congress that will ensure that small communities have access to quality, affordable air transportation services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbce415c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tII/s203/a"},"text":"Pub. L. 106–181, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/92"},"text":"114 Stat. 92","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/11/tII/s2708"},"text":"Pub. L. 108–11, title II, § 2708","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-04-16"},"text":"Apr. 16, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/601"},"text":"117 Stat. 601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tII/s225/b/3"},"text":"Pub. L. 108–176, title II, § 225(b)(3)","children":[],"tail":", title IV, § 412, "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2529"},"text":"117 Stat. 2529","children":[],"tail":", 2551; "},{"tag":"ref","attrib":{"href":"/us/pl/110/330/s5/b"},"text":"Pub. L. 110–330, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-09-30"},"text":"Sept. 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/3718"},"text":"122 Stat. 3718","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/69/s5/b"},"text":"Pub. L. 111–69, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-01"},"text":"Oct. 1, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2055"},"text":"123 Stat. 2055","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/249/s5/b"},"text":"Pub. L. 111–249, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-09-30"},"text":"Sept. 30, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2628"},"text":"124 Stat. 2628","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/30/tII/s205/b"},"text":"Pub. L. 112–30, title II, § 205(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-09-16"},"text":"Sept. 16, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/358"},"text":"125 Stat. 358","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/91/s5/b"},"text":"Pub. L. 112–91, § 5(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-01-31"},"text":"Jan. 31, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/4"},"text":"126 Stat. 4","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIV/s429"},"text":"Pub. L. 112–95, title IV, § 429","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/100"},"text":"126 Stat. 100","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/190/tI/s1102/e"},"text":"Pub. L. 114–190, title I, § 1102(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/617"},"text":"130 Stat. 617","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/63/tI/s104/b"},"text":"Pub. L. 115–63, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-09-29"},"text":"Sept. 29, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1170"},"text":"131 Stat. 1170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/141/dM/tI/s104/b"},"text":"Pub. L. 115–141, div. M, title I, § 104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-03-23"},"text":"Mar. 23, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/1047"},"text":"132 Stat. 1047","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIV/s455"},"text":"Pub. L. 115–254, div. B, title IV, § 455","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"