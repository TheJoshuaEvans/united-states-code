{"tag":"section","attrib":{"id":"idcac0c979-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5335"},"text":null,"children":[{"tag":"num","attrib":{"value":"5335"},"text":"§ 5335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National transit database","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcac0c97a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5335/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Transit Database","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To help meet the needs of individual public transportation systems, the United States Government, State and local governments, and the public for information on which to base public transportation service planning, the Secretary shall maintain a reporting system, using uniform categories to accumulate public transportation financial, operating, geographic service area coverage, and asset condition information and using a uniform system of accounts. The reporting and uniform systems shall contain appropriate information to help any level of government make a public sector investment decision. The Secretary may request and receive appropriate information from any source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcac0c97b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5335/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting and Uniform Systems","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may award a grant under section 5307 or 5311 only if the applicant, and any person that will receive benefits directly from the grant, are subject to the reporting and uniform systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcac0c97c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5335/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data Required to Be Reported","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient of a grant under this chapter shall report to the Secretary, for inclusion in the national transit database under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcac0c97d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5335/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information relating to a transit asset inventory or condition assessment conducted by the recipient;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcac0c97e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5335/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any data on assaults on transit workers of the recipients; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcac0c97f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5335/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any data on fatalities that result from an impact with a bus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcac0c980-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{