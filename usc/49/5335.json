ref":"/us/stat/105/2115"},"text":"105 Stat. 2115","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5335(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1623(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the text of 49 App.:1608(j) is omitted as superseded by 31:ch. 75.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “by ","children":[{"tag":"date","attrib":{"date":"1977-01-10"},"text":"January 10, 1977","children":[],"tail":"” are omitted as executed. The word “maintain” is substituted for “develop, test, and prescribe” for clarity. The text of 49 App.:1611(a) (3d and 4th sentences) is omitted as executed. The words “or data as he deems” and “public or private” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “After ","children":[{"tag":"date","attrib":{"date":"1978-07-01"},"text":"July 1, 1978","children":[],"tail":"” are omitted as executed. The reference to 49 App.:1604 is omitted as obsolete. The words “for such grant”, “or organization”, “each . . . both”, and “prescribed under subsection (a) of this section” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “commitments, and reservations” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2) and (3), the words “uncommitted, and unreserved” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3) and (5), the words “last day” are substituted for “close” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(4), the words “a listing of” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(5), the words “a status report on all” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(6), the words “a status report on”, “a letter of credit or other”, and “already” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), before clause (1), the words “the transferability provisions of” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcac0c984-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/18"},"text":"Pub. L. 104–287, § 5(18)","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:5335(d)(2)(B) to amend an erroneous cross-reference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcac0c985-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcac0c986-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s30014/1"},"text":"Pub. L. 117–58, § 30014(1)","children":[],"tail":", inserted “geographic service area coverage,” after “operating,” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s30014/2"},"text":"Pub. L. 117–58, § 30014(2)","children":[],"tail":", added subsec. (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “The recipient of a grant under this chapter shall report to the Secretary, for inclusion in the National Transit Database, any information relating to a transit asset inventory or condition assessment conducted by the recipient.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", §§ 20025(a)(1), 20030(j), struck out “of Transportation” after “the Secretary” and substituted “public transportation financial, operating, and asset condition information” for “public transportation financial and operating information”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s20025/a/2"},"text":"Pub. L. 112–141, § 20025(a)(2)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s3033/a"},"text":"Pub. L. 109–59, § 3033(a)","children":[],"tail":", substituted “National transit database” for “Reports and audits” in section catchline, redesignated pars. (1) and (2) of subsec. (a) as subsecs. (a) and (b), respectively, inserted subsec. (b) heading, substituted “The Secretary may award a grant under section 5307 or 5311” for “The Secretary may make a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5307"},"text":"section 5307 of this title","children":[],"tail":"” in subsec. (b), and struck out former subsec. (b) which related to submission of a report in January- 1993, on carrying out former "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5307/b/5"},"text":"section 5307(b)(5) of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"