il":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “at a minimum” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “streamline and”, “with respect to a person who is required to file a registration statement under this subsection”, and “with the Department of Transportation” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the word “impose” is substituted for “assess” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g)(2)(A), before clause (i), the words “Not later than ","children":[{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":"” are omitted as obsolete. In clause (viii), the words “of funds” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g)(2)(B), the words “of fees” and “from persons” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (i)(1), the words “(relating to coordination of Federal information policy)” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (i)(2)(A), the words “Notwithstanding any other provisions of this subsection” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca8c4c5a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:5108(f) to correct an erroneous cross-reference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8c4c5b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca8c4c5c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (g)(2)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" substituted “5116(h)” for “5116(i)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary” for “Secretary of Transportation” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7109/a/1"},"text":"Pub. L. 109–59, § 7109(a)(1)","children":[],"tail":", substituted “Division 1.1, 1.2, or 1.3 explosive material” for “class A or B explosive”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary may” for “Secretary of Transportation may” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7109/a/2"},"text":"Pub. L. 109–59, § 7109(a)(2)","children":[],"tail":", amended subpar. (B) generally. Prior to amendment, subpar. (B) read as follows: “a person manufacturing, fabricating, marking, maintaining, reconditioning, repairing, or testing a package or container the person represents, marks, certifies, or sells for use in transporting in commerce hazardous material the Secretary designates.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7109/a/3"},"text":"Pub. L. 109–59, § 7109(a)(3)","children":[],"tail":", substituted “design, manufacture, fabricate, inspect, mark, maintain, recondition, repair, or test a package, container packaging component, or” for “manufacture, fabricate, mark, maintain, recondition, repair, or test a package or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary requires” for “Secretary of Transportation requires” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7109/b"},"text":"Pub. L. 109–59, § 7109(b)","children":[],"tail":", substituted “any of the activities” for “the activity”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7109/c"},"text":"Pub. L. 109–59, § 7109(c)","children":[],"tail":", amended heading and text of subsec. (c) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) Each person required to file a registration statement under subsection (a) of this section must file the first statement not later than ","children":[{"tag":"date","attrib":{"date":"1992-03-31"},"text":"March 31, 1992","children":[],"tail":". The Secretary of Transportation may extend that date to "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":", for activities referred to in subsection (a)(1) of this section. A person shall renew the statement periodically consistent with regulations the Secretary prescribes, but not more than once each year and not less than once every 5 years."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) The Secretary of Transportation shall decide by regulation when and under what circumstances a registration statement must be amended and the procedures to follow in amending the statement.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary” for “Secretary of Transportation” in subsec. (d), “Secretary in carrying” for “Secretary of Transportation in carrying” in subsec. (e), and “Secretary shall” for “Secretary of Transportation shall” in subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary shall” for “Secretary of Transportation shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7109/f/1"},"text":"Pub. L. 109–59, § 7109(f)(1)","children":[],"tail":", substituted “shall” for “may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary shall establish” for “Secretary of Transportation shall establish” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7109/f/2"},"text":"Pub. L. 109–59, § 7109(f)(2)","children":[],"tail":", substituted “$3,000” for “$5,000” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary shall” for “Secretary of Transportation shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2)(C). ","children":[{