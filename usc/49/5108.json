{"tag":"section","attrib":{"id":"idca8c4c29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108"},"text":null,"children":[{"tag":"num","attrib":{"value":"5108"},"text":"§ 5108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8c4c2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons Required to File","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8c4c2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person shall file a registration statement with the Secretary under this subsection if the person is transporting or causing to be transported in commerce any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8c4c2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a highway-route-controlled quantity of radioactive material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c4c2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than 25 kilograms of a Division 1.1, 1.2, or 1.3 explosive material in a motor vehicle, rail car, or transport container.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c4c2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more than one liter in each package of a hazardous material the Secretary designates as extremely toxic by inhalation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c4c2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hazardous material in a bulk packaging, container, or tank, as defined by the Secretary, if the bulk packaging, container, or tank has a capacity of at least 3,500 gallons or more than 468 cubic feet.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c4c30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a shipment of at least 5,000 pounds (except in a bulk packaging) of a class of hazardous material for which placarding of a vehicle, rail car, or freight container is required under regulations prescribed under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c4c31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may require any of the following persons to file a registration statement with the Secretary under this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8c4c32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person transporting or causing to be transported hazardous material in commerce and not required to file a registration statement under paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c4c33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person designing, manufacturing, fabricating, inspecting, marking, maintaining, reconditioning, repairing, or testing a package, container, or packaging component that is represented, marked, certified, or sold as qualified for use in transporting hazardous material in commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c4c34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person required to file a registration statement under this subsection may transport or cause to be transported, or design, manufacture, fabricate, inspect, mark, maintain, recondition, repair, or test a package, container packaging component, or container for use in transporting, hazardous material, only if the person has a statement on file as required by this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c4c35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may waive the filing of a registration statement, or the payment of a fee, required under this subsection, or both, for any person not domiciled in the United States who solely offers hazardous materials for transportation to the United States from a place outside the United States if the country of which such person is a domiciliary does not require persons domiciled in the United States who solely offer hazardous materials for transportation to the foreign country from places in the United States to file registration statements, or to pay fees, for making such an offer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c4c36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form, Contents, and Limitation on Filings","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8c4c37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A registration statement under subsection (a) of this section shall be in the form and contain information the Secretary requires by regulation. The Secretary may use existing forms of the Department of Transportation and the Environmental Protection Agency to carry out this subsection. The statement shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8c4c38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and principal place of business of the registrant;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c4c39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of each activity the registrant carries out for which filing a statement under subsection (a) of this section is required; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c4c3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each State in which the person carries out any of the activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c4c3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person carrying out more than one activity, or an activity at more than one location, for which filing is required only has to file one registration statement to comply with subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c4c3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each person required to file a registration statement under subsection (a) shall file the statement in accordance with regulations prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c4c3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Simplifying the Registration Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may take necessary action to simplify the registration process under subsections (a)–(c) of this section and to minimize the number of applications, documents, and other information a person is required to file under this chapter and other laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c4c3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation With Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Environmental Protection Agency shall assist the Secretary in carrying out subsections (a)–(g)(1) and (h) of this section by providing the Secretary with information the Secretary requests to carry out the objectives of subsections (a)–(g)(1) and (h).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c4c3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Statements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make a registration statement filed under subsection (a) of this section available for inspection by any person for a fee the Secretary establishes. However, this subsection does not require the release of information described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":" or otherwise protected by law from disclosure to the public."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c4c40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8c4c41-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall establish, impose, and collect from a person required to file a registration statement under subsection (a) of this section a fee necessary to pay for the costs of the Secretary in processing the statement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c4c42-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8c4c43-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to a fee established under paragraph (1) of this subsection, the Secretary shall establish and impose by regulation and collect an annual fee. Subject to subparagraph (B) of this paragraph, the fee shall be at least $250 but not more than $3,000 from each person required to file a registration statement under this section. The Secretary shall determine the amount of the fee under this paragraph on at least one of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca8c4c44-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gross revenue from transporting hazardous material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8c4c45-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type of hazardous material transported or caused to be transported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8c4c46-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of hazardous material transported or caused to be transported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8c4c47-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of shipments of hazardous material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8c4c48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of activities that the person carries out for which filing a registration statement is required under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8c4c49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the threat to property, individuals, and the environment from an accident or incident involving the hazardous material transported or caused to be transported.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8c4c4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of gross revenue derived from transporting hazardous material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8c4c4b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount to be made available to carry out sections 5108(g)(2), 5115, and 5116 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8c4c4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c4c4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall adjust the amount being collected under this paragraph to reflect any unexpended balance in the account established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5116/h"},"text":"section 5116(h) of this title","children":[],"tail":". However, the Secretary is not required to refund any fee collected under this paragraph."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c4c4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall transfer to the Secretary of the Treasury amounts the Secretary of Transportation collects under this paragraph for deposit in the Hazardous Materials Emergency Preparedness Fund established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5116/h"},"text":"section 5116(h) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c4c4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees on exempt persons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a)(4), the Secretary shall impose and collect a fee of $25 from a person who is required to register under this section but who is otherwise exempted by the Secretary from paying any fee under this section. The fee shall be used to pay the costs incurred by the Secretary in processing registration statements filed by such persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c4c50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintaining Proof of Filing and Payment of Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may prescribe regulations requiring a person required to file a registration statement under subsection (a) of this section to maintain proof of the filing and payment of fees imposed under subsection (g) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8c4c51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8c4c52-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Chapter 35 of title 44 does not apply to an activity of the Secretary under subsections (a)–(g)(1) and (h) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c4c53-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8c4c54-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section does not apply to an employee of a hazmat employer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8c4c55-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5108/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subsections (a)–(h) of this section do not apply to a department, agency, or instrumentality of the United States Government, an authority of a State or political subdivision of a State, an Indian tribe, or an employee of a department, agency, instrumentality, or authority carrying out official duties.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8c4c56-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/765"},"text":"108 Stat. 765","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/311/tI"},"text":"Pub. L. 103–311, title I","children":[],"tail":", §§ 104, 117(a)(3), 119(d)(1), "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1673"},"text":"108 Stat. 1673","children":[],"tail":", 1678, 1680; "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/3"},"text":"Pub. L. 105–102, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2204"},"text":"111 Stat. 2204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/225/s7/b/1"},"text":"Pub. L. 105–225, § 7(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1511"},"text":"112 Stat. 1511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII"},"text":"Pub. L. 109–59, title VII","children":[],"tail":", §§ 7109(a)–(c), (e), (f), 7114(d)(3), 7126, "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1897"},"text":"119 Stat. 1897","children":[],"tail":", 1898, 1900, 1909; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVII/s7203/b/1"},"text":"Pub. L. 114–94, div. A, title VII, § 7203(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"da