{"tag":"section","attrib":{"id":"idcc648e48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175"},"text":null,"children":[{"tag":"num","attrib":{"value":"47175"},"text":"§ 47175.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc648e49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Airport capacity enhancement project","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “airport capacity enhancement project” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc648e4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project for construction or extension of a runway, including any land acquisition, taxiway, or safety area associated with the runway or runway extension; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc648e4b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other airport development projects as the Secretary may designate as facilitating a reduction in air traffic congestion and delays.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Airport sponsor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “airport sponsor” has the meaning given the term “sponsor” under section 47102.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation safety project","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “aviation safety project” means an aviation project that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc648e4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has as its primary purpose reducing the risk of injury to persons or damage to aircraft and property, as determined by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc648e4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is needed to respond to a recommendation from the National Transportation Safety Board, as determined by the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc648e50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary for an airport to comply with part 139 of title 14, Code of Federal Regulations (relating to airport certification).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congested airport","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “congested airport” means an airport that accounted for at least 1 percent of all delayed aircraft operations in the United States in the most recent year for which such data is available and an airport listed in table 1 of the Federal Aviation Administration’s Airport Capacity Benchmark Report 2004 or any successor report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e52-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Federal agency” means a department or agency of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e53-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General aviation airport construction or improvement project","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “general aviation airport construction or improvement project” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc648e54-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project for the construction or extension of a runway, including any land acquisition, helipad, taxiway, safety area, apron, or navigational aids associated with the runway or runway extension, at a general aviation airport, a reliever airport, or a commercial service airport that is not a primary airport (as such terms are defined in section 47102); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc648e55-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other airport development project that the Secretary designates as facilitating aviation capacity building projects at a general aviation airport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e56-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint use airport","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “joint use airport” means an airport owned by the Department of Defense, at which both military and civilian aircraft make shared use of the airfield.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e57-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47175/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terminal development","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “terminal development” has the meaning given such term in section 47102.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc648e58-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/tIII/s304/a"},"text":"Pub. L. 108–176, title III, § 304(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2538"},"text":"117 Stat. 2538","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tI/s152/g"},"text":"Pub. L. 112–95, title I, § 152(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/34"},"text":"126 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tI/s191/b"},"text":"Pub. L. 115–254, div. B, title I, § 191(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3239"},"text":"132 Stat. 3239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s784"},"text":"Pub. L. 118–63, title VII, § 784","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1313"},"text":"138 Stat. 1313","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc648e59-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc648e5a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc648e5b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s784/4"},"text":"Pub. L. 118–63, § 784(4)","children":[],"tail":", redesignated par. (3) as (1). Former par. (1) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s784/4"},"text":"Pub. L. 118–63, § 784(4)","children":[],"tail":", redesignated par. (1) as (2). Former par. (2) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s784/4"},"text":"Pub. L. 118–63, § 784(4)","children":[],"tail":", redesignated par. (4) as (3). Former par. (3) redesignated (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s784/1"},"text":"Pub. L. 118–63, § 784(1)","children":[],"tail":", substituted “or” for “and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s784/4"},"text":"Pub. L. 118–63, § 784(4)","children":[],"tail":", redesignated par. (2) as (4). Former par. (4) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s784/2/A"},"text":"Pub. L. 118–63, § 784(2)(A)","children":[],"tail":", struck out “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s784/2/B"},"text":"Pub. L. 118–63, § 784(2)(B)","children":[],"tail":", struck out subpar. (B) designation and redesignated cls. (i) and (ii) of former subpar. (B) as subpars. (B) and (C), respectively, of par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s784/4"},"text":"Pub. L. 118–63, § 784(4)","children":[],"tail":", redesignated par. (6) as (5). Former par. (5) struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s784/3"},"text":"Pub. L. 118–63, § 784(3)","children":[],"tail":", struck out par. (5). Text read as follows: “The term ‘aviation security project’ means a security project at an airport required by the Department of Homeland Security.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6), (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s784/4"},"text":"Pub. L. 118–63, § 784(4)","children":[],"tail":", (5), added par. (8) and redesignated former par. (8) as (6). Former par. (6) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Par. (8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s152/g/1"},"text":"Pub. L. 112–95, § 152(g)(1)","children":[],"tail":", substituted “2004 or any successor report” for “2001”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s152/g/2"},"text":"Pub. L. 112–95, § 152(g)(2)","children":[],"tail":", added par. (7)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc648e5c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc648e5d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
