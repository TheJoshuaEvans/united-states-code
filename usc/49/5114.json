{"tag":"section","attrib":{"id":"idca8ebce0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5114"},"text":null,"children":[{"tag":"num","attrib":{"value":"5114"},"text":"§ 5114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air transportation of ionizing radiation material","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8ebce1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transporting in Air Commerce","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Material that emits ionizing radiation spontaneously may be transported on a passenger-carrying aircraft in air commerce (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a"},"text":"section 40102(a) of this title","children":[],"tail":") only if the material is intended for a use in, or incident to, research or medical diagnosis or treatment and does not present an unreasonable hazard to health and safety when being prepared for, and during, transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8ebce2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe procedures for monitoring and enforcing regulations prescribed under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8ebce3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children"