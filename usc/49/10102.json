{"tag":"section","attrib":{"id":"idcadb084c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102"},"text":null,"children":[{"tag":"num","attrib":{"value":"10102"},"text":"§ 10102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb084d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Board” means the Surface Transportation Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb084e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “car service” includes (A) the use, control, supply, movement, distribution, exchange, interchange, and return of locomotives, cars, other vehicles, and special types of equipment used in the transportation of property by a rail carrier, and (B) the supply of trains by a rail carrier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb084f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “control”, when referring to a relationship between persons, includes actual control, legal control, and the power to exercise control, through or by (A) common directors, officers, stockholders, a voting trust, or a holding or investment company, or (B) any other means;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0850-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “person”, in addition to its meaning under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":", includes a trustee, receiver, assignee, or personal representative of a person;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0851-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “rail carrier” means a person providing common carrier railroad transportation for compensation, but does not include street, suburban, or interurban electric railways not operated as part of the general system of rail transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0852-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “railroad” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb0853-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bridge, car float, lighter, ferry, and intermodal equipment used by or in connection with a railroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb0854-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the road used by a rail carrier and owned by it or operated under an agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb0855-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a switch, spur, track, terminal, terminal facility, and a freight depot, yard, and ground, used or necessary for transportation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0856-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “rate” means a rate or charge for transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0857-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State of the United States and the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0858-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “transportation” includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb0859-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a locomotive, car, vehicle, vessel, warehouse, wharf, pier, dock, yard, property, facility, instrumentality, or equipment of any kind related to the movement of passengers or property, or both, by rail, regardless of ownership or an agreement concerning use; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb085a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" services related to that movement, including receipt, delivery, elevation, transfer in transit, refrigeration, icing, ventilation, storage, handling, and interchange of passengers and property; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb085b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10102/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States” means the States of the United States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcadb085c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/806"},"text":"109 Stat. 806","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcadb085d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcadb085e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcadb085f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 10102 and 1010