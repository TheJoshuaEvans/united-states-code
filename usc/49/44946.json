{"tag":"section","attrib":{"id":"idcc34cbc7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946"},"text":null,"children":[{"tag":"num","attrib":{"value":"44946"},"text":"§ 44946.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aviation Security Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc34cbc8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall establish within the Transportation Security Administration an aviation security advisory committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc34cbc9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc34cbca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall consult the Advisory Committee, as appropriate, on aviation security matters, including on the development, refinement, and implementation of policies, programs, rulemaking, and security directives pertaining to aviation security, while adhering to sensitive security guidelines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbcb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc34cbcc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Committee shall develop, at the request of the Administrator, recommendations for improvements to aviation security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cbcd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations of subcommittees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Recommendations agreed upon by the subcommittees established under this section shall be approved by the Advisory Committee before transmission to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Periodic reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee shall periodically submit to the Administrator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc34cbcf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports on matters identified by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cbd0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports on other matters identified by a majority of the members of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbd1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Committee shall submit to the Administrator an annual report providing information on the activities, findings, and recommendations of the Advisory Committee, including its subcommittees, for the preceding year. Not later than 6 months after the date that the Administrator receives the annual report, the Administrator shall publish a public version describing the Advisory Committee’s activities and such related matters as would be informative to the public consistent with the policy of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbd2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Feedback","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after receiving recommendations transmitted by the Advisory Committee under paragraph (2) or (4), the Administrator shall respond in writing to the Advisory Committee with feedback on each of the recommendations, an action plan to implement any of the recommendations with which the Administrator concurs, and a justification for why any of the recommendations have been rejected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbd3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after providing written feedback to the Advisory Committee under paragraph (5), the Administrator shall notify the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Homeland Security of the House of Representatives on such feedback, and provide a briefing upon request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbd4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prior to briefing the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Homeland Security of the House of Representatives under paragraph (6), the Administrator shall submit to such committees a report containing information relating to the recommendations transmitted by the Advisory Committee in accordance with paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc34cbd5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc34cbd6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc34cbd7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall appoint the members of the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cbd8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The membership of the Advisory Committee shall consist of individuals representing not more than 34 member organizations. Each organization shall be represented by 1 individual (or the individual’s designee).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cbd9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The membership of the Advisory Committee shall include representatives of air carriers, all-cargo air transportation, indirect air carriers, labor organizations representing air carrier employees, labor organizations representing transportation security officers, aircraft manufacturers, airport operators, airport construction and maintenance contractors, labor organizations representing employees of airport construction and maintenance contractors, general aviation, privacy organizations, the travel industry, airport-based businesses (including minority-owned small businesses), businesses that conduct security screening operations at airports, aeronautical repair stations, passenger advocacy groups, the aviation security technology industry (including screening technology and biometrics), victims of terrorist acts against aviation, and law enforcement and security experts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbda-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term of office.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc34cbdb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of each member of the Advisory Committee shall be two years, but a member may continue to serve until a successor is appointed. A member of the Advisory Committee may be reappointed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cbdc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Removal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may review the participation of a member of the Advisory Committee and remove such member for cause at any time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbdd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The members of the Advisory Committee shall not receive pay, allowances, or benefits from the Government by reason of their service on the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbde-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc34cbdf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall require the Advisory Committee to meet at least semiannually and may convene additional meetings as necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cbe0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At least 1 of the meetings described in subparagraph (A) shall be open to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cbe1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attendance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Advisory Committee shall maintain a record of the persons present at each meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbe2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Member access to sensitive security information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date of a member’s appointment, the Administrator shall determine if there is cause for the member to be restricted from possessing sensitive security information. Without such cause, and upon the member voluntarily signing a non-disclosure agreement, the member may be granted access to sensitive security information that is relevant to the member’s advisory duties. The member shall protect the sensitive security information in accordance with part 1520 of title 49, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbe3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A stakeholder representative on the Advisory Committee who is elected by the appointed membership of the Advisory Committee shall chair the Advisory Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc34cbe4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcommittees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc34cbe5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Advisory Committee chairperson, in coordination with the Administrator, may establish within the Advisory Committee any subcommittee that the Administrator and Advisory Committee determine to be necessary. The Administrator and the Advisory Committee shall create subcommittees to address aviation security issues, including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc34cbe6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air cargo security","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The implementation of the air cargo security programs established by the Transportation Security Administration to screen air cargo on passenger aircraft and all-cargo aircraft in accordance with established cargo screening mandates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cbe7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General aviation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"General aviation facilities, general aviation aircraft, and helicopter operations at general aviation and commercial service airports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cbe8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Perimeter and access control","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Recommendations on airport perimeter security, exit lane security and technology at commercial service airports, and access control issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cbe9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Security technology","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Security technology standards and requirements, including their harmonization internationally, technology to screen passengers, passenger baggage, carry-on baggage, and cargo, and biometric technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Risk-based security","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All subcommittees established by the Advisory Committee chairperson in coordination with the Administrator shall consider risk-based security approaches in the performance of their functions that weigh the optimum balance of costs and benefits in transportation security, including for passenger screening, baggage screening, air cargo security policies, and general aviation security matters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbeb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings and reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each subcommittee shall meet at least quarterly and submit to the Advisory Committee for inclusion in the annual report required under subsection (b)(4) information, including recommendations, regarding issues within the subcommittee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subcommittee chairs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each subcommittee shall be co-chaired by a Government official and an industry official.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc34cbed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subject Matter Experts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each subcommittee under this section shall include subject matter experts with relevant expertise who are appointed by the respective subcommittee chairpersons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc34cbee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability of Chapter ","children":[],"tail":"10"},{"tag":"inline","attrib":{},"text":" of Title ","children":[],"tail":"5.—"}],"tail":null},{"tag":"content","attrib":{},"text":"Chapter 10 of title 5 shall not apply to the Advisory Committee and its subcommittees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc34cbef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc34cbf0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Administrator” means the Administrator of the Transportation Security Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbf1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory committee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Advisory Committee” means the aviation security advisory committee established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbf2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Perimeter security.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc34cbf3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “perimeter security” means procedures or systems to monitor, secure, and prevent unauthorized access to an airport, including its airfield and terminal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cbf4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44946/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “perimeter security” includes the fence area surrounding an airport, access gates, and access controls.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc34cbf5-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/238/s2/a"},"text":"Pub. L. 113–238, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2842"},"text":"128 Stat. 2842","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/190/tIII/s3411"},"text":"Pub. L. 114–190, title III, § 3411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/662"},"text":"130 Stat. 662","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/d/37"},"text":"Pub. L. 115–254, div. K, title I, § 1991(d)(37)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3641"},"text":"132 Stat. 3641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/317"},"text":"Pub. L. 117–286, § 4(a)(317)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4340"},"text":"136 Stat. 4340","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc34cbf6-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc34cbf7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc34cbf8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of Title 5” for “FACA” in heading and “Chapter 10 of title 5” for “The Federal Advisory Committee Act (5 U.S.C. App.)” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/37/B"},"text":"Pub. L. 115–254, § 1991(d)(37)(B)","children":[],"tail":", substituted “Administrator” for “Assistant Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/37/C"},"text":"Pub. L. 115–254, § 1991(d)(37)(C)","children":[],"tail":", substituted “the Administrator receives” for “the Secretary receives” and “the Administrator shall” for “the Secretary shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/37/D"},"text":"Pub. L. 115–254, § 1991(d)(37)(D)","children":[],"tail":", substituted “The” for “Not later than 180 days after the date of enactment of the Aviation Security Stakeholder Participation Act of 2014, the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/37/A"},"text":"Pub. L. 115–254, § 1991(d)(37)(A)","children":[],"tail":", added par. (1), redesignated former par. (1) as (2), and struck out former par. (2) which defined “Assistant Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/s3411/b"},"text":"Pub. L. 114–190, § 3411(b)","children":[],"tail":", substituted “paragraph (2) or (4)” for “paragraph (4)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/s3411/a"},"text":"Pub. L. 114–190, § 3411(a)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, text read as follows: “The term of each member of the Advisory Committee shall be 2 years. A member of the Advisory Committee may be reappointed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
