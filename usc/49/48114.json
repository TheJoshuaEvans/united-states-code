{"tag":"section","attrib":{"id":"idcc6e0428-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114"},"text":null,"children":[{"tag":"num","attrib":{"value":"48114"},"text":"§ 48114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Funding for aviation programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc6e0429-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc6e042a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Airport and airway trust fund guarantee.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc6e042b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The total budget resources made available from the Airport and Airway Trust Fund each fiscal year pursuant to sections 48101, 48102, 48103, and 106(k) shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc6e042c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in fiscal year 2013, be equal to 90 percent of the estimated level of receipts plus interest credited to the Airport and Airway Trust Fund for that fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc6e042d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in fiscal years 2014 through 2018, be equal to the sum of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcc6e042e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/a/1/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent of the estimated level of receipts plus interest credited to the Airport and Airway Trust Fund for that fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc6e042f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/a/1/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the actual level of receipts plus interest credited to the Airport and Airway Trust Fund for the second preceding fiscal year minus the total amount made available for obligation from the Airport and Airway Trust Fund for the second preceding fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Such amounts may be used only for the aviation investment programs listed in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e0430-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guarantee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No funds may be appropriated or limited for aviation investment programs listed in subsection (b)(1) unless the amount described in subparagraph (A) has been provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e0431-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional authorizations of appropriations from the general fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any fiscal year through fiscal year 2018, if the amount described in paragraph (1) is appropriated, there is further authorized to be appropriated from the general fund of the Treasury such sums as may be necessary for the Federal Aviation Administration Operations account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6e0432-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc6e0433-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Total budget resources","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “total budget resources” means the total amount made available from the Airport and Airway Trust Fund for the sum of obligation limitations and budget authority made available for a fiscal year for the following budget accounts that are subject to the obligation limitation on contract authority provided in this title and for which appropriations are provided pursuant to authorizations contained in this title:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc6e0434-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 69–8106–0–7–402 (Grants in Aid for Airports).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e0435-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 69–8107–0–7–402 (Facilities and Equipment).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e0436-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 69–8108–0–7–402 (Research and Development).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e0437-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 69–8104–0–7–402 (Trust Fund Share of Operations).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e0438-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Estimated level of receipts plus interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “estimated level of receipts plus interest” means the level of excise taxes and interest credited to the Airport and Airway Trust Fund under section 9502 of the Internal Revenue Code of 1986 for a fiscal year as set forth in the President’s budget baseline projection as defined in section 257 of the Balanced Budget and Emergency Deficit Control Act of 1985 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/177"},"text":"Public Law 99–177","children":[],"tail":") (Treasury identification code 20–8103–0–7–402) for that fiscal year submitted pursuant to "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of title 31","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6e0439-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement of Guarantees.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc6e043a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Total airport and airway trust fund funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall not be in order in the House of Representatives or the Senate to consider any bill, joint resolution, amendment, motion, or conference report that would cause total budget resources in a fiscal year for aviation investment programs described in subsection (b) to be less than the amount required by subsection (a)(1)(A) for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e043b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48114/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital priority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall not be in order in the House of Representatives or the Senate to consider any bill, joint resolution, amendment, motion, or conference report that provides an appropriation (or any amendment thereto) for any fiscal year through fiscal year 2018 for Research and Development or Operations if the sum of the obligation limitation for Grants-in-Aid for Airports and the appropriation for Facilities and Equipment for such fiscal year is below the sum of the authorized levels for Grants-in-Aid for Airports and for Facilities and Equipment for such fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc6e043c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/tI/s104/a"},"text":"Pub. L. 108–176, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2496"},"text":"117 Stat. 2496","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tI/s104"},"text":"Pub. L. 112–95, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/16"},"text":"126 Stat. 16","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/55/tI/s106/a"},"text":"Pub. L. 114–55, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-09-30"},"text":"Sept. 30, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/524"},"text":"129 Stat. 524","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/190/tI/s1106/a"},"text":"Pub. L. 114–190, title I, § 1106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/618"},"text":"130 Stat. 618","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/63/tI/s107/a"},"text":"Pub. L. 115–63, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-09-29"},"text":"Sept. 29, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1170"},"text":"131 Stat. 1170","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tI/s116"},"text":"Pub. L. 115–254, div. B, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3201"},"text":"132 Stat. 3201","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc6e043d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc6e043e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc6e043f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 9502 of the Internal Revenue Code of 1986, referred to in subsec. (b)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9502"},"text":"section 9502 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 257 of the Balanced Budget and Emergency Deficit Control Act of 1985, referred to in subsec. (b)(2), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s907"},"text":"section 907 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc6e0440-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc6e0441-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" substituted “in fiscal years 2014 through 2018” for “in fiscal year 2014 and each fiscal year thereafter” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/63/s107/a/1"},"text":"Pub. L. 115–63, § 107(a)(1)","children":[],"tail":", substituted “2018” for “2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/63/s107/a/2"},"text":"Pub. L. 115–63, § 107(a)(2)","children":[],"tail":", substituted “2018” for “2017”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/s1106/a/1"},"text":"Pub. L. 114–190, § 1106(a)(1)","children":[],"tail":", substituted “fiscal year 2017,” for “fiscal year 2016,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/s1106/a/2"},"text":"Pub. L. 114–190, § 1106(a)(2)","children":[],"tail":", substituted “fiscal year 2017” for “fiscal year 2016”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/55/s106/a/1"},"text":"Pub. L. 114–55, § 106(a)(1)","children":[],"tail":", substituted “2016’ for “2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/55/s106/a/2"},"text":"Pub. L. 114–55, § 106(a)(2)","children":[],"tail":", substituted “2016” for “2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s104/a"},"text":"Pub. L. 112–95, § 104(a)","children":[],"tail":", amended subpar. (A) generally. Prior to amendment, text read as follows: “The total budget resources made available from the Airport and Airway Trust Fund each fiscal year through fiscal year 2007 pursuant to sections 48101, 48102, 48103, and 106(k) of title 49, United States Code, shall be equal to the level of receipts plus interest credited to the Airport and Airway Trust Fund for that fiscal year. Such amounts may be used only for aviation investment programs listed in subsection (b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s104/b"},"text":"Pub. L. 112–95, § 104(b)","children":[],"tail":", substituted “subsection (b)(1)” for “subsection (b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s104/c"},"text":"Pub. L. 112–95, § 104(c)","children":[],"tail":", substituted “2015” for “2007”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s104/d"},"text":"Pub. L. 112–95, § 104(d)","children":[],"tail":", substituted “Estimated level” for “Level” in heading and “estimated level of receipts plus interest” for “level of receipts plus interest” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s104/e"},"text":"Pub. L. 112–95, § 104(e)","children":[],"tail":", substituted “2015” for “2007”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc6e0442-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc6e0443-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc6e0444-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deemed References to Chapters 509 and 511 of Title 51","children":[],"tail":null},{"tag":"p","attrib":{},"text":"General references to “this title” deemed to refer also to chapters 509 and 511 of Title 51, National and Commercial Space Programs, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/8"},"text":"section 4(d)(8) of Pub. L. 111–314","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
