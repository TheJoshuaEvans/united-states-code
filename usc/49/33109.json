{"tag":"section","attrib":{"id":"idcb8ddd79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109"},"text":null,"children":[{"tag":"num","attrib":{"value":"33109"},"text":"§ 33109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Stolen Passenger Motor Vehicle Information System","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb8ddd7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8ddd7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1993-07-25"},"text":"July 25, 1993","children":[],"tail":", the Attorney General shall establish, and thereafter maintain, a National Stolen Passenger Motor Vehicle Information System containing the vehicle identification numbers of stolen passenger motor vehicles and stolen passenger motor vehicle parts. The System shall be located in the National Crime Information Center and shall include at least the following information on each passenger motor vehicle reported to a law enforcement authority as stolen and not recovered:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8ddd7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vehicle identification number.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8ddd7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the make and model year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8ddd7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the vehicle was reported as stolen.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8ddd7f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of the law enforcement authority that received the report of the theft of the vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8ddd80-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification numbers of the vehicle parts (or derivatives of those numbers), at the time of the theft, if those numbers are different from the vehicle identification number of the vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddd81-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In establishing the System, the Attorney General shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8ddd82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local law enforcement authorities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8ddd83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Crime Information Center Policy Advisory Board to ensure the security of the information in the System and that the System will not compromise the security of stolen passenger motor vehicle and passenger motor vehicle parts information in the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddd84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Attorney General decides that the Center is not able to perform the functions of the System, the Attorney General shall make an agreement for the operation of the System separate from the Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddd85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall prescribe by regulation the effective date of the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8ddd86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requests for Information","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8ddd87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall prescribe by regulation procedures under which an individual or entity intending to transfer a passenger motor vehicle or passenger motor vehicle part may obtain information on whether the vehicle or part is listed in the System as stolen.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddd88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On request of an insurance carrier, a person lawfully selling or distributing passenger motor vehicle parts in interstate commerce, or an individual or enterprise engaged in the business of repairing passenger motor vehicles, the Attorney General (or the entity the Attorney General designates) immediately shall inform the insurance carrier, person, individual, or enterprise whether the System has a record of a vehicle or vehicle part with a particular vehicle identification number (or derivative of that number) being reported as stolen. The Attorney General may require appropriate verification to ensure that the request is legitimate and will not compromise the security of the System.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8ddd89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory Committee","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8ddd8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1992-12-24"},"text":"December 24, 1992","children":[],"tail":", the Attorney General shall establish in the Department of Justice an advisory committee. The Attorney General shall develop the System with the advice and recommendations of the committee."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddd8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8ddd8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The committee is composed of the following 10 members:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb8ddd8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb8ddd8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb8ddd8f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual who is qualified to represent the interests of the law enforcement community at the State level.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb8ddd90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual who is qualified to represent the interests of the law enforcement community at the local level.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb8ddd91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual who is qualified to represent the interests of the automotive recycling industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb8ddd92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/2/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual who is qualified to represent the interests of the automotive repair industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb8ddd93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/2/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual who is qualified to represent the interests of the automotive rebuilders industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb8ddd94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/2/A/viii"},"text":null,"children":[{"tag":"num","attrib":{"value":"viii"},"text":"(viii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual who is qualified to represent the interests of the automotive parts suppliers industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb8ddd95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/2/A/ix"},"text":null,"children":[{"tag":"num","attrib":{"value":"ix"},"text":"(ix)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual who is qualified to represent the interests of the insurance industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb8ddd96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/2/A/x"},"text":null,"children":[{"tag":"num","attrib":{"value":"x"},"text":"(x)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one individual who is qualified to represent the interests of consumers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8ddd97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall appoint the individuals described in subparagraph (A)(iii)–(x) of this paragraph and shall serve as chairman of the committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddd98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The committee shall make recommendations on developing and carrying out—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8ddd99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Stolen Passenger Motor Vehicle Information System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8ddd9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the verification system under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s33110"},"text":"section 33110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddd9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1993-04-25"},"text":"April 25, 1993","children":[],"tail":", the committee shall submit to the Attorney General, the Secretary, and Congress a report including the recommendations of the committee."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8ddd9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Immunity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person performing any activity under this section or section 33110 or 33111 in good faith and with the reasonable belief that such activity was in accordance with such section shall be immune from any civil action respecting such activity which is seeking money damages or equitable relief in any court of the United States or a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb8ddd9d-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1084"},"text":"108 Stat. 1084","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/152/s5"},"text":"Pub. L. 104–152, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-07-02"},"text":"July 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1385"},"text":"110 Stat. 1385","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb8ddd9e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb8ddd9f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb8ddda0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"33109(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2026c(a), (b) (last sentence), (c), (f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 20, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/513"},"text":"Pub. L. 92–513","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/947"},"text":"86 Stat. 947","children":[],"tail":", § 609; added "},{"tag":"html:span","attrib":{},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/519/s306/e"},"text":"Pub. L. 102–519, § 306(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/3398"},"text":"106 Stat. 3398","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"33109(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2026c(b) (1st sentence), (e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"33109(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2026c(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the words “National Stolen Passenger Motor Vehicle Information System” are substituted for “National Stolen Auto Part Information System” for consistency with the terminology used and with the source provisions restated in the revised chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the words “establish, and thereafter maintain” are substituted for “maintain” for clarity. The words “shall be located” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(B), the words “stolen passenger motor vehicle and passenger motor vehicle parts information” are substituted for “stolen vehicle and vehicle parts information” for consistency with the terminology used in the revised chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(4), the text of 15:2026c(f) (1st sentence) is omitted as surplus. The words “the effective date of the System” are substituted for “shall be effective as provided” because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “intending to transfer” are substituted for “seeking to transfer” for clarity. The words “passenger motor vehicle or passenger motor vehicle part” are substituted for “a vehicle or vehicle parts” for consistency with the terminology used in the revised chapter. The words “whether the vehicle or part” are substituted for “whether a part” for consistency with source provisions restated in the revised section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “shall inform the insurance carrier, person, individual, or enterprise whether” are substituted for “provide such insurance carrier or person with a determination as to whether” for clarity and consistency in the revised subsection. The words “may require appropriate verification” are substituted for “may require such verification as the Attorney General deems appropriate” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “and appoint” are omitted as unnecessary because of the restatement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb8ddda1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb8ddda2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/152"},"text":"Pub. L. 104–152","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb8ddda3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb8ddda4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Committees","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory committees established after ","children":[{"tag":"date","attrib":{"date":"1973-01-05"},"text":"Jan. 5, 1973","children":[],"tail":", to terminate not later than the expiration of 2-year period beginning on date of their establishment, unless, in the case of a committee established by the President or an officer of the Federal Government, such committee is renewed by appropriate action prior to expiration of such 2-year period, or in the case of a committee established by Congress, its duration is otherwise provided for by law. See "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
