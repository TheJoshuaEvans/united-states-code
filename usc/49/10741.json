{"tag":"section","attrib":{"id":"idcadfc35c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10741"},"text":null,"children":[{"tag":"num","attrib":{"value":"10741"},"text":"§ 10741.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions against discrimination by rail carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcadfc35d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10741/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadfc35e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10741/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A rail carrier providing transportation or service subject to the jurisdiction of the Board under this part may not subject a person, place, port, or type of traffic to unreasonable discrimination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadfc35f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10741/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, a rail carrier engages in unreasonable discrimination when it charges or receives from a person a different compensation for a service rendered, or to be rendered, in transportation the rail carrier may perform under this part than it charges or receives from another person for performing a like and contemporaneous service in the transportation of a like kind of traffic under substantially similar circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadfc360-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10741/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This section shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadfc361-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10741/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracts described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10709"},"text":"section 10709 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadfc362-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10741/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rail rates applicable to different routes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadfc363-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10741/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discrimination against the traffic of another carrier providing transportation by any mode.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadfc364-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10741/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Differences between rates, classifications, rules, and practices of rail carriers do not constitute a violation of this section if such differences result from different services provided by rail carriers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcadfc365-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/819"},"text":"109 Stat. 819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcadfc366-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcadfc367-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcadfc368-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10741, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1390"},"text":"92 Stat. 1390","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/296/s33/d"},"text":"Pub. L. 96–296, § 33(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-01"},"text":"July 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/825"},"text":"94 Stat. 825","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/tII/s212"},"text":"Pub. L. 96–448, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1912"},"text":"94 Stat. 1912","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/521/s7/h"},"text":"Pub. L. 99–521, § 7(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2995"},"text":"100 Stat. 2995","children":[],"tail":", related to prohibitions against discrimination by common carriers, prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":". See sections 10741 and 15505 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcadfc369-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcadfc36a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
