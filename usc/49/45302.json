{"tag":"section","attrib":{"id":"idcc373c89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45302"},"text":null,"children":[{"tag":"num","attrib":{"value":"45302"},"text":"§ 45302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees involving aircraft not providing air transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc373c8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies only to aircraft not used to provide air transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373c8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority and Maximum Fees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Federal Aviation Administration may impose fees to pay for the costs of issuing airman certificates to pilots and certificates of registration of aircraft and processing forms for major repairs and alterations of fuel tanks and fuel systems of aircraft. The following fees may not be more than the amounts specified:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc373c8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $12 for issuing an airman’s certificate to a pilot.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373c8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $25 for registering an aircraft after the transfer of ownership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373c8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45302/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $15 for renewing an aircraft registration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373c8f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45302/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $7.50 for processing a form for a major repair or alteration of a fuel tank or fuel system of an aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373c90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall adjust the maximum fees established by subsection (b) of this section for changes in the Consumer Price Index of All Urban Consumers published by the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373c91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit to Account and Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Money collected from fees imposed under this section shall be credited to the account in the Treasury from which the Administrator incurs expenses in carrying out chapter 441 and sections 44701–44716 of this title (except sections 44701(c), 44703(g)(2), and 44713(d)(2)). The money is available to the Administrator to pay expenses for which the fees are collected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373c92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc373c93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45302/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fee may not be imposed under this section before the date on which the regulations prescribed under sections 44111(d), 44703(g)(2), and 44713(d)(2) of this title take effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373c94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45302/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of imposition of other fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fee may not be imposed for a service or activity under this section during any period in which a fee for the same service or activity is imposed under section 45305.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc373c95-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1225"},"text":"108 Stat. 1225","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/59"},"text":"Pub. L. 103–429, § 6(59)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4385"},"text":"108 Stat. 4385","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tI/s122/c"},"text":"Pub. L. 112–95, title I, § 122(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/20"},"text":"126 Stat. 20","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tV/s539/j"},"text":"Pub. L. 115–254, div. B, title V, § 539(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3371"},"text":"132 Stat. 3371","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc373c96-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc373c97-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc373c98-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":nu