{"tag":"section","attrib":{"id":"idca7e1acf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118"},"text":null,"children":[{"tag":"num","attrib":{"value":"1118"},"text":"§ 1118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca7e1ad0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7e1ad1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorizations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There is authorized to be appropriated for purposes of this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7e1ad2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $140,000,000 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7e1ad3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $145,000,000 for fiscal year 2025;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7e1ad4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $148,000,000 for fiscal year 2026;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7e1ad5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $151,000,000 for fiscal year 2027; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7e1ad6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $154,000,000 for fiscal year 2028.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1ad7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts authorized under paragraph (1) shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7e1ad8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emergency Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board has an emergency fund of $2,000,000 available for necessary expenses of the Board, not otherwise provided for, for accident investigations. In addition, there are authorized to be appropriated such sums as may be necessary to increase the fund to, and maintain the fund at, a level not to exceed $4,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7e1ad9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees, Refunds, and Reimbursements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7e1ada-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may impose and collect such fees, refunds, and reimbursements as it determines to be appropriate for services provided by or through the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1adb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Receipts credited as offsetting collections","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", any fee, refund, or reimbursement collected under this subsection—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7e1adc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited as offsetting collections to the account that finances the activities and services for which the fee is imposed or with which the refund or reimbursement is associated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7e1add-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be available for expenditure only to pay the costs of activities and services for which the fee is imposed or with which the refund or reimbursement is associated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7e1ade-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1adf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1118/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Refunds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may refund any fee paid by mistake or any amount paid in excess of that required.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca7e1ae0-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/752"},"text":"108 Stat. 752","children":[],"tail":"; "},{"tag":"ref",