attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s4012/a/2/B"},"text":"Pub. L. 108–458, § 4012(a)(2)(B)","children":[],"tail":", added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71"},"text":"Pub. L. 107–71","children":[],"tail":" which directed the addition of subsec. (c) to section 44909, without specifying the Code title to be amended, was executed by making the addition to this section, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" substituted “should” for “shall” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc267424-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcc267425-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Commissioner of U.S. Customs and Border Protection” substituted for “Commissioner of Customs” in subsec. (c)(1) and (2)(F) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/125/s802/d/2"},"text":"section 802(d)(2) of Pub. L. 114–125","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s211"},"text":"section 211 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc267426-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading"