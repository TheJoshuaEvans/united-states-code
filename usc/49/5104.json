{"tag":"section","attrib":{"id":"idca8a01e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5104"},"text":null,"children":[{"tag":"num","attrib":{"value":"5104"},"text":"§ 5104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Representation and tampering","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8a01e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may represent, by marking or otherwise, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8a01e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a package, component of a package, or packaging for transporting hazardous material is safe, certified, or complies with this chapter only if the package, component of a package, or packaging meets the requirements of each applicable regulation prescribed under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a01e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hazardous material is present in a package, container, motor vehicle, rail freight car, aircraft, or vessel only if the material is present.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a01e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tampering","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person may alter, remove, destroy, or otherwise tamper unlawfully with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8a01e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a marking, label, placard, or description on a document required under this chapter or a regulation prescribed under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a01e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a package, component of a package, or packaging, container, motor vehicle, rail freight car, aircraft, or vessel used to transport hazardous material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8a01ea-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/761"},"text":"108 Stat. 761","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/311/tI/s117/b"},"text":"Pub. L. 103–311, title I, § 117(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1678"},"text":"108 Stat. 1678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/4"},"text":"Pub. L. 103–429, § 6(