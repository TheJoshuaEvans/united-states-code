","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-378"},"text":"100 Stat. 3341–378","children":[],"tail":") is omitted as surplus because the complete names of the Administrator of the Federal Aviation Administration and the Secretary of Transportation are used the first time those terms appear in a section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words “an organization within the Federal Aviation Administration” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc6e047f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc6e0480-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1950-09-07/ch905"},"text":"Act of September 7, 1950, ch. 905","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/770"},"text":"64 Stat. 770","children":[],"tail":", referred to in par. (4), was classified to subchapter II (§ 2421 et seq.) of chapter 33 of former Title 49, Transportation, and was omitted from the Code when subtitles II, III, and V to X of Title 49, Transportation, were enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/745"},"text":"108 Stat. 745","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1940-06-29/ch444"},"text":"Act of June 29, 1940, ch. 444","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/54/686"},"text":"54 Stat. 686","children":[],"tail":", referred to in par. (5), was classified to subchapter I (§ 2401 et seq.) of chapter 33 of former Title 49, Transportation, and was omitted from the Code when subtitles II, III, and V to X of Title 49, Transportation, were enacted by "},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/745"},"text":"108 Stat. 745","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcc6e0481-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 49103 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s50103"},"text":"section 50103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc6e0482-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Pars. (3), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/154"},"text":"Pub. L. 105–154","children":[],"tail":" substituted “Ronald Reagan Washington National Airport” for “Washington National Airport”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc6e0483-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcc6e0484-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/154/s1"},"text":"Pub. L. 105–154, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-06"},"text":"Feb. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3"},"text":"112 Stat. 3","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/154/s1"},"text":"“The airport described in the Act entitled ‘An Act to provide for the administration of the Washington National Airport, and for other purposes’, approved ","children":[{"tag":"date","attrib":{"date":"1940-06-29"},"text":"June 29, 1940","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/54/686"},"text":"54 Stat. 686","children":[],"tail":") [section 2401 et seq. of former Title 49, Transportation, see References in Text note above], and known as the Washington National Airport, shall be known and designated as the ‘Ronald Reagan Washington National Airport’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/154/s2/b"},"text":"Pub. L. 105–154, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-06"},"text":"Feb. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/4"},"text":"112 Stat. 4","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/154/s2/b"},"text":"“Any reference in a law, map, regulation, document, paper, or other record of the United States to the Washington National Airport shall be deemed to be a reference to the ‘Ronald Reagan Washington National Airport’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
