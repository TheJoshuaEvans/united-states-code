/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Washington Dulles International Airport” means the airport constructed under the Act of ","children":[{"tag":"date","attrib":{"date":"1950-09-07"},"text":"September 7, 1950","children":[],"tail":" (ch. 905, "},{"tag":"ref","attrib":{"href":"/us/stat/64/770"},"text":"64 Stat. 770","children":[],"tail":"), and includes the Dulles Airport Access Highway and Right-of-way, including the extension between Interstate Routes I–495 and I–66."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e047a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49103/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Ronald Reagan Washington National Airport” means the airport described in the Act of ","children":[{"tag":"date","attrib":{"date":"1940-06-29"},"text":"June 29, 1940","children":[],"tail":" (ch. 444, "},{"tag":"ref","attrib":{"href":"/us/stat/54/686"},"text":"54 Stat. 686","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc6e047b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/26"},"text":"Pub. L. 105–102, § 2(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2207"},"text":"111 Stat. 2207","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/154/s2/a/1/D"},"text":"Pub. L. 105–154, § 2(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-06"},"text":"Feb. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3"},"text":"112 Stat. 3","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc6e