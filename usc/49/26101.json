{"tag":"section","attrib":{"id":"idcb3f2156-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101"},"text":null,"children":[{"tag":"num","attrib":{"value":"26101"},"text":"§ 26101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-speed rail corridor planning","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb3f2157-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corridor Planning Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3f2158-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may provide under this section financial assistance to a public agency or group of public agencies for corridor planning for up to 50 percent of the publicly financed costs associated with eligible activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f2159-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No less than 20 percent of the publicly financed costs associated with eligible activities shall come from State and local sources, which State and local sources may not include funds from any Federal program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3f215a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Activities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3f215b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A corridor planning activity is eligible for financial assistance under subsection (a) if the Secretary determines that it is necessary to establish appropriate engineering, operational, financial, environmental, or socioeconomic projections for the establishment of high-speed rail service in the corridor and that it leads toward development of a prudent financial and institutional plan for implementation of specific high-speed rail improvements, or if it is an activity described in subparagraph (M). Eligible corridor planning activities include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb3f215c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" environmental assessments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3f215d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" feasibility studies emphasizing commercial technology improvements or applications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3f215e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic analyses, including ridership, revenue, and operating expense forecasting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3f215f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the impact on rail employment of developing high-speed rail corridors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3f2160-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing community economic impacts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3f2161-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordination with State and metropolitan area transportation planning and corridor planning with other States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3f2162-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operational planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3f2163-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" route selection analyses and purchase of rights-of-way for proposed high-speed rail service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3f2164-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preliminary engineering and design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3f2165-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of specific improvements to a corridor, including electrification, line straightening and other right-of-way improvements, bridge rehabilitation and replacement, use of advanced locomotives and rolling stock, ticketing, coordination with other modes of transportation, parking and other means of passenger access, track, signal, station, and other capital work, and use of intermodal terminals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3f2166-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation of financing plans and prospectuses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3f2167-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creation of public/private partnerships; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3f2168-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/1/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the acquisition of locomotives, rolling stock, track, and signal equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f2169-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No financial assistance shall be provided under this section for corridor planning with respect to the main line of the Northeast Corridor, between Washington, District of Columbia, and Boston, Massachusetts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3f216a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria for Determining Financial Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Selection by the Secretary of recipients of financial assistance under this section shall be based on such criteria as the Secretary considers appropriate, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3f216b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the relationship of the corridor to the Secretary’s national high-speed ground transportation policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f216c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the proposed planning focuses on systems which will achieve sustained speeds of 125 mph or greater;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f216d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the integration of the corridor into metropolitan area and statewide transportation planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f216e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential interconnection of the corridor with other parts of the Nation’s transportation system, including the interconnection with other countries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f216f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated effect of the corridor on the congestion of other modes of transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f2170-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the work to be funded will aid the efforts of State and local governments to comply with the Clean Air Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"42 U.S.C. 7401","children":[],"tail":" et seq.);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f2171-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the past and proposed financial commitments and other support of State and local governments and the private sector to the proposed high-speed rail program, including the acquisition of rolling stock;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f2172-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated level of ridership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f2173-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated capital cost of corridor improvements, including the cost of closing, improving, or separating highway-rail grade crossings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f2174-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rail transportation employment impacts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f2175-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" community economic impacts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f2176-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the projected revenues of the proposed high-speed rail service, along with any financial commitments of State or local governments and the private sector, are expected to cover capital costs and operating and maintenance expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f2177-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether a specific route has been selected, specific improvements identified, and capacity studies completed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f2178-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26101/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the corridor has been designated as a high-speed rail corridor by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb3f2179-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/440/tI/s103/a/2"},"text":"Pub. L. 103–440, title I, § 103(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4616"},"text":"108 Stat. 4616","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIX/s9001/a/1"},"text":"Pub. L. 109–59, title IX, § 9001(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1918"},"text":"119 Stat. 1918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tV/s501/a"},"text":"Pub. L. 110–432, div. B, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4959"},"text":"122 Stat. 4959","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb3f217a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb3f217b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb3f217c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Clean Air Act, referred to in subsec. (c)(6), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1955-07-14/ch360"},"text":"act July 14, 1955, ch. 360","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/322"},"text":"69 Stat. 322","children":[],"tail":", which is classified generally to chapter 85 (§ 7401 et seq.) of Title 42, The Public Health and Welfare. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s7401"},"text":"section 7401 of Title 42","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb3f217d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 26101 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s28101"},"text":"section 28101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb3f217e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s501/a/1"},"text":"Pub. L. 110–432, § 501(a)(1)","children":[],"tail":", substituted “High-speed rail corridor planning” for “Corridor development” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s501/a/2"},"text":"Pub. L. 110–432, § 501(a)(2)","children":[],"tail":", substituted “Corridor Planning” for “Corridor Development” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a)(1), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s501/a/3"},"text":"Pub. L. 110–432, § 501(a)(3)","children":[],"tail":", substituted “corridor planning” for “corridor development” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s501/a/4"},"text":"Pub. L. 110–432, § 501(a)(4)","children":[],"tail":", substituted “planning” for “development”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s9001/a/1/A"},"text":"Pub. L. 109–59, § 9001(a)(1)(A)","children":[],"tail":", substituted “development” for “planning” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s9001/a/1/B"},"text":"Pub. L. 109–59, § 9001(a)(1)(B)","children":[],"tail":", substituted “Development” for “Planning” in subsec. heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s9001/a/1/C"},"text":"Pub. L. 109–59, § 9001(a)(1)(C)","children":[],"tail":", substituted “corridor development” for “corridor planning”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s9001/a/1/D/i"},"text":"Pub. L. 109–59, § 9001(a)(1)(D)(i)","children":[],"tail":", inserted “, or if it is an activity described in subparagraph (M)” after “high-speed rail improvements” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s9001/a/1/C"},"text":"Pub. L. 109–59, § 9001(a)(1)(C)","children":[],"tail":", substituted “corridor development” for “corridor planning” in two places in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s9001/a/1/C"},"text":"Pub. L. 109–59, § 9001(a)(1)(C)","children":[],"tail":", substituted “corridor development” for “corridor planning”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(M). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s9001/a/1/D/ii"},"text":"Pub. L. 109–59, § 9001(a)(1)(D)(ii)","children":[],"tail":"–(iv), added subpar. (M)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s9001/a/1/C"},"text":"Pub. L. 109–59, § 9001(a)(1)(C)","children":[],"tail":", substituted “corridor development” for “corridor planning”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s9001/a/1/E"},"text":"Pub. L. 109–59, § 9001(a)(1)(E)","children":[],"tail":", substituted “development” for “planning”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb3f217f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb3f2180-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Findings; Purpose","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/440/tI/s102"},"text":"Pub. L. 103–440, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4615"},"text":"108 Stat. 4615","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/440/tI/s102"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-speed rail offers safe and efficient transportation in certain densely traveled corridors linking major metropolitan areas in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high-speed rail may have environmental advantages over certain other forms of intercity transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amtrak’s Metroliner service between Washington, District of Columbia, and New York, New York, the United States premier high-speed rail service, has shown that Americans will use high-speed rail when that transportation option is available;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new high-speed rail service should not receive Federal subsidies for operating and maintenance expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State and local governments should take the prime responsibility for the development and implementation of high-speed rail service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the private sector should participate in funding the development of high-speed rail systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in some intercity corridors, Federal planning assistance may be required to supplement the funding commitments of State and local governments and the private sector to ensure the adequate planning, including reasonable estimates of the costs and benefits, of high-speed rail systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvement of existing technologies can facilitate the development of high-speed rail systems in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"“(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal assistance is required for the improvement, adaptation, and integration of proven technologies for commercial application in high-speed rail service in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of this title [see Short Title of 1994 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20101"},"text":"section 20101 of this title","children":[],"tail":"] is to encourage farsighted State, local, and private efforts in the analysis and planning for high-speed rail systems in appropriate intercity corridors.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
