{"tag":"section","attrib":{"id":"idcb4fe9f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142"},"text":null,"children":[{"tag":"num","attrib":{"value":"30142"},"text":"§ 30142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importing motor vehicles for personal use","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb4fe9f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30112/a"},"text":"Section 30112(a) of this title","children":[],"tail":" does not apply to an imported motor vehicle if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4fe9f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vehicle is imported for personal use, and not for resale, by an individual (except an individual described in sections 30143 and 30144 of this title);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fe9f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vehicle is imported after ","children":[{"tag":"date","attrib":{"date":"1990-01-31"},"text":"January 31, 1990","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fe9f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual takes the actions required under subsection (b) of this section to receive an exemption.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fe9f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemptions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4fe9f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To receive an exemption under subsection (a) of this section, an individual must—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb4fe9f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide the Secretary of the Treasury (acting for the Secretary of Transportation) with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb4fe9fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appropriate bond in an amount determined under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30141/d"},"text":"section 30141(d) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb4fe9fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a copy of an agreement with an importer registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30141/c"},"text":"section 30141(c) of this title","children":[],"tail":" for bringing the motor vehicle into compliance with applicable motor vehicle safety standards prescribed under this chapter; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb4fe9fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a certification that the vehicle meets the requirement of section 30141(a)(1)(A) or (B) of this title; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4fe9fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" comply with appropriate terms the Secretary of Transportation imposes to ensure that the vehicle—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb4fe9fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be brought into compliance with those standards within a reasonable time (specified by the Secretary of Transportation) after the vehicle is imported; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb4fe9ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be exported (at no cost to the United States Government) by the Secretary of the Treasury or abandoned to the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea00-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30142/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For good cause shown, the Secretary of Transportation may allow an individual additional time, but not more than 30 days after the day on which the motor vehicle is offered for import, to comply with paragraph (1)(A)(ii) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb4fea01-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/962"},"text":"108 Stat. 962","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb4fea02-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb4fea03-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb4fea04-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30142(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(f)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563"},"text":"Pub. L. 89–563","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/718"},"text":"80 Stat. 718","children":[],"tail":", § 108(f); added "},{"tag":"html:span","attrib":{},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/562/s2/b"},"text":"Pub. L. 100–562, § 2(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2822"},"text":"102 Stat. 2822","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30142(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(f)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “after ","children":[{"tag":"date","attrib":{"date":"1990-01-31"},"text":"January 31, 1990","children":[],"tail":"” are substituted for “after the effective date of the regulations initially issued to implement the amendments made to this section by the Imported Vehicle Safety Compliance Act of 1988” for clarity. See 49 C.F.R. part 591."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “the individual takes the actions required under subsection (b) of this section” are substituted for “if that individual takes the actions required by paragraph (2)” for clarity and because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the word “compliance” is substituted for “conformity” for consistency in this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(B), before subclause (i), the word “conditions” is omitted as being included in “terms”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
