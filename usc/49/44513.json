{"tag":"section","attrib":{"id":"idcbe87fd3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513"},"text":null,"children":[{"tag":"num","attrib":{"value":"44513"},"text":"§ 44513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Regional centers of air transportation excellence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbe87fd4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Federal Aviation Administration may make grants to institutions of higher education to establish and operate regional centers of air transportation excellence. The locations shall be distributed in a geographically fair way.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe87fd5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbe87fd6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The responsibilities of each center established under this section shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbe87fd7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conducting research on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbe87fd8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" airspace and airport planning and design;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbe87fd9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" airport capacity enhancement techniques;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbe87fda-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human performance in the air transportation environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbe87fdb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aviation safety and security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbe87fdc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/b/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the supply of trained air transportation personnel, including pilots and mechanics; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbe87fdd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/b/1/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other aviation issues related to developing and maintaining a safe and efficient air transportation system; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe87fde-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interpreting, publishing, and disseminating the results of the research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe87fdf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In conducting research described in paragraph (1)(A) of this subsection, each center may make contracts with nonprofit research organizations and other appropriate persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe87fe0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An institution of higher education interested in receiving a grant under this section may submit an application to the Administrator. The application must be in the form and contain the information that the Administrator requires by regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe87fe1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall select recipients of grants under this section on the basis of the following criteria:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbe87fe2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the needs of the State in which the applicant is located are representative of the needs of the region for improved air transportation services and facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe87fe3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demonstrated research and extension resources available to the applicant to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe87fe4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the applicant to provide leadership in making national and regional contributions to the solution of both long-range and immediate air transportation problems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe87fe5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the applicant has an established air transportation program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe87fe6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the demonstrated ability of the applicant to disseminate results of air transportation research and educational programs through a statewide or regionwide continuing education program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe87fe7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the projects the applicant proposes to carry out under the grant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe87fe8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expenditure Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant may be made under this section in a fiscal year only if the recipient makes an agreement with the Administrator that the Administrator requires to ensure that the recipient will maintain its total expenditures from all other sources for establishing and operating the center and related research activities at a level at least equal to the average level of those expenditures in the 2 fiscal years of the recipient occurring immediately before ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe87fe9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Government’s Share of Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States Government’s share of establishing and operating a center and all related research activities that grant recipients carry out shall not exceed 50 percent of the costs, except that the Administrator may increase such share to a maximum of 75 percent of the costs for a fiscal year if the Administrator determines that a center would be unable to carry out the authorized activities described in this section without additional funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe87fea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocating Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall allocate amounts made available to carry out this section in a geographically fair way.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe87feb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall transmit annually to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate at the time of the President’s budget request a report that lists—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbe87fec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research projects that have been initiated by each center in the preceding year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe87fed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of funding for each research project and the funding source;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe87fee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the institutions participating in each research project and their shares of the overall funding for each research project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe87fef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44513/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of cost-sharing for each research project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbe87ff0-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1182"},"text":"108 Stat. 1182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIX/s907"},"text":"Pub. L. 112–95, title IX, § 907","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/140"},"text":"126 Stat. 140","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbe87ff1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbe87ff2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbe87ff3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44513","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1353(i).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 312(i); added "},{"tag":"html:span","attrib":{},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/508/s9209/a"},"text":"Pub. L. 101–508, § 9209(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/1388-376"},"text":"104 Stat. 1388–376","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “institutions of higher education” and “institution of higher education” are substituted for “colleges or universities” and “college or university” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “one or more” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbe87ff4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbe87ff5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s907/a"},"text":"Pub. L. 112–95, § 907(a)","children":[],"tail":", amended subsec. (f) generally. Prior to amendment, text read as follows: “The United States Government’s share of a grant under this section is 50 percent of the costs of establishing and operating the center and related research activities that the grant recipient carries out.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s907/b"},"text":"Pub. L. 112–95, § 907(b)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbe87ff6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbe87ff7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"FAA Center of Excellence for Automated Systems and Human Factors in Aircraft","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dV/tI/s127"},"text":"Pub. L. 116–260, div. V, title I, § 127","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2348"},"text":"134 Stat. 2348","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/260/dV/tI/s127"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall develop or expand a Center of Excellence focused on automated systems and human factors in transport category aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center of Excellence shall, as appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate collaboration among academia, the FAA, and the aircraft and airline industries, including aircraft, engine, and equipment manufacturers, air carriers, and representatives of the pilot community;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish goals for research in areas of study relevant to advancing technology, improving engineering practices, and facilitating better understanding of human factors concepts in the context of the growing development and reliance on automated or complex systems in commercial aircraft, including continuing education and training;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine issues related to human system integration and flight crew and aircraft interfaces, including tools and methods to support the integration of human factors considerations into the aircraft design and certification process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review safety reports to identify potential human factors issues for research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Avoiding Duplication of Work","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing or expanding the Center of Excellence, the Administrator shall ensure the work of the Center of Excellence does not duplicate or overlap with the work of any other established center of excellence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Member Prioritization.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator, when developing or expanding the Center of Excellence, shall prioritize the inclusion of subject-matter experts whose professional experience enables them to be objective and impartial in their contributions to the greatest extent possible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall require that the membership of the Center of Excellence reflect a balanced viewpoint across broad disciplines in the aviation industry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any member of the Center of Excellence who is a Boeing Company or FAA employee who participated in the certification of the Maneuvering Characteristics Augmentation System for the 737 MAX-8 airplane must disclose such involvement to the FAA prior to performing any work on behalf of the FAA.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transparency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing or expanding the Center of Excellence, the Administrator shall develop procedures to facilitate transparency and appropriate maintenance of records to the maximum extent practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall preclude coordination and collaboration between the Center of Excellence developed or expanded under this section and any other established center of excellence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Administrator $2,000,000 for each of fiscal years 2021 through 2023, out of funds made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s48102/a"},"text":"section 48102(a) of title 49","children":[],"tail":", United States Code, to carry out this section. Amounts appropriated under the preceding sentence for any fiscal year shall remain available until expended.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of terms used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dV/s127"},"text":"section 127 of div. V of Pub. L. 116–260","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dV/s137"},"text":"section 137 of div. V of Pub. L. 116–260","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40101"},"text":"section 40101 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbe87ff8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Center of Excellence for Aviation Human Resource Research","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIX/s908"},"text":"Pub. L. 112–95, title IX, § 908","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/140"},"text":"126 Stat. 140","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/95/tIX/s908"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using amounts made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s48102/a"},"text":"section 48102(a) of title 49","children":[],"tail":", United States Code, the Administrator [of the Federal Aviation Administration] may establish a center of excellence to conduct research on—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" human performance in the air transportation environment, including among air transportation personnel such as air traffic controllers, pilots, and technicians; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other aviation human resource issue pertinent to developing and maintaining a safe and efficient air transportation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities conducted under this section may include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research, development, and evaluation of training programs for air traffic controllers, aviation safety inspectors, airway transportation safety specialists, and engineers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research and development of best practices for recruitment of individuals into the aviation field for mission critical positions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research, in consultation with other relevant Federal agencies, to develop a baseline of general aviation employment statistics and an analysis of future needs in the aviation field.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research and the development of a comprehensive assessment of the airframe and power plant technician certification process and its effect on employment trends.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluation of aviation maintenance technician school environments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Research and an assessment of the ability to develop training programs to allow for the transition of recently unemployed and highly skilled mechanics into the aviation field.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
