{"tag":"section","attrib":{"id":"idcc15d13d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805"},"text":null,"children":[{"tag":"num","attrib":{"value":"44805"},"text":"§ 44805.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small unmanned aircraft safety standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc15d13e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"FAA Process for Acceptance and Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Federal Aviation Administration shall establish a process for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc15d13f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accepting risk-based consensus safety standards related to the design, production, and modification of small unmanned aircraft systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d140-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizing the operation of a small unmanned aircraft system make and model designed, produced, or modified in accordance with the consensus safety standards accepted under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d141-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorizing a manufacturer to self-certify a small unmanned aircraft system make or model that complies with consensus safety standards accepted under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d142-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certifying a manufacturer of small unmanned aircraft systems, or an employee of such manufacturer, that has demonstrated compliance with the consensus safety standards accepted under paragraph (1) and met any other qualifying criteria, as determined by the Administrator, to alternatively satisfy the requirements of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d143-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before accepting consensus safety standards under subsection (a), the Administrator of the Federal Aviation Administration shall consider the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc15d144-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Technologies or standards related to geographic limitations, altitude limitations, and sense and avoid capabilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d145-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Using performance-based requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d146-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assessing varying levels of risk posed by different small unmanned aircraft systems and their operation and tailoring performance-based requirements to appropriately mitigate risk.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d147-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Predetermined action to maintain safety in the event that a communications link between a small unmanned aircraft and its operator is lost or compromised.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d148-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Detectability and identifiability to pilots, the Federal Aviation Administration, and air traffic controllers, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d149-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Means to prevent tampering with or modification of any system, limitation, or other safety mechanism or standard under this section or any other provision of law, including a means to identify any tampering or modification that has been made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d14a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consensus identification standards under section 2202 of the FAA Extension, Safety, and Security Act of 2016 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190"},"text":"Public Law 114–190","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/130/615"},"text":"130 Stat. 615","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d14b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent not considered previously by the consensus body that crafted consensus safety standards, cost-benefit and risk analyses of consensus safety standards that may be accepted pursuant to subsection (a) for newly designed small unmanned aircraft systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d14c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Applicability of consensus safety standards to small unmanned aircraft systems that are not manufactured commercially.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d14d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any technology or standard related to small unmanned aircraft systems that promotes aviation safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d14e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any category of unmanned aircraft systems that should be exempt from the consensus safety standards based on risk factors.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d14f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability of Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The process for authorizing the operation of small unmanned aircraft systems under subsection (a) may allow for operation of any applicable small unmanned aircraft systems within the national airspace system without requiring—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc15d150-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" airworthiness certification requirements under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44704"},"text":"section 44704 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d151-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" type certification under part 21 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d152-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may suspend or revoke the authorizations in subsection (a) if the Administrator determines that the manufacturer or the small unmanned aircraft system is no longer in compliance with the standards accepted by the Administrator under subsection (a)(1) or with the manufacturer’s statement of compliance under subsection (f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d153-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With regard to an authorization under the processes in subsection (a), the Administrator may require a manufacturer of small unmanned aircraft systems to provide the Federal Aviation Administration with the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc15d154-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aircraft system’s operating instructions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d155-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The aircraft system’s recommended maintenance and inspection procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d156-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The manufacturer’s statement of compliance described in subsection (f).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d157-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon request, a sample aircraft to be inspected by the Federal Aviation Administration to ensure compliance with the consensus safety standards accepted by the Administrator under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d158-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Manufacturer’s Statement of Compliance for Small UAS","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A manufacturer’s statement of compliance shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc15d159-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the aircraft make, model, range of serial numbers, and any applicable consensus safety standards used and accepted by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d15a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state that the aircraft make and model meets the provisions of the consensus safety standards identified in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d15b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state that the aircraft make and model conforms to the manufacturer’s design data and is manufactured in a way that ensures consistency across units in the production process in order to meet the applicable consensus safety standards accepted by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d15c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" state that the manufacturer will make available to the Administrator, operators, or customers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc15d15d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/f/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft’s operating instructions, which conform to the consensus safety standards identified in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d15e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/f/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft’s recommended maintenance and inspection procedures, which conform to the consensus safety standards identified in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d15f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state that the manufacturer will monitor safety-of-flight issues and take action to ensure it meets the consensus safety standards identified in paragraph (1) and report these issues and subsequent actions to the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d160-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" state that at the request of the Administrator, the manufacturer will provide reasonable access for the Administrator to its facilities for the purposes of overseeing compliance with this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d161-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" state that the manufacturer, in accordance with the consensus safety standards accepted by the Federal Aviation Administration, has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc15d162-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/f/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ground and flight tested random samples of the aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d163-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/f/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" found the sample aircraft performance acceptable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d164-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/f/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determined that the make and model of aircraft is suitable for safe operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d165-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc15d166-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"False statements of compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be unlawful for any person to knowingly submit a statement of compliance described in subsection (f) that is fraudulent or intentionally false.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d167-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Introduction into interstate commerce","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Unless the Administrator determines operation of an unmanned aircraft system may be conducted without an airworthiness certificate or permission, authorization, or approval under subsection (a), it shall be unlawful for any person to knowingly introduce or deliver for introduction into interstate commerce any small unmanned aircraft system that is manufactured after the date that the Administrator accepts consensus safety standards under this section unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc15d168-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the make and model has been authorized for operation under subsection (a); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d169-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft has alternatively received design and production approval issued by the Federal Aviation Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d16a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44805/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may exempt from the requirements of this section small unmanned aircraft systems that are not capable of navigating beyond the visual line of sight of the operator through advanced flight systems and technology, if the Administrator determines that such an exemption does not pose a risk to the safety of the national airspace system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc15d16b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIII/s345/a"},"text":"Pub. L. 115–254, div. B, title III, § 345(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3291"},"text":"132 Stat. 3291","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIX/s903"},"text":"Pub. L. 118–63, title IX, § 903","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1341"},"text":"138 Stat. 1341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc15d16c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc15d16d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc15d16e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 2202 of the FAA Extension, Safety, and Security Act of 2016, referred to in subsec. (b)(7), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/s2202"},"text":"section 2202 of Pub. L. 114–190","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44802"},"text":"section 44802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc15d16f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s903/1"},"text":"Pub. L. 118–63, § 903(1)","children":[],"tail":", substituted “Small unmanned” for “Small Unmanned” in section catchline. Catchline was editorially conformed to the style used in this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s903/2"},"text":"Pub. L. 118–63, § 903(2)","children":[],"tail":", substituted “operation of a small” for “operation of small”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s903/6"},"text":"Pub. L. 118–63, § 903(6)","children":[],"tail":", redesignated subsecs. (e) to (g) as (c) to (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s903/6"},"text":"Pub. L. 118–63, § 903(6)","children":[],"tail":", redesignated subsec. (h) as (f). Former subsec. (f) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s903/3"},"text":"Pub. L. 118–63, § 903(3)","children":[],"tail":", substituted “subsection (f)” for “subsection (h)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s903/6"},"text":"Pub. L. 118–63, § 903(6)","children":[],"tail":", redesignated subsec. (i) as (g). Former subsec. (g) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s903/4"},"text":"Pub. L. 118–63, § 903(4)","children":[],"tail":", substituted “subsection (f)” for “subsection (h)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s903/6"},"text":"Pub. L. 118–63, § 903(6)","children":[],"tail":", redesignated subsec. (j) as (h). Former subsec. (h) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s903/6"},"text":"Pub. L. 118–63, § 903(6)","children":[],"tail":", redesignated subsec. (i) as (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s903/5"},"text":"Pub. L. 118–63, § 903(5)","children":[],"tail":", substituted “subsection (f)” for “subsection (h)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s903/6"},"text":"Pub. L. 118–63, § 903(6)","children":[],"tail":", redesignated subsec. (j) as (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc15d170-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc15d171-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Unmanned Aircraft Systems Research Facility","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIII/s345/b"},"text":"Pub. L. 115–254, div. B, title III, § 345(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3293"},"text":"132 Stat. 3293","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dB/tIII/s345/b"},"text":"“The Center of Excellence for Unmanned Aircraft Systems shall establish an unmanned aircraft systems research facility to study appropriate safety standards for unmanned aircraft systems and to validate such standards, as directed by the Administrator of the Federal Aviation Administration, consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44805"},"text":"section 44805 of title 49","children":[],"tail":", United States Code, as added by this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
