{"tag":"section","attrib":{"id":"idcb250939-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22703"},"text":null,"children":[{"tag":"num","attrib":{"value":"22703"},"text":"§ 22703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb25093a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of a State rail plan are as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb25093b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To set forth State policy involving freight and passenger rail transportation, including commuter rail operations, in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb25093c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To establish the period covered by the State rail plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb25093d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22703/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To present priorities and strategies to enhance rail service in the State that benefits the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb25093e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22703/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To serve as the basis for Federal and State rail investments within the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb25093f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State rail plan shall be coordinated with other State transportation planning goals and programs, including the plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s135"},"text":"section 135 of title 23","children":[],"tail":", and set forth rail transportation’s role within the State transportation system."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb250940-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tIII/s303/a"},"text":"Pub. L. 110–432, div. B, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4948"},"text":"122 Stat. 4948","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
