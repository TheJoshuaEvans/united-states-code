{"tag":"section","attrib":{"id":"idcc88429c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143"},"text":null,"children":[{"tag":"num","attrib":{"value":"60143"},"text":"§ 60143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Idled pipelines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc88429d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Idled","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “idled”, with respect to a pipeline, means that the pipeline—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc88429e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc88429f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has ceased normal operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8842a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not resume service for a period of not less than 180 days;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8842a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been isolated from all sources of hazardous liquid, natural gas, or other gas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8842a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8842a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been purged of combustibles and hazardous materials and maintains a blanket of inert, nonflammable gas at low pressure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8842a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has not been purged as described in subparagraph (A), but the volume of gas is so small that there is no potential hazard, as determined by the Secretary pursuant to a rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8842a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rulemaking.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8842a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of enactment of the PIPES Act of 2020, the Secretary shall promulgate regulations prescribing the applicability of the pipeline safety requirements to idled natural or other gas transmission and hazardous liquid pipelines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8842a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8842a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The applicability of the regulations under paragraph (1) shall be based on the risk that idled natural or other gas transmission and hazardous liquid pipelines pose to the public, property, and the environment, and shall include requirements to resume operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8842a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or an appropriate State agency shall inspect each idled pipeline and verify that the pipeline has been purged of combustibles and hazardous materials, if required under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8842aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for reinspection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall determine the requirements for periodic reinspection of idled natural or other gas transmission and hazardous liquid pipelines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8842ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resumption of operations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As a condition to allowing an idled pipeline to resume operations, the Secretary shall require that, prior to resuming operations, the pipeline shall be—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc8842ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" inspected with—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcc8842ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/b/2/D/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hydrostatic pressure testing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc8842ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/b/2/D/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an internal inspection device; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc8842af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/b/2/D/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the use of hydrostatic pressure testing or an internal inspection device is not technologically feasible, another comparable technology or practice; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8842b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60143/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in compliance with regulations promulgated under this chapter, including any regulations that became effective while the pipeline was idled.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc8842b1-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dR/tI/s109/a"},"text":"Pub. L. 116–260, div. R, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2223"},"text":"134 Stat. 2223","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc8842b2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc8842b3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the PIPES Act of 2020, referred to in subsec. (b)(1), is the date of enactment of div. R of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
