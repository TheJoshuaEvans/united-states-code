{"tag":"section","attrib":{"id":"idcbd7dee2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44104"},"text":null,"children":[{"tag":"num","attrib":{"value":"44104"},"text":"§ 44104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of aircraft components and dealers’ certificates of registration","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Federal Aviation Administration may prescribe regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7dee3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44104/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the interest of safety for registering and identifying an aircraft engine, propeller, or appliance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7dee4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44104/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the public interest for issuing, suspending, and revoking a dealer’s certificate of registration under this chapter and for its use by a person manufacturing, distributing, or selling aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd7dee5-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1162"},"text":"108 Stat. 1162","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd7dee6-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id