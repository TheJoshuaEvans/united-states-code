{"tag":"section","attrib":{"id":"idcb6c72cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31145"},"text":null,"children":[{"tag":"num","attrib":{"value":"31145"},"text":"§ 31145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination of Governmental activities and paperwork","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation shall coordinate the activities of departments, agencies, and instrumentalities of the United States Government to ensure adequate protection of the safety and health of operators of commercial motor vehicles. The Secretary shall attempt to minimize paperwork burdens to ensure maximum coordination and to avoid overlap and the imposition of unreasonable burdens on persons subject to regulations under this subchapter.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb6c72ce-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1012"},"text":"108 Stat. 1012","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb6c72cf-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb6c72d0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb6c72d1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attr