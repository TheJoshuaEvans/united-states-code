{"tag":"section","attrib":{"id":"idcbd56d3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42304"},"text":null,"children":[{"tag":"num","attrib":{"value":"42304"},"text":"§ 42304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Widespread disruptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd56d3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the event of a widespread disruption, a covered air carrier shall immediately publish, via a prominent link on the air carrier’s public internet website, a clear statement indicating whether, with respect to a passenger of the air carrier whose travel is interrupted as a result of the widespread disruption, the air carrier will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for hotel accommodations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for ground transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide meal vouchers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42304/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" arrange for air transportation on another air carrier or foreign air carrier to the passenger’s destination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42304/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for sleeping facilities inside the airport terminal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d41-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d42-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Widespread disruption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “widespread disruption” means, with respect to a covered air carrier, the interruption of all or the overwhelming majority of the air carrier’s systemwide flight operations, including flight delays and cancellations, as the result of the failure of 1 or more computer systems or computer networks of the air carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d43-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered air carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered air carrier” means an air carrier that provides scheduled passenger air transportation by operating an aircraft that as originally designed has a passenger capacity of 30 or more seats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d44-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Provision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to modify, abridge, or repeal any obligation of an air carrier under section 42301.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd56d45-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIV/s428/a"},"text":"Pub. L. 115–254, div. B, title IV, § 428(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3341"},"text":"132 Stat. 3341","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
