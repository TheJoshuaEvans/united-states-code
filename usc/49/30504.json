{"tag":"section","attrib":{"id":"idcb5715b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504"},"text":null,"children":[{"tag":"num","attrib":{"value":"30504"},"text":"§ 30504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reporting requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb5715b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Junk Yard and Salvage Yard Operators","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb5715b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Beginning at a time established by the Attorney General that is not sooner than the 3d month before the establishment or designation of the National Motor Vehicle Title Information System under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30502"},"text":"section 30502 of this title","children":[],"tail":", an individual or entity engaged in the business of operating a junk yard or salvage yard shall file a monthly report with the operator of the System. The report shall contain an inventory of all junk automobiles or salvage automobiles obtained by the junk yard or salvage yard during the prior month. The inventory shall contain—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb5715b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vehicle identification number of each automobile obtained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb5715b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the automobile was obtained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb5715b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the individual or entity from whom the automobile was obtained; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb5715b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of whether the automobile was crushed or disposed of for sale or other purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb5715b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) of this subsection does not apply to an individual or entity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb5715ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required by State law to report the acquisition of junk automobiles or salvage automobiles to State or local authorities if those authorities make that information available to the operator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb5715bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issued a verification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s33110"},"text":"section 33110 of this title","children":[],"tail":" stating that the automobile or parts from the automobile are not reported as stolen."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb5715bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Insurance Carriers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning at a time established by the Attorney General that is not sooner than the 3d month before the establishment or designation of the System, an individual or entity engaged in business as an insurance carrier shall file a monthly report with the operator. The report may be filed directly or through a designated agent. The report shall contain an inventory of all automobiles of the current model year or any of the 4 prior model years that the carrier, during the prior month, has obtained possession of and has decided are junk automobiles or salvage automobiles. The inventory shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb5715bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vehicle identification number of each automobile obtained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb5715be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the automobile was obtained;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb5715bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the individual or entity from whom the automobile was obtained; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb5715c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the owner of the automobile at the time of the filing of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb5715c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures and Practices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General shall establish by regulation procedures and practices to facilitate reporting in the least burdensome and costly fashion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb5715c2-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/982"},"text":"108 Stat. 982","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/152"},"text":"Pub. L. 104–152","children":[],"tail":", §§ 2(c), 3(a), "},{"tag":"date","attrib":{"date":"1996-07-02"},"text":"July 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1384"},"text":"110 Stat. 1384","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s3/b"},"text":"Pub. L. 105–102, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2215"},"text":"111 Stat. 2215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb5715c3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb5715c4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb5715c5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30504(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2044(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/519/s204/a"},"text":"Pub. L. 102–519, § 204(a)","children":[],"tail":", (b), (d), "},{"tag":"html:a","attrib":{"href":"/us/stat/106/3392"},"text":"106 Stat. 3392","children":[],"tail":", 3393."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30504(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2044(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30504(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2044(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a)(1), before clause (A), the words “Beginning at a time established by the Secretary of Transportation that is not sooner than the 3d month before the establishment or designation of” are substituted for “Beginning at a time determined by the Secretary, but no earlier than 3 months prior to the establishment of” for clarity and consistency with the source provisions restated in section 30502 of the revised title. The words “engaged in the business” are substituted for “in the business” for consistency in the revised chapter. The words “junk yard or salvage yard” are substituted for “automobile junk yard or automobile salvage yard” because of the definitions of “junk yard” and “salvage yard” in section 30501 of the revised title. The words “with the operator of the System” are substituted for “with the operator” for clarity. In clauses (A), (C), and (D), the words “each automobile” are substituted for “each vehicle”, and the words “the automobile” are substituted for “the vehicle”, for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(B), the word “automobile” is substituted for “vehicle” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b), before clause (1), the words “Beginning at a time established by the Secretary that is not sooner than the 3d month before the establishment or designation of” are substituted for “Beginning at a time determined by the Secretary, but no earlier than 3 months prior to the establishment of” for clarity and consistency with the source provisions restated in section 30502 of the revised title. In clauses (1), (3), and (4), the words “each automobile” are substituted for “each vehicle”, and the words “the automobile” are substituted for “the vehicle”, for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb5715c6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb5715c7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/104/152/s2/c"},"text":"Pub. L. 104–152, § 2(c)","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/152/s3/a"},"text":"Pub. L. 104–152, § 3(a)","children":[],"tail":", substituted “Attorney General” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/152/s2/c"},"text":"Pub. L. 104–152, § 2(c)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":", substituted “National Motor Vehicle Title Information System” for “National Automobile Title Information System”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/152/s3/a"},"text":"Pub. L. 104–152, § 3(a)","children":[],"tail":", substituted “Attorney General” for “Secretary”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb5715c8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb5715c9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102/s3/b"},"text":"Pub. L. 105–102, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2215"},"text":"111 Stat. 2215","children":[],"tail":", provided that the amendment made by section 3(b) is effective "},{"tag":"date","attrib":{"date":"1996-07-02"},"text":"July 2, 1996","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" effective as if included in the provisions of the Act to which the amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s3/f"},"text":"section 3(f) of Pub. L. 105–102","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
