{"tag":"section","attrib":{"id":"idcaf2d606-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506"},"text":null,"children":[{"tag":"num","attrib":{"value":"13506"},"text":"§ 13506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Miscellaneous motor carrier transportation exemptions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf2d607-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Neither the Secretary nor the Board has jurisdiction under this part over—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d608-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor vehicle transporting only school children and teachers to or from school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d609-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor vehicle providing taxicab service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d60a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor vehicle owned or operated by or for a hotel and only transporting hotel patrons between the hotel and the local station of a carrier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d60b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a motor vehicle controlled and operated by a farmer and transporting—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf2d60c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the farmer’s agricultural or horticultural commodities and products; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d60d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supplies to the farm of the farmer;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d60e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a motor vehicle controlled and operated by a cooperative association (as defined by section 15(a) of the Agricultural Marketing Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1141j/a"},"text":"12 U.S.C. 1141j(a)","children":[],"tail":")) or by a federation of cooperative associations if the federation has no greater power or purposes than a cooperative association, except that if the cooperative association or federation provides transportation for compensation between a place in a State and a place in another State, or between a place in a State and another place in the same State through another State—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf2d60f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a nonmember that is not a farmer, cooperative association, federation, or the United States Government, the transportation (except for transportation otherwise exempt under this subchapter)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcaf2d610-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be limited to transportation incidental to the primary transportation operation of the cooperative association or federation and necessary for its effective performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf2d611-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not exceed in each fiscal year 25 percent of the total transportation of the cooperative association or federation between those places, measured by tonnage; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d612-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation for all nonmembers may not exceed in each fiscal year, measured by tonnage, the total transportation between those places for the cooperative association or federation and its members during that fiscal year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d613-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transportation by motor vehicle of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf2d614-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ordinary livestock;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d615-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agricultural or horticultural commodities (other than manufactured products thereof);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d616-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commodities listed as exempt in the Commodity List incorporated in ruling numbered 107, ","children":[{"tag":"date","attrib":{"date":"1958-03-19"},"text":"March 19, 1958","children":[],"tail":", Bureau of Motor Carriers, Interstate Commerce Commission, other than frozen fruits, frozen berries, frozen vegetables, cocoa beans, coffee beans, tea, bananas, or hemp, or wool imported from a foreign country, wool tops and noils, or wool waste (carded, spun, woven, or knitted);"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d617-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooked or uncooked fish, whether breaded or not, or frozen or fresh shellfish, or byproducts thereof not intended for human consumption, other than fish or shellfish that have been treated for preserving, such as canned, smoked, pickled, spiced, corned, or kippered products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d618-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" livestock and poultry feed and agricultural seeds and plants, if such products (excluding products otherwise exempt under this paragraph) are transported to a site of agricultural production or to a business enterprise engaged in the sale to agricultural producers of goods used in agricultural production;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d619-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor vehicle used only to distribute newspapers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d61a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf2d61b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation of passengers by motor vehicle incidental to transportation by aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d61c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation of property (including baggage) by motor vehicle as part of a continuous movement which, prior or subsequent to such part of the continuous movement, has been or will be transported by an air carrier or (to the extent so agreed by the United States and approved by the Secretary) by a foreign air carrier; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d61d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation of property by motor vehicle in lieu of transportation by aircraft because of adverse weather conditions or mechanical failure of the aircraft or other causes due to circumstances beyond the control of the carrier or shipper;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d61e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation of a motor vehicle in a national park or national monument;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d61f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor vehicle carrying not more than 15 individuals in a single, daily roundtrip to commute to and from work;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d620-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation of used pallets and used empty shipping containers (including intermodal cargo containers), and other used shipping devices (other than containers or devices used in the transportation of motor vehicles or parts of motor vehicles);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d621-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation of natural, crushed, vesicular rock to be used for decorative purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d622-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation of wood chips;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d623-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" brokers for motor carriers of passengers, except as provided in section 13904(d); ","children":[{"tag":"ref","attrib":{"idref":"fn002051"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002051"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d624-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation of broken, crushed, or powdered glass; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d625-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/a/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation of passengers by 9 to 15 passenger motor vehicles operated by youth or family camps that provide recreational or educational activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d626-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exempt Unless Otherwise Necessary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except to the extent the Secretary or Board, as applicable, finds it necessary to exercise jurisdiction to carry out the transportation policy of section 13101, neither the Secretary nor the Board has jurisdiction under this part over—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d627-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transportation provided entirely in a municipality, in contiguous municipalities, or in a zone that is adjacent to, and commercially a part of, the municipality or municipalities, except—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf2d628-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when the transportation is under common control, management, or arrangement for a continuous carriage or shipment to or from a place outside the municipality, municipalities, or zone; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d629-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that in transporting passengers over a route between a place in a State and a place in another State, or between a place in a State and another place in the same State through another State, the transportation is exempt from jurisdiction under this part only if the motor carrier operating the motor vehicle also is lawfully providing intrastate transportation of passengers over the entire route under the laws of each State through which the route runs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d62a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation by motor vehicle provided casually, occasionally, or reciprocally but not as a regular occupation or business, except when a broker or other person sells or offers for sale passenger transportation provided by a person authorized to transport passengers by motor vehicle under an application pending, or registration issued, under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d62b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the emergency towing of an accidentally wrecked or disabled motor vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d62c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transportation by a motor vehicle designed or used to transport not fewer than 9, and not more than 15, passengers (including the driver), whether operated alone or with a trailer attached for the transport of recreational equipment, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf2d62d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the motor vehicle is operated by a person that provides recreational activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d62e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation is provided within a 150 air-mile radius of the location at which passengers initially boarded the motor vehicle at the outset of the trip; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d62f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13506/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a motor vehicle transporting passengers over a route between a place in a State and a place in another State, the person operating the motor vehicle is lawfully providing transportation of passengers over the entire route in accordance with applicable State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf2d630-47c4-11f1-9671-b5c725212f70"},"