{"tag":"section","attrib":{"id":"idcb7d3b7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A"},"text":null,"children":[{"tag":"num","attrib":{"value":"32304A"},"text":"§ 32304A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer tire information and standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb7d3b7f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consumer Tire Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3b80-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 24 months after the date of enactment of the Ten-in-Ten Fuel Economy Act, the Secretary of Transportation (referred to in this section as the “Secretary”) shall, after notice and opportunity for comment, promulgate rules establishing a national tire fuel efficiency consumer information program for replacement tires designed for use on motor vehicles to educate consumers about the effect of tires on automobile fuel efficiency, safety, and durability.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3b81-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Items included in rule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rulemaking shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7d3b82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national tire fuel efficiency rating system for motor vehicle replacement tires to assist consumers in making more educated tire purchasing decisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3b83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements for providing information to consumers, including information at the point of sale and other potential information dissemination methods, including the Internet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3b84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifications for test methods for manufacturers to use in assessing and rating tires to avoid variation among test equipment and manufacturers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3b85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national tire maintenance consumer education program including,","children":[{"tag":"ref","attrib":{"idref":"fn002130"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002130"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “, including”."}],"tail":" information on tire inflation pressure, alignment, rotation, and tread wear to maximize fuel efficiency, safety, and durability of replacement tires."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3b86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall apply only to replacement tires covered under section 575.104(c) of title 49, Code of Federal Regulations, in effect on the date of the enactment of the Ten-in-Ten Fuel Economy Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3b87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promulgation of Regulations for Tire Fuel Efficiency Minimum Performance Standards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3b88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, after consultation with the Secretary of Energy and the Administrator of the Environmental Protection Agency, shall promulgate regulations for tire fuel efficiency minimum performance standards for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7d3b89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passenger car tires with a maximum speed capability equal to or less than 149 miles per hour or 240 kilometers per hour; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3b8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passenger car tires with a maximum speed capability greater than 149 miles per hour or 240 kilometers per hour.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3b8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tire fuel efficiency minimum performance standards.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7d3b8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standard basis and test procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The minimum performance standards promulgated under paragraph (1) shall be expressed in terms of the rolling resistance coefficient measured using the test procedure specified in section 575.106 of title 49, Code of Federal Regulations (as in effect on the date of enactment of this Act).","children":[{"tag":"ref","attrib":{"idref":"fn002131"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002131"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3b8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No disparate effect on high performance tires","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that the minimum performance standards promulgated under paragraph (1) will not have a disproportionate effect on passenger car high performance tires with a maximum speed capability greater than 149 miles per hour or 240 kilometers per hour.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3b8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idcb7d3b8f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection applies to new pneumatic tires for use on passenger cars.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb7d3b90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not apply to light truck tires, deep tread tires, winter-type snow tires, space-saver or temporary use spare tires, or tires with nominal rim diameters of 12 inches or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3b91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Promulgation of Regulations for Tire Wet Traction Minimum Performance Standards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3b92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall promulgate regulations for tire wet traction minimum performance standards to ensure that passenger tire wet traction capability is not reduced to achieve improved tire fuel efficiency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3b93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tire wet traction minimum performance standards.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7d3b94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basis of standard","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The minimum performance standards promulgated under paragraph (1) shall be expressed in terms of peak coefficient of friction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3b95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Test procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any test procedure promulgated under this subsection shall be consistent with any test procedure promulgated under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3b96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Benchmarking","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct testing to benchmark the wet traction performance of tire models available for sale in the United States as of the date of enactment of this Act ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" to ensure that the minimum performance standards promulgated under paragraph (1) are tailored to—"}],"tail":null},{"tag":"clause","attrib":{"id":"idcb7d3b97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" tires sold in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb7d3b98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the needs of consumers in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3b99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idcb7d3b9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection applies to new pneumatic tires for use on passenger cars.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb7d3b9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not apply to light truck tires, deep tread tires, winter-type snow tires, space-saver or temporary use spare tires, or tires with nominal rim diameters of 12 inches or less.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3b9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination Among Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3b9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compatibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that the test procedures and requirements promulgated under subsections (a), (b), and (c) are compatible and consistent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3b9e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Combined effect of rules","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall evaluate the regulations promulgated under subsections (b) and (c) to ensure that compliance with the minimum performance standards promulgated under subsection (b) will not diminish wet traction performance of affected tires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3b9f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rulemaking deadlines","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall promulgate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7d3ba0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regulations under subsections (b) and (c) not later than 24 months after the date of enactment of this Act; ","children":[{"tag":"sup","attrib":{},"text":"2","children":[],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3ba1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the regulations under subsection (c) not later than the date of promulgation of the regulations under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3ba2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall consult with the Secretary of Energy and the Administrator of the Environmental Protection Agency on the means of conveying tire fuel efficiency consumer information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3ba3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall conduct periodic assessments of the rules promulgated under this section to determine the utility of such rules to consumers, the level of cooperation by industry, and the contribution to national goals pertaining to energy consumption. The Secretary shall transmit periodic reports detailing the findings of such assessments to the Senate Committee on Commerce, Science, and Transportation and the House of Representatives Committee on Energy and Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3ba4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tire Marking","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not require permanent labeling of any kind on a tire for the purpose of tire fuel efficiency information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3ba5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32304A/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application With State and Local Laws and Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section prohibits a State or political subdivision thereof from enforcing a law or regulation on tire fuel efficiency consumer information that was in effect on ","children":[{"tag":"date","attrib":{"date":"2006-01-01"},"text":"January 1, 2006","children":[],"tail":". After a requirement promulgated under this section is in effect, a State or political subdivision thereof may adopt or enforce a law or regulation on tire fuel efficiency consumer information enacted or promulgated after "},{"tag":"date","attrib":{"date":"2006-01-01"},"text":"January 1, 2006","children":[],"tail":", if the requirements of that law or regulation are identical to the requirement promulgated under this section. Nothing in this section shall be construed to preempt a State or political subdivision thereof from regulating the fuel efficiency of tires (including establishing testing methods for determining compliance with such standards) not otherwise preempted under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb7d3ba6-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tI/s111/a"},"text":"Pub. L. 110–140, title I, § 111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1506"},"text":"121 Stat. 1506","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dB/tXXIV/s24332"},"text":"Pub. L. 114–94, div. B, title XXIV, § 24332","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1713"},"text":"129 Stat. 1713","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb7d3ba7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb7d3ba8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb7d3ba9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Ten-in-Ten Fuel Economy Act, referred to in subsec. (a)(1), (3), is the date of enactment of subtitle A (§§ 101–113) of title I of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this Act, referred to in subsecs. (b)(2)(A), (c)(2)(C), and (d)(3)(A), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":", which added subsecs. (b) to (d) and was approved "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb7d3baa-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s24332/1"},"text":"Pub. L. 114–94, § 24332(1)","children":[],"tail":", which directed insertion of “AND STANDARDS” after “CONSUMER TIRE INFORMATION” in section catchline, was executed by inserting “and standards” after “Consumer tire information”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s24332/2/A"},"text":"Pub. L. 114–94, § 24332(2)(A)","children":[],"tail":", substituted “Consumer Tire Information” for “Rulemaking” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s24332/2/B"},"text":"Pub. L. 114–94, § 24332(2)(B)","children":[],"tail":", inserted “(referred to in this section as the ‘Secretary’)” after “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s24332/3"},"text":"Pub. L. 114–94, § 24332(3)","children":[],"tail":", (4), added subsecs. (b) to (d) and redesignated former subsecs. (b) to (e) as (e) to (h), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb7d3bab-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb7d3bac-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
