{"tag":"section","attrib":{"id":"idca8790e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1322"},"text":null,"children":[{"tag":"num","attrib":{"value":"1322"},"text":"§ 1322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Board action","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8790e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date of Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless otherwise provided in subtitle IV, the Board may determine, within a reasonable time, when its actions, other than an action ordering the payment of money, take effect.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8790e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terminating and Changing Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An action of the Board remains in effect under its own terms or until superseded. The Board may change, suspend, or set aside any such action on notice. Notice may be given in a manner determined by the Board. A court of competent jurisdiction may suspend or set aside any such action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8790e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reconsidering Actions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may, at any time on its own initiative because of material error, new evidence, or substantially changed circumstances—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8790e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1322/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reopen a proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8790e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1322/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant rehearing, reargument, or reconsideration of an action of the Board; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8790e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1322/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" change an action of the Board.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"An interested party may petition to reopen and reconsider an action of the Board under this subsection under regulations of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8790e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1322/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Finality of Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subtitle IV, an action of the Board under this section is final on the date on which it is served, and a civil action to enforce, enjoin, suspend, or set aside the action may be filed after that date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8790e8-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tII/s201/a"},"text":"Pub. L. 104–88, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/936"},"text":"109 Stat. 936","children":[],"tail":", § 722; renumbered § 1322, "},{"tag":"ref","attrib":{"href":"/us/pl/114/110/s3/a/5"},"text":"Pub. L. 114–110, § 3(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2228"},"text":"129 Stat. 2228","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8790e9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8790ea-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca8790eb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110"},"text":"Pub. L. 114–110","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s722"},"text":"section 722 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
