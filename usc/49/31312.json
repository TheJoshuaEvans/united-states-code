{"tag":"section","attrib":{"id":"idcb760fab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31312"},"text":null,"children":[{"tag":"num","attrib":{"value":"31312"},"text":"§ 31312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Decertification authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb760fac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of Transportation determines that a State is in substantial noncompliance with this chapter, the Secretary shall issue an order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb760fad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit that State from carrying out licensing procedures under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb760fae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prohibit that State from issuing any commercial driver’s licenses until such time the Secretary determines such State is in substantial compliance with this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb760faf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on Other States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State (other than a State subject to an order under subsection (a)) may issue a non-resident commercial driver’s license to an individual domiciled in a State that is prohibited from such activities under subsection (a) if that individual meets all requirements of this chapter and the nonresident licensing requirements of the issuing State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb760fb0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Previously Issued Licenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed as invalidating or otherwise affecting commercial driver’s licenses issued by a State before the date of issuance of an order under subsection (a) with respect to the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb760fb1-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/tII/s203/a"},"text":"Pub. L. 106–159, title II, § 203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1762"},"text":"113 Stat. 1762","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb760fb2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb760fb3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb760fb4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 31312, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1025"},"text":"108 Stat. 1025","children":[],"tail":", related to grants for testing and ensuring the fitness of operators of commercial motor vehicles, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4011/f"},"text":"Pub. L. 105–178, title IV, § 4011(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/408"},"text":"112 Stat. 408","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
