{"tag":"section","attrib":{"id":"idcb18fbe4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20504"},"text":null,"children":[{"tag":"num","attrib":{"value":"20504"},"text":"§ 20504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection, testing, and investigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb18fbe5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Systems in Use","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb18fbe6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb18fbe7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20504/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspect and test a signal system used by a railroad carrier; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fbe8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20504/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decide whether the system is in safe operating condition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fbe9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out this subsection, the Secretary may employ only an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb18fbea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20504/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has no interest in a patented article required to be used on or with a signal system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fbeb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20504/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has no financial interest in a railroad carrier or in a concern dealing in railroad supplies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb18fbec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Systems Submitted for Investigation and Testing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may investigate, test, and report on the use of and need for a signal system, without cost to the United States Government, when the system is submitted in completed shape for investigation and testing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb18fbed-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/884"},"text":"108 Stat. 884","children":[],"tail":".)"}]