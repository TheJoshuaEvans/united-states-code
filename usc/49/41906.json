{"tag":"section","attrib":{"id":"idcbd2fc53-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41906"},"text":null,"children":[{"tag":"num","attrib":{"value":"41906"},"text":"§ 41906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty to oppose unreasonable prices under the Universal Postal Union Convention","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary of State and the United States Postal Service shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd2fc54-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41906/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take appropriate action to ensure that the prices paid for transporting mail under the Universal Postal Union Convention are not higher than reasonable prices for transporting mail; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd2fc55-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41906/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oppose any existing or proposed Universal Postal Union price that is higher than a reasonable price for transporting mail.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd2fc56-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1156"},"text":"108 Stat. 1156","children":[],"tail":", § 41909; renumbered § 41906, "},{"tag":"ref","attrib":{"href":"/us/pl/110/405/s2/b/7/B"},"text":"Pub. L. 110–405, § 2(b)(7)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text