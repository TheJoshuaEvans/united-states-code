{"tag":"section","attrib":{"id":"idcb8b93b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32919"},"text":null,"children":[{"tag":"num","attrib":{"value":"32919"},"text":"§ 32919.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb8b93b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32919/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When an average fuel economy standard prescribed under this chapter is in effect, a State or a political subdivision of a State may not adopt or enforce a law or regulation related to fuel economy standards or average fuel economy standards for automobiles covered by an average fuel economy standard under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8b93b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32919/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements Must Be Identical","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When a requirement under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32908"},"text":"section 32908 of this title","children":[],"tail":" is in effect, a State or a political subdivision of a State may adopt or enforce a law or regulation on disclosure of fuel economy or fuel operating costs for an automobile covered by section 32908 only if the law or regulation is identical to that requirement."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8b93ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32919/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State and Political Subdivision Automobiles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State or a political subdivision of a State may prescribe requirements for fuel economy for automobiles obtained for its own use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb8b93bb-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1075"},"text":"108 Stat. 1075","children":[],"tail":", § 32918; renumbered § 32919, "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/43/A"},"text":"Pub. L. 103–429, § 6(43)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4382"},"text":"108 Stat. 4382","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb8b93bc-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb8b93bd-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb8b93be-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n",