{"tag":"section","attrib":{"id":"idca747d5c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s354"},"text":null,"children":[{"tag":"num","attrib":{"value":"354"},"text":"§ 354.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Investigative authority of Inspector General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca747d5d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s354/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The statutory authority of the Inspector General of the Department of Transportation includes authority to conduct, pursuant to Federal criminal statutes, investigations of allegations that a person or entity has engaged in fraudulent or other criminal activity relating to the programs and operations of the Department or its operating administrations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca747d5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s354/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulated Entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority to conduct investigations referred to in subsection (a) extends to any person or entity subject to the laws and regulations of the Department or its operating administrations, whether or not they are recipients of funds from the Department or its operating administrations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca747d5f-47c4-11f1-9671-b5c725212f70"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/168/s8/a"},"text":"Pub. L. 108–168, § 8(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2034"},"text":"117 Stat. 2034","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca747d60-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca747d61-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca747d62-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/s228"},"text":"section 228 of Pub. L. 106–159","children":[],"tail":", formerly set out as a note under section 4 of the Inspector General Act of 1978, "},{"tag":"ref","attrib":{"href":"/us/pl/95/452"},"text":"Pub. L. 95–452","children":[],"tail":", formerly set out in the Appendix to Title 5, Government Organization and Employees, which was transferred to this section, redesignated as text of section, and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/168/s8/a"},"text":"Pub. L. 108–168, § 8(a)","children":[],"tail":", (b)(1), was based on "},{"tag":"ref","attrib":{"href":"/us/pl/106/159/tII/s228"},"text":"Pub. L. 106–159, title II, § 228","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1773"},"text":"113 Stat. 1773","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca747d63-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/168"},"text":"Pub. L. 108–168","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/pl/106/159/s228"},"text":"section 228 of Pub. L. 106–159","children":[],"tail":" as this section and substituted “Investigative authority of Inspector General” for “DOT Authority” in section catchline. See Codification note above."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca747d64-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca747d65-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deposit of Forfeited Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dK/tI"},"text":"Pub. L. 113–235, div. K, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2724"},"text":"128 Stat. 2724","children":[],"tail":", provided in part: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/235/dK/tI"},"text":"“That hereafter funds transferred to the Office of the Inspector General through forfeiture proceedings or from the Department of Justice Assets Forfeiture Fund or the Department of the Treasury Forfeiture Fund, as a participating agency, as an equitable share from the forfeiture of property in investigations in which the Office of Inspector General participates, or through the granting of a Petition for Remission or Mitigation, shall be deposited to the credit of this account [Office of Inspector General, Salaries and Expenses] for law enforcement activities authorized under the Inspector General Act of 1978, as amended [see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s401"},"text":"5 U.S.C. 401","children":[],"tail":" et seq.], to remain available until expended.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior appropriation act:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/76/dL/tI"},"text":"Pub. L. 113–76, div. L, title I","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-01-17"},"text":"Jan. 17, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/600"},"text":"128 Stat. 600","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
