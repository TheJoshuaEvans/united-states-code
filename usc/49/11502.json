{"tag":"section","attrib":{"id":"idcaee1af7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11502"},"text":null,"children":[{"tag":"num","attrib":{"value":"11502"},"text":"§ 11502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Withholding State and local income tax by rail carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaee1af8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No part of the compensation paid by a rail carrier providing transportation subject to the jurisdiction of the Board under this part to an employee who performs regularly assigned duties as such an employee on a railroad in more than one State shall be subject to the income tax laws of any State or subdivision of that State, other than the State or subdivision thereof of the employee’s residence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaee1af9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A rail carrier withholding pay from an employee under subsection (a) of this section shall file income tax information returns and other reports only with the State and subdivision of residence of the employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaee1afa-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/844"},"text":"109 Stat. 844","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attr