{"tag":"section","attrib":{"id":"idcb1b6c78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103"},"text":null,"children":[{"tag":"num","attrib":{"value":"21103"},"text":"§ 21103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on duty hours of train employees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb1b6c79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d) of this section, a railroad carrier and its officers and agents may not require or allow a train employee to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb1b6c7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" remain on duty, go on duty, wait for deadhead transportation, be in deadhead transportation from a duty assignment to the place of final release, or be in any other mandatory service for the carrier in any calendar month where the employee has spent a total of 276 hours—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb1b6c7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1b6c7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waiting for deadhead transportation, or in deadhead transportation from a duty assignment to the place of final release; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1b6c7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in any other mandatory service for the carrier;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1b6c7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain or go on duty for a period in excess of 12 consecutive hours;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1b6c7f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain or go on duty unless that employee has had at least 10 consecutive hours off duty during the prior 24 hours; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1b6c80-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" remain or go on duty after that employee has initiated an on-duty period each day for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb1b6c81-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 6 consecutive days, unless that employee has had at least 48 consecutive hours off duty at the employee’s home terminal during which time the employee is unavailable for any service for any railroad carrier except that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb1b6c82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee may work a seventh consecutive day if that employee completed his or her final period of on-duty time on his or her sixth consecutive day at a terminal other than his or her home terminal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb1b6c83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any employee who works a seventh consecutive day pursuant to subparagraph (i) shall have at least 72 consecutive hours off duty at the employee’s home terminal during which time the employee is unavailable for any service for any railroad carrier; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1b6c84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as provided in subparagraph (A), 7 consecutive days, unless that employee has had at least 72 consecutive hours off duty at the employee’s home terminal during which time the employee is unavailable for any service for any railroad carrier, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb1b6c85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a period of 18 months following the date of enactment of the Rail Safety Improvement Act of 2008, an existing collective bargaining agreement expressly provides for such a schedule or, following the expiration of 18 months after the date of enactment of the Rail Safety Improvement Act of 2008, collective bargaining agreements entered into during such period expressly provide for such a schedule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb1b6c86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such a schedule is provided for by a pilot program authorized by a collective bargaining agreement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb1b6c87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such a schedule is provided for by a pilot program under section 21108 of this chapter related to employees’ work and rest cycles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The Secretary may waive paragraph (4), consistent with the procedural requirements of section 20103, if a collective bargaining agreement provides a different arrangement and such an arrangement is in the public interest and consistent with railroad safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb1b6c88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determining Time on Duty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining under subsection (a) of this section the time a train employee is on or off duty, the following rules apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb1b6c89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Time on duty begins when the employee reports for duty and ends when the employee is finally released from duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1b6c8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Time the employee is engaged in or connected with the movement of a train is time on duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1b6c8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Time spent performing any other service for the railroad carrier during a 24-hour period in which the employee is engaged in or connected with the movement of a train is time on duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1b6c8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Time spent in deadhead transportation to a duty assignment is time on duty, but time spent in deadhead transportation from a duty assignment to the place of final release is neither time on duty nor time off duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1b6c8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An interim period available for rest at a place other than a designated terminal is time on duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1b6c8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An interim period available for less than 4 hours rest at a designated terminal is time on duty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1b6c8f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An interim period available for at least 4 hours rest at a place with suitable facilities for food and lodging is not time on duty when the employee is prevented from getting to the employee’s designated terminal by any of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb1b6c90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a casualty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1b6c91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a track obstruction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1b6c92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act of God.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1b6c93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/b/7/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a derailment or major equipment failure resulting from a cause that was unknown and unforeseeable to the railroad carrier or its officer or agent in charge of that employee when that employee left the designated terminal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb1b6c94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limbo Time Limitation and Additional Rest Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb1b6c95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A railroad carrier may not require or allow an employee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb1b6c96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to exceed a total of 40 hours per calendar month spent—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb1b6c97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waiting for deadhead transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb1b6c98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in deadhead transportation from a duty assignment to the place of final release,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"following a period of 12 consecutive hours on duty that is neither time on duty nor time off duty, not including interim rest periods, during the period from the date of enactment of the Rail Safety Improvement Act of 2008 to one year after such date of enactment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1b6c99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to exceed a total of 30 hours per calendar month spent—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb1b6c9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" waiting for deadhead transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb1b6c9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in deadhead transportation from a duty assignment to the place of final release,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"following a period of 12 consecutive hours on duty that is neither time on duty nor time off duty, not including interim rest periods, during the period beginning one year after the date of enactment of the Rail Safety Improvement Act of 2008 except that the Secretary may further limit the monthly limitation pursuant to regulations prescribed under section 21109.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1b6c9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The limitations in paragraph (1) shall apply unless the train carrying the employee is directly delayed by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb1b6c9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a casualty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1b6c9e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1b6c9f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an act of God;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1b6ca0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a derailment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1b6ca1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a major equipment failure that prevents the train from advancing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1b6ca2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a delay resulting from a cause unknown and unforeseeable to a railroad carrier or its officer or agent in charge of the employee when the employee left a terminal.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1b6ca3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each railroad carrier shall report to the Secretary, in accordance with procedures established by the Secretary, each instance where an employee subject to this section spends time waiting for deadhead transportation or in deadhead transportation from a duty assignment to the place of final release in excess of the requirements of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1b6ca4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb1b6ca5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time spent waiting for deadhead transportation or in deadhead transportation from a duty assignment to the place of final release that is not time on duty, plus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1b6ca6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time on duty,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"exceeds 12 consecutive hours, the railroad carrier and its officers and agents shall provide the employee with additional time off duty equal to the number of hours by which such sum exceeds 12 hours.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb1b6ca7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emergencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A train employee on the crew of a wreck or relief train may be allowed to remain or go on duty for not more than 4 additional hours in any period of 24 consecutive hours when an emergency exists and the work of the crew is related to the emergency. In this subsection, an emergency ends when the track is cleared and the railroad line is open for traffic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb1b6ca8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Communication During Time Off Duty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"During a train employee’s minimum off-duty period of 10 consecutive hours, as provided under subsection (a) or during an interim period of at least 4 consecutive hours available for rest under subsection (b)(7) or during additional off-duty hours under subsection (c)(4), a railroad carrier, and its officers and agents, shall not communicate with the train employee by telephone, by pager, or in any other manner that could reasonably be expected to disrupt the employee’s rest. Nothing in this subsection shall prohibit communication necessary to notify an employee of an emergency situation, as defined by the Secretary. The Secretary may waive the requirements of this paragraph for commuter or intercity passenger railroads if the Secretary determines that such a waiver will not reduce safety and is necessary to maintain such railroads’ efficient operations and on-time performance of its trains.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb1b6ca9-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/888"},"text":"108 Stat. 888","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tI/s108/b"},"text":"Pub. L. 110–432, div. A, title I, § 108(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4860"},"text":"122 Stat. 4860","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb1b6caa-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":