ib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939"},"text":"Mar. 4, 1907, ch. 2939","children":[],"tail":", §§ 1(b)(3), 2(b), "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1415"},"text":"34 Stat. 1415","children":[],"tail":", 1416; restated "},{"tag":"html:span","attrib":{},"text":"Dec. 26, 1969","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/169/s1"},"text":"Pub. L. 91–169, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/83/463"},"text":"83 Stat. 463","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:61(b)(4) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939"},"text":"Mar. 4, 1907, ch. 2939","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1415"},"text":"34 Stat. 1415","children":[],"tail":", § 1(b)(4) (last sentence); added "},{"tag":"html:span","attrib":{},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/574/s6"},"text":"Pub. L. 95–574, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2461"},"text":"92 Stat. 2461","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s16/1/C"},"text":"Pub. L. 100–342, § 16(1)(C)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/634"},"text":"102 Stat. 634","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:62(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21103(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:62(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939/s2/c"},"text":"Mar. 4, 1907, ch. 2939, § 2(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1416"},"text":"34 Stat. 1416","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Dec. 26, 1969","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/169/s1"},"text":"Pub. L. 91–169, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/83/464"},"text":"83 Stat. 464","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"July 8, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/348/s4/b"},"text":"Pub. L. 94–348, § 4(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/818"},"text":"90 Stat. 818","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “Except as provided in subsection (c) of this section” are added to alert the reader to the exception restated in subsection (c). The words “train employee” are substituted for “employee” because of the definition of “train employee” in section 21101 of the revised title. In clause (2), the words “12 consecutive hours” are substituted for “continuously . . . fourteen hours” and “except that, effective upon the expiration of the two-year period beginning on the effective date of this paragraph, such fourteen-hour duty period shall be reduced to twelve hours” because the 2-year period has ended.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words before paragraph (1) are added as related to 45:61(b)(3) and (4) (last sentence) and substituted for “In determining, for the purposes of subsection (a), the number of hours an employee is on duty” in 45:62(b) for clarity. In paragraphs (2) and (3), the word “actually” is omitted as surplus. In paragraph (4), the words “neither time on duty nor time off duty” are substituted for “time off duty” for clarity and consistency with the source provisions restated in 21104(b)(3) and (4) of the revised title. In paragraph (7), before clause (A), the words “between designated terminals” are omitted as surplus. The text of 45:61(b)(3)(E) is omitted as surplus because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “A train employee on” are added for consistency in this section. The word “actual” is omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb1b6cad-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb1b6cae-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Rail Safety Improvement Act of 2008, referred to in subsecs. (a)(4)(B)(i) and (c)(1), is the date of enactment of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb1b6caf-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s108/b/1"},"text":"Pub. L. 110–432, § 108(b)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “Except as provided in subsection (c) of this section, a railroad carrier and its officers and agents may not require or allow a train employee to remain or go on duty—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) unless that employee has had at least 8 consecutive hours off duty during the prior 24 hours; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) after that employee has been on duty for 12 consecutive hours, until that employee has had at least 10 consecutive hours off duty.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s108/b/2"},"text":"Pub. L. 110–432, § 108(b)(2)","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s108/b/3"},"text":"Pub. L. 110–432, § 108(b)(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb1b6cb0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb1b6cb1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":" effective 9 months after "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/s108/g"},"text":"section 108(g) of Pub. L. 110–432","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s21101"},"text":"section 21101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
