{"tag":"section","attrib":{"id":"idcb7d3c38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502"},"text":null,"children":[{"tag":"num","attrib":{"value":"32502"},"text":"§ 32502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bumper standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb7d3c39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements and Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall prescribe by regulation bumper standards for passenger motor vehicles and may prescribe by regulation bumper standards for passenger motor vehicle equipment manufactured in, or imported into, the United States. A standard does not apply to a passenger motor vehicle or passenger motor vehicle equipment—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3c3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intended only for export;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labeled for export on the vehicle or equipment and the outside of any container of the vehicle or equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exported.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3c3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A standard under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3c3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not conflict with a motor vehicle safety standard prescribed under chapter 301 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not specify a dollar amount for the cost of repairing damage to a passenger motor vehicle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the greatest practicable extent, may not preclude the attachment of a detachable hitch.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3c41-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For good cause, the Secretary may exempt from all or any part of a standard—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3c42-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multipurpose passenger vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c43-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a make, model, or class of a passenger motor vehicle manufactured for a special use, if the standard would interfere unreasonably with the special use of the vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c44-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a passenger motor vehicle for which an application for an exemption under section 30013(b) ","children":[{"tag":"ref","attrib":{"idref":"fn002132"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002132"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be section “30113(b)”."}],"tail":" of this title has been filed in accordance with the requirements of that section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3c45-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost Reduction and Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When prescribing a standard under this section, the Secretary shall design the standard to obtain the maximum feasible reduction of costs to the public, considering—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3c46-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs and benefits of carrying out the standard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c47-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of the standard on insurance costs and legal fees and costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" savings in consumer time and inconvenience; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" health and safety, including emission standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3c4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s553"},"text":"Section 553 of title 5","children":[],"tail":" applies to a standard prescribed under this section. However, the Secretary shall give an interested person an opportunity to make oral and written presentations of information, views, and arguments. A transcript of each oral presentation shall be kept. Under conditions prescribed by the Secretary, the Secretary may conduct a hearing to resolve an issue of fact material to a standard."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3c4b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe an effective date for a standard under this section. That date may not be earlier than the date the standard is prescribed nor later than 18 months after the date the standard is prescribed. However, the Secretary may prescribe a later date when the Secretary submits to Congress and publishes the reasons for the later date. A standard only applies to a passenger motor vehicle or passenger motor vehicle equipment manufactured on or after the effective date.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3c4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32502/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall conduct research necessary to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb7d3c4d-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1042"},"text":"108 Stat. 1042","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/g/tIII/s351/b/1"},"text":"Pub. L. 105–277, div. A, § 101(g) [title III, § 351(b)(1)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-439"},"text":"112 Stat. 2681–439","children":[],"tail":", 2681–476.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb7d3c4e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb7d3c4f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb7d3c50-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail"