{"tag":"section","attrib":{"id":"idcafee378-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123"},"text":null,"children":[{"tag":"num","attrib":{"value":"14123"},"text":"§ 14123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcafee379-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafee37a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require Class I and Class II motor carriers to file with the Secretary annual financial and safety reports, the form and substance of which shall be prescribed by the Secretary; except that, at a minimum, such reports shall include balance sheets and income statements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee37b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require motor carriers, freight forwarders, brokers, lessors, and associations, or classes of them as the Secretary may prescribe, to file quarterly, periodic, or special reports with the Secretary and to respond to surveys concerning their operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee37c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters To Be Covered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the matters to be covered by any reports to be filed under subsection (a), the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafee37d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee37e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the need to preserve confidential business information and trade secrets and prevent competitive harm;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee37f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private sector, academic, and public use of information in the reports; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee380-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee381-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafee382-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"From filing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may exempt upon good cause shown any party from the financial reporting requirements of subsection (a). Any request for such exemption must demonstrate, at a minimum, that an exemption is required to avoid competitive harm and preserve confidential business information that is not otherwise publicly available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee383-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"From public release.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcafee384-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall allow, upon request, a filer of a report under subsection (a) that is not a publicly held corporation or that is not subject to financial reporting requirements of the Securities and Exchange Commission, an exemption from the public release of such report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcafee385-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After a request under subparagraph (A) and notice and opportunity for comment but in no event later than 90 days after the date of such request, the Secretary shall approve such request if the Secretary finds that the exemption requested is necessary to avoid competitive harm and to avoid the disclosure of information that qualifies as a trade secret or privileged or confidential information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/4"},"text":"section 552(b)(4) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcafee386-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of data for internal dot purposes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an exemption is granted under this paragraph, nothing shall prevent the Secretary from using data from reports filed under this subsection for internal purposes of the Department of Transportation or including such data in aggregate industry statistics released for publication if such inclusion would not render the filer’s data readily identifiable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcafee387-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pending requests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not release publicly the report of a carrier making a request under subparagraph (A) while such request is pending.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee388-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of exemptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Exemptions granted under this subsection shall be for 3-year periods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee389-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14123/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Streamlining and Simplification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall streamline and simplify, to the maximum extent practicable, any reporting requirements the Secretary imposes under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcafee38a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/893"},"text":"109 Stat. 893","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/11"},"text":"Pub. L. 105–102, § 2(11)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2205"},"text":"111 Stat. 2205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcafee38b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcafee38c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcafee38d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:14123(c)(2)(B) to correct a grammatical error.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcafee38e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcafee38f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11145"},"text":"section 11145 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcafee390-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" inserted “in” before “no event”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcafee391-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcafee392-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
