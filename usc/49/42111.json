{"tag":"section","attrib":{"id":"idcbd2fc88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42111"},"text":null,"children":[{"tag":"num","attrib":{"value":"42111"},"text":"§ 42111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mutual aid agreements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An air carrier that will receive payments from another air carrier under an agreement between the air carriers for the time the one air carrier is not providing foreign air transportation, or is providing reduced levels of foreign air transportation, because of a labor strike must file a true copy of the agreement with the Secretary of Transportation and have it approved by the Secretary under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41309"},"text":"section 41309 of this title","children":[],"tail":". Notwithstanding section 41309, the Secretary shall approve the agreement only if it provides that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd2fc89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42111/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the air carrier will receive payments of not more than 60 percent of direct operating expenses, including interest expenses, but not depreciation or amortization expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd2fc8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42111/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefits may be paid for not more than 8 weeks, and may not be for losses incurred during the first 30 days of a strike; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd2fc8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42111/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on request of the striking employees, the dispute will be submitted to binding arbitration under the Railway Labor Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"45 U.S.C. 151","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd2fc8c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1160"},"text":"108 Stat. 1160","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd2fc8d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbd2fc8e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbd2fc8f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text"