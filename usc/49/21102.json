ildren":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21102(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:63a(d) (related to 45:64a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939"},"text":"Mar. 4, 1907, ch. 2939","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1415"},"text":"34 Stat. 1415","children":[],"tail":", § 3A(d) (related to § 5); added "},{"tag":"html:span","attrib":{},"text":"July 8, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/348/s4/d"},"text":"Pub. L. 94–348, § 4(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/819"},"text":"90 Stat. 819","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s16/4"},"text":"Pub. L. 100–342, § 16(4)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/635"},"text":"102 Stat. 635","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:64a(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939/s5/d"},"text":"Mar. 4, 1907, ch. 2939, § 5(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1417"},"text":"34 Stat. 1417","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Dec. 26, 1969","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/169/s1"},"text":"Pub. L. 91–169, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/83/464"},"text":"83 Stat. 464","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s16/6/D"},"text":"Pub. L. 100–342, § 16(6)(D)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/635"},"text":"102 Stat. 635","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21102(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:63a(d) (related to 45:64a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:64a(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939/s5/e"},"text":"Mar. 4, 1907, ch. 2939, § 5(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1417"},"text":"34 Stat. 1417","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Dec. 26, 1969","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/169/s1"},"text":"Pub. L. 91–169, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/83/464"},"text":"83 Stat. 464","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “with respect to one or more of its employees” are omitted as surplus because the authority to exempt a railroad carrier includes the authority to exempt only some of the employees of the carrier. The words “carrier to require or allow its employees to be on duty” are substituted for “any railroad described in this section to work its employees” for clarity and consistency in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb1b6c75-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb1b6c76-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Rail Safety Improvement Act of 2008, referred to in subsec. (c)(1)(B), (4)(C), (D), is div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4848"},"text":"122 Stat. 4848","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2008 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s20101"},"text":"section 20101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb1b6c77-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s108/d/1/A"},"text":"Pub. L. 110–432, § 108(d)(1)(A)","children":[],"tail":", substituted “Nonapplication, exemption, and alternate hours of service regime” for “Nonapplication and exemption” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s108/d/1/B"},"text":"Pub. L. 110–432, § 108(d)(1)(B)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
