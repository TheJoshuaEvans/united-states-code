{"tag":"section","attrib":{"id":"idcbfe044b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44707"},"text":null,"children":[{"tag":"num","attrib":{"value":"44707"},"text":"§ 44707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examining and rating air agencies","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Federal Aviation Administration may examine and rate the following air agencies:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbfe044c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44707/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" civilian schools giving instruction in flying or repairing, altering, and maintaining aircraft, aircraft engines, propellers, and appliances, on the adequacy of instruction, the suitability and airworthiness of equipment, and the competency of instructors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe044d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44707/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" repair stations and shops that repair, alter, and maintain aircraft, aircraft engines, propellers, and appliances, on the adequacy and suitability of the equipment, facilities, and materials for, and methods of, repair and overhaul, and the competency of the individuals doing the work or giving instruction in the work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe044e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44707/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other air agencies the Administrator decides are necessary in the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbfe044f-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1190"},"text":"108 Stat. 1190","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbfe0450-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbfe0451-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbfe0452-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44707","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1427 (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s607"},"text":"Pub. L. 85–726, § 607","children":[],"tail":" (1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/72/779"},"text":"72 Stat. 779","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s6/c/1"},"text":"Pub. L. 89–670, § 6(c)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/938"},"text":"80 Stat. 938","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/449/s7/b"},"text":"Pub. L. 97–449, § 7(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2444"},"text":"96 Stat. 2444","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the word “Administrator” in section 607 (1st sentence) of the Federal Aviation Act of 1958 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/779"},"text":"72 Stat. 779","children":[],"tail":") is retained on authority of 49:106(g). In clauses (1) and (2), the word “overhaul” is omitted as surplus. In clause (1), the words “course of” are omitted as surplus. In clause (3), the words “in his opinion” are omitted as surplus."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbfe0453-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbfe0454-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Aircraft Repair and Maintenance Advisory Panel","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tVII/s734"},"text":"Pub. L. 106–181, title VII, § 734","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/170"},"text":"114 Stat. 170","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/181/tVII/s734"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Panel","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator [of the Federal Aviation Administration]—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish an aircraft repair and maintenance advisory panel to review issues related to the use and oversight of aircraft and aviation component repair and maintenance facilities (in this section referred to as ‘aircraft repair facilities’) located within, or outside of, the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may seek the advice of the panel on any issue related to methods to increase safety by improving the oversight of aircraft repair facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The panel shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" nine members appointed by the Administrator as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" three representatives of labor organizations representing aviation mechanics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative of cargo air carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative of passenger air carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative of aircraft repair facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative of aircraft manufacturers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative of on-demand passenger air carriers and corporate aircraft operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"“(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative of regional passenger air carriers;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative from the Department of Commerce, designated by the Secretary of Commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative from the Department of State, designated by the Secretary of State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative from the Federal Aviation Administration, designated by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The panel shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine the amount and type of work that is being performed by aircraft repair facilities located within, and outside of, the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice and counsel to the Secretary [of Transportation] with respect to the aircraft and aviation component repair work performed by aircraft repair facilities and air carriers, staffing needs, and any balance of trade or safety issues associated with that work.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"DOT To Request Information From Air Carriers and Repair Facilities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection of information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, by regulation, shall require air carriers, foreign air carriers, domestic repair facilities, and foreign repair facilities to submit such information as the Secretary may require in order to assess balance of trade and safety issues with respect to work performed on aircraft used by air carriers, foreign air carriers, United States corporate operators, and foreign corporate operators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Drug and alcohol testing information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Included in the information the Secretary requires under paragraph (1) shall be information on the existence and administration of employee drug and alcohol testing programs in place at the foreign repair facilities, if applicable. The Secretary, if necessary, shall work with the International Civil Aviation Organization to increase the number and improve the administration of employee drug and alcohol testing programs at the foreign repair facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of work done","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Included in the information the Secretary requires under paragraph (1) shall be information on the amount and type of work performed on aircraft registered in and outside of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"DOT To Facilitate Collection of Information About Aircraft Maintenance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall facilitate the collection of information from the National Transportation Safety Board, the Federal Aviation Administration, and other appropriate agencies regarding maintenance performed by aircraft repair facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"DOT To Make Information Available to Public","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make any relevant information received under subsection (d) available to the public, consistent with the authority to withhold trade secrets or commercial, financial, and other proprietary information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The panel established under subsection (a) shall terminate on the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date that is 2 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":"]; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2001-12-31"},"text":"December 31, 2001","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"“(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The definitions contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102"},"text":"section 40102 of title 49","children":[],"tail":", United States Code, shall apply to this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
