xt":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939"},"text":"Mar. 4, 1907, ch. 2939","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1415"},"text":"34 Stat. 1415","children":[],"tail":", § 3A(a) (1st sentence), (b); added "},{"tag":"html:span","attrib":{},"text":"July 8, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/348/s4/d"},"text":"Pub. L. 94–348, § 4(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/819"},"text":"90 Stat. 819","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s16/4"},"text":"Pub. L. 100–342, § 16(4)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/635"},"text":"102 Stat. 635","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:63a(a) (2d–last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939"},"text":"Mar. 4, 1907, ch. 2939","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1415"},"text":"34 Stat. 1415","children":[],"tail":", § 3A(a) (2d–last sentences); added "},{"tag":"html:span","attrib":{},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/574/s4/a"},"text":"Pub. L. 95–574, § 4(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2459"},"text":"92 Stat. 2459","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21104(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:63a(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:63a(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939"},"text":"Mar. 4, 1907, ch. 2939","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1415"},"text":"34 Stat. 1415","children":[],"tail":"; § 3A(c); added "},{"tag":"html:span","attrib":{},"text":"July 8, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/348/s4/d"},"text":"Pub. L. 94–348, § 4(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/819"},"text":"90 Stat. 819","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/574/s4/b"},"text":"Pub. L. 95–574, § 4(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2460"},"text":"92 Stat. 2460","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21104(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:63a(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939"},"text":"Mar. 4, 1907, ch. 2939","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1415"},"text":"34 Stat. 1415","children":[],"tail":", § 3A(f); added "},{"tag":"html:span","attrib":{},"text":"July 8, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/348/s4/d"},"text":"Pub. L. 94–348, § 4(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/819"},"text":"90 Stat. 819","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “signal employee” are substituted for “an individual employed by the railroad who is engaged in installing, repairing or maintaining signal systems” and “an individual described in paragraph (1)” in 45:63a(a), “individual” in 45:63a(b) and (c), and “individual engaged in installing, repairing, or maintaining signal systems” in 45:63a(f) because of the definition of “signal employee” in section 21101 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(1) is substituted for 45:63a(a) (last sentence) for clarity and because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), before clause (A), the words “Except as provided in subsection (c) of this section” are added to alert the reader to the exception restated in subsection (c). The text of 45:63a(a) (2d sentence) is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words before paragraph (1) are added as related to 45:63a(c) and substituted for “In determining for the purposes of subsection (a) of this section the number of hours an individual is on duty” for clarity. In paragraph (2), the word “actually” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the word “actual” is omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb1ddcc5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb1ddcc6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s108/c/1"},"text":"Pub. L. 110–432, § 108(c)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a) which limited the amount of time spent on duty by signal employees."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s108/c/2"},"text":"Pub. L. 110–432, § 108(c)(2)","children":[],"tail":", substituted “duty.” for “duty, except that up to one hour of that time spent returning from the final trouble call of a period of continuous or broken service is time off duty.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s108/c/3"},"text":"Pub. L. 110–432, § 108(c)(3)","children":[],"tail":", inserted at end “A signal employee may not be allowed to remain or go on duty under the emergency authority provided under this subsection to conduct routine repairs, routine maintenance, or routine inspection of signal systems.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s108/c/4"},"text":"Pub. L. 110–432, § 108(c)(4)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb1ddcc7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb1ddcc8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":" effective 9 months after "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/s108/g"},"text":"section 108(g) of Pub. L. 110–432","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s21101"},"text":"section 21101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
