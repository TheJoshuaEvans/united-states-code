{"tag":"section","attrib":{"id":"idcafee368-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14122"},"text":null,"children":[{"tag":"num","attrib":{"value":"14122"},"text":"§ 14122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records: form; inspection; preservation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcafee369-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or the Board, as applicable, may prescribe the form of records required to be prepared or compiled under this subchapter by carriers and brokers, including records related to movement of traffic and receipts and expenditures of money.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee36a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Right of Inspection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or Board, or an employee designated by the Secretary or Board, may on demand and display of proper credentials, in person or in writing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafee36b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspect and examine the lands, buildings, and equipment of a carrier or broker; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee36c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" inspect and copy any record of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcafee36d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14122/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a carrier, broker, or association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcafee36e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14122/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person controlling, controlled by, or under common control with a carrier if the Secretary or Board, as applicable, considers inspection relevant to that person’s relation to, or transaction with, that carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee36f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period for Preservation of Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Board, as applicable, may prescribe the time period during which operating, accounting, and financial records must be preserved by carriers and brokers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcafee370-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/893"},"text":"109 Stat. 893","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32501/d"},"text":"Pub. L. 112–141, div. C, title II, § 32501(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/803"},"text":"126 Stat. 803","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcafee371-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcafee372-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcafee373-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11144"},"text":"section 11144 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcafee374-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" inserted “, in person or in writing” after “prope