{"tag":"section","attrib":{"id":"idcb29c3c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909"},"text":null,"children":[{"tag":"num","attrib":{"value":"22909"},"text":"§ 22909.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad Crossing Elimination Program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb29c3ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation, in cooperation with the Administrator of the Federal Railroad Administration, shall establish a competitive grant program (referred to in this section as the “Program”) under which the Secretary shall award grants to eligible recipients described in subsection (c) for highway-rail or pathway-rail grade crossing improvement projects that focus on improving the safety and mobility of people and goods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c3cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The goals of the Program are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb29c3cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to eliminate highway-rail grade crossings that are frequently blocked by trains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the health and safety of communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce the impacts that freight movement and railroad operations may have on underserved communities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve the mobility of people and goods.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c3d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Recipients","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following entities are eligible to receive a grant under this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb29c3d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State, including the District of Columbia, Puerto Rico, and other United States territories and possessions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A federally recognized Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A unit of local government or a group of local governments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A public port authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A metropolitan planning organization.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A group of entities described in any of paragraphs (1) through (6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c3d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Projects","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may award a grant under the Program for a highway-rail or pathway-rail grade crossing improvement project (including acquiring real property interests) involving—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb29c3d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grade separation or closure, including through the use of a bridge, embankment, tunnel, or combination thereof;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" track relocation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the improvement or installation of protective devices, signals, signs, or other measures to improve safety, provided that such activities are related to a separation or relocation project described in paragraph (1) or (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other means to improve the safety and mobility of people and goods at highway-rail grade crossings (including technological solutions);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a group of related projects described in paragraphs (1) through (4) that would collectively improve the mobility of people and goods; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planning, environmental review, and design of an eligible project described in paragraphs (1) through (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c3df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application Process.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb29c3e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An eligible entity seeking a grant under the Program shall submit an application to the Secretary at such time, in such manner, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Railroad approvals.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb29c3e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), the Secretary shall require applicants to obtain the necessary approvals from any impacted rail carriers or real property owners before proceeding with the construction of a project funded by a grant under the Program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement under subparagraph (A) shall not apply to planning projects described in subsection (d)(6) if the applicant agrees to work collaboratively with rail carriers and right-of-way owners.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c3e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Selection Criteria.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb29c3e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under the Program, the Secretary shall evaluate the extent to which proposed projects would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb29c3e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve safety at highway-rail or pathway-rail grade crossings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grade separate, eliminate, or close highway-rail or pathway-rail grade crossings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the mobility of people and goods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce emissions, protect the environment, and provide community benefits, including noise reduction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve access to emergency services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide economic benefits; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve access to communities separated by rail crossings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under the Program, the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb29c3ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the degree to which the proposed project will use—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb29c3ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb29c3f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative design and construction techniques; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb29c3f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construction materials that reduce greenhouse gas emissions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicant’s planned use of contracting incentives to employ local labor, to the extent permissible under Federal law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether the proposed project will improve the mobility of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb29c3f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multiple modes of transportation, including ingress and egress from freight facilities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb29c3f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" users of nonvehicular modes of transportation, such as pedestrians, bicyclists, and public transportation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether the proposed project is identified in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb29c3f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the freight investment plan component of a State freight plan, as required under section 70202(b)(9);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb29c3f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State rail plan prepared in accordance with chapter 227; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb29c3f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State highway-rail grade crossing action plan, as required under section 11401(b) of the Passenger Rail Reform and Investment Act of 2015 (title XI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Public Law 114–94","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the level of financial support provided by impacted rail carriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Award distribution","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting grants for Program funds in any fiscal year, the Secretary shall comply with the following limitations:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb29c3fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less than 20 percent of the grant funds available for the Program in any fiscal year shall be reserved for projects located in rural areas or on Tribal lands. The requirement under section 22907(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":"), which applies to this section, shall not apply to grant funds reserved specifically under this subparagraph. Not less than 5 percent of the grant funds reserved under this subparagraph shall be reserved for projects in counties with 20 or fewer residents per square mile, according to the most recent decennial census, provided that sufficient eligible applications have been submitted."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less than 25 percent of the grant funds set aside for planning projects in any fiscal year pursuant to section 22104(b) of the Passenger Rail Expansion and Rail Safety Act of 2021 shall be awarded for projects located in rural areas or on tribal lands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than 20 percent of the grant funds available for the Program in any fiscal year may be selected for projects in any single State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/f/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum size","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No grant awarded under this section shall be for less than $1,000,000, except for a planning grant described in subsection (d)(6).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c400-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2),","children":[{"tag":"ref","attrib":{"idref":"fn002085"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002085"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No par. (2) has been enacted."}],"tail":" the Federal share of the cost of a project carried out using a grant under the Program may not exceed 80 percent of the total cost of the project. Applicants may count costs incurred for preliminary engineering associated with highway-rail and pathway-rail grade crossing improvement projects as part of the total project costs."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c401-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Notification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 days before awarding a grant for a project under the Program, the Secretary shall submit written notification of the proposed grant to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives, which shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb29c402-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c403-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of the proposed grant award.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c404-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after each round of award notifications, the Secretary shall post, on the public website of the Department of Transportation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb29c405-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of all eligible applicants that submitted an application for funding under the Program during the current fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c406-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the grant recipients and projects that received grant funding under the Program during such fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c407-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the proposed projects and applicants that were determined to be ineligible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c408-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commuter Rail Eligibility and Grant Conditions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb29c409-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 22905(f) shall not apply to grants awarded under this section for commuter rail passenger transportation projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c40a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall transfer amounts awarded under this section for commuter rail passenger transportation projects to the Federal Transit Administration, which shall administer such funds in accordance with chapter 53.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c40b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protective arrangements.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb29c40c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/j/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraph (2) and section 22905(e)(1), as a condition of receiving a grant under this section, any employee covered by the Railway Labor Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"45 U.S.C. 151","children":[],"tail":" et seq.) and the Railroad Retirement Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s231"},"text":"45 U.S.C. 231","children":[],"tail":" et seq.) who is adversely affected by actions taken in connection with the project financed in whole or in part by such grant shall be covered by employee protective arrangements required to be established under section 22905(c)(2)(B)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c40d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/j/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant recipient under this section, and the successors, assigns, and contractors of such grant recipient—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb29c40e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/j/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be bound by the employee protective arrangements required under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb29c40f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/j/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be responsible for the implementation of such arrangements and for the obligations under such arrangements, but may arrange for another entity to take initial responsibility for compliance with the conditions of such arrangement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c410-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22909/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defined Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “rural area” means any area that is not within an area designated as an urbanized area by the Bureau of the Census.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb29c411-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22305/a"},"text":"Pub. L. 117–58, div. B, title II, § 22305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/720"},"text":"135 Stat. 720","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb29c412-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb29c413-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb29c414-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 11401(b) of the Passenger Rail Reform and Investment Act of 2015, referred to in subsec. (f)(2)(D)(iii), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11401/b"},"text":"section 11401(b) of title XI of div. A of Pub. L. 114–94","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s22907"},"text":"section 22907 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 22104(b) of the Passenger Rail Expansion and Rail Safety Act of 2021, referred to in subsec. (f)(3)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22104/b"},"text":"section 22104(b) of title II of div. B of Pub. L. 117–58","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/696"},"text":"135 Stat. 696","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Railway Labor Act, referred to in subsec. (j)(3)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347"},"text":"act May 20, 1926, ch. 347","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/577"},"text":"44 Stat. 577","children":[],"tail":", which is classified principally to chapter 8 (§ 151 et seq.) of Title 45, Railroads. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"section 151 of Title 45","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Railroad Retirement Act of 1974, referred to in subsec. (j)(3)(A), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-08-29/ch812"},"text":"act Aug. 29, 1935, ch. 812","children":[],"tail":", as amended generally by "},{"tag":"ref","attrib":{"href":"/us/pl/93/445/tI/s101"},"text":"Pub. L. 93–445, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-10-16"},"text":"Oct. 16, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1305"},"text":"88 Stat. 1305","children":[],"tail":", which is classified generally to subchapter IV (§ 231 et seq.) of chapter 9 of Title 45, Railroads. For further details and complete classification of this Act to the Code, see Codification note set out preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s231"},"text":"section 231 of Title 45","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s231t"},"text":"section 231t of Title 45","children":[],"tail":", and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
