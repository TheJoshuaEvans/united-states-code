{"tag":"section","attrib":{"id":"idcc5facc0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143"},"text":null,"children":[{"tag":"num","attrib":{"value":"47143"},"text":"§ 47143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Non-movement area surveillance surface display systems pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc5facc1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Federal Aviation Administration may carry out a pilot program to support non-Federal acquisition and installation of qualifying non-movement area surveillance surface display systems and sensors if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5facc2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator determines that such systems and sensors would improve safety or capacity in the National Airspace System; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5facc3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the non-movement area surveillance surface display systems and sensors supplement existing movement area systems and sensors at the selected airports established under other programs administered by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5facc4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5facc5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of carrying out the pilot program, the Administrator may make a project grant out of funds apportioned under paragraph (1) or paragraph (2) of section 47114(c) to not more than 5 eligible sponsors to acquire and install qualifying non-movement area surveillance surface display systems and sensors. The airports selected to participate in the pilot program shall have existing Administration movement area systems and airlines that are participants in Federal Aviation Administration’s airport collaborative decision-making process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5facc6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data exchange processes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As part of the pilot program carried out under this section, the Administrator may establish data exchange processes to allow airport participation in the Administration’s airport collaborative decision-making process and fusion of the non-movement surveillance data with the Administration’s movement area systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5facc7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall cease to be effective on ","children":[{"tag":"date","attrib":{"date":"2028-10-01"},"text":"October 1, 2028","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5facc8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5facc9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-movement area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “non-movement area” means the portion of the airfield surface that is not under the control of air traffic control.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5facca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-movement area surveillance surface display systems and sensors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “non-movement area surveillance surface display systems and sensors” means a non-Federal surveillance system that uses on-airport sensors that track vehicles or aircraft that are equipped with transponders in the non-movement area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5faccb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifying non-movement area surveillance surface display system and sensors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “qualifying non-movement area surveillance surface display system and sensors” means a non-movement area surveillance surface display system that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc5faccc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the required transmit and receive data formats consistent with the National Airspace System architecture at the appropriate service delivery point;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5faccd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is on-airport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5facce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47143/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is airport operated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc5faccf-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tI/s140/a"},"text":"Pub. L. 115–254, div. B, title I, § 140(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3210"},"text":"132 Stat. 3210","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/15/dB/tII/s2202/i"},"text":"Pub. L. 118–15, div. B, title II, § 2202(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/83"},"text":"137 Stat. 83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/34/tI/s102/i"},"text":"Pub. L. 118–34, title I, § 102(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-26"},"text":"Dec. 26, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1113"},"text":"137 Stat. 1113","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/41/tI/s102/i"},"text":"Pub. L. 118–41, title I, § 102(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-08"},"text":"Mar. 8, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/21"},"text":"138 Stat. 21","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s724"},"text":"Pub. L. 118–63, title VII, § 724","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1267"},"text":"138 Stat. 1267","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc5facd0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc5facd1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc5facd2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2028-10-01"},"text":"October 1, 2028","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2024-05-11"},"text":"May 11, 2024","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/41"},"text":"Pub. L. 118–41","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2024-05-11"},"text":"May 11, 2024","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"March 9, 2024","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2023—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/34"},"text":"Pub. L. 118–34","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2024-03-09"},"text":"March 9, 2024","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2024-01-01"},"text":"January 1, 2024","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/15"},"text":"Pub. L. 118–15","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"2024-01-01"},"text":"January 1, 2024","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"2023-10-01"},"text":"October 1, 2023","children":[],"tail":"”."}],"tail":"\n"}]