{"tag":"section","attrib":{"id":"idca7e1a8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116"},"text":null,"children":[{"tag":"num","attrib":{"value":"1116"},"text":"§ 1116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports, studies, and retrospective reviews","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca7e1a8f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Periodic Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Transportation Safety Board shall report periodically to Congress, departments, agencies, and instrumentalities of the United States Government and State and local governmental authorities concerned with transportation safety, and other interested persons. The report shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7e1a90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advocate meaningful responses to reduce the likelihood of transportation accidents similar to those investigated by the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1a91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" propose corrective action to make the transportation of individuals as safe and free from risk of injury as possible, including action to minimize personal injuries that occur in transportation accidents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7e1a92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Studies, Investigations, and Other Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board also shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7e1a93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out special studies and investigations about transportation safety, including avoiding personal injury;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1a94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine techniques and methods of accident investigation and periodically publish recommended procedures for accident investigations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1a95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" prescribe requirements for persons reporting accidents and aviation incidents that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7e1a96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be investigated by the Board under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7e1a97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involve public aircraft (except aircraft of the armed forces and the intelligence agencies);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1a98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate, examine the effectiveness of, and publish the findings of the Board about the transportation safety consciousness of other departments, agencies, and instrumentalities of the Government and their effectiveness in preventing accidents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1a99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate the adequacy of safeguards and procedures for the transportation of hazardous material and the performance of other departments, agencies, and instrumentalities of the Government responsible for the safe transportation of that material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7e1a9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Transportation Safety Board shall submit a report to Congress on July 1 of each year. The report shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7e1a9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statistical and analytical summary of the transportation accident investigations conducted and reviewed by the Board during the prior calendar year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1a9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a survey and summary of the recommendations made by the Board to reduce the likelihood of recurrence of those accidents together with the observed response to each recommendation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1a9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a list of each recommendation made by the Board to the Secretary of Transportation or the Commandant of the Coast Guard that was closed in an unacceptable status in the preceding 12 months, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7e1a9e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any explanation the Board received from the Secretary or Commandant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7e1a9f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any explanation from the Board as to why the recommendation was closed in an unacceptable status, including a discussion of why alternate means, if any, taken by the Secretary or Commandant to address the Board’s recommendation were inadequate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1aa0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed appraisal of the accident investigation and accident prevention activities of other departments, agencies, and instrumentalities of the United States Government and State and local governmental authorities having responsibility for those activities under a law of the United States or a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1aa1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the activities and operations of the National Transportation Safety Board Training Center during the prior calendar year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1aa2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of accidents, during the prior calendar year, that the Board was required to investigate under section 1131 but did not investigate and an explanation of why they were not investigated; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1aa3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of ongoing investigations that have exceeded the expected time allotted for completion by Board order and an explanation for the additional time required to complete each such investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7e1aa4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retrospective Reviews.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7e1aa5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), not later than ","children":[{"tag":"date","attrib":{"date":"2019-06-01"},"text":"June 1, 2019","children":[],"tail":", and at least every 5 years thereafter, the Chairman shall complete a retrospective review of recommendations issued by the Board that are classified as open by the Board."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1aa6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A review under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7e1aa7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a determination of whether the recommendation should be updated, closed, or reissued in light of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca7e1aa8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changed circumstances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca7e1aa9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more recently issued recommendations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca7e1aaa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of new technologies; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca7e1aab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" new information making the recommendation ineffective or insufficient for achieving its objective; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7e1aac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification for each determination under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1aad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date a review under paragraph (1) is complete, the Chairman shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7e1aae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings of the review under paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7e1aaf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each determination under paragraph (2)(A) and justification under paragraph (2)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7e1ab0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1116/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if applicable, a schedule for updating, closing, or reissuing a recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca7e1ab1-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/751"},"text":"108 Stat. 751","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dC"},"text":"Pub. L. 115–254, div. C","children":[],"tail":", §§ 1107(a), 1111(a), "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3432"},"text":"132 Stat. 3432","children":[],"tail":", 3436; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tXII/s1209"},"text":"Pub. L. 118–63, title XII, § 1209","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1425"},"text":"138 Stat. 1425","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca7e1ab2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca7e1ab3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca7e1ab4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],