{"tag":"section","attrib":{"id":"idcc884340-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103"},"text":null,"children":[{"tag":"num","attrib":{"value":"70103"},"text":"§ 70103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Multimodal Freight Network","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc884341-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary for Multimodal Freight (referred to in this section as the “Assistant Secretary”) shall establish a National Multimodal Freight Network in accordance with this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc884342-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist States in strategically directing resources toward improved system performance for the efficient movement of freight on the Network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884343-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to inform freight transportation planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884344-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist in the prioritization of Federal investment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884345-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assess and support Federal investments to achieve the national multimodal freight policy goals described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s70101/b"},"text":"section 70101(b) of this title","children":[],"tail":" and the national highway freight program goals described in "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s167"},"text":"section 167 of title 23","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc884346-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of National Multimodal Freight Network.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc884347-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary, after soliciting input from stakeholders, including multimodal freight system users, transportation providers, metropolitan planning organizations, local governments, ports, airports, railroads, and States, through a public process to identify critical freight facilities and corridors, including critical commerce corridors, that are vital to achieve the national multimodal freight policy goals described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s70101/b"},"text":"section 70101(b) of this title","children":[],"tail":" and the national highway freight program goals described in "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s167"},"text":"section 167 of title 23","children":[],"tail":", and after providing notice and an opportunity for comment on a draft system, shall designate a National Multimodal Freight Network with the goal of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc884348-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving network and intermodal connectivity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884349-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using measurable data as part of the assessment of the significance of freight movement, including the consideration of points of origin, destinations, and linking components of domestic and international supply chains.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88434a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In designating or redesignating the National Multimodal Freight Network, the Assistant Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc88434b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" origins and destinations of freight movement within, to, and from the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc88434c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" volume, value, tonnage, and the strategic importance of freight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc88434d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to border crossings, airports, seaports, and pipelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc88434e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic factors, including balance of trade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc88434f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to major areas for manufacturing, agriculture, or natural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884350-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access to energy exploration, development, installation, and production areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884351-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intermodal links and intersections that promote connectivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884352-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" freight choke points and other impediments contributing to significant measurable congestion, delay in freight movement, or inefficient modal connections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884353-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impacts on all freight transportation modes and modes that share significant freight infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884354-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilities and transportation corridors identified by a multi-State coalition, a State, a State freight advisory committee, or a metropolitan planning organization, using national or local data, as having critical freight importance to the region;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884355-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" major distribution centers, inland intermodal facilities, and first- and last-mile facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884356-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significance of goods movement, including consideration of global and domestic supply chains.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884357-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In designating or redesignating the National Multimodal Freight Network, the Assistant Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc884358-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use, to the extent practicable, measurable data to assess the significance of goods movement, including the consideration of points of origin, destinations, and linking components of the United States global and domestic supply chains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884359-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consider—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc88435a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the factors described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc88435b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any changes in the economy that affect freight transportation network demand; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc88435c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the States an opportunity to submit proposed designations from the States in accordance with paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88435d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State input.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc88435e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State that proposes additional designations for the National Multimodal Freight Network shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc88435f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider nominations for additional designations from metropolitan planning organizations and State freight advisory committees, as applicable, within the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc884360-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider nominations for additional designations from owners and operators of port, rail, pipeline, and airport facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc884361-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that additional designations are consistent with the State transportation improvement program or freight plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884362-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Critical rural freight facilities and corridors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As part of the designations under subparagraph (A), a State may designate a freight facility or corridor within the borders of the State as a critical rural freight facility or corridor if the facility or corridor—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc884363-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a rural principal arterial;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc884364-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides access or service to energy exploration, development, installation, or production areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc884365-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides access or service to—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcc884366-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/B/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a grain elevator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc884367-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/B/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an agricultural facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc884368-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/B/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mining facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc884369-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/B/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a forestry facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc88436a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/B/iii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intermodal facility;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc88436b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" connects to an international port of entry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc88436c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides access to a significant air, rail, water, or other freight facility in the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc88436d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has been determined by the State to be vital to improving the efficient movement of freight of importance to the economy of the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc88436e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idcc88436f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State may propose additional designations to the National Multimodal Freight Network in the State in an amount that is not more than 30 percent of the total mileage designated by the Under Secretary in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc884370-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination by under secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Under Secretary shall determine how to apply the limitation under clause (i) to the components of the National Multimodal Freight Network.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884371-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission and certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State shall submit to the Under Secretary—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc884372-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of any additional designations proposed to be added under this paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc884373-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a certification that—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcc884374-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State has satisfied the requirements of subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcc884375-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the designations referred to in clause (i) address the factors for designation described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884376-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/b/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Condition for acceptance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall accept from a State a designation under subparagraph (D) only if the Secretary determines that the designation meets the applicable requirements of subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc884377-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Redesignation of National Multimodal Freight Network","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 5 years after the initial designation under subsection (b), and every 5 years thereafter, the Assistant Secretary, using the designation factors described in subsection (b), shall redesignate the National Multimodal Freight Network.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc884378-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVIII/s8001/a"},"text":"Pub. L. 114–94, div. A, title VIII, § 8001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1607"},"text":"129 Stat. 1607","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI"},"text":"Pub. L. 117–58, div. B, title I","children":[],"tail":", §§ 21101(d)(3), 21103, "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/656"},"text":"135 Stat. 656","children":[],"tail":", 657.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc884379-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc88437a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcc88437b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 70103 was transferred and renumbered as ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50903"},"text":"section 50903 of Title 51","children":[],"tail":", National and Commercial Space Programs."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 70104 to 70121 were transferred and renumbered as sections 50904 to 50923 of Title 51, National and Commercial Space Programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc88437c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21101/d/3/A"},"text":"Pub. L. 117–58, § 21101(d)(3)(A)","children":[],"tail":", substituted “Assistant Secretary for Multimodal Freight (referred to in this section as the ‘Assistant Secretary’)” for “Under Secretary of Transportation for Policy” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21101/d/3/D/i"},"text":"Pub. L. 117–58, § 21101(d)(3)(D)(i)","children":[],"tail":", substituted “Designation of National Multimodal Freight Network” for “Final Network” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21101/d/3/B"},"text":"Pub. L. 117–58, § 21101(d)(3)(B)","children":[],"tail":", (C), redesignated subsec. (c) as (b) and struck out former subsec. (b) which required the establishment of an interim National Multimodal Freight Network no later than 180 days after "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21101/d/3/D/ii"},"text":"Pub. L. 117–58, § 21101(d)(3)(D)(ii)","children":[],"tail":", substituted “The Assistant Secretary” for “Not later than 1 year after the date of enactment of this section, the Under Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21101/d/3/D/iii"},"text":"Pub. L. 117–58, § 21101(d)(3)(D)(iii)","children":[],"tail":", (iv), substituted “Assistant Secretary” for “Under Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21103/1"},"text":"Pub. L. 117–58, § 21103(1)","children":[],"tail":", added subpar. (C) and struck out former subpar. (C) which read as follows: “provide the States with an opportunity to submit proposed designations in accordance with paragraph (4).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(C)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21103/2/A"},"text":"Pub. L. 117–58, § 21103(2)(A)","children":[],"tail":", substituted “30 percent” for “20 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21103/2/B"},"text":"Pub. L. 117–58, § 21103(2)(B)","children":[],"tail":", added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21101/d/3/C"},"text":"Pub. L. 117–58, § 21101(d)(3)(C)","children":[],"tail":", (E), redesignated subsec. (d) as (c), substituted “subsection (b)” for “subsection (c)” in two places, and substituted “Assistant Secretary” for “Under Secretary”. Former subsec. (c) redesignated (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc88437d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc88437e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
