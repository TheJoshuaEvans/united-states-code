{"tag":"section","attrib":{"id":"idcab4e2b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5318"},"text":null,"children":[{"tag":"num","attrib":{"value":"5318"},"text":"§ 5318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Bus testing facility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcab4e2b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Facility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall maintain one facility for testing a new bus model for maintainability, reliability, safety, performance (including braking performance), structural integrity, fuel economy, emissions, and noise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcab4e2b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation and Maintenance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall enter into a contract or cooperative agreement with, or make a grant to, a qualified person or organization to operate and maintain the facility. The contract, cooperative agreement, or grant may provide for the testing of rail cars and other public transportation vehicles at the facility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcab4e2b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5318/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The person operating and maintaining the facility shall establish and collect fees for the testing of vehicles at the facility. The Secretary must approve the fees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcab4e2b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5318/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Amounts To Pay for Testing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall enter into a contract or cooperative agreement with, or make a grant to, the operator of the facility under which the Secretary shall pay 80 percent of the cost of testing a vehicle at the facility from amounts available to carry out this section. The entity having the vehicle tested shall pay 20 percent of the cost.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcab4e2b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5318/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquiring New Bus Models.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcab4e2b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5318/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts appropriated or otherwise made available under this chapter may be obligated or expended to acquire a new bus model only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcab4e2b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5318/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bus of that model has been tested at a facility authorized under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcab4e2ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5318/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the bus tested under subparagraph (A) met—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcab4e2bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5318/e/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance standards for maintainability, reliability, performance (including braking performance), structural integrity, fuel economy, emissions, and noise, as established by the Secretary by rule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcab4e2bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5318/e/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the minimum safety performance standards established by the Secretary pursuant to section 5329(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcab4e2bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5318/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bus test “pass/fail” standard","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of enactment of the Federal Public Transportation Act of 2012, the Secretary shall issue a final rule under subparagraph (B)(i). The final rule issued under paragraph ","children":[{"tag":"ref","attrib":{"idref":"fn002035"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002035"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “subparagraph”."}],"tail":" (B)(i) shall include a bus model scoring system that results in a weighted, aggregate score that uses the testing categories under subsection (a) and considers the relative importance of each such testing category. The final rule issued under subparagraph (B)(i) shall establish a “pass/fail” standard that uses the aggregate score described in the preceding sentence. Amounts appropriated or otherwise made available under this chapter may be obligated or expended to acquire a new bus model only if the new bus model has received a passing aggregate test score. The Secretary shall work with the bus testing facility, bus manufacturers, and transit agencies to develop the bus model scoring system under this paragraph. A passing aggregate test score under the rule issued under subparagraph (B)(i) indicates only that amounts appropriated or made available under this chapter may be obligated or expended to acquire a new bus model and shall not be interpreted as a warranty or guarantee that the new bus model will meet a purchaser’s specific requirements."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcab4e2be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5318/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A facility operated and maintained under this section may use funds made available under this section for the acquisition of equipment and capital projects related to testing new bus models.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcab4e2bf-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/817"},"text":"108 Stat. 817","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/8"},"text":"Pub. L. 103–429, § 6(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4378"},"text":"108 Stat. 4378","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIII"},"text":"Pub. L. 105–178, title III","children":[],"tail":", §§ 3018, 3029(b)(8), "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/361"},"text":"112 Stat. 361","children":[],"tail":", 372; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIII"},"text":"Pub. L. 109–59, title III","children":[],"tail":", §§ 3002(b)(4), 3020, "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1545"},"text":"119 Stat. 1545","children":[],"tail":", 1608; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dB/s20014"},"text":"Pub. L. 112–141, div. B, § 20014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/694"},"text":"126 Stat. 694","children"