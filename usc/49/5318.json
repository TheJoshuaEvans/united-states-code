":[{"tag":"html:span","attrib":{},"text":"July 9, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/365"},"text":"Pub. L. 88–365","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/302"},"text":"78 Stat. 302","children":[],"tail":", § 3(m) (2d–last sentences); added "},{"tag":"html:span","attrib":{},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/240/s3009"},"text":"Pub. L. 102–240, § 3009","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/2093"},"text":"105 Stat. 2093","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5318(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1608 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/17/s317/b/5"},"text":"Pub. L. 100–17, § 317(b)(5)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/233"},"text":"101 Stat. 233","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/240/s6021/c"},"text":"Pub. L. 102–240, § 6021(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/2184"},"text":"105 Stat. 2184","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1608 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Apr. 2, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/17"},"text":"Pub. L. 100–17","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/132"},"text":"101 Stat. 132","children":[],"tail":", § 317(b)(6); added "},{"tag":"html:span","attrib":{},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/240/s6021/d"},"text":"Pub. L. 102–240, § 6021(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/2184"},"text":"105 Stat. 2184","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Under the contract entered into under paragraph (2)” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “to the operator of the facility” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the text of section 317(b)(5) of the Surface Transportation and Relocation Assistance Act of 1987 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/17"},"text":"Public Law 100–17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/132"},"text":"101 Stat. 132","children":[],"tail":") is omitted as obsolete. The words “operating and maintaining the facility” are substituted for “described in paragraph (3)” for clarity."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcab4e2c3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:5318(e) to correct an erroneous cross-reference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcab4e2c4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcab4e2c5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Federal Public Transportation Act of 2012, referred to in subsec. (e)(2), is deemed to be ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see section 3(a), (b) of "},{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", set out as Effective and Termination Dates of 2012 Amendment notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcab4e2c6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" added subsec. (e) and struck out former subsec. (e). Prior to amendment, text read as follows: “Amounts appropriated or made available under this chapter may be obligated or expended to acquire a new bus model only if a bus of that model has been tested at the facility maintained by the Secretary under subsection (a).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s3020/a"},"text":"Pub. L. 109–59, § 3020(a)","children":[],"tail":", amended heading and text of subsec. (a) generally. Prior to amendment, text read as follows: “The Secretary of Transportation shall establish one facility for testing a new bus model for maintainability, reliability, safety, performance (including braking performance), structural integrity, fuel economy, emissions, and noise. The facility shall be established by renovating a facility built with assistance of the United States Government to train rail personnel.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s3002/b/4"},"text":"Pub. L. 109–59, § 3002(b)(4)","children":[],"tail":", substituted “public transportation” for “mass transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s3020/b"},"text":"Pub. L. 109–59, § 3020(b)","children":[],"tail":", substituted “to carry out this section” for “under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5309/m/1/C"},"text":"section 5309(m)(1)(C) of this title","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s3020/c"},"text":"Pub. L. 109–59, § 3020(c)","children":[],"tail":", amended heading and text of subsec. (e) generally. Prior to amendment, text read as follows: “The Secretary has a bus testing revolving loan fund consisting of amounts authorized for the fund under section 317(b)(5) of the Surface Transportation and Uniform Relocation Assistance Act of 1987. The Secretary shall make available as repayable advances from the fund to the person operating and maintaining the facility amounts to operate and maintain the facility.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s3018/a"},"text":"Pub. L. 105–178, § 3018(a)","children":[],"tail":", substituted “enter into a contract or cooperative agreement with, or make a grant to,” for “make a contract with” and inserted “or organization” after “qualified person”, “, cooperative agreement, or grant” after “The contract”, and “mass transportation” after “and other”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":", §§ 3018(b), 3029(b)(8), substituted “enter into a contract or cooperative agreement with, or make a grant to,” for “make a contract with” and “5309(m)(1)(C) of this title” for “5338(j)(5) of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" inserted “Uniform” before “Relocation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcab4e2c7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcab4e2c8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","