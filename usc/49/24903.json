{"tag":"section","attrib":{"id":"idcb3a6585-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903"},"text":null,"children":[{"tag":"num","attrib":{"value":"24903"},"text":"§ 24903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb3a6586-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out this chapter and the Regional Rail Reorganization Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s701"},"text":"45 U.S.C. 701","children":[],"tail":" et seq.), Amtrak may—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3a6587-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, maintain, and dispose of any interest in property used to provide improved high-speed rail transportation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24902"},"text":"section 24902 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3a6588-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, by condemnation or otherwise, any interest in real property that Amtrak considers necessary to carry out the goals of section 24902;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3a6589-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for rail freight, intercity rail passenger, and commuter rail passenger transportation over property acquired under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3a658a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve rail rights of way between Boston, Massachusetts, and the District of Columbia (including the route through Springfield, Massachusetts, and routes to Harrisburg, Pennsylvania, and Albany, New York, from the Northeast Corridor main line) to achieve the goals of section 24902 of providing improved high-speed rail passenger transportation between Boston, Massachusetts, and the District of Columbia, and intermediate intercity markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3a658b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire, build, improve, and install passenger stations, communications and electric power facilities and equipment, public and private highway and pedestrian crossings, and other facilities and equipment necessary to provide improved high-speed rail passenger transportation over rights of way improved under clause (4) of this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3a658c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make agreements with other carriers and commuter authorities to grant, acquire, or make arrangements for rail freight or commuter rail passenger transportation over, rights of way and facilities acquired under the Regional Rail Reorganization Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s701"},"text":"45 U.S.C. 701","children":[],"tail":" et seq.), the Railroad Revitalization and Regulatory Reform Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s801"},"text":"45 U.S.C. 801","children":[],"tail":" et seq.), and chapter 224 of this title; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3a658d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint a general manager of the Northeast Corridor improvement program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3a658e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensatory Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Rail freight and commuter rail passenger transportation provided under subsection (a)(3) of this section shall be provided under compensatory agreements with the responsible carriers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3a658f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation for Transportation Over Certain Rights of Way and Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3a6590-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agreement under subsection (a)(6) of this section shall provide for reasonable reimbursement of costs but may not cross-subsidize intercity rail passenger, commuter rail passenger, and rail freight transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3a6591-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the parties do not agree, the Surface Transportation Board shall order that the transportation continue over facilities acquired under the Regional Rail Reorganization Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s701"},"text":"45 U.S.C. 701","children":[],"tail":" et seq.), the Railroad Revitalization and Regulatory Reform Act of 1976 ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s801"},"text":"45 U.S.C. 801","children":[],"tail":" et seq.), and chapter 224 of this title and shall determine compensation (without allowing cross-subsidization between commuter rail passenger and intercity rail passenger and rail freight transportation) for the transportation not later than 120 days after the dispute is submitted. The Board shall assign to a rail carrier obtaining transportation under this subsection the costs Amtrak incurs only for the benefit of the carrier, plus a proportionate share of all other costs of providing transportation under this paragraph incurred for the common benefit of Amtrak and the carrier. The proportionate share shall be based on relative measures of volume of car operations, tonnage, or other factors that reasonably reflect the relative use of rail property covered by this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3a6592-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24903/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not prevent the parties from making an agreement under subsection (a)(6) of this section after the Board makes a decision under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb3a6593-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/934"},"text":"108 Stat. 934","children":[],"tail":", § 24904; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/22"},"text":"Pub. L. 103–429, § 6(22)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4380"},"text":"108 Stat. 4380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/134/tIV/s405/b/2"},"text":"Pub. L. 105–134, title IV, § 405(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2586"},"text":"111 Stat. 2586","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tII/s212/b/2"},"text":"Pub. L. 110–432, div. B, title II, § 212(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4924"},"text":"122 Stat. 4924","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32932/c/4"},"text":"Pub. L. 112–141, div. C