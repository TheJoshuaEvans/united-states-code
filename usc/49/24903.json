text":"45:851(a)(8).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24904(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:851(a)(3) (proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24904(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:851(a)(6) (words after 8th comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24904(c)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:562(a)(2) (2d–5th sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24904(c)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:562(a)(2) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “the purposes of” are omitted as surplus. The words “this part” are substituted for “this subchapter, the Rail Passenger Service Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s501"},"text":"45 U.S.C. 501","children":[],"tail":" et seq.]” for clarity because subchapter III of chapter 17 of title 45, United States Code, and the Rail Passenger Service Act make up part C of subtitle V of the revised title. In clause (1), the words “by purchase, lease, exchange, gift, or otherwise, and to hold . . . sell, lease, or otherwise”, “real or personal”, and “which is necessary or” are omitted as surplus. The words “to provide” are substituted for “establishing and maintaining” for consistency in this chapter. In clause (2), the words “for the United States, by lease, purchase, condemnation, or otherwise” and “(including lands, easements, and rights-of-way, and any other property interests, including contract rights) are omitted as surplus. In clause (3), the words “the continuous operation and maintenance of” are omitted as surplus. In clause (4), the words “Washington” and “at its option” are omitted as surplus. In clause (5), the words “other safety facilities or equipment . . . any” and “which it determines are” are omitted as surplus. In clause (6), the words “Notwithstanding any other provision of this chapter”, “tracks, rights-of-way and other”, and “by the Corporation” in 45:562(a)(2) (1st sentence) and “other railroads” and “trackage rights, contract services, and other appropriate” in 45:851(a)(6) are omitted as surplus. In clause (7), the words “qualified individual to serve as the” are omitted as surplus. In clause (8), the words “on a basis which is consistent with, and” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “shall provide for” are substituted for “to be on such terms and conditions as are necessary to” to eliminate unnecessary words. The word “reasonable” is substituted for “on an equitable and fair basis” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “If the parties do not” are substituted for “In the event of a failure to” for clarity. The words “to be provided”, “consistent with equitable and fair compensation principles”, “proper amount of”, “the provision of”, and “the date of” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “either before or” are omitted as surplus because the National Railroad Passenger Corporation may make agreements on arrangements for rail freight or commuter rail transportation under subsection (a)(6) of this section and this subsection applies only when there is no agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb3a6597-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:24904(a)(2) to correct an error in the codification enacted by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1994-07-05/s1"},"text":"section 1 of the Act of July 5, 1994","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Public Law 103–272","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/934"},"text":"108 Stat. 934","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb3a6598-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb3a6599-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Regional Rail Reorganization Act of 1973, referred to in subsecs. (a) and (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/236"},"text":"Pub. L. 93–236","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-01-02"},"text":"Jan. 2, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/985"},"text":"87 Stat. 985","children":[],"tail":", which is classified principally to chapter 16 (§ 701 et seq.) of Title 45, Railroads. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s701"},"text":"section 701 of Title 45","children":[],"tail":" and Tables."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Railroad Revitalization and Regulatory Reform Act of 1976, referred to in subsecs. (a)(6) and (c)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/210"},"text":"Pub. L. 94–210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-02-05"},"text":"Feb. 5, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/31"},"text":"90 Stat. 31","children":[],"tail":". For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s801"},"text":"section 801 of Title 45","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb3a659a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":nul