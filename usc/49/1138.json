{"tag":"section","attrib":{"id":"idca82d5ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1138"},"text":null,"children":[{"tag":"num","attrib":{"value":"1138"},"text":"§ 1138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Evaluation and audit of National Transportation Safety Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca82d5af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1138/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To promote economy, efficiency, and effectiveness in the administration of the programs, operations, and activities of the National Transportation Safety Board, the Comptroller General of the United States shall evaluate and audit the programs and expenditures of the Board. Such evaluation and audit shall be conducted as determined necessary by the Comptroller General or the appropriate congressional committees.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca82d5b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1138/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibility of Comptroller General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General shall evaluate and audit Board programs, operations, and activities, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca82d5b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1138/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information management and security, including privacy protection of personally identifiable information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d5b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1138/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resource management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d5b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1138/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" workforce development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d5b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1138/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procurement and contracting planning, practices and policies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d5b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1138/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process and procedures to select an accident to investigate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d5b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1138/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the Board follows leading practices in selected management areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d5b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1138/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the Board addresses management challenges in completing accident investigations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca82d5b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1138/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Congressional Committees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section the term “appropriate congressional committees” means the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca82d5b9-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/443/s5/a"},"text":"Pub. L. 109–443, § 5(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-21"},"text":"Dec. 21, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3299"},"text":"120 Stat. 3299","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/188/tXV/s1502"},"text":"Pub. L. 113–188, title XV, § 1502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2025"},"text":"128 Stat. 2025","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dC/s1110"},"text":"Pub. L. 115–254, div. C, § 1110","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3435"},"text":"132 Stat. 3435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tXII/s1221/a"},"text":"Pub. L. 118–63, title XII, § 1221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1432"},"text":"138 Stat. 1432","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca82d5ba-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca82d5bb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca82d5bc-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" substituted “expenditures of the” for “expenditures of the National Transportation Safety”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(5) to (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1110/1"},"text":"Pub. L. 115–254, § 1110(1)","children":[],"tail":", added par. (5) and redesignated former pars. (5) and (6) as (6) and (7), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1110/2"},"text":"Pub. L. 115–254, § 1110(2)","children":[],"tail":", inserted comma after “Science”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/188"},"text":"Pub. L. 113–188","children":[],"tail":" struck out “at least annually, but may be conducted” after “Such evaluation and audit shall be conducted”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
