{"tag":"section","attrib":{"id":"idcb05e8ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14904"},"text":null,"children":[{"tag":"num","attrib":{"value":"14904"},"text":"§ 14904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Additional rate violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb05e8eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rebates by Agents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person, or an officer, employee, or agent of that person, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb05e8ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers, grants, gives, solicits, accepts, or receives a rebate for concession, in violation of a provision of this part related to motor carrier transportation subject to jurisdiction under subchapter I of chapter 135; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb05e8ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by any means assists or permits another person to get transportation that is subject to jurisdiction under that subchapter at less than the rate in effect for that transportation under section 13702,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is liable to the United States for a civil penalty of $200 for the first violation and $250 for a subsequent violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e8ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Undercharging.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb05e8ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Freight forwarder","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A freight forwarder providing service subject to jurisdiction under subchapter III of chapter 135, or an officer, agent, or employee of that freight forwarder, that assists a person in getting, or willingly permits a person to get, service provided under that subchapter at less than the rate in effect for that service under section 13702, is liable to the United States for a civil penalty of not more than $500 for the first violation and not more than $2,000 for a subsequent violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb05e8f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Others","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person that by any means gets, or attempts to get, service provided under subchapter III of chapter 135 at less than the rate in effect for that service under section 13702, is liable to the United States for a civil penalty of not more than $500 for the first violation and not more than $2,000 for a subsequent violation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb05e8f1-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/915"},"text":"109 Stat. 915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb05e8f2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb05e8f3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb05e8f4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11904"},"text":"section 11904 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb05e8f5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb05e8f6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
