{"tag":"section","attrib":{"id":"idca63dc3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118"},"text":null,"children":[{"tag":"num","attrib":{"value":"118"},"text":"§ 118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Office of Multimodal Freight Infrastructure and Policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca63dc40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca63dc41-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Department” means the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc42-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Freight office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Freight Office” means the Office of Multimodal Freight Infrastructure and Policy established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc43-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca63dc44-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish within the Department an Office of Multimodal Freight Infrastructure and Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca63dc45-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Freight Office shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca63dc46-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out the national multimodal freight policy described in section 70101;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc47-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to administer and oversee certain multimodal freight grant programs within the Department in accordance with subsection (d);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote and facilitate the sharing of information between the private and public sectors with respect to freight issues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct research on improving multimodal freight mobility, and to oversee the freight research activities of the various agencies within the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist cities and States in developing freight mobility and supply chain expertise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc4b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to liaise and coordinate with other Federal departments and agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out other duties, as prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca63dc4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration of Policies and Programs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Freight Office shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca63dc4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" develop and manage—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the national freight strategic plan described in section 70102; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Multimodal Freight Network established under section 70103;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc52-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee the development and updating of the State freight plans described in section 70202; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc53-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide guidance or best practices relating to the development and updating of State freight plans under that section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc54-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc55-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administer multimodal freight grant programs, including multimodal freight grants established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s117"},"text":"section 117 of title 23","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc56-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures for analyzing and evaluating applications for grants under those programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc57-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assist States in the establishment of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc58-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State freight advisory committees under section 70201; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc59-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" multi-State freight mobility compacts under section 70204; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc5a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide to the Bureau of Transportation Statistics input regarding freight data and planning tools.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca63dc5b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistant Secretary.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca63dc5c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Freight Office shall be headed by an Assistant Secretary for Multimodal Freight, who shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc5d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be appointed by the President, by and with the advice and consent of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have professional standing and demonstrated knowledge in the field of freight transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc5f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc60-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to the Under Secretary of Transportation for Policy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc61-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for the management and oversight of the activities, decisions, operations, and personnel of the Freight Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc62-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work with the modal administrations of the Department to encourage multimodal collaboration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc63-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such additional duties as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca63dc64-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consolidation and Elimination of Duplicative Offices.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca63dc65-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consolidation of offices and office functions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may consolidate into the Freight Office any office or office function within the Department that the Secretary determines has duties, responsibilities, resources, or expertise that support the purposes of the Freight Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc66-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elimination of offices","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may eliminate any office within the Department if the Secretary determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc67-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purposes of the office are duplicative of the purposes of the Freight Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the office or the functions of the office have been substantially consolidated with the Freight Office pursuant to paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elimination of the office will not adversely affect the requirements of the Secretary under any Federal law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the elimination of the office will improve the efficiency and effectiveness of the programs and functions conducted by the office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca63dc6b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staffing and Budgetary Resources.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca63dc6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that the Freight Office is adequately staffed and funded.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staffing.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of positions to freight office","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subparagraph (B), the Secretary may transfer to the Freight Office any position within any other office of the Department if the Secretary determines that the position is necessary to carry out the purposes of the Freight Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary transfers a position to the Freight Office pursuant to subparagraph (A), the Secretary, in coordination with the appropriate modal administration of the Department, shall ensure that the transfer of the position does not adversely affect the requirements of the modal administration under any Federal law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budgetary resources.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc71-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of funds from consolidated or eliminated offices.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idca63dc72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/g/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To carry out the purposes of the Freight Office, the Secretary may transfer to the Freight Office from any office or office function that is consolidated or eliminated under subsection (f) any funds allocated for the consolidated or eliminated office or office function.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca63dc73-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/g/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retransfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any portion of any funds or limitations of obligations transferred to the Freight Office pursuant to clause (i) may be transferred back to, and merged with, the original account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of funds allocated for administrative costs.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idca63dc75-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/g/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may transfer to the Freight Office any funds allocated for the administrative costs of the programs referred to in subsection (d)(3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca63dc76-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/g/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retransfer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any portion of any funds or limitations of obligations transferred to the Freight Office pursuant to clause (i) may be transferred back to, and merged with, the original account.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca63dc77-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Website.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca63dc78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of freight office","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall make publicly available on the website of the Department a description of the Freight Office, including a description of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs managed or made available by the Freight Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibility requirements for those programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clearinghouse","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may establish a clearinghouse for tools, templates, guidance, and best practices on a page of the website of the Department that supports the purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca63dc7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, and not less frequently than once every 180 days thereafter until the date on which the Secretary determines that the requirements of this section have been met, the Secretary shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a notification that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca63dc7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the programs and activities administered or overseen by the Freight Office; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc7f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of those programs and activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc80-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc81-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of employees working in the Freight Office as of the date of the notification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of employees expected to join the Freight Office to support the programs and activities described in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of positions that, as a result of the consolidation of offices under this section, were—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca63dc84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" eliminated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca63dc85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transferred, assigned, or joined to the Freight Office;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicates whether the Secretary has consolidated into the Freight Office any office or office function pursuant to subsection (f)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary has consolidated such an office or function, describes the rationale for the consolidation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicates whether the Secretary has eliminated any office pursuant to subsection (f)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Secretary has eliminated such an office, describes the rationale for the elimination;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes any other actions carried out by the Secretary to implement this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/i/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes any recommendations of the Secretary for legislation that may be needed to further implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca63dc8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Provisions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca63dc8f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on other law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this section, nothing in this section alters or affects any law (including regulations) with respect to a program referred to in subsection (d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on responsibilities of other agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided in this section, nothing in this section abrogates the responsibilities of any agency, operating administration, or office within the Department that is otherwise charged by law (including regulations) with any aspect of program administration, oversight, or project approval or implementation with respect to a program or project subject to the responsibilities of the Freight Office under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on pending applications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section affects any pending application under a program referred to in subsection (d) that was received by the Secretary on or before the date of enactment of the Surface Transportation Investment Act of 2021.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca63dc92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca63dc93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated to the Secretary such sums as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s118/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Authorizations under subsections (f) and (g) are subject to appropriations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca63dc95-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI/s21101/a"},"text":"Pub. L. 117–58, div. B, title I, § 21101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/652"},"text":"135 Stat. 652","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca63dc96-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca63dc97-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca63dc98-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section and the date of enactment of the Surface Transportation Investment Act of 2021, referred to in subsecs. (i) and (j)(3), are the date of enactment of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
