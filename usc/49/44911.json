{"tag":"section","attrib":{"id":"idcc26742d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911"},"text":null,"children":[{"tag":"num","attrib":{"value":"44911"},"text":"§ 44911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intelligence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc26742e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, “intelligence community” means the intelligence and intelligence-related activities of the following units of the United States Government:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc26742f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc267430-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc267431-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of the Treasury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc267432-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Energy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc267433-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Departments of the Army, Navy, and Air Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc267434-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Central Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc267435-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Security Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc267436-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Defense Intelligence Agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc267437-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Bureau of Investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc267438-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Drug Enforcement Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc267439-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policies and Procedures on Report Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each unit in the intelligence community shall prescribe policies and procedures to ensure that intelligence reports about terrorism are made available, as appropriate, to the heads of other units in the intelligence community, the Secretary of Transportation, and the Administrator of the Transportation Security Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc26743a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unit for Strategic Planning on Terrorism","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The heads of the units in the intelligence community shall place greater emphasis on strategic intelligence efforts by establishing a unit for strategic planning on terrorism.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc26743b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Intelligence Officer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the request of the Secretary of Homeland Security, the Director of Central Intelligence shall designate at least one intelligence officer of the Central Intelligence Agency to serve in a senior position in the Office of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc26743c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44911/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Working Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The heads of units in the intelligence community, the Secretary of Homeland Security, and the Administrator of the Transportation Security Administration shall review and, as appropriate, revise written working agreements between the intelligence community and the Administrator of the Transportation Security Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc26743d-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1212"},"text":"108 Stat. 1212","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI"},"text":"Pub. L. 107–71, title I","children":[],"tail":", §§ 101(f)(7), (9), 102(b), (c), "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/603"},"text":"115 Stat. 603","children":[],"tail":", 605; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/d/9"},"text":"Pub. L. 115–254, div. K, title I, § 1991(d)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3633"},"text":"132 Stat. 3633","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc26743e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc26743f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc267440-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44911(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358d (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/604/s111/e"},"text":"Pub. L. 101–604, § 111(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3080"},"text":"104 Stat. 3080","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44911(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358d (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/604/s111/a"},"text":"Pub. L. 101–604, § 111(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3080"},"text":"104 Stat. 3080","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44911(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358d (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/604/s111/b"},"text":"Pub. L. 101–604, § 111(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3080"},"text":"104 Stat. 3080","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44911(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358d (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/604/s111/c"},"text":"Pub. L. 101–604, § 111(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3080"},"text":"104 Stat. 3080","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44911(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358d (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/604/s111/d"},"text":"Pub. L. 101–604, § 111(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3080"},"text":"104 Stat. 3080","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the word “units” is substituted for “agencies” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (e), the words “Not later than 180 days after the date of enactment of this Act” in section 111(a) and (d) of the Aviation Security Improvement Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/640"},"text":"Public Law 101–640","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3080"},"text":"104 Stat. 3080","children":[],"tail":") are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “the heads of other units in the intelligence community, the Secretary of Transportation, and the Administrator of the Federal Aviation Administration” are substituted for “other members of the intelligence community, the Department of Transportation, and the Federal Aviation Administration” for clarity and consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (c) and (e), the words “heads of units in the intelligence community” are substituted for “intelligence community” for clarity and consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “memorandums of understanding” are omitted as being included in “written working agreements”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc267441-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc267442-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/9/A"},"text":"Pub. L. 115–254, § 1991(d)(9)(A)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration” for “Under Secretary of Transportation for Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/9/B"},"text":"Pub. L. 115–254, § 1991(d)(9)(B)","children":[],"tail":", substituted “request of the Secretary of Homeland Security” for “request of the Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/9/C"},"text":"Pub. L. 115–254, § 1991(d)(9)(C)","children":[],"tail":", substituted “Secretary of Homeland Security, and the Administrator of the Transportation Security Administration” for “Secretary, and the Under Secretary” and “intelligence community and the Administrator of the Transportation Security Administration” for “intelligence community and the Under Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s102/b"},"text":"Pub. L. 107–71, § 102(b)","children":[],"tail":", struck out “international” before “terrorism”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s101/f/7"},"text":"Pub. L. 107–71, § 101(f)(7)","children":[],"tail":", (9), substituted “Under Secretary of Transportation for Security” for “Administrator of the Federal Aviation Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s102/c"},"text":"Pub. L. 107–71, § 102(c)","children":[],"tail":", substituted “place” for “consider placing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s101/f/7"},"text":"Pub. L. 107–71, § 101(f)(7)","children":[],"tail":", substituted “Under Secretary” for “Administrator” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc267443-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcc267444-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the intelligence community deemed to be a reference to the Director of National Intelligence. Reference to the Director of Central Intelligence or the Director of the Central Intelligence Agency in the Director’s capacity as the head of the Central Intelligence Agency deemed to be a reference to the Director of the Central Intelligence Agency. See section 1081(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458"},"text":"Pub. L. 108–458","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t50/s3001"},"text":"section 3001 of Title 50","children":[],"tail":", War and National Defense."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
