{"tag":"section","attrib":{"id":"idcbc7160c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41727"},"text":null,"children":[{"tag":"num","attrib":{"value":"41727"},"text":"§ 41727.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Passenger Rights ","children":[{"tag":"ref","attrib":{"idref":"fn002144"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002144"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"idcbc7160d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41727/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall require each covered air carrier to submit a summarized 1-page document that describes the rights of passengers in air transportation, including guidelines for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc7160e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41727/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation (regarding rebooking options, refunds, meals, and lodging) for flight delays of various lengths.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc7160f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41727/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation (regarding rebooking options, refunds, meals, and lodging) for flight diversions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc71610-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41727/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation (regarding rebooking options, refunds, meals, and lodging) for flight cancellations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc71611-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41727/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Compensation for mishandled baggage, including delayed, damaged, pilfered, or lost baggage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc71612-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41727/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Voluntary relinquishment of a ticketed seat due to overbooking or priority of other passengers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc71613-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41727/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Involuntary denial of boarding and forced removal for whatever reason, including for safety and security reasons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc71614-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41727/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing of Summarized Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after each air carrier submits its guidelines to the Secretary under subsection (a), the air carrier shall make available such 1-page document in a prominent location on its website.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbc71615-47c4-11f1-9671-b5c725212f70"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tV/s510/a"},"text":"Pub. L. 118–63, title V, § 510(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1193"},"text":"138 Stat. 1193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbc71616-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbc71617-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcbc71618-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section, as added and amended by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s510/a"},"text":"section 510(a) of Pub. L. 118–63","children":[],"tail":", is based on "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIV/s429"},"text":"Pub. L. 115–254, div. B, title IV, § 429","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3341"},"text":"132 Stat. 3341","children":[],"tail":", which was formerly set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s42301"},"text":"section 42301 of this title","children":[],"tail":" before being transferred to this chapter and renumbered as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbc71619-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s510/a/1"},"text":"Pub. L. 118–63, § 510(a)(1)","children":[],"tail":", transferred "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s429"},"text":"section 429 of Pub. L. 115–254","children":[],"tail":" to this chapter, renumbered it as this section, and amended style of section catchline. See Codification note above."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s510/a/2"},"text":"Pub. L. 118–63, § 510(a)(2)","children":[],"tail":", substituted “The Secretary” for “Not later than 90 days after the date of enactment of this Act, the Secretary” in introductory provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
