{"tag":"section","attrib":{"id":"idcb05e94a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14914"},"text":null,"children":[{"tag":"num","attrib":{"value":"14914"},"text":"§ 14914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb05e94b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14914/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After notice and an opportunity for a hearing, a person found by the Surface Transportation Board to have violated a provision of law that the Board carries out or a regulation prescribed under that law by the Board that is related to transportation which occurs under subchapter II of chapter 135 for which a civil penalty is provided, is liable to the United States for the civil penalty provided. The amount of the civil penalty shall be assessed by the Board by written notice. In determining the amount of the penalty, the Board shall consider the nature, circumstances, extent, and gravity of the prohibited acts committed and, with respect to the violator, the degree of culpability, any history of prior offenses, ability to pay, and other matters that justice requires.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e94c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14914/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compromise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may compromise, modify, or remit, with or without consideration, a civil penalty until the assessment is referred to the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e94d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14914/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a person fails to pay an assessment of a civil penalty after it has become final, the Board may refer the matter to the Attorney General for collection in an appropriate district court of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e94e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14914/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Refunds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may refund or remit a civil penalty collected under this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb05e94f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14914/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" application has been made for refund or remission of the penalty within 1 year from the date of payment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb05e950-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14914/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board finds that the penalty was unlawfully, improperly, or excessively imposed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb05e951-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/918"},"text":"109 Stat. 918","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb05e952-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb05e953-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb05e954-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
