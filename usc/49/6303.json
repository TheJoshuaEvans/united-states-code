{"tag":"section","attrib":{"id":"idcad64d68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6303"},"text":null,"children":[{"tag":"num","attrib":{"value":"6303"},"text":"§ 6303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Intermodal transportation database","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad64d69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In consultation with the Under Secretary Transportation for Policy, the Assistant Secretaries of the Department, and the heads of the operating administrations of the Department, the Director shall establish and maintain a transportation database for all modes of transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad64d6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The database established under this section shall be suitable for analyses carried out by the Federal Government, the States, and metropolitan planning organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad64d6b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The database established under this section shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad64d6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the volumes and patterns of movement of goods, including local, interregional, and international movement, by all modes of transportation, intermodal combinations, and relevant classification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the volumes and patterns of movement of people, including local, interregional, and international movements, by all modes of transportation (including bicycle and pedestrian modes), intermodal combinations, and relevant classification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6303/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the location and connectivity of transportation facilities and services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6303/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national accounting of expenditures and capital stocks on each mode of transportation and intermodal combination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad64d70-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tII/s52011/a"},"text":"Pub. L. 112–141, div. E, title II, § 52011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/890"},"text":"126 Stat. 890","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad64d71-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcad64d72-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcad64d73-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
