{"tag":"section","attrib":{"id":"idcbce4121-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41742"},"text":null,"children":[{"tag":"num","attrib":{"value":"41742"},"text":"§ 41742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Essential air service authorization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbce4122-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41742/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbce4123-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41742/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Out of the amounts received by the Federal Aviation Administration credited to the account established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s45303"},"text":"section 45303 of this title","children":[],"tail":" or otherwise provided to the Administration, the sum of $50,000,000 for each fiscal year is authorized and shall be made available immediately for obligation and expenditure to carry out the essential air service program under this subchapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4124-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41742/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to amounts authorized under paragraph (1), there is authorized to be appropriated out of the Airport and Airway Trust Fund (established under section 9502 of the Internal Revenue Code of 1986) $348,544,000 for fiscal year 2024, $340,000,000 for fiscal year 2025, $342,000,000 for fiscal year 2026, $342,000,000 for fiscal year 2027, and $350,000,000 for fiscal year 2028 to carry out the essential air service program under this subchapter of which not more than $12,000,000 per fiscal year may be used for the marketing incentive program for communities and for State marketing assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4125-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41742/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization for additional employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to amounts authorized under paragraphs (1) and (2), there are authorized to be appropriated such sums as may be necessary for the Secretary of Transportation to hire and employ 4 additional employees for the office responsible for carrying out the essential air service program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbce4126-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41742/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Additional Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, in any fiscal year in which funds credited to the account established under section 45303, including the funds derived from fees imposed under the authority contained in section 45301(a), exceed the $50,000,000 made available under subsection (a)(1), such funds shall be made available immediately for obligation and expenditure to carry out the essential air service program under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbce4127-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41742/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The funds made available under this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbce4128-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1152"},"text":"108 Stat. 1152","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/tII/s278/c"},"text":"Pub. L. 104–264, title II, § 278(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3249"},"text":"110 Stat. 3249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tII/s209/a"},"text":"Pub. L. 106–181, title II, § 209(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/95"},"text":"114 Stat. 95","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tIV/s404"},"text":"Pub. L. 108–176, title IV, § 404","children":[],"tail":", "}