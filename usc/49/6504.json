{"tag":"section","attrib":{"id":"idcad8bec9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504"},"text":null,"children":[{"tag":"num","attrib":{"value":"6504"},"text":"§ 6504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Incorporation of Department of Transportation research","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad8beca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":", and not less frequently than once every 5 years thereafter, in concurrence with the applicable strategic plan under section 6503, the Secretary of Transportation shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8becb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a review of research conducted by the Department of Transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8becc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable and appropriate, identify modifications to laws, regulations, guidance, and other policy documents to incorporate any innovations resulting from the research described in paragraph (1) that have the potential to improve the safety or efficiency of the United States transportation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8becd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting a review under subsection (a), the Secretary of Transportation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8bece-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify any innovative practices, materials, or technologies that have demonstrable benefits to the transportation system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8becf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine whether the practices, materials, or technologies described in paragraph (1) require any statutory or regulatory modifications for adoption; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bed0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8bed1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if modifications are determined to be required under paragraph (2), develop—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcad8bed2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a proposal for those modifications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8bed3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the manner in which any such regulatory modifications would be—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcad8bed4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/b/3/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporated into the Unified Regulatory Agenda; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcad8bed5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/b/3/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adopted into existing regulations as soon as practicable; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8bed6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if modifications are determined not to be required under paragraph (2), develop a description of the means by which the practices, materials, or technologies described in paragraph (1) will otherwise be incorporated into Department of Transportation or modal administration policy or guidance, including as part of the Technology Transfer Program of the Office of the Assistant Secretary for Research and Technology.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8bed7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On completion of each review under subsection (a), the Secretary of Transportation shall submit to the appropriate committees of Congress a report describing, with respect to the period covered by the report—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8bed8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each new practice, material, or technology identified under subsection (b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bed9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any statutory or regulatory modification for the adoption of such a practice, material, or technology that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8beda-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is determined to be required under subsection (b)(2); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8bedb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6504/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was otherwise made during that period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad8bedc-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tV/s25016/a"},"text":"Pub. L. 117–58, div. B, title V, § 25016(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/872"},"text":"135 Stat. 872","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
