{"tag":"section","attrib":{"id":"idcb0f851b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20114"},"text":null,"children":[{"tag":"num","attrib":{"value":"20114"},"text":"§ 20114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial procedures","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb0f851c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Contempt","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a trial for criminal contempt for violating an injunction or restraining order issued under this chapter, the violation of which is also a violation of this chapter, the defendant may demand a jury trial. The defendant shall be tried as provided in rule 42(b) of the Federal Rules of Criminal Procedure (18 App. U.S.C.).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0f851d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subpenas For Witnesses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A subpena for a witness required to attend a district court of the United States in an action brought under this chapter may be served in any judicial district.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0f851e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Agency Action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20104/c"},"text":"section 20104(c) of this title","children":[],"tail":", a proceeding to review a final action of the Secretary of Transportation under this part or, as applicable to railroad safety, chapter 51 or 57 of this title shall be brought in the appropriate court of appeals as provided in chapter 158 of title 28."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0f851f-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/870"},"text":"108 Stat. 870","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb0f8520-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb0f8521-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb0f8522-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20114(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:439(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458"},"text":"Pub. L. 91–458","children":[],"tail":", §§ 209(d), 210(b), "},{"tag":"html:a","attrib":{"href":"/us/stat/84/975"},"text":"84 Stat. 975","children":[],"tail":", 976."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20114(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:438(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20114(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:431(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458/s202/f"},"text":"Pub. L. 91–458, § 202(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/972"},"text":"84 Stat. 972","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Sept. 3, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/365/s5/a/1"},"text":"Pub. L. 102–365, § 5(a)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/975"},"text":"106 Stat. 975","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “the defendant may demand a jury trial” are substituted for “trial shall be by the court, or, upon demand of the accused, by a jury” to eliminate unnecessary words and for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “may be served in any judicial district” are substituted for “may run into any other district” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “a final action of the Secretary” are substituted for “Any final agency action taken by the Secretary” to eliminate unnecessary words. The words “this part or, as applicable to railroad safety, chapter 51 or 57 of this title” are substituted for “this subchapter or under any of the other Federal railroad safety laws, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s441/e"},"text":"section 441(e) of this title","children":[],"tail":"” because of the restatement. The words “is subject to judicial review as provided in chapter 7 of title 5” are omitted as unnecessary because 5:ch. 7 applies unless otherwise stated. The words “by and in the manner prescribed” are omitted as surplus."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
