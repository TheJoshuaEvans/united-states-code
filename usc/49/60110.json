{"tag":"section","attrib":{"id":"idcc7c5c2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110"},"text":null,"children":[{"tag":"num","attrib":{"value":"60110"},"text":"§ 60110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Excess flow valves","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc7c5c2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies only to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc7c5c2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a natural gas distribution system installed after the effective date of regulations prescribed under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other natural gas distribution system when repair to the system requires replacing a part to accommodate installing excess flow valves.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Installation Requirements and Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1994-04-24"},"text":"April 24, 1994","children":[],"tail":", the Secretary of Transportation shall prescribe standards on the circumstances, if any, under which an operator of a natural gas distribution system must install excess flow valves in the system. The Secretary shall consider—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc7c5c32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the system design pressure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the system operating pressure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the types of customers to which the distribution system supplies gas, including hospitals, schools, and commercial enterprises;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the technical feasibility and cost of installing, operating, and maintaining the valve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public safety benefits of installing the valve;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of customer meters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors the Secretary considers relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Availability","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc7c5c3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than ","children":[{"tag":"date","attrib":{"date":"1994-10-24"},"text":"October 24, 1994","children":[],"tail":", the Secretary shall prescribe standards requiring an operator of a natural gas distribution system to notify in writing its customers having lines in which excess flow valves are not required by law but can be installed according to the standards prescribed under subsection (e) of this section, of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc7c5c3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the availability of excess flow valves for installation in the system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc7c5c3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety benefits to be derived from installation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc7c5c3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs associated with installation, maintenance, and replacement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The standards shall provide that, except when installation is required under subsection (b) of this section, excess flow valves shall be installed at the request of the customer if the customer will pay all costs associated with installation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary decides under subsection (b) of this section that there are no circumstances under which an operator must install excess flow valves, the Secretary shall submit to Congress a report on the reasons for the decision not later than 30 days after the decision is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60110/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1994-04-24"},"text":"April 24, 1994","children":[],"tail":", the Secretary shall develop standards for the performance of excess flow valves used to protect lines in a natural gas distribution system. The Secretary may adopt industry accepted performance standards in order to comply with the requirement under the preceding sentence. The standards shall be incorporated into regulations the Secretary prescribes under this section. All excess flow valves shall be installed according to the standards."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc7c5c41-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1316"},"text":"108 Stat. 1316","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/304"},"text":"Pub. L. 104–304","children":[],"tail":", §§ 8, 20(j), "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3800"},"text":"110 Stat. 3800","children":[],"tail":", 3805; "},{"tag":"ref","attrib":{"href":"/us/pl/107/355/s21/1"},"text":"Pub. L. 107–355, § 21(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3010"},"text":"116 Stat. 3010","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc7c5c42-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc7c5c43-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc7c5c44-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60110(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1672(j)(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/481"},"text":"Pub. L. 90–481","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/720"},"text":"82 Stat. 720","children":[],"tail":", § 3(j); added "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/508/s104"},"text":"Pub. L. 102–508, § 104","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/3291"},"text":"106 Stat. 3291","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60110(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1672(j)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60110(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1672(j)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60110(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1672(j)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60110(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1672(j)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “in a manner” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “on when” are substituted for “prescribing the circumstances, if any, under which” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc7c5c45-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc7c5c46-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355"},"text":"Pub. L. 107–355","children":[],"tail":" substituted “circumstances, if any, under which an operator” for “circumstances under which an operator” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s20/j"},"text":"Pub. L. 104–304, § 20(j)","children":[],"tail":", substituted “standards” for “regulations” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s8/1"},"text":"Pub. L. 104–304, § 8(1)","children":[],"tail":", which directed the insertion of “, if any,” after “circumstances” in the first sentence of subsection (b)(1), could not be executed because the word “circumstances” did not appear in subsec. (b)(1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s8/2"},"text":"Pub. L. 104–304, § 8(2)","children":[],"tail":", inserted “, operating, and maintaining” after “cost of installing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s20/j"},"text":"Pub. L. 104–304, § 20(j)","children":[],"tail":", substituted “standards” for “regulations” after “prescribe” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s8/3"},"text":"Pub. L. 104–304, § 8(3)","children":[],"tail":", inserted “, maintenance, and replacement” after “installation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s20/j"},"text":"Pub. L. 104–304, § 20(j)","children":[],"tail":", substituted “standards” for “regulations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s8/4"},"text":"Pub. L. 104–304, § 8(4)","children":[],"tail":", inserted after first sentence “The Secretary may adopt industry accepted performance standards in order to comply with the requirement under the preceding sentence.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
