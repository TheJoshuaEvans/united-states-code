{"tag":"section","attrib":{"id":"idcaf2d680-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13541"},"text":null,"children":[{"tag":"num","attrib":{"value":"13541"},"text":"§ 13541.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to exempt transportation or services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf2d681-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13541/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In any matter subject to jurisdiction under this part, the Secretary or the Board, as applicable, shall exempt a person, class of persons, or a transaction or service from the application, in whole or in part, of a provision of this part, or use this exemption authority to modify the application of a provision of this part as it applies to such person, class, transaction, or service, when the Secretary or Board finds that the application of that provision—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d682-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13541/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not necessary to carry out the transportation policy of section 13101;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d683-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13541/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not needed to protect shippers from the abuse of market power or that the transaction or service is of limited scope; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d684-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13541/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d685-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13541/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initiation of Proceeding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Board, as applicable, may, where appropriate, begin a proceeding under this section on the Secretary’s or Board’s own initiative or on application by an interested party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d686-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13541/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Board, as applicable, may specify the period of time during which an exemption granted under this section is effective.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d687-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13541/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Board, as applicable, may revoke an exemption, to the extent specified, on finding that application of a provision of this part to the person, class, or transportation is necessary to carry out the transportation policy of section 13101.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d688-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13541/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d689-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13541/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The exemption authority under this section may not be used to relieve a person from the application of, and compliance with, any law, rule, regulation, standard, or order pertaining to cargo loss and damage, insurance, safety fitness, or activities approved under section 13703 or 14302 or not terminated under section 13907(d)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d68a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13541/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Water carriers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Board, as applicable, may not exempt a water carrier from the application of, or compliance with, section 13701 or 13702 for transportation in the non-contiguous domestic trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d68b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13541/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuation of Certain Existing Exemptions for Water Carriers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or Board, as applicable, shall not regulate or exercise jurisdiction under this part over the transportation by water carrier in the non-contiguous domestic trade of any cargo or type of cargo or service which was not subject to regulation by, or under the jurisdiction of, either the Federal Maritime Commission or Interstate Commerce Commission under Federal law in effect on ","children":[{"tag":"date","attrib":{"date":"1995-11-01"},"text":"November 1, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf2d68c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/866"},"text":"109 Stat. 866","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf2d68d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf2d68e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf2d68f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10505"},"text":"section 10505 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaf2d690-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcaf2d691-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcaf2d692-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Interstate Commerce Commission","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Interstate Commerce Commission abolished by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s101"},"text":"section 101 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
