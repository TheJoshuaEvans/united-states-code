{"tag":"section","attrib":{"id":"idca747daa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s501"},"text":null,"children":[{"tag":"num","attrib":{"value":"501"},"text":"§ 501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions and application","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca747dab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca747dac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the definitions in sections 10102 and 13102 of this title apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca747dad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “migrant worker” has the same meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31501"},"text":"section 31501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca747dae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “motor carrier of migrant workers” means a motor carrier of migrant workers subject to the jurisdiction of the Secretary of Transportation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31502/c"},"text":"section 31502(c) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"s