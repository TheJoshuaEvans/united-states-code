{"tag":"section","attrib":{"id":"idca87914b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102"},"text":null,"children":[{"tag":"num","attrib":{"value":"5102"},"text":"§ 5102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca87914c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “commerce” means trade or transportation in the jurisdiction of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca87914d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between a place in a State and a place outside of the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca87914e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that affects trade or transportation between a place in a State and a place outside of the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca87914f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a United States-registered aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca879150-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “hazardous material” means a substance or material the Secretary designates under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5103/a"},"text":"section 5103(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca879151-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “hazmat employee”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca879152-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means an individual—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca879153-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca879154-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/3/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed on a full time, part time, or temporary basis by a hazmat employer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca879155-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/3/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is self-employed (including an owner-operator of a motor vehicle, vessel, or aircraft) transporting hazardous material in commerce; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca879156-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who during the course of such full time, part time, or temporary employment, or such self employment, directly affects hazardous material transportation safety as the Secretary decides by regulation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca879157-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes an individual, employed on a full time, part time, or temporary basis by a hazmat employer, or self employed, who during the course of employment—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca879158-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" loads, unloads, or handles hazardous material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca879159-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designs, manufactures, fabricates, inspects, marks, maintains, reconditions, repairs, or tests a package, container, or packaging component that is represented, marked, certified, or sold as qualified for use in transporting hazardous material in commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca87915a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prepares hazardous material for transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca87915b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is responsible for the safety of transporting hazardous material; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca87915c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates a vehicle used to transport hazardous material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca87915d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “hazmat employer”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca87915e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means a person—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca87915f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca879160-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/4/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employs or uses at least 1 hazmat employee on a full time, part time, or temporary basis; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca879161-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/4/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is self-employed (including an owner-operator of a motor vehicle, vessel, or aircraft) transporting hazardous material in commerce; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca879162-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca879163-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/4/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transports hazardous material in commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca879164-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/4/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" causes hazardous material to be transported in commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca879165-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/4/A/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designs, manufactures, fabricates, inspects, marks, maintains, reconditions, repairs, or tests a package, container, or packaging component that is represented, marked, certified, or sold as qualified for use in transporting hazardous material in commerce; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca879166-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a department, agency, or instrumentality of the United States Government, or an authority of a State, political subdivision of a State, or Indian tribe, carrying out an activity described in clause (ii).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca879167-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “imminent hazard” means the existence of a condition relating to hazardous material that presents a substantial likelihood that death, serious illness, severe personal injury, or a substantial endangerment to health, property, or the environment may occur before the reasonably foreseeable completion date of a formal proceeding begun to lessen the risk of that death, illness, injury, or endangerment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca879168-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Indian tribe” has the same meaning given that term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"25 U.S.C. 450b","children":[],"tail":")."},{"tag":"ref","attrib":{"idref":"fn002025"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002025"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca879169-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “motor carrier”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca87916a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a motor carrier, motor private carrier, and freight forwarder as those terms are defined in section 13102; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca87916b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a freight forwarder, as so defined, if the freight forwarder is not performing a function relating to highway transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca87916c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “National Response Team” means the National Response Team established under the National Contingency Plan established under section 105 of the Comprehensive Environmental Response, Compensation, and Liability Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9605"},"text":"42 U.S.C. 9605","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca87916d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “person”, in addition to its meaning under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t1/s1"},"text":"section 1 of title 1","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca87916e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" includes a government, Indian tribe, or authority of a government or tribe that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca87916f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/9/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" offers hazardous material for transportation in commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca879170-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/9/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transports hazardous material to further a commercial enterprise; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca879171-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/9/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designs, manufactures, fabricates, inspects, marks, maintains, reconditions, repairs, or tests a package, container, or packaging component that is represented, marked, certified, or sold as qualified for use in transporting hazardous material in commerce; but","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca879172-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca879173-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/9/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Postal Service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca879174-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/9/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in sections 5123 and 5124 of this title, a department, agency, or instrumentality of the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca879175-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “public sector employee”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca879176-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means an individual employed by a State, political subdivision of a State, or Indian tribe and who during the course of employment has responsibilities related to responding to an accident or incident involving the transportation of hazardous material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca879177-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an individual employed by a State, political subdivision of a State, or Indian tribe as a firefighter or law enforcement officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca879178-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/10/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes an individual who volunteers to serve as a firefighter for a State, political subdivision of a State, or Indian tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca879179-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Secretary” means the Secretary of Transportation except as otherwise provided.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca87917a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “State” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca87917b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5119"},"text":"section 5119 of this title","children":[],"tail":", a State of the United States, the District of Columbia, Puerto Rico, the Northern Mariana Islands, the Virgin Islands, American Samoa, Guam, and any other territory or possession of the United States designated by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca87917c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/12/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5119"},"text":"section 5119 of this title","children":[],"tail":", a State of the United States and the District of Columbia."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca87917d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “transports” or “transportation” means the movement of property and loading, unloading, or storage incidental to the movement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca87917e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5102/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States” means all of the States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca87917f-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/759"},"text":"108 Stat. 759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/311/tI/s117/a/1"},"text":"Pub. L. 103–311, title I, § 117(a)(1)","ch