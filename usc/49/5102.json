tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5102(13)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1802(16).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this chapter, the words “or shipped” are omitted as being included in “transported”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), before subclause (A), the text of 49 App.:1802(1), (3), and (13) is omitted because the complete names of the Administrator of the Environmental Protection Agency, Director of the Federal Emergency Management Agency, and Secretary of Transportation are used the first time the terms appear in a section. The words “traffic, commerce” are omitted as surplus. In subclause (B), the words “between a place in a State and a place outside of the State” are substituted for “described in clause (A)” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clauses (3)(C) and (10)(B), the words “at a minimum” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (5), the words “administrative hearing or other” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (9), before subclause (A), the words “including any trustee, receiver, assignee, or similar representative thereof” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (12), the words “by any mode” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca879183-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca879184-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"25 U.S.C. 450b","children":[],"tail":"), referred to in par. (6), is "},{"tag":"ref","attrib":{"href":"/us/pl/93/638/s4"},"text":"section 4 of Pub. L. 93–638","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-01-04"},"text":"Jan. 4, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2204"},"text":"88 Stat. 2204","children":[],"tail":", which was classified to "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s450b"},"text":"section 450b of Title 25","children":[],"tail":", Indians, prior to editorial reclassification as "},{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"section 5304 of Title 25","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca8a0185-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7102/2"},"text":"Pub. L. 109–59, § 7102(2)","children":[],"tail":". See 2005 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Par. (1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7102/1"},"text":"Pub. L. 109–59, § 7102(1)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(A)(i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7102/2/A"},"text":"Pub. L. 109–59, § 7102(2)(A)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/s302/a/1"},"text":"Pub. L. 110–244, § 302(a)(1)","children":[],"tail":", (2), added cl. (i) and struck out former cl. (i) which read as follows: “employed by a hazmat employer; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7102/2/B"},"text":"Pub. L. 109–59, § 7102(2)(B)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/s302/a/1"},"text":"Pub. L. 110–244, § 302(a)(1)","children":[],"tail":", (3), substituted “course of such full time, part time, or temporary employment, or such self employment,” for “course of employment” and inserted “and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7102/2/D/i"},"text":"Pub. L. 109–59, § 7102(2)(D)(i)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/s302/a/1"},"text":"Pub. L. 110–244, § 302(a)(1)","children":[],"tail":", substituted “employed on a full time, part time, or temporary basis by a hazmat employer, or self employed,” for “employed by a hazmat employer,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7102/2/C"},"text":"Pub. L. 109–59, § 7102(2)(C)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/s302/a/1"},"text":"Pub. L. 110–244, § 302(a)(1)","children":[],"tail":", redesignated subpar. (C) as (B) and struck out former subpar. (B) which read as follows: “includes an owner-operator of a motor vehicle transporting hazardous material in commerce; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7102/2/D/ii"},"text":"Pub. L. 109–59, § 7102(2)(D)(ii)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/s302/a/1"},"text":"Pub. L. 110–244, § 302(a)(1)","children":[],"tail":", added cl. (ii) and struck out former cl. (ii) which read as follows: “manufactures, reconditions, or tests containers, drums, and packagings represented as qualified for use in transporting hazardous material;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7102/2/C"},"text":"Pub. L. 109–59, § 7102(2)(C)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/s302/a/1"},"text":"Pub. L. 110–244, § 302(a)(1)","children":[],"tail":", redesignated subpar. (C) as (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7102/3"},"text":"Pub. L. 109–59, § 7102(3)","children":[],"tail":", amended par. (4) generally. Prior to amendment, par. (4) consisted of subpars. (A) to (C), which included within definition of “hazmat employer” a person using at least one employee in connection with transporting or containers for transporting hazardous material, an owner-operator of a motor vehicle transporting hazardous material in commerce, and a department, agency, or instrumentality of the United States Government, or an authority of a State, political subdivision of a State, or Indian tribe, carrying out certain described activities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7102/4"},"text":"Pub. L. 109–59, § 7102(4)","ch