{"tag":"section","attrib":{"id":"idcb0859a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s16102"},"text":null,"children":[{"tag":"num","attrib":{"value":"16102"},"text":"§ 16102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Recordkeeping and reporting violations","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A person required to make a report to the Board, or make, prepare, or preserve a record, under chapter 157 about transportation subject to this part that knowingly and willfully—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0859a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s16102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes a false entry in the report or record,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0859a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s16102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" destroys, mutilates, changes, or by another means falsifies the record,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0859aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s16102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not enter business related facts and transactions in the record,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0859ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s16102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" makes, prepares, or preserves the record in violation of a regulation or order of the Board, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0859ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s16102/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" files a false report or record with the Board,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined under title 18 or imprisoned not more than 2 years, or both.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0859ad-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s106/a"},"text":"Pub. L. 104–88, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/930"},"text":"109 Stat. 930","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb0859ae-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb0859af-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb0859b0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11909"},"text":"section 11909 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":