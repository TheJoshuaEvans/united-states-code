{"tag":"section","attrib":{"id":"idcabe7f0c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332"},"text":null,"children":[{"tag":"num","attrib":{"value":"5332"},"text":"§ 5332.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nondiscrimination","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcabe7f0d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, “person” includes a governmental authority, political subdivision, authority, legal representative, trust, unincorporated organization, trustee, trustee in bankruptcy, and receiver.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcabe7f0e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may not be excluded from participating in, denied a benefit of, or discriminated against under, a project, program, or activity receiving financial assistance under this chapter because of race, color, religion, national origin, sex, disability, or age.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcabe7f0f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcabe7f10-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall take affirmative action to ensure compliance with subsection (b) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcabe7f11-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Secretary decides that a person receiving financial assistance under this chapter is not complying with subsection (b) of this section, a civil rights law of the United States, or a regulation or order under that law, the Secretary shall notify the person of the decision and require action be taken to ensure compliance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcabe7f12-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Secretary for Noncompliance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a person does not comply with subsection (b) of this section within a reasonable time after receiving notice, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcabe7f13-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct that no further financial assistance of the United States Government under this chapter be provided to the person;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcabe7f14-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refer the matter to the Attorney General with a recommendation that a civil action be brought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcabe7f15-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proceed under title VI of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcabe7f16-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take any other action provided by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcabe7f17-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions by Attorney General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Attorney General may bring a civil action for appropriate relief when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcabe7f18-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a matter is referred to the Attorney General under subsection (d)(2) of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcabe7f19-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General believes a person is engaged in a pattern or practice in violation of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcabe7f1a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5332/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application and Relationship to Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies to an employment or business opportunity and is in addition to title VI of the Civil Rights Act of 1964 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s2000d"},"text":"42 U.S.C. 2000d","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcabe7f1b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/834"},"text":"108 Stat. 834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dB"},"text":"Pub. L. 112–141, div. B","children":[],"tail":", §§ 20023(a), 20030(g), "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/717"},"text":"126 Stat. 717","children":[],"tail":", 731.)"}],"tail":"\n"},{"tag