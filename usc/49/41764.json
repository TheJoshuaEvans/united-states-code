{"tag":"section","attrib":{"id":"idcbd0b2ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41764"},"text":null,"children":[{"tag":"num","attrib":{"value":"41764"},"text":"§ 41764.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Use of Federal facilities and assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd0b2ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41764/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Federal Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To permit the Secretary of Transportation to make use of such expert advice and services as the Secretary may require in carrying out this subchapter, the Secretary may use available services and facilities of other agencies and instrumentalities of the United States Government—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd0b2f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41764/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the consent of the appropriate Federal officials; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd0b2f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41764/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a reimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd0b2f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41764/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each appropriate department or agency of the United States Government shall exercise the duties and powers of that head in such manner as to assist in carrying out the policy specified in section 41761.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd0b2f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41764/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Oversight","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make available to the Comptroller General of the United States such information with respect to any Federal credit instrument made under this subchapter as the Comptroller General may require to carry out the duties of the Comptroller General under chapter 7 of title 31, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd0b2f4-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tII/s210/a"},"text":"Pub. L. 106–181, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/101"},"text":"114 Stat. 101","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd0b2f5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbd0b2f6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcbd0b2f7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as an Effective Date of 2000 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
