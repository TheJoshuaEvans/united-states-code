{"tag":"section","attrib":{"id":"idcad3dc68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903"},"text":null,"children":[{"tag":"num","attrib":{"value":"5903"},"text":"§ 5903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad3dc69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Providing Erroneous Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person, To ","children":[{"tag":"ref","attrib":{"idref":"fn002044"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002044"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should not be capitalized."}],"tail":" whom section 5902(b) applies, tendering a loaded container or trailer may not provide erroneous information in a certification required by "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5902/b"},"text":"section 5902(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad3dc6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transporting Prior to Receiving Certification.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad3dc6b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Presumption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If no certification is received by a motor carrier before or when a loaded intermodal container or trailer is tendered to it, the motor carrier may presume that the gross cargo weight of the container or trailer is less than 29,001 pounds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dc6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Copy of certification not required to accompany container or trailer","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this chapter to the contrary, a copy of the certification required by section 5902(b) is not required to accompany the intermodal container or trailer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad3dc6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unlawful Coercion","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad3dc6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person may not coerce or attempt to coerce a person participating in intermodal transportation to transport a loaded container or trailer having an actual gross cargo weight of more than 29,000 pounds before the certification required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5902/b"},"text":"section 5902(b) of this title","children":[],"tail":" is provided."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dc6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person, knowing that the weight of a loaded container or trailer or the weight of a tractor-trailer combination carrying the container or trailer is more than the weight allowed by applicable State law, may not coerce or attempt to coerce a carrier to transport the container or trailer or to operate the tractor-trailer combination in violation of that State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad3dc70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Leased Operators.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad3dc71-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a motor carrier knows that the gross cargo weight of an intermodal container or trailer subject to the certification requirements of section 5902(b) would result in a violation of applicable State gross vehicle weight laws, then—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad3dc72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the motor carrier shall give notice to the operator of a vehicle which is leased by the vehicle operator to a motor carrier that transports an intermodal container or trailer of the gross cargo weight of the container or trailer as certified to the motor carrier under section 5902(b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad3dc73-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the notice shall be provided to the operator prior to the operator being tendered the container or trailer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad3dc74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the notice required by this subsection shall be in writing, but may be transmitted electronically; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad3dc75-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the motor carrier shall bear the burden of proof to establish that it tendered the required notice to the operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dc76-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5903/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the operator of a leased vehicle transporting a container or trailer subject to this chapter is fined because of a violation of a State’s gross vehicle weight laws or regulations and the lessee motor carrier cannot establish that it tendered to the operator the notice required by paragraph (1) of this subsection, then the operator shall be entitled to reimbursement from the motor carrier in the amount of any fine and court costs resulting from the failure of the motor carrier to tender the notice to the operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad3dc77-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/860"},"text":"108 Stat. 860","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/291/tII/s205"},"text":"Pub. L. 104–291, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3456"},"text":"110 Stat. 3456","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad3dc78-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcad3dc79-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcad3dc7a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5903(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:508(a)(3) (related to violations).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5903(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:508(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5903(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:508(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “may not” are substituted for “it shall be a violation” and “It shall be unlawful” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “After the date on which the Secretary of Transportation issues final regulations to enforce this section” are omitted because of section 5907(b) of the revised title. The words “to fail to comply with paragraph (1) or (2)” are omitted as unnecessary because the failure to comply with an affirmative duty is a violation without the need to say so specifically. The word “false” is omitted as included in “erroneous”. The word “written” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “(as such term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10102"},"text":"section 10102 of this title","children":[],"tail":")” are omitted as unnecessary because of section 5901(1) of the revised title. The word “transport” is substituted for “provide transportation of” for consistency and to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad3dc7b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcad3dc7c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/291/s205/1"},"text":"Pub. L. 104–291, § 205(1)","children":[],"tail":", inserted “, To whom section 5902(b) applies,” after “person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/291/s205/2"},"text":"Pub. L. 104–291, § 205(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Transporting Prior To Receiving Certification","children":[],"tail":".—A motor carrier may not transport a loaded container or trailer to which "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5902/b"},"text":"section 5902(b) of this title","children":[],"tail":" applies before receiving the certification required by section 5902(b).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/291/s205/3"},"text":"Pub. L. 104–291, § 205(3)","children":[],"tail":", substituted “29,000 pounds” for “10,000 pounds (including packing materials and pallets)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/291/s205/4"},"text":"Pub. L. 104–291, § 205(4)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
