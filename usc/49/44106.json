{"tag":"section","attrib":{"id":"idcbd7deee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106"},"text":null,"children":[{"tag":"num","attrib":{"value":"44106"},"text":"§ 44106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocation of aircraft certificates for controlled substance violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd7deef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, “controlled substance” has the same meaning given that term in section 102 of the Comprehensive Drug Abuse Prevention and Control Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7def0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7def1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator of the Federal Aviation Administration shall issue an order revoking the certificate of registration for an aircraft issued to an owner under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44103"},"text":"section 44103 of this title","children":[],"tail":" and any other certificate of registration that the owner of the aircraft holds under section 44103, if the Administrator finds that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7def2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft was used to carry out, or facilitate, an activity that is punishable by death or imprisonment for more than one year under a law of the United States or a State related to a controlled substance (except a law related to simple possession of a controlled substance); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7def3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner of the aircraft permitted the use of the aircraft knowing that the aircraft was to be used for the activity described in clause (A) of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7def4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An aircraft owner that is not an individual is deemed to have permitted the use of the aircraft knowing that the aircraft was to be used for the activity described in paragraph (1)(A) of this subsection only if a majority of the individuals who control the owner of the aircraft or who are involved in forming the major policy of the owner permitted the use of the aircraft knowing that the aircraft was to be used for the activity described in paragraph (1)(A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7def5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advice to Holders and Opportunity To Answer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the Administrator revokes a certificate under subsection (b) of this section, the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7def6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the holder of the certificate of the charges or reasons on which the Administrator bases the proposed action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7def7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the holder of the certificate an opportunity to answer the charges and state why the certificate should not be revoked.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7def8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeals","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7def9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person whose certificate is revoked by the Administrator under subsection (b) of this section may appeal the revocation order to the National Transportation Safety Board. The Board shall affirm or reverse the order after providing notice and a hearing on the record. In conducting the hearing, the Board is not bound by the findings of fact of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7defa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When a person files an appeal with the Board under this subsection, the order of the Administrator revoking the certificate is stayed. However, if the Administrator advises the Board that safety in air transportation or air commerce requires the immediate effectiveness of the order—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7defb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the order remains effective; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7defc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board shall dispose of the appeal not later than 60 days after notification by the Administrator under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7defd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person substantially affected by an order of the Board under this subsection may seek judicial review of the order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s46110"},"text":"section 46110 of this title","children":[],"tail":". The Administrator shall be made a party to that judicial proceeding."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7defe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquittal","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7deff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may not revoke, and the Board may not affirm a revocation of, a certificate of registration under this section on the basis of an activity described in subsection (b)(1)(A) of this section if the holder of the certificate is acquitted of all charges related to a controlled substance in an indictment or information arising from the activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7df00-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Administrator has revoked a certificate of registration of a person under this section because of an activity described in subsection (b)(1)(A) of this section, the Administrator shall reissue a certificate to the person if the person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7df01-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsequently is acquitted of all charges related to a controlled substance in an indictment or information arising from the activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7df02-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44106/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" otherwise meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44102"},"text":"section 44102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd7df03-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1163"},"text":"108 Stat. 1163","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd7df04-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbd7df05-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbd7df06-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44106(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1401(e)(2)(C).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 501(e)(2)(A)– (C), (F); added "},{"tag":"html:span","attrib":{},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/499/s4/a"},"text":"Pub. L. 98–499, § 4(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2314"},"text":"98 Stat. 2314","children":[],"tail":", 2315."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44106(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1401(e)(2)(A) (less last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44106(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1401(e)(2)(B) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44106(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1401(e)(2)(B) (2d–last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44106(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1401(e)(2)(A) (last sentence), (F).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “knowing that the aircraft was to be used for the activity described in paragraph (1)(A) of this subsection” are substituted for “with knowledge of such intended use” for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
