{"tag":"section","attrib":{"id":"idcc5d6242-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47137"},"text":null,"children":[{"tag":"num","attrib":{"value":"47137"},"text":"§ 47137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Airport security program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc5d6243-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47137/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To improve security at public airports in the United States, the Secretary of Transportation shall carry out not less than one project to test and evaluate innovative aviation security systems and related technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d6244-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47137/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall give the highest priority to a request from an eligible sponsor for a grant to undertake a project that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d6245-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47137/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluates and tests the benefits of innovative aviation security systems or related technology, including explosives detection systems, for the purpose of improving aviation and aircraft physical security, access control, and passenger and baggage screening; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6246-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47137/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides testing and evaluation of airport security systems and technology in an operational, testbed environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d6247-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47137/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matching Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 47109, the United States Government’s share of allowable project costs for a project under this section shall be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d6248-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47137/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may establish such terms and conditions as the Secretary determines appropriate for carrying out a project under this section, including terms and conditions relating to the form and content of a proposal for a project, project assurances, and schedule of payments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d6249-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47137/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in cooperation with the Secretary of Homeland Security, shall administer the program authorized by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d624a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47137/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Sponsor Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “eligible sponsor” means a nonprofit corporation composed of a consortium of public and private persons, including a sponsor of a primary airport, with the necessary engineering and technical expertise to successfully conduct the testing and evaluation of airport and aircraft related security systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d624b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47137/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amounts made available to the Secretary under section 47115 in a fiscal year, the Secretary shall make available not less than $5,000,000 for the purpose of carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc5d624c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tI/s134/a"},"text":"Pub. L. 106–181, title I, § 134(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/83"},"text":"114 Stat. 83","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tI/s157"},"text":"Pub. L. 108–176, title I, § 157","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2508"},"text":"117 Stat. 2508","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc5d624d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc5d624e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc5d624f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" added subsec. (e) and redesignated former subsecs. (e) and (f) as (f) and (g), respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc5d6250-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc5d6251-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc5d6252-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as an Effective Date of 2000 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
