of reenacted in Title 49, Transportation, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/449"},"text":"Pub. L. 97–449","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2413"},"text":"96 Stat. 2413","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/745"},"text":"108 Stat. 745","children":[],"tail":". The Act was also repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s7/5"},"text":"Pub. L. 104–287, § 7(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3400"},"text":"110 Stat. 3400","children":[],"tail":". For disposition of sections of former Title 49, see Table at the beginning of Title 49."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca747d53-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" substituted “Federal Motor Carrier Safety Administration” for “Federal Highway Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
