{"tag":"section","attrib":{"id":"idcc6e04c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106"},"text":null,"children":[{"tag":"num","attrib":{"value":"49106"},"text":"§ 49106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Metropolitan Washington Airports Authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc6e04c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Status","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Metropolitan Washington Airports Authority shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc6e04c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a public body corporate and politic with the powers and jurisdiction—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc6e04c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conferred upon it jointly by the legislative authority of Virginia and the District of Columbia or by either of them and concurred in by the legislative authority of the other jurisdiction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that at least meet the specifications of this section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e04c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" independent of Virginia and its local governments, the District of Columbia, and the United States Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e04c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a political subdivision constituted only to operate and improve the Metropolitan Washington Airports as primary airports serving the Metropolitan Washington area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6e04c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc6e04ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Airports Authority shall be authorized—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc6e04cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire, maintain, improve, operate, protect, and promote the Metropolitan Washington Airports for public purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to issue bonds from time to time in its discretion for public purposes, including paying any part of the cost of airport improvements, construction, and rehabilitation and the acquisition of real and personal property, including operating equipment for the airports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to acquire real and personal property by purchase, lease, transfer, or exchange;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exercise the powers of eminent domain in Virginia that are conferred on it by Virginia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to levy fees or other charges; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make and maintain agreements with employee organizations to the extent that the Federal Aviation Administration was authorized to do so on ","children":[{"tag":"date","attrib":{"date":"1986-10-18"},"text":"October 18, 1986","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e04d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Bonds issued under paragraph (1)(B) of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc6e04d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not a debt of Virginia, the District of Columbia, or a political subdivision of Virginia or the District of Columbia; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be secured by the Airports Authority’s revenues generally, or exclusively from the income and revenues of certain designated projects whether or not any part of the projects are financed from the proceeds of the bonds.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6e04d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board of Directors","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc6e04d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Airports Authority shall be governed by a board of directors composed of the following 17 members:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc6e04d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 7 members appointed by the Governor of Virginia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 members appointed by the Mayor of the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members appointed by the Governor of Maryland; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 members appointed by the President with the advice and consent of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e04da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The chairman of the board shall be appointed from among the members by majority vote of the members and shall serve until replaced by majority vote of the members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e04db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the board shall be appointed to the board for 6 years, except that of the members first appointed by the President after ","children":[{"tag":"date","attrib":{"date":"1996-10-09"},"text":"October 9, 1996","children":[],"tail":", one shall be appointed for 4 years. Any member of the board shall be eligible for reappointment for 1 additional term. A member shall not serve after the expiration of the member’s term(s)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e04dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A member of the board—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc6e04dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not hold elective or appointive political office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serves without compensation except for reasonable expenses incident to board functions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" must reside within the Washington Standard Metropolitan Statistical Area, except that a member of the board appointed by the President must be a registered voter of a State other than Maryland, Virginia, or the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e04e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A vacancy in the board shall be filled in the manner in which the original appointment was made. A member appointed to fill a vacancy occurring before the expiration of the term for which the member’s predecessor was appointed shall be appointed only for the remainder of that term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e04e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc6e04e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 2 of the members of the board appointed by the President may be of the same political party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out their duties on the board, members appointed by the President shall ensure that adequate consideration is given to the national interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6e04e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member appointed by the President may be removed by the President for cause. A member appointed by the Mayor of the District of Columbia, the Governor of Maryland or the Governor of Virginia may be removed or suspended from office only for cause and in accordance with the laws of the jurisdiction from which the member is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e04e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Ten votes are required to approve bond issues and the annual budget.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6e04e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conflicts of Interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the board and their immediate families may not be employed by or otherwise hold a substantial financial interest in any enterprise that has or is seeking a contract or agreement with the Airports Authority or is an aeronautical, aviation services, or airport services enterprise that otherwise has interests that can be directly affected by the Airports Authority. The official appointing a member may make an exception if the financial interest is completely disclosed when the member is appointed and the member does not participate in board decisions that directly affect the interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6e04e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Actions To Be Taken by Regulation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An action of the Airports Authority changing, or having the effect of changing, the hours of operation of, or the type of aircraft serving, either of the Metropolitan Washington Airports may be taken only by regulation of the Airports Authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6e04e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To assist the Secretary in carrying out this chapter, the Secretary may hire 2 staff individuals to be paid by the Airports Authority. The Airports Authority shall provide clerical and support staff that the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6e04e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49106/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Contracting Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall review contracts of the Airports Authority to decide whether the contracts were awarded by procedures that follow sound Government contracting principles and comply with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s49104/a/4"},"text":"section 49104(a)(4) of this title","children":[],"tail":". The Comptroller General shall submit periodic reports of the conclusions reached as a result of the review to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc6e04ea-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/26"},"text":"Pub. L. 105–102, § 2(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2210"},"text":"111 Stat. 2210","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/225/s7/c/1/A"},"text":"Pub. L. 105–225, § 7(c)(1)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1511"},"text":"112 Stat. 1511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tII/s231/i"},"text":"Pub. L. 106–181, title II, § 231(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/115"},"text":"114 Stat. 115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/55/dC/tI/s191"},"text":"Pub. L. 112–55, div. C, title I, § 191","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2011-11-18"},"text":"Nov. 18, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/671"},"text":"125 