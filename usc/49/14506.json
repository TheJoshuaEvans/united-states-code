{"tag":"section","attrib":{"id":"idcb012dce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14506"},"text":null,"children":[{"tag":"num","attrib":{"value":"14506"},"text":"§ 14506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb012dcf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction on Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No State, political subdivision of a State, interstate agency, or other political agency of two or more States may enact or enforce any law, rule, regulation standard, or other provision having the force and effect of law that requires a motor carrier, motor private carrier, freight forwarder, or leasing company to display any form of identification on or in a commercial motor vehicle (as defined in section 14504a), other than forms of identification required by the Secretary of Transportation under section 390.21 of title 49, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb012dd0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a), a State may continue to require display of credentials that are required—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb012dd1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the International Registration Plan under section 31704;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb012dd2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under the International Fuel Tax Agreement under section 31705 or under an applicable State law if, on ","children":[{"tag":"date","attrib":{"date":"2006-10-01"},"text":"October 1, 2006","children":[],"tail":", the State has a form of highway use taxation not subject to collection through the International Fuel Tax Agreement;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb012dd3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14506/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under a State law regarding motor vehicle license plates or other displays that the Secretary determines are appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb012dd4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14506/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with Federal requirements for hazardous materials transportation under section 5103; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb012dd5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14506/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in connection with the Federal vehicle inspection standards under section 31136.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb012dd6-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4306/a"},"text":"Pub. L. 109–59, title IV, § 4306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1773"},"text":"119 Stat. 1773","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/tIII/s301/q"},"text":"Pub. L. 110–244, title III, § 301(q)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1617"},"text":"122 Stat. 1617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb012dd7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb012dd8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb012dd9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" inserted “or under an applicable State law if, on "},{"tag":"date","attrib":{"date":"2006-10-01"},"text":"October 1, 2006","children":[],"tail":", the State has a form of highway use taxation not subject to collection through the International Fuel Tax Agreement” before semicolon at end."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
