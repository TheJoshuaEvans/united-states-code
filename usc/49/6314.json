{"tag":"section","attrib":{"id":"idcad8be0b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314"},"text":null,"children":[{"tag":"num","attrib":{"value":"6314"},"text":"§ 6314.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Port performance freight statistics program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad8be0c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall establish, on behalf of the Secretary, a port performance statistics program to provide nationally consistent measures of performance of, at a minimum—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8be0d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Nation’s top 25 ports by tonnage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be0e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Nation’s top 25 ports by 20-foot equivalent unit; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be0f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Nation’s top 25 ports by dry bulk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8be10-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8be11-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Port capacity and throughput","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than January 15 of each year, the Director shall submit an annual report to Congress that includes statistics on capacity and throughput at the ports described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be12-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Port performance measures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall collect port performance measures for each of the United States ports referred to in subsection (a) that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8be13-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives Federal assistance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be14-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to Federal regulation to submit necessary information to the Bureau that includes statistics on capacity and throughput as applicable to the specific configuration of the port.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8be15-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8be16-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall obtain recommendations for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8be17-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" port performance measures, including specifications and data measurements to be used in the program established under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be18-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process for the Department to collect timely and consistent data, including identifying safeguards to protect proprietary information described in subsection (b)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be19-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Working group","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date of the enactment of the Transportation for Tomorrow Act of 2015, the Director shall commission a working group composed of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8be1a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operating administrations of the Department;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be1b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Coast Guard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be1c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Maritime Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be1d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" U.S. Customs and Border Protection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be1e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Marine Transportation System National Advisory Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be1f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Army Corps of Engineers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be20-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Great Lakes St. Lawrence Seaway Development Corporation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be21-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Bureau of Labor Statistics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be22-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Maritime Advisory Committee for Occupational Safety and Health;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be23-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Advisory Committee on Supply Chain Competitiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be24-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from the rail industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be25-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from the trucking industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be26-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from the maritime shipping industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be27-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/N"},"text":null,"children":[{"tag":"num","attrib":{"value":"N"},"text":"(N)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from a labor organization for each industry described in subparagraphs (K) through (M);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/O"},"text":null,"children":[{"tag":"num","attrib":{"value":"O"},"text":"(O)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from the International Longshoremen’s Association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/P"},"text":null,"children":[{"tag":"num","attrib":{"value":"P"},"text":"(P)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from the International Longshore and Warehouse Union;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/Q"},"text":null,"children":[{"tag":"num","attrib":{"value":"Q"},"text":"(Q)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from a port authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/R"},"text":null,"children":[{"tag":"num","attrib":{"value":"R"},"text":"(R)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 representative from a terminal operator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/S"},"text":null,"children":[{"tag":"num","attrib":{"value":"S"},"text":"(S)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of the National Freight Advisory Committee of the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/2/T"},"text":null,"children":[{"tag":"num","attrib":{"value":"T"},"text":"(T)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of the Transportation Research Board of the National Academies of Sciences, Engineering, and Medicine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of the enactment of the Transportation for Tomorrow Act of 2015, the working group commissioned under paragraph (2) shall submit its recommendations to the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8be2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to Data","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall ensure that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8be30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the statistics compiled under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8be31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are readily accessible to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with applicable security constraints and confidentiality interests; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6314/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the data acquired, regardless of source, shall be protected in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3572"},"text":"section 3572 of title 44","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad8be34-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVI/s6018/a"},"text":"Pub. L. 114–94, div. A, title VI, § 6018(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1576"},"text":"129 Stat. 1576","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/tIII/s302/c/3/B"},"text":"Pub. L. 115–435, title III, § 302(c)(3)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5553"},"text":"132 Stat. 5553","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dAA/tV/s512/c/7/A/ii"},"text":"Pub. L. 116–260, div. AA, title V, § 512(c)(7)(A)(ii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2757"},"text":"134 Stat. 2757","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad8be35-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad8be36-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","a