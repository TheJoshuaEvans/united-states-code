{"tag":"section","attrib":{"id":"idcb2027cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301"},"text":null,"children":[{"tag":"num","attrib":{"value":"22301"},"text":"§ 22301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Capital grants for class II and class III railroads","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb2027d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb2027d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall establish a program for making capital grants to class II and class III railroads. Such grants shall be for projects in the public interest that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb2027d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb2027d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rehabilitate, preserve, or improve railroad track (including roadbed, bridges, and related track structures) used primarily for freight transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb2027d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the continued or greater use of railroad transportation for freight shipments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb2027d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce the use of less fuel efficient modes of transportation in the transportation of such shipments; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2027d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrate innovative technologies and advanced research and development that increase fuel economy, reduce greenhouse gas emissions, and lower the costs of operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2027d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants may be provided under this chapter—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb2027d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly to the class II or class III railroad; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2027d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the concurrence of the class II or class III railroad, to a State or local government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2027da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Class II and class III railroad applicants for a grant under this chapter are encouraged to utilize the expertise and assistance of State transportation agencies in applying for and administering such grants. State transportation agencies are encouraged to provide such expertise and assistance to such railroads.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2027db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2008-10-01"},"text":"October 1, 2008","children":[],"tail":", the Secretary shall issue final regulations to implement the program under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2027dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The maximum Federal share for carrying out a project under this section shall be 80 percent of the project cost. The non-Federal share may be provided by any non-Federal source in cash, equipment, or supplies. Other in-kind contributions may be approved by the Secretary on a case-by-case basis consistent with this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2027dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Grants provided under this section shall be used to implement track capital projects as soon as possible. In no event shall grant funds be contractually obligated for a project later than the end of the third Federal fiscal year following the year in which the grant was awarded. Any funds not so obligated by the end of such fiscal year shall be returned to the Secretary for reallocation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2027de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee Protection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require as a condition of any grant made under this section that the recipient railroad provide a fair arrangement at least as protective of the interests of employees who are affected by the project to be funded with the grant as the terms imposed under section 11326(a), as in effect on the date of the enactment of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2027df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Labor Standards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb2027e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prevailing wages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure that laborers and mechanics employed by contractors and subcontractors in construction work financed by a grant made under this section will be paid wages not less than those prevailing on similar construction in the locality, as determined by the Secretary of Labor under subchapter IV of chapter 31 of title 40 (commonly known as the “Davis-Bacon Act”). The Secretary shall make a grant under this section only after being assured that required labor standards will be maintained on the construction work.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2027e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Wage rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Wage rates in a collective bargaining agreement negotiated under the Railway Labor Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"45 U.S.C. 151","children":[],"tail":" et seq.) are deemed for purposes of this subsection to comply with the "},{"tag":"ref","attrib":{"idref":"fn002078"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002078"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “the” probably should not appear."}],"tail":" subchapter IV of chapter 31 of title 40."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2027e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall conduct a study of the projects carried out with grant assistance under this section to determine the extent to which the program helps promote a reduction in fuel use associated with the transportation of freight and demonstrates innovative technologies that increase fuel economy, reduce greenhouse gas emissions, and lower the costs of operation. Not later than ","children":[{"tag":"date","attrib":{"date":"2009-03-31"},"text":"March 31, 2009","children":[],"tail":", the Secretary shall submit a report to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate on the study, including any recommendations the Secretary considers appropriate regarding the program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2027e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22301/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary $50,000,000 for each of fiscal years 2008 through 2011 for carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb2027e4-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/tXI/s1112/a"},"text":"Pub. L. 110–140, title XI, § 1112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1758"},"text":"121 Stat. 1758","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tVII/s701/b"},"text":"Pub. L. 110–432, div. A, title VII, § 701(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4906"},"text":"122 Stat. 4906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb2027e5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb2027e6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb2027e7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this chapter, referred to in subsec. (d), probably means the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":", which amended this chapter generally and was approved "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Railway Labor Act, referred to in subsec. (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347"},"text":"act May 20, 1926, ch. 347","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/577"},"text":"44 Stat. 577","children":[],"tail":", which is classified principally to chapter 8 (§ 151 et seq.) of Title 45, Railroads. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"section 151 of Title 45","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb2027e8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 22301, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tVII/s7202/a"},"text":"Pub. L. 105–178, title VII, § 7202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/470"},"text":"112 Stat. 470","children":[],"tail":", related to grants for light density rail line pilot projects, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/110/140"},"text":"Pub. L. 110–140","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb2027e9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1)(A)(iii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":" substituted “or” for “and”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb2027ea-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb2027eb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective on the date that is 1 day after ","children":[{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/s1601"},"text":"section 1601 of Pub. L. 110–140","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t2/s1824"},"text":"section 1824 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
