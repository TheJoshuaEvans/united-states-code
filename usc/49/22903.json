{"tag":"section","attrib":{"id":"idcb2509da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903"},"text":null,"children":[{"tag":"num","attrib":{"value":"22903"},"text":"§ 22903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Project management oversight","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb2509db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Management Plan Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive Federal financial assistance for a major capital project under this chapter, an applicant must prepare and carry out a project management plan approved by the Secretary of Transportation. The plan shall provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb2509dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate recipient staff organization with well-defined reporting relationships, statements of functional responsibilities, job descriptions, and job qualifications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2509dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a budget covering the project management organization, appropriate consultants, property acquisition, utility relocation, systems demonstration staff, audits, and miscellaneous payments the recipient may be prepared to justify;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2509de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a construction schedule for the project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2509df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a document control procedure and recordkeeping system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2509e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a change order procedure that includes a documented, systematic approach to handling the construction change orders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2509e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" organizational structures, management skills, and staffing levels required throughout the construction phase;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2509e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quality control and quality assurance functions, procedures, and responsibilities for construction, system installation, and integration of system components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2509e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" material testing policies and procedures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2509e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" internal plan implementation and reporting requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2509e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" criteria and procedures to be used for testing the operational system or its major components;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2509e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodic updates of the plan, especially related to project budget and project schedule, financing, and ridership estimates; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2509e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the recipient’s commitment to submit periodically a project budget and project schedule to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"status":"repealed","id":"idcb2509e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"[(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Repealed. ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11316/p"},"text":"Pub. L. 114–94, div. A, title XI, § 11316(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1679"},"text":"129 Stat. 1679","children":[],"tail":"]"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2509e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to Sites and Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each recipient of assistance under this chapter shall provide the Secretary and a contractor the Secretary chooses under subsection (b) of this section with access to the construction sites and records of the recipient when reasonably necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb2509ea-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tIII/s301/a"},"text":"Pub. L. 110–432, div. B, title III, § 301(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4941"},"text":"122 Stat. 4941","children":[],"tail":", § 24403; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11316/p"},"text":"Pub. L. 114–94, div. A, title XI, § 11316(p)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1679"},"text":"129 Stat. 1679","children":[],"tail":"; renumbered § 22903, "},{"tag":"ref","attrib":{"href":"/us/pl/115/420/s7/a/1"},"text":"Pub. L. 115–420, § 7(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5445"},"text":"132 Stat. 5445","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb2509eb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb2509ec-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb2509ed-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/420"},"text":"Pub. L. 115–420","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s24403"},"text":"section 24403 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" struck out subsec. (b) which related to secretarial oversight."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb2509ee-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb2509ef-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
