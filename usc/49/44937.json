{"tag":"section","attrib":{"id":"idcc3259fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44937"},"text":null,"children":[{"tag":"num","attrib":{"value":"44937"},"text":"§ 44937.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on transferring duties and powers","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as specifically provided by law, the Administrator of the Transportation Security Administration may not transfer a duty or power under section 44903(a), (b), (c), or (e), 44906, 44912, 44935, 44936, or 44938(b)(3) of this title to another department, agency, or instrumentality of the United States Government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcc3259fe-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1219"},"text":"108 Stat. 1219","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/57"},"text":"Pub. L. 103–429, § 6(57)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4385"},"text":"108 Stat. 4385","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s101/f/7"},"text":"Pub. L. 107–71, title I, § 101(f)(7)","children":[],"tail":", (9), "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/603"},"text":"115 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/d/28"},"text":"Pub. L. 115–254, div. K, title I, § 1991(d)(28)","children":[],"tail":", "},{"tag":"date","attrib"