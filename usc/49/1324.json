{"tag":"section","attrib":{"id":"idca8790f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1324"},"text":null,"children":[{"tag":"num","attrib":{"value":"1324"},"text":"§ 1324.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of process in court proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8790f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1324/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Agent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier providing transportation subject to the jurisdiction of the Board under subtitle IV shall designate an agent on whom service of process in an action before a district court may be made. Except as otherwise provided, process in an action before a district court shall be served on the designated agent of that carrier at the office or usual place of residence of that agent. If the carrier does not have a designated agent, service may be made by posting the notice in the office of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8790f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1324/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Changing Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A designation under this section may be changed at any time in the same manner as originally made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8790f8-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tII/s201/a"},"text":"Pub. L. 104–88, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/937"},"text":"109 Stat. 937","children":[],"tail":", § 724; renumbered § 1324 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/110"},"text":"Pub. L. 114–110","children":[],"tail":", §§ 3(a)(5), 8(b), "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2228"},"text":"129 Stat. 2228","children":[],"tail":", 2232.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8790f9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8790fa-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca8790fb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s3/a/3"},"text":"Pub. L. 114–110, § 3(a)(3)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s724"},"text":"section 724 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s8/b"},"text":"Pub. L. 114–110, § 8(b)","children":[],"tail":", struck out “in the District of Columbia” after “designate an agent” and “usual place of residence”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
