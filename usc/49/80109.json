{"tag":"section","attrib":{"id":"idcc8ab4d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80109"},"text":null,"children":[{"tag":"num","attrib":{"value":"80109"},"text":"§ 80109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liens under negotiable bills","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A common carrier issuing a negotiable bill of lading has a lien on the goods covered by the bill for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8ab4d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80109/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charges for storage, transportation, and delivery (including demurrage and terminal charges), and expenses necessary to preserve the goods or incidental to transporting the goods after the date of the bill; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab4d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80109/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other charges for which the bill expressly specifies a lien is claimed to the extent the charges are allowed by law and the agreement between the consignor and carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc8ab4d8-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1349"},"text":"108 Stat. 1349","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc8ab4d9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc8ab4da-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc8ab4db-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80109","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:105.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-08-29/ch415/s25"},"text":"Aug. 29, 1916, ch. 415, § 25","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/542"},"text":"39 Stat. 542","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, before clause (1), the word “If” is omitted as surplus. The words “covered by the bill” are substituted for “therein mentioned” for clarity. In clause (1), the words “charges for storage, transportation, and delivery (including demurrage and terminal charges)” are substituted for “all charges on those goods for freight, storage, demurrage and terminal charges . . . and all other charges incurred in transportation and delivery” as being inclusive and to conform to section 7–307 of the Uniform Commercial Code. In clause (2), the words “other charges for which the bill expressly specifies a lien” are substituted for “unless the bill expressly enumerates other charges for which a lien . . . In such case there shall also be a lien for the charges enumerated” for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
