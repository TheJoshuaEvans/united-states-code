{"tag":"section","attrib":{"id":"idca6d51c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s311"},"text":null,"children":[{"tag":"num","attrib":{"value":"311"},"text":"§ 311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional notification requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca6d51c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b) or as expressly provided in another provision of law, the Secretary of Transportation shall provide to the appropriate committees of Congress notice of an announcement concerning a covered project at least 3 full business days before the announcement is made by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6d51c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emergency Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to an allocation of funds under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s125"},"text":"section 125 of title 23","children":[],"tail":", the Secretary shall provide to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Environment and Public Works of the Senate notice of the allocation—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6d51c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 3 full business days before the issuance of the allocation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d51c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" concurrently with the issuance of the allocation, if the allocation is made using the quick release process of the Department (or any successor process).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6d51c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s311/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6d51c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s311/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate committees of congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “appropriate committees of Congress” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca6d51c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s311/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s311/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Environment and Public Works, the Committee on Commerce, Science, and Transportation, and the Committee on Banking, Housing, and Urban Affairs of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d51cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s311/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered project","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered project” means a project competitively selected by the Department to receive a discretionary grant award, letter of intent, loan commitment, loan guarantee commitment, or line of credit commitment in an amount equal to or greater than $750,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d51cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s311/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Department” means the Department of Transportation, including the modal administrations of the Department.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca6d51cd-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/322/tIV/s5001/a"},"text":"Pub. L. 114–322, title IV, § 5001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-12-16"},"text":"Dec. 16, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/1884"},"text":"130 Stat. 1884","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
