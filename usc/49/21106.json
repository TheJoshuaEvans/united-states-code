ag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939"},"text":"Mar. 4, 1907, ch. 2939","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1415"},"text":"34 Stat. 1415","children":[],"tail":", § 2(a)(3), (4); added "},{"tag":"html:span","attrib":{},"text":"July 8, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/348/s4/a/3"},"text":"Pub. L. 94–348, § 4(a)(3)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/818"},"text":"90 Stat. 818","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s16/2"},"text":"Pub. L. 100–342, § 16(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/634"},"text":"102 Stat. 634","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:62(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939"},"text":"Mar. 4, 1907, ch. 2939","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1415"},"text":"34 Stat. 1415","children":[],"tail":", § 2(e); added "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s19/b/1"},"text":"Pub. L. 100–342, § 19(b)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/638"},"text":"102 Stat. 638","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:63a(d) (related to 45:62(a)(3)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939"},"text":"Mar. 4, 1907, ch. 2939","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1415"},"text":"34 Stat. 1415","children":[],"tail":", § 3A(d) (related to § 2(a)(3)); added "},{"tag":"html:span","attrib":{},"text":"July 8, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/348/s4/d"},"text":"Pub. L. 94–348, § 4(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/819"},"text":"90 Stat. 819","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s16/4"},"text":"Pub. L. 100–342, § 16(4)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/635"},"text":"102 Stat. 635","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, before clause (1), the words “and any individuals employed to maintain the right of way of a railroad carrier” are substituted for 45:62(e) because of the restatement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb1ddcdf-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb1ddce0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, in par. (1), substituted “sanitary, give those employees and individuals an opportunity for rest free from the interruptions caused by noise under the control of the carrier, and provide indoor toilet facilities, potable water, and other features to protect the health of employees;” for “sanitary and give those employees and individuals an opportunity for rest free from the interruptions caused by noise under the control of the carrier;”, and added subsecs. (b) to (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
