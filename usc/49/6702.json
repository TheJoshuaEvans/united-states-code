{"tag":"section","attrib":{"id":"idcadb079d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702"},"text":null,"children":[{"tag":"num","attrib":{"value":"6702"},"text":"§ 6702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Local and regional project assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcadb079e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb079f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Area of persistent poverty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “area of persistent poverty” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb07a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any county (or equivalent jurisdiction) in which, during the 30-year period ending on the date of enactment of this chapter, 20 percent or more of the population continually lived in poverty, as measured by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcadb07a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 1990 decennial census;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcadb07a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 2000 decennial census; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcadb07a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recent annual small area income and poverty estimate of the Bureau of the Census;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any census tract with a poverty rate of not less than 20 percent, as measured by the 5-year data series available from the American Community Survey of the Bureau of the Census for the period of 2014 through 2018; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible entity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible entity” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb07a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any territory or possession of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public agency or publicly chartered authority established by 1 or more States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a special purpose district or public authority with a transportation function, including a port authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federally recognized Indian Tribe or a consortium of such Indian Tribes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transit agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a multi-State or multijurisdictional group of entities described in any of subparagraphs (A) through (H).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible project","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible project” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb07b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a highway or bridge project eligible for assistance under title 23;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public transportation project eligible for assistance under chapter 53;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a passenger rail or freight rail transportation project eligible for assistance under this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a port infrastructure investment, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcadb07b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inland port infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcadb07b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a land port-of-entry;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the surface transportation components of an airport project eligible for assistance under part B of subtitle VII;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project for investment in a surface transportation facility located on Tribal land, the title or maintenance responsibility of which is vested in the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project to replace or rehabilitate a culvert or prevent stormwater runoff for the purpose of improving habitat for aquatic species that will advance the goal of the program described in subsection (b)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/3/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other surface transportation infrastructure project that the Secretary considers to be necessary to advance the goal of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “program” means the Local and Regional Project Assistance Program established under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rural area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “rural area” means an area that is located outside of an urbanized area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Urbanized area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “urbanized area” means an area with a population of more than 200,000 residents, based on the most recent decennial census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb07bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb07c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish and carry out a program, to be known as the “Local and Regional Project Assistance Program”, to provide for capital investments in surface transportation infrastructure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The goal of the program shall be to fund eligible projects that will have a significant local or regional impact and improve transportation infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb07c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb07c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the program, the Secretary may make grants to eligible entities, on a competitive basis, in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amount","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, each grant made under the program shall be in an amount equal to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb07c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $5,000,000 for an urbanized area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than $1,000,000 for a rural area; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than $25,000,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than 15 percent of the funds made available to carry out the program for a fiscal year may be awarded to eligible projects in a single State during that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb07c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of Eligible Projects.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb07ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of funding opportunity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date on which funds are made available to carry out the program, the Secretary shall publish a notice of funding opportunity for the funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible to receive a grant under the program, an eligible entity shall submit to the Secretary an application—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb07cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in such form and containing such information as the Secretary considers to be appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by such date as the Secretary may establish, subject to the condition that the date shall be not later than 90 days after the date on which the Secretary issues the solicitation under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Primary selection criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under the program, the Secretary shall evaluate the extent to which a project—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb07cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves environmental sustainability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves the quality of life of rural areas or urbanized areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increases economic competitiveness and opportunity, including increasing tourism opportunities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contributes to a state of good repair; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improves mobility and community connectivity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional selection criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting projects to receive grants under the program, the Secretary shall take into consideration the extent to which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb07d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project sponsors collaborated with other public and private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the project adopts innovative technologies or techniques, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcadb07d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcadb07d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative project delivery techniques; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcadb07da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" innovative project financing;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project has demonstrated readiness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project is cost effective.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transparency.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb07de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, shall evaluate, through a methodology that is discernible and transparent to the public, the means by which each application submitted under paragraph (2) addresses the criteria under paragraphs (3) and (4) or otherwise established by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The methodology under subparagraph (A) shall be published by the Secretary as part of the notice of funding opportunity under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 270 days after the date on which amounts are made available to provide grants under the program for a fiscal year, the Secretary shall announce the selection by the Secretary of eligible projects to receive the grants in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical assistance.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb07e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On request of an eligible entity that submitted an application under paragraph (2) for a project that is not selected to receive a grant under the program, the Secretary shall provide to the eligible entity technical assistance and briefings relating to the project.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/d/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Technical assistance provided under this paragraph shall not be considered a guarantee of future selection of the applicable project under the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb07e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb07e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the Federal share of the cost of an eligible project carried out using a grant provided under the program shall not exceed 80 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of an eligible project carried out in a rural area, a historically disadvantaged community, or an area of persistent poverty using a grant under this subsection may exceed 80 percent, at the discretion of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of other federal funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts provided under any of the following programs shall be considered to be a part of the non-Federal share for purposes of this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb07e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The tribal transportation program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s202"},"text":"section 202 of title 23","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal lands transportation program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s203"},"text":"section 203 of title 23","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The TIFIA program (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s601/a"},"text":"section 601(a) of title 23","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Railroad Rehabilitation and Improvement Financing Program under chapter 224.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb07ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Considerations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb07ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the total amount made available to carry out the program for each fiscal year—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb07ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 50 percent shall be allocated for eligible projects located in rural areas; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 50 percent shall be allocated for eligible projects located in urbanized areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Historically disadvantaged communities and areas of persistent poverty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the total amount made available to carry out the program for each fiscal year, not less than 1 percent shall be awarded for projects in historically disadvantaged communities or areas of persistent poverty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multimodal and geographical considerations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In selecting projects to receive grants under the program, the Secretary shall take into consideration geographical and modal diversity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb07f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Planning.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb07f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amounts made available to carry out the program for each fiscal year, not less than 5 percent shall be made available for the planning, preparation, or design of eligible projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability of certain limitations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subparagraphs (A) and (B) of subsection (c)(2) shall not apply with respect to amounts made available for planning, preparation, or design under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb07f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amounts made available to carry out the program for each fiscal year, the Secretary may transfer not more than 2 percent for a fiscal year to the Administrator of any of the Federal Highway Administration, the Federal Transit Administration, the Federal Railroad Administration, or the Maritime Administration to award and oversee grants and credit assistance in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb07f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit Program Costs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb07f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to paragraph (2), at the request of an eligible entity, the Secretary may use a grant provided to the eligible entity under the program to pay the subsidy or credit risk premium, and the administrative costs, of an eligible project that is eligible for Federal credit assistance under—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb07f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/i/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 224; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb07f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/i/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" chapter 6 of title 23.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than 20 percent of the funds made available to carry out the program for a fiscal year may be used to carry out paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb07fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to carry out this section $1,500,000,000 for each of fiscal years 2022 through 2026, to remain available for a period of 3 fiscal years following the fiscal year for which the amounts are appropriated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb07fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb07fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make available on the website of the Department of Transportation at the end of each fiscal year an annual report that describes each eligible project for which a grant was provided under the program during that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb07fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comptroller general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date on which the initial grants are awarded for eligible projects under the program, the Comptroller General of the United States shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb07ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/k/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" review the administration of the program, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcadb0800-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/k/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the solicitation process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcadb0801-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/k/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the selection process, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcadb0802-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/k/2/A/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy and fairness of the process; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcadb0803-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/k/2/A/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection criteria; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb0804-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6702/k/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report describing the findings of the review under subparagraph (A), including recommendations for improving the administration of the program, if any.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcadb0805-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI/s21202/a"},"text":"Pub. L. 117–58, div. B, title I, § 21202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/671"},"text":"135 Stat. 671","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/146/s21/a"},"text":"Pub. L. 117–146, § 21(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-06-16"},"text":"June 16, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/1284"},"text":"136 Stat. 1284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcadb0806-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcadb0807-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcadb0808-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in subsec. (a)(1)(A), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcadb0809-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/146"},"text":"Pub. L. 117–146","children":[],"tail":" designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
