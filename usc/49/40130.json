{"tag":"section","attrib":{"id":"idcbb6733e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40130"},"text":null,"children":[{"tag":"num","attrib":{"value":"40130"},"text":"§ 40130.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" FAA authority to conduct criminal history record checks","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbb6733f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40130/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal History Background Checks.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbb67340-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40130/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Federal Aviation Administration, for certification purposes of the Administration only, is authorized—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbb67341-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40130/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct, in accordance with the established request process, a criminal history background check of an airman in the criminal repositories of the Federal Bureau of Investigation and States by submitting positive identification of the airman to a fingerprint-based repository in compliance with section 217 of the National Crime Prevention and Privacy Compact Act of 1998 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t34/s40316"},"text":"34 U.S.C. 40316","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbb67342-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40130/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to receive relevant criminal history record information regarding the airman checked.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb67343-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40130/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Release of information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In accessing a repository referred to in paragraph (1), the Administrator shall be subject to the conditions and procedures established by the Department of Justice or the State, as appropriate, for other governmental agencies conducting background checks for noncriminal justice purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb67344-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40130/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may not use the authority under paragraph (1) to conduct criminal investigations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb67345-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40130/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may collect reimbursement to process the fingerprint-based checks under this subsection, to be used for expenses incurred, including Federal Bureau of Investigation fees, in providing these services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb67346-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40130/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designated Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall designate, by order, employees of the Administration who may carry out the authority described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbb67347-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tVIII/s802/a"},"text":"Pub. L. 112–95, title VIII, § 802(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/118"},"text":"126 Stat. 118","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tXI/s1101/h"},"text":"Pub. L. 118–63, title XI, § 1101(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1413"},"text":"138 Stat. 1413","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbb67348-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbb67349-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbb6734a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t34/s40316"},"text":"34 U.S.C. 40316","children":[],"tail":")” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s14616"},"text":"42 U.S.C. 14616","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
