{"tag":"section","attrib":{"id":"idcad8be42-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501"},"text":null,"children":[{"tag":"num","attrib":{"value":"6501"},"text":"§ 6501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual modal research plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad8be43-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modal Plans Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8be44-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than June 1 of each year, the head of each modal administration and joint program office of the Department of Transportation shall prepare and submit to the Assistant Secretary for Research and Technology of the Department of Transportation (referred to in this chapter as the “Assistant Secretary”)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8be45-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comprehensive annual modal research plan for the following fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be46-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a detailed outlook for the fiscal year thereafter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be47-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each plan under paragraph (1) shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8be48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a general description of the strategic goals of the Department that are addressed by the research programs being carried out by the Assistant Secretary or modal administration, as applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of each proposed research program, as described in the budget request submitted by the Secretary of Transportation to the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1108"},"text":"section 1108 of title 31","children":[],"tail":" for the following fiscal year, including—"}],"tail":null},{"tag":"clause","attrib":{"id":"idcad8be4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the major objectives of the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be4b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requested amount of funding for each program and area;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of activities the Assistant Secretary or modal administration plans to carry out under the research programs described in subparagraph (B);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of the potential impact of the research programs described in subparagraph (B), including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcad8be4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential outputs, outcomes, and impacts on technologies and practices used by entities subject to the jurisdiction of the modal administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential effects on applicable regulations of the modal administration, including the modification or modernization of those regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" potential economic or societal impacts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" progress made toward achieving strategic goals of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcad8be52-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/D/iv/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable modal administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcad8be53-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/D/iv/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be54-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of potential partnerships to be established to conduct the research program, including partnerships with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcad8be55-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be56-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private sector entities; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be57-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such other requirements as the Assistant Secretary considers to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be58-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to strategic plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each plan prepared or submitted under paragraph (1), after the plan required in 2016, shall be consistent with the strategic plan developed under section 6503.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8be59-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8be5a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than September 1 of each year, the Assistant Secretary, for each plan and outlook submitted by the head of a modal administration or joint program office pursuant to subsection (a), shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8be5b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the scope of the research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be5c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcad8be5d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve the plan and outlook; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" request that the plan and outlook be—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcad8be5f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revised in accordance with such suggestions as the Assistant Secretary shall include to ensure conformity with the criteria described in paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcad8be60-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resubmitted to the Assistant Secretary for approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be61-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting a review under paragraph (1)(A), the Assistant Secretary shall, with respect to the modal research plan that is the subject of the review—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8be62-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" take into consideration whether—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcad8be63-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plan contains research objectives that are consistent with the strategic research and policy objectives of the Department of Transportation included in the strategic plan required under section 6503; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be64-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research programs described in the plan have the potential to benefit the safety, mobility, and efficiency of the United States transportation system;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be65-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and evaluate any potential opportunities for collaboration between or among modal administrations with respect to particular research programs described in the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be66-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and evaluate whether other modal administrations may be better suited to carry out the research programs described in the plan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be67-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" assess whether any projects described in the plan are—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcad8be68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" duplicative across modal administrations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unnecessary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take into consideration such other criteria as the Assistant Secretary determines to be necessary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be6b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than January 30 of each year, the Secretary shall publish on a public website each plan and outlook that has been approved under paragraph (1)(B)(i).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rejection of duplicative research efforts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Assistant Secretary may not approve any plan submitted by the head of a modal administration or joint program office pursuant to subsection (a) if any of the projects described in the plan duplicate significant aspects of research efforts of any other modal administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection limits the ability of the head of a modal administration to comply with applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8be6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No funds may be expended by the Department of Transportation on research that has been determined by the Assistant Secretary under subsection (b)(4) to be duplicative unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8be6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research is required by an Act of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research was part of a contract that was funded before the date of enactment of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be71-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the research updates previously commissioned research; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Assistant Secretary certifies to Congress that such research is necessary, and provides justification for such certification.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8be73-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8be74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall annually certify to Congress that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8be75-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each modal research plan has been reviewed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be76-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is no duplication of study for research directed, commissioned, or conducted by the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be77-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corrective action plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary, after submitting a certification under paragraph (1), identifies duplication of research within the Department of Transportation, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8be78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify Congress of the duplicative research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6501/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress a corrective action plan to eliminate the duplicative research.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad8be7a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVI/s6019/b/1"},"text":"Pub. L. 114–94, div. A, title VI, § 6019(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1578"},"text":"129 Stat. 1578","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tV/s25015/a"},"text":"Pub. L. 117–58, div. B, title V, § 25015(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/870"},"text":"135 Stat. 870","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad8be7b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad8be7c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcad8be7d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this chapter, referred to in subsec. (c)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcad8be7e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25015/a/1/A"},"text":"Pub. L. 117–58, § 25015(a)(1)(A)","children":[],"tail":", added par. (1) and struck out former par. (1). Prior to amendment, text read as follows: “Not later than May 1 of each year, the head of each modal administration and joint program office of the Department of Transportation shall submit to the Assistant Secretary for Research and Technology of the Department of Transportation (referred to in this chapter as the ‘Assistant Secretary’) a comprehensive annual modal research plan for the upcoming fiscal year and a detailed outlook for the following fiscal year.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25015/a/1/D"},"text":"Pub. L. 117–58, § 25015(a)(1)(D)","children":[],"tail":", added par. (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25015/a/1/B"},"text":"Pub. L. 117–58, § 25015(a)(1)(B)","children":[],"tail":", inserted “prepared or” before “submitted”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25015/a/1/C"},"text":"Pub. L. 117–58, § 25015(a)(1)(C)","children":[],"tail":", redesignated par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25015/a/2/A/i"},"text":"Pub. L. 117–58, § 25015(a)(2)(A)(i)","children":[],"tail":", inserted “by the head of a modal administration or joint program office” after “submitted” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25015/a/2/A/ii"},"text":"Pub. L. 117–58, § 25015(a)(2)(A)(ii)","children":[],"tail":", added cl. (ii) and struck out former cl. (ii) which read as follows: “request that the plan and outlook be revised and resubmitted for approval.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25015/a/2/B"},"text":"Pub. L. 117–58, § 25015(a)(2)(B)","children":[],"tail":", (C), added par. (2) and redesignated former pars. (2) and (3) as (3) and (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25015/a/2/D"},"text":"Pub. L. 117–58, § 25015(a)(2)(D)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25015/a/3"},"text":"Pub. L. 117–58, § 25015(a)(3)","children":[],"tail":", which directed amendment without providing closing quotation marks designating the provisions to be inserted, was executed by substituting “subsection (b)(4)” for “subsection (b)(3)” in introductory provisions, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcad8be7f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcad8be80-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcad8be81-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVI/s6019/a"},"text":"Pub. L. 114–94, div. A, title VI, § 6019(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1577"},"text":"129 Stat. 1577","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tVI/s6019/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Federal transportation research planning—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should be coordinated by the Office of the Secretary [of Transportation]; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" should be, to the extent practicable, multimodal and not occur solely within the sub-agencies of the Department [of Transportation];","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" managing a multimodal research portfolio within the Office of the Secretary will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" help identify opportunities in which research could be applied across modes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent duplication of efforts and waste of limited Federal resources;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Assistant Secretary for Research and Technology at the Department of Transportation will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give stakeholders a formal opportunity to address concerns;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure unbiased research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve the overall research products of the Department; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" increasing transparency of transportation research and development efforts will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" build stakeholder confidence in the final product; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lead to the improved implementation of research findings.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
