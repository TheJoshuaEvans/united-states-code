{"tag":"section","attrib":{"id":"idcc373d27-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46102"},"text":null,"children":[{"tag":"num","attrib":{"value":"46102"},"text":"§ 46102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc373d28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conducting Proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subchapter II of chapter 5 of title 5, the Secretary of Transportation (or the Administrator of the Transportation Security Administration with respect to security duties and powers designated to be carried out by the Administrator of the Transportation Security Administration or the Administrator of the Federal Aviation Administration with respect to aviation safety duties and powers designated to be carried out by the Administrator of the Federal Aviation Administration) may conduct proceedings in a way conducive to justice and the proper dispatch of business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373d29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appearance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may appear and be heard before the Secretary, the Administrator of the Transportation Security Administration, and the Administrator of the Federal Aviation Administration in person or by an attorney. The Secretary may appear and participate as an interested party in a proceeding the Administrator of the Federal Aviation Administration conducts under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40113/a"},"text":"section 40113(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373d2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recording and Public Access","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Official action taken by the Secretary, Administrator of the Transportation Security Administration, and Administrator of the Federal Aviation Administration under this part shall be recorded. Proceedings before the Secretary, Administrator of the Transportation Security Administration, and Administrator of the Federal Aviation Administration shall be open to the public on the request of an interested party unless the Secretary, Administrator of the Transportation Security Administration, or Administrator of the Federal Aviation Administration decides that secrecy is required because of national defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373d2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conflicts of Interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, the Administrator of the Transportation Security Administration, the Administrator of the Federal Aviation Administration, or an officer or employee of the Federal Aviation Administration may not participate in a proceeding referred to in subsection (a) of this section in which the individual has a pecuniary interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc373d2c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1226"},"text":"108 Stat. 1226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s140/b/1"},"text":"Pub. L. 107–71, title I, § 140(b)(1)","children":[],"tail":", (2), (4)–(6), "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/641"},"text":"115 Stat. 641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/f/1"},"text":"Pub. L. 115–254, div. K, title I, § 1991(f)(1)","children":[],"tail":"–(5), "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3642"},"text":"132 Stat. 3642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc373d2d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc373d2e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc373d2f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{