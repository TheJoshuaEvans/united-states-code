{"tag":"section","attrib":{"id":"idcc398662-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46107"},"text":null,"children":[{"tag":"num","attrib":{"value":"46107"},"text":"§ 46107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by the Attorney General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc398663-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions To Enforce Section","children":[],"tail":" 40106(b).—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General may bring a civil action in a district court of the United States against a person to enforce ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40106/b"},"text":"section 40106(b) of this title","children":[],"tail":". The action may be brought in the judicial district in which the person does business or the violation occurred."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc398664-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions To Enforce This Part","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc398665-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46107/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On request of the Secretary of Transportation (or the Administrator of the Transportation Security Administration with respect to security duties and powers designated to be carried out by the Administrator of the Transportation Security Administration or the Administrator of the Federal Aviation Administration with respect to aviation safety duties and powers designated to be carried out by the Administrator of the Federal Aviation Administration), the Attorney General may bring a civil action in an appropriate court—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc398666-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46107/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enforce this part or a requirement or regulation prescribed, or an order or any term of a certificate or permit issued, under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc398667-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46107/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prosecute a person violating this part or a requirement or regulation prescribed, or an order or any term of a certificate or permit issued, under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc398668-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46107/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The costs and expenses of a civil action shall be paid out of the appropriations for the expenses of the courts of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc398669-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation of Secretary, Administrator of the Transportation Security Administration, or Administrator of the Federal Aviation Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On request of the Attorney General, the Secretary, Administrator of the Transportation Security Administration, or Administrator of the Federal Aviation Administration, as appropriate, may participate in a civil action under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc39866a-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1229"},"text":"108 Stat. 1229","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s140/b/1"},"text":"Pub. L. 107–71, title I, § 140(b)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/641"},"text":"115 Stat. 641","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/f/1"},"text":"Pub. L. 115–254, div. K, title I, § 1991(f)(1)","children":[],"tail":"–(4), "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3642"},"text":"132 Stat. 3642","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc39866b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc39866c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc39866d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":