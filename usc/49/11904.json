{"tag":"section","attrib":{"id":"idcaf08bea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11904"},"text":null,"children":[{"tag":"num","attrib":{"value":"11904"},"text":"§ 11904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful disclosure of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf08beb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf08bec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rail carrier providing transportation subject to the jurisdiction of the Board under this part, or an officer, agent, or employee of that rail carrier, or another person authorized to receive information from that rail carrier, that knowingly discloses to another person, except the shipper or consignee; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08bed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" person who solicits or knowingly receives,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"information described in subsection (b) without the consent of the shipper or consignee shall be fined not more than $1,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf08bee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The information referred to in subsection (a) is information about the nature, kind, quantity, destination, consignee, or routing of property tendered or delivered to that rail carrier for transportation provided under this part, or information about the contents of a contract authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10709"},"text":"section 10709 of this title","children":[],"tail":", that may be used to the detriment of the shipper or consignee or may disclose improperly, to a competitor, the business transactions of the shipper or consignee."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf08bef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This part does not prevent a rail carrier providing transportation subject to the jurisdiction of the Board under this part from giving information—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf08bf0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in response to legal process issued under authority of a court of the United States or a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08bf1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an officer, employee, or agent of the United States Government, a State, or a territory or possession of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08bf2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11904/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to another rail carrier or its agent to adjust mutual traffic accounts in the ordinary course of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf08bf3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An employee of the Board delegated to make an inspection or examination under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11144"},"text":"section 11144 of this title","children":[],"tail":" who knowingly discloses information acquired during that inspection or examination, except as directed by the Board, a court, or a judge of that court, shall be fined not more than $500, imprisoned for not more than 6 months, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf08bf4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11904/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person that knowingly discloses confidential data made available to such person under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11163"},"text":"section 11163 of this title","children":[],"tail":" by a rail carrier providing transportation subject to the jurisdiction of the Board under this part shall be fined not more than $50,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf08bf5-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/851"},"text":"109 Stat. 851","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/6"},"text":"Pub. L. 105–102, § 2(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2204"},"text":"111 Stat. 2204","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf08bf6-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcaf08bf7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcaf08bf8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:11904(a)(2) to correct a grammatical error.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf08bf9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf08bfa-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11910"},"text":"section 11910 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A prior section 11904, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1457"},"text":"92 Stat. 1457","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/521/s13/a"},"text":"Pub. L. 99–521, § 13(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2998"},"text":"100 Stat. 2998","children":[],"tail":", related to additional rate and discrimination violations, prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s14904"},"text":"section 14904 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcaf08bfb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" struck out “a” before “person”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaf08bfc-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcaf08bfd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
