{"tag":"section","attrib":{"id":"idcad191ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5564"},"text":null,"children":[{"tag":"num","attrib":{"value":"5564"},"text":"§ 5564.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interim preservation of certain rail passenger terminals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad191ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5564/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Grant Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (b) of this section, the Secretary of Transportation may make a grant of financial assistance to a responsible person (including a governmental authority) to preserve a rail passenger terminal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5562/a/2"},"text":"section 5562(a)(2) of this title","children":[],"tail":". To receive assistance under this section, the person must be qualified, prepared, committed, and authorized by law to maintain (and prevent the demolition, dismantling, or further deterioration of) the terminal until plans for its reuse are prepared."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad191ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5564/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may make a grant of financial assistance under this section only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad191f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5564/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary decides the rail passenger terminal has a reasonable likelihood of being converted to, or conditioned for reuse as, an intermodal transportation terminal, a civic or cultural activities center, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad191f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5564/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" planning activity directed toward conversion or reuse has begun and is proceeding in a competent way.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad191f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5564/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximizing Preservation of Terminals","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad191f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5564/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts appropriated to carry out this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5562/a/2"},"text":"section 5562(a)(2) of this title","children":[],"tail":" shall be expended in the way most likely to maximize the preservation of rail passenger terminals that are—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad191f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5564/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably capable of conversion to intermodal transportation terminals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad191f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5564/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" listed in the National Register of Historic Places maintained by the Secretary of the Interior; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad191f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5564/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended (on the basis of architectural integrity and quality) by the Advisory Council on Historic Preservation or the Chairman of the National Endowment for the Arts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad191f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5564/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation may not make a grant under this section for more than 80 percent of the total cost of maintaining the terminal for an interim period of not more than 5 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad191f8-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/852"},"text":"108 Stat. 852","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad191f9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcad191fa-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcad191fb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5564(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1653(i)(3) (1st sentence words before proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670"},"text":"Pub. L. 89–670","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/931"},"text":"80 Stat. 931","children":[],"tail":", § 4(i)(3); added "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/496"},"text":"Pub. L. 93–496","children":[],"tail":", §§ 6, 15, "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1529"},"text":"88 Stat. 1529","children":[],"tail":", 1533; "},{"tag":"html:span","attrib":{},"text":"Oct. 5, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/421/s14"},"text":"Pub. L. 95–421, § 14","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/929"},"text":"92 Stat. 929","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5564(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1653(i)(3) (1st sentence proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5564(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1653(i)(3) (2d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Subject to subsection (b) of this section” are added for clarity. The word “authority” is substituted for “entity” for consistency in the revised title. The words “in accordance with regulations” and “applicable” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words before clause (1) are substituted for “","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That” for clarity and consistency in the revised title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “The Secretary of Transportation may not make a grant” are substituted for “The amount of the Federal share of any grant . . . shall not exceed” for clarity and consistency in this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
