{"tag":"section","attrib":{"id":"idcb250908-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22406"},"text":null,"children":[{"tag":"num","attrib":{"value":"22406"},"text":"§ 22406.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations.","children":[{"tag":"ref","attrib":{"idref":"fn002079"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002079"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The period probably should not appear."}],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"idcb250909-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22406/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb25090a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22406/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated for credit assistance under this chapter, which shall be provided at the discretion of the Secretary, $50,000,000 for each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb25090b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22406/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Refund of premium","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary $70,000,000 to repay the credit risk premium in accordance with section 22402(f)(5).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb25090c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22406/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts appropriated pursuant to this subsection shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb25090d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22406/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb25090e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22406/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Credit assistance provided under subsection (a) may not exceed $20,000,000 for any loan or loan guarantee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb25090f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22406/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less than 3 percent of the amounts appropriated pursuant to subsection (a) in each fiscal year shall be made available to the Secretary for use in place of charges collected under section 22403(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(1) for passenger railroads and freight railroads other than Class I carriers."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb250910-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22406/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Short line set-aside","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not less than 50 percent of the amounts appropriated pursuant to subsection (a)(1) for each fiscal year shall be set aside for freight railroads other than Class I carriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb250911-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI/s21301/h"},"text":"Pub. L. 117–58, div. B, title I, § 21301(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/690"},"text":"135 Stat. 690","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
