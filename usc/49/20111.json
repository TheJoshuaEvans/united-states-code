{"tag":"section","attrib":{"id":"idcb0d14ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111"},"text":null,"children":[{"tag":"num","attrib":{"value":"20111"},"text":"§ 20111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by the Secretary of Transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb0d14f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusive Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation has exclusive authority—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0d14f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to impose and compromise a civil penalty for a violation of a railroad safety regulation prescribed or order issued by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0d14f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20113"},"text":"section 20113 of this title","children":[],"tail":", to request an injunction for a violation of a railroad safety regulation prescribed or order issued by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0d14f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recommend appropriate action be taken under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20112/a"},"text":"section 20112(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0d14f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance Orders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may issue an order directing compliance with this part or with a railroad safety regulation prescribed or order issued under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0d14f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Orders Prohibiting Individuals From Performing Safety-Sensitive Functions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0d14f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If an individual’s violation of this part, chapter 51 of this title, or a regulation prescribed, or an order issued, by the Secretary under this part or chapter 51 of this title is shown to make that individual unfit for the performance of safety-sensitive functions, the Secretary, after providing notice and an opportunity for a hearing, may issue an order prohibiting the individual from performing safety-sensitive functions in the railroad industry for a specified period of time or until specified conditions are met.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0d14f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not affect the Secretary’s authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20104"},"text":"section 20104 of this title","children":[],"tail":" to act on an emergency basis."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0d14f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations Requiring Reporting of Remedial Actions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0d14f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall prescribe regulations to require that a railroad carrier notified by the Secretary that imposition of a civil penalty will be recommended for a failure to comply with this part, chapter 51 or 57 of this title, or a regulation prescribed or order issued under any of those provisions, shall report to the Secretary, not later than the 30th day after the end of the month in which the notification is received—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0f84fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actions taken to remedy the failure; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f84fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate remedial actions cannot be taken by that 30th day, an explanation of the reasons for the delay.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f84fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0f84fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"1993-06-03"},"text":"June 3, 1993","children":[],"tail":", shall issue a notice of a regulatory proceeding for proposed regulations to carry out this subsection; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f84fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20111/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"1994-09-03"},"text":"September 3, 1994","children":[],"tail":", shall prescribe final regulations to carry out this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0f84ff-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tai