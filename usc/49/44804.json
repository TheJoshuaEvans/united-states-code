{"tag":"section","attrib":{"id":"idcc15d130-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44804"},"text":null,"children":[{"tag":"num","attrib":{"value":"44804"},"text":"§ 44804.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unmanned aircraft in the Arctic","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc15d131-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44804/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall develop a plan and initiate a process to work with relevant Federal agencies and national and international communities to designate permanent areas in the Arctic where unmanned aircraft may operate 24 hours per day for research and commercial purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d132-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44804/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan Contents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The plan under subsection (a) shall include the development of processes to facilitate the safe operation of unmanned aircraft beyond the visual line of sight.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d133-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44804/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each permanent area designated under subsection (a) shall enable over-water flights from the surface to at least 2,000 feet in altitude, with ingress and egress routes from selected coastal launch sites.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d134-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44804/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To implement the plan under subsection (a), the Secretary may enter into an agreement with relevant national and international communities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d135-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44804/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aircraft Approval.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc15d136-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44804/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), not later than 1 year after the entry into force of an agreement necessary to effectuate the purposes of this section, the Secretary shall work with relevant national and international communities to establish and implement a process for approving the use of a unmanned aircraft in the designated permanent areas in the Arctic without regard to whether the unmanned aircraft is used as a public aircraft, a civil aircraft, or a model aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d137-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44804/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may implement an existing process to meet the requirements under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc15d138-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIII/s344/a"},"text":"Pub. L. 115–254, div. B, title III, § 344(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3290"},"text":"132 Stat. 3290","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIX/s902/a"},"text":"Pub. L. 118–63, title IX, § 902(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1341"},"text":"138 Stat. 1341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc15d139-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc15d13a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcc15d13b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s332/d"},"text":"section 332(d) of Pub. L. 112–95","children":[],"tail":", which was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40101"},"text":"section 40101 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIII/s341/b/2"},"text":"Pub. L. 115–254, div. B, title III, § 341(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3287"},"text":"132 Stat. 3287","children":[],"tail":". The remainder of the note comprised of subtitle B of title III of "},{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":" was transferred and is set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44802"},"text":"section 44802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc15d13c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s902/a/1"},"text":"Pub. L. 118–63, § 902(a)(1)","children":[],"tail":", substituted “Unmanned” for “Small unmanned” in section catchline. Catchline was editorially conformed to the style used in this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b), (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s902/a/2"},"text":"Pub. L. 118–63, § 902(a)(2)","children":[],"tail":", struck out “small” before “unmanned aircraft” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
