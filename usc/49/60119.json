{"tag":"section","attrib":{"id":"idcc81165c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60119"},"text":null,"children":[{"tag":"num","attrib":{"value":"60119"},"text":"§ 60119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc81165d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60119/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Regulations, Orders, and Other Final Agency Actions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc81165e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60119/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (b) of this section, a person adversely affected by a regulation prescribed under this chapter or an order issued under this chapter may apply for review of the regulation or order by filing a petition for review in the United States Court of Appeals for the District of Columbia Circuit or in the court of appeals of the United States for the circuit in which the person resides or has its principal place of business. The petition must be filed not later than 89 days after the regulation is prescribed or order is issued. The clerk of the court immediately shall send a copy of the petition to the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc81165f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60119/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A judgment of a court under paragraph (1) of this subsection may be reviewed only by the Supreme Court under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254"},"text":"section 1254 of title 28","children":[],"tail":". A remedy under paragraph (1) is in addition to any other remedies provided by law."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc811660-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60119/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A judicial review of agency action under this section shall apply the standards of review established in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706"},"text":"section 706 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc811661-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60119/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review of Financial Responsibility Orders","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc811662-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60119/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person adversely affected by an order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s60111"},"text":"section 60111 of this title","children":[],"tail":" may apply for review of the order by filing a petition for review in the appropriate court of appeals of the United States. The petition must be filed not later than 60 days after the order is issued. Findings of fact the Secretary makes are conclusive if supported by substantial evidence."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc811663-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60119/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A judgment of a court under paragraph (1) of this subsection may be reviewed only by the Supreme Court under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1254/1"},"text":"section 1254(1) of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc811664-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1323"},"text":"108 Stat. 1323","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/90"},"text":"Pub. L. 112–90","children":[],"tail":", §§ 2(d), 20(b), "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1905"},"text":"125 Stat. 1905","children":[],"tail":", 1917.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc811665-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc811666-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc811667-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{