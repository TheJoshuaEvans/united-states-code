{"tag":"section","attrib":{"id":"idcb7d3bff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310"},"text":null,"children":[{"tag":"num","attrib":{"value":"32310"},"text":"§ 32310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" New Car Assessment Program roadmap","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb7d3c00-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, and not less frequently than once every 4 years thereafter, the Secretary of Transportation (referred to in this section as the “Secretary”) shall establish a roadmap for the implementation of the New Car Assessment Program of the National Highway Traffic Safety Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3c01-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A roadmap under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3c02-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" cover a term of 10 years, consisting of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7d3c03-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a mid-term component covering the initial 5 years of the term; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3c04-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a long-term component covering the final 5 years of the term; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c05-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be in accordance with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7d3c06-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3c07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115"},"text":"section 1115 of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3c08-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 24401 of the FAST Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s105"},"text":"49 U.S.C. 105","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Public Law 114–94","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3c09-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant plans of the National Highway Traffic Safety Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3c0a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A roadmap under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3c0b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a plan for any changes to the New Car Assessment Program of the National Highway Traffic Safety Administration, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7d3c0c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" descriptions of actions to be carried out to update the passenger motor vehicle information developed under section 32302(a), including the development of test procedures, test devices, test fixtures, and safety performance metrics, which shall, as applicable, incorporate—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb7d3c0d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" objective criteria for evaluating safety technologies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb7d3c0e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable time periods for compliance with new or updated tests;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3c0f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" key milestones, including the anticipated start of an action, completion of an action, and effective date of an update; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3c10-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" descriptions of the means by which an update will improve the passenger motor vehicle information developed under section 32302(a);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c11-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an identification and prioritization of safety opportunities and technologies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7d3c12-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to the mid-term component of the roadmap under subsection (b)(1)(A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb7d3c13-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb7d3c14-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which objective rating tests, evaluation criteria, and other consumer data exist for a market-based, consumer information approach; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3c15-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the long-term component of the roadmap under subsection (b)(1)(B), exist or are in development;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c16-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an identification of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7d3c17-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any safety opportunity or technology that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb7d3c18-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is identified through the activities carried out pursuant to subsection (d) or (e); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb7d3c19-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not included in the roadmap under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3c1a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons why such a safety opportunity or technology is not included in the roadmap; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3c1b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any developments or information that would be necessary for the Secretary to consider including such a safety opportunity or technology in a future roadmap; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c1c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" consideration of the benefits of consistency with other rating systems used—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7d3c1d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3c1e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" internationally.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3c1f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before finalizing a roadmap under this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3c20-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make the roadmap available for public comment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c21-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review any public comments received under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c22-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate in the roadmap under this section those comments, as the Secretary determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3c23-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stakeholder Engagement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not less frequently than annually, the Secretary shall engage stakeholders that represent a diversity of technical backgrounds and viewpoints—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7d3c24-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to identify—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7d3c25-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" safety opportunities or technologies in development that could be included in future roadmaps; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7d3c26-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" opportunities to benefit from collaboration or harmonization with third-party safety rating programs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c27-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assist with long-term planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide an interim update of the status and development of the following roadmap to be established under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7d3c29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32310/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect feedback or other information that the Secretary determines to be relevant to enhancing the New Car Assessment Program of the National Highway Traffic Safety Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb7d3c2a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tIV/s24213/c/1"},"text":"Pub. L. 117–58, div. B, title IV, § 24213(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/827"},"text":"135 Stat. 827","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb7d3c2b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb7d3c2c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb7d3c2d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
