{"tag":"section","attrib":{"id":"idcbbb2e44-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41111"},"text":null,"children":[{"tag":"num","attrib":{"value":"41111"},"text":"§ 41111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Simplified procedure to apply for, amend, modify, suspend, and transfer certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbbb2e45-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbb2e46-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation shall prescribe regulations that simplify the procedure for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbbb2e47-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41111/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acting on an application for a certificate to provide air transportation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbb2e48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41111/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amending, modifying, suspending, or transferring any part of that certificate under section 41105 or 41110(a) or (c) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbb2e49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Regulations under this section shall provide for notice and an opportunity for each interested person to file appropriate written evidence and argument. An oral evidentiary hearing is not required to be provided under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbb2e4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"When Simplified Procedure Used","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may use the simplified procedure to act on an application for a certificate to provide air transportation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":", or to amend, modify, suspend, or transfer any part of that certificate under section 41105 or 41110(a) or (c) of this title, when the Secretary decides the use of the procedure is in the public interest."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbb2e4b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbb2e4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41111/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the extent the Secretary finds practicable, regulations under this section shall include each standard the Secretary will apply when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbbb2e4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41111/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deciding whether to use the simplified procedure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbb2e4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41111/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making a decision on an action in which the procedure is used.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbb2e4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41111/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The regulations may provide that written evidence and argument may be filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41108/b"},"text":"section 41108(b) of this title","children":[],"tail":" as a part of a response opposing or supporting the issuance of a certificate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbbb2e50-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1125"},"text":"108 Stat. 1125","children":[],"tail":".)"}],"tail":"\n"},{"tag