{"tag":"section","attrib":{"id":"idcb11f680-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20149"},"text":null,"children":[{"tag":"num","attrib":{"value":"20149"},"text":"§ 20149.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Coordination with the Department of Labor","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation shall consult with the Secretary of Labor on a regular basis to ensure that all applicable laws affecting safe working conditions for railroad employees are appropriately enforced to ensure a safe and productive working environment for the railroad industry.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb11f681-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/440/tII/s213/a"},"text":"Pub. L. 103–440, title II, § 213(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4623"},"text":"108 Stat. 4623","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
