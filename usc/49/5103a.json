{"tag":"section","attrib":{"id":"idca8a01af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a"},"text":null,"children":[{"tag":"num","attrib":{"value":"5103a"},"text":"§ 5103a.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on issuance of hazmat licenses","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8a01b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8a01b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance of licenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State may not issue to any individual a license to operate a motor vehicle transporting in commerce a hazardous material unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8a01b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “the Secretary of Homeland Security”; ","children":[{"tag":"ref","attrib":{"idref":"fn002026"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002026"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The quotation marks and semicolon probably should not appear."}],"tail":" has first determined, upon receipt of a notification under subsection (d)(1)(B), that the individual does not pose a security risk warranting denial of the license; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8a01b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual holds a valid transportation security card issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70105"},"text":"section 70105 of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a01b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Renewals included","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of this section, the term “issue”, with respect to a license, includes renewal of the license.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a01b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hazardous Materials Described","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitation in subsection (a) shall apply with respect to any material defined as hazardous material by the Secretary of Transportation for which the Secretary of Transportation requires placarding of a commercial motor vehicle transporting that material in commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a01b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations on Chemical and Biological Materials","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Health and Human Services shall recommend to the Secretary of Transportation any chemical or biological material or agent for regulation as a hazardous material under section 5103(a) if the Secretary of Health and Human Services determines that such material or agent poses a significant risk to the health of individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a01b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Background Records Check.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8a01b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Upon the request of a State regarding issuance of a license under subsection (a)(1)(A) to an individual, the Attorney General—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8a01b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall carry out a background records check regarding the individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8a01ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon completing the background records check, shall notify the Secretary of Homeland Security of the completion and results of the background records check.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a01bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scope","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A background records check regarding an individual under this subsection shall consist of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8a01bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A check of the relevant criminal history data bases.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8a01bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of an alien, a check of the relevant data bases to determine the status of the alien under the immigration laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8a01be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As appropriate, a check of the relevant international data bases through Interpol–U.S. National Central Bureau or other appropriate means.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a01bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State shall submit to the Secretary of Homeland Security, at such time and in such manner as the Secretary of Homeland Security may prescribe, the name, address, and such other information as the Secretary of Homeland Security may require, concerning—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8a01c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each alien to whom the State issues a license described in subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a01c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each other individual to whom such a license is issued, as the Secretary of Homeland Security may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a01c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alien Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “alien” has the meaning given the term in section 101(a)(3) of the Immigration and Nationality Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a01c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Background Checks for Drivers Hauling Hazardous Materials.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8a01c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8a01c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employer notification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of enactment of this subsection, the Director of the Transportation Security Administration, after receiving comments from interested parties, shall develop and implement a process for notifying hazmat employers designated by an applicant of the results of the applicant’s background record check, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca8a01c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such notification is appropriate considering the potential security implications; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8a01c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director, in a final notification of threat assessment,","children":[{"tag":"ref","attrib":{"idref":"fn002027"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002027"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Comma probably should appear after “applicant”."}],"tail":" served on the applicant "},{"tag":"ref","attrib":{"idref":"fn002027"},"text":"2","children":[],"tail":" determines that the applicant does not meet the standards set forth in regulations issued to carry out this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8a01c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to other background records checks.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idca8a01c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elimination of redundant checks","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual with respect to whom the Transportation Security Administration—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca8a01ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/1/B/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has performed a security threat assessment under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca8a01cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/1/B/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has issued a final notification of no security threat,","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":" is deemed to have met the requirements of any other background check that is required for purposes of any Federal law applicable to transportation workers if that background check is equivalent to, or less stringent than, the background check required under this section.","children":[],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8a01cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination by director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date of issuance of the report under paragraph (5), but no later than 120 days after the date of enactment of this subsection, the Director shall initiate a rulemaking proceeding, including notice and opportunity for comment, to determine which background checks required for purposes of Federal laws applicable to transportation workers are equivalent to, or less stringent than, those required under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8a01cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Future rulemakings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall make a determination under the criteria established under clause (ii) with respect to any rulemaking proceeding to establish or modify required background checks for transportation workers initiated after the date of enactment of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a01ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeals process for more stringent state procedures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a State establishes its own standards for applicants for a hazardous materials endorsement to a commercial driver’s license, the State shall also provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8a01cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an appeals process similar to and to the same extent as the process provided under part 1572 of title 49, Code of Federal Regulations, by which an applicant denied a hazardous materials endorsement to a commercial driver’s license by that State may appeal that denial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8a01d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a waiver process similar to and to the same extent as the process provided under part 1572 of title 49, Code of Federal Regulations, by which an applicant denied a hazardous materials endorsement to a commercial driver’s license by that State may apply for a waiver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a01d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Clarification of term defined in regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “transportation security incident”, as defined in part 1572 of title 49, Code of Federal Regulations, does not include a work stoppage or other nonviolent employee-related action resulting from an employer-employee dispute. Not later than 30 days after the date of enactment of this subsection, the Director shall modify the definition of that term to reflect the preceding sentence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a01d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Background check capacity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2005-10-01"},"text":"October 1, 2005","children":[],"tail":", the Director shall transmit to the Committee on Commerce, Science, and Transportation of the Senate and the Committees on Transportation and Infrastructure and Homeland Security of the House of Representatives a report on the implementation of fingerprint-based security threat assessments and the adequacy of fingerprinting locations, personnel, and resources to accomplish the timely processing of fingerprint-based security threat assessments for individuals holding commercial driver’s licenses who are applying to renew hazardous materials endorsements."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a01d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8a01d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date of enactment of this subsection, the Director shall transmit to the committees referred to in paragraph (4) a report on the Director’s plans to reduce or eliminate redundant background checks for holders of hazardous materials endorsements performed under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8a01d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca8a01d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/5/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a list of background checks and other security or threat assessment requirements applicable to transportation workers under Federal laws for which the Department of Homeland Security is responsible and the process by which the Secretary of Homeland Security will determine whether such checks or assessments are equivalent to, or less stringent than, the background check performed under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca8a01d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/g/5/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an analysis of how the Director plans to reduce or eliminate redundant background checks in a manner that will continue to ensure the highest level of safety and security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8a01d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commercial Motor Vehicle Operators Registered to Operate in Mexico or Canada.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8a01d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning on the date that is 6 months after the date of enactment of this subsection, a commercial motor vehicle operator registered to operate in Mexico or Canada shall not operate a commercial motor vehicle transporting a hazardous material in commerce in the United States until the operator has undergone a background records check similar to the background records check required for commercial motor vehicle operators licensed in the United States to transport hazardous materials in commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a01da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director of the Transportation Security Administration may extend the deadline established by paragraph (1) for a period not to exceed 6 months if the Director determines that such an extension is necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8a01db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5103a/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commercial motor vehicle defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “commercial motor vehicle” has the meaning given that term by section 31101.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8a01dc-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/tX/s1012/a/1"},"text":"Pub. L. 107–56, title X, § 1012(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/396"},"text":"115 Stat. 396","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII"},"text":"Pub. L. 109–59, title VII","children":[],"tail":", §§ 7104, 7105, 7126, "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1894"},"text":"119 Stat. 1894","children":[],"tail":", 1909; "},{"tag":"ref","attrib":{"href":"/us/pl/110/53/tXV/s1556/a"},"text":"Pub. L. 110–53, title XV, § 1556(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-08-03"},"text":"Aug. 3, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/475"},"text":"121 Stat. 475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/tIII/s302/b"},"text":"Pub. L. 110–244, title III, § 302(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1618"},"text":"122 Stat. 1618","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1978"},"text":"Pub. L. 115–254, div. K, title I, § 1978","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3618"},"text":"132 Stat. 3618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8a01dd-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8a01de-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca8a01df-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"With respect to a “transportation security card issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s70105"},"text":"section 70105 of title 46","children":[],"tail":"”, referred to in subsec. (a)(1)(B), amendments made by "},{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":" to "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s70105"},"text":"section 70105 of Title 46","children":[],"tail":", Shipping, are such that section 70105 now refers to “transportation worker identification credential” rather than “transportation security card”. See "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s70105"},"text":"section 70105 of Title 46","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 101(a)(3) of the Immigration and Nationality Act, referred to in subsec. (f), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/3"},"text":"section 1101(a)(3) of Title 8","children":[],"tail":", Aliens and Nationality."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to in subsecs. (g) and (h), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca8a01e0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1978/a"},"text":"Pub. L. 115–254, § 1978(a)","children":[],"tail":", substituted “unless—” for “unless”, “(A) ‘the Secretary of Homeland Security’;” for “the Secretary of Homeland Security”, and “; or” for period at end and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1978/b"},"text":"Pub. L. 115–254, § 1978(b)","children":[],"tail":", substituted “under subsection (a)(1)(A)” for “described in subsection (a)(1)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (g)(1)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" substituted “subsection” for “Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s1556/a/1"},"text":"Pub. L. 110–53, § 1556(a)(1)","children":[],"tail":", substituted “Secretary of Homeland Security” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s1556/a/2"},"text":"Pub. L. 110–53, § 1556(a)(2)","children":[],"tail":", substituted “Secretary of Transportation” for “Secretary” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s1556/a/3"},"text":"Pub. L. 110–53, § 1556(a)(3)","children":[],"tail":", substituted “Secretary of Homeland Security” for “Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/53/s1556/a/4"},"text":"Pub. L. 110–53, § 1556(a)(4)","children":[],"tail":", substituted “Secretary of Homeland Security” for “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7104/c"},"text":"Pub. L. 109–59, § 7104(c)","children":[],"tail":", substituted “subsection (d)(1)(B),” for “subsection (c)(1)(B),”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7104/a"},"text":"Pub. L. 109–59, § 7104(a)","children":[],"tail":", substituted “with respect to any material defined as hazardous material by the Secretary for which the Secretary requires placarding of a commercial motor vehicle transporting that material in commerce” for “with respect to—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) any material defined as a hazardous material by the Secretary of Transportation; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) any chemical or biological material or agent determined by the Secretary of Health and Human Services or the Attorney General as being a threat to the national security of the United States”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7104/b/2"},"text":"Pub. L. 109–59, § 7104(b)(2)","children":[],"tail":", added subsec. (c). Former subsec. (c) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7104/b/1"},"text":"Pub. L. 109–59, § 7104(b)(1)","children":[],"tail":", redesignated subsec. (c) as (d). Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “submit to the Secretary” for “submit to the Secretary of Transportation” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7104/b/1"},"text":"Pub. L. 109–59, § 7104(b)(1)","children":[],"tail":", redesignated subsec. (d) as (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7104/b/1"},"text":"Pub. L. 109–59, § 7104(b)(1)","children":[],"tail":", redesignated subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (g), (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7105"},"text":"Pub. L. 109–59, § 7105","children":[],"tail":", added subsecs. (g) and (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca8a01e1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca8a01e2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/tX/s1012/c"},"text":"Pub. L. 107–56, title X, § 1012(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/398"},"text":"115 Stat. 398","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/56/tX/s1012/c"},"text":"“There is authorized to be appropriated for the Department of Transportation and the Department of Justice such amounts as may be necessary to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5103a"},"text":"section 5103a of title 49","children":[],"tail":", United States Code, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
