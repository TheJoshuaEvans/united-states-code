{"tag":"section","attrib":{"id":"idca82d62d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154"},"text":null,"children":[{"tag":"num","attrib":{"value":"1154"},"text":"§ 1154.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discovery and use of cockpit and surface vehicle recordings and transcripts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca82d62e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca82d62f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided by this subsection, a party in a judicial proceeding may not use discovery to obtain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca82d630-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any still image that the National Transportation Safety Board has not made available to the public under section 1114(c) or 1114(d) of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82d631-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any part of a cockpit or surface vehicle recorder transcript that the National Transportation Safety Board has not made available to the public under section 1114(c) or 1114(d) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82d632-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a cockpit or surface vehicle recorder recording.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d633-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca82d634-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (4)(A) of this subsection, a court may allow discovery by a party of a cockpit or surface vehicle recorder transcript if, after an in camera review of the transcript, the court decides that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca82d635-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the part of the transcript made available to the public under section 1114(c) or 1114(d) of this title does not provide the party with sufficient information for the party to receive a fair trial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca82d636-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discovery of additional parts of the transcript is necessary to provide the party with sufficient information for the party to receive a fair trial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82d637-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A court may allow discovery, or require production for an in camera review, of a cockpit or surface vehicle recorder transcript that the Board has not made available under section 1114(c) or 1114(d) of this title only if the cockpit or surface vehicle recorder recording is not available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d638-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (4)(A) of this subsection, a court may allow discovery by a party of a cockpit or surface vehicle recorder recording, including with regard to a video recording any still image that the National Transportation Safety Board has not made available to the public under section 1114(c) or 1114(d) of this title, if, after an in camera review of the recording, the court decides that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca82d639-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parts of the transcript made available to the public under section 1114(c) or 1114(d) of this title and to the party through discovery under paragraph (2) of this subsection do not provide the party with sufficient information for the party to receive a fair trial; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82d63a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" discovery of the cockpit or surface vehicle recorder recording, including with regard to a video recording any still image that the National Transportation Safety Board has not made available to the public under section 1114(c) or 1114(d) of this title, is necessary to provide the party with sufficient information for the party to receive a fair trial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d63b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca82d63c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When a court allows discovery in a judicial proceeding of a still image or a part of a cockpit or surface vehicle recorder transcript not made available to the public under section 1114(c) or 1114(d) of this title or a cockpit or surface vehicle recorder recording, the court shall issue a protective order—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca82d63d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/4/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the use of the still image, the part of the transcript, or the recording to the judicial proceeding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca82d63e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/4/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit dissemination of the still image, the part of the transcript, or the recording to any person that does not need access to the still image, the part of the transcript, or the recording for the proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82d63f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A court may allow a still image or a part of a cockpit or surface vehicle recorder transcript not made available to the public under section 1114(c) or 1114(d) of this title or a cockpit or surface vehicle recorder recording to be admitted into evidence in a judicial proceeding, only if the court places the still image, the part of the transcript, or the recording under seal to prevent the use of the still image, the part of the transcript, or the recording for purposes other than for the proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d640-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not prevent the Board from referring at any time to cockpit or surface vehicle recorder information in making safety recommendations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d641-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca82d642-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recorder","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “recorder” means a voice or video recorder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca82d643-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Still image","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “still image” means any still image obtained from a video recorder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca854644-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transcript","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “transcript” includes any written depiction of visual information obtained from a video recorder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca854645-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1154/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No part of a report of the Board, related to an accident or an investigation of an accident, may be admitted into evidence or used in a civil action for damages resulting from a matter mentioned in the report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca854646-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/757"},"text":"108 Stat. 757","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/424/s5/c/1"},"text":"Pub. L. 106–424, § 5(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1885"},"text":"114 Stat. 1885","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dC/s1104/b"},"text":"Pub. L. 115–254, div. C, § 1104(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3430"},"text":"132 Stat. 3430","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca854647-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca854648-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca854649-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1154(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1905(c)(3), (d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633"},"text":"Pub. L. 93–633","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2156"},"text":"88 Stat. 2156","children":[],"tail":", § 306(c)(3), (d); added "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/309/s2"},"text":"Pub. L. 97–309, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1453"},"text":"96 Stat. 1453","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/641/s4"},"text":"Pub. L. 101–641, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/4655"},"text":"104 Stat. 4655","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1154(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1441(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s701/e"},"text":"Pub. L. 85–726, § 701(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/781"},"text":"72 Stat. 781","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(d) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s6/d"},"text":"Pub. L. 89–670, § 6(d)","children":[],"tail":" (1st sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/80/938"},"text":"80 Stat. 938","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1903(a)(1)(A), (c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633/s304/a/1/A"},"text":"Pub. L. 93–633, § 304(a)(1)(A)","children":[],"tail":", (c), "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2168"},"text":"88 Stat. 2168","children":[],"tail":", 2171."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “transcript” is substituted for “transcriptions” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(A), the words “that the National Transportation Safety Board has not made available to the public” are substituted for “other than such portions made available to the public by the Board” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(B), the words “prepared by or under the direction of the Board” are omitted as unnecessary and for consistency with the source provisions restated in this subsection.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “civil action” are substituted for “suit or action” in 49 App.:1441(e) and 1903(c) for consistency with the Federal Rules of Civil Procedure (28 App. U.S.C.).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca85464a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca85464b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1104/b/1"},"text":"Pub. L. 115–254, § 1104(b)(1)","children":[],"tail":", substituted “In General” for “Transcripts and Recordings” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1104/b/2"},"text":"Pub. L. 115–254, § 1104(b)(2)","children":[],"tail":", added subpar. (A) and redesignated former subpars. (A) and (B) as (B) and (C), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1104/b/3"},"text":"Pub. L. 115–254, § 1104(b)(3)","children":[],"tail":", substituted “recorder recording, including with regard to a video recording any still image that the National Transportation Safety Board has not made available to the public under section 1114(c) or 1114(d) of this title,” for “recorder recording” in introductory provisions and in subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1104/b/4"},"text":"Pub. L. 115–254, § 1104(b)(4)","children":[],"tail":", inserted “a still image or” before “a part of a cockpit” in introductory provisions and substituted “the still image, the part of the transcript, or the recording” for “the part of the transcript or the recording” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1104/b/4/B"},"text":"Pub. L. 115–254, § 1104(b)(4)(B)","children":[],"tail":", inserted “a still image or” before “a part of a cockpit” and substituted “the still image, the part of the transcript, or the recording” for “the part of the transcript or the recording” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1104/b/5"},"text":"Pub. L. 115–254, § 1104(b)(5)","children":[],"tail":", added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/424/s5/c/1/A"},"text":"Pub. L. 106–424, § 5(c)(1)(A)","children":[],"tail":", substituted “and surface vehicle recordings and transcripts” for “voice and other material” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/424/s5/c/1/B"},"text":"Pub. L. 106–424, § 5(c)(1)(B)","children":[],"tail":", substituted “cockpit or surface vehicle recorder” for “cockpit voice recorder” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/424/s5/c/1/C"},"text":"Pub. L. 106–424, § 5(c)(1)(C)","children":[],"tail":", substituted “section 1114(c) or 1114(d)” for “section 1114(c)” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/424/s5/c/1/D"},"text":"Pub. L. 106–424, § 5(c)(1)(D)","children":[],"tail":", which directed the amendment of this section by adding par. (6) at the end, was executed by adding par. (6) at the end of subsec. (a) to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
