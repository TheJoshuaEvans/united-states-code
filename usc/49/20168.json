{"tag":"section","attrib":{"id":"idcb16b20f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168"},"text":null,"children":[{"tag":"num","attrib":{"value":"20168"},"text":"§ 20168.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Installation of audio and image recording devices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb16b210-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of enactment of the Passenger Rail Reform and Investment Act of 2015, the Secretary of Transportation shall promulgate regulations to require each railroad carrier that provides regularly scheduled intercity rail passenger or commuter rail passenger transportation to the public to install inward- and outward-facing image recording devices in all controlling locomotive cabs and cab car operating compartments in such passenger trains.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb16b211-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Device Standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each inward- and outward-facing image recording device shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb16b212-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a minimum 12-hour continuous recording capability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b213-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have crash and fire protections for any in-cab image recordings that are stored only within a controlling locomotive cab or cab car operating compartment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b214-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have recordings accessible for review during an accident or incident investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb16b215-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish a process to review and approve or disapprove an inward- or outward-facing image recording device for compliance with the standards described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb16b216-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A railroad carrier subject to the requirements of subsection (a) that has installed an inward- or outward-facing image recording device approved under subsection (c) may use recordings from that inward- or outward-facing image recording device for the following purposes:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb16b217-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Verifying that train crew actions are in accordance with applicable safety laws and the railroad carrier’s operating rules and procedures, including a system-wide program for such verification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b218-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Assisting in an investigation into the causation of a reportable accident or incident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b219-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Documenting a criminal act or monitoring unauthorized occupancy of the controlling locomotive cab or car operating compartment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b21a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other purposes that the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb16b21b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretion.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb16b21c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb16b21d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require in-cab audio recording devices for the purposes described in subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb16b21e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" define in appropriate technical detail the essential features of the devices required under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b21f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may exempt any railroad carrier subject to the requirements of subsection (a) or any part of the carrier’s operations from the requirements under subsection (a) if the Secretary determines that the carrier has implemented an alternative technology or practice that provides an equivalent or greater safety benefit or that is better suited to the risks of the operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb16b220-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tampering.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb16b221-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), a railroad carrier subject to the requirements of subsection (a) may take appropriate enforcement or administrative action against any employee that tampers with or disables an audio or inward- or outward-facing image recording device installed by the railroad carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b222-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporarily obscuring field of view of an image recording device while expressing breast milk.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb16b223-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of expressing breast milk, an employee may temporarily obscure the field of view of an image recording device required under this section if the passenger train on which such device is installed is not in motion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb16b224-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resuming operation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The crew of a passenger train on which an image recording device has been obscured pursuant to subparagraph (A) shall ensure that such image recording device is no longer obscured immediately after the employee has finished expressing breast milk and before resuming operation of the passenger train.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb16b225-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation of Data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each railroad carrier subject to the requirements of subsection (a) shall preserve recording device data for 1 year after the date of a reportable accident or incident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb16b226-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Protections","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not disclose publicly any part of an in-cab audio or image recording or transcript of oral communications by or among train employees or other operating employees responsible for the movement and direction of the train, or between such operating employees and company communication centers, related to an accident or incident investigated by the Secretary. The Secretary may make public any part of a transcript or any written depiction of visual information that the Secretary determines is relevant to the accident at the time a majority of the other factual reports on the accident or incident are released to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb16b227-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An in-cab audio or image recording obtained by a railroad carrier under this section may not be used to retaliate against an employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb16b228-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20168/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed as requiring a railroad carrier to cease or restrict operations upon a technical failure of an inward- or outward-facing image recording device or in-cab audio device. Such railroad carrier shall repair or replace the failed inward- or outward-facing image recording device as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb16b229-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11411/a"},"text":"Pub. L. 114–94, div. A, title XI, § 11411(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1686"},"text":"129 Stat. 1686","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/328/dKK/s102/c"},"text":"Pub. L. 117–328, div. KK, § 102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6096"},"text":"136 Stat. 6096","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb16b22a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb16b22b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb16b22c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Passenger Rail Reform and Investment Act of 2015, referred to in subsec. (a), is the date of enactment of title XI of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb16b22d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328"},"text":"Pub. L. 117–328","children":[],"tail":" designated existing provisions as par. (1) and inserted heading, substituted “Except as provided in paragraph (2), a railroad carrier” for “A railroad carrier”, and added par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb16b22e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb16b22f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2022 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dKK/s103/c"},"text":"Pub. L. 117–328, div. KK, § 103(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/6096"},"text":"136 Stat. 6096","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dKK/s103/c"},"text":"“The amendments made by section 102(c) [amending this section] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb16b230-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
