{"tag":"section","attrib":{"id":"idcad64d91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305"},"text":null,"children":[{"tag":"num","attrib":{"value":"6305"},"text":"§ 6305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advisory council on transportation statistics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad64d92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall establish and consult with an advisory council on transportation statistics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad64d93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Function","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory council established under this section shall advise the Director on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad64d94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality, reliability, consistency, objectivity, and relevance of transportation statistics and analyses collected, supported, or disseminated by the Bureau and the Department; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods to encourage cooperation and interoperability of transportation data collected by the Bureau, the operating administrations of the Department, States, local governments, metropolitan planning organizations, and private sector entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad64d96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad64d97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The advisory council shall be composed of not fewer than 9 and not more than 11 members appointed by the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64d98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting members for the advisory council, the Director shall appoint individuals who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad64d99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are not officers or employees of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad64d9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" possess expertise in—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcad64d9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation data collection, analysis, or application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad64d9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economics; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad64d9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/c/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation safety; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad64d9e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent a cross section of transportation stakeholders, to the greatest extent possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad64d9f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms of Appointment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad64da0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), members of the advisory council shall be appointed to staggered terms not to exceed 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64da1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member may be renominated for 1 additional 3-year term.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64da2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Current members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member serving on an advisory council on transportation statistics on the day before the date of enactment of the Transportation Research and Innovative Technology Act of 2012 shall serve until the end of the appointed term of the member.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad64da3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6305/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of Chapter ","children":[],"tail":"10"},{"tag":"inline","attrib":{},"text":" of Title ","children":[],"tail":"5.—"}],"tail":null},{"tag":"content","attrib":{},"text":"Chapter 10 of title 5 shall apply to the advisory council established under this section, except that ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of title 5","children":[],"tail":" shall not apply."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad64da4-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tII/s52011/a"},"text":"Pub. L. 112–141, div. E, title II, § 52011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/891"},"text":"126 Stat. 891","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/a/304"},"text":"Pub. L. 117–286, § 4(a)(304)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4339"},"text":"136 Stat. 4339","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad64da5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad64da6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcad64da7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Transportation Research and Innovative Technology Act of 2012, referred to in subsec. (d)(3), is the date of enactment of div. E of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcad64da8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “Chapter 10 of Title 5” for “Federal Advisory Committee Act” in heading and “Chapter 10 of title 5 shall apply to the advisory council established under this section, except that "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of title 5","children":[],"tail":"” for “The Federal Advisory Committee Act (5 U.S.C. App.) shall apply to the advisory council established under this section, except that section 14 of that Act” in text."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcad64da9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcad64daa-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcad64dab-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Termination of Advisory Council on Transportation Statistics","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Advisory Council on Transportation Statistics terminated ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s418/g"},"text":"section 418(g) of Pub. L. 115–254","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s42301"},"text":"section 42301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcad64dac-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Advisory Council on Transportation Statistics","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240/tVI/s6007"},"text":"Pub. L. 102–240, title VI, § 6007","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2174"},"text":"105 Stat. 2174","children":[],"tail":", required the Director to establish an Advisory Council on Transportation Statistics composed of not more than 6 members to provide advice on the quality of transportation statistics and analysis."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
