n":[{"tag":"html:p","attrib":{},"text":"15:1397(a)(2)(D), (b)(1) (1st sentence), (2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563/s108/a/2/D"},"text":"Pub. L. 89–563, § 108(a)(2)(D)","children":[],"tail":", (b)(1) (1st sentence), (2), "},{"tag":"html:a","attrib":{"href":"/us/stat/80/722"},"text":"80 Stat. 722","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/492/s103/a/1"},"text":"Pub. L. 93–492, § 103(a)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1477"},"text":"88 Stat. 1477","children":[],"tail":", 1478."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(b)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563/s108/b/3"},"text":"Pub. L. 89–563, § 108(b)(3)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/723"},"text":"80 Stat. 723","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/492/s103/a/1/B"},"text":"Pub. L. 93–492, § 103(a)(1)(B)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1478"},"text":"88 Stat. 1478","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/562/s2/a"},"text":"Pub. L. 100–562, § 2(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2818"},"text":"102 Stat. 2818","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"30112(b) (4)–(8)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(no source).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30112(b)(9)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(i).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Except as provided in this section . . . and subchapter III of this chapter” are substituted for 15:1397(c)(1) to eliminate unnecessary words and because of the restatement. The reference to section 30113 is added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the text of 15:1397(a)(2)(D) is omitted as obsolete because under section 30124 of the revised title a standard prescribed under this chapter may not allow compliance by use of a safety belt interlock or a continuous buzzer. In clause (2)(A), the words “despite exercising reasonable care” are substituted for “in the exercise of due care” for clarity and consistency in the revised title. The words “motor vehicle safety standards prescribed under this chapter” are substituted for “Federal motor vehicle safety standards” for clarity and consistency in this chapter. In clause (2)(B), the words “without knowing about the noncompliance” are substituted for “unless such person knows that such vehicle or equipment does not so conform” to eliminate unnecessary words and for consistency in the revised title. Clauses (4)–(8) are added to provide cross–references to sections restating exceptions to the general rule restated in subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb464d1b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb464d1c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this paragraph, referred to in subsec. (a)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this paragraph, referred to in subsec. (b)(10), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb464d1d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s31207/1"},"text":"Pub. L. 112–141, § 31207(1)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s31207/2"},"text":"Pub. L. 112–141, § 31207(2)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", which directed amendment of section 30112(a), without specifying the title to be amended, by designating existing provisions as par. (1) and adding par. (2), was executed to this section, to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb464d1e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb464d1f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
