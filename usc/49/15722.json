{"tag":"section","attrib":{"id":"idcb085929-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15722"},"text":null,"children":[{"tag":"num","attrib":{"value":"15722"},"text":"§ 15722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records: form; inspection; preservation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb08592a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form of Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may prescribe the form of records required to be prepared or compiled under this subchapter by pipeline carriers and lessors, including records related to movement of traffic and receipts and expenditures of money.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb08592b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board, or an employee designated by the Board, may on demand and display of proper credentials—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb08592c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15722/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspect and examine the lands, buildings, and equipment of a pipeline carrier or lessor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb08592d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15722/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" inspect and copy any record of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb08592e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15722/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pipeline carrier, lessor, or association; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb08592f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15722/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person controlling, controlled by, or under common control with a pipeline carrier if the Board considers inspection relevant to that person’s relation to, or transaction with, that carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb085930-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may prescribe the time period during which operating, accounting, and financial records must be preserved by pipeline carriers and lessors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb085931-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s106/a"},"text":"Pub. L. 104–88, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/926"},"text":"109 Stat. 926","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb085932-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb085933-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb085934-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11144"},"text":"section 11144 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb085935-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb085936-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
