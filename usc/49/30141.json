{"tag":"section","attrib":{"id":"idcb4d78c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141"},"text":null,"children":[{"tag":"num","attrib":{"value":"30141"},"text":"§ 30141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importing motor vehicles capable of complying with standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb4d78c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30112/a"},"text":"Section 30112(a) of this title","children":[],"tail":" does not apply to a motor vehicle if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4d78c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" on the initiative of the Secretary of Transportation or on petition of a manufacturer or importer registered under subsection (c) of this section, the Secretary decides—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb4d78c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the vehicle is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb4d78ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" substantially similar to a motor vehicle originally manufactured for import into and sale in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb4d78cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30115"},"text":"section 30115 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb4d78cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the same model year (as defined under regulations of the Secretary of Transportation) as the model of the motor vehicle it is being compared to; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb4d78cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" capable of being readily altered to comply with applicable motor vehicle safety standards prescribed under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4d78ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if there is no substantially similar United States motor vehicle, the safety features of the vehicle comply with or are capable of being altered to comply with those standards based on destructive test information or other evidence the Secretary of Transportation decides is adequate;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d78cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vehicle is imported by a registered importer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d78d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the registered importer pays the annual fee the Secretary of Transportation establishes under subsection (e) of this section to pay for the costs of carrying out the registration program for importers under subsection (c) of this section and any other fees the Secretary of Transportation establishes to pay for the costs of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb4d78d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processing bonds provided to the Secretary of the Treasury under subsection (d) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4d78d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making the decisions under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4d78d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures on Deciding on Motor Vehicle Capability","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4d78d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall establish by regulation procedures for making a decision under subsection (a)(1) of this section and the information a petitioner must provide to show clearly that the motor vehicle is capable of being brought into compliance with applicable motor vehicle safety standards prescribed under this chapter. In establishing the procedures, the Secretary shall provide for a minimum period of public notice and written comment consistent with ensuring expeditious, but complete, consideration and avoiding delay by any person. In making a decision under those procedures, the Secretary shall consider test information and other information available to the Secretary, including any information provided by the manufacturer. If the Secretary makes a negative decision, the Secretary may not make another decision for the same model until at least 3 calendar months have elapsed after the negative decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d78d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall publish each year in the Federal Register a list of all decisions made under subsection (a)(1) of this section. Each published decision applies to the model of the motor vehicle for which the decision was made. A positive decision permits another importer registered under subsection (c) of this section to import a vehicle of the same model under this section if the importer complies with all the terms of the decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4d78d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registration","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4d78d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation shall establish procedures for registering a person who complies with requirements prescribed by the Secretary by regulation under this subsection, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb4d78d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recordkeeping requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4d78d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspection of records and facilities related to motor vehicles the person has imported, altered, or both; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4d78da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements that ensure that the importer (or a successor in interest) will be able technically and financially to carry out responsibilities under sections 30117(b), 30118–30121, and 30166(f) of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d78db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall deny registration to a person whose registration is revoked under paragraph (4) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d78dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation may deny registration to a person that is or was owned or controlled by, or under common ownership or control with, a person whose registration was revoked under paragraph (4) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fe9dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation shall establish procedures for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb4fe9de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoking or suspending a registration issued under paragraph (1) of this subsection for not complying with a requirement of this subchapter or any of sections 30112, 30115, 30117–30122, 30125(c), 30127, or 30166 of this title or regulations prescribed under this subchapter or any of those sections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4fe9df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automatically suspending a registration for not paying a fee under subsection (a)(3) of this section in a timely manner or for knowingly filing a false or misleading certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30146"},"text":"section 30146 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4fe9e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reinstating suspended registrations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fe9e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bonds","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4fe9e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person importing a motor vehicle under this section shall provide a bond to the Secretary of the Treasury (acting for the Secretary of Transportation) and comply with the terms the Secretary of Transportation decides are appropriate to ensure that the vehicle—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb4fe9e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will comply with applicable motor vehicle safety standards prescribed under this chapter within a reasonable time (specified by the Secretary of Transportation) after the vehicle is imported; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4fe9e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will be exported (at no cost to the United States Government) by the Secretary of the Treasury or abandoned to the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fe9e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the bond provided under this subsection shall be at least equal to the dutiable value of the motor vehicle (as determined by the Secretary of the Treasury) but not more than 150 percent of that value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fe9e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fee Review, Adjustment, and Use","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall review and make appropriate adjustments at least every 2 years in the amounts of the fees required to be paid under subsection (a)(3) of this section. The Secretary of Transportation shall establish the fees for each fiscal year before the beginning of that year. All fees collected remain available until expended without fiscal year limit to the extent provided in advance by appropriation laws. The amounts are only for use by the Secretary of Transportation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4fe9e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out this section and sections 30146(a)–(c)(1), (d), and (e) and 30147(b) of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fe9e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30141/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in advancing to the Secretary of the Treasury amounts for costs incurred under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30146"},"text":"section 30146 of this title","children":[],"tail":" to reimburse the Secretary of the Treasury for those costs."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb4fe9e9-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/960"},"text":"108 Stat. 960","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/23"},"text":"Pub. L. 103–429, § 6(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4380"},"text":"108 Stat. 4380","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb4fe9ea-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb4fe9eb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb4fe9ec-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30141(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(c)(3)(A), (C)(i).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563"},"text":"Pub. L. 89–563","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/718"},"text":"80 Stat. 718","children":[],"tail":", § 108(c)(2), (3)(A)–(D); added "},{"tag":"html:span","attrib":{},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/562/s2/b"},"text":"Pub. L. 100–562, § 2(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2818"},"text":"102 Stat. 2818","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30141(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(c)(3)(C) (ii)–(iv).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30141(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(c)(3)(D).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30141(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(c)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30141(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(c)(3)(B).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(A)(iv), the words “prescribed under this chapter” are substituted for “Federal” for consistency in this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), before clause (A), the words “any other fees” are substituted for “such other annual fee or fees” to eliminate unnecessary words. In clause (B), the words “this subchapter” are substituted for “this section” for clarity. See H. Rept. No. 100–431, 100th Cong., 1st Sess., p. 19 (1987).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “procedures for making a decision under subsection (a)(1) of this section” are substituted for “procedures for considering such petitions” and “procedures for determinations made on the Secretary’s initiative” because of the restatement. The words “(whether or not confidential)” are omitted as unnecessary because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the word “permits” is substituted for “shall be sufficient authority” for clarity. The word “conditions” is omitted as being included in “terms”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), before clause (A), the words “under this subsection” are added for clarity. The word “including” is substituted for “include, as a minimum” to eliminate unnecessary words. In clause (B), the words “(relating to discovery, notification, and remedy of defects)” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “directly or indirectly” are omitted as unnecessary because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1), before clause (A), the word “conditions” is omitted as being included in “terms”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb4fe9ed-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:30141(c)(4)(A) and 30165(a) to correct erroneous cross-references.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb4fe9ee-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","at