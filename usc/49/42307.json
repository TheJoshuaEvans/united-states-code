{"tag":"section","attrib":{"id":"idcbd56d74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42307"},"text":null,"children":[{"tag":"num","attrib":{"value":"42307"},"text":"§ 42307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirement to maintain a live customer chat or monitored text messaging number","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd56d75-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d76-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42307/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A covered air carrier that operates a domestic or international flight to, from, or within the United States shall maintain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd56d77-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42307/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a customer service telephone line staffed by live agents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd56d78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42307/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a customer chat option that allows for customers to speak to a live agent within a reasonable time, to the greatest extent practicable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd56d79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42307/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a monitored text messaging number that enables customers to communicate and speak with a live agent directly.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7de7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42307/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The services required under paragraph (1) shall be provided to customers without charge for the use of such services, and shall be available at all times.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7de7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rulemaking Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall promulgate such rules as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7de7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42307/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Air Carrier Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “covered air carrier” means an air carrier that sells tickets for scheduled passenger air transportation on an aircraft that, as originally designed, has a passenger capacity of 30 or more seats.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7de7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42307/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning on the date that is 120 days after the date of enactment of this section, a covered air carrier shall comply with the requirement specified in subsection (a) without regard to whether the Secretary has promulgated any rules to carry out this section as of the date that is 120 days after such date of enactment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd7de7e-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tV/s505/b/1"},"text":"Pub. L. 118–63, title V, § 505(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1191"},"text":"138 Stat. 1191","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd7de7f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbd7de80-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbd7de81-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (d), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
