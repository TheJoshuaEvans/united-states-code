{"tag":"section","attrib":{"id":"idca63dc24-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117"},"text":null,"children":[{"tag":"num","attrib":{"value":"117"},"text":"§ 117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Council on Credit and Finance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca63dc25-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall establish a Council on Credit and Finance in accordance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca63dc26-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca63dc27-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be composed of the following members:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Deputy Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Under Secretary of Transportation for Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Chief Financial Officer and Assistant Secretary for Budget and Programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The General Counsel of the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Assistant Secretary for Transportation Policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Federal Highway Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Federal Transit Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Federal Railroad Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may designate up to 3 additional officials of the Department to serve as at-large members of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson and vice chairperson.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca63dc32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Deputy Secretary of Transportation shall serve as the chairperson of the Council.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca63dc33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vice chairperson","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief Financial Officer and Assistant Secretary for Budget and Programs shall serve as the vice chairperson of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Executive Director of the National Surface Transportation and Innovative Finance Bureau shall serve as a nonvoting member of the Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca63dc35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca63dc36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review applications for assistance submitted under the programs referred to in subparagraphs (A), (B), and (C) of section 116(d)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review applications for assistance submitted under the program referred to in section 116(d)(1)(D), as determined appropriate by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Secretary regarding the selection of projects to receive assistance under such programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review, on a regular basis, projects that received assistance under such programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca63dc3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s117/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out such additional duties as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca63dc3b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tIX/s9002/a"},"text":"Pub. L. 114–94, div. A, title IX, § 9002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1618"},"text":"129 Stat. 1618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca63dc3c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca63dc3d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idca63dc3e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
