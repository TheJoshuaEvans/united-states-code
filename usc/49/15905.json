{"tag":"section","attrib":{"id":"idcb085973-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15905"},"text":null,"children":[{"tag":"num","attrib":{"value":"15905"},"text":"§ 15905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on actions by and against pipeline carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb085974-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A pipeline carrier providing transportation or service subject to this part must begin a civil action to recover charges for transportation or service provided by the carrier within 3 years after the claim accrues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb085975-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Overcharges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person must begin a civil action to recover overcharges under section 15904(b)(1) within 3 years after the claim accrues. If an election to file a complaint with the Board is made under section 15904(c)(1), the complaint must be filed within 3 years after the claim accrues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb085976-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person must file a complaint with the Board to recover damages under section 15904(b)(2) within 2 years after the claim accrues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb085977-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15905/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extensions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The limitation periods under subsection (b) are extended for 6 months from the time written notice is given to the claimant by the carrier of disallowance of any part of the claim specified in the notice if a written claim is given to the carrier within those limitation periods. The limitation periods under subsection (b) and the 2-year period under subsection (c) are extended for 90 days from the time the carrier begins a civil action under subsection (a) to recover charges related to the same transportation or service, or collects (without beginning a civil action under that subsection) the charge for that transportation or service if that action is begun or collection is made within the appropriate period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb085978-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15905/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person must begin a civil action to enforce an order of the Board against a carrier for the payment of money within one year after the date the order required the money to be paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb085979-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15905/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Government Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to transportation for the United States Government. The time limitations under this section are extended, as related to transportation for or on behalf of the United States Government, for 3 years from the date of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb08597a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15905/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" payment of the rate for the transportation or service involved,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb08597b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15905/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsequent refund for overpayment of that rate, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb08597c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15905/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deduction made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3726"},"text":"section 3726 of title 31","children":[],"tail":","}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"whichever is later.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb08597d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15905/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accrual Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A claim related to a shipment of property accrues under this section on delivery or tender of delivery by the carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb08597e-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s106/a"},"text":"Pub. L. 104–88, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/928"},"text":"109 Stat. 928","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb08597f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb085980-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb085981-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11706"},"text":"section 11706 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb085982-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb085983-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
