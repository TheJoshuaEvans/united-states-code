xt":null,"children":[{"tag":"html:span","attrib":{},"text":"103(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1652(e)(1) (1st sentence related to FRA).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670"},"text":"Pub. L. 89–670","children":[],"tail":", §§ 3(e) (related to FRA) (1), (3), (4), 6(f)(3)(C) (related to FRA), "},{"tag":"html:a","attrib":{"href":"/us/stat/80/932"},"text":"80 Stat. 932","children":[],"tail":", 940."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1652a.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 8, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/348/s6"},"text":"Pub. L. 94–348, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/820"},"text":"90 Stat. 820","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"103(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1652(e) (related to FRA) (1) (2d, last sentences), (3) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"103(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1655(f)(3)(A).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s6/f/3/A"},"text":"Pub. L. 89–670, § 6(f)(3)(A)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/940"},"text":"80 Stat. 940","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 22, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/401/s6"},"text":"Pub. L. 92–401, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/617"},"text":"86 Stat. 617","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633/s113/e/1"},"text":"Pub. L. 93–633, § 113(e)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2163"},"text":"88 Stat. 2163","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1652(e)(3) (related to FRA) (less last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"103(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1652(e)(4) (related to FRA).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1655(f)(3)(C) (related to FRA).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “To carry out” are substituted for “for purposes of administering and enforcing” in 49:1652a for consistency and to eliminate surplus words. The words “under those laws” are substituted for “pursuant to Federal railroad safety laws” to eliminate surplus words. The words “is responsible” are substituted for “shall retain full and final responsibility” and “shall be responsible” to eliminate surplus words. The words “and for the establishment of all policies with respect to implementation of such laws” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Each of these components” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “vested in the Secretary” are substituted for “as set forth in the statutes transferred to the Secretary” in 49:1655(f)(3)(A) for clarity and consistency. The words “section 6(e)(1), (2), and (6)(A) of the Department of Transportation Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s1655/e/1"},"text":"49 U.S.C. 1655(e)(1)","children":[],"tail":", (2), and (6)(A))” are substituted for “subsection (e) of this section (other than subsection (e)(4) of this section)” in 49:1655(f)(3)(A) for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “law” is substituted for “statute” in 49:1652(e)(4) for consistency. The words after “administratively final” in 49:1655(f)(3)(C) are omitted as unnecessary because of the restatement of the revised title and those laws giving a right to appeal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca499d83-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"Section 5(m)(1) amends 49:103(c)(1) to include a reference to section 20134(c) of the revised title. The reference is included because 45:445 on which section 20134(c) is based provides that the duties and powers under that provision are to be carried out by the Administrator of the Federal Railroad Administration rather than the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca499d84-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca499d85-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Passenger Rail Investment and Improvement Act of 2008, referred to in subsec. (j)(3), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca499d86-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":", which directed substitution of “division C (except sections 3302, 3501(b), 3509, 3906, 4710, and 4711) of subtitle I of title 41” for “title III of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s251"},"text":"41 U.S.C. 251","children":[],"tail":" et seq.)” in subsec. (e), was executed to subsec. (i), to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s307/1"},"text":"Pub. L. 110–432, § 307(1)","children":[],"tail":", (2), inserted heading and struck out at end “To carry out all railroad safety laws of the United States, the Administration is divided on a geographical basis into at least 8 safety offices. The Secretary of Transportation is responsible for all acts taken under those laws and for ensuring that the laws are uniformly administered and enforced among the safety offices.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (k). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":", §§ 101, 307(3), (4), added subsecs. (b) to (k) and struck out former subsecs. (b) to (e), which related to: in subsec. (b), Administrator as head of the Administration; in subsec. (c), Administrator’s duties and powers; in subsec. (d), transfer of duties or powers and effect of Administrator’s decision; and, in subsec. (e), authority of Secretary of Transportation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" inserted “subtitle I of title 40 and title III of” before “the Federal Property” and substituted “("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s251"},"text":"41 U.S.C. 251","children":[],"tail":" et seq.)” for “("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s471"},"text":"40 U.S.C. 471","children":[],"tail":" et seq.)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":" substituted “section 20134(c) and chapters 203–211 of this title, and chapter 213 of this title in carrying out chapters 203–211” for “section 6(e)(1), (2), and (6)(A) of the Department of Transportation Act (49 App. U.S.C. 1655(e)(1), (2), and (6)(A))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/440"},"text":"Pub. L. 103–440","children":[],"tail":" added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/216"},"text":"Pub. L. 98–216","children":[],"tail":" substituted “49 App. U.S.C.” for “49 U.S.C.”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca499d87-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca499d88-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Update of Federal Railroad Administration Web Site","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tIII/s307"},"text":"Pub. L. 110–432, div. A, title III, § 307","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4881"},"text":"122 Stat. 4881","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11316/j/5"},"text":"Pub. L. 114–94, div. A, title XI, § 11316(j)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1677"},"text":"129 Stat. 1677","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tXI/s11316/j/5"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall update the Federal Railroad Administration’s public Web site to better facilitate the ability of the public, including those individuals who are not regular users of the public Web site, to find current information regarding the Federal Railroad Administration’s activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Reporting of Violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On the Federal Railroad Administration’s public Web site’s home page, the Secretary shall provide a mechanism for the public to submit written reports of potential violations of Federal railroad safety and hazardous materials transportation laws, regulations, and orders to the Federal Railroad Administration.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “Secretary” and “railroad”, as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s307"},"text":"section 307 of Pub. L. 110–432","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/s2/a"},"text":"section 2(a) of Pub. L. 110–432","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s20102"},"text":"section 20102 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca499d89-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Funds for Broadband High Speed Internet Service Connection for Federal Railroad Administration Employees","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/447/dH/tI/s151"},"text":"Pub. L. 108–447, div. H, title I, § 151","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-08"},"text":"Dec. 8, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3222"},"text":"118 Stat. 3222","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/447/dH/tI/s151"},"text":"“Notwithstanding any provisions of this or any other Act, during the fiscal year ending ","children":[{"tag":"date","attrib":{"date":"2005-09-30"},"text":"September 30, 2005","children":[],"tail":", and hereafter, the Federal Railroad Administration may use funds appropriated by this or any other Act to provide for the installation of a broadband high speed internet service connection, including necessary equipment, for Federal Railroad Administration employees, and to either pay directly recurring monthly charges or to reimburse a percentage of such monthly charges which are paid by such employees: "},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That the Federal Railroad Administration certifies that adequate safeguards against private misuse exist, and that the service is necessary for direct support of the agency’s mission.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
