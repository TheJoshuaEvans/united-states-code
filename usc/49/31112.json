cargo”, and the word “law” is substituted for “statute”, for consistency in the revised title. The words “Dwight D. Eisenhower System of Interstate and Defense Highways” are substituted for “National System of Interstate and Defense Highways” because of the Act of ","children":[{"tag":"date","attrib":{"date":"1990-10-15"},"text":"October 15, 1990","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/101/427"},"text":"Public Law 101–427","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/927"},"text":"104 Stat. 927","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b), before clause (1), and (g)(1), the words “dismantled easily or divided easily” are substituted for “easily dismantled or divided” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(4), the words “Except as revised under this paragraph or paragraph (5) of this subsection” are substituted for “Except as modified pursuant to subparagraph (B) or (E) of this subsection” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb62fceb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb62fcec-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/6"},"text":"Pub. L. 116–6","children":[],"tail":" substituted “Kansas, and Oregon” for “and Kansas” in heading and added par. (6)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" inserted before period at end “, but not including a trailer or a semitrailer transported as part of a towaway trailer transporter combination (as defined in section 31111(a))”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s137/b/1"},"text":"Pub. L. 114–113, § 137(b)(1)","children":[],"tail":", substituted “Nebraska, and Kansas” for “and Nebraska” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s137/b/2"},"text":"Pub. L. 114–113, § 137(b)(2)","children":[],"tail":", substituted a semicolon for “; and” at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s137/b/3"},"text":"Pub. L. 114–113, § 137(b)(3)","children":[],"tail":", substituted “; and” for period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/113/s137/a"},"text":"Pub. L. 114–113, § 137(a)","children":[],"tail":", substituted “Nebraska and Kansas may” for “Nebraska may” and “the relevant state” for “the State of Nebraska”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4112/b"},"text":"Pub. L. 109–59, § 4112(b)","children":[],"tail":", substituted “Iowa, and Nebraska” for “and Iowa” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4112/a"},"text":"Pub. L. 109–59, § 4112(a)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/66"},"text":"Pub. L. 105–66","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1998-02-28"},"text":"February 28, 1998","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1997-09-30"},"text":"September 30, 1997","children":[],"tail":"”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/205"},"text":"Pub. L. 104–205","children":[],"tail":", which directed amendment of this section by adding a new subsection designated par. (4) without specifying where, was executed by adding par. (4) to subsec. (d) to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/59"},"text":"Pub. L. 104–59","children":[],"tail":" substituted “Alaska, and Iowa” for “and Alaska” in heading and added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb62fced-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcb62fcee-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/154/s1/b"},"text":"Pub. L. 118–154, § 1(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2024-12-17"},"text":"Dec. 17, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1691"},"text":"138 Stat. 1691","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/154/s1/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"United States Route 20 in each of the States of Oregon, Idaho, Montana, Wyoming, Nebraska, Iowa, Illinois, Indiana, Ohio, Pennsylvania, New York, and Massachusetts shall be known and designated as the ‘National Medal of Honor Highway’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the highway referred to in subsection (b) shall be deemed to be a reference to the ‘National Medal of Honor Highway’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb62fcef-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
