{"tag":"section","attrib":{"id":"idcafee413-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502"},"text":null,"children":[{"tag":"num","attrib":{"value":"14502"},"text":"§ 14502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax discrimination against motor carrier transportation property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcafee414-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafee415-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “assessment” means valuation for a property tax levied by a taxing district.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee416-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “assessment jurisdiction” means a geographical area in a State used in determining the assessed value of property for ad valorem taxation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee417-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motor carrier transportation property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “motor carrier transportation property” means property, as defined by the Secretary, owned or used by a motor carrier providing transportation in interstate commerce whether or not such transportation is subject to jurisdiction under subchapter I of chapter 135.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee418-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commercial and industrial property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “commercial and industrial property” means property, other than transportation property and land used primarily for agricultural purposes or timber growing, devoted to a commercial or industrial use, and subject to a property tax levy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee419-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acts Burdening Interstate Commerce","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The following acts unreasonably burden and discriminate against interstate commerce and a State, subdivision of a State, or authority acting for a State or subdivision of a State may not do any of them:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafee41a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excessive valuation of property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Assess motor carrier transportation property at a value that has a higher ratio to the true market value of the motor carrier transportation property than the ratio that the assessed value of other commercial and industrial property in the same assessment jurisdiction has to the true market value of the other commercial and industrial property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee41b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tax on assessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Levy or collect a tax on an assessment that may not be made under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee41c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ad valorem tax","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Levy or collect an ad valorem property tax on motor carrier transportation property at a tax rate that exceeds the tax rate applicable to commercial and industrial property in the same assessment jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafee41d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Jurisdiction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafee41e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t28/s1341"},"text":"section 1341 of title 28","children":[],"tail":" and without regard to the amount in controversy or citizenship of the parties, a district court of the United States has jurisdiction, concurrent with other jurisdiction of courts of the United States and the States, to prevent a violation of subsection (b) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee41f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation in relief","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Relief may be granted under this subsection only if the ratio of assessed value to true market value of motor carrier transportation property exceeds, by at least 5 percent, the ratio of assessed value to true market value of other commercial and industrial property in the same assessment jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee420-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Burden of proof","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The burden of proof in determining assessed value and true market value is governed by State law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafee421-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Violation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the ratio of the assessed value of other commercial and industrial property in the assessment jurisdiction to the true market value of all other commercial and industrial property cannot be determined to the satisfaction of the district court through the random-sampling method known as a sales assessment ratio study (to be carried out under statistical principles applicable to such a study), the court shall find, as a violation of this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcafee422-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the motor carrier transportation property at a value that has a higher ratio to the true market value of the motor carrier transportation property than the assessment value of all other property subject to a property tax levy in the assessment jurisdiction has to the true market value of all such other property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcafee423-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14502/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection of ad valorem property tax on the motor carrier transportation property at a tax rate that exceeds the tax ratio rate applicable to taxable property in the taxing district.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcafee424-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/900"},"text":"109 Stat. 900","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcafee425-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcafee426-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcafee427-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11503a"},"text":"section 11503a of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcafee428-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcafee429-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
