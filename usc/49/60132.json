{"tag":"section","attrib":{"id":"idcc85d1a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60132"},"text":null,"children":[{"tag":"num","attrib":{"value":"60132"},"text":"§ 60132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National pipeline mapping system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc85d1a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information To Be Provided","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 6 months after the date of enactment of this section, the operator of a pipeline facility (except distribution lines and gathering lines) shall provide to the Secretary of Transportation the following information with respect to the facility:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d1a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60132/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Geospatial data appropriate for use in the National Pipeline Mapping System or data in a format that can be readily converted to geospatial data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60132/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The name and address of the person with primary operational control to be identified as its operator for purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60132/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A means for a member of the public to contact the operator for additional information about the pipeline facilities it operates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60132/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other geospatial or technical data, including design and material specifications, that the Secretary determines are necessary to carry out the purposes of this section. The Secretary shall give reasonable notice to operators that the data are being requested.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person providing information under subsection (a) shall provide to the Secretary updates of the information to reflect changes in the pipeline facility owned or operated by the person and as otherwise required by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60132/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Assistance To Improve Local Response Capabilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide technical assistance to State and local officials to improve local response capabilities for pipeline emergencies by adapting information available through the National Pipeline Mapping System to software used by emergency response personnel responding to pipeline emergencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60132/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Map of High-consequence Areas","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d1ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60132/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain, as part of the National Pipeline Mapping System, a map of designated high-consequence areas (as described in section 60109(a)) in which pipelines are required to meet integrity management program regulations, excluding any proprietary or sensitive security information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60132/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" update the map biennially.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60132/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program To Promote Awareness of National Pipeline Mapping System","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this subsection, the Secretary shall develop and implement a program promoting greater awareness of the existence of the National Pipeline Mapping System to State and local emergency responders and other interested parties. The program shall include guidance on how to use the National Pipeline Mapping System to locate pipelines in communities and local jurisdictions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60132/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Disclosure Limited","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not disclose information collected pursuant to subsection (a) except to the extent permitted by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc85d1b1-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s15/a"},"text":"Pub. L. 107–355, § 15(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3005"},"text":"116 Stat. 3005","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/90"},"text":"Pub. L. 112–90","children":[],"tail":", §§ 6(a), 11, "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1909"},"text":"125 Stat. 1909","children":[],"tail":", 1913.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc85d1b2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc85d1b3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc85d1b4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355"},"text":"Pub. L. 107–355","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to in subsec. (e), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90"},"text":"Pub. L. 112–90","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc85d1b5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90/s11/a"},"text":"Pub. L. 112–90, § 11(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90/s6/a"},"text":"Pub. L. 112–90, § 6(a)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90/s11/b"},"text":"Pub. L. 112–90, § 11(b)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc85d1b6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc85d1b7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Information to Emergency Response Agencies","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90/s6/b"},"text":"Pub. L. 112–90, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1910"},"text":"125 Stat. 1910","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/90/s6/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":"], the Secretary shall issue guidance to owners and operators of pipeline facilities on the importance of providing system-specific information about their pipeline facilities to emergency response agencies of the communities and jurisdictions in which those facilities are located."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before issuing guidance under paragraph (1), the Secretary shall consult with owners and operators of pipeline facilities to determine the extent to which the owners and operators are already providing system-specific information about their pipeline facilities to emergency response agencies.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Terms used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90/s6/b"},"text":"section 6(b) of Pub. L. 112–90","children":[],"tail":", set out above, have the meaning given those terms in this chapter, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/90/s1/c/1"},"text":"section 1(c)(1) of Pub. L. 112–90","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s60101"},"text":"section 60101 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
