{"tag":"section","attrib":{"id":"idcc707539-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101"},"text":null,"children":[{"tag":"num","attrib":{"value":"50101"},"text":"§ 50101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Buying goods produced in the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc70753a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may obligate an amount that may be appropriated to carry out section 106(k), 44502(a)(2), or 44509, subchapter I of chapter 471, or chapter 481 (except sections 48102(e), 48106, 48107, and 48110) of this title for a project only if steel and manufactured goods used in the project are produced in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc70753b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may waive subsection (a) of this section if the Secretary finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc70753c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applying subsection (a) would be inconsistent with the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc70753d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the steel and goods produced in the United States are not produced in a sufficient and reasonably available amount or are not of a satisfactory quality;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc70753e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" when procuring a facility or equipment under section 44502(a)(2) or 44509, subchapter I of chapter 471, or chapter 481 (except sections 48102(e), 48106, 48107, and 48110) of this title—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc70753f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of components and subcomponents produced in the United States is more than 60 percent of the cost of all components of the facility or equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc707540-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" final assembly of the facility or equipment has occurred in the United States; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc707541-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" including domestic material will increase the cost of the overall project by more than 25 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc707542-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Labor Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, labor costs involved in final assembly are not included in calculating the cost of components.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc707543-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Certain Rolling Stock Procurements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc707544-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Financial assistance made available under the provisions described in subsection (a) shall not be used in awarding a contract or subcontract to an entity on or after the date of enactment of this subsection for the procurement of rolling stock for use in an airport-related project if the manufacturer of the rolling stock—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc707545-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incorporated in or has manufacturing facilities in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc707546-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is owned or controlled by, is a subsidiary of, or is otherwise related legally or financially to a corporation based in a country that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc707547-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is identified as a nonmarket economy country (as defined in section 771(18) of the Tariff Act of 1930 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s1677/18"},"text":"19 U.S.C. 1677(18)","children":[],"tail":")) as of the date of enactment of this subsection;"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc707548-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was identified by the United States Trade Representative in the most recent report required by section 182 of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2242"},"text":"19 U.S.C. 2242","children":[],"tail":") as a foreign country included on the priority watch list defined in subsection (g)(3) of that section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc707549-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to monitoring by the Trade Representative under section 306 of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2416"},"text":"19 U.S.C. 2416","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc70754a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc70754b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (1), the term “otherwise related legally or financially” does not include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc70754c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minority relationship or investment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc70754d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" relationship with or investment in a subsidiary, joint venture, or other entity based in a country described in paragraph (1)(B) that does not export rolling stock or components of rolling stock for use in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc70754e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Corporation based in people’s republic of china","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subparagraph (A)(i), for purposes of paragraph (1), the term “otherwise related legally or financially” includes a minority relationship or investment if the relationship or investment involves a corporation based in the People’s Republic of China.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc70754f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"International agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall be applied in a manner consistent with the obligations of the United States under international agreements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc707550-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc707551-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may waive the limitation described in paragraph (1) using the criteria described in subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc707552-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50101/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 10 days after issuing a waiver under subparagraph (A), the Secretary shall notify the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc707553-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1298"},"text":"108 Stat. 1298","children":[],"tail":", § 49101; renumbered § 50101 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/88/D"},"text":"Pub. L. 104–287, § 5(88)(D)","children":[],"tail":", (89), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3398"},"text":"110 Stat. 3398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s768/a"},"text":"Pub. L. 118–63, title VII, § 768(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1293"},"text":"138 Stat. 1293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc707554-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc707555-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc707556-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"49101(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2226a(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/508/s9129"},"text":"Pub. L. 101–508, § 9129","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/1388-371"},"text":"104 Stat. 1388–371","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"49101(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2226a(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"49101(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2226a(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this chapter, the word “goods” is substituted for “product” and “products” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Notwithstanding any other provision of law” are omitted as surplus. The words “after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “The Secretary may waive” are substituted for “shall not apply” for consistency. In clause (2), the words “steel and goods” are substituted for “materials and products” for consistency. In clause (4), the word “contract” is omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc707557-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/89"},"text":"Pub. L. 104–287, § 5(89)","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This makes a clarifying amendment to 49:50101(a) and (b)(3), 50102, 50104(b)(1), and 50105, as redesignated by clause (88)(D) of this section, because 49:47106(d) was struck by section 108(1) of the Federal Aviation Administration Authorization Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305"},"text":"Public Law 103–305","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1573"},"text":"108 Stat. 1573","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc707558-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc707559-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to in subsec. (d)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc70755a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsecs. (a), (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s768/a/1"},"text":"Pub. L. 118–63, § 768(a)(1)","children":[],"tail":", struck out “(except section 47127)” after “subchapter I of chapter 471”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s768/a/2"},"text":"Pub. L. 118–63, § 768(a)(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/88/D"},"text":"Pub. L. 104–287, § 5(88)(D)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s49101"},"text":"section 49101 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/89"},"text":"Pub. L. 104–287, § 5(89)","children":[],"tail":", substituted “section 47127” for “sections 47106(d) and 47127”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc70755b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc70755c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Buy America Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tI/s167"},"text":"Pub. L. 115–254, div. B, title I, § 167","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3227"},"text":"132 Stat. 3227","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dB/tI/s167"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of Waivers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary of Transportation determines that it is necessary to waive the application of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s50101/a"},"text":"section 50101(a) of title 49","children":[],"tail":", United States Code, based on a finding under section 50101(b) of that title, the Secretary, at least 10 days before the date on which the waiver takes effect, shall—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make publicly available, in an easily identifiable location on the website of the Department of Transportation, a detailed written justification of the waiver determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide an informal public notice and comment opportunity on the waiver determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each fiscal year, the Secretary shall submit to the appropriate committees of Congress [Committee on Commerce, Science, and Transportation of the Senate and Committee on Transportation and Infrastructure of the House of Representatives] a report on waivers issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s50101"},"text":"section 50101 of title 49","children":[],"tail":", United States Code, during the fiscal year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc70755d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Domestic Products","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/tIII/s305"},"text":"Pub. L. 103–305, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1592"},"text":"108 Stat. 1592","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/305/tIII/s305"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition Against Fraudulent Use of ‘Made in America’ Labels","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person shall not intentionally affix a label bearing the inscription of ‘Made in America’, or any inscription with that meaning, to any product sold in or shipped to the United States, if that product is not a domestic product.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person who violates paragraph (1) shall not be eligible for any contract for a procurement carried out with amounts authorized under this title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47509"},"text":"section 47509 of this title","children":[],"tail":", amending sections 44505 and 48102 of this title, and enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40101"},"text":"section 40101 of this title","children":[],"tail":"], including any subcontract under such a contract pursuant to the debarment, suspension, and ineligibility procedures in subpart 9.4 of chapter 1 of title 48, Code of Federal Regulations, or any successor procedures thereto."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Buy American Act","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), the head of each office within the Federal Aviation Administration that conducts procurements shall ensure that such procurements are conducted in compliance with sections 2 through 4 of the Act of ","children":[{"tag":"date","attrib":{"date":"1933-03-03"},"text":"March 3, 1933","children":[],"tail":" ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s10a"},"text":"41 U.S.C. 10a","children":[],"tail":" through 10c, popularly known as the ‘Buy American Act’ [see "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s8301"},"text":"41 U.S.C. 8301","children":[],"tail":" et seq.])."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This subsection shall apply only to procurements made for which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amounts are authorized by this title to be made available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicitations for bids are issued after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary, before ","children":[{"tag":"date","attrib":{"date":"1995-01-01"},"text":"January 1, 1995","children":[],"tail":", shall report to the Congress on procurements covered under this subsection of products that are not domestic products."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, the term ‘domestic product’ means a product—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is manufactured or produced in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 percent of the cost of the articles, materials, or supplies of which are mined, produced, or manufactured in the United States.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following prior authorization act: ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/581/tIII/s305"},"text":"Pub. L. 102–581, title III, § 305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-31"},"text":"Oct. 31, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4896"},"text":"106 Stat. 4896","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc70755e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Purchase of American Made Equipment and Products","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/tIII/s306"},"text":"Pub. L. 103–305, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1593"},"text":"108 Stat. 1593","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tII/s218/f"},"text":"Pub. L. 118–63, title II, § 218(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1056"},"text":"138 Stat. 1056","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tII/s218/f"},"text":"“It is the sense of Congress that any recipient of a grant under this title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47509"},"text":"section 47509 of this title","children":[],"tail":", amending sections 44505 and 48102 of this title, and enacting provisions set out as notes under this section and "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40101"},"text":"section 40101 of this title","children":[],"tail":"], or under any amendment made by this title, should purchase, when available and cost-effective, American made equipment and products when expending grant monies.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
