{"tag":"section","attrib":{"id":"idcc28e4d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918"},"text":null,"children":[{"tag":"num","attrib":{"value":"44918"},"text":"§ 44918.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crew training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc28e4d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basic Security Training.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc28e4d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each air carrier providing scheduled passenger air transportation shall carry out a training program for flight and cabin crew members to prepare the crew members for potential threat conditions and unruly passenger behavior.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc28e4d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An air carrier training program under this subsection shall include, at a minimum, elements that address each of the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc28e4d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recognize suspicious behavior and activities and determine the seriousness of any occurrence of such behavior and activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc28e4d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Crew communication and coordination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc28e4d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proper commands to give passengers and attackers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriate responses to defend oneself.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of protective devices assigned to crew members (to the extent such devices are required by the Administrator of the Federal Aviation Administration or the Administrator of the Transportation Security Administration).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Psychology of terrorists to cope with hijacker behavior and passenger responses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Situational training exercises regarding various threat conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" De-escalation training based on recommendations issued by the Air Carrier Training Aviation Rulemaking Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Methods to subdue and restrain an active attacker.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proper conduct of a cabin search, including explosive device recognition.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other subject matter considered appropriate by the Administrator of the Transportation Security Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2b55e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier training program under this subsection shall be subject to approval by the Administrator of the Transportation Security Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2b55e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of the FAA Reauthorization Act of 2024, the Administrator of the Transportation Security Administration, in consultation with the Federal Air Marshal Service and the Aviation Security Advisory Committee, shall establish minimum standards for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc2b55e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the training provided under this subsection and any for recurrent training; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individuals or entities providing such training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2b55e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing programs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding paragraphs (3) and (4), any training program of an air carrier to prepare flight and cabin crew members for potential threat conditions that was approved by the Administrator or the Administrator of the Transportation Security Administration before ","children":[{"tag":"date","attrib":{"date":"2003-12-12"},"text":"December 12, 2003","children":[],"tail":", may continue in effect until disapproved or ordered modified by the Administrator of the Transportation Security Administration."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2b55e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Transportation Security Administration, in consultation with the Administrator and the Federal Air Marshal Service, shall monitor air carrier training programs under this subsection and shall periodically review an air carrier’s training program to ensure that the program is adequately preparing crew members for potential threat conditions based on changes in the potential or actual threat conditions. In determining when an air carrier’s training program should be reviewed under this paragraph, the Administrator of the Transportation Security Administration shall consider complaints from crew members. The Administrator of the Transportation Security Administration shall ensure that employees responsible for monitoring the training programs have the necessary resources and knowledge, including self-defense training expertise and experience.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2b55e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Transportation Security Administration, in consultation with the Administrator, shall order air carriers to modify training programs under this subsection to reflect new or different security threats.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2b55e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advanced Self-Defense Training.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc2b55e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Transportation Security Administration shall develop and provide a voluntary training program for flight and cabin crew members of air carriers providing scheduled passenger air transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2b55e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The training program under this subsection shall include both classroom and effective hands-on training in the following elements of self-defense:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc2b55ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Deterring a passenger who might present a threat.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advanced control, striking, and restraint techniques.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training to defend oneself against edged or contact weapons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Methods to subdue and restrain an attacker.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use of available items aboard the aircraft for self-defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Appropriate and effective responses to defend oneself, including the use of force against an attacker.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2b55f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other element of training that the Administrator of the Transportation Security Administration considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2b55f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation not required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A crew member shall not be required to participate in the training program under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2b55f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (8), neither the Federal Government nor an air carrier shall be required to compensate a crew member for participating in the training program under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2b55f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A crew member shall not be required to pay a fee for the training program under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2b55f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing the training program under this subsection, the Administrator of the Transportation Security Administration shall consult with law enforcement personnel and security experts who have expertise in self-defense training, terrorism experts, representatives of air carriers, the director of self-defense training in the Federal Air Marshal Service, flight attendants, labor organizations representing flight attendants, and educational institutions offering law enforcement training programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2b55f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of tsa official","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Transportation Security Administration shall designate an official in the Transportation Security Administration to be responsible for implementing the training program under this subsection. The official shall consult with air carriers and labor organizations representing crew members before implementing the program to ensure that it is appropriate for situations that may arise on board an aircraft during a flight.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2b55f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air carrier accommodation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier with a crew member participating in the training program under this subsection shall provide a process through which each such crew member may obtain reasonable accommodations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2b55f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44918/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Actions by crew members under this section shall be subject to the provisions of section 44903(k).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc2b55f8-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s107/a"},"text":"Pub. L. 107–71, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/610"},"text":"115 Stat. 610","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXIV/s1403/a"},"text":"Pub. L. 107–296, title XIV, § 1403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2305"},"text":"116 Stat. 2305","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tVI/s603"},"text":"Pub. L. 108–176, title VI, § 603","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2563"},"text":"117 Stat. 2563","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/d/16"},"text":"Pub. L. 115–254, div. K, title I, § 1991(d)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3635"},"text":"132 Stat. 3635","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIV/s427"},"text":"Pub. L. 118–63, title IV, § 427","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1169"},"text":"138 Stat. 1169","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc2b55f9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc2b55fa-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc2b55fb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the FAA Reauthorization Act of 2024, referred to in subsec. (a)(4), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc2b55fc-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s427/1/A"},"text":"Pub. L. 118–63, § 427(1)(A)","children":[],"tail":", inserted “and unruly passenger behavior” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s427/1/B/i"},"text":"Pub. L. 118–63, § 427(1)(B)(i)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows: “Recognizing suspicious activities and determining the seriousness of any occurrence.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s427/1/B/ii"},"text":"Pub. L. 118–63, § 427(1)(B)(ii)","children":[],"tail":", added subpar. (H) and struck out former subpar. (H) which read as follows: “Flight deck procedures or aircraft maneuvers to defend the aircraft and cabin crew responses to such procedures and maneuvers.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(I) to (K). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s427/1/B/iii"},"text":"Pub. L. 118–63, § 427(1)(B)(iii)","children":[],"tail":", (iv), added subpar. (I) and redesignated former subpars. (I) and (J) as (J) and (K), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s427/1/C"},"text":"Pub. L. 118–63, § 427(1)(C)","children":[],"tail":", added par. (4) and struck out former par. (4). Prior to amendment, text read as follows: “The Administrator of the Transportation Security Administration may establish minimum standards for the training provided under this subsection and for recurrent training.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s427/1/D"},"text":"Pub. L. 118–63, § 427(1)(D)","children":[],"tail":", inserted “and the Federal Air Marshal Service” after “consultation with the Administrator”, substituted “and shall periodically” for “and periodically shall”, and inserted “based on changes in the potential or actual threat conditions” before period at end of first sentence and “, including self-defense training expertise and experience” before period at end of third sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s427/2/A"},"text":"Pub. L. 118–63, § 427(2)(A)","children":[],"tail":", substituted “Except as provided in paragraph (8), neither” for “Neither”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s427/2/B"},"text":"Pub. L. 118–63, § 427(2)(B)","children":[],"tail":", added par. (8)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/16/C"},"text":"Pub. L. 115–254, § 1991(d)(16)(C)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration” for “Under Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/16/A/i"},"text":"Pub. L. 115–254, § 1991(d)(16)(A)(i)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration” for “Under Secretary for Border and Transportation Security of the Department of Homeland Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/16/A/ii"},"text":"Pub. L. 115–254, § 1991(d)(16)(A)(ii)","children":[],"tail":", substituted “The” for “Not later than one year after the date of enactment of the Vision 100—Century of Aviation Reauthorization Act, the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/16/A/iii"},"text":"Pub. L. 115–254, § 1991(d)(16)(A)(iii)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"December 12, 2003","children":[],"tail":",” for “the date of enactment of the Vision 100—Century of Aviation Reauthorization Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/16/B/i"},"text":"Pub. L. 115–254, § 1991(d)(16)(B)(i)","children":[],"tail":", substituted “The” for “Not later than one year after the date of enactment of the Vision 100—Century of Aviation Reauthorization Act, the”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/16/B/ii"},"text":"Pub. L. 115–254, § 1991(d)(16)(B)(ii)","children":[],"tail":", substituted “Federal Air Marshal Service” for “Federal Air Marshals Service”."}],"