{"tag":"section","attrib":{"id":"idcc40b251-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46505"},"text":null,"children":[{"tag":"num","attrib":{"value":"46505"},"text":"§ 46505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carrying a weapon or explosive on an aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc40b252-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, “loaded firearm” means a starter gun or a weapon designed or converted to expel a projectile through an explosive, that has a cartridge, a detonator, or powder in the chamber, magazine, cylinder, or clip.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc40b253-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Criminal Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual shall be fined under title 18, imprisoned for not more than 10 years, or both, if the individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc40b254-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46505/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when on, or attempting to get on, an aircraft in, or intended for operation in, air transportation or intrastate air transportation, has on or about the individual or the property of the individual a concealed dangerous weapon that is or would be accessible to the individual in flight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc40b255-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46505/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has placed, attempted to place, or attempted to have placed a loaded firearm on that aircraft in property not accessible to passengers in flight; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc40b256-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46505/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has on or about the individual, or has placed, attempted to place, or attempted to have placed on that aircraft, an explosive or incendiary device.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc40b257-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Penalty Involving Disregard for Human Life","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who willfully and without regard for the safety of human life, or with reckless disregard for the safety of human life, violates subsection (b) of this section, shall be fined under title 18, imprisoned for not more than 20 years, or both, and, if death results to any person, shall be imprisoned for any term of years or for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc40b258-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46505/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (b)(1) of this section does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc40b259-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46505/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement officer of a State or political subdivision of a State, or an officer or employee of the United States Government, authorized to carry arms in an official capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc40b25a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46505/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another individual the Administrator of the Federal Aviation Administration or the Administrator of the Transportation Security Administration by regulation authorizes to carry a dangerous weapon in air transportation or intrastate air transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc40b25b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46505/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual transporting a weapon (except a loaded firearm) in baggage not accessible to a passenger in flight if the air carrier was informed of the presence of the weapon.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc40b25c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46505/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conspiracy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If two or more persons conspire to violate subsection (b) or (c), and one or more of such persons do any act to effect the object of the conspiracy, each of the parties to such conspiracy shall be punished as provided in such subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc40b25d-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1244"},"text":"108 Stat. 1244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVII/s705/b"},"text":"Pub. L. 104–132, title VII, § 705(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-04-24"},"text":"Apr. 24, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1295"},"text":"110 Stat. 1295","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tVIII"},"text":"Pub. L. 107–56, title VIII","children":[],"tail":", §§ 810(g), 811(j), "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/381"},"text":"115 Stat. 381","children":[],"tail":", 382; "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s140/d/8"},"text":"Pub. L. 107–71, title I, § 140(d)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/642"},"text":"115 Stat. 642","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/h/1"},"text":"Pub. L. 115–254, div. K, title I, § 1991(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3645"},"text":"132 Stat. 3645","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc40b25e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc40b25f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc40b260-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46505(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1472(","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")(4)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 902("},{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")(4); added "},{"tag":"html:span","attrib":{},"text":"Feb. 18, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/193/s502/c"},"text":"Pub. L. 96–193, § 502(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/59"},"text":"94 Stat. 59","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46505(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1472(","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")(1)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 902("},{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")(1); added "},{"tag":"html:span","attrib":{},"text":"Sept. 5, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/197/s1"},"text":"Pub. L. 87–197, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/466"},"text":"75 Stat. 466","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 5, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/366/s203"},"text":"Pub. L. 93–366, § 203","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/417"},"text":"88 Stat. 417","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Feb. 18, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/193/s502/a"},"text":"Pub. L. 96–193, § 502(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/59"},"text":"94 Stat. 59","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/473/s2014/c/1"},"text":"Pub. L. 98–473, § 2014(c)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2189"},"text":"98 Stat. 2189","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46505(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1472(","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")(2)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 902("},{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")(2); added "},{"tag":"html:span","attrib":{},"text":"Sept. 5, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/197/s1"},"text":"Pub. L. 87–197, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/466"},"text":"75 Stat. 466","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Aug. 5, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/366/s203"},"text":"Pub. L. 93–366, § 203","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/418"},"text":"88 Stat. 418","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 12, 1984","children":[],"tail":", Pub. L 98–473, § 2014(c)(2), "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2189"},"text":"98 Stat. 2189","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46505(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1472(","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")(3)."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 902("},{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")(3); added "},{"tag":"html:span","attrib":{},"text":"Sept. 5, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/197/s1"},"text":"Pub. L. 87–197, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/466"},"text":"75 Stat. 466","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Aug. 5, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/366/s203"},"text":"Pub. L. 93–366, § 203","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/418"},"text":"88 Stat. 418","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Feb. 18, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/193/s502/b"},"text":"Pub. L. 96–193, § 502(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/59"},"text":"94 Stat. 59","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the definition of “firearm” is merged with the definition of “loaded firearm” because the term “firearm” is only used in the defined term “loaded firearm”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the words “fined under title 18” are substituted for “fined not more than $10,000” and “fined not more than $25,000” for consistency with title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b)(1) and (d)(2), the words “deadly or” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “baggage or other” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the words “bomb or similar” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1), the words “State or political subdivision of a State” are substituted for “municipal or State government” for consistency in the revised title and with other titles of the United States Code. The words “or required” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(3), the word “contained” is omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc40b261-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc40b262-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" substituted “Administrator of the Transportation Security Administration” for “Under Secretary of Transportation for Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s810/g"},"text":"Pub. L. 107–56, § 810(g)","children":[],"tail":", substituted “20 years, or both, and, if death results to any person, shall be imprisoned for any term of years or for life.” for “15 years, or both.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s140/d/8"},"text":"Pub. L. 107–71, § 140(d)(8)","children":[],"tail":", inserted “or the Under Secretary of Transportation for Security” after “Federal Aviation Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56/s811/j"},"text":"Pub. L. 107–56, § 811(j)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s705/b/1"},"text":"Pub. L. 104–132, § 705(b)(1)","children":[],"tail":", substituted “10 years” for “one year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s705/b/2"},"text":"Pub. L. 104–132, § 705(b)(2)","children":[],"tail":", substituted “15 years” for “5 years”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
