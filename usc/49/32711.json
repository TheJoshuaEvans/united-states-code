{"tag":"section","attrib":{"id":"idcb81f6a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32711"},"text":null,"children":[{"tag":"num","attrib":{"value":"32711"},"text":"§ 32711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to State law","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Except to the extent that State law is inconsistent with this chapter, this chapter does not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb81f6a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32711/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" affect a State law on disconnecting, altering, or tampering with an odometer with intent to defraud; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb81f6a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32711/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" exempt a person from complying with that law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb81f6a6-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1056"},"text":"108 Stat. 1056","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb81f6a7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb81f6a8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb81f6a9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgr