{"tag":"section","attrib":{"id":"idcb5e41a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31103"},"text":null,"children":[{"tag":"num","attrib":{"value":"31103"},"text":"§ 31103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial motor vehicle operators grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb5e41aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall administer a commercial motor vehicle operators grant program funded under section 31104.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb5e41ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The purpose of the grant program is to train individuals in the safe operation of commercial motor vehicles (as defined in section 31301).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb5e41ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veterans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In administering grants under this section, the Secretary shall award priority to grant applications for programs to train former members of the armed forces (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of title 10","children":[],"tail":") in the safe operation of such vehicles."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb5e41ad-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/987"},"text":"108 Stat. 987","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4003/d"},"text":"Pub. L. 105–178, title IV, § 4003(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/397"},"text":"112 Stat. 397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4307/a"},"text":"Pub. L. 109–59, title IV, § 4307(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1774"},"text":"119 Stat. 1774","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32933/c"},"text":"Pub. L. 112–141, div. C, title II, § 32933(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/830"},"text":"126 Stat. 830","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV/s5101/b"},"text":"Pub. L. 114–94, div. A, title V, § 5101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1523"},"text":"129 Stat. 1523","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","i