{"tag":"section","attrib":{"id":"idcc34cc2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45103"},"text":null,"children":[{"tag":"num","attrib":{"value":"45103"},"text":"§ 45103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc34cc2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Alcohol or a Controlled Substance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual may not use alcohol or a controlled substance after ","children":[{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", in violation of law or a United States Government regulation and serve as an airman, crewmember, airport security screening employee, air carrier employee responsible for safety-sensitive functions (as decided by the Administrator of the Federal Aviation Administration), or employee of the Administration with responsibility for safety-sensitive functions."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc34cc2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rehabilitation Required To Resume Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a) of this section, an individual found to have used alcohol or a controlled substance after ","children":[{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", in violation of law or a Government regulation may serve as an airman, crewmember, airport security screening employee, air carrier employee responsible for safety-sensitive functions (as decided by the Administrator), or employee of the Administration with responsibility for safety-sensitive functions only if the individual completes a rehabilitation program described in "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s45105"},"text":"section 45105 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc34cc2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance of Prior Duties Prohibited","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual who served as an airman, crewmember, airport security screening employee, air carrier employee responsible for safety-sensitive functions (as decided by the Administrator), or employee of the Administration with responsibility for safety-sensitive functions and who was found by the Administrator to have used alcohol or a controlled substance after ","children":[{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", in violation of law or a Government regulation may not carry out the duties related to air transportation that the individual carried out before the finding of the Administrator if the individual—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc34cc2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used the alcohol or controlled substance when on duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cc30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" began or completed a rehabilitation program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s45105"},"text":"section 45105 of this title","children":[],"tail":" before using the alcohol or controlled substance; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cc31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refuses to begin or complete a rehabilitation program described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s45105"},"text":"section 45105 of this title","children":[],"tail":" after a finding by the Administrator under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc34cc32-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1222"},"text":"108 Stat. 1222","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s139/2"},"text":"Pub. L. 107–71, title I, § 139(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/640"},"text":"115 Stat. 640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc34cc33-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc34cc34-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width