{"tag":"section","attrib":{"id":"idcc77a152-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107"},"text":null,"children":[{"tag":"num","attrib":{"value":"60107"},"text":"§ 60107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State pipeline safety grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc77a153-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a State authority files an application not later than September 30 of a calendar year, the Secretary of Transportation shall pay not more than 80 percent of the cost of the personnel, equipment, and activities the authority reasonably requires during the next calendar year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc77a154-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out a safety program under a certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s60105"},"text":"section 60105 of this title","children":[],"tail":" or an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s60106"},"text":"section 60106 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc77a155-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to act as an agent of the Secretary on interstate gas pipeline facilities or interstate hazardous liquid pipeline facilities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc77a156-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After notifying and consulting with a State authority, the Secretary may withhold any part of a payment when the Secretary decides that the authority is not carrying out satisfactorily a safety program or not acting satisfactorily as an agent. The Secretary may pay an authority under this section only when the authority ensures the Secretary that it will provide the remaining costs of a safety program, except when the Secretary waives this requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc77a157-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Apportionment and Method of Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall apportion the amount appropriated to carry out this section among the States. A payment may be made under this section in installments, in advance, or on a reimbursable basis.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc77a158-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Authority and Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc77a159-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may prescribe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc77a15a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the form of, and way of filing, an application under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc77a15b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reporting and fiscal procedures the Secretary considers necessary to ensure the proper accounting of money of the Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc77a15c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifications for a State to meet to receive a payment under this section, including qualifications for State employees who perform inspection activities under section 60105 or 60106 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc77a15d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The qualifications prescribed under paragraph (1)(C) of this subsection may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc77a15e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the experience and training of the employee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc77a15f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" order training or other requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc77a160-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for approval of qualifications on a conditional basis until specified requirements are met.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc77a161-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60107/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repurposing of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a State program’s certification is rejected under section 60105(f) or such program is otherwise suspended or interrupted, the Secretary may use any undistributed, deobligated, or recovered funds authorized under this section to carry out pipeline safety activities for that State within the period of availability for such funds.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc77a162-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/