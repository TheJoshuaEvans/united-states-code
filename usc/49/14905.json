{"tag":"section","attrib":{"id":"idcb05e8f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14905"},"text":null,"children":[{"tag":"num","attrib":{"value":"14905"},"text":"§ 14905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Penalties for violations of rules relating to loading and unloading motor vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb05e8f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever knowingly authorizes, consents to, or permits a violation of subsection (a) or (b) of section 14103 or who knowingly violates subsection (a) of such section is liable to the United States for a civil penalty of not more than $10,000 for each violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e8f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever knowingly violates ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s14103/b"},"text":"section 14103(b) of this title","children":[],"tail":" shall be fined under title 18 or imprisoned not more than 2 years, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb05e8fa-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29