{"tag":"section","attrib":{"id":"idcb4fea2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146"},"text":null,"children":[{"tag":"num","attrib":{"value":"30146"},"text":"§ 30146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Release of motor vehicles and bonds","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb4fea30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance Certification and Bond","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4fea31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsections (c) and (d) of this section, an importer registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30141/c"},"text":"section 30141(c) of this title","children":[],"tail":" may license or register an imported motor vehicle for use on public streets, roads, or highways, or release custody of a motor vehicle imported by the registered importer or imported by an individual under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s30142"},"text":"section 30142 of this title","children":[],"tail":" and altered by the registered importer to meet applicable motor vehicle safety standards prescribed under this chapter to a person for license or registration for use on public streets, roads, or highways, only after 30 days after the registered importer certifies to the Secretary of Transportation, in the way the Secretary prescribes, that the motor vehicle complies with each standard prescribed in the year the vehicle was manufactured and that applies in that year to that vehicle. A vehicle may not be released if the Secretary gives written notice before the end of the 30-day period that the Secretary will inspect the vehicle under subsection (c) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretaries of Transportation and the Treasury shall prescribe regulations—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb4fea33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the release of a motor vehicle and bond required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30141/d"},"text":"section 30141(d) of this title","children":[],"tail":" at the end of the 30-day period, unless the Secretary of Transportation issues a notice of an inspection under subsection (c) of this section; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4fea34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing that the Secretary of Transportation shall release the vehicle and bond promptly after an inspection under subsection (c) of this section showing compliance with the standards applicable to the vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each registered importer shall include on each motor vehicle released under this subsection a label prescribed by the Secretary of Transportation identifying the importer and stating that the vehicle has been altered by the importer to comply with the standards applicable to the vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fea36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reliance on Manufacturer’s Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making a certification under subsection (a)(1) of this section, the registered importer may rely on the manufacturer’s certification for the model to which the motor vehicle involved is substantially similar if the importer certifies that any alteration made by the importer did not affect the compliance of the safety features of the vehicle and the importer keeps records verifying the certification for the period the Secretary of Transportation prescribes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fea37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidence of Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4fea38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation may require that the certification under subsection (a)(1) of this section be accompanied by evidence of compliance the Secretary considers appropriate or may inspect the certified motor vehicle, or both. If the Secretary gives notice of an inspection, an importer may release the vehicle only after—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb4fea39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an inspection showing the motor vehicle complies with applicable motor vehicle safety standards prescribed under this chapter for which the inspection was made; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4fea3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" release of the vehicle by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall inspect periodically a representative number of motor vehicles for which certifications have been filed under subsection (a)(1) of this section. In carrying out a motor vehicle testing program under this chapter, the Secretary shall include a representative number of motor vehicles for which certifications have been filed under subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fea3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Challenging the Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A motor vehicle or bond may not be released under subsection (a) of this section if the Secretary of Transportation, not later than 30 days after receiving a certification under subsection (a)(1) of this section, gives written notice that the Secretary believes or has reason to believe that the certification is false or contains a mispresentation.","children":[{"tag":"ref","attrib":{"idref":"fn002109"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002109"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “misrepresentation.”"}],"tail":" The vehicle and bond may be released only after the Secretary is satisfied with the certification and any modification of the certification."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fea3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30146/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bond Release","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A release of a bond required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30141/d"},"text":"section 30141(d) of this title","children":[],"tail":" is deemed an acceptance of a certification or completion of an inspection under this section but is not a decision by the Secretary of Transportation under section 30118(a) or (b) of this title of compliance with applicable motor vehicle safety standards prescribed under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb4fea3e-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/964"},"text":"108 Stat. 964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb4fea3f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb4fea40-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb4fea41-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30146(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(c)(3)(E)(i) (1st, 3d, last sentences), (vii).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563"},"text":"Pub. L. 89–563","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/718"},"text":"80 Stat. 718","children":[],"tail":", § 108(c)(3)(E); added "},{"tag":"html:span","attrib":{},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/562/s2/b"},"text":"Pub. L. 100–562, § 2(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2820"},"text":"102 Stat. 2820","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30146(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(c)(3)(E)(ii).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30146(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(c)(3)(E)(i) (2d sentence), (iii), (iv).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30146(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(c)(3)(E)(vi).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30146(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(c)(3)(E)(v).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “Except as provided in subsections (c) and (d) of this section” are added because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(B), the words “showing compliance with the standards” are substituted for “showing no such failure to comply” for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
