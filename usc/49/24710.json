{"tag":"section","attrib":{"id":"idcb381bae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710"},"text":null,"children":[{"tag":"num","attrib":{"value":"24710"},"text":"§ 24710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Long-distance routes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb381baf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Evaluation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using the financial and performance metrics developed under section 207 of the Passenger Rail Investment and Improvement Act of 2008, Amtrak shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb381bb0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluate annually the financial and operating performance of each long-distance passenger rail route operated by Amtrak; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb381bb1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rank the overall performance of such routes for 2008 and identify each long-distance passenger rail route operated by Amtrak in 2008 according to its overall performance as belonging to the best performing third of such routes, the second best performing third of such routes, or the worst performing third of such routes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb381bb2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Improvement Plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amtrak shall develop and post on its website a performance improvement plan for its long-distance passenger rail routes to achieve financial and operating improvements based on the data collected through the application of the financial and performance metrics developed under section 207 of that Act. The plan shall address—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb381bb3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on-time performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb381bb4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" scheduling, frequency, routes, and stops;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb381bb5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the feasibility of restructuring service into connected corridor service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb381bb6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" performance-related equipment changes and capital improvements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb381bb7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on-board amenities and service, including food, first class, and sleeping car service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb381bb8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State or other non-Federal financial contributions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb381bb9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving financial performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb381bba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anticipated Federal funding of operating and capital costs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb381bbb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other aspects of Amtrak’s long-distance passenger rail routes that affect the financial, competitive, and functional performance of service on Amtrak’s long-distance passenger rail routes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb381bbc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amtrak shall implement the performance improvement plan developed under subsection (b)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb381bbd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning in fiscal year 2010 for those routes identified as being in the worst performing third under subsection (a)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb381bbe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning in fiscal year 2011 for those routes identified as being in the second best performing third under subsection (a)(2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb381bbf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" beginning in fiscal year 2012 for those routes identified as being in the best performing third under subsection (a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb381bc0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Railroad Administration shall monitor the development, implementation, and outcome of improvement plans under this section. If the Federal Railroad Administration determines that Amtrak is not making reasonable progress in implementing its performance improvement plan or, after the performance improvement plan is implemented under subsection (c)(1) in accordance with the terms of that plan, Amtrak has not achieved the outcomes it has established for such routes, under the plan for any calendar year, the Federal Railroad Administration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb381bc1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall notify Amtrak, the Inspector General of the Department of Transportation, the Committee on Transportation and Infrastructure of the House of Representatives, and the Committee on Commerce, Science, and Transportation of the Senate of its determination under this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb381bc2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide Amtrak with an opportunity for a hearing with respect to that determination; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb381bc3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24710/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may withhold appropriated funds otherwise available to Amtrak for the operation of a route or routes from among the worst performing third of routes currently served by Amtrak on which Amtrak is not making reasonable progress, other than funds made available for passenger safety or security measures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb381bc4-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tII/s210/a"},"text":"Pub. L. 110–432, div. B, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4918"},"text":"122 Stat. 4918","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb381bc5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb381bc6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb381bc7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 207 of the Passenger Rail Investment and Improvement Act of 2008, referred to in subsecs. (a) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s207"},"text":"section 207 of Pub. L. 110–432","children":[],"tail":", which is set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s24101"},"text":"section 24101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
