{"tag":"section","attrib":{"id":"idcae9603d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11145"},"text":null,"children":[{"tag":"num","attrib":{"value":"11145"},"text":"§ 11145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by rail carriers, lessors, and associations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcae9603e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11145/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board may require—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcae9603f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11145/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rail carriers, lessors, and associations, or classes of them as the Board may prescribe, to file annual, periodic, and special reports with the Board containing answers to questions asked by it; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae96040-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11145/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person furnishing cars to a rail carrier to file reports with the Board containing answers to questions about those cars.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae96041-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11145/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcae96042-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11145/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An annual report shall contain an account, in as much detail as the Board may require, of the affairs of the rail carrier, lessor, or association for the 12-month period ending on December 31 of each year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae96043-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11145/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An annual report shall be filed with the Board by the end of the third month after the end of the year for which the report is made unless the Board extends the filing date or changes the period covered by the report. The annual report and, if the Board requires, any other report made under this section, shall be made under oath.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcae96044-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/835"},"text":"109 Stat. 835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcae96045-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcae96046-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcae96047-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"tex