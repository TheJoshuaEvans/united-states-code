{"tag":"section","attrib":{"id":"idcc30105c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44934"},"text":null,"children":[{"tag":"num","attrib":{"value":"44934"},"text":"§ 44934.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Security Liaison Officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc30105d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44934/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment, Designation, and Stationing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Transportation Security Administration shall establish the position of Foreign Security Liaison Officer for each airport outside the United States at which the Administrator decides an Officer is necessary for air transportation security. In coordination with the Secretary of State, the Administrator shall designate an Officer for each of those airports. In coordination with the Secretary of State, the Administrator shall designate an Officer for each of those airports where extraordinary security measures are in place. The Secretary of State shall give high priority to stationing those Officers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc30105e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44934/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties and Powers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An Officer reports directly to the Administrator of the Transportation Security Administration. The Officer at each airport shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc30105f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44934/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the liaison of the Administrator to foreign security authorities (including governments of foreign countries and foreign airport authorities) in carrying out United States Government security requirements at that airport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc301060-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44934/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, carry out duties and powers referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44933/b"},"text":"section 44933(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc301061-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44934/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination of Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The activities of each Officer shall be coordinated with the chief of the diplomatic mission of the United States to which the Officer is assigned. Activities of an Officer under this section shall be consistent with the duties and powers of the Secretary of State and the chief of mission to a foreign country under section 103 of the Omnibus Diplomatic Security and Antiterrorism Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s4802"},"text":"22 U.S.C. 4802","children":[],"tail":") and section 207 of the Foreign Service Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/usc/t22/s3927"},"text":"22 U.S.C. 3927","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc301062-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1217"},"text":"108 Stat. 1217","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s101/f/4"},"text":"Pub. L. 107–71, title I, § 101(f)(4)","children":[],"tail":", (5), (7), (9), "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/603"},"text":"115 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/d/25"},"text":"Pub. L. 115–254, div. K, title I, § 1991(d)(25)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3638"},"text":"132 Stat. 3638","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc301063-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc301064-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc301065-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44934(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358b(b)(1), (2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 319(b); added "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/604/s104"},"text":"Pub. L. 101–604, § 104","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3071"},"text":"104 Stat. 3071","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44934(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358b(b)(3), (4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44934(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358b(b)(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":"” are omitted as obsolete. The words “shall designate” are substituted for “shall begin assigning” for consistency with the source provisions restated in section 44933 of the revised title and because of the restatement. The words “Not later than 2 years after "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":"” are omitted as obsolete. The word “designate” is substituted for “assign” for consistency with the source provisions restated in section 44933 of the revised title. The words “outside the United States” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “to the office of” are omitted as unnecessary. In clause (1), the words “governments of foreign countries and foreign airport authorities” are substituted for “foreign governments and airport authorities” for clarity and consistency in the revised title and with other titles of the United States Code. In clause (2), the words “duties and powers” are substituted for “responsibilities” for consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “duties and powers” are substituted for “authorities” for clarity and consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc301066-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc301067-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/25/A"},"text":"Pub. L. 115–254, § 1991(d)(25)(A)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration” for “Under Secretary of Transportation for Security”, “airports. In coordination with the Secretary of State” for “airports. In coordination with the Secretary”, “The Secretary of State shall give high priority” for “The Secretary shall give high priority”, and, wherever appearing, “Administrator” for “Under Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/25/B/i"},"text":"Pub. L. 115–254, § 1991(d)(25)(B)(i)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration” for “Under Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/25/B/ii"},"text":"Pub. L. 115–254, § 1991(d)(25)(B)(ii)","children":[],"tail":", substituted “Administrator” for “Under Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/25/C"},"text":"Pub. L. 115–254, § 1991(d)(25)(C)","children":[],"tail":", substituted “the Secretary of State and the chief” for “the Secretary and the chief”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s101/f/7"},"text":"Pub. L. 107–71, § 101(f)(7)","children":[],"tail":", (9), substituted “Under Secretary” for “Administrator” wherever appearing and “of Transportation for Security” for “of the Federal Aviation Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s101/f/4"},"text":"Pub. L. 107–71, § 101(f)(4)","children":[],"tail":", substituted “Under Secretary” for “Assistant Administrator for Civil Aviation Security” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s101/f/5"},"text":"Pub. L. 107–71, § 101(f)(5)","children":[],"tail":", substituted “Under Secretary” for “Assistant Administrator”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
