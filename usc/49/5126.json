{"tag":"section","attrib":{"id":"idca95e877-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5126"},"text":null,"children":[{"tag":"num","attrib":{"value":"5126"},"text":"§ 5126.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca95e878-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5126/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person under contract with a department, agency, or instrumentality of the United States Government that transports hazardous material, or causes hazardous material to be transported, or designs, manufactures, fabricates, inspects, marks, maintains, reconditions, repairs, or tests a package, container, or packaging component that is represented as qualified for use in transporting hazardous material shall comply with this chapter, regulations prescribed and orders issued under this chapter, and all other requirements of the Government, State and local governments, and Indian tribes (except a requirement preempted by a law of the United States) in the same way and to the same extent that any person engaging in that transportation, designing, manufacturing, fabricating, inspecting, marking, maintaining, reconditioning, repairing, or testing that is in or affects commerce must comply with the provision, regulation, order, or requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e879-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5126/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95e87a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5126/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pipeline subject to regulation under chapter 601 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e87b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5126/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any matter that is subject to the postal laws and regulations of the United States under this chapter or title 18 or 39.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca95e87c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/783"},"text":"108 Stat. 783","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/311/tI/s117/a/2"},"text":"Pub. L. 103–311, title I, § 117(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1678"},"text":"108 Stat. 1678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII/s7124"},"text":"Pub. L. 109–59, title VII, § 7124","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1908"},"text":"119 Stat. 1908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/tIII/s302/d"},"text":"Pub. L. 110–244, title III, § 302(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1618"},"text":"122 Stat. 1618","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca95e87d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca95e87e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca95e87f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"chil