 "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633/s112/f"},"text":"Pub. L. 93–633, § 112(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2161"},"text":"88 Stat. 2161","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/129/s216/a"},"text":"Pub. L. 96–129, § 216(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/1015"},"text":"93 Stat. 1015","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/615/s13"},"text":"Pub. L. 101–615, § 13","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3260"},"text":"104 Stat. 3260","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “manufactures” is substituted for “manufacturers” to correct an error in the source provisions. The words “of the executive, legislative, or judicial branch”, “be subject to and”, “substantive and procedural”, and “this chapter or any other” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca95e880-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca95e881-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":". See 2005 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7124/4"},"text":"Pub. L. 109–59, § 7124(4)","children":[],"tail":", substituted “designing, manufacturing, fabricating, inspecting, marking, maintaining, reconditioning, repairing, or testing” for “manufacturing, fabricating, marking, maintenance, reconditioning, repairing, or testing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7124/3"},"text":"Pub. L. 109–59, § 7124(3)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":", substituted “shall comply with this chapter” for “must comply with this chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7124/1"},"text":"Pub. L. 109–59, § 7124(1)","children":[],"tail":", (2), substituted “transports hazardous material, or causes hazardous material to be transported,” for “transports or causes to be transported hazardous material,” and “designs, manufactures, fabricates, inspects, marks, maintains, reconditions, repairs, or tests a package, container, or packaging component that is represented” for “manufactures, fabricates, marks, maintains, reconditions, repairs, or tests a packaging or a container that the person represents, marks, certifies, or sells”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/311"},"text":"Pub. L. 103–311","children":[],"tail":" substituted “a packaging or a” for “a package or”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca95e882-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca95e883-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" effective as of the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":") and to be treated as included in "},{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" as of that date, and provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", as in effect on the day before "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", that are amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" to be treated as not enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/s121/b"},"text":"section 121(b) of Pub. L. 110–244","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
