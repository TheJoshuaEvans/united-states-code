{"tag":"section","attrib":{"id":"idcb54a502-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304"},"text":null,"children":[{"tag":"num","attrib":{"value":"30304"},"text":"§ 30304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by chief driver licensing officials","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb54a503-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individuals Covered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As soon as practicable, the chief driver licensing official of each participating State shall submit to the Secretary of Transportation a report containing the information specified by subsection (b) of this section for each individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb54a504-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is denied a motor vehicle operator’s license by that State for cause;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a505-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose motor vehicle operator’s license is revoked, suspended, or canceled by that State for cause; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a506-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" who is convicted under the laws of that State of any of the following motor vehicle-related offenses or comparable offenses:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb54a507-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operating a motor vehicle while under the influence of, or impaired by, alcohol or a controlled substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a508-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a traffic violation arising in connection with a fatal traffic accident, reckless driving, or racing on the highways.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a509-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failing to give aid or provide identification when involved in an accident resulting in death or personal injury.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a50a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" perjury or knowingly making a false affidavit or statement to officials about activities governed by a law or regulation on the operation of a motor vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a50b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb54a50c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, a report under subsection (a) of this section shall contain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb54a50d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual’s legal name, date of birth, sex, and, at the Secretary’s discretion, height, weight, and eye and hair color;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a50e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the State providing the information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a50f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the social security account number if used by the State for driver record or motor vehicle license purposes, and the motor vehicle operator’s license number if different from the social security account number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a510-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A report under subsection (a) of this section about an event that occurs during the 2-year period before the State becomes a participating State is sufficient if the report contains all of the information that is available to the chief driver licensing official when the State becomes a participating State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a511-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time for Filing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a report under subsection (a) of this section is about an event that occurs—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb54a512-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during the 2-year period before the State becomes a participating State, the report shall be submitted not later than 6 months after the State becomes a participating State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a513-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the State becomes a participating State, the report shall be submitted not later than 31 days after the motor vehicle department of the State receives any information specified in subsection (b)(1) of this section that is the subject of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a514-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Events Occurring Before Participation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not require a State to report information about an event that occurs before the 2-year period before the State becomes a participating State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a515-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30304/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Driver Record Inquiry","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before issuing a motor vehicle operator’s license to an individual or renewing such a license, a State shall request from the Secretary information from the National Driver Register under section 30302 and the commercial driver’s license information system under section 31309 on the individual’s driving record.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb54a516-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/975"},"text":"108 Stat. 975","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/159/tII/s204"},"text":"Pub. L. 106–159, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1762"},"text":"113 Stat. 1762","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb54a517-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb54a518-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb54a519-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30304","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"23:401 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 25, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/364/s205"},"text":"Pub. L. 97–364, § 205","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1742"},"text":"96 Stat. 1742","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “after the date of enactment of this title [","children":[{"tag":"date","attrib":{"date":"1982-10-25"},"text":"Oct. 25, 1982","children":[],"tail":"]” are omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(A), the words “(including day, month, and year)” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “A report under subsection (a) of this section” are substituted for “any report concerning an occurrence specified in subsection (a)(1), (2), or (3) of this section” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), before clause (1), the words “required to be transmitted by a chief driver licensing official of a State” are omitted as surplus. In clause (1), the words “specified in subsection (a)(1), (2), or (3) of this section” are omitted as surplus. In clause (2), the words “the motor vehicle department of the State receives any information specified in subsection (b)(1) of this section that is the subject of the report” are substituted for “receipt by a State motor vehicle department of any information specified in subsection (b)(1), (2), or (3) of this section which is the subject of such report” because of the restatement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb57151a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb57151b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159"},"text":"Pub. L. 106–159","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
