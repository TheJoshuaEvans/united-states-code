{"tag":"section","attrib":{"id":"idcbcbd0c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736"},"text":null,"children":[{"tag":"num","attrib":{"value":"41736"},"text":"§ 41736.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air transportation to noneligible places","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbcbd0c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proposals and Decisions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbcbd0c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A State or local government may propose to the Secretary of Transportation that the Secretary provide compensation to an air carrier to provide air transportation to a place that is not an eligible place under this subchapter. Not later than 90 days after receiving a proposal under this section, the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbcbd0ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decide whether to designate the place as eligible to receive compensation under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbcbd0cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbcbd0cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approve the proposal if the State or local government or a person is willing and able to pay 50 percent of the compensation for providing the transportation, and notify the State or local government of the approval; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbcbd0cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disapprove the proposal if the Secretary decides the proposal is not reasonable under paragraph (2) of this subsection, and notify the State or local government of the disapproval and the reasons for the disapproval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbcbd0ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In deciding whether a proposal is reasonable, the Secretary shall consider, among other factors—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbcbd0cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the traffic-generating potential of the place;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbcbd0d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost to the United States Government of providing the proposed transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbcbd0d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distance of the place from the closest hub airport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbcbd0d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval for Certain Air Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsection (a)(1)(B) of this section, the Secretary shall approve a proposal under this section to compensate an air carrier for providing air transportation to a place in the 48 contiguous States or the District of Columbia and designate the place as eligible for compensation under this section if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbcbd0d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at any time before ","children":[{"tag":"date","attrib":{"date":"1978-10-23"},"text":"October 23, 1978","children":[],"tail":", the place was served by a carrier holding a certificate under section 401 of the Federal Aviation Act of 1958;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbcbd0d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the place is more than 50 miles from the nearest small hub airport or an eligible place;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbcbd0d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the place is more than 150 miles from the nearest hub airport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbcbd0d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or local government submitting the proposal or a person is willing and able to pay 25 percent of the cost of providing the compensated transportation.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Paragraph (4) does not apply to any community approved for service under this section during the period beginning ","children":[{"tag":"date","attrib":{"date":"1991-10-01"},"text":"October 1, 1991","children":[],"tail":", and ending "},{"tag":"date","attrib":{"date":"1997-12-31"},"text":"December 31, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbcbd0d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Level of Air Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbcbd0d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary designates a place under subsection (a)(1) of this section as eligible for compensation under this section, the Secretary shall decide, not later than 6 months after the date of the designation, on the level of air transportation to be provided under this section. Before making a decision, the Secretary shall consider the views of any interested community, the appropriate State authority of the State in which the place is located, and the State or local government or person agreeing to pay compensation for the transportation under subsection (b)(4) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbcbd0d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After making the decision under paragraph (1) of this subsection, the Secretary shall provide notice that any air carrier that is willing to provide the level of air transportation established under paragraph (1) for a place may submit an application to provide the transportation. In selecting an applicant, the Secretary shall consider, among other factors—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbcbd0da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the factors listed in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41733/c/1"},"text":"section 41733(c)(1) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbcbd0db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the views of the State or local government or person agreeing to pay compensation for the transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbcbd0dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation Payments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbcbd0dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall pay compensation under this section when and in the way the Secretary decides is appropriate. The Secretary shall continue to pay compensation under this section only as long as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbcbd0de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the air carrier maintains the level of air transportation established by the Secretary under subsection (c)(1) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbcbd0df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or local government or person agreeing to pay compensation for transportation under this section continues to pay that compensation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbcbd0e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary decides the compensation is necessary to maintain the transportation to the place.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbcbd0e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may require the State or local government or person agreeing to pay compensation under this section to make advance payments or provide other security to ensure that timely payments are made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbcbd0e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall review periodically the level of air transportation provided under this section. Based on the review and consultation with any interested community, the appropriate State authority of the State in which the community is located, and the State or local government or person paying compensation under this section, the Secretary may make appropriate adjustments in the level of transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbcbd0e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withdrawal of Eligibility Designations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After providing notice and an opportunity for interested persons to comment, the Secretary may withdraw the designation of a place under subsection (a)(1) of this section as eligible to receive compensation under this section if the place has received air transportation under this section for at least 2 years and the Secretary decides the withdrawal would be in the public interest. The Secretary by regulation shall prescribe standards for deciding whether the withdrawal of a designation under this subsection is in the public interest. The standards shall include the factors listed in subsection (a)(2) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbcbd0e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ending, Suspending, and Reducing Air Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier providing air transportation for compensation under this section may end, suspend, or reduce that transportation below the level of transportation established by the Secretary under this section only after giving the Secretary, the affected community, and the State or local government or person paying compensation under this section at least 30 days’ notice before ending, suspending, or reducing the transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbcbd0e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbcbd0e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proposals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No proposal under subsection (a) may be accepted by the Secretary after the date of enactment of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbcbd0e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41736/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not provide any compensation under this section after the date that is 2 years after the date of enactment of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbcbd0e8-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1149"},"text":"108 Stat. 1149","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tII/s202"},"text":"Pub. L. 106–181, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/91"},"text":"114 Stat. 91","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIV/s453/b"},"text":"Pub. L. 115–254, div. B, title IV, § 453(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3348"},"text":"132 Stat. 3348","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbcbd0e9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbcbd0ea-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbcbd0eb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":