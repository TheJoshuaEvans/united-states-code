{"tag":"section","attrib":{"id":"idcc40b242-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46503"},"text":null,"children":[{"tag":"num","attrib":{"value":"46503"},"text":"§ 46503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interference with security screening personnel","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc40b243-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual in an area within a commercial service airport in the United States who, by assaulting a Federal, airport, or air carrier employee who has security duties within the airport, interferes with the performance of the duties of the employee or lessens the ability of the employee to perform those duties, shall be fined under title 18, imprisoned for not more than 10 years, or both. If the individual used a dangerous weapon in committing the assault or interference, the individual may be imprisoned for any term of years or life imprisonment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc40b244-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Airport and Air Carrier Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, an airport or air carrier employee who has security duties within the airport includes an airport or air carrier employee performing ticketing, check-in, baggage claim, or boarding functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc40b245-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s114/a"},"text":"Pub. L. 107–71, title I, § 114(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/623"},"text":"115 Stat. 623","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIV/s436"},"text":"Pub. L. 118–63, title IV, § 436","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1176"},"text":"138 Stat. 1176","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc40b246-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc40b247-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcc40b248-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 46503, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1242"},"text":"108 Stat. 1242","children":[],"tail":", provided for death penalty sentencing procedure for individuals convicted of aircraft piracy, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60003/b/2"},"text":"Pub. L. 103–322, title VI, § 60003(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1970"},"text":"108 Stat. 1970","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc40b249-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
