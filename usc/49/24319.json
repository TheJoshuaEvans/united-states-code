{"tag":"section","attrib":{"id":"idcb333a95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319"},"text":null,"children":[{"tag":"num","attrib":{"value":"24319"},"text":"§ 24319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Grant process and reporting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb333a96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures for Grant Requests","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb333a97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish and maintain substantive and procedural requirements, including schedules, for grant requests under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb333a98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" report any changes to such procedures to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb333a99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb333a9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Requests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amtrak shall transmit to the Secretary a grant request annually, or as additionally required, for Federal funds appropriated to the Secretary of Transportation for the use of Amtrak.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb333a9e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb333a9f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each grant request under subsection (b) shall, as applicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb333aa0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" categorize and identify, by source, the Federal funds and program income that will be used for the upcoming fiscal year for each of the Northeast Corridor and National Network in 1 of the categories or subcategories set forth in paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333aa1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe the operations, services, programs, projects, and other activities to be funded within each of the categories set forth in paragraph (2), including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb333aa2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the estimated scope, schedule, and budget necessary to complete each project and program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb333aa3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance measures used to quantify expected and actual project outcomes and benefits, aggregated by fiscal year, project milestone, and any other appropriate grouping; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333aa4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the status of efforts to improve Amtrak’s safety culture.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb333aa5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant categories.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb333aa6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operating expenses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each grant request to use Federal funds for operating expenses shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb333aa7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include estimated net operating costs not covered by other Amtrak revenue sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb333aa8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specify Federal funding requested for each service line described in section 24320(b)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb333aa9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be itemized by route.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333aaa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Debt service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant request to use Federal funds for expenses related to debt, including payment of principle and interest, as allowed under section 205 of the Passenger Rail Investment and Improvement Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Public Law 110–432","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s24101"},"text":"49 U.S.C. 24101","children":[],"tail":" note)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333aab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Capital","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant request to use Federal funds and program income for capital expenses shall include capital projects and programs primarily associated with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb333aac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" normalized capital replacement programs, including regularly recurring work programs implemented on a systematic basis on classes of physical railroad assets, such as track, structures, electric traction and power systems, rolling stock, and communications and signal systems, to maintain and sustain the condition and performance of such assets to support continued railroad operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb333aad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improvement projects to support service and safety enhancements, including discrete projects implemented in accordance with a fixed scope, schedule, and budget that result in enhanced or new infrastructure, equipment, or facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb333aae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" backlog capital replacement projects, including discrete projects implemented in accordance with a fixed scope, schedule, and budget that primarily replace or rehabilitate major infrastructure assets, including tunnels, bridges, stations, and similar assets, to reduce the state of good repair backlog on the Amtrak network;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb333aaf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategic initiative projects, including discrete projects implemented in accordance with a fixed scope, schedule, and budget that primarily improve overall operational performance, lower costs, or otherwise improve Amtrak’s corporate efficiency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb333ab0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" statutory, regulatory, or other legally mandated projects, including discrete projects implemented in accordance with a fixed scope, schedule, and budget that enable Amtrak to fulfill specific legal or regulatory mandates.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333ab1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contingency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A grant request to use Federal funds for operating and capital expense contingency shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb333ab2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contingency levels for specified activities and operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb333ab3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process for the utilization of such contingency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb333ab4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modification of categories","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation and Amtrak may jointly agree to modify the categories set forth in paragraph (2) if such modifications are necessary to improve the transparency, oversight, or delivery of projects funded through grant requests under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb333ab5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review and Approval.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb333ab6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Thirty-day approval process.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb333ab7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 30 days after the date that Amtrak submits a complete grant request under this section, the Secretary of Transportation shall finish a review of the request and provide notice to Amtrak that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb333ab8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the request is approved; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb333ab9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the request is disapproved, including the reason for the disapproval and an explanation of any deficient items.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333aba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a grant request is approved, the Secretary shall enter into a grant agreement with Amtrak.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb333abb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fifteen-day modification period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 15 days after the date of a notice under paragraph (1)(A)(ii), Amtrak shall submit a modified request for the Secretary’s review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb333abc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modified requests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 15 days after the date that Amtrak submits a modified request under paragraph (2), the Secretary shall either approve the modified request, or, if the Secretary finds that the request is still incomplete or deficient, the Secretary shall identify in writing to the Committee on Commerce, Science, and Transportation and the Committee on Appropriations of the Senate and the Committee on Transportation and Infrastructure and the Committee on Appropriations of the House of Representatives the remaining deficiencies and recommend a process for resolving the outstanding portions of the request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb333abd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payments to Amtrak.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb333abe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant agreement entered into under subsection (d) shall specify the operations, services, programs, projects, and other activities to be funded by the grant, consistent with the categories required for Amtrak in a grant request under subsection (c)(1)(A). The grant agreement shall include provisions, consistent with the requirements of this chapter, to measure Amtrak’s performance and ensure accountability in delivering the operations, services, programs, projects, and other activities to be funded by the grant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb333abf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Schedule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (3), in each fiscal year for which amounts are appropriated to the Secretary for the use of Amtrak, and for which the Secretary and Amtrak have entered into a grant agreement under subsection (d), the Secretary shall disburse grant funds to Amtrak on the following schedule:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb333ac0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent on October 1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333ac1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent on January 1.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb35aac2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent on April 1.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35aac3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make a payment to Amtrak of appropriated funds—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb35aac4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using an otherwise allowable approach to the method prescribed for a specific project or category of projects under paragraph (2) if the Secretary and Amtrak agree that a different payment method is necessary to more successfully implement and report on an operation, service, program, project, or other activity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb35aac5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" more frequently than the schedule under paragraph (2) if Amtrak, for good cause, requests more frequent payment before the end of a payment period; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb35aac6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with a different frequency or in different percentage allocations in the event of a continuing resolution or in the absence of an appropriations Act for the duration of a fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35aac7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Amounts and Early Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts appropriated to the Secretary for the use of Amtrak shall remain available until expended. Amounts for capital acquisitions and improvements may be appropriated for a fiscal year before the fiscal year in which the amounts will be obligated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35aac8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts appropriated to the Secretary for the use of Amtrak may not be used to cross-subsidize operating losses or capital costs of commuter rail passenger or freight rail transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35aac9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable Laws and Regulations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb35aaca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Single audit act of 1984","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24301/a/3"},"text":"section 24301(a)(3) of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s7501/a/13"},"text":"section 7501(a)(13) of title 31","children":[],"tail":", Amtrak shall be deemed a “non-Federal entity” for purposes of chapter 75 of title 31."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35aacb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations and guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may apply some or all of the requirements set forth in the regulations and guidance promulgated by the Secretary relating to the management, administration, cost principles, and audit requirements for Federal awards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35aacc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amtrak Grant Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall determine the varying levels of detail and information that will be included in reports for operations, services, program, projects, program income, cash on hand, and other activities within each of the grant categories described in subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35aacd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24319/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Northeast Corridor","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 24102, for purposes of this section, the term “Northeast Corridor” means the Northeast Corridor main line between Boston, Massachusetts, and the District of Columbia, and facilities and services used to operate and maintain that line.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb35aace-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11202/a"},"text":"Pub. L. 114–94, div. A, title XI, § 11202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1628"},"text":"129 Stat. 1628","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/420/s4/b/1"},"text":"Pub. L. 115–420, § 4(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5444"},"text":"132 Stat. 5444","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22206/b"},"text":"Pub. L. 117–58, div. B, title II, § 22206(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/700"},"text":"135 Stat. 700","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb35aacf-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb35aad0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb35aad1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 205 of the Passenger Rail Investment and Improvement Act of 2008, referred to in subsec. (c)(2)(B), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/s205"},"text":"section 205 of div. B of Pub. L. 110–432","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s24101"},"text":"section 24101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Single Audit Act of 1984, referred to in subsec. (h)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/502"},"text":"Pub. L. 98–502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2327"},"text":"98 Stat. 2327","children":[],"tail":", which enacted chapter 75 (§ 7501 et seq.) of Title 31, Money and Finance, and provisions set out as notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s7501"},"text":"section 7501 of Title 31","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1984 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s7501"},"text":"section 7501 of Title 31","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb35aad2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22206/b/1"},"text":"Pub. L. 117–58, § 22206(b)(1)","children":[],"tail":", inserted “and reporting” after “process” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22206/b/2"},"text":"Pub. L. 117–58, § 22206(b)(2)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “Not later than 90 days after the date of enactment of the Passenger Rail Reform and Investment Act of 2015, the Secretary of Transportation shall establish and transmit to the Committee on Commerce, Science, and Transportation and the Committee on Appropriations of the Senate and the Committee on Transportation and Infrastructure and the Committee on Appropriations of the House of Representatives substantive and procedural requirements, including schedules, for grant requests under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22206/b/3"},"text":"Pub. L. 117–58, § 22206(b)(3)","children":[],"tail":", substituted “a grant request annually, or as additionally required,” for “grant requests”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22206/b/4"},"text":"Pub. L. 117–58, § 22206(b)(4)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) related to contents of grant request."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22206/b/5/A"},"text":"Pub. L. 117–58, § 22206(b)(5)(A)","children":[],"tail":", (B), inserted “complete” after “submits a” and substituted “shall finish” for “shall complete” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1)(A)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22206/b/5/C"},"text":"Pub. L. 117–58, § 22206(b)(5)(C)","children":[],"tail":", struck out “incomplete or” before “deficient items”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22206/b/6/A"},"text":"Pub. L. 117–58, § 22206(b)(6)(A)","children":[],"tail":", substituted “programs, projects, and other activities to be funded by the grant, consistent with the categories required for Amtrak in a grant request under subsection (c)(1)(A)” for “and other activities to be funded by the grant” and “programs, projects, and other activities” for “or activities”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(A) to (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22206/b/6/B"},"text":"Pub. L. 117–58, § 22206(b)(6)(B)","children":[],"tail":", added subpar. (A) and redesignated former subpars. (A) and (B) as (B) and (C), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22206/b/7"},"text":"Pub. L. 117–58, § 22206(b)(7)","children":[],"tail":", (8), added subsecs. (h) and (i) and redesignated former subsec. (h) as (j)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/420"},"text":"Pub. L. 115–420","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb35aad3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb35aad4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb35aad5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/420/s4/b/2"},"text":"Pub. L. 115–420, § 4(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5444"},"text":"132 Stat. 5444","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/420/s4/b/2"},"text":"“Nothing in this subsection [amending this section] or an amendment made by this subsection shall affect a grant request made under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24319"},"text":"section 24319 of title 49","children":[],"tail":", United States Code, before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
