{"tag":"section","attrib":{"id":"idcb05e92c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14910"},"text":null,"children":[{"tag":"num","attrib":{"value":"14910"},"text":"§ 14910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General civil penalty when specific penalty not provided","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When another civil penalty is not provided under this chapter, a person that violates a provision of this part or a regulation or order prescribed under this part, or a condition of a registration under this part related to transportation that is subject to jurisdiction under subchapter I or III of chapter 135 or a condition of a registration of a foreign motor carrier or foreign motor private carrier under section 13902, is liable to the United States for a civil penalty of $500 for each violation. A separate violation occurs each day the violation continues.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb05e92d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/917"},"text":"109 Stat. 917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb05e92e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb05e92f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb05e930-47c4-11f1-9671-b5c725212f70"},"text":null,"childre