ords) and (3a) (last sentence 1st–5th words) is omitted as executed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca7938a2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca7938a3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":" substituted “a provision of this chapter, subchapter III of chapter 311 (except sections 31138 and 31139), or "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31502"},"text":"section 31502 of this title","children":[],"tail":", a person that knowingly and willfully violates any of those provisions or a regulation or order of the Secretary of Transportation under any of those provisions” for “this chapter, "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s3102"},"text":"section 3102 of this title","children":[],"tail":", or the Motor Carrier Safety Act of 1984, a person that knowingly and willfully violates a provision of this chapter or such section or Act, or a regulation or order of the Secretary of Transportation under this chapter or such section or Act”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/554"},"text":"Pub. L. 98–554","children":[],"tail":" inserted “, "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s3102"},"text":"section 3102 of this title","children":[],"tail":", or the Motor Carrier Safety Act of 1984” after “chapter” the first place it appears and inserted “or such section or Act” after “chapter” the second and third places it appears."}],"tail":"\n"}],"tail":