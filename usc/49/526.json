) (related to “Sec. 222(a)”); added "},{"tag":"html:a","attrib":{"href":"/us/act/1956-08-03/ch905/s2"},"text":"Aug. 3, 1956, ch. 905, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/70/958"},"text":"70 Stat. 958","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1655(f)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s6/f/2"},"text":"Pub. L. 89–670, § 6(f)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/940"},"text":"80 Stat. 940","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The section is included because 49:1655(f)(2) gave the same administrative powers exercised by the Interstate Commerce Commission under certain sections of title 49 to the Secretary of Transportation to carry out duties transferred to the Secretary by 49:1655(e). See the revision notes for section 501 of the revised title for an explanation of the transfer under 49:1655(f)(2). The powers of the Commission have been codified in subtitle IV of the revised title. The comparable provisions of title 49 that are represented by the section may be found as follows:","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"dispositionOfSections","id":"idca7938a0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca7938a1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag"