{"tag":"section","attrib":{"id":"idca7baa05-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1112"},"text":null,"children":[{"tag":"num","attrib":{"value":"1112"},"text":"§ 1112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special boards of inquiry on air transportation safety","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca7baa06-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If an accident involves a substantial question about public safety in air transportation, the National Transportation Safety Board may establish a special board of inquiry composed of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7baa07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member of the Board acting as chairman; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7baa08-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 2 members representing the public, appointed by the President on notification of the establishment of the special board of inquiry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7baa09-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications and Conflicts of Interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The public members of a special board of inquiry must be qualified by training and experience to participate in the inquiry and may not have a pecuniary interest in an aviation enterprise involved in the accident to be investigated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7baa0a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A special board of inquiry has the same authority that the Board has under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca7baa0b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/747"},"text":"108 Stat. 747","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca7baa0c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca7baa0d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca7baa0e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag"