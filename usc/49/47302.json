{"tag":"section","attrib":{"id":"idcc648e6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47302"},"text":null,"children":[{"tag":"num","attrib":{"value":"47302"},"text":"§ 47302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Providing airport and airway property in foreign territories","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc648e70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the concurrence of the Secretary of State and the consideration of objectives of the International Civil Aviation Organization—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc648e71-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation may acquire, establish, and construct airport property and airway property (except meteorological facilities) in foreign territory; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Commerce may acquire, establish, and construct meteorological facilities in foreign territory.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc648e73-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specific Appropriations Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except for airport property transferred under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47304/b"},"text":"section 47304(b) of this title","children":[],"tail":", an airport (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a"},"text":"section 40102(a) of this title","children":[],"tail":") may be acquired, established, or constructed under subsection (a) of this section only if amounts have been appropriated specifically for the airport."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc648e74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accepting Foreign Payments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation or Commerce, as appropriate, may accept payment from a government of a foreign country or international organization for facilities or services sold or provided the government or organization under this chapter. The amount received may be credited to the appropriation current when the expenditures are or were paid, the appropriation current when the amount is received, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc648e75-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1281"},"text":"108 Stat. 1281","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc648e76-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc648e77-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc648e78-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47302(a), (b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1152.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-16/ch473/s3"},"text":"June 16, 1948, ch. 473, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/451"},"text":"62 Stat. 451","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s1403"},"text":"Pub. L. 85–726, § 1403","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/808"},"text":"72 Stat. 808","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s6/c/1"},"text":"Pub. L. 89–670, § 6(c)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/938"},"text":"80 Stat. 938","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/449/s7/b"},"text":"Pub. L. 97–449, § 7(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2444"},"text":"96 Stat. 2444","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47302(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1154.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-16/ch473/s5"},"text":"June 16, 1948, ch. 473, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/451"},"text":"62 Stat. 451","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this chapter, the words “government of a foreign country” are substituted for “foreign government” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the title “Secretary of Commerce” is substituted for “Chief of the Weather Bureau of the Department of Commerce” in section 3, and “Chief of the Weather Bureau” in section 5, of the International Aviation Facilities Act (ch. 473, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/62/451"},"text":"62 Stat. 451","children":[],"tail":") because of sections 1 and 2 of Reorganization Plan No. 2 of 1965 (eff. "},{"tag":"date","attrib":{"date":"1965-07-13"},"text":"July 13, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1318"},"text":"79 Stat. 1318","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “by contract or otherwise” are omitted as surplus. The words “airport property and airway property (except meteorological facilities)” and “meteorological facilities” are substituted for “within their respective fields” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “for the airport” are substituted for “for such purpose” for clarity. The words “by the Congress” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “on behalf of the United States” are omitted as surplus. The words “sold or provided” are substituted for “supplied or . . . performed” for consistency in this chapter. The words “by the Secretary of Transportation or the Secretary of Commerce, either directly or indirectly” and “the authority of” are omitted as surplus. The words “or the Civil Aeronautics Act of 1938, as amended” are omitted as obsolete because the Act was repealed by section 1401(b) of the Federal Aviation Act of 1958 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/806"},"text":"72 Stat. 806","children":[],"tail":"). The words “including the operation of airport property and airway property in such countries, the training of foreign nationals, the rendering of technical assistance and advice to such countries, and the performance of other similar services” are omitted as being included in “facilities or services sold or provided”. The words “or both” are substituted for “or (C) in part as provided under clause (A) and in part as provided under clause (B)” to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
