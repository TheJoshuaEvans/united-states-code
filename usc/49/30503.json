{"tag":"section","attrib":{"id":"idcb57159c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503"},"text":null,"children":[{"tag":"num","attrib":{"value":"30503"},"text":"§ 30503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb57159d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each State shall make titling information maintained by that State available for use in operating the National Motor Vehicle Title Information System established or designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30502"},"text":"section 30502 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb57159e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Verification Checks","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each State shall establish a practice of performing an instant title verification check before issuing a certificate of title to an individual or entity claiming to have purchased an automobile from an individual or entity in another State. The check shall consist of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb57159f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" communicating to the operator—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb5715a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the vehicle identification number of the automobile for which the certificate of title is sought;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb5715a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the State that issued the most recent certificate of title for the automobile; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb5715a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name of the individual or entity to whom the certificate of title was issued; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb5715a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" giving the operator an opportunity to communicate to the participating State the results of a search of the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb5715a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants to States","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb5715a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In cooperation with the States and not later than ","children":[{"tag":"date","attrib":{"date":"1994-01-01"},"text":"January 1, 1994","children":[],"tail":", the Attorney General shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb5715a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a review of systems used by the States to compile and maintain information about the titling of automobiles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb5715a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determine for each State the cost of making titling information maintained by that State available to the operator to meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30502/d"},"text":"section 30502(d) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb5715a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General may make reasonable and necessary grants to participating States to be used in making titling information maintained by those States available to the operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb5715a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":", the Attorney General shall report to Congress on which States have met the requirements of this section. If a State has not met the requirements, the Attorney General shall describe the impediments that have resulted in the State’s failure to meet the requirements."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb5715aa-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/981"},"text":"108 Stat. 981","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/152"},"text":"Pub. L. 104–152","children":[],"tail":", §§ 2(b), (c), 3(a), 6(a), "},{"tag":"date","attrib":{"date":"1996-07-02"},"text":"July 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1384"},"text":"110 Stat. 1384","children":[],"tail":", 1385; "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s3/b"},"text":"Pub. L. 105–102, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2215"},"text":"111 Stat. 2215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb5715ab-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historica