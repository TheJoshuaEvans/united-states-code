,"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2043(a)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/519/s203"},"text":"Pub. L. 102–519, § 203","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/3391"},"text":"106 Stat. 3391","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30503(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2043(a)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30503(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2043(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30503(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2043(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “for use in operating . . . established or designated” are substituted for “for use in establishing . . . established” for clarity and for consistency with the source provisions restated in section 30502 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “The check” are substituted for “Such instant title verification check” to eliminate unnecessary words. In subclauses (A) and (B), the words “of the automobile” are substituted for “of the vehicle” for consistency in the revised chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1)(B), the words “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30502/d"},"text":"section 30502(d) of this title","children":[],"tail":"” are substituted for “subsection (b)” to reflect the apparent intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2)(A), before subclause (i), the words “is not more than the lesser of” are substituted for “does not exceed . . . whichever is lower” for clarity. In subclause (i), the words “paragraph (1)(B) of this subsection” are substituted for “subsection (d)(1)(B)” to reflect the apparent intent of Congress.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2)(B), the word “fair” is omitted as being included in “reasonable”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb5715ae-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb5715af-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/104/152/s2/c"},"text":"Pub. L. 104–152, § 2(c)","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/152/s2/c"},"text":"Pub. L. 104–152, § 2(c)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":", substituted “National Motor Vehicle Title Information System” for “National Automobile Title Information System”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/152/s3/a"},"text":"Pub. L. 104–152, § 3(a)","children":[],"tail":", substituted “Attorney General” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/152/s6/a"},"text":"Pub. L. 104–152, § 6(a)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “The Secretary may make grants to participating States to be used in making titling information maintained by those States available to the operator if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) the grant to a State is not more than the lesser of—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) 25 percent of the cost of making titling information maintained by that State available to the operator as determined by the Secretary under paragraph (1)(B) of this subsection; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) $300,000; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the Secretary decides that the grants are reasonable and necessary to establish the System.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/152"},"text":"Pub. L. 104–152","children":[],"tail":", §§ 2(b), 3(a), substituted “"},{"tag":"date","attrib":{"date":"1998-10-01"},"text":"October 1, 1998","children":[],"tail":"” for “"},{"tag":"date","attrib":{"date":"1997-01-01"},"text":"January 1, 1997","children":[],"tail":"” and substituted “Attorney General” for “Secretary” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb5715b0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb5715b1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102/s3/b"},"text":"Pub. L. 105–102, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2215"},"text":"111 Stat. 2215","children":[],"tail":", provided that the amendment made by section 3(b) is effective "},{"tag":"date","attrib":{"date":"1996-07-02"},"text":"July 2, 1996","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" effective as if included in the provisions of the Act to which the amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s3/f"},"text":"section 3(f) of Pub. L. 105–102","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
