{"tag":"section","attrib":{"id":"idcc053007-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44725"},"text":null,"children":[{"tag":"num","attrib":{"value":"44725"},"text":"§ 44725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Life-limited aircraft parts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc053008-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Federal Aviation Administration shall conduct a rulemaking proceeding to require the safe disposition of life-limited parts removed from an aircraft. The rulemaking proceeding shall ensure that the disposition deter installation on an aircraft of a life-limited part that has reached or exceeded its life limits.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc053009-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safe Disposition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For the purposes of this section, safe disposition includes any of the following methods:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc05300a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44725/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The part may be segregated under circumstances that preclude its installation on an aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc05300b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44725/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The part may be permanently marked to indicate its used life status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc05300c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44725/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The part may be destroyed in any manner calculated to prevent reinstallation in an aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc05300d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44725/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The part may be marked, if practicable, to include the recordation of hours, cycles, or other airworthiness information. If the parts are marked with cycles or hours of usage, that information must be updated every time the part is removed from service or when the part is retired from service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc05300e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44725/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other method approved by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc05300f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44725/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadlines","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the rulemaking proceeding under subsection (a), the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc053010-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44725/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after the date of the enactment of this section, issue a notice of proposed rulemaking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc053011-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44725/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 180 days after the close of the comment period on the proposed rule, issue a final rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc053012-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44725/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prior-Removed Life-Limited Parts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No rule issued under subsection (a) shall require the marking of parts removed from aircraft before the effective date of the rules issued under subsection (a), nor shall any such rule forbid the installation of an otherwise airworthy life-limited part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc053013-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tV/s504/a"},"text":"Pub. L. 106–181, title V, § 504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/134"},"text":"114 Stat. 134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc053014-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc053015-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc053016-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (c)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc053017-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc053018-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as an Effective Date of 2000 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
