{"tag":"section","attrib":{"id":"idcbfe04a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711"},"text":null,"children":[{"tag":"num","attrib":{"value":"44711"},"text":"§ 44711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions and exemption","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbfe04a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbfe04a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate a civil aircraft in air commerce without an airworthiness certificate in effect or in violation of a term of the certificate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe04a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" serve in any capacity as an airman with respect to a civil aircraft, aircraft engine, propeller, or appliance used, or intended for use, in air commerce—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbfe04a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without an airman certificate authorizing the airman to serve in the capacity for which the certificate was issued; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbfe04a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in violation of a term of the certificate or a regulation prescribed or order issued under section 44701(a) or (b) or any of sections 44702–44716 of this title;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe04a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ for service related to civil aircraft used in air commerce an airman who does not have an airman certificate authorizing the airman to serve in the capacity for which the airman is employed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe04a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate as an air carrier without an air carrier operating certificate or in violation of a term of the certificate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe04aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate aircraft in air commerce in violation of a regulation prescribed or certificate issued under section 44701(a) or (b) or any of sections 44702–44716 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe04ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate a seaplane or other aircraft of United States registry on the high seas in violation of a regulation under section 3 of the International Navigational Rules Act of 1977 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s1602"},"text":"33 U.S.C. 1602","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe04ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violate a term of an air agency, design organization certificate, or production certificate or a regulation prescribed or order issued under section 44701(a) or (b) or any of sections 44702–44716 of this title related to the holder of the certificate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe04ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate an airport without an airport operating certificate required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44706"},"text":"section 44706 of this title","children":[],"tail":" or in violation of a term of the certificate;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe04ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacture, deliver, sell, or offer for sale any aviation fuel or additive in violation of a regulation prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44714"},"text":"section 44714 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe04af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work as an aircraft dispatcher outside of a physical location designated as a dispatching center or flight following center of an air carrier, except as provided under section 44747; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe04b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violate section 44732 or any regulation issued thereunder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbfe04b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On terms the Administrator of the Federal Aviation Administration prescribes as being in the public interest, the Administrator may exempt a foreign aircraft and airmen serving on the aircraft from subsection (a) of this section. However, an exemption from observing air traffic regulations may not be granted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbfe04b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Employment of Convicted Counterfeit Part Traffickers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person subject to this chapter may knowingly employ anyone to perform a function related to the procurement, sale, production, or repair of a part or material, or the installation of a part into a civil aircraft, who has been convicted in a court of law of a violation of any Federal law relating to the installation, production, repair, or sale of a counterfeit or fraudulently-represented aviation part or material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbfe04b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Post-employment Restrictions for Inspectors and Engineers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbfe04b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person holding a certificate issued under part 21 or 119 of title 14, Code of Federal Regulations, may not knowingly employ, or make a contractual arrangement that permits, an individual to act as an agent or representative of such person in any matter before the Administration if the individual, in the preceding 2-year period—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbfe04b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" served as, or was responsible for oversight of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbfe04b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a flight standards inspector of the Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbfe04b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of the Administration with responsibility for certification functions with respect to a holder of a certificate issued under section 44704(a); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbfe04b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" had responsibility to inspect, or oversee inspection of, the operations of such person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe04b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44711/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written and oral communications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of paragraph (1), an individual shall be considered to be acting as an agent or representative of a certificate holder in a matter before the Administration if the individual makes any written or oral communication on behalf of the certificate holder to the Administration (or any of its officers or employees) in connection with a particular matter, whether or not involving a specific party and without regard to whether the individual has participated in, or had responsibility for, the particular matter while serving as an individual covered under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc004daa-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1193"},"text":"108 Stat. 1193","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/56"},"text":"Pub. L. 103–429, § 6(56)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4385"},"text":"108 Stat. 4385","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tV/s505/b"},"text":"Pub. L. 106–181, title V, § 505(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/136"},"text":"114 Stat. 136","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tII/s227/d"},"text":"Pub. L. 108–176, title II, § 227(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2532"},"text":"117 Stat. 2532","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIII"},"text":"Pub. L. 112–95, title III","children":[],"tail":", §§ 307(b), 342(a), "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/61"},"text":"126 Stat. 61","childre