{"tag":"section","attrib":{"id":"idcbc25b60-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708"},"text":null,"children":[{"tag":"num","attrib":{"value":"41708"},"text":"§ 41708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbc25b61-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent the Secretary of Transportation finds necessary to carry out this subpart, this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41709"},"text":"section 41709 of this title","children":[],"tail":" apply to a person controlling an air carrier or affiliated (within the meaning of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s11343/c"},"text":"section 11343(c) of this title","children":[],"tail":") with a carrier."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc25b62-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may require an air carrier or foreign air carrier—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc25b63-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbc25b64-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to file annual, monthly, periodical, and special reports with the Secretary in the form and way prescribed by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc25b65-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to file the reports under oath;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc25b66-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide specific answers to questions on which the Secretary considers information to be necessary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc25b67-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to file with the Secretary a copy of each agreement, arrangement, contract, or understanding between the carrier and another carrier or person related to transportation affected by this subpart.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc25b68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Diverted and Cancelled Flights.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc25b69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monthly reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require an air carrier referred to in paragraph (2) to file with the Secretary a monthly report on each flight of the air carrier that is diverted from its scheduled destination to another airport and each flight of the air carrier that departs the gate at the airport at which the flight originates but is cancelled before wheels-off time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc25b6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier that is required to file a monthly airline service quality performance report pursuant to part 234 of title 14, Code of Federal Regulations, shall be subject to the requirement of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc25b6b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A monthly report filed by an air carrier under paragraph (1) shall include, at a minimum, the following information:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbc25b6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For a diverted flight—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbc25b6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the flight number of the diverted flight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbc25b6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scheduled destination of the flight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbc25b6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date and time of the flight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbc25b70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the airport to which the flight was diverted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbc25b71-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" wheels-on time at the diverted airport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbc25b72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/A/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time, if any, passengers deplaned the aircraft at the diverted airport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbc25b73-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/A/vii"},"text":null,"children":[{"tag":"num","attrib":{"value":"vii"},"text":"(vii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the flight arrives at the scheduled destination airport—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcbc25b74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/A/vii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gate-departure time at the diverted airport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcbc25b75-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/A/vii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wheels-off time at the diverted airport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcbc25b76-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/A/vii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the wheels-on time at the scheduled arrival airport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcbc25b77-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/A/vii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gate-arrival time at the scheduled arrival airport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc25b78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For flights cancelled after gate departure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbc25b79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the flight number of the cancelled flight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbc25b7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the scheduled origin and destination airports of the cancelled flight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbc25b7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date and time of the cancelled flight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbc25b7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gate-departure time of the cancelled flight; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbc25b7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/3/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time the aircraft returned to the gate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc25b7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41708/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall compile the information provided in the monthly reports filed pursuant to paragraph (1) in a single monthly report and publish such report on the Internet Web site of the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbc25b7f-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1141"},"text":"108 Stat. 1141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIV/s402/a"},"text":"Pub. L. 112–95, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/83"},"text":"126 Stat. 83","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbc4cb80-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbc4cb81-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbc4cb82-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","childr