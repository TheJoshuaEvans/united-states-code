{"tag":"section","attrib":{"id":"idcb012dc5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14505"},"text":null,"children":[{"tag":"num","attrib":{"value":"14505"},"text":"§ 14505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State tax","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A State or political subdivision thereof may not collect or levy a tax, fee, head charge, or other charge on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb012dc6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14505/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a passenger traveling in interstate commerce by motor carrier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb012dc7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14505/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation of a passenger traveling in interstate commerce by motor carrier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb012dc8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14505/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of passenger transportation in interstate commerce by motor carrier; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb012dc9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14505/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross receipts derived from such transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb012dca-47c4-11f1-9671-b5c725212f70"},"te