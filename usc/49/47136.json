{"tag":"section","attrib":{"id":"idcc5d6216-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136"},"text":null,"children":[{"tag":"num","attrib":{"value":"47136"},"text":"§ 47136.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Zero-emission airport vehicles and infrastructure","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc5d6217-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may establish a pilot program under which the sponsors of public-use airports may use funds made available under this chapter or section 48103 for use at such airports to carry out—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d6218-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities associated with the acquisition, by purchase or lease, and operation of eligible zero-emission vehicles and equipment, including removable power sources for such vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6219-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction or modification of infrastructure to facilitate the delivery of fuel, power or services necessary for the use of such vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d621a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A public-use airport is eligible for participation in the program if the eligible vehicles or equipment are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d621b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used exclusively on airport property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d621c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" used exclusively to transport passengers and employees between the airport and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc5d621d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nearby facilities which are owned or controlled by the airport or which otherwise directly support the functions or services provided by the airport; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5d621e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intermodal surface transportation facility adjacent to the airport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d621f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting from among applicants for participation in the program, the Secretary shall give priority consideration to applicants that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d6220-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will achieve the greatest air quality benefits measured by the amount of emissions reduced per dollar of funds expended under the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6221-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a long-term management plan for eligible vehicles and equipment that includes the existing and future infrastructure requirements of the airport related to such vehicles and equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d6222-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of a project carried out under the program shall be the Federal share specified in section 47109.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d6223-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Assistance.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d6224-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The sponsor of a public-use airport may use not more than 10 percent of the amounts made available to the sponsor under the program in any fiscal year for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc5d6225-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technical assistance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5d6226-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" project management support to assist the airport with the solicitation, acquisition, and deployment of zero-emission vehicles, related equipment, and supporting infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6227-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Providers of technical assistance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To receive the technical assistance or project management support described in paragraph (1), participants in the program may use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc5d6228-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a nonprofit organization selected by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5d6229-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a university transportation center receiving grants under section 5505 in the region of the airport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d622a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Materials Identifying Best Practices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may create and make available materials identifying best practices for carrying out activities funded under the program based on previous related projects and other sources.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d622b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowable Project Cost","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The allowable project cost for the acquisition of a zero-emission vehicle shall be the total cost of purchasing or leasing the vehicle, including the cost of technical assistance or project management support described in subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d622c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Flexible Procurement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A sponsor of a public-use airport may use funds made available under the program to acquire, by purchase or lease, a zero-emission vehicle and a removable power source in separate transactions, including transactions by which the airport purchases the vehicle and leases the removable power source.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d622d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Testing Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d622e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A sponsor of a public-use airport may not use funds made available under the program to acquire a zero-emission vehicle unless that make, model, or type of vehicle has been tested by a Federal vehicle testing facility acceptable to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d622f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties for false statements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A certification of compliance under paragraph (1) shall be considered a certification required under this subchapter for purposes of section 47126.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d6230-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d6231-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible zero-emission vehicle and equipment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “eligible zero-emission vehicle and equipment” means a zero-emission vehicle, equipment related to such a vehicle, or ground support equipment that includes zero-emission technology that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc5d6232-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" used exclusively on airport property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5d6233-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" used exclusively to transport passengers and employees between the airport and—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc5d6234-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/j/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nearby facilities which are owned or controlled by the airport or which otherwise directly support the functions or services provided by the airport; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc5d6235-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/j/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intermodal surface transportation facility adjacent to the airport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6236-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Removable power source","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “removable power source” means a power source that is separately installed in, and removable from, a zero-emission vehicle and may include a battery, a fuel cell, an ultra-capacitor, or other power source used in a zero-emission vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6237-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Zero-emission vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “zero-emission vehicle” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc5d6238-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/j/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a zero-emission vehicle as defined in section 88.102–94 of title 40, Code of Federal Regulations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5d6239-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47136/j/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vehicle that produces zero exhaust emissions of any criteria pollutant (or precursor pollutant) under any possible operational modes and conditions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc5d623a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tV/s511/a"},"text":"Pub. L. 112–95, title V, § 511(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/107"},"text":"126 Stat. 107","children":[],"tail":", § 47136a; renumbered § 47136 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tI"},"text":"Pub. L. 115–254, div. B, title I","children":[],"tail":", §§ 166(b)(1), 192(a), "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3226"},"text":"132 Stat. 3226","children":[],"tail":", 3239; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s722"},"text":"Pub. L. 118–63, title VII, § 722","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1265"},"text":"138 Stat. 1265","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc5d623b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc5d623c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcc5d623d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 47136, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tI/s133/a"},"text":"Pub. L. 106–181, title I, § 133(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/81"},"text":"114 Stat. 81","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tV/s511/d"},"text":"Pub. L. 112–95, title V, § 511(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/108"},"text":"126 Stat. 108","children":[],"tail":", related to inherently low-emission airport vehicle pilot program, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tI/s166/a"},"text":"Pub. L. 115–254, div. B, title I, § 166(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3226"},"text":"132 Stat. 3226","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc5d623e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" inserted dash after “applicants that” and par (1) designation before “will”, substituted “; and” for period at end, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s166/b/1"},"text":"Pub. L. 115–254, § 166(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s47136a"},"text":"section 47136a of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s192/a/1"},"text":"Pub. L. 115–254, § 192(a)(1)","children":[],"tail":", added subsecs. (a) and (b) and struck out former subsecs. (a) and (b) which related to the establishment of a zero-emission vehicle pilot program and location in air quality nonattainment areas, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s192/a/2"},"text":"Pub. L. 115–254, § 192(a)(2)","children":[],"tail":", added subsecs. (d) to (j) and struck out former subsecs. (d) to (f) which related to Federal share of project costs, technical assistance, and materials identifying best practices, respectively."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc5d623f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc5d6240-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deployment of Zero Emission Vehicle Technology","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tI/s192/c"},"text":"Pub. L. 115–254, div. B, title I, § 192(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3241"},"text":"132 Stat. 3241","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dB/tI/s192/c"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may establish a zero-emission airport technology program—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the deployment of commercially viable zero-emission airport vehicles, technology, and related infrastructure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to minimize the risk of deploying such vehicles, technology, and infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General authority.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assistance to nonprofit organizations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide assistance under the program to not more than 3 geographically diverse, eligible organizations to conduct zero-emission airport technology and infrastructure projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Forms of assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may provide assistance under the program in the form of grants, contracts, and cooperative agreements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection of participants.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National solicitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting participants, the Secretary shall—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a national solicitation for applications for assistance under the program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" select the recipients of assistance under the program on a competitive basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting from among applicants for assistance under the program, the Secretary shall consider—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of an applicant to contribute significantly to deploying zero-emission technology as the technology relates to airport operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the financing plan and cost-share potential of the applicant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other factors, as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"ln [sic] selecting from among applicants for assistance under the program, the Secretary shall give priority consideration to an applicant that has successfully managed advanced transportation technology projects, including projects related to zero-emission transportation operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible projects","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A recipient of assistance under the program shall use the assistance—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review and conduct demonstrations of zero-emission technologies and related infrastructure at airports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate the credibility of new, unproven vehicle and energy-efficient technologies in various aspects of airport operations prior to widespread investment in the technologies by airports and the aviation industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect data and make the recipient’s findings available to airports, so that airports can evaluate the applicability of new technologies to their facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to report the recipient’s findings to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative provisions.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of a project carried out under the program may not exceed 80 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms and conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant, contract, or cooperative agreement under this section shall be subject to such terms and conditions as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the following definitions apply:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘eligible organization’ means an organization that has expertise in zero-emission technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Organization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘organization’ means—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described [sic] in section 501(c)(3) of the Internal Revenue Code of 1986 and exempt from tax under section 501(a) of the Internal Revenue Code of 1986;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a university transportation center receiving grants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5505"},"text":"section 5505 of title 49","children":[],"tail":", United States Code; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other Federal or non-Federal entity as the Secretary considers appropriate.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
