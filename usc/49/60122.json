{"tag":"section","attrib":{"id":"idcc811687-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122"},"text":null,"children":[{"tag":"num","attrib":{"value":"60122"},"text":"§ 60122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc811688-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc811689-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person that the Secretary of Transportation decides, after written notice and an opportunity for a hearing, has violated section 60114(b), 60114(d), or 60118(a) of this title or a regulation prescribed or order issued under this chapter is liable to the United States Government for a civil penalty of not more than $200,000 for each violation. A separate violation occurs for each day the violation continues. The maximum civil penalty under this paragraph for a related series of violations is $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc81168a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person violating a standard or order under section 60103 or 60111 of this title is liable to the Government for a civil penalty of not more than $50,000 for each violation. A penalty under this paragraph may be imposed in addition to penalties imposed under paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc81168b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person violating section 60129, or an order issued thereunder, is liable to the Government for a civil penalty of not more than $1,000 for each violation. The penalties provided by paragraph (1) do not apply to a violation of section 60129 or an order issued thereunder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc81168c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of a civil penalty under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc81168d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc81168e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, circumstances, and gravity of the violation, including adverse impact on the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc81168f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the violator, the degree of culpability, any history of prior violations, and any effect on ability to continue doing business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc811690-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" good faith in attempting to comply; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc811691-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" self-disclosure and correction of violations, or actions to correct a violation, prior to discovery by the Pipeline and Hazardous Materials Safety Administration; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc811692-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary may consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc811693-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the economic benefit gained from the violation without any reduction because of subsequent damages; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc811694-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other matters that justice requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc811695-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection and Compromise","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc811696-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may request the Attorney General to bring a civil action in an appropriate district court of the United States to collect a civil penalty imposed under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc811697-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may compromise the amount of a civil penalty imposed under this section before referral to the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc811698-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Setoff","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Government may deduct the amount of a civil penalty imposed or compromised under this section from amounts it owes the person liable for the penalty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc811699-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deposit in Treasury","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts collected under this section shall be deposited in the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc81169a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60122/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Multiple Penalties for Same Act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Separate penalties for violating a regulation prescribed under this chapter and for violating an order under section 60112 or 60118(b) of this title may not be imposed under this chapter if both violations are based on the same act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc81169b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1325"},"text":"108 Stat. 1325","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/355"},"text":"Pub. L. 107–355","children":[],"tail":", §§ 6(b), 8(b)(1), (2), 21(3), "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2992"},"text":"116 Stat. 2992","childre