:{},"text":"46104(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1354(c) (related to this chapter).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1484(a) (related to examiner).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(b)(1)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the word “Administrator” in section 313(c) of the Federal Aviation Act of 1958 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/753"},"text":"72 Stat. 753","children":[],"tail":") is retained on authority of 49:106(g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(1) is substituted for “sign and issue subpenas”, “shall have the power to require by subpena the attendance and testimony of witnesses and the production of all books, papers, and documents relating to any matter under investigation”, and “The attendance of witnesses, and the production of books, papers, and documents, may be required from any place in the United States, at any designated place of hearing” in 49 App.:1484 for clarity and consistency in the revised title and with other titles of the United States Code and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “petition a court of the United States to enforce the subpena” are substituted for “invoke the aid of any court of the United States in requiring attendance and testimony of witnesses and the production of such books, papers, and documents under the provisions of this section” in 49 App.:1484(c) to eliminate unnecessary words. The words “to enforce a subpena under this section” are substituted for “in case of contumacy or refusal to obey a subpena issued to any person, issue an order requiring such person to appear before the Board (and produce books, papers, or documents if so ordered) and give evidence touching the matter in question” in 49 App.:1484(d) to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “pending before it, at any stage of such proceeding or investigation” in 49 App.:1484(e) are omitted as surplus. The words “a person to give” are substituted for “to be taken”, and the words “to produce records” are added, for clarity and consistency. The last sentence is substituted for 49 App.:1484(e) (last sentence) for clarity and consistency and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(4), the words “shall be cautioned . . . to testify the whole truth, and shall be carefully examined” in 49 App.:1484(f) are omitted as surplus. The words “shall be under oath” are substituted for “shall be required to swear (or affirm, if he so requests)” for consistency and because of 1:1.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “that the witness and individual would have been” are added for clarity and consistency in the revised title and with other titles of the Code. The words “fees, charges, or” and “on the subject” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “duly . . . for such purpose” are omitted as surplus. The words “employee appointed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3105"},"text":"section 3105 of title 5","children":[],"tail":"” are substituted for “examiner”, and the words “subpena witnesses” are substituted for “sign and issue subpenas”, for consistency in the revised title and with other titles of the Code. The words “In all cases heard by an examiner or a single member” are omitted as surplus."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc39864f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc398650-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/f/6/A"},"text":"Pub. L. 115–254, § 1991(f)(6)(A)","children":[],"tail":", substituted “subpoena” for “subpena” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/f/4"},"text":"Pub. L. 115–254, § 1991(f)(4)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration,” for “Under Secretary,” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/f/2"},"text":"Pub. L. 115–254, § 1991(f)(2)","children":[],"tail":", substituted “or Administrator of the Federal Aviation Administration” for “or Administrator” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/f/3"},"text":"Pub. L. 115–254, § 1991(f)(3)","children":[],"tail":", substituted “by the Administrator of the Federal Aviation Administration)” for “by the Administrator)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/f/1"},"text":"Pub. L. 115–254, § 1991(f)(1)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration with respect to security duties and powers designated to be carried out by the Administrator of the Transportation Security Administration” for “Under Secretary of Transportation for Security with respect to security duties and powers designated to be carried out by the Under Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/f/6/B"},"text":"Pub. L. 115–254, § 1991(f)(6)(B)","children":[],"tail":", substituted “Subpoenas” for “Subpenas” in heading and “the Administrator of the Federal Aviation Administration, or” for “the Administrator, or” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s140/b/1"},"text":"Pub. L. 107–71, § 140(b)(1)","children":[],"tail":", in introductory provisions inserted “the Under Secretary of Transportation for Security with respect to security duties and powers designated to be carried out by the Under Secretary or” after “(or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s140/b/2"},"text":"Pub. L. 107–71, § 140(b)(2)","children":[],"tail":", substituted “, Under Secretary, or Administrator” for “or Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s140/b/2"},"text":"Pub. L. 107–71, § 140(b)(2)","children":[],"tail":", (6), inserted “the Under Secretary,” after ‘Secretary,” and substituted “, Under Secretary, or Administrator” for “or Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s140/b/2"},"text":"Pub. L. 107–71, § 140(b)(2)","children":[],"tail":", substituted “, Under Secretary, or Administrator” for “or Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
