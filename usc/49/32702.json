{"tag":"section","attrib":{"id":"idcb7f85c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32702"},"text":null,"children":[{"tag":"num","attrib":{"value":"32702"},"text":"§ 32702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7f85c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32702/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “auction company” means a person taking possession of a motor vehicle owned by another to sell at an auction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32702/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “dealer” means a person that sold at least 5 motor vehicles during the prior 12 months to buyers that in good faith bought the vehicles other than for resale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32702/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “distributor” means a person that sold at least 5 motor vehicles during the prior 12 months for resale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32702/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “leased motor vehicle” means a motor vehicle leased to a person for at least 4 months by a lessor that leased at least 5 vehicles during the prior 12 months.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32702/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “odometer” means an instrument or system of components for measuring and recording the distance a motor vehicle is driven, but does not include an auxiliary instrument or system of components designed to be reset by the operator of the vehicle to record mileage of a trip.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32702/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “repair” and “replace” mean to restore to a sound working condition by replacing any part of an odometer or by correcting any inoperative part of an odometer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32702/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “title” means the certificate of title or other document issued by the State indicating ownership.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32702/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “transfer” means to change ownership by sale, gift, or any other means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb7f85d1-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"