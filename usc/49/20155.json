{"tag":"section","attrib":{"id":"idcb1440c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20155"},"text":null,"children":[{"tag":"num","attrib":{"value":"20155"},"text":"§ 20155.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tank cars","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb1440c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20155/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Railroad Administration shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb1440c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20155/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" validate a predictive model to quantify the relevant dynamic forces acting on railroad tank cars under accident conditions within 1 year after the date of enactment of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1440c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20155/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" initiate a rulemaking to develop and implement appropriate design standards for pressurized tank cars within 18 months after the date of enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb1440c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20155/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Older Tank Car Impact Resistance Analysis and Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 1 year after the date of enactment of this section the Federal Railroad Administration shall conduct a comprehensive analysis to determine the impact resistance of the steels in the shells of pressure tank cars constructed before 1989. Within 6 months after completing that analysis the Administration shall transmit a report, including recommendations for reducing any risk of catastrophic fracture and separation of such cars, to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb1440c8-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIX/s9005/b/1"},"text":"Pub. L. 109–59, title IX, § 9005(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1924"},"text":"119 Stat. 1924","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb1440c9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb1440ca-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb1440cb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in text, is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb1440cc-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb1440cd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Phase-Out of All Tank Cars Used To Transport Class 3 Flammable Liquids","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVII/s7304"},"text":"Pub. L. 114–94, div. A, title VII, § 7304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1596"},"text":"129 Stat. 1596","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tVII/s7304"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided for in subsection (b), beginning on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"], all DOT–111 specification railroad tank cars used to transport Class 3 flammable liquids shall meet the DOT–117, DOT–117P, or DOT–117R specifications in part 179 of title 49, Code of Federal Regulations, regardless of train composition."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Phase-Out Schedule","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Certain tank cars not meeting DOT–117, DOT–117P, or DOT–117R specifications on the date of enactment of this Act may be used, regardless of train composition, until the following end-dates:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For transport of unrefined petroleum products in Class 3 flammable service, including crude oil—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2018-01-01"},"text":"January 1, 2018","children":[],"tail":", for non-jacketed DOT–111 tank cars;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2018-03-01"},"text":"March 1, 2018","children":[],"tail":", for jacketed DOT–111 tank cars;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2020-04-01"},"text":"April 1, 2020","children":[],"tail":", for non-jacketed CPC–1232 tank cars; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2025-05-01"},"text":"May 1, 2025","children":[],"tail":", for jacketed CPC–1232 tank cars."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For transport of ethanol—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2023-05-01"},"text":"May 1, 2023","children":[],"tail":", for non-jacketed and jacketed DOT–111 tank cars;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2023-07-01"},"text":"July 1, 2023","children":[],"tail":", for non-jacketed CPC–1232 tank cars; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2025-05-01"},"text":"May 1, 2025","children":[],"tail":", for jacketed CPC–1232 tank cars."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For transport of Class 3 flammable liquids in Packing Group I, other than Class 3 flammable liquids specified in paragraphs (1) and (2), ","children":[{"tag":"date","attrib":{"date":"2025-05-01"},"text":"May 1, 2025","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For transport of Class 3 flammable liquids in Packing Groups II and III, other than Class 3 flammable liquids specified in paragraphs (1) and (2), ","children":[{"tag":"date","attrib":{"date":"2029-05-01"},"text":"May 1, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Retrofitting Shop Capacity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of Transportation] may extend the deadlines established under paragraphs (3) and (4) of subsection (b) for a period not to exceed 2 years if the Secretary determines that insufficient retrofitting shop capacity will prevent the phase-out of tank cars not meeting the DOT–117, DOT–117P, or DOT–117R specifications by the deadlines set forth in such paragraphs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conforming Regulatory Amendments.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Immediately after the date of enactment of this section [","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"], the Secretary—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remove or revise the date-specific deadlines in any applicable regulations or orders to the extent necessary to conform with the requirements of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not enforce any such date-specific deadlines or requirements that are inconsistent with the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to require the Secretary to issue regulations, except as required under paragraph (1), to implement this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to prohibit the Secretary from implementing the final rule issued on ","children":[{"tag":"date","attrib":{"date":"2015-05-08"},"text":"May 08, 2015","children":[],"tail":", entitled ‘Enhanced Tank Car Standards and Operational Controls for High-Hazard Flammable Trains’ (80 Fed. Reg. 26643), other than the provisions of the final rule that are inconsistent with this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Class ","children":[],"tail":"3"},{"tag":"inline","attrib":{},"text":" Flammable Liquid Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘Class 3 flammable liquid’ has the meaning given the term flammable liquid in section 173.120(a) of title 49, Code of Federal Regulations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb1440ce-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Thermal Blankets","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVII/s7305"},"text":"Pub. L. 114–94, div. A, title VII, § 7305","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1597"},"text":"129 Stat. 1597","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tVII/s7305"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"], the Secretary [of Transportation] shall issue such regulations as are necessary to require that each tank car built to meet the DOT–117 specification and each non-jacketed tank car modified to meet the DOT–117R specification be equipped with an insulating blanket with at least ½-inch-thick material that has been approved by the Secretary pursuant to section 179.18(c) of title 49, Code of Federal Regulations."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall prohibit the Secretary from approving new or alternative technologies or materials as they become available that provide a level of safety at least equivalent to the level of safety provided for under subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb1440cf-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Modification Reporting","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVII/s7308"},"text":"Pub. L. 114–94, div. A, title VII, § 7308","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1599"},"text":"129 Stat. 1599","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/tIII/s302/c/5"},"text":"Pub. L. 115–435, title III, § 302(c)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5553"},"text":"132 Stat. 5553","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/435/tIII/s302/c/5"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"], the Secretary [of Transportation] shall implement a reporting requirement to monitor industry-wide progress toward modifying rail tank cars used to transport Class 3 flammable liquids by the applicable deadlines established in section 7304 [set out as a note above]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tank Car Data","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall collect data from shippers and rail tank car owners on—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of tank cars modified to meet the DOT–117R specification, or equivalent, specifying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type or specification of each tank car before it was modified, including non-jacketed DOT–111, jacketed DOT–111, non-jacketed DOT–111 meeting the CPC–1232 standard, or jacketed DOT–111 meeting the CPC–1232 standard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification number of each Class 3 flammable liquid carried by each tank car in the past year;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of tank cars built to meet the DOT–117 specification, or equivalent; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the total number of tank cars used or likely to be used to transport Class 3 flammable liquids that have not been modified, specifying—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type or specification of each tank car not modified, including the non-jacketed DOT–111, jacketed DOT–111, non-jacketed DOT–111 meeting the CPC–1232 standard, or jacketed DOT–111 meeting the CPC–1232 standard; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identification number of each Class 3 flammable liquid carried by each tank car in the past year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tank Car Shop Data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall conduct a survey of tank car facilities modifying tank cars to the DOT–117R specification, or equivalent, or building new tank cars to the DOT–117 specification, or equivalent, to generate statistically-valid estimates of the anticipated number of tank cars those facilities expect to modify to DOT–117R specification, or equivalent, or build to the DOT–117 specification, or equivalent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Frequency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall collect the data under subsection (b) and conduct the survey under subsection (c) annually until ","children":[{"tag":"date","attrib":{"date":"2029-05-01"},"text":"May 1, 2029","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Protections.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall only report data in industry-wide totals and shall treat company-specific information as confidential business information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Level of confidentiality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall ensure the data collected under subsection (b) and the survey data under subsection (c) have the same level of confidentiality as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3572"},"text":"section 3572 of title 44","children":[],"tail":", United States Code, as administered by the Bureau of Transportation Statistics."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" designate the Director of the Bureau of Transportation Statistics to collect data under subsection (b) and the survey data under subsection (c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct the Director to ensure the confidentially of company-specific information to the maximum extent permitted by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each year, not later than 60 days after the date that both the collection of the data under subsection (b) and the survey under subsection (c) are complete, the Secretary shall submit a written report on the aggregate results, without company-specific information, to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"“(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Class ","children":[],"tail":"3"},{"tag":"inline","attrib":{},"text":" Flammable Liquid","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘Class 3 flammable liquid’ has the meaning given the term flammable liquid in section 173.120 of title 49, Code of Federal Regulations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
