{"tag":"section","attrib":{"id":"idcb8ddd5c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33107"},"text":null,"children":[{"tag":"num","attrib":{"value":"33107"},"text":"§ 33107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary vehicle identification standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb8ddd5d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Election To Inscribe or Affix Identifying Marks","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation by regulation may prescribe a vehicle theft prevention standard under which a person may elect to inscribe or affix an identifying number or symbol on major parts of a motor vehicle manufactured or owned by the person for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s511"},"text":"section 511 of title 18","children":[],"tail":" and related provisions. The standard may include provisions for registration of the identification with the Secretary or a person designated by the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8ddd5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standard Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The standard under this section shall be practicable and provide relevant objective criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8ddd5f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Voluntary Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Compliance with the standard under this section is voluntary. Failure to comply does not subject a person to a penalty or enforcement under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8ddd60-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Other Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Compliance with the standard under this section does not relieve a manufacturer from a requirement of a standard prescribed under section 33102 or 33103 of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb8ddd61-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1083"},"text":"108 Stat. 1083","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb8ddd62-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb8ddd63-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb8ddd64-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag"