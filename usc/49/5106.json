{"tag":"section","attrib":{"id":"idca8c4bf0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5106"},"text":null,"children":[{"tag":"num","attrib":{"value":"5106"},"text":"§ 5106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Handling criteria","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may prescribe criteria for handling hazardous material, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8c4bf1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5106/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a minimum number of personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c4bf2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5106/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimum levels of training and qualifications for personnel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c4bf3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5106/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the kind and frequency of inspections;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c4bf4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5106/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equipment for detecting, warning of, and controlling risks posed by the hazardous material;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c4bf5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5106/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specifications for the use of equipment and facilities used in handling and transporting the hazardous material; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8c4bf6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5106/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a system of monitoring safety procedures for transporting the hazardous material.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8c4bf7-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/763"},"text":"108 Stat. 763","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII/s7126"},"text":"Pub. L. 109–59, title VII, § 7126","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1909"},"text":"119 Stat. 1909","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8c4bf8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca8c4bf9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca8c4bfa-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag