{"tag":"section","attrib":{"id":"idcb8b9393-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32917"},"text":null,"children":[{"tag":"num","attrib":{"value":"32917"},"text":"§ 32917.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for executive agency automobiles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb8b9394-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32917/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, “executive agency” has the same meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8b9395-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32917/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fleet Average Fuel Economy","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8b9396-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32917/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The President shall prescribe regulations that require passenger automobiles leased for at least 60 consecutive days or bought by executive agencies in a fiscal year to achieve a fleet average fuel economy (determined under paragraph (2) of this subsection) for that year of at least the greater of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8b9397-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32917/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 18 miles a gallon; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b9398-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32917/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable average fuel economy standard under section 32902(b) or (c) of this title for the model year that includes January 1 of that fiscal year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8b9399-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32917/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Fleet average fuel economy is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8b939a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32917/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of passenger automobiles leased for at least 60 consecutive days or bought by executive agencies in a fiscal year (except automobiles designed for combat-related missions, law enforcement work, or emergency rescue work); divided by","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b939b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32917/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the fractions obtained by dividing the number of automobiles of each model leased or bought by the fuel economy of that model.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb8b939c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1075"},"text":"108 Stat. 1075","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb8b939d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb8b939e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb8b939f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32917(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2010(b)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 20, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/513"},"text":"Pub. L. 92–513","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/947"},"text":"86 Stat. 947","children":[],"tail":", § 510; added "},{"tag":"html:span","attrib":{},"text":"Dec. 22, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/163/s301"},"text":"Pub. L. 94–163, § 301","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/89/915"},"text":"89 Stat. 915","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32917(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2010(a), (b)(1), (3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “within 120 days after ","children":[{"tag":"date","attrib":{"date":"1975-12-22"},"text":"December 22, 1975","children":[],"tail":"” and “which begins after "},{"tag":"date","attrib":{"date":"1975-12-22"},"text":"December 22, 1975","children":[],"tail":"” are omitted as executed. The words “(determined under paragraph (2) of this subsection)” are added for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), before clause (A), the words “As used in this section: (1) The term” are omitted as surplus. In clause (A), the words “to which this section applies” and “for the Armed Forces” are omitted as surplus. In clause (B), the words “the sum of the fractions obtained” are substituted for “a sum of terms, each term of which is a fraction created” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
