{"tag":"section","attrib":{"id":"idcb54a455-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172"},"text":null,"children":[{"tag":"num","attrib":{"value":"30172"},"text":"§ 30172.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Whistleblower incentives and protections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb54a456-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb54a457-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered action” means any administrative or judicial action, including any related administrative or judicial action, brought by the Secretary or the Attorney General under this chapter that in the aggregate results in monetary sanctions exceeding $1,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a458-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monetary sanctions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “monetary sanctions” means monies, including penalties and interest, ordered or agreed to be paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a459-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Original information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “original information” means information that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb54a45a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is derived from the independent knowledge or analysis of an individual;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a45b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not known to the Secretary from any other source, unless the individual is the original source of the information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a45c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not exclusively derived from an allegation made in a judicial or an administrative action, in a governmental report, a hearing, an audit, or an investigation, or from the news media, unless the individual is a source of the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a45d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Part supplier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “part supplier” means a manufacturer of motor vehicle equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a45e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Successful resolution","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “successful resolution”, with respect to a covered action, includes any settlement or adjudication of the covered action.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a45f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Whistleblower","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “whistleblower” means any employee or contractor of a motor vehicle manufacturer, part supplier, or dealership who voluntarily provides to the Secretary original information relating to any motor vehicle defect, noncompliance, or any violation or alleged violation of any notification or reporting requirement of this chapter, which is likely to cause unreasonable risk of death or serious physical injury.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a460-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Awards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb54a461-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the original information that a whistleblower provided to the Secretary leads to the successful resolution of a covered action, the Secretary, subject to subsection (c), may pay an award or awards to one or more whistleblowers in an aggregate amount of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb54a462-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than 10 percent, in total, of collected monetary sanctions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a463-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 30 percent, in total, of collected monetary sanctions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a464-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment of awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amount payable under paragraph (1) shall be paid from the monetary sanctions collected, and any monetary sanctions so collected shall be available for such payment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a465-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of Awards; Denial of Awards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb54a466-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination of awards.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb54a467-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discretion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The determination of whether, to whom, or in what amount to make an award shall be in the discretion of the Secretary subject to the provisions in subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a468-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining an award made under subsection (b), the Secretary shall take into consideration—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb54a469-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if appropriate, whether a whistleblower reported or attempted to report the information internally to an applicable motor vehicle manufacturer, part supplier, or dealership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb54a46a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the significance of the original information provided by the whistleblower to the successful resolution of the covered action;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb54a46b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the degree of assistance provided by the whistleblower and any legal representative of the whistleblower in the covered action; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb54a46c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such additional factors as the Secretary considers relevant.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a46d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Denial of awards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No award under subsection (b) shall be made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb54a46e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any whistleblower who is convicted of a criminal violation related to the covered action for which the whistleblower otherwise could receive an award under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a46f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any whistleblower who, acting without direction from an applicable motor vehicle manufacturer, part supplier, or dealership, or agent thereof, deliberately causes or substantially contributes to the alleged violation of a requirement of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a470-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any whistleblower who submits information to the Secretary that is based on the facts underlying the covered action submitted previously by another whistleblower;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a471-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any whistleblower who fails to provide the original information to the Secretary in such form as the Secretary may require by regulation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a472-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" if the applicable motor vehicle manufacturer, parts supplier, or dealership has an internal reporting mechanism in place to protect employees from retaliation, to any whistleblower who fails to report or attempt to report the information internally through such mechanism, unless—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb54a473-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the whistleblower reasonably believed that such an internal report would have resulted in retaliation, notwithstanding section 30171(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb54a474-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the whistleblower reasonably believed that the information—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcb54a475-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/2/E/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was already internally reported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcb54a476-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/2/E/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was already subject to or part of an internal inquiry or investigation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcb54a477-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/2/E/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was otherwise already known to the motor vehicle manufacturer, part supplier, or dealership; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb54a478-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/c/2/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has good cause to waive this requirement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a479-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A whistleblower may be represented by counsel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a47a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Contract Necessary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No contract with the Secretary is necessary for any whistleblower to receive an award under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a47b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection of Whistleblowers; Confidentiality.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb54a47c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 30167, and except as provided in paragraphs (4) and (5) of this subsection, the Secretary, and any officer or employee of the Department of Transportation, shall not disclose any information, including information provided by a whistleblower to the Secretary, which could reasonably be expected to reveal the identity of a whistleblower, except in accordance with the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":", unless—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb54a47d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" required to be disclosed to a defendant or respondent in connection with a public proceeding instituted by the Secretary or any entity described in paragraph (5);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a47e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the whistleblower provides prior written consent for the information to be disclosed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a47f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary, or other officer or employee of the Department of Transportation, receives the information through another source, such as during an inspection or investigation under section 30166, and has authority under other law to release the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a480-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Redaction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, and any officer or employee of the Department of Transportation, shall take reasonable measures to not reveal the identity of the whistleblower when disclosing any information under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a481-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Section 552(b)(3)(b)","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":", paragraph (1) of this subsection shall be considered a statute described in subsection (b)(3)(B) of that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a482-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection is intended to limit the ability of the Attorney General to present such evidence to a grand jury or to share such evidence with potential witnesses or defendants in the course of an ongoing criminal investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a483-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability to government agencies.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb54a484-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/f/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Without the loss of its status as confidential in the hands of the Secretary, all information referred to in paragraph (1) may, in the discretion of the Secretary, when determined by the Secretary to be necessary or appropriate to accomplish the purposes of this chapter and in accordance with subparagraph (B), be made available to the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb54a485-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/f/5/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Department of Justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb54a486-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/f/5/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An appropriate department or agency of the Federal Government, acting within the scope of its jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a487-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/f/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maintenance of information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each entity described in subparagraph (A) shall maintain information described in that subparagraph as confidential, in accordance with the requirements in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a488-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of False Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A whistleblower who knowingly and intentionally makes any false, fictitious, or fraudulent statement or representation, or who makes or uses any false writing or document knowing the same to contain any false, fictitious, or fraudulent statement or entry, shall not be entitled to an award under this section and shall be subject to prosecution under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1001"},"text":"section 1001 of title 18","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a489-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeals.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb54a48a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any determination made under this section, including whether, to whom, or in what amount to make an award, shall be in the discretion of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a48b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any determination made by the Secretary under this section may be appealed by a whistleblower to the appropriate court of appeals of the United States not later than 30 days after the determination is issued by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a48c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The court shall review the determination made by the Secretary in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s706"},"text":"section 706 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a48d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30172/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of enactment of this section, the Secretary shall promulgate regulations on the requirements of this section, consistent with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb54a48e-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dB/tXXIV/s24352/a"},"text":"Pub. L. 114–94, div. B, title XXIV, § 24352(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1716"},"text":"129 Stat. 1716","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb54a48f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb54a490-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb54a491-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (i), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb54a492-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb54a493-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dB/tXXIV/s24352/b"},"text":"Pub. L. 114–94, div. B, title XXIV, § 24352(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1720"},"text":"129 Stat. 1720","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dB/tXXIV/s24352/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Original information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Information submitted to the Secretary of Transportation by a whistleblower in accordance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30172"},"text":"section 30172 of title 49","children":[],"tail":", United States Code, shall not lose its status as original information solely because the whistleblower submitted the information prior to the effective date of the regulations issued under subsection (i) of that section if that information was submitted after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Awards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A whistleblower may receive an award under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30172"},"text":"section 30172 of title 49","children":[],"tail":", United States Code, regardless of whether the violation underlying the covered action occurred prior to the date of enactment of this Act, and may receive an award prior to the Secretary of Transportation promulgating the regulations under subsection (i) of that section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
