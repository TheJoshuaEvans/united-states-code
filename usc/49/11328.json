{"tag":"section","attrib":{"id":"idcaee1ad8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11328"},"text":null,"children":[{"tag":"num","attrib":{"value":"11328"},"text":"§ 11328.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restrictions on officers and directors","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaee1ad9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11328/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person may hold the position of officer or director of more than one rail carrier only when authorized by the Board. The Board may authorize a person to hold the position of officer or director of more than one of those carriers when public or private interests will not be adversely affected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaee1ada-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11328/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This section shall not apply to an individual holding the position of officer or director only of Class III rail carriers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaee1adb-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/843"},"text":"109 Stat. 843","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaee1adc-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaee1add-47c4-11f1-9671-b5c725212f70"