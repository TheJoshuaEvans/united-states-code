{"tag":"section","attrib":{"id":"idcb20277b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22103"},"text":null,"children":[{"tag":"num","attrib":{"value":"22103"},"text":"§ 22103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb20277c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State must file an application with the Secretary of Transportation for financial assistance for a project described under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s22101/a"},"text":"section 22101(a) of this title","children":[],"tail":" not later than January 1 of the fiscal year for which amounts have been appropriated. However, for a fiscal year for which the authorization of appropriations for assistance under this chapter has not been enacted by the first day of the fiscal year, the State must file the application not later than 90 days after the date of enactment of a law authorizing the appropriations for that fiscal year. The Secretary shall prescribe the form of the application."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb20277d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In considering an application under this subsection, the Secretary shall consider the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb20277e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage of rail lines that rail carriers have identified to the Surface Transportation Board for abandonment or potential abandonment in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb20277f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood of future abandonments in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb202780-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ratio of benefits to costs for a proposed project calculated using the methodology established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s22101/b"},"text":"section 22101(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb202781-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the likelihood that the rail line will continue operating with assistance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb202782-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22103/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of rail bankruptcies, rail restructuring, and rail mergers on the State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb202783-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/896"},"text":"108 Stat. 896","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s308/f/3"},"text":"Pub. L. 104–88, title III, § 308(f)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/947"},"text":"109 Stat. 947","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb202784-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb202785-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb202786-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail