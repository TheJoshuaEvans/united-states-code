{"tag":"section","attrib":{"id":"idcae96011-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11141"},"text":null,"children":[{"tag":"num","attrib":{"value":"11141"},"text":"§ 11141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcae96012-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11141/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms “rail carrier” and “lessor” include a receiver or trustee of a rail carrier and lessor, respectively;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae96013-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11141/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “lessor” means a person owning a railroad that is leased to and operated by a carrier providing transportation subject to the jurisdiction of the Board under this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae96014-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11141/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “association” means an organization maintained by or in the interest of a group of rail carriers providing transportation or service subject to the jurisdiction of the Board under this part that performs a service, or engages in activities, related to transportation under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcae96015-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/834"},"text":"109 Stat. 834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcae96016-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcae96017-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcae96018-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11141, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1425"},"text":"92 Stat. 1425","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/521/s9/c"},"text":"Pub. L. 99–521, § 9(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2997"},"text":"100 Stat. 2997","children":[],"tail":", defined terms for purposes of former sections 11141 to 11145 of this title, prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":". See sections 11141, 14121, and 15721 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcae96019-47c4-11f1-9671-b5c725