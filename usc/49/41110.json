{"tag":"section","attrib":{"id":"idcbb8be1c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110"},"text":null,"children":[{"tag":"num","attrib":{"value":"41110"},"text":"§ 41110.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective periods and amendments, modifications, suspensions, and revocations of certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbb8be1d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbb8be1e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":" is effective from the date specified in it and remains in effect until—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbb8be1f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation suspends or revokes the certificate under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbb8be20-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the end of the period the Secretary specifies for an air carrier having a certificate of temporary authority issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102/a/2"},"text":"section 41102(a)(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbb8be21-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary certifies that transportation is no longer being provided under a certificate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8be22-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On application or on the initiative of the Secretary and after notice and an opportunity for a hearing or, except as provided in paragraph (4) of this subsection, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41111"},"text":"section 41111 of this title","children":[],"tail":", the Secretary may—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbb8be23-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amend, modify, or suspend any part of a certificate if the Secretary finds the public convenience and necessity require amendment, modification, or suspension; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbb8be24-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revoke any part of a certificate if the Secretary finds that the holder of the certificate intentionally does not comply with this chapter, sections 41308–41310(a), 41501, 41503, 41504, 41506, 41510, 41511, 41701, 41702, 41705–41709, 41711, 41712, and 41731–41742, chapter 419, subchapter II of chapter 421, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s46301/b"},"text":"section 46301(b) of this title","children":[],"tail":", a regulation or order of the Secretary under any of those provisions, or a term of its certificate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8be25-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may revoke a certificate under paragraph (2)(B) of this subsection only if the holder of the certificate does not comply, within a reasonable time the Secretary specifies, with an order to the holder requiring compliance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8be26-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certificate to provide foreign air transportation may not be amended, modified, suspended, or revoked under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41111"},"text":"section 41111 of this title","children":[],"tail":" if the holder of the certificate requests an oral evidentiary hearing or the Secretary finds, under all the facts and circumstances, that the hearing is required in the public interest."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb8be27-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"All-Cargo Air Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may order that a certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41103"},"text":"section 41103 of this title","children":[],"tail":" authorizing all-cargo air transportation is ineffective if, after notice and an opportunity for a hearing, the Secretary finds that the transportation is not provided to the minimum extent specified by the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb8be28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Air Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbb8be29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding subsection (a)(2)–(4) of this section, after notice and a reasonable opportunity for the affected air carrier to present its views, but without a hearing, the Secretary may suspend or revoke the authority of an air carrier to provide foreign air transportation to a place under a certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":" if the carrier—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbb8be2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifies the Secretary, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41734/a"},"text":"section 41734(a) of this title","children":[],"tail":" or a regulation of the Secretary, that it intends to suspend all transportation to that place; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbb8be2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not provide regularly scheduled transportation to the place for 90 days immediately before the date the Secretary notifies the carrier of the action the Secretary proposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8be2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1)(B) of this subsection does not apply to a place provided seasonal transportation comparable to the transportation provided during the prior year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb8be2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary Certificates","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On application or on the initiative of the Secretary, the Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbb8be2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the performance of an air carrier issued a certificate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102/c"},"text":"section 41102(c) of this title","children":[],"tail":" on the basis that the air carrier will provide innovative or low-priced air transportation under the certificate; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8be2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amend, modify, suspend, or revoke the certificate or authority under subsection (a)(2) or (c) of this section if the air carrier has not provided, or is not providing, the transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb8be30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Continuing Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbb8be31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To hold a certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":", an air carrier must continue to be fit, willing, and able to provide the transportation authorized by the certificate and to comply with this part and regulations of the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8be32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" After notice and an opportunity for a hearing, the Secretary shall amend, modify, suspend, or revoke any part of a certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":" if the Secretary finds that the air carrier—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbb8be33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not fit, willing, and able to provide the transportation authorized by the certificate and to comply with this part and regulations of the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbb8be34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not file reports necessary for the Secretary to decide if the carrier is complying with the requirements of clause (A) of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb8be35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Illegal Importation of Controlled Substances","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbb8be36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in consultation with appropriate departments, agencies, and instrumentalities of the United States Government, shall reexamine immediately the fitness of an air carrier that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbb8be37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" violates the laws and regulations of the United States related to the illegal importation of a controlled substance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbb8be38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not adopt available measures to prevent the illegal importation of a controlled substance into the United States on its aircraft; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8be39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when appropriate, shall amend, modify, suspend, or revoke the certificate of the carrier issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb8be3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41110/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An interested person may file a response with the Secretary opposing or supporting the amendment, modification, suspension, or revocation of a certificate under subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbbb2e3b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1123"},"text":"108 Stat. 1123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/50"},"text":"Pub. L. 103–429, § 6(50)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4384"},"text":"108 Stat. 4384","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbbb2e3c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbbb2e3d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbbb2e3e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41110(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1371(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s401/f"},"text":"Pub. L. 85–726, § 401(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/755"},"text":"72 Stat. 755","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/504"},"text":"Pub.