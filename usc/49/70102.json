{"tag":"section","attrib":{"id":"idcc88431d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102"},"text":null,"children":[{"tag":"num","attrib":{"value":"70102"},"text":"§ 70102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National freight strategic plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc88431e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary for Multimodal Freight (referred to in this section as the “Assistant Secretary”) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc88431f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a national freight strategic plan in accordance with this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884320-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the plan on the public Internet Web site of the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc884321-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The national freight strategic plan shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc884322-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the condition and performance of the National Multimodal Freight Network established under section 70103;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884323-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forecasts of freight volumes for the succeeding 5-, 10-, and 20-year periods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884324-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of major trade gateways and national freight corridors that connect major population centers, trade gateways, and other major freight generators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884325-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an identification of bottlenecks on the National Multimodal Freight Network that create significant freight congestion, based on a quantitative methodology developed by the Assistant Secretary, which shall include, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc884326-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information from the Freight Analysis Framework of the Federal Highway Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884327-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, an estimate of the cost of addressing each bottleneck and any operational improvements that could be implemented;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884328-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of statutory, regulatory, technological, institutional, financial, and other barriers to improved freight transportation performance, and a description of opportunities for overcoming the barriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884329-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process for addressing multistate projects and encouraging jurisdictions to collaborate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88432a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies to improve freight intermodal connectivity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88432b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of corridors providing access to energy exploration, development, installation, or production areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88432c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of corridors providing access to major areas for manufacturing, agriculture, or natural resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88432d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of best practices for improving the performance of the National Multimodal Freight Network, including critical commerce corridors and rural and urban access to critical freight corridors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88432e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an identification of best practices to mitigate the impacts of freight movement on communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88432f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" best practices for reducing environmental impacts of freight movement (including reducing local air pollution from freight movement, stormwater runoff, and wildlife habitat loss resulting from freight facilities, freight vehicles, or freight activity);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884330-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possible strategies to increase the resilience of the freight system, including the ability to anticipate, prepare for, or adapt to conditions, or withstand, respond to, or recover rapidly from disruptions, including extreme weather and natural disasters;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884331-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies to promote United States economic growth and international competitiveness;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884332-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of any potential unique impacts of the national freight system on rural and other underserved and historically disadvantaged communities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884333-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" strategies for decarbonizing freight movement, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884334-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/b/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of the impacts of e-commerce on the national multimodal freight system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc884335-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 5 years after the date of completion of the national freight strategic plan under subsection (a), and every 5 years thereafter, the Assistant Secretary shall update the plan and publish the updated plan on the public Internet Web site of the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc884336-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Assistant Secretary shall develop and update the national freight strategic plan—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc884337-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after providing notice and an opportunity for public comment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884338-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70102/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with State departments of transportation, metropolitan planning organizations, and other appropriate public and private transportation stakeholders.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc884339-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVIII/s8001/a"},"text":"Pub. L. 114–94, div. A, title VIII, § 8001(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1606"},"text":"129 Stat. 1606","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI"},"text":"Pub. L. 117–58, div. B, title I","children":[],"tail":", §§ 21101(d)(2), 21102, "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/656"},"text":"135 Stat. 656","children":[],"tail":", 657.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc88433a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc88433b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcc88433c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 70102 was transferred and renumbered as ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50902"},"text":"section 50902 of Title 51","children":[],"tail":", National and Commercial Space Programs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc88433d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21101/d/2/A"},"text":"Pub. L. 117–58, § 21101(d)(2)(A)","children":[],"tail":", substituted “The Assistant Secretary for Multimodal Freight (referred to in this section as the ‘Assistant Secretary’)” for “Not later than 2 years after the date of enactment of this section, the Under Secretary of Transportation for Policy” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21101/d/2/B"},"text":"Pub. L. 117–58, § 21101(d)(2)(B)","children":[],"tail":", substituted “Assistant Secretary” for “Under Secretary” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(12) to (17). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21102"},"text":"Pub. L. 117–58, § 21102","children":[],"tail":", added pars. (12) to (17)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21101/d/2/C"},"text":"Pub. L. 117–58, § 21101(d)(2)(C)","children":[],"tail":", substituted “Assistant Secretary” for “Under Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s21101/d/2/D"},"text":"Pub. L. 117–58, § 21101(d)(2)(D)","children":[],"tail":", substituted “Assistant Secretary” for “Under Secretary” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc88433e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc88433f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
