{"tag":"section","attrib":{"id":"idcc0c34ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744"},"text":null,"children":[{"tag":"num","attrib":{"value":"44744"},"text":"§ 44744.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Flight crew alerting","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc0c34ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on ","children":[{"tag":"date","attrib":{"date":"2022-12-27"},"text":"December 27, 2022","children":[],"tail":", the Administrator may not issue a type certificate for a transport category airplane unless such airplane incorporates a flight crew alerting system that, at a minimum—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c34ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" displays and differentiates among warnings, cautions, and advisories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c34f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes functions to assist the flight crew in prioritizing corrective actions and responding to systems failures.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c34f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The prohibition in subsection (a) shall not apply to any application for an original or amended type certificate that was submitted to the Administrator prior to ","children":[{"tag":"date","attrib":{"date":"2020-12-27"},"text":"December 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c34f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety Enhancements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c34f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction on airworthiness certificate issuance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning on the date that is 1 year after the date on which the Administrator issues a type certificate for the Boeing 737-10, the Administrator may not issue an original airworthiness certificate for any Boeing 737 MAX aircraft unless the Administrator finds that the type design for the aircraft includes safety enhancements that have been approved by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c34f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restriction on operation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on the date that is 3 years after the date on which the Administrator issues a type certificate for the Boeing 737-10, no person may operate a Boeing 737 MAX aircraft unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c34f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the type design for the aircraft includes safety enhancements approved by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c34f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the aircraft was—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc0c34f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produced in conformance with such type design; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc0c34f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" altered in accordance with such type design.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c34f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c34fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Boeing 737 max aircraft","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “Boeing 737 MAX aircraft” means any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c34fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Model 737 series aircraft designated as a 737-7, 737-8, 737-8200, 737-9, or 737-10; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c34fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other variant of a model described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c34fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety enhancement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “safety enhancement” means any design change to the flight crew alerting system approved by the Administrator for the Boeing 737-10, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c34fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc0c34ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" synthetic enhanced angle-of-attack system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc0c3500-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means to shut off stall warning and overspeed alerts; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c3501-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44744/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any design changes equivalent to subparagraph (A) determined appropriate by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc0c3502-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dO/tV/s501/a"},"text":"Pub. L. 117–328, div. O, title V, § 501(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5230"},"text":"136 Stat. 5230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc0c3503-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc0c3504-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc0c3505-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Costs of Safety Enhancements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dO/tV/s501/c"},"text":"Pub. L. 117–328, div. O, title V, § 501(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5231"},"text":"136 Stat. 5231","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dO/tV/s501/c"},"text":"“Any costs associated with the safety enhancements required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44744"},"text":"section 44744 of title 49","children":[],"tail":", United States Code, as added by subsection (a), shall be borne by the holder of the type certificate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc0c3506-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Congressional Briefings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dO/tV/s501/d"},"text":"Pub. L. 117–328, div. O, title V, § 501(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5231"},"text":"136 Stat. 5231","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dO/tV/s501/d"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than ","children":[{"tag":"date","attrib":{"date":"2023-03-01"},"text":"March 1, 2023","children":[],"tail":", and on a quarterly basis thereafter, the Administrator shall brief Congress on the status of—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the issuance of a type certificate for the Boeing 737-7 and 737-10, including any design enhancements, pilot procedures, or training requirements resulting from system safety assessments; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of safety enhancements for Boeing 737 MAX aircraft, as required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44744"},"text":"section 44744 of title 49","children":[],"tail":", United States Code, as added by subsection (a).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
