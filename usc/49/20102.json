{"tag":"section","attrib":{"id":"idcb0ac9f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102"},"text":null,"children":[{"tag":"num","attrib":{"value":"20102"},"text":"§ 20102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0ac9f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “Class I railroad”, “Class II railroad”, and “Class III railroad” mean railroad carriers that have annual carrier operating revenues that meet the threshold amount for Class I carriers, Class II carriers, and Class III carriers, respectively, as determined by the Surface Transportation Board under section 1201.1–1 of title 49, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0ac9f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “railroad”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0ac9f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means any form of nonhighway ground transportation that runs on rails or electromagnetic guideways, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb0ac9f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commuter or other short-haul railroad passenger service in a metropolitan or suburban area and commuter railroad service that was operated by the Consolidated Rail Corporation on ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"January 1, 1979","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb0ac9f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" high speed ground transportation systems that connect metropolitan areas, without regard to whether those systems use new technologies not associated with traditional railroads; but","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0ac9f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include rapid transit operations in an urban area that are not connected to the general railroad system of transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0ac9f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “railroad carrier” means a person providing railroad transportation, except that, upon petition by a group of commonly controlled railroad carriers that the Secretary determines is operating within the United States as a single, integrated rail system, the Secretary may by order treat the group of railroad carriers as a single railroad carrier for purposes of one or more provisions of part A, subtitle V of this title and implementing regulations and order, subject to any appropriate conditions that the Secretary may impose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0ac9f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “safety-related railroad employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0ac9fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a railroad employee who is subject to chapter 211;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0ac9fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another operating railroad employee who is not subject to chapter 211;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0ac9fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee who maintains the right of way of a railroad;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0ac9fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee of a railroad carrier who is a hazmat employee as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5102/3"},"text":"section 5102(3) of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0ac9fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/4/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee who inspects, repairs, or maintains locomotives, passenger cars, or freight cars; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0ac9ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20102/4/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other employee of a railroad carrier who directly affects railroad safety, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0aca00-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/863"},"text":"108 Stat. 863","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/s2/b"},"text":"Pub. L. 110–432, div. A, § 2(b)","children":[],"tail":", title IV, § 407, "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4850"},"text":"122 Stat. 4850","children":[],"tail":", 4886.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb0aca01-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb0aca02-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb0aca03-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col"