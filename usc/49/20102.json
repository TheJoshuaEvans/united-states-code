xt":"Sept. 18, 1940, ch. 722, § 14(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/54/919"},"text":"54 Stat. 919","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s17/1"},"text":"Pub. L. 100–342, § 17(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/635"},"text":"102 Stat. 635","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20102(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(no source).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (1) is substituted for the source provisions to avoid repeating the definition of “railroad” in each chapter in this part.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (2) is added to distinguish between railroad transportation and the entity providing railroad transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb0aca04-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb0aca05-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s2/b"},"text":"Pub. L. 110–432, § 2(b)","children":[],"tail":", added pars. (1) and (4) and redesignated former pars. (1) and (2) as (2) and (3), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s407"},"text":"Pub. L. 110–432, § 407","children":[],"tail":", amended par. (3) generally. Prior to amendment, text read as follows: “ ‘railroad carrier’ means a person providing railroad transportation.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb0aca06-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"definitions","id":"idcb0aca07-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Definitions Applicable to Division A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":null}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/s2/a"},"text":"Pub. L. 110–432, div. A, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4849"},"text":"122 Stat. 4849","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11316/j/2"},"text":"Pub. L. 114–94, div. A, title XI, § 11316(j)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1677"},"text":"129 Stat. 1677","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tXI/s11316/j/2"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In this division [see Short Title of 2008 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20101"},"text":"section 20101 of this title","children":[],"tail":"]:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Crossing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘crossing’ means a location within a State, other than a location where one or more railroad tracks cross one or more railroad tracks at grade, where—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public highway, road, or street, or a private roadway, including associated sidewalks and pathways, crosses one or more railroad tracks either at grade or grade-separated; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pathway explicitly authorized by a public authority or a railroad carrier that is dedicated for the use of nonvehicular traffic, including pedestrians, bicyclists, and others, that is not associated with a public highway, road, or street, or a private roadway, crosses one or more railroad tracks either at grade or grade-separated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Department","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Department’ means the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Railroad","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘railroad’ has the meaning given that term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20102"},"text":"section 20102 of title 49","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Railroad carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘railroad carrier’ has the meaning given that term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20102"},"text":"section 20102 of title 49","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Secretary’ means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘State’ means a State of the United States, the District of Columbia, or the Commonwealth of Puerto Rico.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
