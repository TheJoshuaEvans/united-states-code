ldren":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47305(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1159(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47305(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1160.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-16/ch473/s12"},"text":"June 16, 1948, ch. 473, § 12","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/454"},"text":"62 Stat. 454","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s1403"},"text":"Pub. L. 85–726, § 1403","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/808"},"text":"72 Stat. 808","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/623/s3"},"text":"Pub. L. 93–623, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2103"},"text":"88 Stat. 2103","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47305(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1159(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the title “Secretary of Commerce” is substituted for “Chief of the Weather Bureau” in section 10(b)–(d), and for “Chief of the Weather Bureau” and “Weather Bureau” in section 12, of the International Aviation Facilities Act (ch. 473, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/62/454"},"text":"62 Stat. 454","children":[],"tail":") because of sections 1 and 2 of Reorganization Plan No. 2 of 1965 (eff. "},{"tag":"date","attrib":{"date":"1965-07-13"},"text":"July 13, 1965","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/79/1318"},"text":"79 Stat. 1318","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “do and perform, by contract or otherwise, all acts and things necessary or incident to” and “pursuant to this chapter or any other provision of law” are omitted as surplus. In clause (1), the words “from time to time” and “by construction, installation, reengineering, relocation, or otherwise” are omitted as surplus. The text of 49 App.:1159(a)(2) is omitted as surplus because of 49:322(a). In clause (2), the words “under such conditions as he may deem proper” and “space or” are omitted as surplus. The words “for not more than 20 years” are substituted for “and for such periods as may be desirable (not to exceed twenty years)” to eliminate unnecessary words. The words “for purposes essential or appropriate to their consolidation, operation, protection, and administration under this chapter” are omitted as surplus. In clause (3), the words “the sale of fuel, oil, equipment, food and supplies, hotel accommodations, and other” and “necessary or desirable for the operation and administration of such properties” are omitted as surplus. In clause (4), the word “reasonable” is substituted for “just and reasonable” for consistency in the revised title and with other titles of the United States Code. The words “(including but not limited to landing fees and fees for the use of communication services)” are omitted as surplus. In clause (5), the words “by purchase or otherwise, real or personal” and “which he may consider necessary for the purposes of this section” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “including handling charges” are omitted as surplus. The words “facilities and services sold or provided” are substituted for “of the fuel, oil, equipment, food, supplies, services, shelter, or other assistance or services sold or furnished” for consistency and to eliminate unnecessary words. The words “under subsection (a)(3) and (4) of this section” are added for clarity. The words “if any” are omitted as surplus. The words “deposited in the Treasury as” are substituted for “credited to” for clarity and consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “use personnel and facilities of the United States Government most advantageously and without unnecessary duplication” are substituted for “to the end that personnel and facilities of existing United States Government agencies shall be utilized to the fullest possible advantage and not be unnecessarily duplicated” to eliminate unnecessary words. The word “request” is substituted for “arrange for” for clarity. The words “department, agency, or instrumentality of the Government” are substituted for “other United States Government agencies” for consistency in the revised title and with other titles of the Code. The words “on a reimbursable basis” are substituted for “and to reimburse any such agency for such service out of funds appropriated to the Department of Transportation or the Department of Commerce, as the case may be” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc648ea1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc648ea2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2011—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/350"},"text":"Pub. L. 111–350","children":[],"tail":" substituted “Section 6101(b) to (d) of title 41” for “Section 3709 of the Revised Statutes ("},{"tag":"ref","attrib":{"href":"/us/usc/t41/s5"},"text":"41 U.S.C. 5","children":[],"tail":")”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc648ea3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc648ea4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annette Island Airport, Alaska; Renewal of Lease","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1956-05-09/ch241"},"text":"Act May 9, 1956, ch. 241","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/146"},"text":"70 Stat. 146","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/act/1956-05-09/ch241"},"text":"“That the Congress of the United States hereby approves the extension, from year to year, until ","children":[{"tag":"date","attrib":{"date":"1999-06-30"},"text":"June 30, 1999","children":[],"tail":", of a lease of certain land comprising part of Annette Island, Alaska, for use by the Civil Aeronautics Administration [now the Federal Aviation Administration] as an airport, entered into by the United States of America and the Council of the Annette Island Reserve on "},{"tag":"date","attrib":{"date":"1948-12-13"},"text":"December 13, 1948","children":[],"tail":", section 5 of which lease provides that no renewal thereof shall extend beyond "},{"tag":"date","attrib":{"date":"1959-06-30"},"text":"June 30, 1959","children":[],"tail":", unless approved by Congress.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
