{"tag":"section","attrib":{"id":"idcc0c3581-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44748"},"text":null,"children":[{"tag":"num","attrib":{"value":"44748"},"text":"§ 44748.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aircraft dispatching","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc0c3582-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44748/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aircraft Dispatching Certificate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person may serve as an aircraft dispatcher for an air carrier unless such person holds the appropriate aircraft dispatcher certificate issued by the Administrator of the Federal Aviation Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c3583-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44748/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proof of Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Upon the request of the Administrator or an authorized representative of the National Transportation Safety Board, or other appropriate Federal agency, a person who holds such a certificate, and is performing dispatching, shall present the certificate for inspection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c3584-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44748/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dispatch Centers and Flight Following Centers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c3585-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44748/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each air carrier shall establish and maintain sufficient dispatch centers and flight following centers necessary to maintain operational control of each flight of the air carrier at all times.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c3586-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44748/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An air carrier shall ensure that each dispatch center and flight following center of the air carrier—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c3587-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44748/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a sufficient number of aircraft dispatchers on duty at the dispatch center or flight following center to ensure proper operational control of each flight of the air carrier at all times;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c3588-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44748/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the necessary equipment, in good repair, to maintain proper operational control of each flight of the air carrier at all times; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c3589-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44748/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the presence of physical security and cybersecurity protections to prevent unauthorized access to the dispatch center or flight following center or to the operations of either such center.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c358a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44748/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c358b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44748/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), an air carrier may not dispatch aircraft from any location other than the dispatch center or flight following center of the air carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c358c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44748/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Emergency authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the event of an emergency or other event that renders a dispatch center or a flight following center inoperable, an air carrier may dispatch aircraft from a location other than the dispatch center or flight following center of the air carrier for a period of time not to exceed 14 consecutive days per location without approval of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc0c358d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIV/s420/b/1"},"text":"Pub. L. 118–63, title IV, § 420(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1164"},"text":"138 Stat. 1164","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
