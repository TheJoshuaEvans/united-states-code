{"tag":"section","attrib":{"id":"idcc5d61b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47133"},"text":null,"children":[{"tag":"num","attrib":{"value":"47133"},"text":"§ 47133.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on use of revenues","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc5d61b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47133/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Local taxes on aviation fuel (except taxes in effect on ","children":[{"tag":"date","attrib":{"date":"1987-12-30"},"text":"December 30, 1987","children":[],"tail":") or the revenues generated by an airport that is the subject of Federal assistance may not be expended for any purpose other than the capital or operating costs of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d61b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47133/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the airport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d61b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47133/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the local airport system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d61b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47133/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other local facility that is owned or operated by the person or entity that owns or operates the airport that is directly and substantially related to the air transportation of passengers or property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d61b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47133/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d61ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47133/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prior laws and agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not apply if a provision enacted not later than ","children":[{"tag":"date","attrib":{"date":"1982-09-02"},"text":"September 2, 1982","children":[],"tail":", in a law controlling financing by the airport owner or operator, or a covenant or assurance in a debt obligation issued not later than "},{"tag":"date","attrib":{"date":"1982-09-02"},"text":"September 2, 1982","children":[],"tail":", by the owner or operator, provides that the revenues, including local taxes on aviation fuel at public airports, from any of the facilities of the owner or operator, including the airport, be used to support not only the airport but also the general debt obligations or other facilities of the owner or operator."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d61bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47133/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sale of private airport to public sponsor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a privately owned airport, subsection (a) shall not apply to the proceeds from the sale of the airport to a public sponsor if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc5d61bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47133/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale is approved by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5d61bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47133/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" funding is provided under this subchapter for any portion of the public sponsor’s acquisition of airport land; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5d61be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47133/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount equal to the remaining unamortized portion of any airport improvement grant made to that airport for purposes other than land acquisition, amortized over a 20-year period, plus an amount equal to the Federal share of the current fair market value of any land acquired with an airport improvement grant made to that airport on or after ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":", is repaid to the Secretary by the private owner."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d61bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47133/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of repayments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Repayments referred to in paragraph (2)(C) shall be treated as a recovery of prior year obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d61c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47133/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to prevent the use of a State tax on aviation fuel to support a State aviation program or the use of airport revenue on or off the airport for a noise mitigation purpose.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc5d61c1-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264/tVIII/s804/a"},"text":"Pub. L. 104–264, title VIII, § 804(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3271"},"text":"110 Stat. 3271","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tI/s149/a"},"text":"Pub. L. 112–95, title I, § 149(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/32"},"text":"126 Stat. 32","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc5d61c2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc5d61c3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc5d61c4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":", designated existing provisions as par. (1), inserted heading, and added pars. (2) and (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc5d61c5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc5d61c6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tI/s149/b"},"text":"Pub. L. 112–95, title I, § 149(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/32"},"text":"126 Stat. 32","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/95/tI/s149/b"},"text":"“The amendments made by subsection (a) [amending this section] shall apply to grants issued on or after ","children":[{"tag":"date","attrib":{"date":"1996-10-01"},"text":"October 1, 1996","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc5d61c7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided, section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", and not to be construed as affecting funds made available for a fiscal year ending before "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/s3"},"text":"section 3 of Pub. L. 104–264","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc5d61c8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Use of Mineral Revenue at Certain Airports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tVIII/s813"},"text":"Pub. L. 112–95, title VIII, § 813","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/124"},"text":"126 Stat. 124","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/95/tVIII/s813"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, the Administrator of the Federal Aviation Administration may declare certain revenue derived from or generated by mineral extraction, production, lease, or other means at a general aviation airport to be revenue greater than the amount needed to carry out the 5-year projected maintenance needs of the airport in order to comply with the applicable design and safety standards of the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Revenue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An airport sponsor that is in compliance with the conditions under subsection (c) may allocate revenue identified by the Administrator under subsection (a) for Federal, State, or local transportation infrastructure projects carried out by the airport sponsor or by a governing body within the geographical limits of the airport sponsor’s jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An airport sponsor may not allocate revenue identified by the Administrator under subsection (a) unless the airport sponsor—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" enters into a written agreement with the Administrator that sets forth a 5-year capital improvement program for the airport, which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the projected costs for the operation, maintenance, and capacity needs of the airport in order to comply with applicable design and safety standards of the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriately adjusts such costs to account for inflation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" agrees in writing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to waive all rights to receive entitlement funds or discretionary funds to be used at the airport under section 47114 or 47115 of title 49, United States Code, during the 5-year period of the capital improvement plan described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to perpetually comply with sections 47107(b) and 47133 of such title, unless granted specific exceptions by the Administrator in accordance with this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to operate the airport as a public-use airport, unless the Administrator specifically grants a request to allow the airport to close; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with all grant assurance obligations in effect as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":"] during the 20-year period beginning on the date of enactment of this Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Completion of Determination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after receiving an airport sponsor’s application and requisite supporting documentation to declare that certain mineral revenue is not needed to carry out the 5-year capital improvement program at such airport, the Administrator shall determine whether the airport sponsor’s request should be granted. The Administrator may not unreasonably deny an application under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rulemaking","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act, the Administrator shall promulgate regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Aviation Airport Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘general aviation airport’ has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47102"},"text":"section 47102 of title 49","children":[],"tail":", United States Code, as amended by this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
