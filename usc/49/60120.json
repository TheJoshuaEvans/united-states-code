 App.:2010(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/129"},"text":"Pub. L. 96–129","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/989"},"text":"93 Stat. 989","children":[],"tail":", § 211(f); added "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/508/s211/b"},"text":"Pub. L. 102–508, § 211(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/3304"},"text":"106 Stat. 3304","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60120(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1679b(a)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2008(a)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60120(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1677(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/481/s10/c"},"text":"Pub. L. 90–481, § 10(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/725"},"text":"82 Stat. 725","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/129"},"text":"Pub. L. 96–129","children":[],"tail":", §§ 104(a)(1), 152(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/93/992"},"text":"93 Stat. 992","children":[],"tail":", 999."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2006(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the text of 49 App.:1677(b)(2) and 2006(b)(2) and the words “shall have jurisdiction to determine such actions” in 49 App.:1679b(a)(1) and 2008(a)(1) are omitted as redundant and because of 28:1331 and 1345. The word “civil” is added for consistency in the revised title and with other titles of the United States Code and because of rule 2 of the Federal Rules of Civil Procedure (28 App. U.S.C.). The words “to enforce this chapter” are substituted for “for equitable relief to redress or restrain a violation by any person of a provision of this chapter” to eliminate unnecessary words. The word “prescribed” is substituted for “issued” for consistency in the revised title and with other titles of the Code. The words “necessary or . . . mandatory or prohibitive injunctive relief, interim equitable relief, and” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “the Attorney General may bring a civil action in a district court of the United States” are substituted for “such district court shall, upon the request of the Attorney General . . . have jurisdiction to issue to such person an order” for clarity and consistency and because of 28:1331 and 1345. The words “contumacy or” are omitted as surplus. The word “premises” is added for clarity and consistency. The words “or examine” are omitted as being included in “inspect”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “mandatory or prohibitive” are omitted as surplus. The words “the defendant may demand a jury trial” are substituted for “trial shall be by the court or, upon demand of the accused, by a jury” to eliminate unnecessary words and for consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “common law or statutory” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc811674-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc811675-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90"},"text":"Pub. L. 112–90","children":[],"tail":" added at end “The maximum amount of civil penalties for administrative enforcement actions under section 60122 shall not apply to enforcement actions under this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355"},"text":"Pub. L. 107–355","children":[],"tail":" reenacted subsec. heading without change, added par. (1) and struck out former par. (1), inserted par. (2) heading and realigned margins. Prior to amendment, par. (1) read as follows: “On the request of the Secretary of Transportation, the Attorney General may bring a civil action in an appropriate district court of the United States to enforce this chapter or a regulation prescribed or order issued under this chapter. The court may award appropriate relief, including punitive damages.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
