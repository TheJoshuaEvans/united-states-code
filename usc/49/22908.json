{"tag":"section","attrib":{"id":"idcb275378-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908"},"text":null,"children":[{"tag":"num","attrib":{"value":"22908"},"text":"§ 22908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restoration and enhancement grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb275379-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb27537a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicant","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 22901(1), the term “applicant” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb27537b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, including the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb27537c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a group of States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb27537d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity implementing an interstate compact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb27537e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a public agency or publicly chartered authority established by 1 or more States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb27537f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a political subdivision of a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb275380-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a federally recognized Indian Tribe;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb275381-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amtrak or another rail carrier that provides intercity rail passenger transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb275382-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rail carrier in partnership with at least 1 of the entities described in subparagraphs (A) through (F); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb275383-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any combination of the entities described in subparagraphs (A) through (F).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb275384-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operating assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “operating assistance”, with respect to any route subject to section 209 of the Passenger Rail Investment and Improvement Act of 2008 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Public Law 110–432","children":[],"tail":"), means any cost allocated, or that may be allocated, to a route pursuant to the cost methodology established under such section or under section 24712."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb275385-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall develop and implement a program for issuing operating assistance grants to applicants, on a competitive basis, for the purpose of initiating, restoring, or enhancing intercity rail passenger transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb275386-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An applicant for a grant under this section shall submit to the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb275387-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a capital and mobilization plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb275388-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes any capital investments, service planning actions (such as environmental reviews), and mobilization actions (such as qualification of train crews) required for initiation of intercity rail passenger transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb275389-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes the timeline for undertaking and completing each of the investments and actions referred to in subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb27538a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an operating plan that describes the planned operation of the service, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb27538b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity and qualifications of the train operator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb27538c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the identity and qualifications of any other service providers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb27538d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service frequency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb27538e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the planned routes and schedules;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb27538f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the station facilities that will be utilized;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb275390-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projected ridership, revenues, and costs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb275391-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" descriptions of how the projections under subparagraph (F) were developed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb275392-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the equipment that will be utilized, how such equipment will be acquired or refurbished, and where such equipment will be maintained; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb275393-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan for ensuring safe operations and compliance with applicable safety regulations;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb275394-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a funding plan that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb275395-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the funding of initial capital costs and operating costs for the first 6 years of operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb275396-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes a commitment by the applicant to provide the funds described in subparagraph (A) to the extent not covered by Federal grants and revenues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb275397-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the funding of operating costs and capital costs, to the extent necessary, after the first 6 years of operation; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb275398-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of the status of negotiations and agreements with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb275399-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each of the railroads or regional transportation authorities whose tracks or facilities would be utilized by the service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb27539a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the anticipated railroad carrier, if such entity is not part of the applicant group; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb27539b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/c/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other service providers or entities expected to provide services or facilities that will be used by the service, including any required access to Amtrak systems, stations, and facilities if Amtrak is not part of the applicant group.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb27539c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In awarding grants under this section, the Secretary shall give priority to applications—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb27539d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which planning, design, any environmental reviews, negotiation of agreements, acquisition of equipment, construction, and other actions necessary for initiation of service have been completed or nearly completed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb27539e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that would restore service over routes formerly operated by Amtrak, including routes described in section 11304 of the Passenger Rail Reform and Investment Act of 2015;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb27539f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that would provide daily or daytime service over routes where such service did not previously exist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2753a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that include funding (including funding from railroads), or other significant participation by State, local, and regional governmental and private entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2753a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that include a funding plan that demonstrates the intercity rail passenger service will be financially sustainable beyond the 3-year grant period;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2753a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that would provide service to regions and communities that are underserved or not served by other intercity public transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2753a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/d/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that would foster economic development, particularly in rural communities and for disadvantaged populations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2753a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/d/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that would provide other non-transportation benefits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2753a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/d/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that would enhance connectivity and geographic coverage of the existing national network of intercity rail passenger service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2753a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/d/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for routes selected under the Corridor Identification and Development Program and operated by Amtrak.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2753a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb2753a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Federal operating grants authorized under this section for any individual intercity rail passenger transportation route may not provide funding for more than 6 years (including for any such routes selected for funding before the date of enactment of the Passenger Rail Expansion and Rail Safety Act of 2021) and may not be renewed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2753a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not more than 6 of the operating assistance grants awarded pursuant to subsection (b) may be simultaneously active.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2753aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum funding","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Grants described in paragraph (1) may not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb2753ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent of the projected net operating costs for the first year of service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2753ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 80 percent of the projected net operating costs for the second year of service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2753ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent of the projected net operating costs for the third year of service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2753ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/e/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 60 percent of the projected net operating costs for the fourth year of service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/e/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent of the projected net operating costs for the fifth year of service; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/e/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 30 percent of the projected net operating costs for the sixth year of service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c3b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use With Capital Grants and Other Federal Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A recipient of an operating assistance grant under subsection (b) may use that grant in combination with other Federal grants awarded that would benefit the applicable service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c3b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts appropriated for carrying out this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c3b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination With Amtrak","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary awards a grant under this section to a rail carrier other than Amtrak, Amtrak may be required consistent with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24711/c/1"},"text":"section 24711(c)(1) of this title","children":[],"tail":" to provide access to its reservation system, stations, and facilities that are directly related to operations to such carrier, to the extent necessary to carry out the purposes of this section. The Secretary may award an appropriate portion of the grant to Amtrak as compensation for this access."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c3b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb29c3b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require a grant recipient under this section to enter into a grant agreement that requires such recipient to provide similar information regarding the route performance, financial, and ridership projections, and capital and business plans that Amtrak is required to provide, and such other data and information as the Secretary considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Installments; termination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb29c3b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award grants under this section in installments, as the Secretary considers appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb29c3b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" terminate any grant agreement upon—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb29c3b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/i/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cessation of service; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb29c3ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/i/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the violation of any other term of the grant agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require each recipient of a grant under this section to comply with the grant requirements of section 22905.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb29c3bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 4 years after the date of enactment of the Passenger Rail Reform and Investment Act of 2015, the Secretary, after consultation with grant recipients under this section, shall submit to Congress a report that describes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb29c3bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the implementation of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the investments and operations funded by such grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/j/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the performance of the routes funded by such grants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/j/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the plans of grant recipients for continued operation and funding of such routes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb29c3c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22908/j/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any legislative recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb29c3c2-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11303/a"},"text":"Pub. L. 114–94, div. A, title XI, § 11303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1651"},"text":"129 Stat. 1651","children":[],"tail":", § 24408; renumbered § 22908 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/420/s7/a/1"},"text":"Pub. L. 115–420, § 7(a)(1)","children":[],"tail":", (b)(2)(E), "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5445"},"text":"132 Stat. 5445","children":[],"tail":", 5446; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22304"},"text":"Pub. L. 117–58, div. B, title II, § 22304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/719"},"text":"135 Stat. 719","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb29c3c3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb29c3c4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb29c3c5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 209 of the Passenger Rail Investment and Improvement Act of 2008, referred to in subsec. (a)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tII/s209"},"text":"section 209 of title II of div. B of Pub. L. 110–432","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s24101"},"text":"section 24101 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 11304 of the Passenger Rail Reform and Investment Act of 2015, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tIX/s11304"},"text":"section 11304 of title IX of div. A of Pub. L. 114–94","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1655"},"text":"129 Stat. 1655","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of the Passenger Rail Expansion and Rail Safety Act of 2021, referred to in subsec. (e)(1), is the date of enactment of title II of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of the Passenger Rail Reform and Investment Act of 2015, referred to in subsec. (j), is the date of enactment of title XI of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb29c3c6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22304/1"},"text":"Pub. L. 117–58, § 22304(1)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) defined applicant."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22304/2"},"text":"Pub. L. 117–58, § 22304(2)","children":[],"tail":", substituted “6 years” for “3 years” in pars. (A) and (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22304/3"},"text":"Pub. L. 117–58, § 22304(3)","children":[],"tail":", added par. (10)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22304/4/A"},"text":"Pub. L. 117–58, § 22304(4)(A)","children":[],"tail":", struck out “assistance” before “grants” and substituted “6 years (including for any such routes selected for funding before the date of enactment of the Passenger Rail Expansion and Rail Safety Act of 2021)” for “3 years”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3)(A) to (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22304/4/B"},"text":"Pub. L. 117–58, § 22304(4)(B)","children":[],"tail":", added subpars. (A) to (F) and struck out former subpars. (A) to (C) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) 80 percent of the projected net operating costs for the first year of service;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) 60 percent of the projected net operating costs for the second year of service; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(C) 40 percent of the projected net operating costs for the third year of service.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/420/s7/a/1"},"text":"Pub. L. 115–420, § 7(a)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s24408"},"text":"section 24408 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/420/s7/b/2/E/i"},"text":"Pub. L. 115–420, § 7(b)(2)(E)(i)","children":[],"tail":", substituted “22901(1)” for “24401(1)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/420/s7/b/2/E/ii"},"text":"Pub. L. 115–420, § 7(b)(2)(E)(ii)","children":[],"tail":", substituted “22905” for “24405”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb29c3c7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb29c3c8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
