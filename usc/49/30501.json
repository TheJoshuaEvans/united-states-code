{"tag":"section","attrib":{"id":"idcb571567-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501"},"text":null,"children":[{"tag":"num","attrib":{"value":"30501"},"text":"§ 30501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb571568-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “automobile” has the same meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32901/a"},"text":"section 32901(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb571569-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “certificate of title” means a document issued by a State showing ownership of an automobile.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb57156a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “insurance carrier” means an individual or entity engaged in the business of underwriting automobile insurance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb57156b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “junk automobile” means an automobile that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb57156c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incapable of operating on public streets, roads, and highways; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb57156d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has no value except as a source of parts or scrap.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb57156e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “junk yard” means an individual or entity engaged in the business of acquiring or owning junk automobiles for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb57156f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resale in their entirety or as spare parts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb571570-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rebuilding, restoration, or crushing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb571571-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “operator” means the individual or entity authorized or designated as the operator of the National Motor Vehicle Title Information System under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30502/b"},"text":"section 30502(b) of this title","children":[],"tail":", or the Attorney General, if there is no authorized or designated individual or entity."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb571572-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “salvage automobile” means an automobile that is damaged by collision, fire, flood, accident, trespass, or other event, to the extent that its fair salvage value plus the cost of repairing the automobile for legal operation on public streets, roads, and highways would be more than the fair market value of the automobile immediately before the event that caused the damage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb571573-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “salvage yard” means an individual or entity engaged in the business of acquiring or owning salvage automobiles for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb571574-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" resale in their entirety or as spare parts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb571575-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rebuilding, restoration, or crushing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb571576-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30501/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State of the United States or the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb571577-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/979"},"text":"108 Stat. 979","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/152"},"text":"Pub. L. 104–152","children":[],"tail":", §§ 2(c), 3(a), "},{"tag":"date","attrib":{"date":"1996-07-02"},"text":"July 2, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1384"},"text":"110 Stat. 1384","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s3/b"},"text":"Pub. L. 105–102, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2215"},"text":"111 Stat. 2215","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb571578-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb571579-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb57157a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30501","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2041.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/519/s201"},"text":"Pub. L. 102–519, § 201","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/3389"},"text":"106 Stat. 3389","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the word “showing” is substituted for “evidencing” to use a more commonly understood term.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), (5), and (8), the words “individual or entity” are substituted for “individual, corporation, or other entity” for clarity and consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(4) and (7), the words “public streets, roads, and highways” are substituted for “roads or highways” for clarity and consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(6), the words “National Automobile Title Information System” are substituted for “information system” for clarity. The words “no authorized or designated individual or entity” are substituted for “no such individual or entity is authorized” for clarity","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(7), the word “event” is substituted for “occurrence” for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of 15:2041(9) is omitted because the complete title of the Secretary of Transportation is used the first time the term appears in a section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb57157b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb57157c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" amended directory language of "},{"tag":"ref","attrib":{"href":"/us/pl/104/152/s2/c"},"text":"Pub. L. 104–152, § 2(c)","children":[],"tail":". See 1996 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Par. (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/152/s3/a"},"text":"Pub. L. 104–152, § 3(a)","children":[],"tail":", substituted “Attorney General” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/152/s2/c"},"text":"Pub. L. 104–152, § 2(c)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s3/b"},"text":"Pub. L. 105–102, § 3(b)","children":[],"tail":", substituted “National Motor Vehicle Title Information System” for “National Automobile Title Information System”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb57157d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb57157e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102/s3/b"},"text":"Pub. L. 105–102, § 3(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2215"},"text":"111 Stat. 2215","children":[],"tail":", provided that the amendment made by section 3(b) is effective "},{"tag":"date","attrib":{"date":"1996-07-02"},"text":"July 2, 1996","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" effective as if included in the provisions of the Act to which the amendment relates, see "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s3/f"},"text":"section 3(f) of Pub. L. 105–102","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
