{"tag":"section","attrib":{"id":"idca7e1ae8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1119"},"text":null,"children":[{"tag":"num","attrib":{"value":"1119"},"text":"§ 1119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Accident and safety data classification and publication","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca7e1ae9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1119/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of the enactment of this section, the National Transportation Safety Board shall, in consultation and coordination with the Administrator of the Federal Aviation Administration, develop a system for classifying air carrier accident data maintained by the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7e1aea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1119/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements for Classification System.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7e1aeb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1119/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The system developed under this section shall provide for the classification of accident and safety data in a manner that, in comparison to the system in effect on the date of the enactment of this section, provides for safety-related categories that provide clearer descriptions of accidents associated with air transportation, including a more refined classification of accidents which involve fatalities, injuries, or substantial damage and which are only related to the operation of an aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1aec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1119/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public comment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing a system of classification under paragraph (1), the Board shall provide adequate opportunity for public review and comment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1aed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1119/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final classification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After providing for public review and comment, and after consulting with the Administrator, the Board shall issue final classifications. The Board shall ensure that air travel accident covered under this section is classified in accordance with the final classifications issued under this section for data for calendar year 1997, and for each subsequent calendar year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1aee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1119/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall publish on a periodic basis accident and safety data in accordance with the final classifications issued under paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1aef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1119/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recommendations of the administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may, from time to time, request the Board to consider revisions (including additions to the classification system developed under this section). The Board shall respond to any request made by the Administrator under this section not later than 90 days after receiving that request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7e1af0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1119/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeals.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7e1af1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1119/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of rights","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any case in which an employee of the Board determines that an occurrence associated with the operation of an aircraft constitutes an accident, the employee shall notify the owner or operator of that aircraft of the right to appeal that determination to the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1af2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1119/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall establish and publish the procedures for appeals under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1af3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1119/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall not apply in the case of an accident that results in a loss of life.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca7e1af4-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264/tIV/s407/a/1"},"text":"Pub. L. 104–264, title IV, § 407(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3257"},"text":"110 Stat. 3257","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/168/s5"},"text":"Pub. L. 108–168, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-06"},"text":"Dec. 6, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2034"},"text":"117 Stat. 2034","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca7e1af5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca7e1af6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca7e1af7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsecs. (a) and (b)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264"},"text":"Pub. L. 104–264","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca7e1af8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/168"},"text":"Pub. L. 108–168","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca7e1af9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idca7e1afa-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided, section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", and not to be construed as affecting funds made available for a fiscal year ending before "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/s3"},"text":"section 3 of Pub. L. 104–264","children":[],"tail":", set out as an Effective Date of 1996 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca7e1afb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Multimodal Accident Database Management System","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dC/s1108"},"text":"Pub. L. 115–254, div. C, § 1108","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3433"},"text":"132 Stat. 3433","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dC/s1108"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"], the [National Transportation Safety] Board shall establish and maintain a multimodal accident database management system for Board investigators."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the system shall be to support the Board in improving—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the quality of accident data the Board makes available to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the selection of accidents for investigation and allocation of limited resources.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The system shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain a historical record of accidents that are investigated by the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be capable of the secure storage, retrieval, and management of information associated with the investigations of such accidents.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
