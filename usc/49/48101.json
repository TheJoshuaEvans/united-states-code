{"tag":"section","attrib":{"id":"idcc694936-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101"},"text":null,"children":[{"tag":"num","attrib":{"value":"48101"},"text":"§ 48101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air navigation facilities and equipment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc694937-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not more than a total of the following amounts may be appropriated to the Secretary of Transportation out of the Airport and Airway Trust Fund established under section 9502 of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9502"},"text":"26 U.S.C. 9502","children":[],"tail":") to acquire, establish, and improve air navigation facilities under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44502/a/1/A"},"text":"section 44502(a)(1)(A) of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc694938-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,191,250,000 for fiscal year 2024.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694939-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,575,000,000 for fiscal year 2025.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc69493a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,625,000,000 for fiscal year 2026.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc69493b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,675,000,000 for fiscal year 2027.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc69493c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $3,725,000,000 for fiscal year 2028.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc69493d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts appropriated under this section remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc69493e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Expenditures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the amounts appropriated under subsection (a), such sums as may be necessary may be used for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc69493f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The implementation and use of upgrades to the current automated surface observation system/automated weather observing system, if the upgrade is successfully demonstrated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694940-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The acquisition and construction of remote towers (as defined in section 161 of the FAA Reauthorization Act of 2018).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694941-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The remediation and elimination of identified cybersecurity vulnerabilities in the air traffic control system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694942-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The construction of facilities dedicated to improving the cybersecurity of the National Airspace System.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694943-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Systems associated with the Data Communications program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694944-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The infrastructure, sustainment, and the elimination of the deferred maintenance backlog of air navigation facilities and other facilities for which the Federal Aviation Administration is responsible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694945-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The modernization and digitization of the Civil Aviation Registry.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694946-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The construction of necessary Priority 1 National Airspace System facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694947-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Cost-beneficial construction, rehabilitation, or retrofitting programs designed to reduce Federal Aviation Administration facility operating costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc694948-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s48101/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Life-Cycle Cost Estimates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Federal Aviation Administration shall establish life-cycle cost estimates for any air traffic control modernization project the total life-cycle costs of which equal or exceed $50,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc694949-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1294"},"text":"108 Stat. 1294","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/305/tI/s102/a"},"text":"Pub. L. 103–305, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1571"},"text":"108 Stat. 1571","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/tI/s102/a"},"text":"Pub. L. 104–264, title I, § 102(a)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3216"},"text":"110 Stat. 3216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/6/s3"},"text":"Pub. L. 106–6, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-03-31"},"text":"Mar. 31, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/10"},"text":"113 Stat. 10","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tI/s102"},"text":"Pub. L. 106–181, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{