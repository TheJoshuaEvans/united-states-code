{"tag":"section","attrib":{"id":"idcc0c34ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742"},"text":null,"children":[{"tag":"num","attrib":{"value":"44742"},"text":"§ 44742.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interference with the duties of organization designation authorization unit members","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc0c34cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Federal Aviation Administration shall continuously seek to eliminate or minimize interference by an ODA holder that affects the performance of authorized functions by ODA unit members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c34d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c34d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be unlawful for any individual who is a supervisory employee of an ODA holder that manufactures a transport category airplane to commit an act of interference with an ODA unit member’s performance of authorized functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c34d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil penalty.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c34d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Individuals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual shall be subject to a civil penalty under section 46301(a)(1) for each violation under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c34d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this paragraph shall be construed as limiting or constricting any other authority of the Administrator to pursue an enforcement action against an individual or organization for violation of applicable Federal laws or regulations of the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c34d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c34d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to oda holder","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An ODA unit member of an ODA holder that manufactures a transport category airplane shall promptly report any instances of interference to the office of the ODA holder that is designated to receive such reports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c34d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to the faa.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c34d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The ODA holder office described in paragraph (1) shall investigate reports and submit to the office of the Administration designated by the Administrator to accept and review such reports any instances of interference reported under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c34d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall prescribe parameters for the submission of reports to the Administration under this paragraph, including the manner, time, and form of submission. Such report shall include the results of any investigation conducted by the ODA holder in response to a report of interference, a description of any action taken by the ODA holder as a result of the report of interference, and any other information or potentially mitigating factors the ODA holder or the Administrator deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc0c34da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc0c34db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The definitions contained in section 44736(c) shall apply to this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc0c34dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interference","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “interference” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc0c34dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" blatant or egregious statements or behavior, such as harassment, beratement, or threats, that a reasonable person would conclude was intended to improperly influence or prejudice an ODA unit member’s performance of his or her duties; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc0c34de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44742/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the presence of non-ODA unit duties or activities that conflict with the performance of authorized functions by ODA unit members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc0c34df-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dV/tI/s107/a"},"text":"Pub. L. 116–260, div. V, title I, § 107(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2323"},"text":"134 Stat. 2323","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
