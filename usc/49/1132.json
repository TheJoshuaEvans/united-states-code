{"tag":"section","attrib":{"id":"idca80641e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1132"},"text":null,"children":[{"tag":"num","attrib":{"value":"1132"},"text":"§ 1132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil aircraft accident investigations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca80641f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca806420-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1132/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The National Transportation Safety Board shall investigate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca806421-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1132/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each accident involving civil aircraft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca806422-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1132/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with the participation of appropriate military authorities, each accident involving both military and civil aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca806423-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1132/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person employed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s1113/b/1"},"text":"section 1113(b)(1) of this title","children":[],"tail":" that is conducting an investigation or hearing about an aircraft accident has the same authority to conduct the investigation or hearing as the Board."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca806424-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification and Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall prescribe regulations governing the notification and reporting of accidents involving civil aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca806425-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1132/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation of Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall provide for the participation of the Secretary of Transportation in the investigation of an aircraft accident under this chapter when participation is necessary to carry out the duties and powers of the Secretary. However, the Secretary may not participate in establishing probable cause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca806426-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1132/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accidents Involving Only Military Aircraft","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an accident involves only military aircraft and a duty of the Secretary is or may be involved, the military authorities shall provide for the participation of the Secretary. In any other accident involving only military aircraft, the military authorities shall give the Board or Secretary information the military authorities decide would contribute to the promotion of air safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca806427-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/753"},"text":"108 Stat. 753","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca806428-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca806429-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca80642a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:t