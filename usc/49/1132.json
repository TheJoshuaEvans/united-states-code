tat/96/2444"},"text":"96 Stat. 2444","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(d) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1903(a)(1)(A).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1132(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1442(b), (c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1), (d) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1903(a)(1)(A).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(A), the words “and report the facts, conditions, and circumstances related to each accident and the probable cause thereof” in 49 App.:1441(a)(2) are omitted as unnecessary because of section 1131(d) of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(B), the words “provide for” in 49 App.:1442(a) are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “any member of the National Transportation Safety Board or any officer or employee of the National Transportation Safety Board” in 49 App.:1441(c) are omitted as unnecessary because of sections 1113 and 1134 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (c) and (d), the words “Secretary of Transportation” and “Secretary” are substituted for “Administrator” in sections 701(g) and 702(b) and (c) of the Federal Aviation Act of 1958 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/782"},"text":"72 Stat. 782","children":[],"tail":") for consistency. Section 6(c)(1) of the Department of Transportation Act ("},{"tag":"ref","attrib":{"href":"/us/pl/89/670"},"text":"Public Law 89–670","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/938"},"text":"80 Stat. 938","children":[],"tail":") transferred all duties and powers of the Federal Aviation Agency and the Administrator to the Secretary of Transportation. However, the Secretary was to carry out certain provisions through the Administrator. In addition, various laws enacted since then have vested duties and powers in the Administrator. All provisions of law the Secretary is required to carry out through the Administrator are included in 49:106(g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “and his representatives” in 49 App.:1441(g) are omitted because of 49:322(b). The words “when participation is necessary to carry out the duties and powers” are substituted for “In order to assure the proper discharge . . . of his duties and responsibilities” to eliminate unnecessary words. The words “or his representatives” are omitted because of 49:322(b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
