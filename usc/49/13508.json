{"tag":"section","attrib":{"id":"idcaf2d642-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508"},"text":null,"children":[{"tag":"num","attrib":{"value":"13508"},"text":"§ 13508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limited authority over cooperative associations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf2d643-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding section 13506(a)(5), any cooperative association (as defined by section 15(a) of the Agricultural Marketing Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t12/s1141j/a"},"text":"12 U.S.C. 1141j(a)","children":[],"tail":")) or a federation of cooperative associations shall prepare and maintain such records relating to transportation provided by such association or federation, in such form as the Secretary or the Board may require by regulation to carry out the provisions of such section 13506(a)(5). The Secretary or the Board, or an employee designated by the Secretary or the Board, may on demand and display of proper credentials—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d644-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspect and examine the lands, buildings, and equipment of such association or federation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d645-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspect and copy any record of such association or federation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d646-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 13506(a)(5), the Secretary or the Board may require a cooperative association or federation of cooperative associations described in subsection (a) of this section to file reports with the Secretary or the Board containing answers to questions about transportation provided by such association or federation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d647-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary or the Board may bring a civil action to enforce subsections (a) and (b) of this section or a regulation or order of the Secretary or the Board issued under this section, when violated by a cooperative association or federation of cooperative associations described in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d648-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Penalties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d649-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person required to make a report to the Secretary or the Board, answer a question, or maintain a record under this section, or an officer, agent, or employee of that person, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf2d64a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not make the report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d64b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not specifically, completely, and truthfully answer the question; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d64c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not maintain the record in the form and manner prescribed under this section;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is liable to the United States for a civil penalty of not more than $500 for each violation and for not more than $250 for each additional day the violation continues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d64d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Trial in a civil action under paragraph (1) shall be in the judicial district in which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf2d64e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cooperative association or federation of cooperative associations has its principal office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d64f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the violation occurred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d650-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the offender is found.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Process in the action may be served in the judicial district of which the offender is an inhabitant or in which the offender may be found.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d651-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evasion Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person, or an officer, employee, or agent of that person, that by any means knowingly and willfully tries to evade compliance with the provisions of this section shall be fined at least $200 but not more than $500 for the first violation and at least $250 but not more than $2,000 for a subsequent violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d652-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recordkeeping Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person required to make a report, answer a question, or maintain a record under this section, or an officer, agent, or employee of that person, that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d653-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully does not make that report;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d654-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully does not specifically, completely, and truthfully answer that question in 30 days from the date that the question is required to be answered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d655-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully does not maintain that record in the form and manner prescribed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d656-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully falsifies, destroys, mutilates, or changes that report or record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d657-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/f/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully files a false report or record under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d658-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/f/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully makes a false or incomplete entry in that record about a business-related fact or transaction; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d659-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13508/f/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully maintains a record in violation of a regulation or order issued under this section;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined not more than $5,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf2d65a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/863"},"text":"109 Stat. 863","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf2d65b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf2d65c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf2d65d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10529"},"text":"section 10529 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaf2d65e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcaf2d65f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
