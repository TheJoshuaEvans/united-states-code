":"ref","attrib":{"href":"/us/pl/105/206/s9009/d"},"text":"Pub. L. 105–206, § 9009(d)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1)(A) In consultation with the State, the metropolitan planning organization designated for a transportation management area shall select the projects to be carried out in the area with United States Government participation under this chapter or title 23, except projects of the National Highway System or under the Bridge and Interstate Maintenance programs.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) In cooperation with the metropolitan planning organization designated for a transportation management area, the State shall select the projects to be carried out in the area of the National Highway System or under the Bridge and Interstate Maintenance programs.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s3006/e/1"},"text":"Pub. L. 105–178, § 3006(e)(1)","children":[],"tail":", added par. (2) and struck out former par. (2) which read as follows: “If the Secretary does not certify before "},{"tag":"date","attrib":{"date":"1993-10-01"},"text":"October 1, 1993","children":[],"tail":", that a metropolitan planning organization is carrying out its responsibilities, the Secretary may withhold any part of the apportionment under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s104/b/3"},"text":"section 104(b)(3) of title 23","children":[],"tail":" attributed to the relevant metropolitan area under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s133/d/3"},"text":"section 133(d)(3) of title 23","children":[],"tail":" and capital amounts apportioned under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5336"},"text":"section 5336 of this title","children":[],"tail":". If an organization remains uncertified for more than 2 consecutive years after "},{"tag":"date","attrib":{"date":"1994-09-30"},"text":"September 30, 1994","children":[],"tail":", 20 percent of that apportionment and capital amounts shall be withheld. The withheld apportionments shall be restored when the Secretary certifies the organization.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s3006/e/2"},"text":"Pub. L. 105–178, § 3006(e)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s3006/f"},"text":"Pub. L. 105–178, § 3006(f)","children":[],"tail":", added subsec. (h)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaa1cf10-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcaa1cf11-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective and Termination Dates of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s20030/a"},"text":"section 20030(a) of Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dG/tIV/s114001"},"text":"Pub. L. 112–141, div