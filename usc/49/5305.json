{"tag":"section","attrib":{"id":"idcaa1ced9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305"},"text":null,"children":[{"tag":"num","attrib":{"value":"5305"},"text":"§ 5305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Planning programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaa1ceda-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “State” means a State of the United States, the District of Columbia, and Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaa1cedb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaa1cedc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants and agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Under criteria established by the Secretary, the Secretary may award grants to States, authorities of the States, metropolitan planning organizations, and local governmental authorities, and make agreements with other departments, agencies, or instrumentalities of the Government to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaa1cedd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop transportation plans and programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaa1cede-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plan, engineer, design, and evaluate a public transportation project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaa1cedf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct technical studies relating to public transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaa1cee0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Activities eligible under paragraph (1) include the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaa1cee1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Studies related to management, planning, operations, capital requirements, and economic feasibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaa1cee2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluating previously financed projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaa1cee3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Peer reviews and exchanges of technical data, information, assistance, and related activities in support of planning and environmental analyses among metropolitan planning organizations and other transportation planners.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaa1cee4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other similar and related activities preliminary to and in preparation for constructing, acquiring, or improving the operation of facilities and equipment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaa1cee5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purpose","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent practicable, the Secretary shall ensure that amounts appropriated or made available under section 5338 to carry out this section and sections 5303, 5304, and 5306 are used to support balanced and comprehensive transportation planning that considers the relationships among land use and all transportation modes, without regard to the programmatic source of the planning amounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaa1cee6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Metropolitan Planning Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaa1cee7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Apportionment to states.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaa1cee8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall apportion 80 percent of the amounts made available under subsection (g)(1) among the States to carry out sections 5303 and 5306 in the ratio that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcaa1cee9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population of urbanized areas in each State, as shown by the latest available decennial census of population; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaa1ceea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total population of urbanized areas in all States, as shown by that census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaa1ceeb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum apportionment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subparagraph (A), a State may not receive less than 0.5 percent of the amount apportioned under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaa1ceec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation to mpo’s","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts apportioned to a State under paragraph (1) shall be made available, not later than 30 days after the date of apportionment, to metropolitan planning organizations in the State designated under this section under a formula that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaa1ceed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considers population of urbanized areas;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaa1ceee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an appropriate distribution for urbanized areas to carry out the cooperative processes described in this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaa1ceef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State develops in cooperation with the metropolitan planning organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaa1cef0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary approves.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaa1cef1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplemental amounts.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaa1cef2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall apportion 20 percent of the amounts made available under subsection (g)(1) among the States to supplement allocations made under paragraph (1) for metropolitan planning organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaa1cef3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Formula","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall apportion amounts referred to in subparagraph (A) under a formula that reflects the additional cost of carrying out planning, programming, and project selection responsibilities under sections 5303 and 5306 in certain urbanized areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaa1cef4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Planning and Research Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaa1cef5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Apportionment to states.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaa1cef6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall apportion the amounts made available under subsection (g)(2) among the States for grants and contracts to carry out this section and sections 5304 and 5306 in the ratio that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcaa1cef7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population of urbanized areas in each State, as shown by the latest available decennial census; bears to","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaa1cef8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the population of urbanized areas in all States, as shown by that census.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaa1cef9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum apportionment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subparagraph (A), a State may not receive less than 0.5 percent of the amount apportioned under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaa1cefa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supplemental amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State, as the State considers appropriate, may authorize part of the amount made available under this subsection to be used to supplement amounts made available under subsection (d).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaa1cefb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Government Share of Costs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaa1cefc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in paragraph (2), the Government share of the cost of an activity funded using amounts made available under this section may not exceed 80 percent of the cost of the activity unless the Secretary determines that it is in the interests of the Government—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaa1cefd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not to require a State or local match; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaa1cefe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow a Government share greater than 80 percent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaa1ceff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain activities.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaa1cf00-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Government share of the cost of an activity funded using amounts made available under this section shall be not less than 90 percent for an activity that assists parts of an urbanized area or rural area with lower population density or lower average income levels compared to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcaa1cf01-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/f/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable urbanized area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaa1cf02-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/f/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the applicable rural area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaa1cf03-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/f/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an adjoining urbanized area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaa1cf04-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/f/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an adjoining rural area.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaa1cf05-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State or metropolitan planning organization that carries out an activity described in subparagraph (A) with an increased Government share described in that subparagraph shall report to the Secretary, in a form as determined by the Secretary, how the increased Government share for transportation planning activities benefits commuting and other essential travel in parts of the applicable urbanized area or rural area described in subparagraph (A) with lower population density or lower average income levels.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaa1cf06-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allocation of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Of the funds made available by or appropriated to carry out this section under section 5338(a)(2)(A) for a fiscal year—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaa1cf07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 82.72 percent shall be available for the metropolitan planning program under subsection (d); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaa1cf08-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 17.28 percent shall be available to carry out subsection (e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaa1cf09-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5305/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds apportioned under this section to a State that have not been obligated in the 3-year period beginning after the last day of the fiscal year for which the funds are authorized shall be reapportioned among the States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaa1cf0a-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/794"},"text":"108 Stat. 794","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIII/s3006"},"text":"Pub. L. 105–178, title III, § 3006","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/346"},"text":"112 Stat. 346","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/206/tIX/s9009/d"},"text":"Pub. L. 105–206, title IX, § 9009(d)","children":[]