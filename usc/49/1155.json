t. 1740","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(d) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1903(a)(1)(A).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1155(a)(5)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1473(b)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s903/b/1"},"text":"Pub. L. 85–726, § 903(b)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/786"},"text":"72 Stat. 786","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/504/s36"},"text":"Pub. L. 95–504, § 36","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1741"},"text":"92 Stat. 1741","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1473(b)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s903/b/4"},"text":"Pub. L. 85–726, § 903(b)(4)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/787"},"text":"72 Stat. 787","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(d) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1903(a)(1)(A).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1155(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1472(p).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 902(p); added "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1962","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/810/s4"},"text":"Pub. L. 87–810, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/76/921"},"text":"76 Stat. 921","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 5, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/366/s103/b"},"text":"Pub. L. 93–366, § 103(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/410"},"text":"88 Stat. 410","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/223/s204/e"},"text":"Pub. L. 100–223, § 204(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1520"},"text":"101 Stat. 1520","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “section 1132 or 1134(b) or (f)(1) (related to an aircraft accident) of this title” are substituted for “any provision of subchapter . . . VII . . . of this chapter” in 49 App.:1471(a)(1) because those sections restate the relevant source provisions of 49 App.:ch. 20 carried out by the Board. The words “regulation prescribed or order issued under either of those sections” are substituted for “rule, regulation, or order issued thereunder” for clarity and consistency in the revised title and with other titles of the United States Code and because “rule” and “regulation” are synonymous. The words “liable to the United States Government” are substituted for “subject to” for clarity. The words “for each such violation” are omitted as unnecessary because of 18:1.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the word “civilian” is omitted as unnecessary. The words “with respect thereto” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(4), the words “imposed or compromised” are substituted for “finally determined or fixed by order of the Board, or the amount agreed upon in compromise” in 49 App.:1471(a)(2) for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(5), the words “imposed or assessed” are omitted as surplus. The words “civil action against the person” are substituted for “proceedings in personam against the person” in 49 App.:1473(b)(1) for consistency with rule 2 of the Federal Rules of Civil Procedure (28 App. U.S.C.) and to eliminate unnecessary words. The text of 49 App.:1473(b)(1) (1st sentence words after 1st comma and last sentence) is omitted as unnecessary because penalties imposed by the National Transportation Safety Board do not involve liens on aircraft. The text of 49 App.:1473(b)(4) is omitted as unnecessary because of 28:ch. 131.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca854658-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca854659-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Uniform Code of Military Justice, referred to in subsec. (a)(2), is classified generally to chapter 47 (§ 801 et seq.) of Title 10, Armed Forces.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idca85465a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior chapter 31 (§§ 3101–3104) of subtitle II redesignated and restated as chapter 315 (§§ 31501–31504) of subtitle VI of this title by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/c"},"text":"Pub. L. 103–272, § 1(c)","children":[],"tail":", (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca85465b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s1216/a/1"},"text":"Pub. L. 118–63, § 1216(a)(1)","children":[],"tail":", substituted “Penalties” for “Aviation penalties” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s1216/a/2"},"text":"Pub. L. 118–63, § 1216(a)(2)","children":[],"tail":", substituted “section 1136(g), or section 1139(g)” for “or section 1136(g) (related to an aircraft accident)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264"},"text":"Pub. L. 104–264","children":[],"tail":" substituted “, section 1134(b), section 1134(f)(1), or section 1136(g)” for “or 1134(b) or (f)(1)” and “any of” for “either of”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca85465c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca85465d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264"},"text":"Pub. L. 104–264","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", and not to be construed as affecting funds made available for a fiscal year ending before "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/s3"},"text":"section 3 of Pub. L. 104–264","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
