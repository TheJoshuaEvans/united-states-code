g":"html:a","attrib":{"href":"/us/pl/97/331/s3"},"text":"Pub. L. 97–331, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1619"},"text":"96 Stat. 1619","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30103(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1405.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30103(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1394(a)(6).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1410a(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563"},"text":"Pub. L. 89–563","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/718"},"text":"80 Stat. 718","children":[],"tail":", §§ 124(e), 160; added "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/492"},"text":"Pub. L. 93–492","children":[],"tail":", §§ 102(a), 106, "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1477"},"text":"88 Stat. 1477","children":[],"tail":", 1481."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1420.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30103(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(k).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563/s108/k"},"text":"Pub. L. 89–563, § 108(k)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/723"},"text":"80 Stat. 723","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/562/s2/b"},"text":"Pub. L. 100–562, § 2(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2818"},"text":"102 Stat. 2818","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “or the Transportation of Explosives Act, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s831–835"},"text":"18 U.S.C. 831–835","children":[],"tail":")” are omitted as obsolete because 18:831–835 have been repealed. The word “prescribe” is substituted for “adopt” for consistency. The words “or continue in effect” and “In prescribing safety regulations” are omitted as surplus. The word “prescribed” is substituted for “issued” for consistency. The words “to comply” and “Federal” are omitted as surplus. The words “in effect” are added for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the word “Federal” is omitted as surplus. The word “prescribe” is substituted for “either to establish, or to continue in effect” for consistency and to eliminate unnecessary words. The words “standard prescribed under this chapter” are substituted for “Federal standard” for clarity. The words “However, the United States . . . may prescribe” are substituted for “Nothing in this section shall be construed to prevent the Federal . . . from establishing” for consistency. The words “of a State” are substituted for “thereof” for clarity. The word “standard” is substituted for “safety requirement” for consistency. The words “performance requirement” are substituted for “standard of performance” to avoid using “standard” in 2 different ways.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(2) is substituted for 15:1392(d) (2d sentence) for consistency and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “be deemed to” and “of the United States” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “United States” are substituted for “Federal” in 15:1420 for consistency. The words “Consumer” in 15:1420, “not in lieu of” in 15:1410a(e) and 1420, and “not in substitution for” in 15:1394(a)(6) are omitted as surplus. The word “other” is added for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb4402c8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb4402c9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1995—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" substituted “subchapter I of chapter 135” for “subchapter II of chapter 105” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb4402ca-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb4402cb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
