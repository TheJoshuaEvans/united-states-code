{"tag":"section","attrib":{"id":"idcc7c5c79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114"},"text":null,"children":[{"tag":"num","attrib":{"value":"60114"},"text":"§ 60114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" One-call notification systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc7c5c7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall prescribe regulations providing minimum requirements for establishing and operating a one-call notification system for a State to adopt that will notify an operator of a pipeline facility of activity in the vicinity of the facility that could threaten the safety of the facility. The regulations shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc7c5c7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that the system apply to all areas of the State containing underground pipeline facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that a person, including a government employee or contractor, intending to engage in an activity the Secretary decides could cause physical damage to an underground facility must contact the appropriate system to establish if there are underground facilities present in the area of the intended activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that all operators of underground pipeline facilities participate in an appropriate one-call notification system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifications for an operator of a facility, a private contractor, or a State or local authority to operate a system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c7f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for advertisement and notice of the availability of a system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c80-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement about the information to be provided by a person contacting the system under clause (2) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c81-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement for the response of the operator of the system and of the facility after they are contacted by an individual under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement that each State decide whether the system will be toll free.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a requirement for sanctions substantially the same as provided under sections 60120 and 60122 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Marking Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On notification by an operator of a damage prevention program or by a person planning to carry out demolition, excavation, tunneling, or construction in the vicinity of a pipeline facility, the operator of the facility shall mark accurately, in a reasonable and timely way, the location of the pipeline facilities in the vicinity of the demolition, excavation, tunneling, or construction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section and regulations prescribed under this section do not affect the liability established under a law of the United States or a State for damage caused by an activity described in subsection (a)(2) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition Applicable to Excavators","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person who engages in demolition, excavation, tunneling, or construction—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc7c5c87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not engage in a demolition, excavation, tunneling, or construction activity in a State that has adopted a one-call notification system without first using that system to establish the location of underground facilities in the demolition, excavation, tunneling, or construction area;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not engage in such demolition, excavation, tunneling, or construction activity in disregard of location information or markings established by a pipeline facility operator pursuant to subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" and who causes damage to a pipeline facility that may endanger life or cause serious bodily harm or damage to property—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc7c5c8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not fail to promptly report the damage to the owner or operator of the facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc7c5c8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the damage results in the escape of any flammable, toxic, or corrosive gas or liquid, may not fail to promptly report to other appropriate authorities by calling the 911 emergency telephone number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition Applicable to Underground Pipeline Facility Owners and Operators","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any owner or operator of a pipeline facility who fails to respond to a location request in order to prevent damage to the pipeline facility or who fails to take reasonable steps, in response to such a request, to ensure accurate marking of the location of the pipeline facility in order to prevent damage to the pipeline facility shall be subject to a civil action under section 60120 or assessment of a civil penalty under section 60122.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not conduct an enforcement proceeding under subsection (d) for a violation within the boundaries of a State that has the authority to impose penalties described in section 60134(b)(7) against persons who violate that State’s damage prevention laws, unless the Secretary has determined that the State’s enforcement is inadequate to protect safety, consistent with this chapter, and until the Secretary issues, through a rulemaking proceeding, the procedures for determining inadequate State enforcement of penalties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60114/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technology Development Grants","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make grants to any organization or entity (not including for-profit entities) for the development of technologies that will facilitate the prevention of pipeline damage caused by demolition, excavation, tunneling, or construction activities, with emphasis on wireless and global positioning technologies having potential for use in connection with notification systems and underground facility locating and marking services. Funds provided under this subsection may not be used for lobbying or in direct support of litigation. The Secretary may also support such technology development through cooperative agreements with trade associations, academic institutions, and other organizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc7ecc8f-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1318"},"text":"108 Stat. 1318","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/91"},"text":"Pub. L. 104–287, § 5(91)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3398"},"text":"110 Stat. 3398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/304/s20/d"},"text":"Pub. L. 104–304, § 20(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3804"},"text":"110 Stat. 3804","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/355"},"text":"Pub. L. 107–355","children":[],"tail":", §§ 3(b), 21(2), "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2986"},"text":"116 Stat. 2986","children":[],"tail":", 3010; "},{"tag":"ref","attrib":{"href":"/us/pl/109/468/s2/a/1"},"text":"Pub. L. 109–468, § 2(a)(1)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3486"},"text":"120 Stat. 3486","children":[],"tail":", 3489.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc7ecc90-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc7ecc91-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc7ecc92-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60114(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1687(b), (e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/481"},"text":"Pub. L. 90–481","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/720"},"text":"82 Stat. 720","children":[],"tail":", § 20(a)–(e); added "},{"tag":"html:span","attrib":{},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/561/s303/a"},"text":"Pub. L. 100–561, § 303(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2814"},"text":"102 Stat. 2814","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60114(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1687(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60114(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1687(h).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/481"},"text":"Pub. L. 90–481","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/720"},"text":"82 Stat. 720","children":[],"tail":", § 20(h); added "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/508/s304/a"},"text":"Pub. L. 102–508, § 304(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/3308"},"text":"106 Stat. 3308","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60114(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1687(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60114(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1687(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “Not later than 18 months after ","children":[{"tag":"date","attrib":{"date":"1988-10-31"},"text":"October 31, 1988","children":[],"tail":"” are omitted as obsolete. The words “as described in subsection (a)” are omitted as surplus. In clause (1), the words “or systems” are omitted because of 1:1. In clause (8), the words “or not” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “all of the requirements established under” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “contractor, excavator, or other” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), before clause (1), the words “When apportioning the amount appropriated to carry out” are substituted for “In making allocations under” for consistency with section 60107 of the revised title. In clause (2), the words “shall withhold part of a payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s60107"},"text":"section 60107 of this title","children":[],"tail":"” are substituted for “such State may not receive the full reimbursement under such sections to which it would otherwise be entitled” for clarity and consistency."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc7ecc93-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:60114(a)(9) to clarify the restatement of 49 App.:1687(b) by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1994-07-05/s1"},"text":"section 1 of the Act of July 5, 1994","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Public Law 103–272","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1319"},"text":"108 Stat. 1319","children":[],"tail":"), because the requirement for substantially the same sanctions was not intended to include criminal penalties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc7ecc94-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc7ecc95-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsecs. (d) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/468"},"text":"Pub. L. 109–468","children":[],"tail":" added subsecs. (d) to (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s3/b"},"text":"Pub. L. 107–355, § 3(b)","children":[],"tail":", inserted “, including a government employee or contractor,” after “person”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s21/2"},"text":"Pub. L. 107–355, § 21(2)","children":[],"tail":", redesignated subsec. (d) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(9). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/pl/104/304/s20/d/1"},"text":"Pub. L. 104–304, § 20(d)(1)","children":[],"tail":", amended par. (9) identically, substituting “60120 and 60122” for “60120, 60122, and 60123”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s20/d/2"},"text":"Pub. L. 104–304, § 20(d)(2)","children":[],"tail":", (3), redesignated subsec. (c) as (b) and struck out former subsec. (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Grants","children":[],"tail":".—The Secretary may make a grant to a State under this section to develop and establish a one-call notification system consistent with subsection (a) of this section.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s20/d/3"},"text":"Pub. L. 104–304, § 20(d)(3)","children":[],"tail":", redesignated subsec. (c) as (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s20/d/2"},"text":"Pub. L. 104–304, § 20(d)(2)","children":[],"tail":", (3), redesignated subsec. (e) as (d) and struck out former subsec. (d) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(d) ","children":[{"tag":"inline","attrib":{},"text":"Apportionment","children":[],"tail":".—When apportioning the amount appropriated to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s60107"},"text":"section 60107 of this title","children":[],"tail":" among the States, the Secretary—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) shall consider whether a State has adopted or is seeking adoption of a one-call notification system under this section; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) shall withhold part of a payment under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s60107"},"text":"section 60107 of this title","children":[],"tail":" when the Secretary decides a State has not adopted, or is not seeking adoption of, a one-call notification system.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc7ecc96-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc7ecc97-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s8/1"},"text":"section 8(1) of Pub. L. 104–287","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5303"},"text":"section 5303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc7ecc98-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Nationwide Toll-Free Number System","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s17"},"text":"Pub. L. 107–355, § 17","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/3008"},"text":"116 Stat. 3008","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/355/s17"},"text":"“Within 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":"], the Secretary of Transportation shall, in conjunction with the Federal Communications Commission, facility operators, excavators, and one-call notification system operators, provide for the establishment of a 3-digit nationwide toll-free telephone number system to be used by State one-call notification systems.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
