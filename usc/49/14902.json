{"tag":"section","attrib":{"id":"idcb05e8d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14902"},"text":null,"children":[{"tag":"num","attrib":{"value":"14902"},"text":"§ 14902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty for accepting rebates from carrier","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb05e8d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14902/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delivering property to a carrier providing transportation or service subject to jurisdiction under chapter 135 for transportation under this part or for whom that carrier will transport the property as consignor or consignee for that person from a State or territory or possession of the United States to another State or possession, territory, or to a foreign country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb05e8d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14902/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly accepting or receiving by any means a rebate or offset against the rate for transportation for, or service of, that property contained in a tariff required under section 13702;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"is liable to the United States for a civil penalty in an amount equal to 3 times the amount of money that person accepted or received as a rebate or offset and 3 times the value of other consideration accepted or received as a rebate or offset. In a civil action under this section, all money or other consideration received by the person during a period of 6 years before an action is brought under this section may be included in determining the amount of the penalty, and if that total amount is included, the penalty shall be 3 times that total amount.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb05e8d6-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/915"},"text":"109 Stat. 915","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb05e8d7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb05e8d8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb05e8d9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11902"},"text":"section 11902 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb05e8da-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb05e8db-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
