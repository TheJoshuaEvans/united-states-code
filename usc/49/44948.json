{"tag":"section","attrib":{"id":"idcc34cc01-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44948"},"text":null,"children":[{"tag":"num","attrib":{"value":"44948"},"text":"§ 44948.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Deployment Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc34cc02-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44948/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established within the Transportation Security Administration a National Deployment Office, to be headed by an individual with supervisory experience. Such individual shall be designated by the Administrator of the Transportation Security Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc34cc03-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44948/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The individual designated as the head of the National Deployment Office shall be responsible for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc34cc04-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44948/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Maintaining a National Deployment Force within the Transportation Security Administration, including transportation security officers, supervisory transportation security officers and lead transportation security officers, to provide the Administration with rapid and efficient response capabilities and augment the Department of Homeland Security’s homeland security operations to mitigate and reduce risk, including for the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc34cc05-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44948/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Airports temporarily requiring additional security personnel due to an emergency, seasonal demands, hiring shortfalls, severe weather conditions, passenger volume mitigation, equipment support, or other reasons.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cc06-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44948/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Special events requiring enhanced security including National Special Security Events, as determined by the Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cc07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44948/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Response in the aftermath of any manmade disaster, including any terrorist attack.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cc08-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44948/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Other such situations, as determined by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cc09-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44948/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Educating transportation security officers regarding how to participate in the Administration’s National Deployment Force.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cc0a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44948/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recruiting officers to serve on the National Deployment Force, in accordance with a staffing model to be developed by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cc0b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44948/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Approving 1-year appointments for officers to serve on the National Deployment Force, with an option to extend upon officer request and with the approval of the appropriate Federal Security Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cc0c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44948/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Training officers to serve on the National Deployment Force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc34cc0d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1988/a"},"text":"Pub. L. 115–254, div. K, title I, § 1988(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3622"},"text":"132 Stat. 3622","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc34cc0e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc34cc0f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc34cc10-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Career Development","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1988/d"},"text":"Pub. L. 115–254, div. K, title I, § 1988(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3623"},"text":"132 Stat. 3623","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dK/tI/s1988/d"},"text":"“The Administrator [of the Transportation Security Administration] may consider service in the National Deployment Force as a positive factor when evaluating applicants for promotion opportunities within the TSA [Transportation Security Administration].”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
