{"tag":"section","attrib":{"id":"idcb81f637-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706"},"text":null,"children":[{"tag":"num","attrib":{"value":"32706"},"text":"§ 32706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspections, investigations, and records","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb81f638-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Inspect and Investigate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32707"},"text":"section 32707 of this title","children":[],"tail":", the Secretary of Transportation may conduct an inspection or investigation necessary to carry out this chapter or a regulation prescribed or order issued under this chapter. The Secretary shall cooperate with State and local officials to the greatest extent possible in conducting an inspection or investigation. The Secretary may give the Attorney General information about a violation of this chapter or a regulation prescribed or order issued under this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb81f639-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entry, Inspection, and Impoundment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb81f63a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out subsection (a) of this section, an officer or employee designated by the Secretary, on display of proper credentials and written notice to the owner, operator, or agent in charge, may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb81f63b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter and inspect commercial premises in which a motor vehicle or motor vehicle equipment is manufactured, held for shipment or sale, maintained, or repaired;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb81f63c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter and inspect noncommercial premises in which the Secretary reasonably believes there is a motor vehicle or motor vehicle equipment that is an object of a violation of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb81f63d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspect that motor vehicle or motor vehicle equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb81f63e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impound for not more than 72 hours for inspection a motor vehicle or motor vehicle equipment that the Secretary reasonably believes is an object of a violation of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb81f63f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An inspection or impoundment under this subsection shall be conducted at a reasonable time, in a reasonable way, and with reasonable promptness. The written notice may consist of a warrant issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32707"},"text":"section 32707 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb81f640-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reasonable Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Secretary impounds for inspection a motor vehicle (except a vehicle subject to subchapter I of chapter 135 of this title) or motor vehicle equipment under subsection (b)(1)(D) of this section, the Secretary shall pay reasonable compensation to the owner of the vehicle or equipment if the inspection or impoundment results in denial of use, or reduction in value, of the vehicle or equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb81f641-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records and Information Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb81f642-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To enable the Secretary to decide whether a dealer or distributor is complying with this chapter and regulations prescribed and orders issued under this chapter, the Secretary may require the dealer or distributor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb81f643-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to keep records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb81f644-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide information from those records if the Secretary states the purpose for requiring the information and identifies the information to the fullest extent practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb81f645-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow an officer or employee designated by the Secretary to inspect relevant records of the dealer or distributor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb81f646-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection and subsection (e)(1)(B) of this section do not authorize the Secretary to require a dealer or distributor to provide information on a regular periodic basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb81f647-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Authority and Civil Actions To Enforce","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb81f648-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out this chapter, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb81f649-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspect and copy records of any person at reasonable times;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb81f64a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" order a person to file written reports or answers to specific questions, including reports or answers under oath; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb81f64b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct hearings, administer oaths, take testimony, and require (by subpena or otherwise) the appearance and testimony of witnesses and the production of records the Secretary considers advisable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb81f64c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A witness summoned under this subsection is entitled to the same fee and mileage the witness would have been paid in a court of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb81f64d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civil action to enforce a subpena or order of the Secretary under this subsection may be brought in the United States district court for any judicial district in which the proceeding by the Secretary is conducted. The court may punish a failure to obey an order of the court to comply with the subpena or order of the Secretary as a contempt of court.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb81f64e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32706/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may not fail to keep records, refuse access to or copying of records, fail to make reports or provide information, fail to allow entry or inspection, or fail to permit impoundment, as required under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb81f64f-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1052"},"text":"108 Stat. 1052","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/35"},"text":"Pub. L. 103–429, § 6(35)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4380"},"text":"108 Stat. 4380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/19"},"text":"Pub. L. 105–102, § 2(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2205"},"text":"111 Stat. 2205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb81f650-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb81f651-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb81f652-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32706(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1990d(a)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 20, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/513"},"text":"Pub. L. 92–513","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/947"},"text":"86 Stat. 947","children":[],"tail":", §§ 414(a)–(c), 416; added "},{"tag":"html:span","attrib":{},"text":"July 14, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/364/s408/2"},"text":"Pub. L. 94–364, § 408(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/985"},"text":"90 Stat. 985","children":[],"tail":", 988."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32706(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1990d(a)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32706(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1990d(a)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32706(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1990d(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32706(e)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1990d(c)(1)–(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32706(e)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1990d(c)(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32706(e)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1990d(c)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32706(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1990f.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32707"},"text":"section 32707 of this title","children":[],"tail":"” are added for clarity. The words “appropriate” and “consistent with the purposes of this subsection” are omitted as surplus. The words “The Secretary may give the Attorney General information” are substituted for “Information obtained . . . may be referred to the Attorney General for investigative consideration” to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “duly” and “stating their purpose and” are omitted as surplus. In clause (A), the words “any factory, warehouse, establishment, or other” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “shall be commenced and completed” are omitted as surplus. The words “a warrant issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32707"},"text":"section 32707 of this title","children":[],"tail":"” are substituted for “an administrative inspection warrant” for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “the authority of” and “any item of” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1), before clause (A), the words “the Secretary may require” are substituted for “as the Secretary may reasonably require” and “as the Secretary finds necessary” to eliminate unnecessary words. In clause (B), the words “such officer or employee” and “reason or” are omitted as surplus. In clause (C), the words “duly” and “upon request of such officer or employee” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), the words “and subsection (e)(1)(B) of this section” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(1), before clause (A), the words “In carrying out this chapter” are substituted for “For the purpose of carrying out the provisions of this subchapter”, “In order to carry out the provisions of this subchapter”, “relevant to any function of the Secretary under this subchapter”, and “relating to any function of the Secretary under this subchapter” for consistency. The words “or, with the authorization of the Secretary, any officer or employee of the Department of Transportation” and “or his duly authorized agent” are omitted as surplus because of 49:322(b). In clause (A), the words “inspect and copy” are substituted for “have access to, and for the purposes of examination the right to copy” to eliminate unnecessary words. The word “records” is substituted for “documentary evidence” for consistency. The words “having materials or information” are omitted as surplus. In clause (B), the word “order” is substituted for “require, by general or special orders” to eliminate unnecessary words. The words “in such form as the Secretary may prescribe” and “shall be filed with the Secretary within such reasonable period as the Secretary may prescribe” are omitted as surplus because of 49:322(a). In clause (C), the words “sit and act at such times and places” are omitted as being included in “conduct hearings”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(3), the words “A civil action to enforce a subpena or order of the Secretary under this subsection may be brought in the United States district court for the judicial district in which the proceeding by the Secretary was conducted” are substituted for 15:1990d(c)(4) (words before last comma) for consistency in the revised title and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb81f653-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:32706(e)(3) to clarify the restatement of 15:1990d(c)(4) by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1994-07-05/s1"},"text":"section 1 of the Act of July 5, 1994","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Public Law 103–272","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1053"},"text":"108 Stat. 1053","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb81f654-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:32706(c) to correct a cross-reference necessary because of the restatement of subtitle IV of title 49 by the ICC Termination Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Public Law 104–88","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/803"},"text":"109 Stat. 803","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb81f655-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb81f656-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" substituted “subchapter I of chapter 135” for “subchapter II of chapter 105”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" substituted “any judicial district in which the proceeding by the Secretary is conducted.” for “the judicial district in which the proceeding by the Secretary was conducted.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb81f657-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb81f658-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s9"},"text":"section 9 of Pub. L. 103–429","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
