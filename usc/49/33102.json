{"tag":"section","attrib":{"id":"idcb8b93ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102"},"text":null,"children":[{"tag":"num","attrib":{"value":"33102"},"text":"§ 33102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Theft prevention standard for high theft lines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb8b93ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8b93ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation by regulation shall prescribe a vehicle theft prevention standard that conforms to the requirements of this chapter. The standard shall apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8b93f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" covered major parts that manufacturers install in passenger motor vehicles in lines designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s33104"},"text":"section 33104 of this title","children":[],"tail":" as high theft lines; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" major replacement parts for the major parts described in clause (A) of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8b93f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The standard may apply only to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8b93f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" major parts that manufacturers install in passenger motor vehicles having a model year designation later than the calendar year in which the standard takes effect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" major replacement parts manufactured after the standard takes effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8b93f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standard Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The standard shall be practicable and provide relevant objective criteria.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8b93f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Major Part and Replacement Part Standards","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8b93f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For a major part installed by the manufacturer of the motor vehicle, the standard may not require a part to have more than one identification.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8b93f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For a major replacement part, the standard may not require—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8b93f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identification of a part not designed as a replacement for a major part required to be identified under the standard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inscribing or affixing of identification except a symbol identifying the manufacturer and a common symbol identifying the part as a major replacement part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8b93fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records and Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This chapter does not authorize the Secretary to require a person to keep records or make reports, except as provided in sections 33104(c), 33106(c), 33108(a), and 33112 ","children":[{"tag":"ref","attrib":{"idref":"fn002137"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002137"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb8b93fc-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1077"},"text":"108 Stat. 1077","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb8b93fd-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb8b93fe-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb8b93ff-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"h