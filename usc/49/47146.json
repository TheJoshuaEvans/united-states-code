{"tag":"section","attrib":{"id":"idcc5fad0a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146"},"text":null,"children":[{"tag":"num","attrib":{"value":"47146"},"text":"§ 47146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General aviation program runway extension pilot program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc5fad0b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall establish and carry out a pilot program to provide grants to general aviation airports to increase the usable runway length capability at such airports in order to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5fad0c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expand access to such airports for larger aircraft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5fad0d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the development and economic viability of such airports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5fad0e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5fad0f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purpose of carrying out the pilot program established in subsection (a), the Secretary shall make grants to not more than 2 sponsors of general aviation airports per fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5fad10-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A sponsor of a general aviation airport shall use a grant awarded under this section to plan, design, or construct a project to extend an existing primary runway by not greater than 1,000 feet in order to accommodate large turboprop or turbojet aircraft that cannot be accommodated with the existing runway length.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5fad11-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To be eligible to receive a grant under this section, a sponsor of a general aviation airport shall submit an application to the Secretary at such time, in such form, and containing such information as the Secretary may require.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5fad12-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In selecting an applicant for a grant under this section, the Secretary shall prioritize projects that demonstrate that the existing runway length at the airport is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc5fad13-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inadequate to support the near-term operations of 1 or more business entities operating at the airport as of the date of submission of such application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5fad14-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a direct aircraft operational impediment to airport economic viability, job creation or retention, or local economic development; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5fad15-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not located within 20 miles of another National Plan of Integrated Airport Systems airport with comparable runway length.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5fad16-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Project Justification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A project that demonstrates the criteria described in subsection (b) shall be considered a justified cost with respect to the pilot program, notwithstanding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5fad17-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any benefit-cost analysis required under section 47115(d); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5fad18-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a project justification determination described in section 3 of chapter 3 of FAA Order 5100.38D, Airport Improvement Program Handbook (dated ","children":[{"tag":"date","attrib":{"date":"2014-09-30"},"text":"September 30, 2014","children":[],"tail":") (or any successor document)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5fad19-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Government’s share of allowable project costs for a project carried out with a grant under this section shall be the Government’s share of allowable project costs specified under section 47109.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5fad1a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 5 years after the establishment of the pilot program under subsection (a), the Secretary shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report that evaluates the pilot program, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5fad1b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information regarding the level of applicant interest in grants for increasing runway length;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5fad1c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of large aircraft that accessed each general aviation airport that received a grant under the pilot program in comparison to the number of such aircraft that accessed the airport prior to the date of enactment of the FAA Reauthorization Act of 2024, based on data provided to the Secretary by the airport sponsor not later than 6 months before the submission date described in this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5fad1d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description, provided to the Secretary by the airport sponsor not later than 6 months before the submission date described in this subsection, of the economic development opportunities supported by increasing the runway length at general aviation airports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5fad1e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47146/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each of fiscal years 2025 through 2028, the Secretary may use funds under section 47116(b)(2) to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc5fad1f-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s726/a"},"text":"Pub. L. 118–63, title VII, § 726(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1269"},"text":"138 Stat. 1269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc5fad20-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc5fad21-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc5fad22-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the FAA Reauthorization Act of 2024, referred to in subsec. (e)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
