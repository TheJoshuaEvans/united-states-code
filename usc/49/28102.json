{"tag":"section","attrib":{"id":"idcb41920b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28102"},"text":null,"children":[{"tag":"num","attrib":{"value":"28102"},"text":"§ 28102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limit on certain accident or incident liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb41920c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When a publicly financed commuter transportation authority established under Virginia law makes a contract to indemnify Amtrak for liability for operations conducted by or for the authority or to indemnify a rail carrier over whose tracks those operations are conducted, liability against Amtrak, the authority, or the carrier for all claims (including punitive damages) arising from an accident or incident in the District of Columbia related to those operations may not be more than the limits of the liability coverage the authority maintains to indemnify Amtrak or the carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb41920d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Required Liability Coverage","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A publicly financed commuter transportation authority referred to in subsection (a) of this section must maintain a total minimum liability coverage of at least $200,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb41920e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effectiveness","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section is effective only after Amtrak or a rail carrier seeking an indemnification contract under this section makes an operating agreement with a publicly financed commuter transportation authority established under Virginia law to provide access to its property for revenue transportation related to the operations of the authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb41920f-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/940"},"text":"108 Stat. 940","children":[],"tail":", § 26102; renumbered § 28102, "},{"tag":"ref","attrib":{"href":"/us/pl/103/440/tI/s103/a/1"},"text":"Pub. L. 103–440, title I, § 103(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4616"},"text":"108 Stat. 4616","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb419210-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb419211-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb419212-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children