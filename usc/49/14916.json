{"tag":"section","attrib":{"id":"idcb05e963-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916"},"text":null,"children":[{"tag":"num","attrib":{"value":"14916"},"text":"§ 14916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful brokerage activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb05e964-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may provide interstate brokerage services as a broker only if that person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb05e965-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is registered under, and in compliance with, section 13904; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb05e966-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has satisfied the financial security requirements under section 13906.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e967-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb05e968-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a non-vessel-operating common carrier (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t46/s40102"},"text":"section 40102 of title 46","children":[],"tail":") or an ocean freight forwarder (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s40102"},"text":"section 40102 of title 46","children":[],"tail":") when arranging for inland transportation as part of an international through movement involving ocean transportation between the United States and a foreign port;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb05e969-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a customs broker licensed in accordance with section 111.2 of title 19, Code of Federal Regulations, only to the extent that the customs broker is engaging in a movement under a customs bond or in a transaction involving customs business, as defined by section 111.1 of title 19, Code of Federal Regulations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb05e96a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an indirect air carrier holding a Standard Security Program approved by the Transportation Security Administration, only to the extent that the indirect air carrier is engaging in the activities as an air carrier as defined in section 40102(2) or in the activities defined in section 40102(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e96b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalties and Private Cause of Action","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any person who knowingly authorizes, consents to, or permits, directly or indirectly, either alone or in conjunction with any other person, a violation of subsection (a) is liable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb05e96c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the United States Government for a civil penalty in an amount not to exceed $10,000 for each violation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb05e96d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the injured party for all valid claims incurred without regard to amount.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e96e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liable Parties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The liability for civil penalties and for claims under this section for unauthorized brokering shall apply, jointly and severally—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb05e96f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to any corporate entity or partnership involved; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb05e970-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14916/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the individual officers, directors, and principals of such entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb05e971-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32919/a"},"text":"Pub. L. 112–141, div. C, title II, § 32919(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/827"},"text":"126 Stat. 827","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV/s5508/a/5"},"text":"Pub. L. 114–94, div. A, title V, § 5508(a)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1554"},"text":"129 Stat. 1554","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb05e972-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb05e973-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb05e974-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" substituted section symbol for “SEC.” before section designation."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb05e975-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb05e976-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb05e977-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
