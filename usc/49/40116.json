"html:span","attrib":{},"text":"Dec. 23, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/569/s4/a"},"text":"Pub. L. 91–569, § 4(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1502"},"text":"84 Stat. 1502","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Feb. 18, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/193/s402"},"text":"Pub. L. 96–193, § 402","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/57"},"text":"94 Stat. 57","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40116(f) (1)(C)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1512(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"40116(f)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1512(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a) is made applicable to subsections (b) and (e) of this section to avoid having to repeat the term being defined. In subsection (a), the words “Commonwealth of Puerto Rico, the Virgin Islands, Guam” are omitted as surplus because of the definition of “territory or possession of the United States” in section 40102(a) of the revised title. The word “authority” is substituted for “agencies” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), reference to 49 App.:1513(f), restated as subsection (c) of this section, is added for clarity. The words “directly or indirectly” are omitted as surplus. The text of 49 App.:1513(a) (words after “subsection (e) and”) is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (d)(2)(A), before clause (i), and (f)(1)(C) and (2), the word “political” is added for consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(1)(A), the word “pay” is substituted for “compensation” for consistency in the revised title and with chapter 55 of title 5, United States Code. The words “rendered by the employee in the performance of his duties and shall include wages and salary” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(1)(B), the words “means a State of the United States” are substituted for “also means” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(1)(C), the words “of a State” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(2), before clause (A), the words “as such an employee” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbacd722-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:40116(d)(2)(A)(iv) to conform to the style of title 49 and to set out the effective date for this clause.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbacd723-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbacd724-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this clause, referred to in subsec. (d)(2)(A)(v), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbacd725-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (d)(2)(A)(v). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" added cl. (v)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264"},"text":"Pub. L. 104–264","children":[],"tail":", in introductory provisions, substituted “a State, a” for “a State or” and inserted “, and any person that has purchased or leased an airport under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s47134"},"text":"section 47134 of this title","children":[],"tail":"” after “of a State”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":", which directed substitution of “"},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"August 23, 1994","children":[],"tail":"” for “the date of enactment of this clause”, was executed by making the substitution for “the date of the enactment of this clause” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" substituted “levy” for “Levy”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d)(2)(A)(iv). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/s112/e"},"text":"Pub. L. 103–305, § 112(e)","children":[],"tail":", added cl. (iv)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/s208"},"text":"Pub. L. 103–305, § 208","children":[],"tail":", added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbacd726-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbacd727-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as otherwise specifically provided, amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264"},"text":"Pub. L. 104–264","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1996-09-30"},"text":"Sept. 30, 1996","children":[],"tail":", and not to be construed as affecting funds made available for a fiscal year ending before "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/s3"},"text":"section 3 of Pub. L. 104–264","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbacd728-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2018 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tI/s159/b"},"text":"Pub. L. 115–254, div. B, title I, § 159(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3220"},"text":"132 Stat. 3220","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dB/tI/s159/b"},"text":"“Nothing in this section [amending this section] or an amendment made by this section shall affect a change to a rate or other provision of a tax, fee, or charge under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40116"},"text":"section 40116 of title 49","children":[],"tail":", United States Code, that was enacted prior to the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"]. Such provision of a tax, fee, or charge shall continue to be subject to the requirements to which such provision was subject under that section as in effect on the day before the date of enactment of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
