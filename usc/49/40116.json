{"tag":"section","attrib":{"id":"idcbacd6fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116"},"text":null,"children":[{"tag":"num","attrib":{"value":"40116"},"text":"§ 40116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State taxation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbacd6fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, “State” includes the District of Columbia, a territory or possession of the United States, and a political authority of at least 2 States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbacd6fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c) of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40117"},"text":"section 40117 of this title","children":[],"tail":", a State, a political subdivision of a State, and any person that has purchased or leased an airport under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s47134"},"text":"section 47134 of this title","children":[],"tail":" may not levy or collect a tax, fee, head charge, or other charge on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbacd6fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual traveling in air commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbacd6fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation of an individual traveling in air commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbacd6ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale of air transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbacd700-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the gross receipts from that air commerce or transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbacd701-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aircraft Taking Off or Landing in State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State or political subdivision of a State may levy or collect a tax on or related to a flight of a commercial aircraft or an activity or service on the aircraft only if the aircraft takes off or lands in the State or political subdivision as part of the flight.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbacd702-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unreasonable Burdens and Discrimination Against Interstate Commerce","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbacd703-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbacd704-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “air carrier transportation property” means property (as defined by the Secretary of Transportation) that an air carrier providing air transportation owns or uses.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbacd705-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “assessment” means valuation for a property tax levied by a taxing district.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbacd706-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “assessment jurisdiction” means a geographical area in a State used in determining the assessed value of property for ad valorem taxation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbacd707-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “commercial and industrial property” means property (except transportation property and land used primarily for agriculture or timber growing) devoted to a commercial or industrial use and subject to a property tax levy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbacd708-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbacd709-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A State, political subdivision of a State, or authority acting for a State or political subdivision may not do any of the following acts because those acts unreasonably burden and discriminate against interstate commerce:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbacd70a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assess air carrier transportation property at a value that has a higher ratio to the true market value of the property than the ratio that the assessed value of other commercial and industrial property of the same type in the same assessment jurisdiction has to the true market value of the other commercial and industrial property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbacd70b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" levy or collect a tax on an assessment that may not be made under clause (i) of this subparagraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbacd70c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" levy or collect an ad valorem property tax on air carrier transportation property at a tax rate greater than the tax rate applicable to commercial and industrial property in the same assessment jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbacd70d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" levy or collect a tax, fee, or charge, first taking effect after ","children":[{"tag":"date","attrib":{"date":"1994-08-23"},"text":"August 23, 1994","children":[],"tail":", exclusively upon any business located at a commercial service airport or operating as a permittee of such an airport other than a tax, fee, or charge wholly utilized for airport or aeronautical purposes."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbacd70e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise provided under section 47133, levy or collect a tax, fee, or charge, first taking effect after the date of enactment of this clause, upon any business located at a commercial service airport or operating as a permittee of such an airport that is not generally imposed on sales or services by that State, political subdivision, or authority unless wholly utilized for airport or aeronautical purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbacd70f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraph (A) of this paragraph does not apply to an in lieu tax completely used for airport and aeronautical purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbacd710-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Allowable Taxes and Charges","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d) of this section, a State or political subdivision of a State may levy or collect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbacd711-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" taxes (except those taxes enumerated in subsection (b) of this section), including property taxes, net income taxes, franchise taxes, and sales or use taxes on the sale of goods or services; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbacd712-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable rental charges, landing fees, and other service charges from aircraft operators for using airport facilities of an airport owned or operated by that State or subdivision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbacd713-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay of Air Carrier Employees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbacd714-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbacd715-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “pay” means money received by an employee for services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbacd716-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State of the United States, the District of Columbia, and a territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbacd717-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an employee is deemed to have earned 50 percent of the employee’s pay in a State or political subdivision of a State in which the scheduled flight time of the employee in the State or subdivision is more than 50 percent of the total scheduled flight time of the employee when employed during the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbacd718-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The pay of an employee of an air carrier having regularly assigned duties on aircraft in at least 2 States is subject to the income tax laws of only the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbacd719-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or political subdivision of the State that is the residence of the employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbacd71a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State or political subdivision of the State in which the employee earns more than 50 percent of the pay received by the employee from the carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbacd71b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Compensation paid by an air carrier to an employee described in subsection (a) in connection with such employee’s authorized leave or other authorized absence from regular duties on the carrier’s aircraft in order to perform services on behalf of the employee’s airline union shall be subject to the income tax laws of only the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbacd71c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State or political subdivision of the State that is the residence of the employee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbacd71d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40116/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The State or political subdivision of the State in which the employee’s scheduled flight time would have been more than 50 percent of the employee’s total scheduled flight time for the calendar year had the employee been engaged full time in the performance of regularly assigned duties on the carrier’s aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbacd71e-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1111"},"text":"108 Stat. 1111","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/305/tI/s112/e"},"text":"Pub. L. 103–305, title I, § 112(e)","children":[],"tail":", title II, § 208, "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1576"},"text":"108 Stat. 1576","children":[],"tail":", 1588; "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/tI/s149/b"},"text":"Pub. L. 104–264, title I, § 149(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"