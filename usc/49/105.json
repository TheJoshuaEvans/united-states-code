{"tag":"section","attrib":{"id":"idca499d9f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s105"},"text":null,"children":[{"tag":"num","attrib":{"value":"105"},"text":"§ 105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Highway Traffic Safety Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca499da0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The National Highway Traffic Safety Administration is an administration in the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca499da1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the Administration is the Administrator who is appointed by the President, by and with the advice and consent of the Senate. The Administration has a Deputy Administrator who is appointed by the Secretary of Transportation, with the approval of the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca499da2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall carry out—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca499da3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" duties and powers vested in the Secretary by chapter 4 of title 23, except those related to highway design, construction and maintenance, traffic control devices, identification and surveillance of accident locations, and highway-related aspects of pedestrian safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca499da4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" additional duties and powers prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca499da5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may carry out chapter 301 of this title through the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca499da6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall consult with the Federal Highway Administrator on all matters related to the design, construction, maintenance, and operation of highways.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca499da7-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449/s1/b"},"text":"Pub. L. 97–449, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2415"},"text":"96 Stat. 2415","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/m/3"},"text":"Pub. L. 103–272, § 5(m)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1375"},"text":"108 Stat. 1375","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca499da8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca499da9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca499daa-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"105","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"23:401 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/564/s201/a"},"text":"Pub. L. 89–564, § 201(a)","children":[],"tail":" (less pay of Administrator and Deputy Administrator), (b)(2), (c), (d), "},{"tag":"html:a","attrib":{"href":"/us/stat/80/735"},"text":"80 Stat. 735","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s8/h"},"text":"Pub. L. 89–670, § 8(h)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/943"},"text":"80 Stat. 943","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Dec. 31, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/605/s202/a"},"text":"Pub. L. 91–605, § 202(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1739"},"text":"84 Stat. 1739","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “The . . . is an administration in the” are substituted for “There is hereby established within the”, in section 201(a) (1st sentence) of the Highway Safety Act of 1966 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/564"},"text":"Pub. L. 89–564","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/731"},"text":"80 Stat. 731","children":[],"tail":") to conform to other sections of the revised title. The words “(hereafter in this section referred to as the ‘Administration’)” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “carry out . . . duties and powers . . . prescribed by the Secretary” are substituted for “perform such duties as are delegated to him by the Secretary” to eliminate surplus words and for consistency. The list of excepted programs in clause (1) is substituted for “highway safety programs, research and development not specifically referred to in paragraph (1) of this subsection”, in section 201(b)(2) of the Highway Safety Act of 1966 for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “Administration . . . authorized by this section” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of section 201(d) of the Highway Safety Act of 1966 is omitted as executed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca499dab-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca499dac-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":" substituted “chapter 301 of this title” for “the National Traffic and Motor Vehicle Safety Act of 1966 ("},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1381"},"text":"15 U.S.C. 1381","children":[],"tail":" et seq.)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca499dad-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca499dae-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Required Reporting of NHTSA Agenda","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dB/tXXIV/s24401"},"text":"Pub. L. 114–94, div. B, title XXIV, § 24401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1720"},"text":"129 Stat. 1720","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dB/tXXIV/s24401"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Not later than December 1 of the year beginning after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"], and each year thereafter, the Administrator of the National Highway Traffic Safety Administration shall publish on the public website of the Administration, and file with the Committees on Energy and Commerce and Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate an annual plan for the following calendar year detailing the Administration’s projected activities, including—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator’s policy priorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rulemakings projected to be commenced;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any plans to develop guidelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any plans to restructure the Administration or to establish or alter working groups;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any planned projects or initiatives of the Administration, including the working groups and advisory committees of the Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any projected dates or timetables associated with any of the items described in paragraphs (1) through (5).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca499daf-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"National Highway Traffic Safety Administration Electronics, Software, and Engineering Expertise","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tI/s31401"},"text":"Pub. L. 112–141, div. C, title I, § 31401","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/772"},"text":"126 Stat. 772","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/141/dC/tI/s31401"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Council for Vehicle Electronics, Vehicle Software, and Emerging Technologies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of Transportation] shall establish, within the National Highway Traffic Safety Administration, a Council for Vehicle Electronics, Vehicle Software, and Emerging Technologies (referred to in this section as the ‘Council’) to build, integrate, and aggregate the Administration’s expertise in passenger motor vehicle electronics and other new and emerging technologies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation of roadmap","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall research the inclusion of emerging lightweight plastic and composite technologies in motor vehicles to increase fuel efficiency, lower emissions, meet fuel economy standards, and enhance passenger motor vehicle safety through continued utilization of the Administration’s Plastic and Composite Intensive Vehicle Safety Roadmap (Report No. DOT HS 810 863).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Intra-agency coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall coordinate with all components of the Administration responsible for vehicle safety, including research and development, rulemaking, and defects investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Honors Recruitment Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish, within the National Highway Traffic Safety Administration, an honors program for engineering students, computer science students, and other students interested in vehicle safety that will enable such students to train with engineers and other safety officials for careers in vehicle safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stipend","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary is authorized to provide a stipend to any student during the student’s participation in the program established under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council, in consultation with affected stakeholders, shall periodically assess the implications of emerging safety technologies in passenger motor vehicles, including the effect of such technologies on consumers, product availability, and cost.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
