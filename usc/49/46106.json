nd rule 81(b) of the Federal Rules of Civil Procedure (28 App. U.S.C.).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc398660-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc398661-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/f/3"},"text":"Pub. L. 115–254, § 1991(f)(3)","children":[],"tail":", substituted “by the Administrator of the Federal Aviation Administration)” for “by the Administrator)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/f/1"},"text":"Pub. L. 115–254, § 1991(f)(1)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration with respect to security duties and powers designated to be carried out by the Administrator of the Transportation Security Administration” for “Under Secretary of Transportation for Security with respect to security duties and powers designated to be carried out by the Under Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s140/b/7"},"text":"Pub. L. 107–71, § 140(b)(7)","children":[],"tail":", substituted “Department of Transportation” for “Secretary of Transportation and Administrator of the Federal Aviation Administration” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s140/b/1"},"text":"Pub. L. 107–71, § 140(b)(1)","children":[],"tail":", inserted “the Under Secretary of Transportation for Security with respect to security duties and powers designated to be carried out by the Under Secretary or” after “(or”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
