{"tag":"section","attrib":{"id":"idcb05e8dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14903"},"text":null,"children":[{"tag":"num","attrib":{"value":"14903"},"text":"§ 14903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tariff violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb05e8dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty for Undercharging and Overcharging","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person that offers, grants, gives, solicits, accepts, or receives by any means transportation or service provided for property by a carrier subject to jurisdiction under chapter 135 at a rate different than the rate in effect under section 13702 is liable to the United States for a civil penalty of not more than $100,000 for each violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e8de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Criminal Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier providing transportation or service subject to jurisdiction under chapter 135 or an officer, director, receiver, trustee, lessee, agent, or employee of a corporation that is subject to jurisdiction under that chapter, that willfully does not observe its tariffs as required under section 13702, shall be fined under title 18 or imprisoned not more than 2 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e8df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14903/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions of Agents and Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When acting in the scope of their employment, the actions and omissions of persons acting for or employed by a carrier or shipper that is subject to this section are considered to be the actions and omissions of that carrier or shipper as well as that person.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e8e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14903/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Trial in a criminal action under this section is in the judicial district in which any part of the violation is committed or through which the transportation is conducted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb05e8e1-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/915"},"text":"109 Stat. 915","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/12"},"text":"Pub. L. 105–102, § 2(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2205"},"text":"111 Stat. 2205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb05e8e2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb05e8e3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb05e8e4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:14903(a) to correct a grammatical error.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb05e8e5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb05e8e6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11903"},"text":"section 11903 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb05e8e7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" inserted “a” before “civil penalty of not more than”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb05e8e8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb05e8e9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
