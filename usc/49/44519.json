{"tag":"section","attrib":{"id":"idcbe8803b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519"},"text":null,"children":[{"tag":"num","attrib":{"value":"44519"},"text":"§ 44519.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certification personnel continuing education and training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbe8803c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Federal Aviation Administration shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbe8803d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a program for regular recurrent training of engineers, inspectors, and other subject-matter experts employed in the Aircraft Certification Service of the Administration in accordance with the training strategy developed pursuant to section 231 of the FAA Reauthorization Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Public Law 115–254","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/132/3256"},"text":"132 Stat. 3256","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe8803e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the maximum extent practicable, implement measures, including assignments in multiple divisions of the Aircraft Certification Service, to ensure that such engineers and other subject-matter experts in the Aircraft Certification Service have access to diverse professional opportunities that expand their knowledge and skills;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe8803f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a program to provide continuing education and training to Administration personnel who hold positions involving aircraft certification and flight standards, including human factors specialists, engineers, flight test pilots, inspectors, and, as determined appropriate by the Administrator, industry personnel who may be responsible for compliance activities including designees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe88040-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in consultation with outside experts, develop—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbe88041-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an education and training curriculum on current and new aircraft technologies, human factors, project management, and the roles and responsibilities associated with oversight of designees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe88042-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended practices for compliance with Administration regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe88043-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall, to the maximum extent practicable, ensure that actions taken pursuant to subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbe88044-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" permit engineers, inspectors, and other subject matter experts to continue developing knowledge of, and expertise in, new and emerging technologies in systems design, flight controls, principles of aviation safety, system oversight, and certification project management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe88045-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimize the likelihood of an individual developing an inappropriate bias toward a designer or manufacturer of aircraft, aircraft engines, propellers, or appliances;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe88046-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with any applicable collective bargaining agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe88047-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" account for gaps in knowledge and skills (as identified by the Administrator in consultation with the exclusive bargaining representatives certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s7111"},"text":"section 7111 of title 5","children":[],"tail":", United States Code) between Administration employees and private-sector employees for each group of Administration employees covered under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe88048-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44519/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Administrator, $10,000,000 for each of fiscal years 2021 through 2028 to carry out this section. Amounts appropriated under the preceding sentence for any fiscal year shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbe88049-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dV/tI/s112/a"},"text":"Pub. L. 116–260, div. V, title I, § 112(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2331"},"text":"134 Stat. 2331","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIII/s306/d"},"text":"Pub. L. 118–63, title III, § 306(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1072"},"text":"138 Stat. 1072","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbe8804a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbe8804b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbe8804c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 231 of the FAA Reauthorization Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Public Law 115–254","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/132/3256"},"text":"132 Stat. 3256","children":[],"tail":"), referred to in subsec. (a)(1), is "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s231"},"text":"section 231 of Pub. L. 115–254","children":[],"tail":", div. B, title II, "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3256"},"text":"132 Stat. 3256","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbe8804d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" substituted “2028” for “2023”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
