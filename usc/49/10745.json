{"tag":"section","attrib":{"id":"idcae2338b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10745"},"text":null,"children":[{"tag":"num","attrib":{"value":"10745"},"text":"§ 10745.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation services or facilities furnished by shipper","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A rail carrier providing transportation or service subject to the jurisdiction of the Board under this part may establish a charge or allowance for transportation or service for property when the owner of the property, directly or indirectly, furnishes a service related to or an instrumentality used in the transportation or service. The Board may prescribe the maximum reasonable charge or allowance a rail carrier subject to its jurisdiction may pay for a service or instrumentality furnished under this section. The Board may begin a proceeding under this section on its own initiative or on application.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcae2338c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/821"},"text":"109 Stat. 821","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcae2338d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcae2338e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcae2338f-4