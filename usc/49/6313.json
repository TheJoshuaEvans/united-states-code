{"tag":"section","attrib":{"id":"idcad8bdfa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6313"},"text":null,"children":[{"tag":"num","attrib":{"value":"6313"},"text":"§ 6313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mandatory response authority for freight data collection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad8bdfb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6313/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Freight Data Collection.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8bdfc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6313/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An owner, official, agent, person in charge, or assistant to the person in charge of a freight corporation, company, business, institution, establishment, or organization described in paragraph (2) shall be fined in accordance with subsection (b) if that individual neglects or refuses, when requested by the Director or other authorized officer, employee, or contractor of the Bureau to submit data under section 6302(b)(3)(B)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8bdfd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6313/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to answer completely and correctly to the best knowledge of that individual all questions relating to the corporation, company, business, institution, establishment, or other organization; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8bdfe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6313/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make available records or statistics in the official custody of the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bdff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6313/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Description of entities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A freight corporation, company, business, institution, establishment, or organization referred to in paragraph (1) is a corporation, company, business, institution, establishment, or organization that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8be00-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6313/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receives Federal funds relating to the freight program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8be01-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6313/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" has consented to be subject to a fine under this subsection on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcad8be02-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6313/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refusal to supply any data requested; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcad8be03-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6313/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" failure to respond to a written request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8be04-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6313/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fines.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8be05-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6313/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), an individual described in subsection (a) shall be fined not more than $500.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8be06-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6313/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Willful actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an individual willfully gives a false answer to a question described in subsection (a)(1), the individual shall be fined not more than $10,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad8be07-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tII/s52011/a"},"text":"Pub. L. 112–141, div. E, title II, § 52011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/895"},"text":"126 Stat. 895","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad8be08-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcad8be09-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcad8be0a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
