{"tag":"section","attrib":{"id":"idcaf546a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702"},"text":null,"children":[{"tag":"num","attrib":{"value":"13702"},"text":"§ 13702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tariff requirement for certain transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf546aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except when providing transportation for charitable purposes without charge, a carrier subject to jurisdiction under chapter 135 may provide transportation or service that is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf546ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in noncontiguous domestic trade, except with regard to bulk cargo, forest products, recycled metal scrap, waste paper, and paper waste; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for movement of household goods;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"only if the rate for such transportation or service is contained in a tariff that is in effect under this section. The carrier may not charge or receive a different compensation for the transportation or service than the rate specified in the tariff, whether by returning a part of that rate to a person, giving a person a privilege, allowing the use of a facility that affects the value of that transportation or service, or another device. A rate contained in a tariff shall be stated in money of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf546ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tariff Requirements for Noncontiguous Domestic Trade.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf546ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier providing transportation or service described in subsection (a)(1) shall publish and file with the Board tariffs containing the rates established for such transportation or service. The carriers shall keep such tariffs available for public inspection. The Board shall prescribe the form and manner of publishing, filing, and keeping tariffs available for public inspection under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may prescribe any specific information and charges to be identified in a tariff, but at a minimum tariffs must identify plainly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf546b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the carriers that are parties to it;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the places between which property will be transported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" terminal charges if a carrier provides transportation or service subject to jurisdiction under subchapter III of chapter 135;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" privileges given and facilities allowed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any rules that change, affect, or determine any part of the published rate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inland divisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier providing transportation or service described in subsection (a)(1) under a joint rate for a through movement shall not be required to state separately or otherwise reveal in tariff filings the inland divisions of that through rate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time-volume rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Rates in tariffs filed under this subsection may vary with the volume of cargo offered over a specified period of time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Changes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may permit carriers to change rates, classifications, rules, and practices without filing complete tariffs under this subsection that cover matter that is not being changed when the Board finds that action to be consistent with the public interest. Those carriers may either—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf546b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish new tariffs that incorporate changes, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plainly indicate the proposed changes in the tariffs then in effect and make the tariffs as changed available for public inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Complaints","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A complaint that a rate or related rule or practice maintained in a tariff under this subsection violates section 13701(a) may be submitted to the Board for resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf546bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tariff Requirements for Household Goods Carriers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf546bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier providing transportation described in subsection (a)(2) shall maintain rates and related rules and practices in a published tariff. The tariff must be available for inspection by the Board and be made available for inspection by shippers upon reasonable request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier that maintains a tariff under this subsection may not enforce the provisions of the tariff unless the carrier has given notice that the tariff is available for inspection in its bill of lading or by other actual notice to individuals whose shipments are subject to the tariff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier that maintains a tariff under this subsection is bound by the tariff except as otherwise provided in this part. A tariff that does not comply with this subsection may not be enforced against any individual shipper.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incorporation by reference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier may incorporate by reference the rates, terms, and other conditions of a tariff in agreements covering the transportation of household goods.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Complaints","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A complaint that a rate or related rule or practice maintained in a tariff under this subsection violates section 13701(a) may be submitted to the Board for resolution.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf546c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Invalidation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may invalidate a tariff prepared by a carrier or carriers under this section if that tariff violates this section or a regulation of the Board carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf546c2-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/868"},"text":"109 Stat. 868","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf546c3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf546c4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf546c5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in sections 10761 and 10762 of this title prior to the general amendment of this subtitle by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaf546c6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcaf546c7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
