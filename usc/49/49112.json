{"tag":"section","attrib":{"id":"idcc707526-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49112"},"text":null,"children":[{"tag":"num","attrib":{"value":"49112"},"text":"§ 49112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Separability and effect of judicial order","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc707527-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Separability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any provision of this chapter, or the application of a provision of this chapter to a person or circumstance, is held invalid, the remainder of this chapter and the application of the provision to other persons or circumstances is not affected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc707528-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Judicial Order","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any action of the Airports Authority that was required to be submitted to the Board of Review under section 6007(f)(4) of the Metropolitan Washington Airports Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Public Law 99–500","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-380"},"text":"100 Stat. 1783–380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/599"},"text":"Public Law 99–599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-383"},"text":"100 Stat. 3341–383","children":[],"tail":") before "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"October 9, 1996","children":[],"tail":", remains in effect and may not be set aside only because of a judicial order invalidating certain functions of the Board."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc707529-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/26"},"text":"Pub. L. 105–102, § 2(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2214"},"text":"111 Stat. 2214","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tXI/s1101/y"},"text":"Pub. L. 118–63, title XI, § 1101(y)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1415"},"text":"138 Stat. 1415","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc70752a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc70752b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc70752c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}