L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 902(n)(2), (4); added "},{"tag":"html:span","attrib":{},"text":"Aug. 5, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/366/s103/b"},"text":"Pub. L. 93–366, § 103(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/410"},"text":"88 Stat. 410","children":[],"tail":", 411."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46501(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1301(38) (words before 10th comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46501(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1472(n)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), before subclause (A), the words “any of the following” are substituted for “includes” for clarity. In subclause (B), the words “armed forces” are substituted for “national defense forces” because of 10:101. In subclause (D)(i), the word “place” is substituted for “point” for consistency in the revised title. The word “actually” is omitted as surplus. In subclause (D)(ii), the words “on which an individual commits” are substituted for “having . . . committed aboard” for clarity. In subclause (D)(iii), the words “against which an individual commits” are substituted for “regarding which an offense . . . is committed” for clarity. The words “(Montreal, ","children":[{"tag":"date","attrib":{"date":"1971-09-23"},"text":"September 23, 1971","children":[],"tail":")” are omitted as surplus. In subclause (E), the words “the lessee does not have a principal place of business” are substituted for “none” for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3), the words “by force or threat thereof, or . . . other” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
