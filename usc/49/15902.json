{"tag":"section","attrib":{"id":"idcb08594f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15902"},"text":null,"children":[{"tag":"num","attrib":{"value":"15902"},"text":"§ 15902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by the Board","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board may bring a civil action to enforce an order of the Board, except a civil action to enforce an order for the payment of money, when it is violated by a pipeline carrier providing transportation subject to this part.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb085950-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s106/a"},"text":"Pub. L. 104–88, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/927"},"text":"109 Stat. 927","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb085951-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb085952-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb085953-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11702"},"text":"section 11702 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"r