{"tag":"section","attrib":{"id":"idcbda2864-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44112"},"text":null,"children":[{"tag":"num","attrib":{"value":"44112"},"text":"§ 44112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation of liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbda2865-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbda2866-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “lessor” means a person leasing for at least 30 days a civil aircraft, aircraft engine, or propeller.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbda2867-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “owner” means a person that owns a civil aircraft, aircraft engine, or propeller.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbda2868-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44112/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “secured party” means a person having a security interest in, or security title to, a civil aircraft, aircraft engine, or propeller under a conditional sales contract, equipment trust contract, chattel or corporate mortgage, or similar instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbda2869-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A lessor, owner, or secured party is liable for personal injury, death, or property loss or damage only when a civil aircraft, aircraft engine, or propeller is in the actual possession or operational control of the lessor, owner, or secured party, and the personal injury, death, or property loss or damage occurs because of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbda286a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft, engine, or propeller; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbda286b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the flight of, or an object falling from, the aircraft, engine, or propeller.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbda286c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1167"},"text":"108 Stat. 1167","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tV/s514"},"text":"Pub. L. 115–254, div. B, title V, § 514","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3358"},"text":"132 Stat. 3358","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbda286d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbda286e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbda286f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44112","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1404.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s504"},"text":"Pub. L. 85–726, § 504","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/774"},"text":"72 Stat. 774","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"July 8, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/81/s2"},"text":"Pub. L. 86–81, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/180"},"text":"73 Stat. 180","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), clauses (1) and (3) are derived from 49 App.:1404 (2d–57th words). Clause (2) is added for clarity. In clause (1), the words “bona fide” are omitted as surplus. In clause (3), the word “nature” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “personal injury, death” are substituted for “any injury to or death of persons”, and the words “on land or water” are substituted for “on the surface of the earth (whether on land or water)”, to eliminate unnecessary words. In clause (2), the words “ascent, descent, or” and “dropping or” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbda2870-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbda2871-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", in introductory provisions, struck out “on land or water” before “only when” and inserted “operational” before “control”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
