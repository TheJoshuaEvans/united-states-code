{"tag":"section","attrib":{"id":"idcaf546c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703"},"text":null,"children":[{"tag":"num","attrib":{"value":"13703"},"text":"§ 13703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certain collective activities; exemption from antitrust laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf546c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf546ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to enter","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A motor carrier providing transportation or service subject to jurisdiction under chapter 135 may enter into an agreement with one or more such carriers to establish—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf546cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through routes and joint rates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rates for the transportation of household goods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" classifications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mileage guides;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rules;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" divisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rate adjustments of general application based on industry average carrier costs (so long as there is no discussion of individual markets or particular single-line rates); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for joint consideration, initiation, or establishment of matters described in subparagraphs (A) through (G).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of agreement to board; approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An agreement entered into under paragraph (1) may be submitted by any carrier or carriers that are parties to such agreement to the Board for approval and may be approved by the Board only if it finds that such agreement is in the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may require compliance with reasonable conditions consistent with this part to assure that the agreement furthers the transportation policy set forth in section 13101.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independently established rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any carrier which is a party to an agreement under paragraph (1) is not, and may not be, precluded from independently establishing its own rates, classification, and mileages or from adopting and using a noncollectively made classification or mileage guide.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investigations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf546d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reasonableness","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may suspend and investigate the reasonableness of any rate, rule, classification, or rate adjustment of general application made pursuant to an agreement under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions not in the public interest","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may investigate any action taken pursuant to an agreement approved under this section. If the Board finds that the action is not in the public interest, the Board may take such measures as may be necessary to protect the public interest with regard to the action, including issuing an order directing the parties to cease and desist or modify the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of approval","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Board approves the agreement or renews approval of the agreement, it may be made and carried out under its terms and under the conditions required by the Board, and the antitrust laws, as defined in the first section of the Clayton Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"15 U.S.C. 12","children":[],"tail":"), do not apply to parties and other persons with respect to making or carrying out the agreement."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf546da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may require an organization established or continued under an agreement approved under this section to maintain records and submit reports. The Board, or its delegate, may inspect a record maintained under this section, or monitor any organization’s compliance with this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf546db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf546dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may review an agreement approved under this section, on its own initiative or on request, and shall change the conditions of approval or terminate it when necessary to protect the public interest. Action of the Board under this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf546dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approving an agreement,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" denying, ending, or changing approval,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribing the conditions on which approval is granted, or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" changing those conditions,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"has effect only as related to application of the antitrust laws referred to in subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Periodic review of approvals","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to this section, in the 5-year period beginning on the date of the enactment of this paragraph and in each 5-year period thereafter, the Board shall initiate a proceeding to review any agreement approved pursuant to this section. Any such agreement shall be continued unless the Board determines otherwise.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf546e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing Agreements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf546e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements existing as of ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":null}],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Agreements approved under former section 10706(b) and in effect on ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":", shall be treated for purposes of this section as approved by the Board under this section beginning on "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cases pending as of date of the enactment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in section 227 (other than subsection (b)) of the Motor Carrier Safety Improvement Act of 1999, including the amendments made by such section, shall be construed to affect any case brought under this section that is pending before the Board as of the date of the enactment of this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf546e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Statutory Construction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf546e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Undercharge claims","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall serve as a basis for any undercharge claim.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Obligation of shipper","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this title, the ICC Termination Act of 1995, or any amendments or repeals made by such Act shall be construed as creating any obligation for a shipper based solely on a classification that was on file with the Interstate Commerce Commission or elsewhere on ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf546e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Industry Standard Guides.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf546e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf546ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Routes, rates, classifications, mileage guides, and rules established under agreements approved under this section shall be published and made available for public inspection upon request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation of carriers","children":[],"tail":".—"}],"tail":null},{"tag":"clause","attrib":{"id":"idcaf546ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/f/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A motor carrier of property whose routes, rates, classifications, mileage guides, rules, or packaging are determined or governed by publications established under agreements approved under this section must participate in the determining or governing publication for such provisions to apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf546ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/f/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Power of attorney","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The motor carrier of property shall issue a power of attorney to the publishing agent and, upon its acceptance, the agent shall issue a written certification to the motor carrier affirming its participation in the governing publication, and the certification shall be made available for public inspection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf546ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mileage limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No carrier subject to jurisdiction under subchapter I or III of chapter 135 may enforce collection of its mileage rates unless such carrier—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf546ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a participant in a publication of mileages formulated under an agreement approved under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf546f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses a publication of mileage (other than a publication described in subparagraph (A)) that can be examined by any interested person upon reasonable request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf546f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13703/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Single Line Rate Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “single line rate” means a rate, charge, or allowance proposed by a single motor carrier that is applicable only over its line and for which the transportation can be provided by that carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf546f2-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/869"},"text":"109 Stat. 869","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/28"},"text":"Pub. L. 104–287, § 5(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3391"},"text":"110 Stat. 3391","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/9"},"text":"Pub. L. 105–102, § 2(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2204"},"text":"111 Stat. 2204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/159/tII/s227"},"text":"Pub. L. 106–159, title II, § 227","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1772"},"text":"113 Stat. 1772","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/7/dI/tIII/s354"},"text":"Pub. L. 108–7, div. I, title III, § 354","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-02-20"},"text":"Feb. 20, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/421"},"text":"117 Stat. 421","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf546f3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcaf546f4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcaf546f5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:13703(a)(2) to correct an erroneous cross-reference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf546f6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcaf546f7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this paragraph, referred to in subsecs. (c)(2) and (d)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159"},"text":"Pub. L. 106–159","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Former section 10706(b), referred to in subsec. (d)(1), probably means ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10706/b"},"text":"section 10706(b) of this title","children":[],"tail":" as in effect before that section was omitted and a new section 10706 enacted in the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/804"},"text":"109 Stat. 804","children":[],"tail":", 812."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 227 of the Motor Carrier Safety Improvement Act of 1999, referred to in subsec. (d)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/s227"},"text":"section 227 of Pub. L. 106–159","children":[],"tail":", which amended this section. See 1999 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The ICC Termination Act of 1995, referred to in subsec. (e)(2), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/803"},"text":"109 Stat. 803","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1995 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s101"},"text":"section 101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf546f8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10706"},"text":"section 10706 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcaf546f9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2003—Subsecs. (d) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/7"},"text":"Pub. L. 108–7","children":[],"tail":" redesignated subsecs. (e) to (h) as (d) to (g), respectively, and struck out heading and text of former subsec. (d). Text read as follows: “The Board shall not take any action that would permit the establishment of nationwide collective ratemaking authority.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/s227/a"},"text":"Pub. L. 106–159, § 227(a)","children":[],"tail":", designated introductory provisions as par. (1) and inserted heading, redesignated former pars. (1) to (4) as subpars. (A) to (D), respectively, of par. (1) and realigned their margins, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/s227/b"},"text":"Pub. L. 106–159, § 227(b)","children":[],"tail":", amended heading and text of subsec. (d) generally. Prior to amendment, text read as follows: “Subject to subsection (c), approval of an agreement under subsection (a) shall expire 3 years after the date of approval unless renewed under this subsection. The approval may be renewed upon request of the parties to the agreement if such parties resubmit the agreement to the Board, the agreement is unchanged, and the Board approves such renewal. The Board shall approve the renewal unless it finds that the renewal is not in the public interest. Parties to the agreement may continue to undertake activities pursuant to the previously approved agreement while the renewal request is pending.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/s227/c"},"text":"Pub. L. 106–159, § 227(c)","children":[],"tail":", designated existing provisions as par. (1), inserted par. heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" substituted “paragraph (1)” for “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/28/A"},"text":"Pub. L. 104–287, § 5(28)(A)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":",” for “the day before the effective date of this section” and “"},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"” for “such effective date”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/28/B"},"text":"Pub. L. 104–287, § 5(28)(B)","children":[],"tail":", substituted “"},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"” for “the day before the effective date of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaf546fa-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcaf546fb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcaf546fc-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Interstate Commerce Commission","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Interstate Commerce Commission abolished by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s101"},"text":"section 101 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcaf546fd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deemed References to Chapters 509 and 511 of Title 51","children":[],"tail":null},{"tag":"p","attrib":{},"text":"General references to “this title” deemed to refer also to chapters 509 and 511 of Title 51, National and Commercial Space Programs, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/8"},"text":"section 4(d)(8) of Pub. L. 111–314","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
