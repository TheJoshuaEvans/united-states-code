{"tag":"section","attrib":{"id":"idcb8dde0b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33114"},"text":null,"children":[{"tag":"num","attrib":{"value":"33114"},"text":"§ 33114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb8dde0c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8dde0d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacture for sale, sell, offer for sale, introduce or deliver for introduction in interstate commerce, or import into the United States, a motor vehicle or major replacement part subject to a standard prescribed under section 33102 or 33103 of this title, unless it conforms to the standard;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dde0e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to comply with a regulation prescribed by the Secretary of Transportation or Attorney General under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dde0f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33114/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to keep specified records, refuse access to or copying of records, fail to make reports or provide items or information, or fail or refuse to allow entry or inspection, as required by this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dde10-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33114/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to provide the certification required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s33108/c"},"text":"section 33108(c) of this title","children":[],"tail":", or provide a certification that the person knows, or in the exercise of reasonable care has reason to know, is false or misleading in a material respect; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dde11-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33114/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" knowingly—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8dde12-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33114/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" own, operate, maintain, or control a chop shop;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dde13-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33114/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct operations in a chop shop; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dde14-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33114/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transport a passenger motor vehicle or passenger motor vehicle part to or from a chop shop.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8dde15-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a)(1) of this section does not apply to a person establishing that in the exercise of reasonable care the person did not have reason to know that the motor vehicle or major replacement part was not in conformity with the standard.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb8dde16-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1091"},"text":"108 Stat. 1091","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb8dde17-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb8dde18-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb8dde19-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thea