n":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s2022"},"text":"section 2022 of this title","children":[],"tail":" takes effect under this subchapter for such vehicle or major replacement part” are omitted as obsolete because the standard applies to passenger motor vehicles and major replacement parts starting with the 1987 model year. See 50 Fed. Reg. 43166 (1985)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(5)(A), the words “of any kind” are omitted as unnecessary because of the definition of “chop shop” in section 33101 of the revised title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
