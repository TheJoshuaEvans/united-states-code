il":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2717(e)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31306(h)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2717(e)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31306(i)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2717(e)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31306(j)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2717(f)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2)(B), the words “may require” are substituted for “as determined by the Secretary” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), before subclause (A), the word “subsequent” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “of any individual” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(4), the words “by any individual” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(5), the word “tested” is substituted for “assayed” for consistency. The words “2d confirmation test” are substituted for “independent test” for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(6), the word “Secretary” is substituted for “Department” for consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “The Secretary of Transportation may provide” are substituted for “Nothing in subsection (a) of this section shall preclude the Secretary from providing” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the words “rule” and “ordinance” are omitted as being included in “law, regulation, standard, or order”. The words “whether the provisions apply specifically to commercial motor vehicle employees, or to the general public” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb71552f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb715530-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s5402/a/1/B"},"text":"Pub. L. 114–94, § 5402(a)(1)(B)","children":[],"tail":", struck out at end “The regulations shall permit such motor carriers to conduct preemployment testing of such employees for the use of alcohol.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B), (C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s5402/a/1/A"},"text":"Pub. L. 114–94, § 5402(a)(1)(A)","children":[],"tail":", (C), added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s5402/a/2"},"text":"Pub. L. 114–94, § 5402(a)(2)","children":[],"tail":", added subpar. (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s5402/a/3/A"},"text":"Pub. L. 114–94, § 5402(a)(3)(A)","children":[],"tail":", inserted “for urine testing, and technical guidelines for hair testing,” before “including mandatory guidelines” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s5402/a/3/B"},"text":"Pub. L. 114–94, § 5402(a)(3)(B)","children":[],"tail":"–(D), added subpar. (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" inserted “and section 31306a” after “this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/59"},"text":"Pub. L. 104–59","children":[],"tail":" added subpar. (A) and struck out former subpar. (A) which read as follows: “In the interest of commercial motor vehicle safety, the Secretary of Transportation shall prescribe regulations not later than "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"October 28, 1992","children":[],"tail":", that establish a program requiring motor carriers to conduct preemployment, reasonable suspicion, random, and post-accident testing of operators of commercial motor vehicles for the use of alcohol or a controlled substance in violation of law or a United States Government regulation.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb715531-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb715532-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb715533-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb715534-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Hair Testing Guidelines","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/271/tVIII/s8106"},"text":"Pub. L. 115–271, title VIII, § 8106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4106"},"text":"132 Stat. 4106","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/271/tVIII/s8106"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-10-24"},"text":"Oct. 24, 2018","children":[],"tail":"], and annually thereafter until the date that the Secretary of Health and Human Services publishes in the Federal Register a final notice of scientific and technical guidelines for hair testing in accordance with section 5402(b) of the Fixing America’s Surface Transportation Act ("},{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Public Law 114–94","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/129/1312"},"text":"129 Stat. 1312","children":[],"tail":") [set out below], the Secretary of Health and Human Services shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report on—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of the hair testing guidelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation for why the hair testing guidelines have not been issued; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimated date of completion of the hair testing guidelines.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent practicable and consistent with the objective of the hair testing described in subsection (a) to detect illegal or unauthorized use of substances by the individual being tested, the final notice of scientific and technical guidelines under that subsection, as determined by the Secretary of Health and Human Services, shall eliminate the risk of positive test results, of the individual being tested, caused solely by the drug use of others and not caused by the drug use of the individual being tested.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV/s5402/b"},"text":"Pub. L. 114–94, div. A, title V, § 5402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1548"},"text":"129 Stat. 1548","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tV/s5402/b"},"text":"“Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"], the Secretary of Health and Human Services shall issue scientific and technical guidelines for hair testing as a method of detecting the use of a controlled substance for purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31306"},"text":"section 31306 of title 49","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb715535-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Drug Test Results Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/tII/s226"},"text":"Pub. L. 106–159, title II, § 226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1771"},"text":"113 Stat. 1771","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/159/tII/s226"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall conduct a study of the feasibility and merits of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring medical review officers or employers to report all verified positive controlled substances test results on any driver subject to controlled substances testing under part 382 of title 49, Code of Federal Regulations, including the identity of each person tested and each controlled substance found, to the State that issued the driver’s commercial driver’s license; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring all prospective employers, before hiring any driver, to query the State that issued the driver’s commercial driver’s license on whether the State has on record any verified positive controlled substances test on such driver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study Factors","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the study under this section, the Secretary shall assess—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" methods for safeguarding the confidentiality of verified positive controlled substances test results;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs, benefits, and safety impacts of requiring States to maintain records of verified positive controlled substances test results; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether a process should be established to allow drivers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to correct errors in their records; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to expunge information from their records after a reasonable period of time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":"], the Secretary shall submit to Congress a report on the study carried out under this section, together with such recommendations as the Secretary determines appropriate.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb715536-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Post-Accident Alcohol Testing","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4020"},"text":"Pub. L. 105–178, title IV, § 4020","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/414"},"text":"112 Stat. 414","children":[],"tail":", required the Secretary of Transportation to conduct a study of the feasibility of utilizing law enforcement officers for conducting post-accident alcohol testing of commercial motor vehicle operators under this section to obtain more timely information and provided the study would also assess the impact of post-accident alcohol testing requirements on motor carrier employers, including any burden that employers may encounter in meeting the testing requirements under this section, and required the Secretary to transmit to Congress a report and recommendations on the study not later than 18 months after "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
