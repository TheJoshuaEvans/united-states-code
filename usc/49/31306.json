{"tag":"section","attrib":{"id":"idcb715506-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306"},"text":null,"children":[{"tag":"num","attrib":{"value":"31306"},"text":"§ 31306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alcohol and controlled substances testing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb715507-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section and section 31306a, “controlled substance” means any substance under section 102 of the Comprehensive Drug Abuse Prevention and Control Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":") specified by the Secretary of Transportation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb715508-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Testing Program for Operators of Commercial Motor Vehicles","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb715509-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb71550a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the interest of commercial motor vehicle safety, the Secretary of Transportation shall prescribe regulations that establish a program requiring motor carriers to conduct preemployment, reasonable suspicion, random, and post-accident testing of operators of commercial motor vehicles for the use of a controlled substance in violation of law or a United States Government regulation and to conduct reasonable suspicion, random, and post-accident testing of such operators for the use of alcohol in violation of law or a United States Government regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb71550b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The regulations prescribed under subparagraph (A) shall permit motor carriers—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb71550c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct preemployment testing of commercial motor vehicle operators for the use of alcohol; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb71550d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to use hair testing as an acceptable alternative to urine testing—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcb71550e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/b/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conducting preemployment testing for the use of a controlled substance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcb71550f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/b/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in conducting random testing for the use of a controlled substance if the operator was subject to hair testing for preemployment testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb715510-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Secretary of Transportation considers it appropriate in the interest of safety, the Secretary may prescribe regulations for conducting periodic recurring testing of operators of commercial motor vehicles for the use of alcohol or a controlled substance in violation of law or a Government regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb715511-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In prescribing regulations under this subsection, the Secretary of Transportation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb715512-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require that post-accident testing of an operator of a commercial motor vehicle be conducted when loss of human life occurs in an accident involving a commercial motor vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb715513-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may require that post-accident testing of such an operator be conducted when bodily injury or significant property damage occurs in any other serious accident involving a commercial motor vehicle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb715514-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide an exemption from hair testing for commercial motor vehicle operators with established religious beliefs that prohibit the cutting or removal of hair.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb715515-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Testing and Laboratory Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (b) of this section, the Secretary of Transportation shall develop requirements that shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb715516-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote, to the maximum extent practicable, individual privacy in the collection of specimens;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb715517-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for laboratories and testing procedures for controlled substances, incorporate the Department of Health and Human Services scientific and technical guidelines dated ","children":[{"tag":"date","attrib":{"date":"1988-04-11"},"text":"April 11, 1988","children":[],"tail":", and any amendments to those guidelines, for urine testing, and technical guidelines for hair testing, including mandatory guidelines establishing—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb715518-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comprehensive standards for every aspect of laboratory controlled substances testing and laboratory procedures to be applied in carrying out this section, including standards requiring the use of the best available technology to ensure the complete reliability and accuracy of controlled substances tests and strict procedures governing the chain of custody of specimens collected for controlled substances testing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb715519-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the minimum list of controlled substances for which individuals may be tested;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb71551a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate standards and procedures for periodic review of laboratories and criteria for certification and revocation of certification of laboratories to perform controlled substances testing in carrying out this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb71551b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" laboratory protocols and cut-off levels for hair testing to detect the use of a controlled substance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb71551c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require that a laboratory involved in testing under this section have the capability and facility, at the laboratory, of performing screening and confirmation tests;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb71551d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that any test indicating the use of alcohol or a controlled substance in violation of law or a Government regulation be confirmed by a scientifically recognized method of testing capable of providing quantitative information about alcohol or a controlled substance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb71551e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide that each specimen be subdivided, secured, and labeled in the presence of the tested individual and that a part of the specimen be retained in a secure manner to prevent the possibility of tampering, so that if the individual’s confirmation test results are positive the individual has an opportunity to have the retained part tested by a 2d confirmation test done independently at another certified laboratory if the individual requests the 2d confirmation test not later than 3 days after being advised of the results of the first confirmation test;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb71551f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure appropriate safeguards for testing to detect and quantify alcohol in breath and body fluid samples, including urine and blood, through the development of regulations that may be necessary and in consultation with the Secretary of Health and Human Services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb715520-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the confidentiality of test results and medical information (except information about alcohol or a controlled substance) of employees, except that this clause does not prevent the use of test results for the orderly imposition of appropriate sanctions under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb715521-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that employees are selected for tests by nondiscriminatory and impartial methods, so that no employee is harassed by being treated differently from other employees in similar circumstances.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb715522-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Testing as Part of Medical Examination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may provide that testing under subsection (a) of this section for operators subject to subpart E of part 391 of title 49, Code of Federal Regulations, be conducted as part of the medical examination required under that subpart.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb715523-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rehabilitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall prescribe regulations establishing requirements for rehabilitation programs that provide for the identification and opportunity for treatment of operators of commercial motor vehicles who are found to have used alcohol or a controlled substance in violation of law or a Government regulation. The Secretary shall decide on the circumstances under which those operators shall be required to participate in a program. This section does not prevent a motor carrier from establishing a program under this section in cooperation with another motor carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb715524-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sanctions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall decide on appropriate sanctions for a commercial motor vehicle operator who is found, based on tests conducted and confirmed under this section, to have used alcohol or a controlled substance in violation of law or a Government regulation but who is not under the influence of alcohol or a controlled substance as provided in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb715525-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect on State and Local Government Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State or local government may not prescribe or continue in effect a law, regulation, standard, or order that is inconsistent with regulations prescribed under this section. However, a regulation prescribed under this section may not be construed to preempt a State criminal law that imposes sanctions for reckless conduct leading to loss of life, injury, or damage to property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb715526-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"International Obligations and Foreign Laws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In prescribing regulations under this section, the Secretary of Transportation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb715527-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish only requirements that are consistent with international obligations of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb715528-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall consider applicable laws and regulations of foreign countries.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb715529-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other Regulations Allowed","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not prevent the Secretary of Transportation from continuing in effect, amending, or further supplementing a regulation prescribed before ","children":[{"tag":"date","attrib":{"date":"1991-10-28"},"text":"October 28, 1991","children":[],"tail":", governing the use of alcohol or a controlled substance by commercial motor vehicle employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb71552a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31306/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not supersede a penalty applicable to an operator of a commercial motor vehicle under this chapter or another law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb71552b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1017"},"text":"108 Stat. 1017","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/59/tIII/s342/c"},"text":"Pub. L. 104–59, title III, § 342(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-11-28"},"text":"Nov. 28, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/609"},"text":"109 Stat. 609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32402/a/1"},"text":"Pub. L. 112–141, div. C, title II, § 32402(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/795"},"text":"126 Stat. 795","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV/s5402/a"},"text":"Pub. L. 114–94, div. A, title V, § 5402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1547"},"text":"129 Stat. 1547","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb71552c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb71552d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb71552e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31306(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2717(g).","children":[],"tail":