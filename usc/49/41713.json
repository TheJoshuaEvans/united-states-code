ority” is substituted for “agency” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the word “rule” is omitted as being synonymous with “regulation”. The words “standard” and “having authority” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “pursuant to a certificate issued by the Board”, “by air of persons, property, or mail”, and “the State of” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbc4cbc1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:41713(b)(4)(B)(ii) to correct a cross-reference necessary because of the restatement of subtitle IV of title 49 by the ICC Termination Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Public Law 104–88","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/803"},"text":"109 Stat. 803","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbc4cbc2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbc4cbc3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(4)(B)(ii). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" substituted “13102” for “10102”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/s601/b/2/A"},"text":"Pub. L. 103–305, § 601(b)(2)(A)","children":[],"tail":", substituted “Paragraphs (1) and (4) of this subsection do” for “Paragraph (1) of this subsection does”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/s601/b/1"},"text":"Pub. L. 103–305, § 601(b)(1)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbc4cbc4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbc4cbc5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305"},"text":"Pub. L. 103–305","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1995-01-01"},"text":"Jan. 1, 1995","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/305/s601/d"},"text":"section 601(d) of Pub. L. 103–305","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s10521"},"text":"section 10521 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
