{"tag":"section","attrib":{"id":"idcbc4cbb1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41713"},"text":null,"children":[{"tag":"num","attrib":{"value":"41713"},"text":"§ 41713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preemption of authority over prices, routes, and service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbc4cbb2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41713/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, “State” means a State, the District of Columbia, and a territory or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc4cbb3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41713/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preemption","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc4cbb4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41713/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in this subsection, a State, political subdivision of a State, or political authority of at least 2 States may not enact or enforce a law, regulation, or other provision having the force and effect of law related to a price, route, or service of an air carrier that may provide air transportation under this subpart.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc4cbb5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41713/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (1) and (4) of this subsection do not apply to air transportation provided entirely in Alaska unless the transportation is air transportation (except charter air transportation) provided under a certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc4cbb6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41713/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not limit a State, political subdivision of a State, or political authority of at least 2 States that owns or operates an airport served by an air carrier holding a certificate issued by the Secretary of Transportation from carrying out its proprietary powers and rights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc4cbb7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41713/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation by air carrier or carrier affiliated with a direct air carrier.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbc4cbb8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41713/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General rule","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subparagraph (B), a State, political subdivision of a State, or political authority of 2 or more States may not enact or enforce a law, regulation, or other provision having the force and effect of law related to a price, route, or service of an air carrier or carrier affiliated with a direct air carrier through common controlling ownership when such carrier is transporting property by aircraft or by motor vehicle (whether or not such property has had or will have a prior or subsequent air movement).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc4cbb9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41713/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matters not covered","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbc4cbba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41713/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not restrict the safety regulatory authority of a State with respect to motor vehicles, the authority of a State to impose highway route controls or limitations based on the size or weight of the motor vehicle or the hazardous nature of the cargo, or the authority of a State to regulate motor carriers with regard to minimum amounts of financial responsibility relating to insurance requirements and self-insurance authorization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbc4cbbb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41713/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not apply to the transportation of household goods, as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s13102"},"text":"section 13102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc4cbbc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41713/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of paragraph (1)","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This paragraph shall not limit the applicability of paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbc4cbbd-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1143"},"text":"108 Stat. 1143","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/305/tVI/s601/b/1"},"text":"Pub. L. 103–305, title VI, § 601(b)(1)","children":[],"tail":", (2)(A), "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1605"},"text":"108 Stat. 1605","children":[],"tail":", 1606; "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/23"},"text":"Pub. L. 105–102, § 2(23)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2205"},"text":"111 Stat. 2205","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbc4cbbe-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbc4