{"tag":"section","attrib":{"id":"idcb35ab72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24701"},"text":null,"children":[{"tag":"num","attrib":{"value":"24701"},"text":"§ 24701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National rail passenger transportation system","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Amtrak shall operate a national rail passenger transportation system which ties together existing and emergent regional rail passenger service and other intermodal passenger service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb35ab73-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/923"},"text":"108 Stat. 923","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/134/tI/s101/a/1"},"text":"Pub. L. 105–134, title I, § 101(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2572"},"text":"111 Stat. 2572","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb35ab74-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb35ab75-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb35ab76-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24701(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:561(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/518/s401/b"},"text":"Pub. L. 91–518, § 401(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1335"},"text":"84 Stat. 1335","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24701(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:561(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/518/s401/c"},"text":"Pub. L. 91–518, § 401(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1335"},"text":"84 Stat. 1335","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 3, 1973","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/146/s9"},"text":"Pub. L. 93–146, § 9","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/551"},"text":"87 Stat. 551","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the text of 45:561(b) (1st sentence words after 3d comma) is omitted as obsolete because no regional transportation authority provided intercity rail passenger transportation after ","children":[{"tag":"date","attrib":{"date":"1971-05-01"},"text":"May 1, 1971","children":[],"tail":". The words “On "},{"tag":"date","attrib":{"date":"1971-05-01"},"text":"May 1, 1971","children":[],"tail":"” and “begin” are omitted as executed. The words “between points” and “either” are omitted as surplus. In clause (2), the words “under contract with Amtrak” are substituted for 45:561(b) (last sentence) for clarity and to eliminate unnecessary words. The words “at any time subsequent to "},{"tag":"date","attrib":{"date":"1971-05-01"},"text":"May 1, 1971","children":[],"tail":"” are omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “concerning auto-ferry service . . . railroad or any other” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb35ab77-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb35ab78-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134"},"text":"Pub. L. 105–134","children":[],"tail":" substituted section catchline for former catchline which read “Operation of basic system” and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"By Amtrak","children":[],"tail":".—Amtrak shall provide intercity rail passenger transportation within the basic system unless the transportation is provided by—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) a rail carrier with which Amtrak did not make a contract under section 401(a) of the Rail Passenger Service Act; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) a regional transportation authority under contract with Amtrak.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"By Others With Consent of Amtrak","children":[],"tail":".—Except as provided in "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s24306"},"text":"section 24306 of this title","children":[],"tail":", a person may provide intercity rail passenger transportation over a route over which Amtrak provides scheduled intercity rail passenger transportation under a contract under section 401(a) of the Act only with the consent of Amtrak.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
