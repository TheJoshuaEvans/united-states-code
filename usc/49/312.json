{"tag":"section","attrib":{"id":"idca6d51ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312"},"text":null,"children":[{"tag":"num","attrib":{"value":"312"},"text":"§ 312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Alternative timing system","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca6d51cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to the availability of appropriations, the Secretary of Transportation shall provide for the establishment, sustainment, and operation of a resilient,","children":[{"tag":"ref","attrib":{"idref":"fn002011"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002011"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The comma probably should not appear."}],"tail":" and reliable alternative timing system—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6d51d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce critical dependencies and provide a complement to and backup for the timing component of the Global Positioning System (referred to in this section as “GPS”); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d51d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the availability of uncorrupted and non-degraded timing signals for military and civilian users in the event that GPS timing signals are corrupted, degraded, unreliable, or otherwise unavailable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6d51d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6d51d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of enactment of the National Timing Resilience and Security Act of 2018, the Secretary of Transportation shall establish requirements for the procurement of the system required by subsection (a) as a complement to and backup for the timing component of GPS in accordance with the timing requirements study required by section 1618 of the National Defense Authorization Act for Fiscal Year 2017 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328"},"text":"Public Law 114–328","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/130/2595"},"text":"130 Stat. 2595","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d51d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall ensure, to the maximum extent practicable, that the system established under subsection (a) will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca6d51d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be wireless;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be terrestrial;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide wide-area coverage;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be synchronized with coordinated universal time;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be resilient and extremely difficult to disrupt or degrade;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be able to penetrate underground and inside buildings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be capable of deployment to remote locations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be developed, constructed, and operated incorporating applicable private sector expertise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" work in concert with and complement any other similar positioning, navigation, and timing systems, including enhanced long-range navigation systems and Nationwide Differential GPS systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be available for use by Federal and non-Federal government agencies for public purposes at no net cost to the Federal Government within 10 years of initiation of operation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be capable of adaptation and expansion to provide position and navigation capabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate the recommendations from any GPS back-up demonstration program initiated and completed by the Secretary, in coordination with other Federal agencies, before the date specified in subsection (c)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/b/2/M"},"text":null,"children":[{"tag":"num","attrib":{"value":"M"},"text":"(M)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate such other elements as the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6d51e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6d51e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of the National Timing Resilience and Security Act of 2018, the Secretary of Transportation shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report setting forth the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca6d51e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A plan to develop, construct, and operate the system required by subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A description and assessment of the advantages of a system to provide a follow-on complementary and backup positioning and navigation capability to the timing component of GPS.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d51e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for commencement of operation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The system required by subsection (a) shall be in operation by not later than 2 years after the date of enactment of the National Timing Resilience and Security Act of 2018.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d51e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum duration of operational capability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The system required by subsection (a) shall be designed to be fully operational for not less than 20 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6d51e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"LORAN Facilities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6d51e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary of Transportation determines that any LORAN infrastructure, including the underlying real property and any spectrum associated with LORAN, in the possession of the Coast Guard is required by the Department of Transportation for the purpose of establishing the system required by subsection (a), the Commandant shall transfer such property, spectrum, and equipment to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d51ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"CERCLA not affected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection shall not be construed to limit the application of or otherwise affect section 120(h) of the Comprehensive Environmental Response, Compensation, and Liability Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s9620/h"},"text":"42 U.S.C. 9620(h)","children":[],"tail":") with respect to the Federal Government facilities described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6d51eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Agreement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6d51ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may enter into a cooperative agreement (as that term is described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6305"},"text":"section 6305 of title 31","children":[],"tail":") with an entity upon such terms and conditions as the Secretary of Transportation determines will fulfill the purpose and requirements of this section and be in the public interest."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d51ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The cooperative agreement under paragraph (1) shall, at a minimum, require the Secretary of Transportation to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca6d51ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorize the entity to sell timing and other services to commercial and non-commercial third parties, subject to any national security requirements determined by the Secretary, in consultation with the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the entity to develop, construct, and operate at private expense the backup timing system in accordance with this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the entity to make any investments in technologies necessary over the life of such agreement to meet future requirements for advanced timing resilience and technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the entity to share 25 percent of the gross proceeds received by the entity from the sale of timing services to third parties with the Secretary for at least 10 years after the date upon which the Secretary enters into the cooperative agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require the entity—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca6d51f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to assume all financial risk for the completion and operational capability of the system, after the Secretary provides any LORAN facilities necessary for the system under subsection (d), if required for the alternative timing system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca6d51f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to furnish performance and payment bonds in connection with the system in a reasonable amount as determined by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca6d51f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require the entity to make any investments in technologies necessary over the life of the agreement to meet future requirements for advanced timing resiliency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d51f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Competition required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall use competitive procedures similar to those authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2667"},"text":"section 2667 of title 10","children":[],"tail":" in selecting an entity to enter into a cooperative agreement pursuant to this subsection."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d51f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization to purchase services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not purchase timing system services from the entity for use by the Department of Transportation or for provision to other Federal and non-Federal governmental agencies until the system achieves operational status, and then only if the necessary funds for such purchases are provided for in subsequent yearly appropriations acts made available to the Secretary for each and every year in which such purchases are made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d51f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not enter into a cooperative agreement under this subsection unless the Secretary determines that the cooperative agreement is in the best financial interest of the Federal Government. The Secretary shall notify the Committee on Committee on ","children":[{"tag":"ref","attrib":{"idref":"fn002012"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002012"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original."}],"tail":" Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives of such determination not later than 30 days after the date of the determination."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6d51f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s312/e/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection the term “entity” means a non-Federal entity with the demonstrated technical expertise and requisite administrative and financial resources to meet any terms and conditions established by the Secretary for purposes of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca6d51fa-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/tV/s514/b"},"text":"Pub. L. 115–282, title V, § 514(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/4276"},"text":"132 Stat. 4276","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dG/tLVXXXV"},"text":"Pub. L. 116–283, div. G, title LVXXXV","children":[],"tail":" [LXXXV], § 8507(d)(2), "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4754"},"text":"134 Stat. 4754","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/103/dL/tI/s109A"},"text":"Pub. L. 117–103, div. L, title I, § 109A","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/691"},"text":"136 Stat. 691","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca6d51fb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca6d51fc-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca6d51fd-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the National Timing Resilience and Security Act of 2018, referred to in subsecs. (b)(1) and (c)(1), (2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/282/s514"},"text":"section 514 of Pub. L. 115–282","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-12-04"},"text":"Dec. 4, 2018","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 1618 of the National Defense Authorization Act for Fiscal Year 2017, referred to in subsec. (b)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/328/s1618"},"text":"section 1618 of Pub. L. 114–328","children":[],"tail":", div. A, title XVI, "},{"tag":"date","attrib":{"date":"2016-12-23"},"text":"Dec. 23, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/2595"},"text"