{"tag":"section","attrib":{"id":"idcae233ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901"},"text":null,"children":[{"tag":"num","attrib":{"value":"10901"},"text":"§ 10901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorizing construction and operation of railroad lines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcae233af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcae233b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construct an extension to any of its railroad lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae233b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" construct an additional railroad line;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae233b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide transportation over, or by means of, an extended or additional railroad line; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae233b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a person other than a rail carrier, acquire a railroad line or acquire or operate an extended or additional railroad line,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"only if the Board issues a certificate authorizing such activity under subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae233b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A proceeding to grant authority under subsection (a) of this section begins when an application is filed. On receiving the application, the Board shall give reasonable public notice, including notice to the Governor of any affected State, of the beginning of such proceeding.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae233b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall issue a certificate authorizing activities for which such authority is requested in an application filed under subsection (b) unless the Board finds that such activities are inconsistent with the public convenience and necessity. Such certificate may approve the application as filed, or with modifications, and may require compliance with conditions (other than labor protection conditions) the Board finds necessary in the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae233b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcae233b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When a certificate has been issued by the Board under this section authorizing the construction or extension of a railroad line, no other rail carrier may block any construction or extension authorized by such certificate by refusing to permit the carrier to cross its property if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcae233b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the construction does not unreasonably interfere with the operation of the crossed line;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcae233b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation does not materially interfere with the operation of the crossed line; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcae233ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner of the crossing line compensates the owner of the crossed line.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae233bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10901/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the parties are unable to agree on the terms of operation or the amount of payment for purposes of paragraph (1) of this subsection, either party may submit the matters in dispute to the Board for determination. The Board shall make a determination under this paragraph within 120 days after the dispute is submitted for determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcae233bc-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/822"},"text":"109 Stat. 822","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcae233bd-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcae233be-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcae233bf-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 10901, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1402"},"text":"92 Stat. 1402","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/tII/s221"},"text":"Pub. L. 96–448, title II, § 221","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1928"},"text":"94 Stat. 1928","children":[],"tail":", related to authorizing construction and operation of railroad lines, prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcae233c0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcae233c1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
