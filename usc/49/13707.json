{"tag":"section","attrib":{"id":"idcaf5471f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13707"},"text":null,"children":[{"tag":"num","attrib":{"value":"13707"},"text":"§ 13707.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payment of rates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf54720-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13707/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of Possession Upon Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), a carrier providing transportation or service subject to jurisdiction under this part shall give up possession at the destination of the property transported by it only when payment for the transportation or service is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf54721-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13707/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf54722-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13707/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Under regulations of the Secretary governing the payment for transportation and service and preventing discrimination, those carriers may give up possession at destination of property transported by them before payment for the transportation or service. The regulations of the Secretary may provide for weekly or monthly payment for transportation provided by motor carriers and for periodic payment for transportation provided by water carriers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf54723-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13707/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extensions of credit to governmental entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Such a carrier (including a motor carrier being used by a household goods freight forwarder) may extend credit for transporting property for the United States Government, a State, a territory or possession of the United States, or a political subdivision of any of them.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf54724-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13707/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Shipments of household goods.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf54725-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13707/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A carrier providing transportation of a shipment of household goods shall give up possession of the household goods being transported at the destination upon payment of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcaf54726-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13707/b/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 100 percent of the charges contained in a binding estimate provided by the carrier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf54727-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13707/b/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 110 percent of the charges contained in a nonbinding estimate provided by the carrier; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf54728-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13707/b/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a partial delivery of the shipment, the prorated percentage of the charges calculated in accordance with subparagraph (B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf54729-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13707/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Calculation of prorated charges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subparagraph (A)(iii), the prorated percentage of the charges shall be the percentage of the total charges due to the carrier as described in clause (i) or (ii) of subparagraph (A) that is equal to the percentage of the weight of that portion of the shipment delivered to the total weight of the shipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf5472a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13707/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Post-contract services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subparagraph (A) does not apply to additional services requested by a shipper after the contract of service is executed that were not included in the estimate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf5472b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13707/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Impracticable operations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subparagraph (A) does not apply to impracticable operations, as defined by the applicable carrier tariff, except that the charges collected at delivery for such operations shall not exceed 15 percent of all other charges due at delivery. Any remaining charges due shall be paid within 30 days after the carrier presents its freight bill.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf5472c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/873"},"text":"109 Stat. 873","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4203"},"text":"Pub. L. 109–59, title IV, § 4203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1752"},"text":"119 Stat. 1752","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf5472d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf5472e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf5472f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10743"},"text":"section 10743 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcaf54730-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" added par. (3)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaf54731-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcaf54732-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
