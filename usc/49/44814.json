{"tag":"section","attrib":{"id":"idcc184365-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44814"},"text":null,"children":[{"tag":"num","attrib":{"value":"44814"},"text":"§ 44814.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ASSUREd Safe credentialing authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc184366-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44814/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 6 months after the date of enactment of this section, the Administrator of the Federal Aviation Administration shall establish a credentialing authority for the program of record of the Federal Aviation Administration (referred to in this section as “ASSUREd Safe”) under the Center of Excellence for Unmanned Aircraft Systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc184367-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44814/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"ASSUREd Safe shall offer services throughout the United States, and to allies and partners of the United States, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc184368-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44814/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" online and in-person standards, education, and testing for the use of unmanned aircraft systems by first responders for emergency and disaster management operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc184369-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44814/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uniform communications standards, operational standards, and reporting standards for civilian, military, and international allies and partners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc18436a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44814/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other relevant standards development related to operation of unmanned aircraft systems, as determined appropriate by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc18436b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44814/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall ensure that the Center of Excellence for Unmanned Aircraft Systems coordinates with the National Institute of Standards and Technology and the Federal Emergency Management Agency on establishment of ASSUREd Safe, and on any services offered by ASSUREd Safe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc18436c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tX/s1007/a"},"text":"Pub. L. 118–63, title X, § 1007(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1389"},"text":"138 Stat. 1389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc18436d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc18436e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc18436f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
