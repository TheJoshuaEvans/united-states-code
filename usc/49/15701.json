{"tag":"section","attrib":{"id":"idcb08590a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15701"},"text":null,"children":[{"tag":"num","attrib":{"value":"15701"},"text":"§ 15701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Providing transportation and service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb08590b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service on Reasonable Request","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A pipeline carrier providing transportation or service under this part shall provide the transportation or service on reasonable request.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb08590c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rates and Other Terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A pipeline carrier shall also provide to any person, on request, the carrier’s rates and other service terms. The response by a pipeline carrier to a request for the carrier’s rates and other service terms shall be—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb08590d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in writing and forwarded to the requesting person promptly after receipt of the request; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb08590e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promptly made available in electronic form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb08590f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Rate Increases and Changes to Service Terms","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A pipeline carrier may not increase any common carrier rates or change any common carrier service terms unless 20 days have expired after written or electronic notice is provided to any person who, within the previous 12 months—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb085910-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15701/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has requested such rates or terms under subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb085911-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15701/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has made arrangements with the carrier for a shipment that would be subject to such increased rates or changed terms.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb085912-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15701/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Provision of Service","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A pipeline carrier shall provide transportation or service in accordance with the rates and service terms, and any changes thereto, as published or otherwise made available under subsection (b) or (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb085913-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15701/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall, by regulation, establish rules to implement this section. The regulations shall provide for immediate disclosure and dissemination of rates and service terms, including classifications, rules, and practices, and their effective dates. The regulations may modify the 20-day period specified in subsection (c). Final regulations shall be adopted by the Board not later than 180 days after ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb085914-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s106/a"},"text":"Pub. L. 104–88, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/925"},"text":"109 Stat. 925","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/44"},"text":"Pub. L. 104–287, § 5(44)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3393"},"text":"110 Stat. 3393","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb085915-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb085916-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb085917-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11101"},"text":"section 11101 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb085918-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"” for “the effective date of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb085919-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb08591a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
