{"tag":"section","attrib":{"id":"idcafa012e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904"},"text":null,"children":[{"tag":"num","attrib":{"value":"13904"},"text":"§ 13904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of brokers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcafa012f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall register, subject to section 13906(b), a person to be a broker for transportation of property subject to jurisdiction under subchapter I of chapter 135, if the Secretary determines that the person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafa0130-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has sufficient experience to qualify the person to act as a broker for transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafa0131-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is fit, willing, and able to be a broker for transportation and to comply with this part and applicable regulations of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafa0132-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A registration issued under subsection (a) shall only remain in effect while the broker for transportation is in compliance with section 13906(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafa0133-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Experience or Training Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each broker shall employ, as an officer, an individual who—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafa0134-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has at least 3 years of relevant experience; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafa0135-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the Secretary with satisfactory evidence of the individual’s knowledge of related rules, regulations, and industry practices.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafa0136-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registration as Motor Carrier Required.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafa0137-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A broker for transportation may not provide transportation as a motor carrier unless the broker has registered separately under this chapter to provide transportation as a motor carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafa0138-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not apply to a motor carrier registered under this chapter or to an employee or agent of the motor carrier to the extent the transportation is to be provided entirely by the motor carrier, with other registered motor carriers, or with rail or water carriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafa0139-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulation to Protect Motor Carriers and Shippers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Regulations of the Secretary applicable to brokers registered under this section shall provide for the protection of motor carriers and shippers by motor vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafa013a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bond and Insurance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may impose on brokers for motor carriers of passengers such requirements for bonds or insurance or both as the Secretary determines are needed to protect passengers and carriers dealing with such brokers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafa013b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13904/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Update of Registration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require a broker to update its registration under this section not later than 30 days after a change in the broker’s address, other contact information, officers, process agent, or other essential information, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcafa013c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/884"},"text":"109 Stat. 884","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4142/c"},"text":"Pub. L. 109–59, title IV, § 4142(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1747"},"text":"119 Stat. 1747","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/tIII/s305/e"},"text":"Pub. L. 110–244, title III, § 305(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1620"},"text":"122 Stat. 1620","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII"},"text":"Pub. L. 112–141, div. C, title II","children":[],"tail":", §§ 32107(c), 32916(b), "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/782"},"text":"126 Stat. 782","children":[],"tail":", 821.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcafa013d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcafa013e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcafa013f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32916/b/1"},"text":"Pub. L. 112–141, § 32916(b)(1)","children":[],"tail":", substituted “determines that the person—” for “finds that the person is fit”, added par. (1), and inserted par. (2) designation and “is fit” before “, willing”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32916/b/3"},"text":"Pub. L. 112–141, § 32916(b)(3)","children":[],"tail":", added subsecs. (b) and (c). Former subsecs. (b) and (c) redesignated (d) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32916/b/4"},"text":"Pub. L. 112–141, § 32916(b)(4)","children":[],"tail":", amended subsec. (d) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—The broker may provide the transportation itself only if the broker also has been registered to provide the transportation as a motor carrier under this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—This subsection does not apply to a motor carrier registered under this chapter or to an employee or agent of the motor carrier to the extent the transportation is to be provided entirely by the motor carrier, with other registered motor carriers, or with rail or water carriers.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32916/b/2"},"text":"Pub. L. 112–141, § 32916(b)(2)","children":[],"tail":", redesignated subsec. (b) as (d). Former subsec. (d) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32916/b/5"},"text":"Pub. L. 112–141, § 32916(b)(5)","children":[],"tail":", amended subsec. (e) generally. Prior to amendment, text read as follows: “Regulations of the Secretary applicable to brokers registered under this section shall provide for the protection of shippers by motor vehicle.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32916/b/2"},"text":"Pub. L. 112–141, § 32916(b)(2)","children":[],"tail":", redesignated subsec. (c) as (e). Former subsec. (e) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32107/c"},"text":"Pub. L. 112–141, § 32107(c)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32916/b/2"},"text":"Pub. L. 112–141, § 32916(b)(2)","children":[],"tail":", redesignated subsecs. (d) and (e) as (f) and (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" amended subsec. (a) generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) ","children":[{"tag":"inline","attrib":{},"text":"Household Goods","children":[],"tail":".—The Secretary shall register, subject to section 13906(b), a person to be a broker of household goods for transportation of property subject to jurisdiction under subchapter I of chapter 135, if the Secretary finds that the person is fit, willing, and able to be a broker of household goods for transportation and to comply with this part and applicable regulations of the Secretary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) ","children":[{"tag":"inline","attrib":{},"text":"Others","children":[],"tail":".—The Secretary may register a person to provide service subject to jurisdiction under subchapter III of chapter 135 as a broker (other than a broker of household goods) if the Secretary finds that such registration is needed for the protection of shippers and that the person is fit, willing, and able to provide the service and to comply with this part and applicable regulations of the Secretary and Board.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4142/c/1"},"text":"Pub. L. 109–59, § 4142(c)(1)","children":[],"tail":", (3), designated existing provisions as par. (1), inserted heading, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4142/c/2"},"text":"Pub. L. 109–59, § 4142(c)(2)","children":[],"tail":", which directed amendment of par. (1) by inserting “of household goods” after “broker”, was executed by making the insertion in two places to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcafa0140-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcafa0141-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcafa0142-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
