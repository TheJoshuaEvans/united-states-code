l,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2101(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Feb. 18, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/193/s101/3"},"text":"Pub. L. 96–193, § 101(3)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/50"},"text":"94 Stat. 50","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47501(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2101(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Feb. 18, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/193/s101/2"},"text":"Pub. L. 96–193, § 101(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/50"},"text":"94 Stat. 50","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/248/s524/b/2"},"text":"Pub. L. 97–248, § 524(b)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/696"},"text":"96 Stat. 696","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(b)(1)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(b)(1)(E); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/e"},"text":"Pub. L. 98–443, § 3(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “the term” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the text of 49 App.:2101(3) is omitted as surplus because the complete name of the Secretary of Transportation is used the first time the term appears in a section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the word “valid” is omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc648eb7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc648eb8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Part 150 Noise Standards Update","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s786"},"text":"Pub. L. 118–63, title VII, § 786","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1313"},"text":"138 Stat. 1313","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tVII/s786"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"], the Administrator [of the Federal Aviation Administration] shall review and revise, as appropriate, part 150 of title 14, Code of Federal Regulations, to reflect all relevant laws and regulations, including part 161 of title 14, Code of Federal Regulations."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outreach","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As part of the review conducted under subsection (a), the Administrator shall clarify existing and future noise policies and standards and seek feedback from airports, airport users, and individuals living in the vicinity of airports and in airport adjacent communities before implementing any changes to any noise policies or standards.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of this Act, and every 6 months thereafter, the Administrator shall brief the appropriate committees of Congress [Committee on Commerce, Science, and Transportation of the Senate and Committee on Transportation and Infrastructure of the House of Representatives] regarding the review conducted under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The requirement under subsection (c) shall terminate on the earlier of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"date","attrib":{"date":"2028-10-01"},"text":"October 1, 2028","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which 1 briefing is provided under subsection (c) after the changes in subsection (a) are implemented.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc648eb9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reducing Community Aircraft Noise Exposure","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s787"},"text":"Pub. L. 118–63, title VII, § 787","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1313"},"text":"138 Stat. 1313","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tVII/s787"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“In implementing or substantially revising a flight procedure, the Administrator [of the Federal Aviation Administration] shall consider the following actions (to the extent that such actions do not negatively affect aviation safety or efficiency) to reduce undesirable aircraft noise:","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Implement flight procedures that can mitigate the impact of aircraft noise, based on a consensus community recommendation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Work with airport sponsors and potentially impacted neighboring communities in establishing or modifying aircraft arrival and departure routes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In collaboration with local governments, discourage local encroachment of residential or other buildings near airports that could create future aircraft noise complaints or impact airport operations or aviation safety.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc648eba-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Information Sharing Requirement","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s794"},"text":"Pub. L. 118–63, title VII, § 794","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1319"},"text":"138 Stat. 1319","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tVII/s794"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"], the Secretary [of Transportation], acting through the Administrator [of the Federal Aviation Administration], shall establish a mechanism to make helicopter noise complaint data accessible to the FAA [Federal Aviation Administration], to helicopter operators operating in the Washington, DC area, and to the public on a website of the FAA, based on the recommendation of the Government Accountability Office in the report titled ‘Aircraft Noise: Better Information Sharing Could Improve Responses to Washington, D.C. Area Helicopter Noise Concerns’, published on "},{"tag":"date","attrib":{"date":"2021-01-07"},"text":"January 7, 2021","children":[],"tail":" (GAO–21–200)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any helicopter operator operating in the Washington, DC area shall, to the extent practicable, provide helicopter noise complaint data to the FAA through the mechanism established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Helicopter noise complaint data","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘helicopter noise complaint data’—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means general data relating to a complaint made by an individual about helicopter noise in the Washington, DC area and may include—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location and description of the event that is the subject of the complaint;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the start and end time of such event;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"“(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the aircraft that is the subject of the complaint; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"“(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the airport name associated with such event; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the personally identifiable information of the individual who submitted the complaint.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Washington, dc area","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘Washington, DC area’ means the area inside of a 30-mile radius surrounding Ronald Reagan Washington National Airport.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc66d7ab-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Mitigation of Military Helicopter Noise","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283/dA/tX/s1087"},"text":"Pub. L. 116–283, div. A, title X, § 1087","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/3877"},"text":"134 Stat. 3877","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/116/283/dA/tX/s1087"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Process for Tracking Complaints","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Defense, in coordination with the Metropolitan Washington Airports Authority, shall develop a process to receive, track, and analyze complaints of military rotary wing aircraft noise in the National Capital Region that are registered on the noise inquiry websites of Ronald Reagan Washington National Airport and Dulles International Airport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Capital Region","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term ‘National Capital Region’ has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s2674/f/2"},"text":"section 2674(f)(2) of title 10","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc66d7ac-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Addressing Community Noise Concerns","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tI/s175"},"text":"Pub. L. 115–254, div. B, title I, § 175","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3228"},"text":"132 Stat. 3228","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dB/tI/s175"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“When proposing a new area navigation departure procedure, or amending an existing procedure that would direct aircraft between the surface and 6,000 feet above ground level over noise sensitive areas, the Administrator of the Federal Aviation Administration shall consider the feasibility of dispersal headings or other lateral track variations to address community noise concerns, if—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the affected airport operator, in consultation with the affected community, submits a request to the Administrator for such a consideration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the airport operator’s request would not, in the judgment of the Administrator, conflict with the safe and efficient operation of the national airspace system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect of a modified departure procedure would not significantly increase noise over noise sensitive areas, as determined by the Administrator.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc66d7ad-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Aviation Noise Complaints","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tV/s510"},"text":"Pub. L. 112–95, title V, § 510","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/107"},"text":"126 Stat. 107","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/95/tV/s510"},"text":"“Not later than 90 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":"], each owner or operator of a large hub airport (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102/a"},"text":"section 40102(a) of title 49","children":[],"tail":", United States Code) shall publish on an Internet Web site of the airport a telephone number to receive aviation noise complaints related to the airport.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc66d7ae-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Airport Noise Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tVII/s745"},"text":"Pub. L. 106–181, title VII, § 745","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/178"},"text":"114 Stat. 178","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/106/528/s7/a"},"text":"Pub. L. 106–528, § 7(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-22"},"text":"Nov. 22, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2521"},"text":"114 Stat. 2521","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/528/s7/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of Transportation] shall enter into an agreement with the National Academy of Sciences to conduct a study on airport noise in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of Study","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the study, the National Academy of Sciences shall examine—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the threshold of noise at which health begins to be affected;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effectiveness of noise abatement programs at airports located in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impacts of aircraft noise on communities, including schools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the noise assessment practices of the Federal Aviation Administration and whether such practices fairly and accurately reflect the burden of noise on communities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of the agreement entered into under subsection (a), the National Academy of Sciences shall transmit to the Secretary a report on the results of the study. Upon receipt of the report, the Secretary shall transmit a copy of the report to the appropriate committees of Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated such sums as may be necessary to carry out this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc66d7af-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Nonmilitary Helicopter Noise","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tVII/s747"},"text":"Pub. L. 106–181, title VII, § 747","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/179"},"text":"114 Stat. 179","children":[],"tail":", required the Secretary of Transportation to conduct a study on the effects of nonmilitary helicopter noise on individuals in densely populated areas in the continental United States and develop recommendations for the reduction of the effects of nonmilitary helicopter noise, focusing on air traffic control procedures to address helicopter noise problems and the needs of law enforcement, considering the views of representatives of the helicopter industry, and report to Congress a report on the study not later than 1 year after "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
