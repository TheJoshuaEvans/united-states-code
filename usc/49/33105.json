{"tag":"section","attrib":{"id":"idcb8ddd2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33105"},"text":null,"children":[{"tag":"num","attrib":{"value":"33105"},"text":"§ 33105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cost limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb8ddd2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Manufacturer Costs","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A standard under section 33102 or 33103 of this title may not impose—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8ddd2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a manufacturer of motor vehicles, compliance costs of more than $15 a motor vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddd2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on a manufacturer of major replacement parts, compliance costs for each part of more than the reasonable amount (but less than $15) that the Secretary of Transportation specifies in the standard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8ddd30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Costs Involved in Engines and Transmissions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For a manufacturer engaged in identifying engines or transmissions on ","children":[{"tag":"date","attrib":{"date":"1984-10-25"},"text":"October 25, 1984","children":[],"tail":", in a way that substantially complies with the standard—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8ddd31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs of identifying engines and transmissions may not be considered in calculating the manufacturer’s costs under subsection (a) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddd32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manufacturer may not be required under the standard to conform to any identification system for engines and transmissions that imposes greater costs on the manufacturer than are incurred under the identification system used by the manufacturer on ","children":[{"tag":"date","attrib":{"date":"1984-10-25"},"text":"October 25, 1984","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8ddd33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost Adjustments","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8ddd34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8ddd35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33105/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “base period” means calendar year 1984.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8ddd36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33105/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “price index” means the average over a calendar year of the Consumer Price Index (all items—United States city average) published monthly by the Secretary of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddd37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At the beginning of each calendar year, as necessary data become available from the Bureau of Labor Statistics, the Secretary of Labor shall certify to the Secretary of Transportation and publish in the Federal Register the percentage difference between the price index for the 12 months before the beginning of the calendar year and the price index for the base period. For model years beginning in that calendar year, the amounts specified in subsection (a) of this section shall be adjusted by the percentage difference.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb8ddd38-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1081"},"text":"108 Stat. 1081","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb8ddd39-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb8ddd3a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb8ddd3b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"33105","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2024.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 20, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/513"},"text":"Pub. L. 92–513","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/947"},"text":"86 Stat. 947","children":[],"tail":", § 604; added "},{"tag":"html:span","attrib":{},"text":"Oct. 25, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/547/s101/a"},"text":"Pub. L. 98–547, § 101(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2758"},"text":"98 Stat. 2758","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1) and (2), the words “compliance costs” are substituted for “costs . . . to comply with such standard” to eliminate unnecessary words. In clause (2), the words “reasonable amount (but less than $15)” are substituted for “reasonable lesser amount” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “commencing on or after ","children":[{"tag":"date","attrib":{"date":"1985-01-01"},"text":"January 1, 1985","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
