{"tag":"section","attrib":{"id":"idcc621d53-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47153"},"text":null,"children":[{"tag":"num","attrib":{"value":"47153"},"text":"§ 47153.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Waiving and adding terms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc621d54-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47153/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc621d55-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47153/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation may waive, without charge, a term of a conveyance of an interest in property under this subchapter if the Secretary decides that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc621d56-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47153/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the property no longer serves the purpose for which it was conveyed; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc621d57-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47153/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the waiver will not prevent carrying out the purpose for which the conveyance was made and is necessary to advance the civil aviation interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc621d58-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47153/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall waive a term under paragraph (1) of this subsection on terms the Secretary considers necessary to protect or advance the civil aviation interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc621d59-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47153/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waivers and Inclusion of Additional Terms on Request","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On request of the Secretary of Transportation or the Secretary of a military department, a department, agency, or instrumentality of the executive branch of the United States Government or a wholly owned Government corporation may waive a term required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47152"},"text":"section 47152 of this title","children":[],"tail":" or add another term if the appropriate Secretary decides it is necessary to protect or advance the interests of the United States in civil aviation or for national defense."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc621d5a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47153/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restrictions on Waiver","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subsections (a) and (b), the Secretary may not waive any term under this section that an interest in land be used for an aeronautical purpose unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc621d5b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47153/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary provides public notice not less than 30 days before the issuance of a waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc621d5c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47153/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary determines that such waiver—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc621d5d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47153/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not significantly impair the aeronautical purpose of an airport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc621d5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47153/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not result in the permanent closure of an airport (unless the Secretary determines that the waiver will directly facilitate the construction of a replacement airport); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc621d5f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47153/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to protect or advance the civil aviation interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc621d60-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1280"},"text":"108 Stat. 1280","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tI"},"text":"Pub. L. 106–181, title I","children":[],"tail":", §§ 125(d), 135(d)(3), "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/76"},"text":"114 Stat. 76","children":[],"tail":", 85; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s719/b/2"},"text":"Pub. L. 118–63, title VII, § 719(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1261"},"text":"138 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc621d61-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc621d62-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc621d63-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47153(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s6/c/1"},"text":"Pub. L. 89–670, § 6(c)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/938"},"text":"80 Stat. 938","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/449/s7/b"},"text":"Pub. L. 97–449, § 7(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2444"},"text":"96 Stat. 2444","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App.:1622c.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-01/ch589/s4"},"text":"Oct. 1, 1949, ch. 589, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/700"},"text":"63 Stat. 700","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s1402/c"},"text":"Pub. L. 85–726, § 1402(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/807"},"text":"72 Stat. 807","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47153(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App.:1622(g)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1944-10-03/ch479"},"text":"Oct. 3, 1944, ch. 479","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/765"},"text":"58 Stat. 765","children":[],"tail":", § 13(g)(3); added "},{"tag":"html:a","attrib":{"href":"/us/act/1947-07-30/ch404/s2"},"text":"July 30, 1947, ch. 404, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/680"},"text":"61 Stat. 680","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s1402/c"},"text":"Pub. L. 85–726, § 1402(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/807"},"text":"72 Stat. 807","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “Notwithstanding any other provision of law” and “further” are omitted as surplus. The word “waive” is substituted for “grant releases from” and “and to convey, quitclaim, or release any right or interest reserved to the United States by” to eliminate unnecessary words. The words “a term of a gift of an interest in property under this subchapter” are substituted for “any of the terms, conditions, reservations, and restrictions contained in . . . any such instrument of disposal” for clarity and consistency. In clause (1), the words “transferred by such instrument” are omitted as surplus. In clause (2), the text of 50 App.:1622c (last proviso) is omitted as executed. The words “protect or” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “In making any disposition of surplus property under this subsection” are omitted as surplus. The words “Secretary of a military department” are substituted for “the Secretary of the Army, or the Secretary of the Navy” for consistency with other titles of the United States Code and to eliminate unnecessary words. The words “Secretary of the Army” are substituted for “Secretary of War” in section 13(g)(3) of the Surplus Property Act of 1944 (ch. 479, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/58/765"},"text":"58 Stat. 765","children":[],"tail":") because of section 205(a) of the National Security Act of 1947 (ch. 343, "},{"tag":"ref","attrib":{"href":"/us/stat/61/501"},"text":"61 Stat. 501","children":[],"tail":"). The Secretary of the Air Force is included in “Secretary of a military department” because of section 207(a) and (f) of the National Security Act of 1947 (ch. 343, "},{"tag":"ref","attrib":{"href":"/us/stat/61/502"},"text":"61 Stat. 502","children":[],"tail":", 503). The word “waive” is substituted for “omit from the instrument of disposal” to eliminate unnecessary words and for consistency in this subchapter. The words “conditions, reservations, and restrictions” are omitted as surplus."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc621d64-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc621d65-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" added subsec. (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “Notwithstanding subsections (a) and (b), before the Secretary may waive any term imposed under this section that an interest in land be used for an aeronautical purpose, the Secretary must provide notice to the public not less than 30 days before waiving such term.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s135/d/3"},"text":"Pub. L. 106–181, § 135(d)(3)","children":[],"tail":", substituted “conveyance” for “gift” in introductory provisions and subpar. (B) and “conveyed” for “given” in subpar. (A)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s125/d"},"text":"Pub. L. 106–181, § 125(d)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc621d66-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc621d67-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc621d68-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Nothing in amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s125/d"},"text":"section 125(d) of Pub. L. 106–181","children":[],"tail":" to be construed to authorize Secretary of Transportation to issue waiver or make a modification referred to in such amendment, see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s125/e"},"text":"section 125(e) of Pub. L. 106–181","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s47107"},"text":"section 47107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
