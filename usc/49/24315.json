{"tag":"section","attrib":{"id":"idcb333a07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315"},"text":null,"children":[{"tag":"num","attrib":{"value":"24315"},"text":"§ 24315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports and audits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb333a08-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amtrak Annual Operations Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than February 15 of each year, Amtrak shall submit to Congress a report that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb333a09-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each route on which Amtrak provided intercity rail passenger transportation during the prior fiscal year, includes information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb333a0a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ridership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a0b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" passenger-miles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a0c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the short-term avoidable profit or loss for each passenger-mile;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a0d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the revenue-to-cost ratio;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a0e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" revenues;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a0f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Government subsidy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a10-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the subsidy not provided by the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a11-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on-time performance; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a12-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any change made to a route’s or service’s frequency or station stops;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb333a13-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides relevant information about a decision to pay an officer of Amtrak more than the rate for level I of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5312"},"text":"section 5312 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb333a14-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" specifies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb333a15-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" significant operational problems Amtrak identifies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a16-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proposals by Amtrak to solve those problems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb333a17-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Amtrak General and Legislative Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb333a18-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than February 15 of each year, Amtrak shall submit to the President and Congress a complete report of its operations, activities, and accomplishments, including a statement of revenues and expenditures for the prior fiscal year. The report—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb333a19-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include a discussion and accounting of Amtrak’s success in meeting the goal described in section 24902(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a1a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include recommendations for legislation, including the amount of financial assistance needed for operations and capital improvements, the method of computing the assistance, and the sources of the assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a1b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall incorporate the category described in section 24319(c)(2)(C);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a1c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include an action plan for bringing Amtrak-served stations that are not in compliance with the Americans with Disabilities Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s12101"},"text":"42 U.S.C. 12101","children":[],"tail":" et seq.) into compliance with such Act, as required by the settlement agreement entered into in 2020 between Amtrak and the Department of Justice;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a1d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include a status report on—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb333a1e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amtrak-served stations for which Amtrak is solely responsible for compliance with such Act based on a station assessment carried out by Amtrak, including a timeline for any required compliance with such Act, as required by the settlement agreement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb333a1f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amtrak-served stations for which Amtrak has a shared responsibility for compliance with such Act based on a station assessment carried out by Amtrak or by the party responsible for such compliance, including a timeline for any required compliance with such Act for the portions of the station for which Amtrak is the responsible party consistent with the terms of the settlement agreement, identifying who is responsible for compliance (and the status of the compliance of each responsible party with such Act) for such portions and the timeline for compliance in cases in which Amtrak is not the responsible party; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb333a20-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of compliance with such Act for all Amtrak-served stations for which Amtrak is not the responsible party, nor is responsible for a portion of the station, and identify the entity or entities that have responsibility for compliance with such Act, based on a station assessment carried out by Amtrak or the party responsible under such Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb333a21-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amtrak may submit reports to the President and Congress at other times Amtrak considers desirable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb333a22-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amtrak may meet the requirements described in clauses (ii) and (iii) of paragraph (1)(E) by demonstrating that Amtrak took reasonable measures to obtain cooperation from responsible entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb333a23-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amtrak shall submit the action plan and status report required under subparagraphs (D) and (E) of paragraph (1)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb333a24-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually while the settlement agreement referred to in paragraph (1)(D) is in effect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb333a25-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" every 5 years beginning on the first day the settlement is no longer in effect.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb333a26-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary’s Report on Effectiveness of This Part","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall prepare a report on the effectiveness of this part in meeting the requirements for a balanced transportation system in the United States. The report may include recommendations for legislation. The Secretary shall include this report as part of the annual report the Secretary submits under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s308/a"},"text":"section 308(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb333a27-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independent Audits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An independent certified public accountant shall audit the financial statements of Amtrak each year. The audit shall be carried out at the place at which the financial statements normally are kept and under generally accepted auditing standards. A report of the audit shall be included in the report required by subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb333a28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comptroller General Audits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General may conduct performance audits of the activities and transactions of Amtrak. Each audit shall be conducted at the place at which the Comptroller General decides and under generally accepted management principles. The Comptroller General may prescribe regulations governing the audit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb333a29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Records and Property of Amtrak and Rail Carriers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amtrak and, if required by the Comptroller General, a rail carrier with which Amtrak has made a contract for intercity rail passenger transportation shall make available for an audit under subsection (d) or (e) of this section all records and property of, or used by, Amtrak or the carrier that are necessary for the audit. Amtrak and the carrier shall provide facilities for verifying transactions with the balances or securities held by depositories, fiscal agents, and custodians. Amtrak and the carrier may keep all reports and property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb333a2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comptroller General’s Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General shall submit to Congress a report on each audit, giving comments and information necessary to inform Congress on the financial operations and condition of Amtrak and recommendations related to those operations and conditions. The report also shall specify any financial transaction or undertaking the Comptroller General considers is carried out without authority of law. When the Comptroller General submits a report to Congress, the Comptroller General shall submit a copy of it to the President, the Secretary, and Amtrak at the same time.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb333a2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24315/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to Records and Accounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State shall have access to Amtrak’s records, accounts, and other necessary documents used to determine the amount of any payment to Amtrak required of the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb333a2c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/918"},"text":"108 Stat. 918","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/134/tII/s206"},"text":"Pub. L. 105–134, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2584"},"text":"111 Stat. 2584","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII"},"text":"Pub. L. 117–58, div. B, title II","children":[],"tail":", §§ 22204(a), 22206(c)(1), "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/699"},"text":"135 Stat. 699","children":[],"tail":", 702; "},{"tag":"ref","attrib":{"href":"/us/pl/118/205/s2"},"text":"Pub. L. 118–205, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2697"},"text":"138 Stat. 2697","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb333a2d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb333a2e-47c4-11f1-9671-b5c7