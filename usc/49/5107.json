 clause (1), the words “in accordance with the requirements established by such regulations” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), before clause (1), the words “in accordance with the requirements established under this subsection” and “appropriate” before “documentation” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), before clause (1), the words “take such actions as may be necessary to” are omitted as surplus. In clauses (1) and (2), the words “(and amendments thereto)” are omitted as surplus. In clause (1), the words “Secretary of Labor” are substituted for “Occupational Safety and Health Administration of the Department of Labor” because of 29:551.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “and education” are omitted as being included in “training”. Before clause (1), the words “regarding the safe loading, unloading, handling, storage, and transportation of hazardous materials and emergency preparedness for responding to accidents or incidents involving the transportation of hazardous materials in order to meet the requirements issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s1816/b"},"text":"section 1816(b) of this title","children":[],"tail":" may be made under this section” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(1), the words “(relating to coordination of Federal information policy)” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8c4c24-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca8c4c25-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" inserted “through a competitive process” after “shall be made” and struck out “hazmat employee” after “nonprofit” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsecs. (a) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary” for “Secretary of Transportation” in introductory provisions of subsecs. (a) to (c) and “Secretary shall” for “Secretary of Transportation shall” in introductory provisions of subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7108/1"},"text":"Pub. L. 109–59, § 7108(1)","children":[],"tail":", added subsec. (e) and struck out heading and text of former subsec. (e). Text read as follows: “The Secretary shall, subject to the availability of funds under section 5127(c)(3), make grants for training instructors to train hazmat employees under this section. A grant under this subsection shall be made to a nonprofit hazmat employee organization that demonstrates—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) expertise in conducting a training program for hazmat employees; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the ability to reach and involve in a training program a target population of hazmat employees.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7108/3"},"text":"Pub. L. 109–59, § 7108(3)","children":[],"tail":", added subsec. (f). Former subsec. (f) redesignated (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7108/2"},"text":"Pub. L. 109–59, § 7108(2)","children":[],"tail":", redesignated subsec. (f) as (g). Former subsec. (g) redesignated (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7108/4"},"text":"Pub. L. 109–59, § 7108(4)","children":[],"tail":", substituted “section 5106” for “sections 5106, 5108(a)–(g)(1) and (h), and 5109 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7108/2"},"text":"Pub. L. 109–59, § 7108(2)","children":[],"tail":", redesignated subsec. (g) as (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/311/s106"},"text":"Pub. L. 103–311, § 106","children":[],"tail":", in introductory provisions inserted “or duplicate” after “conflict with” and in par. (1) substituted “hazard communication, and hazardous waste operations, and” for “hazardous waste operations and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/311/s119/c/1"},"text":"Pub. L. 103–311, § 119(c)(1)","children":[],"tail":", (2), in first sentence substituted “The Secretary shall, subject to the availability of funds under section 5127(c)(3), make grants for training instructors to train hazmat employees under this section.” for “In consultation with the Secretaries of Transportation and Labor and the Administrator, the Director of the National Institute of Environmental Health Sciences may make grants to train hazmat employees under this section.” and in second sentence inserted “hazmat employee” after “nonprofit”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/311/s119/c/3"},"text":"Pub. L. 103–311, § 119(c)(3)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca8c4c26-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca8c4c27-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca8c4c28-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amend