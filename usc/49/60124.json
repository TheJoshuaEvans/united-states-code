ntent","attrib":{},"text":" ended in any part by the Secretary and a summary of the reasons for ending each agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8116c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60124/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the number and qualifications of State pipeline safety inspectors in each State for which a certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s60105"},"text":"section 60105 of this title","children":[],"tail":" or an agreement under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s60106"},"text":"section 60106 of this title","children":[],"tail":" is in effect and the number and qualifications of inspectors the Secretary recommends for that State."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8116c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60124/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations for legislation the Secretary considers necessary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8116ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60124/a/12/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to promote cooperation among the States in improving—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc8116cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60124/a/12/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gas pipeline safety; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc