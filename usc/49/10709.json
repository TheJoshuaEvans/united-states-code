{"tag":"section","attrib":{"id":"idcadfc32c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709"},"text":null,"children":[{"tag":"num","attrib":{"value":"10709"},"text":"§ 10709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contracts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcadfc32d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One or more rail carriers providing transportation subject to the jurisdiction of the Board under this part may enter into a contract with one or more purchasers of rail services to provide specified services under specified rates and conditions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadfc32e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A party to a contract entered into under this section shall have no duty in connection with services provided under such contract other than those duties specified by the terms of the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadfc32f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadfc330-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A contract that is authorized by this section, and transportation under such contract, shall not be subject to this part, and may not be subsequently challenged before the Board or in any court on the grounds that such contract violates a provision of this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadfc331-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The exclusive remedy for any alleged breach of a contract entered into under this section shall be an action in an appropriate State court or United States district court, unless the parties otherwise agree. This section does not confer original jurisdiction on the district courts of the United States based on section 1331 or 1337 of title 28, United States Code.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadfc332-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadfc333-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A summary of each contract for the transportation of agricultural products (including grain, as defined in section 3 of the United States Grain Standards Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t7/s75"},"text":"7 U.S.C. 75","children":[],"tail":") and products thereof) entered into under this section shall be filed with the Board, containing such nonconfidential information as the Board prescribes. The Board shall publish special rules for such contracts in order to ensure that the essential terms of the contract are available to the general public."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadfc334-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Documents, papers, and records (and any copies thereof) relating to a contract described in subsection (a) shall not be subject to the mandatory disclosure requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadfc335-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any lawful contract between a rail carrier and one or more purchasers of rail service that was in effect on ","children":[{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":", shall be considered a contract authorized by this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadfc336-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A rail carrier that enters into a contract as authorized by this section remains subject to the common carrier obligation set forth in section 11101, with respect to rail transportation not provided under such a contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadfc337-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadfc338-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No later than 30 days after the date of filing of a summary of a contract under this section, the Board may, on complaint, begin a proceeding to review such contract on the grounds described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadfc339-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadfc33a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A complaint may be filed under this subsection—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcadfc33b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/g/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a shipper on the grounds that such shipper individually will be harmed because the proposed contract unduly impairs the ability of the contracting rail carrier or carriers to meet their common carrier obligations to the complainant under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11101"},"text":"section 11101 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcadfc33c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/g/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by a port only on the grounds that such port individually will be harmed because the proposed contract will result in unreasonable discrimination against such port.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadfc33d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the grounds for a complaint described in subparagraph (A) of this paragraph, a complaint may be filed by a shipper of agricultural commodities on the grounds that such shipper individually will be harmed because—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcadfc33e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/g/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rail carrier has unreasonably discriminated by refusing to enter into a contract with such shipper for rates and services for the transportation of the same type of commodity under similar conditions to the contract at issue, and that shipper was ready, willing, and able to enter into such a contract at a time essentially contemporaneous with the period during which the contract at issue was offered; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcadfc33f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/g/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the proposed contract constitutes a destructive competitive practice under this part.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In making a determination under clause (ii) of this subparagraph, the Board shall consider the difference between contract rates and published single car rates.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadfc340-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/g/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this paragraph, the term “unreasonable discrimination” has the same meaning as such term has under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10741"},"text":"section 10741 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadfc341-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadfc342-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 30 days after the date a proceeding is commenced under paragraph (1) of this subsection, or within such shorter time period after such date as the Board may establish, the Board shall determine whether the contract that is the subject of such proceeding is in violation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadfc343-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10709/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Board determines, on the basis of a complaint filed under paragraph (2)(B)(i) of this subsection, that the grounds for a complaint described in such paragraph have been established with respect to a rail carrier, the Board shall, subject to the provisions of this section, order such rail carrier to provide rates and service substantially similar to the contract at issue with such differentials in terms and conditions as are justified by the evidence.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcadfc344-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/817"},"text":"109 Stat. 817","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/24"},"text":"Pub. L. 104–287, § 5(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3390"},"text":"110 Stat. 3390","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/110/s11/d"},"text":"Pub. L. 114–110, § 11(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2234"},"text":"129 Stat. 2234","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcadfc345-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcadfc346-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcadfc347-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10713"},"text":"section 10713 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 10709 to 10713 were omitted in the general amendment of this subtitle by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10709, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1382"},"text":"92 Stat. 1382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/tII/s202"},"text":"Pub. L. 96–448, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1900"},"text":"94 Stat. 1900","children":[],"tail":", related to determination of market dominance in rail carrier rate proceedings. See "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s10707"},"text":"section 10707 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10710, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1383"},"text":"92 Stat. 1383","children":[],"tail":", related to elimination of discrimination against recyclable materials."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10711, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1383"},"text":"92 Stat. 1383","children":[],"tail":", related to effect of former sections 10701(a), (b), 10707, 10709, 10727, and 10728 of this title on rail rates and practices."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10712, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448/tII/s206/a"},"text":"Pub. L. 96–448, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1906"},"text":"94 Stat. 1906","children":[],"tail":", related to inflation-based rate increases."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10713, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448/tII/s208/a"},"text":"Pub. L. 96–448, title II, § 208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1908"},"text":"94 Stat. 1908","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/97/468/tV/s502"},"text":"Pub. L. 97–468, title V, § 502","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-14"},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2552"},"text":"96 Stat. 2552","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/509/tIV/s4051"},"text":"Pub. L. 99–509, title IV, § 4051","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-21"},"text":"Oct. 21, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1910"},"text":"100 Stat. 1910","children":[],"tail":", related to contracts between rail carriers and purchasers of rail services. See "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s10709"},"text":"section 10709 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcadfc348-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110"},"text":"Pub. L. 114–110","children":[],"tail":" struck out subsec. (h) which related to certain contracts for the transportation of agricultural commodities."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1980-10-01"},"text":"October 1, 1980","children":[],"tail":",” for “the effective date of the Staggers Rail Act of 1980”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcadfc349-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcadfc34a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
