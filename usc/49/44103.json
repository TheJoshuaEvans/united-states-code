{"tag":"section","attrib":{"id":"idcbd7deb5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103"},"text":null,"children":[{"tag":"num","attrib":{"value":"44103"},"text":"§ 44103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration of aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd7deb6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7deb7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" On application of the owner of an aircraft that meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44102"},"text":"section 44102 of this title","children":[],"tail":", the Administrator of the Federal Aviation Administration shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7deb8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" register the aircraft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7deb9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue a certificate of registration to its owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7deba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may prescribe the extent to which an aircraft owned by the holder of a dealer’s certificate of registration issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44104/2"},"text":"section 44104(2) of this title","children":[],"tail":" also is registered under this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7debb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Controlled Substance Violations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7debc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator may not issue an owner’s certificate of registration under subsection (a)(1) of this section to a person whose certificate is revoked under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44106"},"text":"section 44106 of this title","children":[],"tail":" during the 5-year period beginning on the date of the revocation, except—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7debd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as provided in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44106/e/2"},"text":"section 44106(e)(2) of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7debe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the Administrator may issue the certificate to the person after the one-year period beginning on the date of the revocation if the Administrator decides that the aircraft otherwise meets the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44102"},"text":"section 44102 of this title","children":[],"tail":" and that denial of a certificate for the 5-year period—"}],"tail":null},{"tag":"clause","attrib":{"id":"idcbd7debf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would be excessive considering the nature of the offense or the act committed and the burden the denial places on the person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbd7dec0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would not be in the public interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7dec1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A decision of the Administrator under paragraph (1)(B)(i) or (ii) of this subsection is within the discretion of the Administrator. That decision or failure to make a decision is not subject to administrative or judicial review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7dec2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certificates as Evidence","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A certificate of registration issued under this section is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7dec3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conclusive evidence of the nationality of an aircraft for international purposes, but not conclusive evidence in a proceeding under the laws of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7dec4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not evidence of ownership of an aircraft in a proceeding in which ownership is or may be in issue.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7dec5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certificates Available for Inspection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An operator of an aircraft shall make available for inspection a certificate of registration for the aircraft when requested by a United States Government, State, or local law enforcement officer.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7dec6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Validity of Aircraft Registration During Renewal.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7dec7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An aircraft may be operated on or after the expiration date found on the certificate of registration issued for such aircraft under this section as if it were not expired if the operator of such aircraft has aboard the aircraft—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7dec8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" documentation validating that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbd7dec9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an aircraft registration renewal application form (AC Form 8050–1B, or a succeeding form) has been submitted to the Administrator for such aircraft but not yet approved or denied; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbd7deca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such aircraft is compliant with maintenance, inspections, and any other requirements for the aircraft’s airworthiness certificate issued under section 44704(d); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7decb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the most recent aircraft registration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7decc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proof of pending renewal application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall provide an applicant for renewal of registration under this section with documentation described in paragraph (1)(A). Such documentation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7decd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be made electronically available to the applicant immediately upon submitting an aircraft registration renewal application to the Civil Aviation Registry for an aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7dece-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the applicant of the operational allowance described in paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7decf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deem an aircraft’s airworthiness certificate issued under section 44704(d) as valid provided that the applicant confirms acknowledgment of the requirements of paragraph (1)(A)(ii);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7ded0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confirm the applicant acknowledged the limitations described in paragraph (3)(A) and (3)(B); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7ded1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include identifying information pertaining to such aircraft and to the registered owner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7ded2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this subsection shall be construed to permit any person to operate an aircraft—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7ded3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with an expired registration, except as specifically provided for under this subsection; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7ded4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44103/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Administrator has denied an application to renew the registration of such aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd7ded5-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1162"},"text":"108 Stat. 1162","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVIII/s812/a"},"text":"Pub. L. 118–63, title VIII, § 812(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1326"},"text":"138 Stat. 1326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd7ded6-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbd7ded7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbd7ded8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","a