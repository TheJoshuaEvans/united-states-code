{"tag":"section","attrib":{"id":"idcc707511-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49111"},"text":null,"children":[{"tag":"num","attrib":{"value":"49111"},"text":"§ 49111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to and effect of other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc707512-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Same Powers and Restrictions Under Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure that the Metropolitan Washington Airports Authority has the same proprietary powers and is subject to the same restrictions under United States law as any other airport except as otherwise provided in this chapter, during the period that the lease authorized by section 6005 of the Metropolitan Washington Airports Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Public Law 99–500","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-375"},"text":"100 Stat. 1783–375","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Public Law 99–591","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-378"},"text":"100 Stat. 3341–378","children":[],"tail":") is in effect—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc707513-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Metropolitan Washington Airports are deemed to be public airports for purposes of chapter 471 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc707514-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Act of ","children":[{"tag":"date","attrib":{"date":"1940-06-29"},"text":"June 29, 1940","children":[],"tail":" (ch. 444, "},{"tag":"ref","attrib":{"href":"/us/stat/54/686"},"text":"54 Stat. 686","children":[],"tail":"), the First Supplemental Civil Functions Appropriations Act, 1941 (ch. 780, "},{"tag":"ref","attrib":{"href":"/us/stat/54/1030"},"text":"54 Stat. 1030","children":[],"tail":"), and the Act of "},{"tag":"date","attrib":{"date":"1950-09-07"},"text":"September 7, 1950","children":[],"tail":" (ch. 905, "},{"tag":"ref","attrib":{"href":"/us/stat/64/770"},"text":"64 Stat. 770","children":[],"tail":"), do not apply to the operation of the Metropolitan Washington Airports, and the Secretary of Transportation is relieved of all responsibility under those Acts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc707515-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inapplicability of Certain Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Metropolitan Washington Airports and the Airports Authority are not subject to the requirements of any law solely by reason of the retention by the United States Government of the fee simple title to those airports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc707516-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Police Power","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Virginia shall have concurrent police power authority over the Metropolitan Washington Airports, and the courts of Virginia may exercise jurisdiction over Ronald Reagan Washington National Airport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc707517-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Planning","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc707518-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49111/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The authority of the National Capital Planning Commission under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s8722"},"text":"section 8722 of title 40","children":[],"tail":" does not apply to the Airports Authority."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc707519-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49111/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Airports Authority shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc70751a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49111/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission and the Advisory Council on Historic Preservation before undertaking any major alterations to the exterior of the main terminal at Washington Dulles International Airport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc70751b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49111/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Commission before undertaking development that would alter the skyline of Ronald Reagan Washington National Airport when viewed from the opposing shoreline of the Potomac River or from the George Washington Parkway.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc70751c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/26"},"text":"Pub. L. 105–102, § 2(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2213"},"text":"111 Stat. 2213","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/154/s2/a/1/D"},"text":"Pub. L. 105–154, § 2(a)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-02-06"},"text":"Feb. 6, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3"},"text":"112 Stat. 3","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/225/s7/c/1/D"},"text":"Pub. L. 105–225, § 7(c)(1)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1511"},"text":"112 Stat. 1511","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tII/s231/j/1"},"text":"Pub. L. 106–181, title II, § 231(j)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/115"},"text":"114 Stat. 115","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107