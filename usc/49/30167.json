{"tag":"section","attrib":{"id":"idcb525b0e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30167"},"text":null,"children":[{"tag":"num","attrib":{"value":"30167"},"text":"§ 30167.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure of information by the Secretary of Transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb525b0f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30167/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Confidentiality of Information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Information obtained under this chapter related to a confidential matter referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":" may be disclosed only in the following ways:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb525b10-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30167/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to other officers and employees carrying out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb525b11-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30167/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" when relevant to a proceeding under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb525b12-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30167/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the public if the confidentiality of the information is preserved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb525b13-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30167/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the public when the Secretary of Transportation decides that disclosure is necessary to carry out ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30101"},"text":"section 30101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb525b14-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30167/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Defect and Noncompliance Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subsection (a) of this section, the Secretary shall disclose information obtained under this chapter related to a defect or noncompliance that the Secretary decides will assist in carrying out sections 30117(b) and 30118–30121 of this title or that is required to be disclosed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30118/a"},"text":"section 30118(a) of this title","children":[],"tail":". A requirement to disclose information under this subsection is in addition to the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb525b15-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30167/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information About Manufacturer’s Increased Costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A manufacturer opposing an action of the Secretary under this chapter because of increased cost shall submit to the Secretary information about the increased cost, including the manufacturer’s cost and the cost to retail purchasers, that allows the public and the Secretary to evaluate the manufacturer’s statement. The Secretary shall evaluate the information promptly and, subject to subsection (a) of this section, shall make the information and evaluation available to the public. The Secretary shall publish a notice in the Federal Register that the information is available.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb525b16-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30167/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withholding Information From Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not authorize information to be withheld from a committee of Congress authorized to have the information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb525b17-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/970"},"text":"108 Stat. 970","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb525b18-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb525b19-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"htm