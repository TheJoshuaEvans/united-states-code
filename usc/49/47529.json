{"tag":"section","attrib":{"id":"idcc6948ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47529"},"text":null,"children":[{"tag":"num","attrib":{"value":"47529"},"text":"§ 47529.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonaddition rule","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc6948ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47529/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (b) of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47530"},"text":"section 47530 of this title","children":[],"tail":", a person may operate a civil subsonic turbojet aircraft with a maximum weight of more than 75,000 pounds that is imported into the United States after "},{"tag":"date","attrib":{"date":"1990-11-04"},"text":"November 4, 1990","children":[],"tail":", only if the aircraft—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc6948ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47529/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complies with the stage 3 noise levels; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6948ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47529/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was purchased by the person importing the aircraft into the United States under a legally binding contract made before ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6948f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47529/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may provide an exemption from subsection (a) of this section to permit a person to obtain modifications to an aircraft to meet the stage 3 noise levels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc6948f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47529/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aircraft Deemed Not Imported","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, an aircraft is deemed not to have been imported into the United States if the aircraft—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc6948f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47529/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" was owned on ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":", by—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc6948f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47529/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation, trust, or partnership organized under the laws of the United States or a State (including the District of Columbia);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6948f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47529/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual who is a citizen of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc6948f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47529/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an entity that is owned or controlled by a corporation, trust, partnership, or individual described in subclause (A) or (B) of this clause; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6948f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47529/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enters the United States not later than 6 months after the expiration of a lease agreement (including any extension) between an owner described in clause (1) of this subsection and a foreign carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc6948f7-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1292"},"text":"108 Stat. 1292","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc6948f8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc6948f9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children"