{"tag":"section","attrib":{"id":"idcc15d172-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806"},"text":null,"children":[{"tag":"num","attrib":{"value":"44806"},"text":"§ 44806.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public unmanned aircraft systems and public safety use of tethered unmanned aircraft systems","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc15d173-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall issue guidance regarding the operation of a public unmanned aircraft system—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc15d174-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to streamline and expedite the process for the issuance of a certificate of authorization or a certificate of waiver;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d175-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to facilitate the capability of public agencies to develop and use test ranges, subject to operating restrictions required by the Federal Aviation Administration, to test and operate public unmanned aircraft systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d176-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide guidance on a public agency’s responsibilities when operating an unmanned aircraft without a civil airworthiness certificate issued by the Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d177-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements With Government Agencies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc15d178-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall enter into an agreement with each appropriate public agency to simplify the process for issuing a certificate of waiver or a certificate of authorization with respect to an application for authorization to operate a public unmanned aircraft system in the national airspace system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d179-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An agreement under paragraph (1) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc15d17a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to an application described in paragraph (1)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc15d17b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for an expedited review of the application;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc15d17c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a decision by the Administrator on approval or disapproval not later than 60 business days after the date of submission of the application; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc15d17d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for an expedited appeal if the application is disapproved;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d17e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for a one-time approval of similar operations carried out during a fixed period of time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d17f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" allow a government public safety agency to operate an unmanned aircraft weighing 4.4 pounds or less if that unmanned aircraft is operated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc15d180-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within or beyond the visual line of sight of the operator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc15d181-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" less than 400 feet above the ground;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc15d182-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" during daylight conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc15d183-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b/2/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within Class G airspace; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc15d184-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/b/2/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" outside of 5 statute miles from any airport, heliport, seaplane base, spaceport, or other location with aviation activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d185-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Safety Use of Actively Tethered Unmanned Aircraft Systems.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc15d186-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Federal Aviation Administration shall permit, and may issue guidance regarding, the use of actively tethered unmanned aircraft systems by a public safety organization for such systems that are—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc15d187-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" operated—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc15d188-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at or below an altitude of 150 feet above ground level within class B, C, D, E, or G airspace, but not at a greater altitude than the ceiling depicted on the UAS Facility Maps published by the Federal Aviation Administration, where applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc15d189-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within zero-grid airspaces as depicted on such UAS Facility Maps, only if operated in life-saving or emergency situations and with prior notification to the Administration in a manner determined by the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc15d18a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" above 150 feet above ground level within class B, C, D, E, or G airspace only with prior authorization from the Administrator;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d18b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not flown directly over non-participating persons;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d18c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated within visual line of sight of the operator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d18d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operated in a manner that does not interfere with and gives way to any other aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d18e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Public actively tethered unmanned aircraft systems may be operated—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc15d18f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without any requirement to obtain a certificate of authorization, certificate of waiver, or other approval by the Federal Aviation Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d190-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without requiring airman certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44703"},"text":"section 44703 of this title","children":[],"tail":" or any rule or regulation relating to airman certification; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d191-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without requiring airworthiness certification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44704"},"text":"section 44704 of this title","children":[],"tail":" or any rule or regulation relating to aircraft certification."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d192-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Actively tethered unmanned aircraft systems operated within the scope of the guidance issued pursuant to paragraph (1) shall be exempt from the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44805"},"text":"section 44805 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d193-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings provision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection shall be construed to preclude the Administrator of the Federal Aviation Administration from issuing new regulations for public actively tethered unmanned aircraft systems in order to ensure the safety of the national airspace system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d194-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Agency Coordination to Enhance the Public Health and Safety Capabilities of Public Unmanned Aircraft Systems","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall assist Federal civilian Government agencies that operate unmanned aircraft systems within civil-controlled airspace, in operationally deploying and integrating sense and avoid capabilities, as necessary to operate unmanned aircraft systems safely within the national airspace system.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d195-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44806/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “public safety organization” means an entity that primarily engages in activities related to the safety and well-being of the general public, including law enforcement, fire departments, emergency medical services, and other organizations that protect and serve the public in matters of safety and security.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc15d196-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIII/s346/a"},"text":"Pub. L. 115–254, div. B, title III, § 346(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3294"},"text":"132 Stat. 3294","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIX/s926/a"},"text":"Pub. L. 118–63, title IX, § 926(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1360"},"text":"138 Stat. 1360","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc15d197-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc15d198-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcc15d199-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in subsecs. (a) and (b) of this section were contained in section 334(a) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":", which was set out in a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40101"},"text":"section 40101 of this title","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIII/s346/b/2"},"text":"Pub. L. 115–254, div. B, title III, § 346(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3295"},"text":"132 Stat. 3295","children":[],"tail":". The remainder of the note comprised of subtitle B of title III of "},{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":" was transferred and is set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44802"},"text":"section 44802 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc15d19a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s926/a/1"},"text":"Pub. L. 118–63, § 926(a)(1)","children":[],"tail":", inserted “and public safety use of tethered unmanned aircraft systems” after “systems” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s926/a/2/A"},"text":"Pub. L. 118–63, § 926(a)(2)(A)","children":[],"tail":", inserted “Safety Use of” after “Public” in heading. Text quoted in directory language of amendment was editorially conformed to the style of the heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s926/a/2/B/i"},"text":"Pub. L. 118–63, § 926(a)(2)(B)(i)","children":[],"tail":", in introductory provisions, substituted “The” for “Not later than 180 days after the date of enactment of this Act, the”, “permit” for “permit the use of”, struck out “public” before “actively tethered”, and inserted “by a public safety organization for such systems” after “unmanned aircraft systems”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s926/a/2/B/ii"},"text":"Pub. L. 118–63, § 926(a)(2)(B)(ii)","children":[],"tail":", added subpar. (A) and struck out former subpar. (A) which read as follows: “operated at an altitude of less than 150 feet above ground level;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(B) to (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s926/a/2/B/iii"},"text":"Pub. L. 118–63, § 926(a)(2)(B)(iii)","children":[],"tail":", (iv), redesignated subpars. (C) to (E) as (B) to (D), respectively, and struck out former subpar. (B) which read as follows: “operated—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(i) within class G airspace; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) at or below the ceiling depicted on the Federal Aviation Administration’s published UAS facility maps for class B, C, D, or E surface area airspace;”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s926/a/2/C"},"text":"Pub. L. 118–63, § 926(a)(2)(C)","children":[],"tail":", substituted “Actively” for “Public actively”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s926/a/3"},"text":"Pub. L. 118–63, § 926(a)(3)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc15d19b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc15d19c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Public UAS Access to Special Use Airspace","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIII/s368"},"text":"Pub. L. 115–254, div. B, title III, § 368","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3310"},"text":"132 Stat. 3310","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dB/tIII/s368"},"text":"“Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"], the Secretary of Transportation shall issue guidance for the expedited and timely access to special use airspace for public unmanned aircraft systems in order to assist Federal, State, local, or tribal law enforcement organizations in conducting law enforcement, emergency response, or for other activities.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
