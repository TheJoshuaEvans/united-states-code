{"tag":"section","attrib":{"id":"idcc8ab505-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80112"},"text":null,"children":[{"tag":"num","attrib":{"value":"80112"},"text":"§ 80112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liability under negotiable bills issued in parts, sets, or duplicates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc8ab506-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Parts and Sets","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A negotiable bill of lading issued in a State for the transportation of goods to a place in the 48 contiguous States or the District of Columbia may not be issued in parts or sets. A common carrier issuing a bill in violation of this subsection is liable for damages for failure to deliver the goods to a purchaser of one part for value in good faith even though the purchase occurred after the carrier delivered the goods to a holder of one of the other parts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8ab507-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duplicates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When at least 2 negotiable bills of lading are issued in a State for the same goods to be transported to a place in the 48 contiguous States or the District of Columbia, the word “duplicate” or another word indicating that the bill is not an original must be put plainly on the face of each bill except the original. A common carrier violating this subsection is liable for damages caused by the violation to a purchaser of the bill for value in good faith as an original bill even though the purchase occurred after the carrier delivered the goods to the holder of the original bill.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc8ab508-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1351"},"text":"108 Stat. 1351","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc8ab509-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc8ab50a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc8ab50b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80112(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:84.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-08-29/ch415"},"text":"Aug. 29, 1916, ch. 415","children":[],"tail":", §§ 4, 5, "},{"tag":"html:a","attrib":{"href":"/us/stat/39/539"},"text":"39 Stat. 539","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"80112(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:85.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “48 contiguous States or the District of Columbia” are substituted for “United States on the Continent of North America, except Alaska and Panama” and the text of 49 App.:84 (proviso) and 85 (proviso) for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “If so issued” and “described therein” are omitted as surplus. The word “occurred” is added for clarity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
