{"tag":"section","attrib":{"id":"idcb202797-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22105"},"text":null,"children":[{"tag":"num","attrib":{"value":"22105"},"text":"§ 22105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sharing project costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb202798-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb202799-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The United States Government’s share of the costs of financial assistance for a project under this chapter is 50 percent, except that for assistance provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s22101/a/2"},"text":"section 22101(a)(2) of this title","children":[],"tail":", the Government’s share is 70 percent. The State may pay its share of the costs in cash or through the following benefits, to the extent that the benefits otherwise would not be provided:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb20279a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22105/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forgiveness of taxes imposed on a rail carrier or its property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb20279b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22105/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" real and tangible personal property (provided by the State or a person for the State) necessary for the safe and efficient operation of rail freight transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb20279c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22105/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" track rights secured by the State for a rail carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb20279d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22105/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cash equivalent of State salaries for State employees working on the State project, except overhead and general administrative costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb20279e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A State may pay more than its required percentage share of the costs of a project under this chapter. When a State, or a person acting for a State, pays more than the State share of the costs of its projects during a fiscal year, the excess amount shall be applied to the State share for the costs of the State projects for later fiscal years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb20279f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements To Combine Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"States may agree to combine any part of the amounts made available under this chapter to carry out a project that is eligible for assistance under this chapter when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb2027a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project will benefit each State making the agreement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2027a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agreement is not a violation of State law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb2027a2-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/897"},"text":"108 Stat. 897","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb2027a3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb2027a4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb2027a5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"22105(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1654(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670"},"text":"Pub. L. 89–670","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/931"},"text":"80 Stat. 931","children":[],"tail":", § 5(e), (j); added "},{"tag":"html:span","attrib":{},"text":"Feb. 5, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/210/s803"},"text":"Pub. L. 94–210, § 803","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/130"},"text":"90 Stat. 130","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 8, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/607"},"text":"Pub. L. 95–607","children":[],"tail":", §§ 102–106(a), 107– 109(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/92/3059"},"text":"92 Stat. 3059","children":[],"tail":", 3062; "},{"tag":"html:span","attrib":{},"text":"Oct. 12, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/86/s115/b"},"text":"Pub. L. 96–86, § 115(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/662"},"text":"93 Stat. 662","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", §§ 1191, 1192, "},{"tag":"html:a","attrib":{"href":"/us/stat/95/699"},"text":"95 Stat. 699","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/468/s501"},"text":"Pub. L. 97–468, § 501","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2551"},"text":"96 Stat. 2551","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/272/s4018"},"text":"Pub. L. 99–272, § 4018","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/111"},"text":"100 Stat. 111","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Dec. 11, 1989","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/213/s2/a"},"text":"Pub. L. 101–213, § 2(a)","children":[],"tail":", (c), "},{"tag":"html:a","attrib":{"href":"/us/stat/103/1843"},"text":"103 Stat. 1843","children":[],"tail":", 1845, 1847."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"22105(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1654(j).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “project” and “projects” are substituted for “program” for clarity and consistency in this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the words “financial assistance for a project under this chapter” are substituted for “rail freight assistance project” for clarity and consistency in this chapter. In clause (B), the words “for use in its rail freight assistance program” are omitted as unnecessary because of the restatement. In clause (D), the words “State employees” are substituted for “State public employees” to eliminate an unnecessary word.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “States may agree” are substituted for “Two or more States . . . enter into an agreement” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
