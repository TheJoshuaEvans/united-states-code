{"tag":"section","attrib":{"id":"idcb0d1470-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107"},"text":null,"children":[{"tag":"num","attrib":{"value":"20107"},"text":"§ 20107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection and investigation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb0d1471-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out this part, the Secretary of Transportation may take actions the Secretary considers necessary, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0d1472-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct investigations, make reports, issue subpenas, require the production of documents, take depositions, and prescribe recordkeeping and reporting requirements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0d1473-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" delegate to a public entity or qualified person the inspection, examination, and testing of railroad equipment, facilities, rolling stock, operations, and persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0d1474-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entry and Inspection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this part, an officer, employee, or agent of the Secretary, at reasonable times and in a reasonable way, may enter and inspect railroad equipment, facilities, rolling stock, operations, and relevant records. When requested, the officer, employee, or agent shall display proper credentials. During an inspection, the officer, employee, or agent is an employee of the United States Government under chapter 171 of title 28.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0d1475-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Railroad Radio Communications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0d1476-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To carry out the Secretary’s responsibilities under this part and under chapter 51, the Secretary may authorize officers, employees, or agents of the Secretary to conduct, with or without making their presence known, the following activities in circumstances the Secretary finds to be reasonable:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0d1477-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Intercepting a radio communication, with or without the consent of the sender or other receivers of the communication, but only where such communication is broadcast or transmitted over a radio frequency which is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb0d1478-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorized for use by one or more railroad carriers by the Federal Communications Commission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb0d1479-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" primarily used by such railroad carriers for communications in connection with railroad operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0d147a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Communicating the existence, contents, substance, purport, effect, or meaning of the communication, subject to the restrictions in paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0d147b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Receiving or assisting in receiving the communication (or any information therein contained).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0d147c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Disclosing the contents, substance, purport, effect, or meaning of the communication (or any part thereof of such communication) or using the communication (or any information contained therein), subject to the restrictions in paragraph (3), after having received the communication or acquired knowledge of the contents, substance, purport, effect, or meaning of the communication (or any part thereof).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0d147d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Recording the communication by any means, including writing and tape recording.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0d147e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accident and incident prevention and investigation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, and officers, employees, and agents of the Department of Transportation authorized by the Secretary, may engage in the activities authorized by paragraph (1) for the purpose of accident and incident prevention and investigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0d147f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of information","children":[],"tail":".—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0d1480-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Information obtained through activities authorized by paragraphs (1) and (2) shall not be admitted into evidence in any administrative or judicial proceeding except—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb0d1481-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a prosecution of a felony under Federal or State criminal law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb0d1482-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to impeach evidence offered by a party other than the Federal Government regarding the existence, electronic characteristics, content, substance, purport, effect, meaning, or timing of, or identity of parties to, a communication intercepted pursuant to paragraphs (1) and (2) in proceedings pursuant to section 5122, 5123, 20702(b), 20111, 20112, 20113, or 20114 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0d1483-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If information obtained through activities set forth in paragraphs (1) and (2) is admitted into evidence for impeachment purposes in accordance with subparagraph (A), the court, administrative law judge, or other officer before whom the proceeding is conducted may make such protective orders regarding the confidentiality or use of the information as may be appropriate in the circumstances to protect privacy and administer justice.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0d1484-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No evidence shall be excluded in an administrative or judicial proceeding solely because the government would not have learned of the existence of or obtained such evidence but for the interception of information that is not admissible in such proceeding under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0d1485-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information obtained through activities set forth in paragraphs (1) and (2) shall not be subject to publication or disclosure, or search or review in connection therewith, under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0d1486-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Nothing in this subsection shall be construed to impair or otherwise affect the authority of the United States to intercept a communication, and collect, retain, analyze, use, and disseminate the information obtained thereby, under a provision of law other than this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0d1487-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20107/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application with other law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 705 of the Communications Act of 1934 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t47/s605"},"text":"47 U.S.C. 605","children":[],"tail":") and chapter 119 of title 18 shall not apply to conduct authorized by and pursuant to this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0d1488-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/866"},"text":"108 Stat. 866","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tIII/s306"},"text":"Pub. L. 110–432, div. A, title III, § 306","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4880"},"text":"122 Stat. 4880","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb0d1489-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb0d148a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb0d148b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20107(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:437(a) (1st sentence words before 9th and after 14th commas).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458/s208/a"},"text":"Pub. L. 91–458, § 208(a)","children":[],"tail":" (1st sentence words before 9th and after 14th commas), "},{"tag":"html:a","attrib":{"href":"/us/stat/84/974"},"text":"84 Stat. 974","children":[],"tail":", 975."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:437(d)(1) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458"},"text":"Pub. L. 91–458","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/971"},"text":"84 Stat. 971","children":[],"tail":", § 208(d)(1) (1st sentence); added "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/423/s6/b"},"text":"Pub. L. 96–423, § 6(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1813"},"text":"94 Stat. 1813","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20107(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:437(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458/s208/b"},"text":"Pub. L. 91–458, § 208(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/975"},"text":"84 Stat. 975","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/574/s9"},"text":"Pub. L. 95–574, § 9","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2462"},"text":"92 Stat. 2462","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/423/s6/a"},"text":"Pub. L. 96–423, § 6(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1813"},"text":"94 Stat. 1813","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “To carry out this part, the Secretary of Transportation may” are substituted for “In carrying out his functions under this subchapter, the Secretary is authorized to perform . . . to carry out the provisions of this subchapter” and “In carrying out the functions formerly vested in the Interstate Commerce Commission and transferred to the Secretary by section 1655(e)(1), (e)(2), and (e)(6)(A) of title 49, Appendix, the Secretary is authorized to perform any act authorized in subsection (a) of this section . . . to carry out such transferred functions” to eliminate unnecessary words. In clause (2), the word “entity” is substituted for “bodies” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “In carrying out this part” are substituted for “To carry out the Secretary’s responsibilities under this subchapter and under the functions transferred by section 1655(e)(1), (e)(2), and (e)(6)(A) of title 49, Appendix” to eliminate unnecessary words. The word “way” is substituted for “manner” for consistency in the revised title and with other titles of the Code. The word “examine” is omitted as being included in “inspect”. The word “considered” is omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb0d148c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb0d148d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb0d148e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Safety Inspections in Mexico","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tIV/s416"},"text":"Pub. L. 110–432, div. A, title IV, § 416","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4890"},"text":"122 Stat. 4890","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11316/j/8"},"text":"Pub. L. 114–94, div. A, title XI, § 11316(j)(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1678"},"text":"129 Stat. 1678","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tXI/s11316/j/8"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Mechanical and brake inspections of rail cars performed in Mexico shall not be treated as satisfying United States rail safety laws or regulations unless the Secretary certifies that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such inspections are being performed under regulations and standards equivalent to those applicable in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the inspections are being performed by employees that have received training similar to the training received by similar railroad employees in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspection records that are required to be available to the crewmembers on board the train, including air slips and blue cards, are maintained in both English and Spanish, and such records are available to the Federal Railroad Administration for review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Railroad Administration is permitted to perform onsite inspections for the purpose of ensuring compliance with the requirements of this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “railroad”, as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s416"},"text":"section 416 of Pub. L. 110–432","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/s2/a"},"text":"section 2(a) of Pub. L. 110–432","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s20102"},"text":"section 20102 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
