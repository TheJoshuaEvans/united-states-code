{"tag":"section","attrib":{"id":"idcb86b18c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905"},"text":null,"children":[{"tag":"num","attrib":{"value":"32905"},"text":"§ 32905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manufacturing incentives for alternative fuel automobiles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb86b18d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dedicated Automobiles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c) of this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32904/a/2"},"text":"section 32904(a)(2) of this title","children":[],"tail":", for any model of dedicated automobile manufactured by a manufacturer after model year 1992, the fuel economy measured for that model shall be based on the fuel content of the alternative fuel used to operate the automobile. A gallon of a liquid alternative fuel used to operate a dedicated automobile is deemed to contain .15 gallon of fuel."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb86b18e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dual Fueled Automobiles","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d) of this section or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32904/a/2"},"text":"section 32904(a)(2) of this title","children":[],"tail":", for any model of dual fueled automobile manufactured by a manufacturer in model years 1993 through 2019, the Administrator of the Environmental Protection Agency shall measure the fuel economy for that model by dividing 1.0 by the sum of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb86b18f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" .5 divided by the fuel economy measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32904/c"},"text":"section 32904(c) of this title","children":[],"tail":" when operating the model on gasoline or diesel fuel; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb86b190-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" .5 divided by the fuel economy—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb86b191-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measured under subsection (a) when operating the model on alternative fuel; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb86b192-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" measured based on the fuel content of B20 when operating the model on B20, which is deemed to contain 0.15 gallon of fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb86b193-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gaseous Fuel Dedicated Automobiles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For any model of gaseous fuel dedicated automobile manufactured by a manufacturer after model year 1992, the Administrator shall measure the fuel economy for that model based on the fuel content of the gaseous fuel used to operate the automobile. One hundred cubic feet of natural gas is deemed to contain .823 gallon equivalent of natural gas. The Secretary of Transportation shall determine the appropriate gallon equivalent of other gaseous fuels. A gallon equivalent of gaseous fuel is deemed to have a fuel content of .15 gallon of fuel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb86b194-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Gaseous Fuel Dual Fueled Automobiles","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For any model of gaseous fuel dual fueled automobile manufactured by a manufacturer in model years 1993 through 2019, the Administrator shall measure the fuel economy for that model by dividing 1.0 by the sum of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb86b195-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" .5 divided by the fuel economy measured under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32904/c"},"text":"section 32904(c) of this title","children":[],"tail":" when operating the model on gasoline or diesel fuel; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb86b196-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" .5 divided by the fuel economy measured under subsection (c) of this section when operating the model on gaseous fuel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb86b197-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electric Dual Fueled Automobiles.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb86b198-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the request of the manufacturer, the Administrator may measure the fuel economy for any model of dual fueled automobile manufactured after model year 2015 that is capable of operating on electricity in addition to gasoline or diesel fuel, obtains its electricity from a source external to the vehicle, and meets the minimum driving range requirements established by the Secretary for dual fueled electric automobiles, by dividing 1.0 by the sum of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb86b199-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage utilization of the model on gasoline or diesel fuel, as determined by a formula based on the model’s alternative fuel range, divided by the fuel economy measured under section 32904(c); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb86b19a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage utilization of the model on electricity, as determined by a formula based on the model’s alternative fuel range, divided by the fuel economy measured under section 32904(a)(2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb86b19b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative calculation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the manufacturer does not request that the Administrator calculate the manufacturing incentive for its electric dual fueled automobiles in accordance with paragraph (1), the Administrator shall calculate such incentive for such automobiles manufactured by such manufacturer after model year 2015 in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb86b19c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fuel Economy Calculations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall calculate the manufacturer’s average fuel economy under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32904/a/1"},"text":"section 32904(a)(1) of this title","children":[],"tail":" for each model described under subsections (a)–(d) of this section by using as the denominator the fuel economy measured for each model under subsections (a)–(d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb86b19d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32905/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fuel Economy Incentive Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order for any model of dual fueled automobile to be eligible to receive the fuel economy incentives included in section 32906(a) and (b), a label shall be attached to the fuel compartment of each dual fueled automobile of that model, notifying that the vehicle can be operated on an alternative fuel and on gasoline or diesel, with the form of alternative fuel stated on the notice. This requirement applies to dual fueled automobiles manufactured on or after ","children":[{"tag":"date","attrib":{"date":"2006-09-01"},"text":"September 1, 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb86b19e-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1065"},"text":"108 Stat. 1065","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/63"},"text":"Pub. L. 104–287, § 5(63)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3395"},"text":"110 Stat. 3395","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII"},"text":"Pub. L. 109–58, title VII","children":[],"tail":", §§ 759, 772(a), "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/833"},"text":"119 Stat. 833","children":[],"tail":", 834; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tI/s109/b"},"text":"Pub. L. 110–140, title I, § 109(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1506"},"text":"121 Stat. 1506","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tIII/s318/c"},"text":"Pub. L. 113–291, div. A, title III, § 318(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3341"},"text":"128 Stat. 3341","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb86b19f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb86b1a0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb86b1a1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32905(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2013(a), (f)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 20, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/513"},"text":"Pub. L. 92–513","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/947"},"text":"86 Stat. 947","children":[],"tail":", § 513(a)–(f); added "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/494/s6/a"},"text":"Pub. L. 100–494, § 6(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2448"},"text":"102 Stat. 2448","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/486/s403/5/A"},"text":"Pub. L. 102–486, § 403(5)(A)","children":[],"tail":"–(F), "},{"tag":"html:a","attrib":{"href":"/us/stat/106/2876"},"text":"106 Stat. 2876","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32905(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2013(b), (f)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32905(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2013(c), (f)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32905(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2013(d), (f)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32905(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2013(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32905(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2013(f)(2)(B).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"32905(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2013(f)(2)(A).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a) and (c), the words “after model year 1992” are substituted for “Subsections (a) and (c) shall apply only to automobiles manufactured after model year 1992” because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (d), before each clause (1), the words “in model years 1993–2004” are substituted for “Except as otherwise provided in this subsection, subsections (b) and (d) shall apply only to automobiles manufactured in model year 1993 through model year 2004” to eliminate unnecessary words and because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “For purposes of this section” and “than natural gas” are omitted as unnecessary because of the restatement. The words “a gallon equivalent of natural gas” are omitted as being included in “A gallon equivalent of any gaseous fuel”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “subject to the provisions of this section” are omitted as unnecessary because of the restatement. The words “for each model described under subsections (a)–(d) of this section” are substituted for “for each model type of dedicated automobile or dual fueled automobile” to eliminate unnecessary words. The words “by using as the denominator” are substituted for “by including as the denominator of the term” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb86b1a2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb86b1a3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsecs. (e) to (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/291"},"text":"Pub. L. 113–291","children":[],"tail":" added subsec. (e) and redesignated former subsecs. (e) and (f) as (f) and (g), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2007—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s109/b/1"},"text":"Pub. L. 110–140, § 109(b)(1)","children":[],"tail":", substituted “1993 through 2019” for “1993–2010” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s109/c"},"text":"Pub. L. 110–140, § 109(c)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “.5 divided by the fuel economy measured under subsection (a) of this section when operating the model on alternative fuel.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s109/b/2"},"text":"Pub. L. 110–140, § 109(b)(2)","children":[],"tail":", substituted “1993 through 2019” for “1993–2010” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f) to (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/140/s109/b/3"},"text":"Pub. L. 110–140, § 109(b)(3)","children":[],"tail":", (4), redesignated subsec. (h) as (f) and struck out former subsecs. (f) and (g) which related to temporary extension of application of subsecs. (b) and (d) and study and report on success of the policy of subsecs. (b) and (d), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsecs. (b), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s772/a/1"},"text":"Pub. L. 109–58, § 772(a)(1)","children":[],"tail":", substituted “1993–2010” for “1993–2004” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s772/a/2"},"text":"Pub. L. 109–58, § 772(a)(2)","children":[],"tail":", substituted “2007” for “2001” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s772/a/3"},"text":"Pub. L. 109–58, § 772(a)(3)","children":[],"tail":", substituted “2010” for “2004”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/58/s759"},"text":"Pub. L. 109–58, § 759","children":[],"tail":", added subsec. (h)."}],