{"tag":"section","attrib":{"id":"idcbb8bde0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41107"},"text":null,"children":[{"tag":"num","attrib":{"value":"41107"},"text":"§ 41107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation of mail","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When the United States Postal Service finds that the needs of the Postal Service require the transportation of mail by aircraft in foreign air transportation or between places in Alaska, in addition to the transportation of mail authorized under certificates in effect, the Postal Service shall certify that finding to the Secretary of Transportation with a statement about the additional transportation and facilities necessary to provide the additional transportation. A copy of each certification and statement shall be posted for at least 20 days in the office of the Secretary. After notice and an opportunity for a hearing, the Secretary shall issue a new certificate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":", or amend or modify an existing certificate under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s41110/a/2/A"},"text":"section 41110(a)(2)(A) of this title","children":[],"tail":", to provide the additional transportation and facilities if the Secretary finds the additional transportation is required by the public convenience and necessity."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcbb8bde1-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":", §§ 1(e), 4(k)(1), "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1121"},"text":"108 Stat. 1121","children":[],"tail":", 1370; "},{"tag":"ref","attrib":{"href":"/us/pl/106/31/tVI/s6003"},"text":"Pub. L. 106–31, title VI, § 6003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-05-21"},"text":"May 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/113"},"text":"113 Stat. 113","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbb8bde2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbb8bde3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbb8bde4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272, § 1(e)"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41107","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1371(m).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s401/m"},"text":"Pub. L. 85–726, § 401(m)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/757"},"text":"72 Stat. 757","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(a)(4)(A) (related to 49 App.:1371(m)), (b)(1)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(a)(4)(A) (related to § 401(m)), (b)(1)(E); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/c"},"text":"Pub. L. 98–443, § 3(c)","children":[],"tail":", (e), "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1703"},"text":"98 Stat. 1703","children":[],"tail":", 1704."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “from time to time” are omitted as surplus. The words “United States Postal Service” and “Postal Service” are substituted for “Postmaster General” in section 401(m) of the Federal Aviation Act of 1958 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/757"},"text":"72 Stat. 757","children":[],"tail":") because of sections 4(a) and 6("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":") of the Postal Reorganization Act ("},{"tag":"ref","attrib":{"href":"/us/pl/91/375"},"text":"Public Law 91–375","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/773"},"text":"84 Stat. 773","children":[],"tail":", 783). The words “in foreign air transportation or between places in Alaska” are substituted for “between any points within the United States or between the United States and foreign countries” for consistency in the revised title and because 49 App.:1551(a)(4)(A) provides that 49 App.:1371(m) no longer applies to interstate or overseas air transportation (except transportation of mail between 2 places in Alaska). In addition, Congress did not intend to maintain the regulation of domestic air transportation of mail. See section 40102(a) of the revised title defining “air transportation” to mean interstate or foreign air transportation or the transportation of mail by aircraft. The word “currently” is omitted as surplus. The words “opportunity for a” are added for consistency in the revised title and with other titles of the United States Code. The words “or certificates” are omitted as surplus because of 1:1. The word “modify” is added for consistency in the revised title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbb8bde5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbb8bde6-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L.","children":[],"tail":" 103–272, § 4(k)"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41107","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(a)(8).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(a)(8); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/c"},"text":"Pub. L. 98–443, § 3(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 30, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/457/s346"},"text":"Pub. L. 100–457, § 346","children":[],"tail":" (related to § 1601(a)(8) of Federal Aviation Act of 1958), "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2155"},"text":"102 Stat. 2155","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(b)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(b)(3); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/f"},"text":"Pub. L. 98–443, § 3(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 30, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/457/s346"},"text":"Pub. L. 100–457, § 346","children":[],"tail":" (related to § 1601(b)(3) of Federal Aviation Act of 1958), "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2155"},"text":"102 Stat. 2155","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4(k) reflects amendments to the restatement required by section 1601(a)(8) of the Federal Aviation Act of 1958 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":"), as added by section 3(c) of the Civil Aeronautics Board Sunset Act of 1984 ("},{"tag":"ref","attrib":{"href":"/us/pl/98/443"},"text":"Public Law 98–443","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"), and section 1601(b)(3) of the Federal Aviation Act of 1958 ("},{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":"), as added by section 3(f) of the Civil Aeronautics Board Sunset Act of 1984 ("},{"tag":"ref","attrib":{"href":"/us/pl/98/443"},"text":"Public Law 98–443","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"). Section 1601(a)(8) provides that the authority under 49 App.:1371("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") and (m) and 1375(b)–(d) as those sections relate to transportation of mail by aircraft between places in Alaska (restated in sections 41107 and 41901–41903 of the revised title) ceases on "},{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":". Section 1601(b)(3) transfers the authority for prescribing rates for transportation of mail between places in Alaska from the Secretary of Transportation to the Postal Service effective "},{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbb8bde7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbb8bde8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/31"},"text":"Pub. L. 106–31","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/k"},"text":"Pub. L. 103–272, § 4(k)","children":[],"tail":". See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/k/1"},"text":"Pub. L. 103–272, § 4(k)(1)","children":[],"tail":", which directed the amendment of this section by substituting “foreign air transportation,” for “foreign air transportation or between places in Alaska,”, effective "},{"tag":"date","attrib":{"date":"1999-01-01"},"text":"Jan. 1, 1999","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/31/s6003"},"text":"Pub. L. 106–31, § 6003","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1998-12-31"},"text":"Dec. 31, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbb8bde9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbb8bdea-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/31/tVI/s6003"},"text":"Pub. L. 106–31, title VI, § 6003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-05-21"},"text":"May 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/113"},"text":"113 Stat. 113","children":[],"tail":", provided that the amendment made by section 6003 is effective "},{"tag":"date","attrib":{"date":"1998-12-31"},"text":"Dec. 31, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbb8bdeb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/k"},"text":"Pub. L. 103–272, § 4(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1370"},"text":"108 Stat. 1370","children":[],"tail":", which provided that the amendments made by that section (amending this section and sections 41901, 41902, and 41903 of this title) were effective "},{"tag":"date","attrib":{"date":"1999-01-01"},"text":"Jan. 1, 1999","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/31/tVI/s6003"},"text":"Pub. L. 106–31, title VI, § 6003","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-05-21"},"text":"May 21, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/113"},"text":"113 Stat. 113","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1998-12-31"},"text":"Dec. 31, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
