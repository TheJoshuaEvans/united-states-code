{"tag":"section","attrib":{"id":"idcc85d20d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60138"},"text":null,"children":[{"tag":"num","attrib":{"value":"60138"},"text":"§ 60138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Response plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc85d20e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60138/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d20f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60138/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain on file a copy of the most recent response plan (as defined in part 194 of title 49, Code of Federal Regulations) prepared by an owner or operator of a pipeline facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d210-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60138/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide upon written request to a person a copy of the plan, which may exclude, as the Secretary determines appropriate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc85d211-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60138/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proprietary information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d212-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60138/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" security-sensitive information, including information described in section 1520.5(a) of title 49, Code of Federal Regulations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d213-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60138/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" specific response resources and tactical resource deployment plans; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d214-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60138/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the specific amount and location of worst case discharges (as defined in part 194 of title 49, Code of Federal Regulations), including the process by which an owner or operator determines the worst case discharge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d215-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60138/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to FOIA","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to require disclosure of information or records that are exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc85d216-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90/s6/c/1"},"text":"Pub. L. 112–90, § 6(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1910"},"text":"125 Stat. 1910","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
