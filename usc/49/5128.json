{"tag":"section","attrib":{"id":"idca95e88d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5128"},"text":null,"children":[{"tag":"num","attrib":{"value":"5128"},"text":"§ 5128.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authorization of appropriations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca95e88e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5128/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"There are authorized to be appropriated to the Secretary to carry out this chapter (except sections 5107(e), 5108(g)(2), 5113, 5115, 5116, and 5119)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95e88f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5128/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $67,000,000 for fiscal year 2022;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e890-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5128/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $68,000,000 for fiscal year 2023;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e891-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5128/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $69,000,000 for fiscal year 2024;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e892-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5128/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $70,000,000 for fiscal year 2025; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e893-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5128/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $71,000,000 for fiscal year 2026.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca95e894-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5128/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hazardous Materials Emergency Preparedness Fund","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"From the Hazardous Materials Preparedness Fund established under section 5116(h), the Secretary may expend, for each of fiscal years 2022 through 2026—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca95e895-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5128/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $39,050,000 to carry out section 5116(a);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e896-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5128/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000 to carry out section 5116(e);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca95e897-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5128/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","childr