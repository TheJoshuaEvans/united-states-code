{"tag":"section","attrib":{"id":"idcae4a525-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10906"},"text":null,"children":[{"tag":"num","attrib":{"value":"10906"},"text":"§ 10906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exception","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding section 10901 and subchapter II of chapter 113 of this title, and without the approval of the Board, a rail carrier providing transportation subject to the jurisdiction of the Board under this part may enter into arrangements for the joint ownership or joint use of spur, industrial, team, switching, or side tracks. The Board does not have authority under this chapter over construction, acquisition, operation, abandonment, or discontinuance of spur, industrial, team, switching, or side tracks.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcae4a526-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/827"},"text":"109 Stat. 827","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcae4a527-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcae4a528-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcae4a529-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p