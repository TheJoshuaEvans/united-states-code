{"tag":"section","attrib":{"id":"idca85468c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303"},"text":null,"children":[{"tag":"num","attrib":{"value":"1303"},"text":"§ 1303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative provisions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca85468d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Open Meetings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca85468e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall be deemed to be an agency for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca85468f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonpublic collaborative discussions.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca854690-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":", a majority of the members may hold a meeting that is not open to public observation to discuss official agency business if—"}],"tail":null},{"tag":"clause","attrib":{"id":"idca854691-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no formal or informal vote or other official agency action is taken at the meeting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca854692-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each individual present at the meeting is a member or an employee of the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca854693-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Counsel of the Board is present at the meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca854694-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure of nonpublic collaborative discussions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided under subparagraph (C), not later than 2 business days after the conclusion of a meeting under subparagraph (A), the Board shall make available to the public, in a place easily accessible to the public—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca854695-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the individuals present at the meeting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca854696-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the matters discussed at the meeting, except for any matters the Board properly determines may be withheld from the public under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b/c"},"text":"section 552b(c) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca854697-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Summary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Board properly determines matters may be withheld from the public under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s555b/c"},"text":"section 555b(c) of title 5","children":[],"tail":", the Board shall provide a summary with as much general information as possible on those matters withheld from the public."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca854698-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ongoing proceedings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a discussion under subparagraph (A) directly relates to an ongoing proceeding before the Board, the Board shall make the disclosure under subparagraph (B) on the date of the final Board decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca854699-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation of open meetings requirements for agency action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this paragraph may be construed to limit the applicability of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":" with respect to a meeting of the members other than that described in this paragraph."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca85469a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statutory construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this paragraph may be construed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca85469b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the applicability of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":" with respect to any information which is proposed to be withheld from the public under subparagraph (B)(ii); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca85469c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/a/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize the Board to withhold from any individual any record that is accessible to that individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca85469d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Representation by Attorneys","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Attorneys designated by the Chairman of the Board may appear for, and represent the Board in, any civil action brought in connection with any function carried out by the Board pursuant to this chapter or subtitle IV or as otherwise authorized by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca85469e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Admission To Practice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s500"},"text":"section 500 of title 5","children":[],"tail":", the Board may regulate the admission of individuals to practice before it and may impose a reasonable admission fee."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca85469f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Certain Documents to Congress.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8546a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Board submits any budget estimate, budget request, supplemental budget estimate, or other budget information, legislative recommendation, prepared testimony for a congressional hearing, or comment on legislation to the President or to the Office of Management and Budget, the Board shall concurrently submit a copy of such document to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8546a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8546a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8546a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1303/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No approval required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No officer or agency of the United States has any authority to require the Board to submit budget estimates or requests, legislative recommendations, prepared testimony for congressional hearings, or comments on legislation to any officer or agency of the United States for approval, comments, or review before submitting such recommendations, testimony, or comments to Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8546a4-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tII/s201/a"},"text":"Pub. L. 104–88, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/934"},"text":"109 Stat. 934","children":[],"tail":", § 703; renumbered § 1303 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/110"},"text":"Pub. L. 114–110","children":[],"tail":", §§ 3(a)(3), (c)(1), 5, "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2228-2230"},"text":"129 Stat. 2228–2230","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8546a5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8546a6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca8546a7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s3/a/3"},"text":"Pub. L. 114–110, § 3(a)(3)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s703"},"text":"section 703 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s5"},"text":"Pub. L. 114–110, § 5","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “For purposes of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":", United States Code, the Board shall be deemed to be an agency.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s3/c/1/A"},"text":"Pub. L. 114–110, § 3(c)(1)(A)","children":[],"tail":", (B), redesignated subsec. (b) as (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “Chapter 9 of title 5, United States Code, shall apply to the Board in the same manner as it does to an independent regulatory agency, and the Board shall be an establishment of the United States Government.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s3/c/1/B"},"text":"Pub. L. 114–110, § 3(c)(1)(B)","children":[],"tail":", redesignated subsec. (d) as (b). Former subsec. (b) redesignated (a)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s3/c/1/A"},"text":"Pub. L. 114–110, § 3(c)(1)(A)","children":[],"tail":", (B), redesignated subsec. (e) as (c) and struck out former subsec. (c). Prior to amendment, text read as follows: “In the performance of their functions, the members, employees, and other personnel of the Board shall not be responsible to or subject to the supervision or direction of any officer, employee, or agent of any other part of the Department of Transportation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s3/c/1/C"},"text":"Pub. L. 114–110, § 3(c)(1)(C)","children":[],"tail":", added subsec. (d). Former subsec. (d) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s3/c/1/B"},"text":"Pub. L. 114–110, § 3(c)(1)(B)","children":[],"tail":", redesignated subsec. (e) as (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s3/c/1/A"},"text":"Pub. L. 114–110, § 3(c)(1)(A)","children":[],"tail":", struck out subsecs. (f) and (g) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(f) ","children":[{"tag":"inline","attrib":{},"text":"Budget Requests","children":[],"tail":".—In each annual request for appropriations by the President, the Secretary of Transportation shall identify the portion thereof intended for the support of the Board and include a statement by the Board—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) showing the amount requested by the Board in its budgetary presentation to the Secretary and the Office of Management and Budget; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) an assessment of the budgetary needs of the Board.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(g) ","children":[{"tag":"inline","attrib":{},"text":"Direct Transmittal to Congress","children":[],"tail":".—The Board shall transmit to Congress copies of budget estimates, requests, and information (including personnel needs), legislative recommendations, prepared testimony for congressional hearings, and comments on legislation at the same time they are sent to the Secretary of Transportation. An officer of an agency may not impose conditions on or impair communications by the Board with Congress, or a committee or Member of Congress, about the information.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
