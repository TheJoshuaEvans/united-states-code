{"tag":"section","attrib":{"id":"idca8790ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1323"},"text":null,"children":[{"tag":"num","attrib":{"value":"1323"},"text":"§ 1323.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Service of notice in Board proceedings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8790ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1323/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designation of Agent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier providing transportation subject to the jurisdiction of the Board under subtitle IV shall designate an agent on whom service of notices in a proceeding before, and of actions of, the Board may be made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8790ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1323/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing and Changing Designations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A designation under subsection (a) shall be in writing and filed with the Board. The designation may be changed at any time in the same manner as originally made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8790ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1323/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Service of Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided, notices of the Board shall be served on its designated agent at the office or usual place of residence of that agent. A notice of action of the Board shall be served immediately on the agent or in another manner provided by law. If that carrier does not have a designated agent, service may be made by posting the notice in the office of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8790f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1323/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule for Rail Carriers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In a proceeding involving the lawfulness of classifications, rates, or practices of a rail carrier that has not designated an agent under this section, service of notice of the Board on an attorney in fact for the carrier constitutes service of notice on the carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8790f1-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tII/s201/a"},"text":"Pub. L. 104–88, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/937"},"text":"109 Stat. 937","children":[],"tail":", § 723; renumbered § 1323 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/110"},"text":"Pub. L. 114–110","children":[],"tail":", §§ 3(a)(5), 8(a), "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2228"},"text":"129 Stat. 2228","children":[],"tail":", 2232.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8790f2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8790f3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca8790f4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s3/a/3"},"text":"Pub. L. 114–110, § 3(a)(3)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s723"},"text":"section 723 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s8/a/1"},"text":"Pub. L. 114–110, § 8(a)(1)","children":[],"tail":", struck out “in the District of Columbia,” after “designate an agent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s8/a/2"},"text":"Pub. L. 114–110, § 8(a)(2)","children":[],"tail":", struck out “in the District of Columbia” after “ usual place of residence”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
