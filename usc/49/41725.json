{"tag":"section","attrib":{"id":"idcbc715fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41725"},"text":null,"children":[{"tag":"num","attrib":{"value":"41725"},"text":"§ 41725.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on certain cell phone voice communications","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbc715fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41725/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall issue regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc715fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41725/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit an individual on an aircraft from engaging in voice communications using a mobile communications device during a flight of that aircraft in scheduled passenger interstate or intrastate air transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc715fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41725/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that exempt from the prohibition described in paragraph (1) any—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbc715fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41725/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" member of the flight crew on duty on an aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc715ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41725/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flight attendant on duty on an aircraft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc71600-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41725/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal law enforcement officer acting in an official capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc71601-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41725/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc71602-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41725/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Flight","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “flight” means, with respect to an aircraft, the period beginning when the aircraft takes off and ending when the aircraft lands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc71603-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41725/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mobile communications device.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbc71604-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41725/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “mobile communications device” means any portable wireless telecommunications equipment utilized for the transmission or reception of voice data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc71605-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41725/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “mobile communications device” does not include a phone installed on an aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbc71606-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIV/s403/a"},"text":"Pub. L. 115–254, div. B, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3328"},"text":"132 Stat. 3328","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
