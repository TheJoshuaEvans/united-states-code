{"tag":"section","attrib":{"id":"idcb085937-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15723"},"text":null,"children":[{"tag":"num","attrib":{"value":"15723"},"text":"§ 15723.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by carriers, lessors, and associations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb085938-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15723/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing of Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may require pipeline carriers, lessors, and associations, or classes of them as the Board may prescribe, to file annual, periodic, and special reports with the Board containing answers to questions asked by it.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb085939-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15723/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Under Oath","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any report under this section shall be made under oath.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb08593a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s106/a"},"text":"Pub. L. 104–88, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/926"},"text":"109 Stat. 926","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb08593b-47c4-11f1-9671-b5