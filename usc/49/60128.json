{"tag":"section","attrib":{"id":"idcc83884a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60128"},"text":null,"children":[{"tag":"num","attrib":{"value":"60128"},"text":"§ 60128.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dumping within pipeline rights-of-way","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc83884b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60128/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person shall excavate for the purpose of unauthorized disposal within the right-of-way of an interstate gas pipeline facility or interstate hazardous liquid pipeline facility, or any other limited area in the vicinity of any such interstate pipeline facility established by the Secretary of Transportation, and dispose solid waste therein.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc83884c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60128/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the term “solid waste” has the meaning given that term in section 1004(27) of the Solid Waste Disposal Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s6903/27"},"text":"42 U.S.C. 6903(27)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc83884d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s18/a"},"text":"Pub. L. 104–304, § 18(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3804"},"text":"110 Stat. 3804","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
