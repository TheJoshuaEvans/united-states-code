trib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “as required in each case by the Secretary” are omitted as surplus. In clause (11), the words “such items as” and “where applicable” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “Beginning ","children":[{"tag":"date","attrib":{"date":"1987-10-01"},"text":"October 1, 1987","children":[],"tail":"” are omitted as executed. The words “with any person” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “In addition to the purposes provided for under subsection (a) of this section” and “with any person” are omitted as surplus. The cross-reference to paragraph (1) is not changed. The cross-reference in 49 App.:1619(h), the source provision being restated in this subsection, is no longer correct, but is apparently still meant to apply to funds made available under 49 App.:1619(a).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), before clause (1), the text of 49 App.:1619(f) (2d sentence) is omitted as executed. In clause (1), The words “vehicles or other” and “the performance of” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcabc0dfb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:5327(c)(1) to correct an erroneous cross-reference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcabc0dfc-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:5327(c) to correct an erroneous cross-reference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcabc0dfd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcabc0dfe-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 5338, referred to in subsecs. (c) and (d)(1), was amended generally by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dC/s30017"},"text":"Pub. L. 117–58, div. C, § 30017","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/912"},"text":"135 Stat. 912","children":[],"tail":". As amended, section 5338 no longer contains a subsec. (f). Provisions relating to oversight, formerly contained in section 5338(f), can be found elsewhere in section 5338."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcabc0dff-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s3012/1"},"text":"Pub. L. 114–94, § 3012(1)","children":[],"tail":", which directed substitution of section “5338(f)” for “section 5338(i)”, was executed by substituting “section 5338(f)” for “section 5338(i)”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s3012/2/A/i"},"text":"Pub. L. 114–94, § 3012(2)(A)(i)","children":[],"tail":", which directed substitution of section 5338(f) for “section 5338(i)” without placing quotation marks around the language to be substituted, was executed by substituting “section 5338(f)” for “section 5338(i)”, to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s3012/2/A/ii"},"text":"Pub. L. 114–94, § 3012(2)(A)(ii)","children":[],"tail":", (B), added pars. (2) and (3) and struck out former par. (2), which read as follows: “a requirement that oversight begin during the project development phase of a project, unless the Secretary finds it more appropriate to begin the oversight during another phase of the project, to maximize the transportation benefits and cost savings associated with project management oversight.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s20020/1/A"},"text":"Pub. L. 112–141, § 20020(1)(A)","children":[],"tail":", in introductory provisions, substituted “Federal financial assistance for a major capital project for public transportation under this chapter or any other provision of Federal law, a recipient must prepare a project management plan approved by the Secretary and carry out the project in accordance with the project management plan” for “United States Government financial assistance for a major capital project under this chapter or the National Capital Transportation Act of 1969 ("},{"tag":"ref","attrib":{"href":"/us/pl/91/143"},"text":"Public Law 91–143","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/83/320"},"text":"83 Stat. 320","children":[],"tail":"), a recipient must prepare and carry out a project management plan approved by the Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s20020/1/B"},"text":"Pub. L. 112–141, § 20020(1)(B)","children":[],"tail":", substituted “quarterly” for “each month”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s20020/2"},"text":"Pub. L. 112–141, § 20020(2)","children":[],"tail":", (3), added subsec. (c) and struck out former subsec. (c) which related to limitations."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s20020/2"},"text":"Pub. L. 112–141, § 20020(2)","children":[],"tail":", (4), redesignated subsec. (e) as (d) and struck out former subsec. (d) which related to access to sites and records."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s20020/5/A"},"text":"Pub. L. 112–141, § 20020(5)(A)","children":[],"tail":", substituted “section 5338(i)” for “subsection (c) of this section”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s20020/5/B"},"text":"Pub. L. 112–141, § 20020(5)(B)","children":[],"tail":", substituted “project development phase” for “preliminary engineering stage” and “another phase” for “another stage”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s20020/4"},"text":"Pub. L. 112–141, § 20020(4)","children":[],"tail":", redesignated subsec. (e) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s20020/2"},"text":"Pub. L. 112–141, § 20020(2)","children":[],"tail":", struck out subsec. (f). Text read as follows: “A recipient of financial assistance for a project under this chapter with an estimated total cost of $1,000,000,000 or more shall submit to the Secretary an annual financial plan for the project. The plan shall be based on detailed annual estimates of the cost to complete the remaining elements of the project and on reasonable assumptions, as determined by the Secretary, of future increases in the cost to complete the project.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s3026/a"},"text":"Pub. L. 109–59, § 3026(a)","children":[],"tail":", added par. (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s3026/b"},"text":"Pub. L. 109–59, § 3026(b)","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, subsec. (c) specified limitations on use of available amounts for certain purposes."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s3024/a"},"text":"Pub. L. 105–178, § 3024(a)","children":[],"tail":", substituted “enter into contracts” for “make contracts” and inserted “and to provide technical assistance to correct deficiencies identified in compliance reviews and audits carried out under this section” before period at end of first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s3024/b"},"text":"Pub. L. 105–178, § 3024(b)","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" substituted “to carry out a major project under section 5309” for “to carry out a major project under section 5307”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" substituted “section 5307, 5309, 5311, or 1