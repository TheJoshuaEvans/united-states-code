{"tag":"section","attrib":{"id":"idcc707568-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103"},"text":null,"children":[{"tag":"num","attrib":{"value":"50103"},"text":"§ 50103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Contract preference for domestic firms","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc707569-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc70756a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “domestic firm” means a business entity incorporated, and conducting business, in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc70756b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “foreign firm” means a business entity not described in clause (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc70756c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preference","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (c) and (d) of this section, the Administrator of the Federal Aviation Administration may make, with a domestic firm, a contract related to a grant made under section 44511, 44512, or 44513 of this title that, under competitive procedures, would be made with a foreign firm, if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc70756d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator decides, and the Secretary of Commerce and the United States Trade Representative concur, that the public interest requires making the contract with the domestic firm, considering United States international obligations and trade relations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc70756e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the difference between the bids submitted by the foreign firm and the domestic firm is not more than 6 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc70756f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final product of the domestic firm will be assembled completely in the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc707570-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 51 percent of the final product of the domestic firm will be produced in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc707571-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (b) of this section does not apply if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc707572-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compelling national security considerations require that subsection (b) of this section not apply; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc707573-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Trade Representative decides that making the contract would violate the multilateral trade agreements (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/4"},"text":"section 3501(4) of title 19","children":[],"tail":") or an international agreement to which the United States is a party."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc707574-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to Certain Grants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies only to a contract related to a grant made under section 44511, 44512, or 44513 of this title for which—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc707575-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an amount is authorized by section 48102(a), (b), or (d) of this title to be made available for the fiscal years ending ","children":[{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc707576-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a solicitation for bid is issued after ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc707577-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall submit a report to Congress on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc707578-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contracts to which this section applies that are made with foreign firms in the fiscal years ending ","children":[{"tag":"date","attrib":{"date":"1991-09-30"},"text":"September 30, 1991","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1992-09-30"},"text":"September 30, 1992","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc707579-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of contracts that meet the requirements of subsection (b) of this section, but that the Trade Representative decides would violate the multilateral trade agreements (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/4"},"text":"section 3501(4) of title 19","children":[],"tail":") or an international agreement to which the United States is a party; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc70757a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50103/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of contracts made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc70757b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1298"},"text":"108 Stat. 1298","children":[],"tail":", § 49103; renumbered § 50103, "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/88/D"},"text":"Pub. L. 104–287, § 5(88)(D)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3398"},"text":"110 Stat. 3398","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/36/tI/s1002/i"},"text":"Pub. L. 106–36, title I, § 1002(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-06-25"},"text":"June 25, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/134"},"text":"113 Stat. 134","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc70757c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc70757d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc70757e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"49103(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2226d(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/508/s9207"},"text":"Pub. L. 101–508, § 9207","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/1388-375"},"text":"104 Stat. 1388–375","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"49103(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2226d(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"49103(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2226d(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"49103(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2226d(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"49103(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2226d(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the text of 49 App.:2226d(e)(1) is omitted because the complete name of the Administrator of the Federal Aviation Administration is used the first time the term appears in a section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “Subject to subsections (c) and (d) of this section” are added to alert the reader to the limitations in those subsections. In clause (1), the words “requires making the contract with the domestic firm” are substituted for “so requires” for clarity. The words “considering United States international obligations and trade relations” are substituted for “In determining under this subsection whether the public interest so requires, the Administrator shall take into account United States international obligations and trade relations” to eliminate unnecessary words. In clause (4), the words “when completely assembled” are omitted as surplus. The words “produced in the United States” are substituted for “domestically produced” for consistency with clause (3).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “(1) such applicability would not be in the public interest” are omitted as redundant to subsection (b)(1) of the revised section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(1), the words “foreign firms” are substituted for “foreign entities” for consistency in the revised section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (e)(3) is substituted for “the number of contracts covered under this subtitle (including the amendments made by this subtitle) and awarded based upon the parameters of this section” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc70757f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc707580-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1999—Subsecs. (c)(2), (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/36"},"text":"Pub. L. 106–36","children":[],"tail":" substituted “multilateral trade agreements (as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t19/s3501/4"},"text":"section 3501(4) of title 19","children":[],"tail":")” for “General Agreement on Tariffs and Trade”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s49103"},"text":"section 49103 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
