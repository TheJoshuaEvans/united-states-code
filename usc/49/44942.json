{"tag":"section","attrib":{"id":"idcc325a91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44942"},"text":null,"children":[{"tag":"num","attrib":{"value":"44942"},"text":"§ 44942.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Performance goals and objectives","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc325a92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44942/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Short Term Transition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc325a93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44942/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of the Transportation Security Administration may, in consultation with other relevant Federal agencies and Congress—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc325a94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44942/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish acceptable levels of performance for aviation security, including screening operations and access control; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc325a95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44942/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide Congress with an action plan, containing measurable goals and milestones, that outlines how those levels of performance will be achieved.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc325a96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44942/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Basics of action plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The action plan shall clarify the responsibilities of the Transportation Security Administration, the Federal Aviation Administration, and any other agency or organization that may have a role in ensuring the safety and security of the civil air transportation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc325a97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44942/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Long-Term Results-Based Management.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc325a98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44942/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance plan.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc325a99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44942/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each year, consistent with the requirements of the Government Performance and Results Act of 1993 (GPRA), the Secretary of Homeland Security and the Administrator of the Transportation Security Administration shall agree on a performance plan for the succeeding 5 years that establishes measurable goals and objectives for aviation security. The plan shall identify action steps necessary to achieve such goals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc34cb9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44942/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to meeting the requirements of GPRA, the performance plan should clarify the responsibilities of the Secretary of Homeland Security, the Administrator of the Transportation Security Administration, and any other agency or organization that may have a role in ensuring the safety and security of the civil air transportation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cb9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44942/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each year, consistent with the requirements of GPRA, the Administrator of the Transportation Security Administration shall prepare and submit to Congress an annual report including an evaluation of the extent goals and objectives were met. The report shall include the results achieved during the year relative to the goals established in the performance plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc34cb9c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s130"},"text":"Pub. L. 107–71, title I, § 130","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/633"},"text":"115 Stat. 633","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/d/33"},"text":"Pub. L. 115–254, div. K, title I, § 1991(d)(33)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3640"},"text":"132 Stat. 3640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc34cb9d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc34cb9e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc34cb9f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Government Performance and Results Act of 1993, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/62"},"text":"Pub. L. 103–62","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-08-03"},"text":"Aug. 3, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/285"},"text":"107 Stat. 285","children":[],"tail":", which enacted "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees, sections 1115 to 1119, 9703, and 9704 of Title 31, Money and Finance, and sections 2801 to 2805 of Title 39, Postal Service, amended "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1105"},"text":"section 1105 of Title 31","children":[],"tail":", and enacted provisions set out as notes under sections 1101 and 1115 of Title 31. For complete classification of this Act to the Code, see Short Title of 1993 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s1101"},"text":"section 1101 of Title 31","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc34cba0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/33/A/i/I"},"text":"Pub. L. 115–254, § 1991(d)(33)(A)(i)(I)","children":[],"tail":", in introductory provisions, substituted “The Administrator of the Transportation Security Administration may, in consultation with other relevant Federal agencies and” for “Within 180 days after the date of enactment of the Aviation and Transportation Security Act, the Under Secretary for Transportation Security may, in consultation with”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/33/A/i/II"},"text":"Pub. L. 115–254, § 1991(d)(33)(A)(i)(II)","children":[],"tail":", substituted “; and” for “, and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/33/A/ii"},"text":"Pub. L. 115–254, § 1991(d)(33)(A)(ii)","children":[],"tail":", inserted comma after “Federal Aviation Administration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/33/B/i"},"text":"Pub. L. 115–254, § 1991(d)(33)(B)(i)","children":[],"tail":", (ii), struck out par. (1) designation and heading “Performance plan and report” and redesignated subpars. (A) and (B) of former par. (1) as pars. (1) and (2), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/33/B/iii/I"},"text":"Pub. L. 115–254, § 1991(d)(33)(B)(iii)(I)","children":[],"tail":", redesignated cls. (i) and (ii) of former par. (1)(A) as subpars. (A) and (B), respectively, of par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/33/B/iii/II"},"text":"Pub. L. 115–254, § 1991(d)(33)(B)(iii)(II)","children":[],"tail":", substituted “the Secretary of Homeland Security and the Administrator of the Transportation Security Administration shall agree” for “the Secretary and the Under Secretary for Transportation Security shall agree”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/33/B/iii/III"},"text":"Pub. L. 115–254, § 1991(d)(33)(B)(iii)(III)","children":[],"tail":", substituted “the Secretary of Homeland Security, the Administrator of the Transportation Security Administration,” for “the Secretary, the Under Secretary for Transportation Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/33/B/iv"},"text":"Pub. L. 115–254, § 1991(d)(33)(B)(iv)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration” for “Under Secretary for Transportation Security”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
