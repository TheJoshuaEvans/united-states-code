{"tag":"section","attrib":{"id":"idcc5d617a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129"},"text":null,"children":[{"tag":"num","attrib":{"value":"47129"},"text":"§ 47129.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resolution of disputes concerning airport fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc5d617b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Request Secretary’s Determination.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d617c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall issue a determination as to whether a fee imposed upon one or more air carriers or foreign air carriers (as those terms are defined in section 40102) by the owner or operator of an airport is reasonable if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc5d617d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written request for such determination is filed with the Secretary by such owner or operator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5d617e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a written complaint requesting such determination is filed with the Secretary by an affected air carrier or foreign air carrier within 60 days after such carrier receives written notice of the establishment or increase of such fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d617f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Calculation of fee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A fee subject to a determination of reasonableness under this section may be calculated pursuant to either a compensatory or residual fee methodology or any combination thereof.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6180-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary not to set fee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In determining whether a fee is reasonable under this section, the Secretary may only determine whether the fee is reasonable or unreasonable and shall not set the level of the fee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6181-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees imposed by privately-owned airports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In evaluating the reasonableness of a fee imposed by an airport receiving an exemption under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47134"},"text":"section 47134 of this title","children":[],"tail":", the Secretary shall consider whether the airport has complied with section 47134(c)(4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d6182-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedural Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1994-08-23"},"text":"August 23, 1994","children":[],"tail":", the Secretary shall publish in the Federal Register final regulations, policy statements, or guidelines establishing—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d6183-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the procedures for acting upon any written request or complaint filed under subsection (a)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6184-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the standards or guidelines that shall be used by the Secretary in determining under this section whether an airport fee is reasonable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d6185-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Decisions By Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The final regulations, policy statements, or guidelines required in subsection (b) shall provide the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d6186-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 120 days after an air carrier or foreign air carrier files with the Secretary a written complaint relating to an airport fee, the Secretary shall issue a final order determining whether such fee is reasonable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6187-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Within 30 days after such complaint is filed with the Secretary, the Secretary shall dismiss the complaint if no significant dispute exists or shall assign the matter to an administrative law judge; and thereafter the matter shall be handled in accordance with part 302 of title 14, Code of Federal Regulations, or as modified by the Secretary to ensure an orderly disposition of the matter within the 120-day period and any specifically applicable provisions of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6188-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The administrative law judge shall issue a recommended decision within 60 days after the complaint is assigned or within such shorter period as the Secretary may specify.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6189-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary, upon the expiration of 120 days after the filing of the complaint, has not issued a final order, the decision of the administrative law judge shall be deemed to be the final order of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d618a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any party to the dispute may seek review of a final order of the Secretary under this subsection in the Circuit Court of Appeals for the District of Columbia Circuit or the court of appeals in the circuit where the airport which gives rise to the written complaint is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d618b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any findings of fact in a final order of the Secretary under this subsection, if supported by substantial evidence, shall be conclusive if challenged in a court pursuant to this subsection. No objection to such a final order shall be considered by the court unless objection was urged before an administrative law judge or the Secretary at a proceeding under this subsection or, if not so urged, unless there were reasonable grounds for failure to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d618c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment Under Protest; Guarantee of Air Carrier and Foreign Air Carrier Access.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d618d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment under protest.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc5d618e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any fee increase or newly established fee which is the subject of a complaint that is not dismissed by the Secretary shall be paid by the complainant air carrier or foreign air carrier to the airport under protest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5d618f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Referral or credit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any amounts paid under this subsection by a complainant air carrier or foreign air carrier to the airport under protest shall be subject to refund or credit to the air carrier or foreign air carrier in accordance with directions in the final order of the Secretary within 30 days of such order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5d6190-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assurance of timely repayment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to assure the timely repayment, with interest, of amounts in dispute determined not to be reasonable by the Secretary, the airport shall obtain a letter of credit, or surety bond, or other suitable credit facility, equal to the amount in dispute that is due during the 120-day period established by this section, plus interest, unless the airport and the complainant air carrier or foreign air carrier agree otherwise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5d6191-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The letter of credit, or surety bond, or other suitable credit facility shall be provided to the Secretary within 20 days of the filing of the complaint and shall remain in effect for 30 days after the earlier of 120 days or the issuance of a timely final order by the Secretary determining whether such fee is reasonable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6192-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guarantee of air carrier and foreign air carrier access","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Contingent upon an air carrier’s or foreign air carrier’s compliance with the requirements of paragraph (1) and pending the issuance of a final order by the Secretary determining the reasonableness of a fee that is the subject of a complaint filed under subsection (a)(1)(B), an owner or operator of an airport may not deny an air carrier or foreign air carrier currently providing air service at the airport reasonable access to airport facilities or service, or otherwise interfere with an air carrier’s or foreign air carrier’s prices, routes, or services, as a means of enforcing the fee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d6193-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d6194-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fee imposed pursuant to a written agreement with air carriers or foreign air carriers using the facilities of an airport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6195-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a fee imposed pursuant to a financing agreement or covenant entered into prior to ","children":[{"tag":"date","attrib":{"date":"1994-08-23"},"text":"August 23, 1994","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6196-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other existing fee not in dispute as of ","children":[{"tag":"date","attrib":{"date":"1994-08-23"},"text":"August 23, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d6197-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect On Existing Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section shall adversely affect—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d6198-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rights of any party under any existing written agreement between an air carrier or foreign air carrier and the owner or operator of an airport; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6199-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of an airport to meet its obligations under a financing agreement, or covenant, that is in force as of ","children":[{"tag":"date","attrib":{"date":"1994-08-23"},"text":"August 23, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d619a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47129/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “fee” means any rate, rental charge, landing fee, or other service charge for the use of airport facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc5d619b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/tI/s113/a/2"},"text":"Pub. L. 103–305, title I, § 113(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-23"},"text":"Aug. 23, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1577"},"text":"108 Stat. 1577","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/tI/s149/d"},"text":"Pub. L. 104–264, title I, § 149(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3227"},"text":"110 Stat. 3227","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/85"},"text":"Pub. L. 104–287, § 5(85)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3397"},"text":"110 Stat. 3397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tI/s148/a"},"text":"Pub. L. 112–95, title I, § 148(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/31"},"text":"126 Stat. 31","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc5d619c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc5d619d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc5d619e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/85/A"},"text":"Pub. L. 104–287, § 5(85)(A)","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:47129(a)(1) to conform to the style of title 49.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc5d619f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/85/B"},"text":"Pub. L. 104–287, § 5(85)(B)","children":[],"tail":" and (C)"}],"tail":null},{"tag":"p","attrib":{},"text":"These set out the date of enactment of 49:47129.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc5d61a0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcc5d61a1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 47129 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47131"},"text":"section 47131 of this title","children":[],"tail":" and was subsequently repealed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc5d61a2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s148/a/1"},"text":"Pub. L. 112–95, § 148(a)(1)","children":[],"tail":", substituted “Resolution of disputes concerning airport fees” for “Resolution of airport-air carrier disputes concerning airport fees” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s148/a/6"},"text":"Pub. L. 112–95, § 148(a)(6)","children":[],"tail":", (7), substituted “air carriers or foreign air carriers” for “air carriers” and “(as those terms are defined in section 40102)” for “(as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102"},"text":"section 40102 of this title","children":[],"tail":")” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s148/a/4"},"text":"Pub. L. 112–95, § 148(a)(4)","children":[],"tail":", substituted “air carrier or foreign air carrier” for “air carrier”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s148/a/4"},"text":"Pub. L. 112–95, § 148(a)(4)","children":[],"tail":", substituted “air carrier or foreign air carrier” for “air carrier”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s148/a/2"},"text":"Pub. L. 112–95, § 148(a)(2)","children":[],"tail":", inserted “and Foreign Air Carrier” after “Carrier” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Su