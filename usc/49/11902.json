{"tag":"section","attrib":{"id":"idcaf08bd3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11902"},"text":null,"children":[{"tag":"num","attrib":{"value":"11902"},"text":"§ 11902.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interference with railroad car supply","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf08bd4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11902/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person that offers or gives anything of value to another person acting for or employed by a rail carrier providing transportation subject to the jurisdiction of the Board under this part intending to influence an action of that other person related to supply, distribution, or movement of cars, vehicles, or vessels used in the transportation of property, or because of the action of that other person, shall be fined not more than $1,000, imprisoned for not more than 2 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf08bd5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11902/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person acting for or employed by a rail carrier providing transportation subject to the jurisdiction of the Board under this part that solicits, accepts, or receives anything of value—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf08bd6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11902/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intending to be influenced by it in an action of that person related to supply, distribution, or movement of cars, vehicles, or vessels used in the transportation of property; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08bd7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11902/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of the action of that person,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall be fined not more than $1,000, imprisoned for not more than 2 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf08bd8-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/850"},"text":"109 Stat. 850","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf08bd9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf08bda-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf08bdb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11907"},"text":"section 11907 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n