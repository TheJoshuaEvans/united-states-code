tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/2182"},"text":"104 Stat. 2182","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2311(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “Dwight D. Eisenhower System of Interstate and Defense Highways” are substituted for “National System of Interstate and Defense Highways” because of the Act of ","children":[{"tag":"date","attrib":{"date":"1990-10-15"},"text":"October 15, 1990","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/101/427"},"text":"Public Law 101–427","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/927"},"text":"104 Stat. 927","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “property” is substituted for “cargo” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(1) is substituted for 49 App.:2311(a) and (b) (2d–last sentences) to eliminate unnecessary words and for consistency in the revised title and with other titles of the United States Code. Hyphens are used in describing the combinations “truck tractor-semitrailer” and “truck tractor-semitrailer-trailer” for consistency. In clause (D), the word “actually” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(2) is substituted for 49 App.:2311(b) (1st sentence) because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “such as rear view mirrors, turn signal lamps, marker lamps, steps and handholds for entry and egress, flexible fender extensions, mudflaps and splash and spray suppressant devices, load-induced tire bulge, refrigeration units or air compressors and other devices” are omitted as unnecessary and because most items listed relate to width rather than length.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “by regulation” are added for clarity. The words “subject to the provisions of subsections (a) and (c) of this section” are omitted as surplus. The text of 49 App.:2311(e)(2) and (3) is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the word “commercial” is added before “motor vehicle” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f)(4)(C), the reference to regulations prescribed under subsection (e) is substituted for the reference in the source to regulations issued under subsection (a) to be more precise. The word “amendment” is substituted for “revision” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (g) is substituted for 49 App.:2311(d) to eliminate unnecessary words. The Secretary’s general authority to prescribe regulations is provided in 49:322(a). The word “vessel” is substituted for “boat” because of 1:3. The text of 49 App.:2311(g) is omitted as executed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb608bbc-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb608bbd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s5520/a"},"text":"Pub. L. 114–94, § 5520(a)","children":[],"tail":", struck out “specifically” before “for the transport” and inserted at end “An automobile transporter shall not be prohibited from the transport of cargo or general freight on a backhaul, so long as it complies with weight limitations for a truck tractor and semitrailer combination.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s5520/b"},"text":"Pub. L. 114–94, § 5520(b)","children":[],"tail":", struck out “only” before “motor vehicles when operating” and inserted “or any other commodity, including cargo or general freight on a backhaul” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s5520/c"},"text":"Pub. L. 114–94, § 5520(c)","children":[],"tail":", added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(6), (7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s5523/a"},"text":"Pub. L. 114–94, § 5523(a)","children":[],"tail":", added pars. (6) and (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s5520/d"},"text":"Pub. L. 114–94, § 5520(d)","children":[],"tail":", added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(H). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s5523/b"},"text":"Pub. L. 114–94, § 5523(b)","children":[],"tail":", added subpar. (H)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244/s301/r/1"},"text":"Pub. L. 110–244, § 301(r)(1)","children":[],"tail":", in heading, substituted “Driveaway saddlemount” for “Drive-away saddlemount with fullmount”, and, in text, substituted “driveaway saddlemount” for “drive-away saddlemount with fullmount” and inserted at end “Such combination may include one fullmount.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244/s301/r/2"},"text":"Pub. L. 110–244, § 301(r)(2)","children":[],"tail":", substituted “all driveaway saddlemount” for “a driveaway saddlemount with fullmount”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4141/a"},"text":"Pub. L. 109–59, § 4141(a)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(D) to (F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4141/b"},"text":"Pub. L. 109–59, § 4141(b)","children":[],"tail":", added subpar. (D) and redesignated former subpars. (D) and (E) as (E) and (F), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4005/1"},"text":"Pub. L. 105–178, § 4005(1)","children":[],"tail":", substituted “section, the following definitions apply:” for “section—” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4005/5"},"text":"Pub. L. 105–178, § 4005(5)","children":[],"tail":", added par. (1). Former par. (1) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4005/2"},"text":"Pub. L. 105–178, § 4005(2)","children":[],"tail":", inserted “"},{"tag":"inline","attrib":{},"text":"Maxi-cube vehicle","children":[],"tail":".—The term” after “(1)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4005/4"},"text":"Pub. L. 105–178, § 4005(4)","children":[],"tail":", redesignated par. (1) as (2). Former par. (2) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4005/3"},"text":"Pub. L. 105–178, § 4005(3)","children":[],"tail":", inserted “"},{"tag":"inline","attrib":{},"text":"Truck tractor","children":[],"tail":".—The term” after “(2)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4005/4"},"text":"Pub. L. 105–178, § 4005(4)","children":[],"tail":", redesignated par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (b)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" added subpar. (E)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb62fcbe-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb62fcbf-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb62fcc0-47c4-11f1-9671-b5c725212f70"},"text":null,"