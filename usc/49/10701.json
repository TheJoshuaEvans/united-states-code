"tag":"ref","attrib":{"href":"/us/stat/108/1369"},"text":"108 Stat. 1369","children":[],"tail":", related to standards for rates for rail carriers. See "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s10701"},"text":"section 10701 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcadd78b0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110"},"text":"Pub. L. 114–110","children":[],"tail":" amended par. (3) generally. Prior to amendment, text read as follows: “The Board shall, within one year after "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":", complete the pending Interstate Commerce Commission non-coal rate guidelines proceeding to establish a simplified and expedited method for determining the reasonableness of challenged rail rates in those cases in which a full stand-alone cost presentation is too costly, given the value of the case.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"January 1, 1996","children":[],"tail":"” for “the effective date of this paragraph”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcadd78b1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcadd78b2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":