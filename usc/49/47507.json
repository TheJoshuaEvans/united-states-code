{"tag":"section","attrib":{"id":"idcc66d829-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47507"},"text":null,"children":[{"tag":"num","attrib":{"value":"47507"},"text":"§ 47507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Nonadmissibility of noise exposure map and related information as evidence","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No part of a noise exposure map or related information described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47503"},"text":"section 47503 of this title","children":[],"tail":" that is submitted to, or prepared by, the Secretary of Transportation and no part of a list of land uses the Secretary identifies as normally compatible with various exposures of individuals to noise may be admitted into evidence or used for any other purpose in a civil action asking for relief for noise resulting from the operation of an airport."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcc66d82a-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1287"},"text":"108 Stat. 1287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc66d82b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc66d82c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc66d82d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":