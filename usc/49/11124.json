{"tag":"section","attrib":{"id":"idcae96005-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11124"},"text":null,"children":[{"tag":"num","attrib":{"value":"11124"},"text":"§ 11124.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" War emergencies; embargoes imposed by carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcae96006-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11124/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcae96007-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11124/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the President, during time of war or threatened war, notifies the Board that it is essential to the defense and security of the United States to give preference or priority to the movement of certain traffic, the Board shall direct that preference or priority be given to that traffic.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae96008-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11124/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the President, during time of war or threatened war, demands that preference and precedence be given to the transportation of troops and material of war over all other traffic, all rail carriers providing transportation subject to the jurisdiction of the Board under this part shall adopt every means within their control to facilitate and expedite the military traffic.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae96009-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11124/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An embargo imposed by any such rail carrier does not apply to shipments consigned to agents of the United States Government for its use. The rail carrier shall deliver those shipments as promptly as possible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcae9600a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/834"},"text":"109 Stat. 834","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcae9600b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcae9600c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcae9600d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11128"},"text":"section 11128 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Prior sections 11124 to 11128 were omitted in the general amendment of this subtitle by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 11124, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1422"},"text":"92 Stat. 1422","children":[],"tail":", related to rerouting traffic on failure of rail carrier to serve the public."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 11125, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1423"},"text":"92 Stat. 1423","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/216/s2/15"},"text":"Pub. L. 98–216, § 2(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-02-14"},"text":"Feb. 14, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/5"},"text":"98 Stat. 5","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/m/28"},"text":"Pub. L. 103–272, § 5(m)(28)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1378"},"text":"108 Stat. 1378","children":[],"tail":", related to directed rail transportation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 11126, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1424"},"text":"92 Stat. 1424","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s5/m/29"},"text":"Pub. L. 103–272, § 5(m)(29)","children":[],"tail":", "},{"tag":"date","attrib":{"