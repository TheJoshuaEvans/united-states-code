{"tag":"section","attrib":{"id":"idcae9602c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11144"},"text":null,"children":[{"tag":"num","attrib":{"value":"11144"},"text":"§ 11144.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records: form; inspection; preservation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcae9602d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11144/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board may prescribe the form of records required to be prepared or compiled under this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcae9602e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11144/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by rail carriers and lessors, including records related to movement of traffic and receipts and expenditures of money; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae9602f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11144/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by persons furnishing cars to or for a rail carrier providing transportation subject to the jurisdiction of the Board under this part to the extent related to those cars or that service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae96030-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11144/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board, or an employee designated by the Board, may on demand and display of proper credentials—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcae96031-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11144/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspect and examine the lands, buildings, and equipment of a rail carrier or lessor; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae96032-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11144/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" inspect and copy any record of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcae96033-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11144/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rail carrier, lessor, or association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcae96034-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11144/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person controlling, controlled by, or under common control with a rail carrier if the Board considers inspection relevant to that person’s relation to, or transaction with, that rail carrier; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcae96035-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11144/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person furnishing cars to or for a rail carrier if the Board prescribed the form of that record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae96036-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11144/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may prescribe the time period during which operating, accounting, and financial records must be preserved by rail carriers, lessors, and persons furnishing cars.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcae96037-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/835"},"text":"109 Stat. 835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcae96038-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcae96039-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcae9603a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11144, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1426"},"text":"92 Stat. 1426","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/296/s24/c"},"text":"Pub. L. 96–296, § 24(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-01"},"text":"July 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/816"},"text":"94 Stat. 816","children":[],"tail":", related to form, inspection, and preservation of records, prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":". See sections 11144, 14122, and 15722 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcae9603b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcae9603c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
