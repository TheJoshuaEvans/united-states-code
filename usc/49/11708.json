{"tag":"section","attrib":{"id":"idcaf08b82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708"},"text":null,"children":[{"tag":"num","attrib":{"value":"11708"},"text":"§ 11708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Voluntary arbitration of certain rail rates and practices disputes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf08b83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of the enactment of the Surface Transportation Board Reauthorization Act of 2015, the Board shall promulgate regulations to establish a voluntary and binding arbitration process to resolve rail rate and practice complaints subject to the jurisdiction of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf08b84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Disputes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The voluntary and binding arbitration process established pursuant to subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf08b85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall apply to disputes involving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08b86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rates, demurrage, accessorial charges, misrouting, or mishandling of rail cars; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08b87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a carrier’s published rules and practices as applied to particular rail transportation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08b88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall not apply to disputes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08b89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to obtain the grant, denial, stay, or revocation of any license, authorization, or exemption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08b8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prescribe for the future any conduct, rules, or results of general, industry-wide applicability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08b8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enforce a labor protective condition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08b8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that are solely between 2 or more rail carriers; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08b8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not prevent parties from independently seeking or utilizing private arbitration services to resolve any disputes the parties may have.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf08b8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Arbitration Procedures.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf08b8f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08b90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make the voluntary and binding arbitration process established pursuant to subsection (a) available only to the relevant parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08b91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may make the voluntary and binding arbitration process available only—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcaf08b92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after receiving the written consent to arbitrate from all relevant parties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf08b93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcaf08b94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/c/1/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the filing of a written complaint; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcaf08b95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/c/1/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" through other procedures adopted by the Board in a rulemaking proceeding;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08b96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to rate disputes, may make the voluntary and binding arbitration process available only to the relevant parties if the rail carrier has market dominance (as determined under section 10707); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08b97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may initiate the voluntary and binding arbitration process not later than 40 days after the date on which a written complaint is filed or through other procedures adopted by the Board in a rulemaking proceeding.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08b98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Initiation of the voluntary and binding arbitration process shall preclude the Board from separately reviewing a complaint or dispute related to the same rail rate or practice in a covered dispute involving the same parties.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08b99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In resolving a covered dispute involving the reasonableness of a rail carrier’s rates, the arbitrator or panel of arbitrators, as applicable, shall consider the Board’s methodologies for setting maximum lawful rates, giving due consideration to the need for differential pricing to permit a rail carrier to collect adequate revenues (as determined under section 10704(a)(2)).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf08b9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Arbitration Decisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any decision reached in an arbitration process under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf08b9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be consistent with sound principles of rail regulation economics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08b9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in writing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08b9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall contain findings of fact and conclusions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08b9e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be binding upon the parties; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08b9f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not have any precedential effect in any other or subsequent arbitration dispute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf08ba0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timelines.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf08ba1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An arbitrator or panel of arbitrators shall be selected not later than 14 days after the date of the Board’s decision to initiate arbitration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08ba2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidentiary process","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The evidentiary process of the voluntary and binding arbitration process shall be completed not later than 90 days after the date on which the arbitration process is initiated unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08ba3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a party requests an extension; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08ba4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the arbitrator or panel of arbitrators, as applicable, grants such extension request.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08ba5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Decision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The arbitrator or panel of arbitrators, as applicable, shall issue a decision not later than 30 days after the date on which the evidentiary record is closed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08ba6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extensions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may extend any of the timelines under this subsection upon the agreement of all parties in the dispute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf08ba7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Arbitrators.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf08ba8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Unless otherwise agreed by all of the parties, an arbitration under this section shall be conducted by an arbitrator or panel of arbitrators, which shall be selected from a roster, maintained by the Board, of persons with rail transportation, economic regulation, professional or business experience, including agriculture, in the private sector.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08ba9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independence","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In an arbitration under this section, the arbitrators shall perform their duties with diligence, good faith, and in a manner consistent with the requirements of impartiality and independence.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08baa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08bab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the parties cannot mutually agree on an arbitrator, or the lead arbitrator of a panel of arbitrators, the parties shall select the arbitrator or lead arbitrator from the roster by alternately striking names from the roster until only 1 name remains meeting the criteria set forth in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08bac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Panel of arbitrators","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the parties agree to select a panel of arbitrators, instead of a single arbitrator, the panel shall be selected under this subsection as follows:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcaf08bad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/f/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The parties to a dispute may mutually select 1 arbitrator from the roster to serve as the lead arbitrator of the panel of arbitrators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf08bae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/f/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the parties cannot mutually agree on a lead arbitrator, the parties shall select a lead arbitrator using the process described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf08baf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/f/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the lead arbitrator selected under this subparagraph, each party to a dispute shall select 1 additional arbitrator from the roster, regardless of whether the other party struck out the arbitrator’s name under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08bb0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/f/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The parties shall share the costs incurred by the Board and arbitrators equally, with each party responsible for paying its own legal and other associated arbitration costs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf08bb1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relief.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf08bb2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to the limitations set forth in paragraphs (2) and (3), an arbitral decision under this section may award the payment of damages or rate prescriptive relief.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08bb3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Practice disputes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The damage award for practice disputes may not exceed $2,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08bb4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rate disputes.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08bb5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monetary limit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The damage award for rate disputes, including any rate prescription, may not exceed $25,000,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08bb6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Time limit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any rate prescription shall be limited to not longer than 5 years from the date of the arbitral decision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf08bb7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a party appeals a decision under this section to the Board, the Board may review the decision under this section to determine if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf08bb8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decision is consistent with sound principles of rail regulation economics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08bb9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a clear abuse of arbitral authority or discretion occurred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08bba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the decision directly contravenes statutory authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08bbb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11708/h/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the award limitation under subsection (g) was violated.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf08bbc-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s13/a"},"text":"Pub. L. 114–110, § 13(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2235"},"text":"129 Stat. 2235","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf08bbd-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf08bbe-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcaf08bbf-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the Surface Transportation Board Reauthorization Act of 2015, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110"},"text":"Pub. L. 114–110","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
