{"tag":"section","attrib":{"id":"idcb18fb95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302"},"text":null,"children":[{"tag":"num","attrib":{"value":"20302"},"text":"§ 20302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb18fb96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (c) of this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20303"},"text":"section 20303 of this title","children":[],"tail":", a railroad carrier may use or allow to be used on any of its railroad lines—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb18fb97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a vehicle only if it is equipped with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb18fb98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" couplers coupling automatically by impact, and capable of being uncoupled, without the necessity of individuals going between the ends of the vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure sill steps and efficient hand brakes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fb9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" secure ladders and running boards when required by the Secretary of Transportation, and, if ladders are required, secure handholds or grab irons on its roof at the top of each ladder;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as otherwise ordered by the Secretary, a vehicle only if it is equipped with secure grab irons or handholds on its ends and sides for greater security to individuals in coupling and uncoupling vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a vehicle only if it complies with the standard height of drawbars required by regulations prescribed by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a locomotive only if it is equipped with a power-driving wheel brake and appliances for operating the train-brake system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb9e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a train only if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb18fb9f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enough of the vehicles in the train are equipped with power or train brakes so that the engineer on the locomotive hauling the train can control the train’s speed without the necessity of brake operators using the common hand brakes for that purpose; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb18fba0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 50 percent of the vehicles in the train are equipped with power or train brakes and the engineer is using the power or train brakes on those vehicles and on all other vehicles equipped with them that are associated with those vehicles in the train.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb18fba1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Refusal To Receive Vehicles Not Properly Equipped","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A railroad carrier complying with subsection (a)(5)(A) of this section may refuse to receive from a railroad line of a connecting railroad carrier or a shipper a vehicle that is not equipped with power or train brakes that will work and readily interchange with the power or train brakes in use on the vehicles of the complying railroad carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb18fba2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Combined Vehicles Loading and Hauling Long Commodities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a)(1)(B) of this section, when vehicles are combined to load and haul long commodities, only one of the vehicles must have hand brakes during the loading and hauling.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb18fba3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Change Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb18fba4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" change the number, dimensions, locations, and manner of application prescribed by the Secretary for safety appliances required by subsection (a)(1)(B) and (C) and (2) of this section only for good cause and after providing an opportunity for a full hearing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fba5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amend regulations for installing, inspecting, maintaining, and repairing power and train brakes only for the purpose of achieving safety; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fba6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increase, after an opportunity for a full hearing, the minimum percentage of vehicles in a train that are required by subsection (a)(5)(B) of this section to be equipped and used with power or train brakes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb18fba7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20302/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Services of Association of American Railroads","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out subsection (d)(2) and (3) of this section, the Secretary may use the services of the Association of American Railroads.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb18fba8-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/881"},"text":"108 Stat. 881","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb18fba9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb18fbaa-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb18fbab-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"20302(a) (1)(A)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,