{"tag":"section","attrib":{"id":"idcc34cbf9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44947"},"text":null,"children":[{"tag":"num","attrib":{"value":"44947"},"text":"§ 44947.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Air cargo security division","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc34cbfa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44947/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of the TSA Modernization Act, the Administrator shall establish an air cargo security division to carry out and engage with stakeholders regarding the implementation of air cargo security programs established by the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc34cbfb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44947/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Leadership; Staffing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The air cargo security division established pursuant to subsection (a) shall be headed by an individual in the executive service within the TSA and be staffed by not fewer than 4 full-time equivalents, including the head of the division.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc34cbfc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44947/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Staffing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Transportation Security Administration shall staff the air cargo security division with existing TSA personnel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc34cbfd-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1943/a"},"text":"Pub. L. 115–254, div. K, title I, § 1943(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3584"},"text":"132 Stat. 3584","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc34cbfe-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc34cbff-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc34cc00-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the TSA Modernization Act, referred to in subsec. (a), is the date of enactment of title I of div. K of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
