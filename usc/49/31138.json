{"tag":"section","attrib":{"id":"idcb67b7ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138"},"text":null,"children":[{"tag":"num","attrib":{"value":"31138"},"text":"§ 31138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum financial responsibility for transporting passengers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb67b7ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirement.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb67b7ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation of passengers for compensation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall prescribe regulations to require minimum levels of financial responsibility sufficient to satisfy liability amounts established by the Secretary covering public liability and property damage for the transportation of passengers for compensation by motor vehicle in the United States between a place in a State and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb67b7ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a place in another State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another place in the same State through a place outside of that State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a place outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb67b7f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation of passengers not for compensation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may prescribe regulations to require minimum levels of financial responsibility sufficient to satisfy liability amounts established by the Secretary covering public liability and property damage for the transportation of passengers for commercial purposes, but not for compensation, by motor vehicle in the United States between a place in a State and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb67b7f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a place in another State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another place in the same State through a place outside of that State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a place outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb67b7f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The level of financial responsibility established under subsection (a) of this section for a motor vehicle with a seating capacity of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb67b7f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 16 passengers shall be at least $5,000,000; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb67b7f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 15 passengers shall be at least $1,500,000.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb67b7f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evidence of Financial Responsibility","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb67b7fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subject to paragraph (2) of this subsection, financial responsibility may be established by evidence of one or a combination of the following if acceptable to the Secretary of Transportation:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb67b7fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insurance, including high self-retention.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a guarantee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a surety bond issued by a bonding company authorized to do business in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb67b7fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person domiciled in a country contiguous to the United States and providing transportation to which a minimum level of financial responsibility under this section applies shall have evidence of financial responsibility in the motor vehicle when the person is providing the transportation. If evidence of financial responsibility is not in the vehicle, the Secretary of Transportation and the Secretary of the Treasury shall deny entry of the vehicle into the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb67b7ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A motor carrier may obtain the required amount of financial responsibility from more than one source provided the cumulative amount is equal to the minimum requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb67b800-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other persons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require a person, other than a motor carrier (as defined in section 13102), transporting passengers by motor vehicle to file with the Secretary the evidence of financial responsibility specified in subsection (c)(1) in an amount not less than the greater of the amount required by subsection (b)(1) or the amount required for such person to transport passengers under the laws of the State or States in which the person is operating; except that the amount of the financial responsibility must be sufficient to pay not more than the amount of the financial responsibility for each final judgment against the person for bodily injury to, or death of, an individual resulting from the negligent operation, maintenance, or use of the motor vehicle, or for loss or damage to property, or both.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb67b801-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb67b802-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, after notice and an opportunity for a hearing, the Secretary of Transportation finds that a person (except an employee acting without knowledge) has knowingly violated this section or a regulation prescribed under this section, the person is liable to the United States Government for a civil penalty of not more than $10,000 for each violation. A separate violation occurs for each day the violation continues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a2803-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation shall impose the penalty by written notice. In determining the amount of the penalty, the Secretary shall consider—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb6a2804-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, circumstances, extent, and gravity of the violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a2805-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the violator, the degree of culpability, any history of prior violations, the ability to pay, and any effect on the ability to continue doing business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6a2806-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other matters that justice requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a2807-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation may compromise the penalty before referring the matter to the Attorney General for collection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a2808-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall bring a civil action in an appropriate district court of the United States to collect a penalty referred to the Attorney General for collection under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a2809-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The amount of the penalty may be deducted from amounts the Government owes the person. An amount collected under this section shall be deposited in the Highway Trust Fund (other than the Mass Transit Account).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6a280a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to a motor vehicle—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6a280b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transporting only school children and teachers to or from school;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a280c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing taxicab service (as defined in section 13102);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a280d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carrying not more than 15 individuals in a single, daily round trip to and from work; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6a280e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31138/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" providing transportation service within a transit service area under an agreement with a Federal, State, or local government funded, in whole or in part, with a grant under section 5307, 5310, or 5311, including transportation designed and carried out to meet the special needs of elderly individuals and individuals with disabilities; except that, in any case in which the transit service area is located in more than 1 State, the minimum level of financial responsibility for such motor vehicle will be at least the highest level required for any of such States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb6a280f-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1005"},"text":"108 Stat. 1005","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s104/c"},"text":"Pub. L. 104–88, title I, § 104(c)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/919"},"text":"109 Stat. 919","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/298/s3/b/2"},"text":"Pub. L. 107–298, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-26"},"text":"Nov. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2343"},"text":"116 Stat. 2343","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV"},"text":"Pub. L. 109–59, title IV","children":[],"tail":", §§ 4120(a), 4121, "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1733"},"text":"119 Stat. 1733","children":[],"tail":", 1734; "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/tIII/s305/a"},"text":"Pub. L. 110–244, title III, § 305(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1619"},"text":"122 Stat. 1619","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb6a2810-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb6a2811-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb6a2812-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31138(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:10927 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 20, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/261/s18/a"},"text":"Pub. L. 97–261, § 18(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1121"},"text":"96 Stat. 1121","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31138(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:10927 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 20, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/261/s18/b"},"text":"Pub. L. 97–261, § 18(b)","children":[],"tail":", (c), "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1121"},"text":"96 Stat. 1121","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31138(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:10927 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 20, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/261/s18/d"},"text":"Pub. L. 97–261, § 18(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1121"},"text":"96 Stat. 1121","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/554/s224"},"text":"Pub. L. 98–554, § 224","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2847"},"text":"98 Stat. 2847","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31138(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:10927 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 20, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/261/s18/e"},"text":"Pub. L. 97–261, § 18(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1122"},"text":"96 Stat. 1122","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31138(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:10927 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 20, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/261/s18/f"},"text":"Pub. L. 97–261, § 18(f)","children":[],"tail":", (g), "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1122"},"text":"96 Stat. 1122","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the text of section 18(b)(1) (words beginning with “except”) and (2) (words beginning with “except”) and (c) of the Bus Regulatory Reform Act of 1982 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/261"},"text":"Public Law 97–261","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1121"},"text":"96 Stat. 1121","children":[],"tail":") is omitted as expired. The word “minimal” is omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “The Secretary shall establish, by regulation, methods and procedures to assure compliance with this section” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(4), the words “The Attorney General shall bring a civil action . . . to collect a penalty referred to the Attorney General for collection under this subsection” are substituted for “Such civil penalty may be recovered in an action brought by the Attorney General on behalf of the United States” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(5), the words “when finally determined (or agreed upon in compromise)” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), before clause (1), the text of section 18(g) of the Bus Regulatory Reform Act of 1982 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/261"},"text":"Public Law 97–261","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1122"},"text":"96 Stat. 1122","children":[],"tail":") is omitted as unnecessary because of the restatement."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb6a2813-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb6a2814-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244/s305/a/1"},"text":"Pub. L. 110–244, § 305(a)(1)","children":[],"tail":", added subsec. (a) and struck out former subsec. (a). Prior to amendment, text read as follows: “The Secretary of Transportation shall prescribe regulations to require minimum levels of financial responsibility sufficient to satisfy liability amounts established by the Secretary covering public liability and property damage for the transportation of passengers by commercial motor vehicle in the United States between a place in a State and—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) a place in another State;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) another place in the same State through a place outside of that State; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) a place outside the United States.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244/s305/a/2"},"text":"Pub. L. 110–244, § 305(a)(2)","children":[],"tail":", struck out “commercial” before “motor vehicle” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4120/a/1"},"text":"Pub. L. 109–59, § 4120(a)(1)","children":[],"tail":", struck out “for compensation” after “passengers” and inserted “commercial” before “motor vehicle” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4120/a/2"},"text":"Pub. L. 109–59, § 4120(a)(2)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4121"},"text":"Pub. L. 109–59, § 4121","children":[],"tail":", substituted “Highway Trust Fund (other than the Mass Transit Account)” for “Treasury as miscellaneous receipts”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/298"},"text":"Pub. L. 107–298","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “providing taxicab service, having a seating capacity of not more than 6 passengers, and not being operated on a regular route or between specified places;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s104/c"},"text":"Pub. L. 104–88, § 104(c)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s104/d"},"text":"Pub. L. 104–88, § 104(d)","children":[],"tail":", added par. (4)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb6a2815-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb6a2816-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb6a2817-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Minimum Financial Responsibility","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV/s5509"},"text":"Pub. L. 114–94, div. A, title V, § 5509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1554"},"text":"129 Stat. 1554","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tV/s5509"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transporting Property","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Secretary [of Transportation] proceeds with a rulemaking to determine whether to increase the minimum levels of financial responsibility required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31139"},"text":"section 31139 of title 49","children":[],"tail":", United States Code, the Secretary shall consider, prior to issuing a final rule—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the rulemaking’s potential impact on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety of motor vehicle transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the motor carrier industry;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ability of the insurance industry to provide the required amount of insurance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the extent to which current minimum levels of financial responsibility adequately cover—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical care;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compensation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other identifiable costs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frequency with which insurance claims exceed current minimum levels of financial responsibility in fatal accidents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of increased levels on motor carrier safety and accident reduction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transporting Passengers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prior to initiating a rulemaking to change the minimum levels of financial responsibility under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31138"},"text":"section 31138 of title 49","children":[],"tail":", United States Code, the Secretary shall complete a study specific to the minimum financial responsibility requirements for motor carriers of passengers."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A study under paragraph (1) shall include, to the extent practicable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of accidents, injuries, and fatalities in the over-the-road bus and school bus industries;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a review of insurance held by over-the-road bus and public and private school bus companies, including companies of various sizes, and an analysis of whether such insurance is adequate to cover claims;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of whether and how insurance affects the behavior and safety record of motor carriers of passengers, including with respect to crash reduction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the anticipated impacts of an increase in financial responsibility on insurance premiums for passenger carriers and service availability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting a study under paragraph (1), the Secretary shall consult with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of the over-the-road bus and private school bus transportation industries, including representatives of bus drivers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" insurers of motor carriers of passengers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary undertakes a study under paragraph (1), the Secretary shall submit to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a report on the results of the study.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
