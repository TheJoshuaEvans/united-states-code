{"tag":"section","attrib":{"id":"idcbb8bdc2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41105"},"text":null,"children":[{"tag":"num","attrib":{"value":"41105"},"text":"§ 41105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfers of certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbb8bdc3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":" may be transferred only when the Secretary of Transportation approves the transfer as being consistent with the public interest."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb8bdc4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When a certificate is transferred, the Secretary shall certify to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives that the transfer is consistent with the public interest. The Secretary shall include with the certification a report analyzing the effects of the transfer on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbb8bdc5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the viability of each carrier involved in the transfer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8bdc6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" competition in the domestic airline industry; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8bdc7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trade position of the United States in the international air transportation market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbb8bdc8-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1121"},"text":"108 Stat. 1121","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/9"},"text":"Pub. L. 104–287, § 5(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3389"},"text":"110 Stat. 3389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbb8bdc9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbb8bdca-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbb8bdcb-47c4-11f1-9671-b5c725212f70"},"text":"\n","childr