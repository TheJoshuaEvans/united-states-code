{"tag":"section","attrib":{"id":"idcc34cbba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44945"},"text":null,"children":[{"tag":"num","attrib":{"value":"44945"},"text":"§ 44945.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of unclaimed money and clothing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc34cbbb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44945/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposition of Unclaimed Money","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3302"},"text":"section 3302 of title 31","children":[],"tail":", unclaimed money recovered at any airport security checkpoint shall be retained by the Transportation Security Administration and shall remain available until expended for the purpose of providing civil aviation security as required in this chapter."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc34cbbc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44945/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposition of Unclaimed Clothing.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc34cbbd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44945/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In disposing of unclaimed clothing recovered at any airport security checkpoint, the Administrator of the Transportation Security Administration shall make every reasonable effort, in consultation with the Secretary of Veterans Affairs, to transfer the clothing to the local airport authority or other local authorities for donation to charity, including local veterans organizations or other local charitable organizations for distribution to homeless or needy veterans and veteran families.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbbe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44945/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In implementing paragraph (1), the Administrator of the Transportation Security Administration may enter into agreements with airport authorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbbf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44945/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other charitable arrangements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection shall prevent an airport or the Transportation Security Administration from donating unclaimed clothing to a charitable organization of their choosing.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc34cbc0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44945/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection shall create a cost to the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc34cbc1-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/334/tV/s515/a"},"text":"Pub. L. 108–334, title V, § 515(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1317"},"text":"118 Stat. 1317","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/271/s2/a"},"text":"Pub. L. 112–271, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2013-01-14"},"text":"Jan. 14, 2013","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/2446"},"text":"126 Stat. 2446","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/d/36"},"text":"Pub. L. 115–254, div. K, title I, § 1991(d)(36)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3641"},"text":"132 Stat. 3641","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc34cbc2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc34cbc3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc34cbc4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b)(1), (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" substituted “Administrator of the Transportation Security Administration” for “Assistant Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2013—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/271"},"text":"Pub. L. 112–271","children":[],"tail":" inserted “and clothing” after “money” in section catchline, designated existing provisions as subsec. (a), inserted heading, and added subsec. (b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc34cbc5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc34cbc6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annual Briefing","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/334/tV/s515/b"},"text":"Pub. L. 108–334, title V, § 515(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1318"},"text":"118 Stat. 1318","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/119/86/dA/tII/s212"},"text":"Pub. L. 119–86, div. A, title II, § 212","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2026-04-30"},"text":"Apr. 30, 2026","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/140/784"},"text":"140 Stat. 784","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/119/86/dA/tII/s212"},"text":"“Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2004-10-18"},"text":"Oct. 18, 2004","children":[],"tail":"] and annually thereafter, the Administrator of the Transportation Security Administration shall provide the Committee on Transportation and Infrastructure of the House of Representatives; the Committee on Appropriations of the House of Representatives; the Committee on Commerce, Science and Transportation of the Senate; and the Committee on Appropriations of the Senate, a briefing that contains a detailed description of the amount of unclaimed money recovered in total and at each individual airport, and specifically how the unclaimed money is being used to provide civil aviation security.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
