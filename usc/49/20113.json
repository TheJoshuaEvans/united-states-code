related to actions by States), "},{"tag":"html:a","attrib":{"href":"/us/stat/84/975"},"text":"84 Stat. 975","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/423/s9/a"},"text":"Pub. L. 96–423, § 9(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1814"},"text":"94 Stat. 1814","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/615/s28/f"},"text":"Pub. L. 101–615, § 28(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3277"},"text":"104 Stat. 3277","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20113(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:436(a)(1) (related to authority to bring actions), (2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458/s207/a"},"text":"Pub. L. 91–458, § 207(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/974"},"text":"84 Stat. 974","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 2, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/574/s8"},"text":"Pub. L. 95–574, § 8","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/2461"},"text":"92 Stat. 2461","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/423/s5"},"text":"Pub. L. 96–423, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1812"},"text":"94 Stat. 1812","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/615/s28/e"},"text":"Pub. L. 101–615, § 28(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3277"},"text":"104 Stat. 3277","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20113(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:436(a)(1) (related to venue), (b)(1) (related to venue), (c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:439(c) (related to actions by States).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458"},"text":"Pub. L. 91–458","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/971"},"text":"84 Stat. 971","children":[],"tail":", § 210(c) (related to actions by States); added "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/423/s9/b"},"text":"Pub. L. 96–423, § 9(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1815"},"text":"94 Stat. 1815","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the language about jurisdiction in 45:439(a) (related to actions by States) is omitted for the reasons explained in the revision note for section 20112(a) of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “impose” is substituted for “assess” for consistency. The words “the authority may bring a civil action in an appropriate district court of the United States” are substituted for “agency may apply to the United States district court” for consistency in the revised title and with other titles of the United States Code. The words “included in or made applicable to such rule, regulation, order, or standard” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the reference to “section 207(d)” in section 210(c) of the Federal Railroad Safety Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/458"},"text":"Public Law 91–458","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/971"},"text":"84 Stat. 971","children":[],"tail":"), as added by section 9(b) of the Federal Railroad Safety Authorization Act of 1980 ("},{"tag":"ref","attrib":{"href":"/us/pl/96/423"},"text":"Public Law 96–423","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1815"},"text":"94 Stat. 1815","children":[],"tail":"), is assumed to have been intended as a reference to section 207(c). The Federal Railroad Safety Authorization Act of 1980 was derived from S. 2730, which in turn was derived from H.R. 7104. See 126 Cong. Rec. 26535 (1980). Section 207(d) in an earlier version of H.R. 7104 was redesignated as section 207(c) during the legislative process and no section 207(d) was enacted. See H.R. Rept. No. 96–1025, 96th Cong., 2d Sess., pp. 14, 15 (1980)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
