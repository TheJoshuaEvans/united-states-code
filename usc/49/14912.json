{"tag":"section","attrib":{"id":"idcb05e93a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14912"},"text":null,"children":[{"tag":"num","attrib":{"value":"14912"},"text":"§ 14912.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Weight-bumping in household goods transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb05e93b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14912/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Weight-Bumping Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For the purposes of this section, “weight-bumping” means the knowing and willful making or securing of a fraudulent weight on a shipment of household goods which is subject to jurisdiction under subchapter I or III of chapter 135.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e93c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14912/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whoever has been found to have committed weight-bumping shall be fined under title 18 or imprisoned not more than 2 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb05e93d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/918"},"text":"109 Stat. 918","children":[],"tail":".)"}],"tai