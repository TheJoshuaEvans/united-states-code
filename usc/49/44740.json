{"tag":"section","attrib":{"id":"idcc09ea8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740"},"text":null,"children":[{"tag":"num","attrib":{"value":"44740"},"text":"§ 44740.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Special rule for certain aircraft operations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc09ea8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The operator of an aircraft with a special airworthiness certification in the experimental category may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc09ea8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate the aircraft for the purpose of conducting a space support vehicle flight (as that term is defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t51/s50902"},"text":"section 50902 of title 51","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09ea8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" conduct such flight under such certificate carrying persons or property for compensation or hire—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc09ea8f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding any rule or term of a certificate issued by the Administrator of the Federal Aviation Administration that would prohibit flight for compensation or hire; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09ea90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without obtaining a certificate issued by the Administrator to conduct air carrier or commercial operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09ea91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limited Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall apply only to a space support vehicle flight that satisfies each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc09ea92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The aircraft conducting the space support vehicle flight—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc09ea93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes flight and lands at a single site that is operated by an entity licensed for operation under chapter 509 of title 51;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09ea94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is owned or operated by a launch or reentry vehicle operator licensed under chapter 509 of title 51, or on behalf of a launch or reentry vehicle operator licensed under chapter 509 of title 51;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09ea95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a launch vehicle, a reentry vehicle, or a component of a launch or reentry vehicle licensed for operations pursuant to chapter 509 of title 51; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09ea96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is used only to simulate space flight conditions in support of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc09ea97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/b/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training for potential space flight participants, government astronauts, or crew (as those terms are defined in chapter 509 of title 51);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc09ea98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/b/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the testing of hardware to be used in space flight; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc09ea99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/b/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development tasks, which require the unique capabilities of the aircraft conducting the flight.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09ea9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules of Construction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc09ea9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Space support vehicles","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 44711(a)(1) shall not apply to a person conducting a space support vehicle flight under this section only to the extent that a term of the experimental certificate under which the person is operating the space support vehicle prohibits the carriage of persons or property for compensation or hire.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09ea9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44740/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of administrator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to limit the authority of the Administrator of the Federal Aviation Administration to exempt a person from a regulatory prohibition on the carriage of persons or property for compensation or hire subject to terms and conditions other than those described in this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc09ea9d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tV/s581/b/1"},"text":"Pub. L. 115–254, div. B, title V, § 581(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3398"},"text":"132 Stat. 3398","children":[],"tail":", § 44737; renumbered § 44740 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dV/tI/s107/d/1"},"text":"Pub. L. 116–260, div. V, title I, § 107(d)(1)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2326"},"text":"134 Stat. 2326","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc09ea9e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc09ea9f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc09eaa0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s107/d/3/A"},"text":"Pub. L. 116–260, § 107(d)(3)(A)","children":[],"tail":", struck out period after “operations” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s107/d/1"},"text":"Pub. L. 116–260, § 107(d)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44737"},"text":"section 44737 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s107/d/3/B"},"text":"Pub. L. 116–260, § 107(d)(3)(B)","children":[],"tail":", substituted “section” for “chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s107/d/3/C"},"text":"Pub. L. 116–260, § 107(d)(3)(C)","children":[],"tail":", struck out “(1)” the second time appearing before “The” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/s107/d/3/D"},"text":"Pub. L. 116–260, § 107(d)(3)(D)","children":[],"tail":", inserted period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc09eaa1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc09eaa2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Modernization of Special Airworthiness Certification Rulemaking Deadline","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVIII/s824"},"text":"Pub. L. 118–63, title VIII, § 824","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1332"},"text":"138 Stat. 1332","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tVIII/s824"},"text":"“Not later than 24 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"], the Administrator [of the Federal Aviation Administration] shall issue a final rule for the rulemaking activity titled ‘Modernization of Special Airworthiness Certification’, published in Fall 2022 in the long-term actions of the Unified Agenda of Federal Regulatory and Deregulatory Actions (RIN 2120–AL50).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc09eaa3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Flight Instruction or Testing","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVIII/s832"},"text":"Pub. L. 118–63, title VIII, § 832","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1339"},"text":"138 Stat. 1339","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tVIII/s832"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorized Additional Pilots","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual acting as an authorized additional pilot during Phase I flight testing of aircraft holding an experimental airworthiness certificate, in accordance with section 21.191 of title 14, Code of Federal Regulations, and meeting the requirements set forth in FAA [Federal Aviation Administration] regulations and policy in effect as of the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"], shall not be deemed to be operating an aircraft carrying persons or property for compensation or hire."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Aircraft","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who uses, causes to use, or authorizes to use aircraft for flights conducted under subsection (a) shall not be deemed to be operating an aircraft carrying persons or property for compensation or hire.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revision of Rules","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator [of the Federal Aviation Administration] shall, as necessary, issue, revise, or repeal the rules, regulations, guidance, or procedures of the FAA to conform to the requirements of this section.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc09eaa4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction Relating to Role of NASA","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tV/s581/b/3"},"text":"Pub. L. 115–254, div. B, title V, § 581(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3399"},"text":"132 Stat. 3399","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dB/tV/s581/b/3"},"text":"“Nothing in this subsection [enacting this section] shall be construed as limiting the ability of [the] National Aeronautics and Space Administration (NASA) to place conditions on or otherwise qualify the operations of NASA contractors providing NASA services.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
