{"tag":"section","attrib":{"id":"idca8546a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304"},"text":null,"children":[{"tag":"num","attrib":{"value":"1304"},"text":"§ 1304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca8546a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall annually transmit to the Congress a report on its activities, including each instance in which the Board has initiated an investigation on its own initiative under this chapter or subtitle IV.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8546aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rate Case Review Metrics.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8546ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall post a quarterly report of rail rate review cases pending or completed by the Board during the previous quarter that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8546ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" summary information of the case, including the docket number, case name, commodity or commodities involved, and rate review guideline or guidelines used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8546ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the rate review proceeding began;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8546ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date for the completion of discovery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8546af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date for the completion of the evidentiary record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8546b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date for the submission of closing briefs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8546b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the Board issued the final decision; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8546b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief summary of the final decision;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8546b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Website posting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each quarterly report shall be posted on the Board’s public website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca8546b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Complaints.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca8546b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall establish and maintain a database of complaints received by the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8546b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall post a quarterly report of formal and informal service complaints received by the Board during the previous quarter that includes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca8546b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the date on which the complaint was received by the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8546b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the type of each complaint;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8546b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the geographic region of each complaint; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca8546ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resolution of each complaint, if appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8546bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written consent","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The quarterly report may identify a complainant that submitted an informal complaint only upon the written consent of the complainant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca8546bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1304/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Website posting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each quarterly report shall be posted on the Board’s public website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca8546bd-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tII/s201/a"},"text":"Pub. L. 104–88, title II, § 201(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/934"},"text":"109 Stat. 934","children":[],"tail":", § 704; renumbered § 1304 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/110"},"text":"Pub. L. 114–110","children":[],"tail":", §§ 3(a)(3), 6, "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2228"},"text":"129 Stat. 2228","children":[],"tail":", 2231.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca8546be-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca8546bf-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca8546c0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s6"},"text":"Pub. L. 114–110, § 6","children":[],"tail":", substituted “Reports” for “Annual report” in section catchline, designated existing provisions as subsec. (a) and inserted heading, substituted “on its activities, including each instance in which the Board has initiated an investigation on its own initiative under this chapter or subtitle IV.” for “on its activities.”, and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s3/a/3"},"text":"Pub. L. 114–110, § 3(a)(3)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s704"},"text":"section 704 of this title","children":[],"tail":" as this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca8546c1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca8546c2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Quarterly Reports","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s15/b"},"text":"Pub. L. 114–110, § 15(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2238"},"text":"129 Stat. 2238","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/110/s15/b"},"text":"“Beginning not later than 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":"], the Surface Transportation Board shall submit quarterly reports to the congressional committees referred to in section 14(b) [Committee on Commerce, Science, and Transportation of the Senate and Committee on Transportation and Infrastructure of the House of Representatives] that describes the Surface Transportation Board’s progress toward addressing the issues raised in each unfinished regulatory proceeding, regardless of whether the proceeding is subject to a statutory or regulatory deadline.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
