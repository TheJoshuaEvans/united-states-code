l,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 2, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/236"},"text":"Pub. L. 93–236","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/985"},"text":"87 Stat. 985","children":[],"tail":", § 303(e) (words “title VII of the Railroad Revitalization and Regulatory Reform Act of 1976 or of”); added "},{"tag":"html:span","attrib":{},"text":"Feb. 5, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/210/s601/d"},"text":"Pub. L. 94–210, § 601(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/84"},"text":"90 Stat. 84","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 30, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/436/s5"},"text":"Pub. L. 94–436, § 5","children":[],"tail":" (related to title VII), "},{"tag":"html:a","attrib":{"href":"/us/stat/90/1399"},"text":"90 Stat. 1399","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “or conveyances”, “(whether real, personal, or mixed)”, “which are made at any time”, “the purposes of”, “imposts”, “or on the recording of deeds, bills of sale, liens, encumbrances, or other instruments evidencing, effectuating, or incident to any such transfers or conveyances, whether imposed on the transferor or on the transferee”, “now or hereafter”, “to compensate . . . the cost of”, “such deeds, bills of sale, liens, encumbrances, or other”, and “the designations and applicable principles in” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
