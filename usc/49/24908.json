{"tag":"section","attrib":{"id":"idcb3cd738-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24908"},"text":null,"children":[{"tag":"num","attrib":{"value":"24908"},"text":"§ 24908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer taxes and levies and recording charges","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A transfer of an interest in rail property under this chapter is exempt from a tax or levy related to the transfer that is imposed by the United States Government, a State, or a political subdivision of a State. On payment of the appropriate and generally applicable charge for the service performed, a transferee or transferor may record an instrument and, consistent with the final system plan, the release or removal of a pre-existing lien or encumbrance of record related to the interest transferred.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb3cd739-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/937"},"text":"108 Stat. 937","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb3cd73a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb3cd73b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb3cd73c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":