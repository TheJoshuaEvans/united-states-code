{"tag":"section","attrib":{"id":"idcb35ab87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24706"},"text":null,"children":[{"tag":"num","attrib":{"value":"24706"},"text":"§ 24706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discontinuance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb35ab88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice of Discontinuance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb35ab89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsection (c), not later than 180 days before discontinuing service over a route, Amtrak shall give notice of the discontinuance in the way Amtrak decides will give a State, a regional or local authority, or another person the opportunity to agree to share or assume the cost of any part of the train, route, or service to be discontinued.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35ab8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notice of the discontinuance under paragraph (1) shall be posted in all stations served by the train to be discontinued at least 14 days before the discontinuance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35ab8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discontinuance or Substantial Alteration of Long-distance Routes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), in an emergency, or during maintenance or construction outages impacting Amtrak routes, Amtrak may not discontinue, reduce the frequency of, suspend, or substantially alter the route of rail service on any segment of any long-distance route in any fiscal year in which Amtrak receives adequate Federal funding for such route on the National Network.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35ab8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Discontinuance for Lack of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb35ab8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amtrak may discontinue service under subsection (a)(1) during—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb35ab8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24706/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the first month of a fiscal year if the authorization of appropriations and the appropriations for Amtrak are not enacted at least 90 days before the beginning of the fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb35ab8f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24706/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the 30 days following enactment of an appropriation for Amtrak or a rescission of an appropriation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35ab90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amtrak shall notify each affected State or regional or local transportation authority of a discontinuance under this subsection as soon as possible after Amtrak decides to discontinue the service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35ab91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Congressional Notification of Discontinuance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), not later than 210 days before discontinuing service over a route, Amtrak shall give written notice of such discontinuance to all of the members of Congress representing any State or district in which the discontinuance would occur.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35ab92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24706/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies to all service over routes provided by Amtrak, notwithstanding any provision of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24701"},"text":"section 24701 of this title","children":[],"tail":" or any other provision of this title except section 24702(b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb35ab93-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/927"},"text":"108 Stat. 927","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/134/tI"},"text":"Pub. L. 105–134, title I","children":[],"tail":", §§ 101(c), 142(a), "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2572"},"text":"111 Stat. 2572","children":[],"tail":", 2576; "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tII/s201/d"},"text":"Pub. L. 110–432, div. B, title II, § 201(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4910"},"text":"122 Stat. 4910","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11316/n/1"},"text":"Pub. L. 114–94, div. A, title XI, § 11316(n)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1678"},"text":"129 Stat. 1678","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22210"},"text":"Pub. L. 117–58, div. B, title II, § 22210","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/708"},"text":"135 Stat. 708","children":[],"ta