"45:565(b) (3d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24706(c)(5)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:565(c) (1st sentence words after 2d comma, last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24706(c)(6)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:565(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/518"},"text":"Pub. L. 91–518","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1327"},"text":"84 Stat. 1327","children":[],"tail":", § 405(g); added "},{"tag":"html:span","attrib":{},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/35/s1188/d"},"text":"Pub. L. 97–35, § 1188(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/699"},"text":"95 Stat. 699","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “Except as provided in subsection (b) of this section” are added for clarity. The word “authority” is substituted for “agency” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “Notwithstanding the provisions of clause (ii)” are omitted as surplus. In clauses (A) and (B), the words “the benefit of” are omitted as surplus. In clause (A), the words “for such fiscal year” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), before clause (A), the words “Amtrak or” are substituted for 45:565(c) (1st sentence words before 2d comma) to eliminate unnecessary words because operations in the basic system have begun. The words “whether occurring before, on, or after ","children":[{"tag":"date","attrib":{"date":"1975-01-01"},"text":"January 1, 1975","children":[],"tail":"” and “without being limited to, such provisions as may be necessary for” are omitted as surplus. In clause (A), the words “to such employees” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11347"},"text":"section 11347 of this title","children":[],"tail":"” are substituted for and coextensive with “section 5(2)(f) of the Interstate Commerce Act” in section 405(b) of the Rail Passenger Service Act ("},{"tag":"ref","attrib":{"href":"/us/pl/91/518"},"text":"Public Law 91–518","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1337"},"text":"84 Stat. 1337","children":[],"tail":") on authority of "},{"tag":"ref","attrib":{"href":"/us/act/1978-10-17/s3/b"},"text":"section 3(b) of the Act of October 17, 1978","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Public Law 95–473","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1466"},"text":"92 Stat. 1466","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(5), the words “be construed to” are omitted as surplus. The text of 45:565(c) (last sentence) is omitted as executed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb35ab97-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb35ab98-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22210/1"},"text":"Pub. L. 117–58, § 22210(1)","children":[],"tail":", substituted “subsection (c), not later than 180 days” for “subsection (b) of this section, at least 180 days”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b) to (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22210/2"},"text":"Pub. L. 117–58, § 22210(2)","children":[],"tail":"–(4), added subsecs. (b) and (d) and redesignated former subsecs. (b) and (c) as (c) and (e), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s11316/n/1/A/i"},"text":"Pub. L. 114–94, § 11316(n)(1)(A)(i)","children":[],"tail":", struck out “a discontinuance under section 24704 or or” after “before”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s11316/n/1/A/ii"},"text":"Pub. L. 114–94, § 11316(n)(1)(A)(ii)","children":[],"tail":", struck out “section 24704 or” after “under”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s11316/n/1/B"},"text":"Pub. L. 114–94, § 11316(n)(1)(B)","children":[],"tail":", struck out “section 24704 or” after “under” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":" added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134/s101/c/1"},"text":"Pub. L. 105–134, § 101(c)(1)","children":[],"tail":"–(3), substituted “180 days” for “90 days” and “or discontinuing service over a route,” for “24707(a) or (b) of this title,” and inserted “or assume” after “agree to share”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134/s101/c/4"},"text":"Pub. L. 105–134, § 101(c)(4)","children":[],"tail":", which directed substitution of “paragraph (1)” for “section 24707(a) or (b) of this title”, was executed by making the substitution for “24707(a) or (b) of this title” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134/s101/c/5"},"text":"Pub. L. 105–134, § 101(c)(5)","children":[],"tail":", which directed substitution of “subsection (a)(1)” for “section 24707(a) or (b) of this title”, was executed by making the substitution for “24707(a) or (b) of this title” to reflect the probable intent of Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134/s142/a"},"text":"Pub. L. 105–134, § 142(a)","children":[],"tail":", struck out subsec. (c) which related to employee protective arrangements."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb35ab99-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb35ab9a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb35ab9b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134/s142/a"},"text":"section 142(a) of Pub. L. 105–134","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/134/s142/c"},"text":"section 142(c) of Pub. L. 105–134","children":[],"tail":", set out in an Employee Protection Reforms note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb35ab9c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deemed References to Chapters 509 and 511 of Title 51","children":[],"tail":null},{"tag":"p","attrib":{},"text":"General references to “this title” deemed to refer also to chapters 509 and 511 of Title 51, National and Commercial Space Programs, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/314/s4/d/8"},"text":"section 4(d)(8) of Pub. L. 111–314","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb381b9d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Employee Protection Reforms","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134/tI"},"text":"Pub. L. 105–134, title I","children":[],"tail":", §§ 141, 142, "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2575"},"text":"111 Stat. 2575","children":[],"tail":", 2576, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/134/tI"},"text":"\n","children":[{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"141"},"text":"“SEC. 141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" RAILWAY LABOR ACT PROCEDURES.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any arrangement in effect before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":"], notices under section 6 of the Railway Labor Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t45/s156"},"text":"45 U.S.C. 156","children":[],"tail":") with respect to all issues relating to employee protective arrangements and severance benefits which are applicable to employees of Amtrak, including all provisions of Appendix C–2 to the National Railroad Passenger Corporation Agreement, signed "},{"tag":"date","attrib":{"date":"1973-07-05"},"text":"July 5, 1973","children":[],"tail":", shall be deemed served and effective on the date which is 45 days after the date of the enactment of this Act. Amtrak, and each affected labor organization representing Amtrak employees, shall promptly supply specific information and proposals with respect to each such notice."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Mediation Board Efforts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (c), the National Mediation Board shall complete all efforts, with respect to the dispute described in subsection (a), under section 5 of the Railway Labor Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s155"},"text":"45 U.S.C. 155","children":[],"tail":") not later than 120 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Railway Labor Act Arbitration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The parties to the dispute described in subsection (a) may agree to submit the dispute to arbitration under section 7 of the Railway Labor Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s157"},"text":"45 U.S.C. 157","children":[],"tail":"), and any award resulting therefrom shall be retroactive to the date which is 120 days after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dispute Resolution","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" With respect to the dispute described in subsection (a) which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is unresolved as of the date which is 120 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not submitted to arbitration as described in subsection (c),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Amtrak shall, and the labor organization parties to such dispute shall, within 127 days after the date of the enactment of this Act, each select an individual from the entire roster of arbitrators maintained by the National Mediation Board. Within 134 days after the date of the enactment of this Act, the individuals selected under the preceding sentence shall jointly select an individual from such roster to make recommendations with respect to such dispute under this subsection. If the National Mediation Board is not informed of the selection under the preceding sentence 134 days after the date of enactment of this Act, the Board shall immediately select such individual.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No individual shall be selected under paragraph (1) who is pecuniarily or otherwise interested in any organization of employees or any railroad.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The compensation of individuals selected under paragraph (1) shall be fixed by the National Mediation Board. The second paragraph of section 10 of the Railway Labor Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s160"},"text":"45 U.S.C. 160","children":[],"tail":"] shall apply to the expenses of such individuals as if such individuals were members of a board created under such section 10."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the parties to a dispute described in subsection (a) fail to reach agreement within 150 days after the date of the enactment of this Act, the individual selected under paragraph (1) with respect to such dispute shall make recommendations to the parties proposing contract terms to resolve the dispute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the parties to a dispute described in subsection (a) fail to reach agreement, no change shall be made by either of the parties in the conditions out of which the dispute arose for 30 days after recommendations are made under paragraph (4).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Section 10 of the Railway Labor Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s160"},"text":"45 U.S.C. 160","children":[],"tail":") shall not apply to a dispute described in subsection (a)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Precedent for Freight","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this Act [see Short Title of 1997 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20101"},"text":"section 20101 of this title","children":[],"tail":"], or in any amendment made by this Act, shall affect the level of protection provided to freight railroad employees and mass transportation employees as it existed on the day before the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"section","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"142"},"text":"“SEC. 142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" SERVICE DISCONTINUANCE.","children":[],"tail":null},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Repeal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 24706(c) is repealed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any provision of a contract entered into before the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":"] between Amtrak and a labor organization representing Amtrak employees relating to employee protective arrangements and severance benefits applicable to employees of Amtrak is extinguished, including all provisions of Appendix C–2 to the National Railroad Passenger Corporation Agreement, signed "},{"tag":"date","attrib":{"date":"1973-07-05"},"text":"July 5, 1973","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsections (a) [amending this section] and (b) of this section shall take effect 180 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication of Bankruptcy Law Provision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s1172/c"},"text":"Section 1172(c) of title 11","children":[],"tail":", United States Code, shall not apply to Amtrak and its employees.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
