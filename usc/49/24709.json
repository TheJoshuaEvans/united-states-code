Pub. L. 91–518","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1327"},"text":"84 Stat. 1327","children":[],"tail":", § 305(i); added "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/496/s4"},"text":"Pub. L. 93–496, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1527"},"text":"88 Stat. 1527","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"May 26, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/25/s3"},"text":"Pub. L. 94–25, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/89/90"},"text":"89 Stat. 90","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/73/s106"},"text":"Pub. L. 96–73, § 106","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/539"},"text":"93 Stat. 539","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/35/s1176"},"text":"Pub. L. 97–35, § 1176","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/692"},"text":"95 Stat. 692","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/272/s13031/h/1"},"text":"Pub. L. 99–272, § 13031(h)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/310"},"text":"100 Stat. 310","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, before clause (1), the words “points within”, “points in”, and “including Montreal, Canada; Vancouver, Canada; and Nuevo Laredo, Mexico” in 45:545(e)(7) are omitted as surplus. The words “establish and” in 45:545(i) (1st sentence) are omitted as executed. The words “trains operated in” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb381ba9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb381baa-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" substituted “The Secretary of Homeland Security,” for “The Secretary of the Treasury and the Attorney General,” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb381bab-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb381bac-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb381bad-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Cross-Border Passenger Rail Service","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tIV/s406"},"text":"Pub. L. 110–432, div. B, title IV, § 406","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4958"},"text":"122 Stat. 4958","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/432/dB/tIV/s406"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":"], Amtrak shall, in consultation with the Secretary [of Transportation], the Secretary of Homeland Security, the Washington State Department of Transportation, and the owners of the relevant railroad infrastructure—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop a strategic plan to facilitate expanded passenger rail service across the international border between the United States and Canada during the 2010 Olympic Games on the Amtrak passenger rail route between Vancouver, British Columbia, Canada, and Eugene, Oregon (commonly known as ‘Amtrak Cascades’);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop recommendations for the Department of Homeland Security to process efficiently rail passengers traveling on Amtrak Cascades across such international border during the 2010 Olympic Games; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to Congress a report containing the strategic plan described in paragraph (1) and the recommendations described in paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Travel Facilitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Using existing authority or agreements, or upon reaching additional agreements with Canada, the Secretary [of Transportation] and other Federal agencies, as appropriate, are authorized to establish facilities and procedures to conduct preclearance of passengers traveling on Amtrak trains from Canada to the United States. The Secretary shall seek to establish such facilities and procedures—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in Vancouver, Canada, no later than ","children":[{"tag":"date","attrib":{"date":"2009-06-01"},"text":"June 1, 2009","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in other areas as determined appropriate by the Secretary.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
