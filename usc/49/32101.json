{"tag":"section","attrib":{"id":"idcb7acabd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101"},"text":null,"children":[{"tag":"num","attrib":{"value":"32101"},"text":"§ 32101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this part (except chapter 329 and except as provided in section 33101)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7acabe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “bumper standard” means a minimum performance standard that substantially reduces—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7acabf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the damage to the front or rear end of a passenger motor vehicle from a low-speed collision (including a collision with a fixed barrier) or from towing the vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7acac0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of repairing the damage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7acac1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “insurer” means a person in the business of issuing, or reinsuring any part of, a passenger motor vehicle insurance policy.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7acac2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “interstate commerce” means commerce between a place in a State and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7acac3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a place in another State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7acac4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another place in the same State through another State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7acac5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “make”, when describing a passenger motor vehicle, means the trade name of the manufacturer of the vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7acac6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “manufacturer” means a person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7acac7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacturing or assembling passenger motor vehicles or passenger motor vehicle equipment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7acac8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" importing motor vehicles or motor vehicle equipment for resale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7acac9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “model”, when describing a passenger motor vehicle, means a category of passenger motor vehicles based on the size, style, and type of a make of vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7acaca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “motor vehicle” means a vehicle driven or drawn by mechanical power and manufactured primarily for use on public streets, roads, and highways, but does not include a vehicle operated only on a rail line.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7acacb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “motor vehicle accident” means an accident resulting from the maintenance or operation of a passenger motor vehicle or passenger motor vehicle equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7acacc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “multipurpose passenger vehicle” means a passenger motor vehicle constructed on a truck chassis or with special features for occasional off-road operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7acacd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “passenger motor vehicle” means a motor vehicle with motive power designed to carry not more than 12 individuals, but does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7acace-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/10/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motorcycle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7acacf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/10/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a truck not designed primarily to carry its operator or passengers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7acad0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “passenger motor vehicle equipment” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7acad1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a system, part, or component of a passenger motor vehicle as originally made;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7acad2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a similar part or component made or sold for replacement or improvement of a system, part, or component, or as an accessory or addition to a passenger motor vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7acad3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a device made or sold for use in towing a passenger motor vehicle.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7acad4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State of the United States, the District of Columbia, Puerto Rico, the Northern Mariana Islands, Guam, American Samoa, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7acad5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32101/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States district court” means a district court of the United States, a United States court for Guam, the Virgin Islands, and American Samoa, and the district court for the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCr