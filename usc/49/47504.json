ag":"html:span","attrib":{},"text":"Feb. 18, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/193/s104/a"},"text":"Pub. L. 96–193, § 104(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/51"},"text":"94 Stat. 51","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/223/s301/a"},"text":"Pub. L. 100–223, § 301(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1523"},"text":"101 Stat. 1523","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47504(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2104(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Feb. 18, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/193/s104/b"},"text":"Pub. L. 96–193, § 104(b)","children":[],"tail":", (d), "},{"tag":"html:a","attrib":{"href":"/us/stat/94/52"},"text":"94 Stat. 52","children":[],"tail":", 53."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47504(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2104(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Feb. 18, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/193/s104/c"},"text":"Pub. L. 96–193, § 104(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/52"},"text":"94 Stat. 52","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/248/s524/b/4"},"text":"Pub. L. 97–248, § 524(b)(4)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/696"},"text":"96 Stat. 696","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/223/s301/b"},"text":"Pub. L. 100–223, § 301(b)","children":[],"tail":", (c), "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1523"},"text":"101 Stat. 1523","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/143/s336"},"text":"Pub. L. 102–143, § 336","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/947"},"text":"105 Stat. 947","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47504(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2104(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(A), the words “the officials of” are omitted as surplus. The words “planning authorities” are substituted for “planning agencies” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(A), the word “establishing” is substituted for “the implementation of” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2)(B), the words “the implementation of” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “to him” and “the measures to be undertaken in carrying out” are omitted as surplus. In clause (B), the word “achieving” is substituted for “obtaining” for clarity. The word “existing” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(2) is substituted for 49 App.:2104(b) (3d sentence) to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1)(B) and (2), the words “for which grant applications are made in accordance with such noise compatibility programs” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), before clause (A), the words “incur obligations to” and “further . . . under this section” are omitted as surplus. In clause (C), the words “to carry out any part of a program” are substituted for “any project to carry out a noise compatibility program”, and the words “or before implementing regulations were prescribed” are substituted for “or the promulgation of its implementing regulations”, for clarity and consistency. The words “the purposes of” before “reducing” are omitted as surplus. The word “noncompatible” is added after “existing” for clarity and consistency. In clause (D), the words “for any project” and “determined to be” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “in turn” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(4), before clause (A), the words “All of” and “made under section 505 of that Act” are omitted as surplus. The word “except” is substituted for “unless” for clarity. In clause (1), the words “relating to United States share of project costs” are omitted as surplus. In clause (2), the words “the purposes of” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “by the Secretary or the Administrator of the Federal Aviation Administration” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc66d80a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This redesignates 49:47504(c)(1)(C) and (D) as 49:47504(c)(2)(C) and (D) because the subject matter is similar to that of 49:47504(c)(2)(A) and (B) that was added by section 119(2) of the Federal Aviation Administration Authorization Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305"},"text":"Public Law 103–305","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1580"},"text":"108 Stat. 1580","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc66d80b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc66d80c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 301(d)(4)(B) of the Airport and Airway Safety and Capacity Expansion Act of 1987, referred to in subsec. (c)(2)(A)(i), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/223/s301/d/4/B"},"text":"section 301(d)(4)(B) of Pub. L. 100–223","children":[],"tail":", which was set out as a note under section 2104 of former Title 49, Transportation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s7/b"},"text":"Pub. L. 103–272, § 7(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1379"},"text":"108 Stat. 1379","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc66d80d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(2)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/232"},"text":"Pub. L. 115–232","children":[],"tail":" added subpar. (F)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s504"},"text":"Pub. L. 112–95, § 504","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s505"},"text":"Pub. L. 112–95, § 505","children":[],"tail":", added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (b)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/s189"},"text":"Pub. L. 108–176, § 189","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2)(C)–(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/s306"},"text":"Pub. L. 108–176, § 306","children":[],"tail":", realigned margins of subpars. (C) and (D) and added subpar. (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"