{"tag":"section","attrib":{"id":"idcc66d7b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47502"},"text":null,"children":[{"tag":"num","attrib":{"value":"47502"},"text":"§ 47502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noise measurement and exposure systems and identifying land use compatible with noise exposure","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"After consultation with the Administrator of the Environmental Protection Agency and United States Government, State, and interstate agencies that the Secretary of Transportation considers appropriate, the Secretary shall by regulation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc66d7b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish a single system of measuring noise that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc66d7b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47502/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a highly reliable relationship between projected noise exposure and surveyed reactions of individuals to noise; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc66d7b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47502/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is applied uniformly in measuring noise at airports and the surrounding area;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc66d7b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish a single system for determining the exposure of individuals to noise resulting from airport operations, including noise intensity, duration, frequency, and time of occurrence; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc66d7b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47502/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify land uses normally compatible with various exposures of individuals to noise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc66d7b6-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1284"},"text":"108 Stat. 1284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc66d7b7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc66d7b8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc66d7b9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text"