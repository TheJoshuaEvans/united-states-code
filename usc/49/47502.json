f the twelfth month which begins after ","children":[{"tag":"date","attrib":{"date":"1980-02-18"},"text":"February 18, 1980","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
