{"tag":"section","attrib":{"id":"idca747d66-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355"},"text":null,"children":[{"tag":"num","attrib":{"value":"355"},"text":"§ 355.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motorcyclist Advisory Council","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca747d67-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 90 days after the date of enactment of this section, the Secretary of Transportation (referred to in this section as the “Secretary”) shall establish a council, to be known as the “Motorcyclist Advisory Council” (referred to in this section as the “Council”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca747d68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca747d69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall be comprised of 13 members, to be appointed by the Secretary, of whom—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca747d6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 5 shall be representatives of units of State or local government with expertise relating to highway engineering and safety issues, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca747d6b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motorcycle and motorcyclist safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca747d6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barrier and road design, construction, and maintenance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca747d6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intelligent transportation systems;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 1 shall be a motorcyclist who serves as a State or local—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca747d6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" traffic and safety engineer;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca747d70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" design engineer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca747d71-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other transportation department official;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of a national association of State transportation officials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d73-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of a national motorcyclist association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of a national motorcyclist foundation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d75-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of a national motorcycle manufacturing association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d76-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a representative of a motorcycle manufacturing company headquartered in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d77-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a roadway safety data expert with expertise relating to crash testing and analysis; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/1/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1 shall be a member of a national safety organization that represents the traffic safety systems industry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca747d79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Term.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca747d7a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to subparagraphs (B) and (C), each member shall serve on the Council for a single term of 2 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d7b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a successor is not appointed for a member of the Council before the expiration of the term of service of the member, the member may serve on the Council for a second term of not longer than 2 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d7c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of replacements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a member of the Council resigns before the expiration of the 2-year term of service of the member—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca747d7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary may appoint a replacement for the member, who shall serve the remaining portion of the term; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca747d7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resigning member may continue to serve after resignation until the date on which a successor is appointed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca747d7f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A vacancy on the Council shall be filled in the manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca747d80-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Council shall serve without compensation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca747d81-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca747d82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advising","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Council shall advise the Secretary, the Administrator of the National Highway Traffic Safety Administration, and the Administrator of the Federal Highway Administration regarding transportation safety issues of concern to motorcyclists, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca747d83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motorcycle and motorcyclist safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" barrier and road design, construction, and maintenance practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the architecture and implementation of intelligent transportation system technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca747d86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Biennial report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than October 31 of the calendar year following the calendar year in which the Council is established, and not less frequently than once every 2 years thereafter, the Council shall submit to the Secretary a report containing recommendations of the Council regarding the issues described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca747d87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties of Secretary.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca747d88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Council recommendations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca747d89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall determine whether to accept or reject a recommendation contained in a report of the Council under subsection (c)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion in review.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idca747d8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall indicate in each review under paragraph (2) whether the Secretary accepts or rejects each recommendation of the Council covered by the review.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca747d8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may indicate in a review under paragraph (2) that a recommendation of the Council is under consideration, subject to the condition that a recommendation so under consideration shall be accepted or rejected by the Secretary in the subsequent review of the Secretary under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca747d8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca747d8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the date on which the Secretary receives a report from the Council under subsection (c)(2), the Secretary shall submit a review describing the response of the Secretary to the recommendations of the Council contained in the Council report to—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca747d8f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Commerce, Science, and Transportation of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca747d90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Environment and Public Works of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca747d91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Transportation, Housing and Urban Development, and Related Agencies of the Committee on Appropriations of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca747d92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Committee on Transportation and Infrastructure of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca747d93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Subcommittee on Transportation, Housing and Urban Development, and Related Agencies of the Committee on Appropriations of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca747d94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A review of the Secretary under this paragraph shall include a description of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca747d95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each recommendation contained in the Council report covered by the review; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca747d96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idca747d97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2/B/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each recommendation of the Council that was categorized under paragraph (1)(B)(ii) as being under consideration by the Secretary in the preceding review submitted under this paragraph; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idca747d98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2/B/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each such recommendation, whether the recommendation—","children":[],"tail":null},{"tag":"item","attrib":{"id":"idca747d99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2/B/ii/II/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accepted or rejected by the Secretary; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"idca747d9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/2/B/ii/II/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remains under consideration by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca747d9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative and technical support","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall provide to the Council such administrative support, staff, and technical assistance as the Secretary determines to be necessary to carry out the duties of the Council under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca747d9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s355/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Council shall terminate on the date that is 6 years after the date on which the Council is established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca747d9d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tIV/s24111/a"},"text":"Pub. L. 117–58, div. B, title IV, § 24111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/812"},"text":"135 Stat. 812","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca747d9e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca747d9f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca747da0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
