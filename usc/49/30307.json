,"children":[{"tag":"html:p","attrib":{},"text":"23:401 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 25, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/364/s208"},"text":"Pub. L. 97–364, § 208","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1746"},"text":"96 Stat. 1746","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/223/s305/b/1"},"text":"Pub. L. 100–223, § 305(b)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1526"},"text":"101 Stat. 1526","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “fined under title 18” are substituted for “fined not more than $10,000” for consistency with title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the reference to “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30305/b/6"},"text":"section 30305(b)(6) of this title","children":[],"tail":"” is used to carry out the probable intent of Congress. Section 305(b)(1) of the Airport and Airway Safety and Capacity Expansion Act of 1987 ("},{"tag":"ref","attrib":{"href":"/us/pl/100/223"},"text":"Public Law 100–223","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1526"},"text":"101 Stat. 1526","children":[],"tail":") amended section 206(b) of the National Driver Register Act of 1982 ("},{"tag":"ref","attrib":{"href":"/us/pl/97/364"},"text":"Public Law 97–364","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1744"},"text":"96 Stat. 1744","children":[],"tail":") by “redesignating paragraphs (3) and (4), and any reference thereto, as paragraphs (4) and (5), respectively”. Because the reference to “section 206(b)(4)” in section 208 of the National Driver Register Act of 1982 appears to have been incorrect before that amendment, and would continue to be incorrect if the reference is redesignated as required by the amendment, a reference to section 30305(b)(6) is used in this section to carry out the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb571553-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb571554-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30305/b"},"text":"Section 30305(b) of this title","children":[],"tail":", referred to in subsec. (a), was amended by "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tII/s2006/b/2/A"},"text":"Pub. L. 105–178, title II, § 2006(b)(2)(A)","children":[],"tail":", (B), "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/336"},"text":"112 Stat. 336","children":[],"tail":", which added a new par. (6) and redesignated former par. (6) as (10)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
