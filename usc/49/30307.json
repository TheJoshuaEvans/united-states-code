{"tag":"section","attrib":{"id":"idcb571549-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30307"},"text":null,"children":[{"tag":"num","attrib":{"value":"30307"},"text":"§ 30307.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb57154a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30307/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person (except an individual described in section 30305(b)(6) ","children":[{"tag":"ref","attrib":{"idref":"fn002113"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002113"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title) shall be fined under title 18, imprisoned for not more than one year, or both, if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb57154b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30307/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person receives under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30305"},"text":"section 30305 of this title","children":[],"tail":" information specified in section 30304(b)(1)(A) or (C) of this title;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb57154c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30307/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclosure of the information is not authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30305"},"text":"section 30305 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb57154d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30307/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person willfully discloses the information knowing that disclosure is not authorized.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb57154e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30307/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person knowingly and willfully requesting, or under false pretenses obtaining, information specified in section 30304(b)(1)(A) or (C) of this title from a person receiving the information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30305"},"text":"section 30305 of this title","children":[],"tail":" shall be fined under title 18, imprisoned for not more than one year, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb57154f-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/979"},"text":"108 Stat. 979","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb571550-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb571551-47c4-11f1-9671-b5c725212f70"},"tex