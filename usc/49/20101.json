{"tag":"section","attrib":{"id":"idcb0859e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20101"},"text":null,"children":[{"tag":"num","attrib":{"value":"20101"},"text":"§ 20101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to promote safety in every area of railroad operations and reduce railroad-related accidents and incidents.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb0859e1-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/863"},"text":"108 Stat. 863","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb0859e2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb0859e3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb0859e4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20101","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:421.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458/s101"},"text":"Pub. L. 91–458, § 101","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/971"},"text":"84 Stat. 971","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “The Congress declares that” are omitted as surplus. The words “accidents and incidents” are substituted for “accidents” for consistency with the source provisions restated in section 20105(b)(1)(B) of the revised title. The words “and to reduce deaths and injuries to persons and to reduce damage to property caused by accidents involving any carrier of hazardous materials” are omitted as obsolete because they applied to 49 App.:1761 and 1762, that were repealed by section 113(g) of the Hazardous Materials Transportation Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/633"},"text":"Public Law 93–633","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/2163"},"text":"88 Stat. 2163","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb0859e5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idcb0859e6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2024 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/205/s1"},"text":"Pub. L. 118–205, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-12-23"},"text":"Dec. 23, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2697"},"text":"138 Stat. 2697","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/205/s1"},"text":"“This Act [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24315"},"text":"section 24315 of this title","children":[],"tail":"] may be cited as the ‘Think Differently Transportation Act’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idcb0859e7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2021 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22001"},"text":"Pub. L. 117–58, div. B, title II, § 22001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/694"},"text":"135 Stat. 694","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dB/tII/s22001"},"text":"“This title [see Tables for classification] may be cited as the ‘Passenger Rail Expansion and Rail Safety Act of 2021’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idcb0859e8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11001"},"text":"Pub. L. 114–94, div. A, title XI, § 11001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1622"},"text":"129 Stat. 1622","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tXI/s11001"},"text":"“This title [see Tables for classification] may be cited as the ‘Passenger Rail Reform and Investment Act of 2015’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11501"},"text":"Pub. L. 114–94, div. A, title XI, § 11501","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1690"},"text":"129 Stat. 1690","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tXI/s11501"},"text":"“This subtitle [subtitle E (§§ 11501–11504) of title XI of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":", enacting sections 24201 and 24202 of this title, amending "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s303"},"text":"section 303 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s138"},"text":"section 138 of Title 23","children":[],"tail":", Highways, and enacting provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s4370m"},"text":"section 4370m of Title 42","children":[],"tail":", The Public Health and Welfare] may be cited as the ‘Track, Railroad, and Infrastructure Network Act’ or the ‘TRAIN Act’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/73/tI/s1302/a"},"text":"Pub. L. 114–73, title I, § 1302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-10-29"},"text":"Oct. 29, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/576"},"text":"129 Stat. 576","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/73/tI/s1302/a"},"text":"“This section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20157"},"text":"section 20157 of this title","children":[],"tail":"] may be cited as the ‘Positive Train Control Enforcement and Implementation Act of 2015’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idcb0859e9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/s1/a"},"text":"Pub. L. 110–432, div. A, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4848"},"text":"122 Stat. 4848","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/432/dA/s1/a"},"text":"“This division [see Tables for classification] may be cited as the ‘Rail Safety Improvement Act of 2008’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/s1/a"},"text":"Pub. L. 110–432, div. B, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4907"},"text":"122 Stat. 4907","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/432/dB/s1/a"},"text":"“This division [enacting chapters 227, 244, and 285 of this title and sections 24105, 24310, 24316, 24702, 24710, 24711, 24910, and 26106 of this title, amending sections 103, 24101, 24102, 24302, 24308, 24706, 24904, 24905, 26101, and 26104 of this title, enacting provisions set out as notes under sections 24101, 24302, 24305, 24307, 24308, 24405, 24702, 24709, 24711, 24902, and 26106 of this title, and amending provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24101"},"text":"section 24101 of this title","children":[],"tail":"] may be cited as the ‘Passenger Rail Investment and Improvement Act of 2008’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idcb0859ea-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1997 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134/s1/a"},"text":"Pub. L. 105–134, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2570"},"text":"111 Stat. 2570","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/134/s1/a"},"text":"“This Act [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s28103"},"text":"section 28103 of this title","children":[],"tail":", amending sections 24101, 24102, 24104, 24301 to 24307, 24309, 24312, 24315, 24701, 24706, 24902, and 24904 of this title, section 8G of the Inspector General Act of 1978, "},{"tag":"ref","attrib":{"href":"/us/pl/95/452"},"text":"Pub. L. 95–452","children":[],"tail":", set out in the Appendix to Title 5, Government Organization and Employees, and "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s9101"},"text":"section 9101 of Title 31","children":[],"tail":", Money and Finance, repealing sections 24310, 24314, 24501 to 24506, 24702 to 24705, 24707, 24708, and 24903 of this title, and "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s1111"},"text":"section 1111 of Title 45","children":[],"tail":", Railroads, and enacting provisions set out as notes under this section and sections 24101, 24104, 24301, 24304, 24305, 24307, 24312, 24315, 24501, and 24706 of this title, section 8G of the Appendix to Title 5, and "},{"tag":"ref","attrib":{"href":"/us/usc/t26/s172"},"text":"section 172 of Title 26","children":[],"tail":", Internal Revenue Code] may be cited as the ‘Amtrak Reform and Accountability Act of 1997’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idcb0859eb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/440/tI/s101"},"text":"Pub. L. 103–440, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4615"},"text":"108 Stat. 4615","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/440/tI/s101"},"text":"“This title [enacting sections 26101 to 26105 of this title, renumbering former sections 26101 and 26102 of this title as 28101 and 28102 of this title, respectively, and enacting provisions set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s26101"},"text":"section 26101 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s838"},"text":"section 838 of Title 45","children":[],"tail":", Railroads] may be cited as the ‘Swift Rail Development Act of 1994’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/440/tII/s201"},"text":"Pub. L. 103–440, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4619"},"text":"108 Stat. 4619","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/440/tII/s201"},"text":"“This title [enacting sections 20145 to 20151 and 21108 of this title, amending sections 103, 20103, 20111, 20116, 20117, 20133, 20142, and 21303 of this title, and enacting provisions set out as a note under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11504"},"text":"section 11504 of this title","children":[],"tail":"] may be cited as the ‘Federal Railroad Safety Authorization Act of 1994’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb0859ec-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Data Accessibility","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22405"},"text":"Pub. L. 117–58, div. B, title II, § 22405","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/738"},"text":"135 Stat. 738","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dB/tII/s22405"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"], the Chief Information Officer of the Department [of Transportation] shall—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a review of the website of the Office of Safety Analysis of the Federal Railroad Administration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide recommendations to the Secretary [of Transportation] for improving the public’s usability and accessibility of the website referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after receiving recommendations from the Chief Information Officer pursuant to subsection (a)(2), the Secretary, after considering such recommendations, shall update the website of the Office of Safety Analysis of the Federal Railroad Administration to improve the usability and accessibility of the website.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb0ac9ed-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Federal Railroad Administration Reporting Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22421/a"},"text":"Pub. L. 117–58, div. B, title II, § 22421(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/750"},"text":"135 Stat. 750","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dB/tII/s22421/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elimination of Duplicative or Unnecessary Reporting or Paperwork Requirements in the Federal Railroad Administration.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Federal Railroad Administration (referred to in this subsection as the ‘FRA Administrator’), in consultation with the Administrator of the Federal Transit Administration, shall conduct a review of existing reporting and paperwork requirements in the Federal Railroad Administration to determine if any such requirements are duplicative or unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Elimination of certain requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the FRA Administrator determines, as a result of the review conducted pursuant to paragraph (1), that any reporting or paperwork requirement that is not statutorily required is duplicative or unnecessary, the FRA Administrator, after consultation with the Administrator of the Federal Transit Administration, shall terminate such requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"], the FRA Administrator shall submit a report to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives that—"}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies all of the reporting or paperwork requirements that were terminated pursuant to paragraph (2); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies any statutory reporting or paperwork requirements that are duplicative or unnecessary and should be repealed.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb0ac9ee-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Shared-Use Study","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11311"},"text":"Pub. L. 114–94, div. A, title XI, § 11311","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1670"},"text":"129 Stat. 1670","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI/s21301/j/4/C"},"text":"Pub. L. 117–58, div. B, title I, § 21301(j)(4)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/693"},"text":"135 Stat. 693","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dB/tI/s21301/j/4/C"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 3 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"], the Secretary [of Transportation], in consultation with Amtrak, commuter rail passenger transportation authorities, other railroad carriers, railroad carriers that own rail infrastructure over which both passenger and freight trains operate, States, the Surface Transportation Board, the Northeast Corridor Commission established under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s24905"},"text":"section 24905 of title 49","children":[],"tail":", United States Code, the State-Supported Route Committee established under section 24712 of such title, and groups representing rail passengers and customers, as appropriate, shall complete a study that evaluates—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the shared use of right-of-way by passenger and freight rail systems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operational, institutional, and legal structures that would best support improvements to the systems referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Areas of Study","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conducting the study under subsection (a), the Secretary shall evaluate—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the access and use of railroad right-of-way by a rail carrier that does not own the right-of-way, such as passenger rail services that operate over privately-owned right-of-way, including an analysis of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" access agreements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" costs of access; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resolution of disputes relating to such access or costs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the effectiveness of existing contractual, statutory, and regulatory mechanisms for establishing, measuring, and enforcing train performance standards, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the manner in which passenger train delays are recorded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the assignment of responsibility for such delays; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of incentives and penalties for performance;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the strengths and weaknesses of the existing mechanisms described in paragraph (2) and possible approaches to address the weaknesses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mechanisms for measuring and maintaining public benefits resulting from publicly funded freight or passenger rail improvements, including improvements directed towards shared-use right-of-way by passenger and freight rail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" approaches to operations, capacity, and cost estimation modeling that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow for transparent decisionmaking; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the proprietary interests of all parties;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" liability requirements and arrangements, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether to expand statutory liability limits to additional parties;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether to revise the current statutory liability limits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether current insurance levels of passenger rail operators are adequate and whether to establish minimum insurance requirements for such passenger rail operators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether to establish alternative insurance models, including other models administered by the Federal Government;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect on rail passenger services, operations, liability limits, and insurance levels of the assertion of sovereign immunity by a State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other issues identified by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after the study under subsection (a) is complete, the Secretary shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the study; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any recommendations for further action, including any legislative proposals consistent with such recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall integrate, as appropriate, the recommendations submitted under subsection (c) into the financial assistance programs under subtitle V of title 49, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb0ac9ef-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Railroad Safety Strategy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tI/s102"},"text":"Pub. L. 110–432, div. A, title I, § 102","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4852"},"text":"122 Stat. 4852","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11316/j/3"},"text":"Pub. L. 114–94, div. A, title XI, § 11316(j)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1677"},"text":"129 Stat. 1677","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tXI/s11316/j/3"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety Goals","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In conjunction with existing federally-required and voluntary strategic planning efforts ongoing at the Department and the Federal Railroad Administration as of the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":"], the Secretary shall develop a long-term strategy for improving railroad safety to cover a period of not less than 5 years. The strategy shall include an annual plan and schedule for achieving, at a minimum, the following goals:"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Reducing the number and rates of accidents, incidents, injuries, and fatalities involving railroads including train collisions, derailments, and human factors.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving the consistency and effectiveness of enforcement and compliance programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving the identification of high-risk highway-rail grade crossings and strengthening enforcement and other methods to increase grade crossing safety.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving research efforts to enhance and promote railroad safety and performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Preventing railroad trespasser accidents, incidents, injuries, and fatalities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Improving the safety of railroad bridges, tunnels, and related infrastructure to prevent accidents, incidents, injuries, and fatalities caused by catastrophic and other failures of such infrastructure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Resource Needs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The strategy and annual plan shall include estimates of the funds and staff resources needed to accomplish the goals established by subsection (a). Such estimates shall also include the staff skills and training required for timely and effective accomplishment of each such goal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission With the President’s Budget","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall submit the strategy and annual plan to the Senate Committee on Commerce, Science, and Transportation and the House of Representatives Committee on Transportation and Infrastructure at the same time as the President’s budget submission.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Achievement of Goals.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Progress assessment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No less frequently than annually, the Secretary shall assess the progress of the Department toward achieving the strategic goals described in subsection (a). The Secretary shall identify any deficiencies in achieving the goals within the strategy and develop and institute measures to remediate such deficiencies. The Secretary and the Administrator shall convey their assessment to the employees of the Federal Railroad Administration and shall identify any deficiencies that should be remediated before the next progress assessment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Beginning in 2009, not later than November 1 of each year, the Secretary shall transmit a report to the Senate Committee on Commerce, Science, and Transportation and the House of Representatives Committee on Transportation and Infrastructure on the performance of the Federal Railroad Administration containing the progress assessment required by paragraph (1) toward achieving the goals of the railroad safety strategy and annual plans under subsection (a).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “railroad”, “Department”, “Secretary”, and “crossing”, as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s102"},"text":"section 102 of Pub. L. 110–432","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/s2/a"},"text":"section 2(a) of Pub. L. 110–432","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s20102"},"text":"section 20102 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb0ac9f0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Reports on Statutory Mandates and Recommendations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tI/s106"},"text":"Pub. L. 110–432, div. A, title I, § 106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4859"},"text":"122 Stat. 4859","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/432/dA/tI/s106"},"text":"“Not later than ","children":[{"tag":"date","attrib":{"date":"2008-12-31"},"text":"December 31, 2008","children":[],"tail":", and annually thereafter, the Secretary shall transmit a report to the House of Representatives Committee on Transportation and Infrastructure and the Senate Committee on Commerce, Science, and Transportation on the specific actions taken to implement unmet statutory mandates regarding railroad safety and each open railroad safety recommendation made by the National Transportation Safety Board or the Department’s Inspector General.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definitions of “Secretary”, “railroad”, and “Department”, as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s106"},"text":"section 106 of Pub. L. 110–432","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/s2/a"},"text":"section 2(a) of Pub. L. 110–432","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s20102"},"text":"section 20102 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
