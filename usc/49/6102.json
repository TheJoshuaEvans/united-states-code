{"tag":"section","attrib":{"id":"idcad3dcb8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6102"},"text":null,"children":[{"tag":"num","attrib":{"value":"6102"},"text":"§ 6102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad3dcb9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"One-call notification system","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “one-call notification system” means a system operated by an organization that has as 1 of its purposes to receive notification from excavators of intended excavation in a specified area in order to disseminate such notification to underground facility operators that are members of the system so that such operators can locate and mark their facilities in order to prevent damage to underground facilities in the course of such excavation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dcba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State one-call notification program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State one-call notification program” means the State statutes, regulations, orders, judicial decisions, and other elements of law and policy in effect in a State that establish the requirements for the operation of one-call notification systems in such State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dcbb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “State” means a State, the District of Columbia, and Puerto Rico.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dcbc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad3dcbd-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tVII/s7302/a"},"text":"Pub. L. 105–178, title VII, § 7302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/478"},"text":"112 Stat. 478","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
