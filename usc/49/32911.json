children":[{"tag":"html:p","attrib":{},"text":"15:2007(a)(1), (2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2007(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 20, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/513"},"text":"Pub. L. 92–513","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/947"},"text":"86 Stat. 947","children":[],"tail":", § 507(b); added "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/425/s6/a/2"},"text":"Pub. L. 96–425, § 6(a)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1826"},"text":"94 Stat. 1826","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2008(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “commits a violation if the . . . fails” are substituted for “the following conduct is unlawful . . . the failure of any person” for clarity and consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the reference to 15:2011 is omitted because that provision is not restated in this chapter. The words “The Secretary of Transportation shall conduct a proceeding, with an opportunity for a hearing on the record, to decide” are substituted for “If, on the record after opportunity for agency hearing, the Secretary determines” in 15:2008 for clarity. The words “the Secretary shall assess the penalties provided for under subsection (b) of this section” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Compliance is determined after considering credits available to the manufacturer under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32903"},"text":"section 32903 of this title","children":[],"tail":"” are substituted for 15:2007(b) to eliminate unnecessary words. The words “the Secretary shall conduct a proceeding, with an opportunity for a hearing on the record, to decide” are substituted for “the Secretary shall commence a proceeding under paragraph (2) of this subsection” in 15:2008(a)(1) and “If, on the record after opportunity for agency hearing, the Secretary determines” in 15:2008(a)(2) for clarity. The words “may not conduct” are substituted for “(unless” in 15:2008(a)(1) for clarity."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb892238-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This makes a conforming amendment necessary because of the restatement of 15:2011 as 49:32918 by section 6(43)(A) of the bill.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb892239-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb89223a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" substituted “, 32917(b), and 32918” for “, and 32917(b)”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
