{"tag":"section","attrib":{"id":"idcafc731a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14101"},"text":null,"children":[{"tag":"num","attrib":{"value":"14101"},"text":"§ 14101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Providing transportation and service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcafc731b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"On Reasonable Request","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier providing transportation or service subject to jurisdiction under chapter 135 shall provide the transportation or service on reasonable request. In addition, a motor carrier shall provide safe and adequate service, equipment, and facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafc731c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contracts With Shippers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafc731d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14101/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A carrier providing transportation or service subject to jurisdiction under chapter 135 may enter into a contract with a shipper, other than for the movement of household goods described in section 13102(10)(A), to provide specified services under specified rates and conditions. If the shipper and carrier, in writing, expressly waive any or all rights and remedies under this part for the transportation covered by the contract, the transportation provided under the contract shall not be subject to the waived rights and remedies and may not be subsequently challenged on the ground that it violates the waived rights and remedies. The parties may not waive the provisions governing registration, insurance, or safety fitness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafc731e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14101/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Remedy for breach of contract","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The exclusive remedy for any alleged breach of a contract entered into under this subsection shall be an action in an appropriate State court or United States district court, unless the parties otherwise agree.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcafc731f-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/890"},"text":"109 Stat. 890","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcafc7320-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcafc7321-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcafc7322-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11101"},"text":"section 11101 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcafc7323-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcafc7324-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
