{"tag":"section","attrib":{"id":"idcb11f66e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20146"},"text":null,"children":[{"tag":"num","attrib":{"value":"20146"},"text":"§ 20146.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Institute for Railroad Safety","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Transportation, in conjunction with a university or college having expertise in transportation safety, shall establish, within one year after ","children":[{"tag":"date","attrib":{"date":"1994-11-02"},"text":"November 2, 1994","children":[],"tail":", an Institute for Railroad Safety. The Institute shall research, develop, fund, and test measures for reducing the number of fatalities and injuries relevant to railroad operations. There are authorized to be appropriated to the Secretary $1,000,000 for each of the fiscal years 1996 through 2000 to fund activities carried out under this section by the Institute, which shall report at least once each year on its use of such funds in carrying out such activities and the results thereof to the Secretary of Transportation and the Congress."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb11f66f-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/440/tII/s210/a"},"text":"Pub. L. 103–440, title II, § 210(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4621"},"text":"108 Stat. 4621","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/49"},"text":"Pub. L. 104–287, § 5(49)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3393"},"text":"110 Stat. 3393","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb11f670-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb11f671-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb11f672-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"November 2, 1994","children":[],"tail":"” for “the date of enactment of the Federal Railroad Safety Authorization Act of 1994”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
