{"tag":"section","attrib":{"id":"idcc707581-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104"},"text":null,"children":[{"tag":"num","attrib":{"value":"50104"},"text":"§ 50104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on airport projects using products or services of foreign countries denying fair market opportunities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc707582-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition and Rules for Construing Section","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc707583-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “project” has the same meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47102"},"text":"section 47102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc707584-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each foreign instrumentality and each territory and possession of a foreign country administered separately for customs purposes is a separate foreign country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc707585-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an article substantially produced or manufactured in a foreign country is a product of the country.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc707586-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a service provided by a person that is a national of a foreign country or that is controlled by a national of a foreign country is a service of the country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc707587-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Use of Available Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc707588-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An amount made available under subchapter I of chapter 471 of this title may not be used for a project that uses a product or service of a foreign country during any period the country is on the list maintained by the United States Trade Representative under subsection (d)(1) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc707589-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) of this subsection does not apply when the Secretary of Transportation decides that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc70758a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applying paragraph (1) to the product, service, or project is not in the public interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc70758b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a product or service of the same class or type and of satisfactory quality is not produced or offered in the United States, or in a foreign country not listed under subsection (d)(1) of this section, in a sufficient and reasonably available amount; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc70758c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the project cost will increase by more than 20 percent if the product or service is excluded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc70758d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Decisions on Denial of Fair Market Opportunities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after a report is submitted to Congress under section 181(b) of the Trade Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s2241/b"},"text":"19 U.S.C. 2241(b)","children":[],"tail":"), the Trade Representative, for a construction project of more than $500,000 for which the government of a foreign country supplies any part of the amount, shall decide whether the foreign country denies fair market opportunities for products and suppliers of the United States in procurement or for United States bidders. In making the decision, the Trade Representative shall consider information obtained in preparing the report and other information the Trade Representative considers relevant."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc70758e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"List of Countries Denying Fair Market Opportunities","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc70758f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Trade Representative shall maintain a list of each foreign country the Trade Representative finds under subsection (c) of this section is denying fair market opportunities. The country shall remain on the list until the Trade Representative decides the country provides fair market opportunities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc707590-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Trade Representative shall publish in the Federal Register—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc707591-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually the list required under paragraph (1) of this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc707592-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s50104/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any modification of the list made before the next list is published.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc707593-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1299"},"text":"108 Stat. 1299","children":[],"tail":", § 49104; renumbered § 50104 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/88/D"},"text":"Pub. L. 104–287, § 5(88)(D)","children":[],"tail":", (89), "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3398"},"text":"110 Stat. 3398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s768/b/2"},"text":"Pub. L. 118–63, title VII, § 768(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1294"},"text":"138 Stat. 1294","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc707594-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc707595-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc707596-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"49104(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(no source).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49104(a)(2)– (4)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2226(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/248"},"text":"Pub. L. 97–248","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/324"},"text":"96 Stat. 324","children":[],"tail":", § 533; added "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/223/s115"},"text":"Pub. L. 100–223, § 115","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1505"},"text":"101 Stat. 1505","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"49104(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2226(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"49104(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2226(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"49104(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2226(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (a)(1) is added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “subchapter I of chapter 471 of this title (except sections 47106(d) and 47127)” are substituted for “Act” in section 533(a)(1) of the Airport and Airway Development Act of 1982, as added by section 115 of the Airport and Airway Safety and Capacity Expansion Act of 1987 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/223"},"text":"Public Law 100–223","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/1505"},"text":"101 Stat. 1505","children":[],"tail":") to correct a mistake."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), before clause (A), the words “with respect to the use of a product or service in a project” are omitted as surplus. In clause (B), the words “or service” are added for clarity and consistency in this section. In clause (C), the words “overall” and “contract” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “the date which is”, “the date on which”, “or not”, and “and equitable” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1), the words “finds under subsection (c) of this section is denying fair market opportunities” are substituted for “with respect to which an affirmative determination is made under subsection (b)” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2)(A), the word “entire” is omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc707597-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/89"},"text":"Pub. L. 104–287, § 5(89)","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This makes a clarifying amendment to 49:50101(a) and (b)(3), 50102, 50104(b)(1), and 50105, as redesignated by clause (88)(D) of this section, because 49:47106(d) was struck by section 108(1) of the Federal Aviation Administration Authorization Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305"},"text":"Public Law 103–305","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1573"},"text":"108 Stat. 1573","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc707598-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc707599-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" struck out “(except section 47127)” after “subchapter I of chapter 471 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/88/D"},"text":"Pub. L. 104–287, § 5(88)(D)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s49104"},"text":"section 49104 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/89"},"text":"Pub. L. 104–287, § 5(89)","children":[],"tail":", substituted “section 47127” for “sections 47106(d) and 47127”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
