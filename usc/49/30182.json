{"tag":"section","attrib":{"id":"idcb54a49a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182"},"text":null,"children":[{"tag":"num","attrib":{"value":"30182"},"text":"§ 30182.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and duties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb54a49b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb54a49c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct motor vehicle safety research, development, and testing programs and activities, including activities related to new and emerging technologies that impact or may impact motor vehicle safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a49d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" collect and analyze all types of motor vehicle and highway safety data and related information to determine the relationship between motor vehicle or motor vehicle equipment performance characteristics and—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb54a49e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accidents involving motor vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a49f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" deaths or personal injuries resulting from those accidents.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a4a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out a program under this section, the Secretary of Transportation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb54a4a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote, support, and advance the education and training of motor vehicle safety staff of the National Highway Traffic Safety Administration in motor vehicle safety research programs and activities, including using program funds for planning, implementing, conducting, and presenting results of program activities, and for related expenses;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a4a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtain experimental and other motor vehicles and motor vehicle equipment for research or testing;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a4a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb54a4a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use any test motor vehicles and motor vehicle equipment suitable for continued use, as determined by the Secretary to assist in carrying out this chapter or any other chapter of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb54a4a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sell or otherwise dispose of test motor vehicles and motor vehicle equipment and use the resulting proceeds to carry out this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a4a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" award grants to States and local governments, interstate authorities, and nonprofit institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a4a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into cooperative agreements, collaborative research, or contracts with Federal agencies, interstate authorities, State and local governments, other public entities, private organizations and persons, nonprofit institutions, colleges and universities, consumer advocacy groups, corporations, partnerships, sole proprietorships, trade associations, Federal laboratories (including government-owned, government-operated laboratories and government-owned, contractor-operated laboratories), and research organizations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a4a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in coordination with Department ","children":[{"tag":"ref","attrib":{"idref":"fn002112"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002112"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “the”."}],"tail":" of State, enter into cooperative agreements and collaborative research and development agreements with foreign governments."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a4a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Public Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this subchapter, the Secretary shall avoid duplication by using the services, research, and testing facilities of public agencies, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a4aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may plan, design, and construct a new facility or modify an existing facility to conduct research, development, and testing in traffic safety, highway safety, and motor vehicle safety. An expenditure of more than $1,500,000 for planning, design, or construction may be made only if 60 days prior notice of the planning, design, or construction is provided to the Committees on Science, Space, and Technology and Transportation and Infrastructure of the House of Representatives and the Committees on Commerce, Science, and Transportation and Environment and Public Works of the Senate. The notice shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb54a4ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief description of the facility being planned, designed, or constructed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a4ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the location of the facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a4ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the maximum cost of the facility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a4ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement identifying private and public agencies that will use the facility and the contribution each agency will make to the cost of the facility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb54a4af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a justification of the need for the facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a4b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Increasing Costs of Approved Facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The estimated maximum cost of a facility noticed under subsection (d) may be increased by an amount equal to the percentage increase in construction costs from the date the notice is submitted to Congress. However, the increase in the cost of the facility may not be more than 10 percent of the estimated maximum cost included in the notice. The Secretary shall decide what increase in construction costs has occurred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb54a4b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30182/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Information, Patents, and Developments","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the United States Government makes more than a minimal contribution to a research or development activity under this chapter, the Secretary shall include in the arrangement for the activity a provision to ensure that all information, patents, and developments related to the activity are available to the public. The owner of a background patent may not be deprived of a right under the patent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb54a4b2-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tI/s31204/a"},"text":"Pub. L. 112–141, div. C, title I, § 31204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/759"},"text":"126 Stat. 759","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dB/tXXIV/s24202/a"},"text":"Pub. L. 114–94, div. B, title XXIV, § 24202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1711"},"text":"129 Stat. 1711","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb54a4b3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb54a4b4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb54a4b5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" added par. (6)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb54a4b6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb54a4b7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
