{"tag":"section","attrib":{"id":"idcc8cfd28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80301"},"text":null,"children":[{"tag":"num","attrib":{"value":"80301"},"text":"§ 80301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8cfd29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “aircraft” means a contrivance used, or capable of being used, for transportation in the air.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “vehicle” means a contrivance used, or capable of being used, for transportation on, below, or above land, but does not include aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8cfd2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s80301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “vessel” means a contrivance used, or capable of being used, for transportation in water, but does not include aircraft.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc8cfd2c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1353"},"text":"108 Stat. 1353","children"