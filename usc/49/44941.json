{"tag":"section","attrib":{"id":"idcc325a88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44941"},"text":null,"children":[{"tag":"num","attrib":{"value":"44941"},"text":"§ 44941.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Immunity for reporting suspicious activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc325a89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44941/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any air carrier or foreign air carrier or any employee of an air carrier or foreign air carrier who makes a voluntary disclosure of any suspicious transaction relevant to a possible violation of law or regulation, relating to air piracy, a threat to aircraft or passenger safety, or terrorism, as defined by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3077"},"text":"section 3077 of title 18","children":[],"tail":", United States Code, to any employee or agent of the Department of Transportation, the Department of Homeland Security, the Department of Justice, any Federal, State, or local law enforcement officer, or any airport or airline security officer shall not be civilly liable to any person under any law or regulation of the United States, any constitution, law, or regulation of any State or political subdivision of any State, for such disclosure."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc325a8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44941/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) shall not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc325a8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44941/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any disclosure made with actual knowledge that the disclosure was false, inaccurate, or misleading; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc325a8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44941/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any disclosure made with reckless disregard as to the truth or falsity of that disclosure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc325a8d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s125/a"},"text":"Pub. L. 107–71, title I, § 125(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/631"},"text":"115 Stat. 631","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/d/32"},"text":"Pub. L. 115–254, div. K, title I, § 1991(d)(32)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3640"},"text":"132 Stat. 3640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc325a8e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc325a8f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc325a90-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" inserted “the Department of Homeland Security,” after “Department of Transportation,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
