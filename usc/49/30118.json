:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30118(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(a)(1)(D) (related to 15:1412(a) (1st–3d sentences)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563/s108/a/1/D"},"text":"Pub. L. 89–563, § 108(a)(1)(D)","children":[],"tail":" (related to §§ 151, 152, 153(c) (1st sentence cl. (6)), 156, 157), "},{"tag":"html:a","attrib":{"href":"/us/stat/80/722"},"text":"80 Stat. 722","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/492/s103/a/1/A"},"text":"Pub. L. 93–492, § 103(a)(1)(A)","children":[],"tail":", (3), "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1477"},"text":"88 Stat. 1477","children":[],"tail":", 1478."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1412(a) (1st–3d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563"},"text":"Pub. L. 89–563","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/718"},"text":"80 Stat. 718","children":[],"tail":", §§ 151, 152, 156 (related to notice), 157 (related to notice); added "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/492/s102/a"},"text":"Pub. L. 93–492, § 102(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1470"},"text":"88 Stat. 1470","children":[],"tail":", 1475."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30118(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(a)(1)(D) (related to 15:1412(a) (last sentence), (b)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1412(a) (last sentence), (b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30118(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(a)(1)(D) (related to 15:1411, 1413(c) (1st sentence cl. (6))).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1411.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1413(c) (1st sentence cl. (6)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563"},"text":"Pub. L. 89–563","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/718"},"text":"80 Stat. 718","children":[],"tail":", § 153(c) (1st sentence cl. (6)); added "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/492/s102/a"},"text":"Pub. L. 93–492, § 102(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1472"},"text":"88 Stat. 1472","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 15, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/331/s4/b/2"},"text":"Pub. L. 97–331, § 4(b)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1620"},"text":"96 Stat. 1620","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30118(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(a)(1)(D) (related to 15:1417).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1417 (related to notice).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30118(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(a)(1)(D) (related to 15:1416).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1416 (related to notice).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the text of 15:1397(a)(1)(D) (related to 15:1411, 1412, 1413(c) (1st sentence cl. (6)), and 1417) is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “making an initial decision” are substituted for “determines” to distinguish the decision from the decision made under subsection (b) of this section. The words “of such determination”, “to the manufacturer”, and “of the Secretary” are omitted as surplus. The words “under this subsection” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “may make a final decision” are substituted for “determines”, and the words “prescribed under this chapter” are added, for clarity and consistency in this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), before clause (A), the words “If the Secretary decides under paragraph (1) of this subsection that the vehicle or equipment contains a defect or does not comply” are added for clarity and because of the restatement. The words “after such presentations by the manufacturer and interested persons” are omitted as surplus. In clause (A), the words “of the defect or noncompliance” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), before clause (1), the words “A manufacturer of a motor vehicle or replacement equipment” are substituted for “manufactured by him” in 15:1411 for clarity. The words “shall notify” are substituted for “he shall furnish notification to” to eliminate unnecessary words. The words “to the Secretary, if ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s1411"},"text":"section 1411 of this title","children":[],"tail":" applies” in 15:1413(c) (1st sentence cl. (6)) are omitted because of the restatement. The words “of the vehicle or equipment” are added for clarity. The words “and he shall remedy the defect or failure to comply in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1414"},"text":"section 1414 of this title","children":[],"tail":"” in 15:1411 are omitted as unnecessary because of the source provisions restated in section 30120 of the revised title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “any requirement under”, “to give notice with respect to”, and “as it relates” are omitted as surplus. The words “The Secretary may take action under this subsection only” are added because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “(including a manufacturer)” are omitted as surplus. The word “information” is substituted for “data” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb48bda7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb48bda8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" added subsec. (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" inserted “or electronic mail” after “certified mail” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/346/s101/a/tIII/s364"},"text":"Pub. L. 106–346, § 101(a) [title III, § 364]","children":[],"tail":", which directed amendment of this section in subsecs. (a), (b)(1), and (c), by inserting “, original equipment,” before “or replacement equipment” wherever appearing, and in subsec. (c), by redesignating pars. (1) and (2) as subpars. (A) and (B), respectively, and realigning margins, by substituting “(1) "},{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—A manufacturer” for “A manufacturer”, and by adding a new par (2) relating to duty of manufacturers, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/414/s2"},"text":"Pub. L. 106–414, § 2","children":[],"tail":". See Construction of 2000 Amendment note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb48bda9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb48bdaa-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/414/s2"},"text":"Pub. L. 106–414, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1800"},"text":"114 Stat. 1800","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/414/s2"},"text":"“The amendments made to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30118"},"text":"section 30118 of title 49","children":[],"tail":", United States Code, by section 364 of the Department of Transportation and Related Agencies Appropriations Act, 2001 ["},{"tag":"ref","attrib":{"href":"/us/pl/106/346/s101/a/tIII/s364"},"text":"Pub. L. 106–346, § 101(a) [title III, § 364]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-23"},"text":"Oct. 23, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1356"},"text":"114 Stat. 1356","children":[],"tail":", 1356A–37] are repealed and such section shall be effective as if such amending section had not been enacted.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
