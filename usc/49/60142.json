{"tag":"section","attrib":{"id":"idcc85d250-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142"},"text":null,"children":[{"tag":"num","attrib":{"value":"60142"},"text":"§ 60142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pipeline safety enhancement programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc85d251-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may establish and carry out limited safety-enhancing testing programs to evaluate innovative technologies and operational practices testing the safe operation of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d252-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a natural gas pipeline facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d253-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hazardous liquid pipeline facility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d254-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d255-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Testing programs established under subsection (a) may not exceed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc85d256-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 5 percent of the total miles of hazardous liquid pipelines in the United States that are regulated by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc85d257-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Pipeline and Hazardous Materials Safety Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc85d258-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State authority under section 60105 or 60106; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d259-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 5 percent of the total miles of natural gas pipelines in the United States that are regulated by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc85d25a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Pipeline and Hazardous Materials Safety Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc85d25b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State authority under section 60105 or 60106.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d25c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operator mileage limitation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall limit the miles of pipelines that each operator can test under each program established under subsection (a) to the lesser of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc85d25d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 38 percent of the total miles of pipelines in the system of the operator that are regulated by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc85d25e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Pipeline and Hazardous Materials Safety Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc85d25f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State authority under section 60105 or 60106; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d260-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1,000 miles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d261-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited areas","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any program established under subsection (a) shall not be located in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc85d262-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a high population area (as defined in section 195.450 of title 49, Code of Federal Regulations (or a successor regulation));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d263-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a high consequence area (as defined in section 192.903 of title 49, Code of Federal Regulations (or a successor regulation)); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d264-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unusually sensitive area (as described under subsection (a)(1)(B)(ii) of section 60109 in accordance with subsection (b) of that section).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d265-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"High consequence areas for hazardous liquid pipelines.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc85d266-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, the Secretary shall submit to Congress a report examining the benefits and costs of prohibiting the testing of hazardous liquid pipelines in high consequence areas (as defined in section 195.450 of title 49, Code of Federal Regulations (or a successor regulation)).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d267-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents of report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report described in subparagraph (A) shall examine—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc85d268-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the safety benefits of allowing the testing of hazardous liquid pipelines in high consequence areas (as defined in section 195.450 of title 49, Code of Federal Regulations (or a successor regulation)); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc85d269-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/b/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether additional testing conditions are required to protect those areas while conducting a testing program established under subsection (a) in those areas.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d26a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duration.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d26b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of a testing program established under subsection (a) shall be not more than a period of 3 years beginning on the date of approval of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d26c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not establish any additional safety-enhancing testing programs under subsection (a) after the date that is 3 years after the date of enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d26d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety Standards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d26e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require, as a condition of approval of a testing program under subsection (a), that the safety measures in the testing program are designed to achieve a level of safety that is greater than the level of safety required by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d26f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Determination.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc85d270-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may issue an order under subparagraph (A) of section 60118(c)(1) to accomplish the purpose of a testing program for a term not to exceed the time period described in subsection (c) if the condition described in paragraph (1) is met, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d271-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An order under subparagraph (A) shall pertain only to those regulations that would otherwise prevent the use of the safety technology to be tested under the testing program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d272-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Increased safety capabilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of paragraph (1), improvement in the reliability, accuracy, durability, or certainty of pipeline safety technologies, techniques, or methods shall constitute an appropriate means of meeting the safety measure requirement described in that paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc884273-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In establishing a testing program under subsection (a), the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc884274-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accident and incident record of the owners or operators participating in the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884275-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc884276-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the owners or operators participating in the program have a safety management system in place; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884277-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how the application of that system proposes to eliminate or mitigate potential safety and environmental risks throughout the duration of the program; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884278-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" whether the proposed safety technology has been tested through a research and development program carried out by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc884279-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc88427a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" collaborative research development organizations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc88427b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/e/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other institutions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc88427c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Data and Findings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc88427d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As a participant in a testing program established under subsection (a), an owner or operator shall submit to the Secretary detailed findings and a summary of data collected as a result of participation in the testing program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88427e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make publicly available on the website of the Department of Transportation an annual report for any ongoing testing program established under subsection (a) summarizing the progress of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc88427f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Revoke Participation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall immediately revoke participation in a testing program under subsection (a) if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc884280-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc884281-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant has an accident or incident involving death or personal injury necessitating in-patient hospitalization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884282-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the testing program is determined to be the cause of, or a contributing factor to, that accident or incident;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884283-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the participant fails to comply with the terms and conditions of the testing program; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884284-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the determination of the Secretary, continued participation in the testing program by the participant would be unsafe or would not be consistent with the goals and objectives of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc884285-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority to Terminate Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall immediately terminate a testing program under subsection (a) if continuation of the testing program would not be consistent with the goals and objectives of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc884286-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Rights.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc884287-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), if a State submits to the Secretary notice that the State requests an exemption from any testing program considered for establishment under this section, the State shall be exempt.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884288-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc884289-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/i/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not grant a requested exemption under paragraph (1) after a testing program is established.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc88428a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/i/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Late notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall not grant a requested exemption under paragraph (1) if the notice submitted under that paragraph is submitted to the Secretary more than 30 days after the date on which the Secretary issues an order providing an effective date for the testing program in accordance with subsection (j).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88428b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a State has not submitted a notice requesting an exemption under paragraph (1), the State shall not enforce any law (including regulations) that is inconsistent with a testing program in effect in the State under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc88428c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Review Process and Public Notice.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc88428d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall publish in the Federal Register and send directly to each relevant State and each appropriate State authority with a certification in effect under section 60105 a notice of each proposed testing program under subsection (a), including the order to be considered, and provide an opportunity for public comment for not less than 90 days.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc88428e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Response from secretary","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than the date on which the Secretary issues an order providing an effective date of a testing program noticed under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc88428f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/j/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the order in the Federal Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884290-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/j/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" respond to each comment submitted under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc884291-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the conclusion of each testing program, the Secretary shall make publicly available on the website of the Department of Transportation a report containing—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc884292-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the findings and conclusions of the Secretary with respect to the testing program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884293-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any recommendations of the Secretary with respect to the testing program, including any recommendations for amendments to laws (including regulations) and the establishment of standards, that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc884294-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/k/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would enhance the safe operation of interstate gas or hazardous liquid pipeline facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc884295-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/k/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are technically, operationally, and economically feasible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc884296-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If a report under subsection (k) indicates that it is practicable to establish technically, operationally, and economically feasible standards for the use of a safety-enhancing technology and any corresponding operational practices tested by the testing program described in the report, the Secretary, as soon as practicable after submission of the report, may promulgate regulations consistent with chapter 5 of title 5 (commonly known as the “Administrative Procedure Act”) that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc884297-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow operators of interstate gas or hazardous liquid pipeline facilities to use the relevant technology or practice to the extent practicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc884298-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60142/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish technically, operationally, and economically feasible standards for the capability and deployment of the technology or practice.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc884299-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dR/tI/s104/a"},"text":"Pub. L. 116–260, div. R, title I, § 104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2216"},"text":"134 Stat. 2216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc88429a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc88429b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (b)(4)(A) and (c)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
