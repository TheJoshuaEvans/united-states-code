},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s407/e"},"text":"Pub. L. 85–726, § 407(e)","children":[],"tail":" (1st–3d sentences), "},{"tag":"html:a","attrib":{"href":"/us/stat/72/766"},"text":"72 Stat. 766","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/623/s7/b"},"text":"Pub. L. 93–623, § 7(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2105"},"text":"88 Stat. 2105","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s9/t"},"text":"Pub. L. 98–443, § 9(t)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1708"},"text":"98 Stat. 1708","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(b)(1)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “unreasonable” is substituted for “undue” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(A) and (B), the word “inspect” is substituted for “have access to” for consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “to carry out this subsection” are substituted for “who shall have authority under the orders of the Board to inspect and examine lands, buildings, equipment, accounts, records, and memorandums to which the Board has access under this subsection” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
