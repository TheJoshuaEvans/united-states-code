{"tag":"section","attrib":{"id":"idcbc4cb87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41709"},"text":null,"children":[{"tag":"num","attrib":{"value":"41709"},"text":"§ 41709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records of air carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbc4cb88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41709/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall prescribe the form of records to be kept by an air carrier, including records on the movement of traffic, receipts and expenditures of money, and the time period during which the records shall be kept. A carrier may keep only records prescribed or approved by the Secretary. However, a carrier may keep additional records if the additional records do not impair the integrity of the records prescribed or approved by the Secretary and are not an unreasonable financial burden on the carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc4cb89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41709/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc4cb8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41709/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary at any time may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbc4cb8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41709/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspect the land, buildings, and equipment of an air carrier or foreign air carrier when necessary to decide under subchapter II of this chapter or section 41102, 41103, or 41302 of this title whether a carrier is fit, willing, and able; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc4cb8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41709/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inspect records kept or required to be kept by an air carrier, foreign air carrier, or ticket agent.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc4cb8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41709/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may employ special agents or auditors to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbc4cb8e-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1142"},"text":"108 Stat. 1142","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbc4cb8f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbc4cb90-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idc