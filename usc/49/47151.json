{"tag":"section","attrib":{"id":"idcc5fad24-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151"},"text":null,"children":[{"tag":"num","attrib":{"value":"47151"},"text":"§ 47151.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to transfer an interest in surplus property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc5fad25-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to sections 47152 and 47153 of this title, a department, agency, or instrumentality of the executive branch of the United States Government or a wholly owned Government corporation may convey to a State, political subdivision of a State, or tax-supported organization any interest in surplus property—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5fad26-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" that the Secretary of Transportation decides is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc5fad27-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" desirable for developing, improving, operating, or maintaining a public airport (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47102"},"text":"section 47102 of this title","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5fad28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably necessary to fulfill the immediate and foreseeable future requirements for developing, improving, operating, or maintaining a public airport; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5fad29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" needed for developing sources of revenue from nonaviation businesses at a public airport; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5fad2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Administrator of General Services approves the conveyance and decides the interest is not best suited for industrial use.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5fad2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ensuring Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Only the Secretary may ensure compliance with an instrument conveying an interest in surplus property under this subchapter. The Secretary may amend the instrument to correct the instrument or to make the conveyance comply with law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc621d2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposing of Interests Not Conveyed Under This Subchapter","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An interest in surplus property that could be used at a public airport but that is not conveyed under this subchapter shall be disposed of under other applicable law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc621d2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Condition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not waive any condition imposed on an interest in surplus property conveyed under subsection (a) that such interest be used for an aeronautical purpose unless the Secretary provides public notice not less than 30 days before the issuance of such waiver and determines that such waiver—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc621d2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not significantly impair the aeronautical purpose of an airport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc621d2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" will not result in the permanent closure of an airport (unless the Secretary determines that the waiver will directly facilitate the construction of a replacement airport); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc621d30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is necessary to protect or advance the civil aviation interests of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc621d31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47151/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requests by Public Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except with respect to a request made by another department, agency, or instrumentality of the executive branch of the United States Government, such a department, agency, or instrumentality shall give priority consideration to a request made by a public agency (as defined in section 47102) for surplus property described in subsection (a) for use at a public airport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc621d32-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1278"},"text":"108 Stat. 1278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tI"},"text":"Pub. L. 106–181, title I","children":[],"tail":", §§ 125(c), 135(d)(1), 136, "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/75"},"text":"114 Stat. 75","children":[],"tail":", 84, 85; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tI/s152/f"},"text":"Pub. L. 112–95, title I, § 152(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/34"},"text":"126 Stat. 34","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVII/s719/b/1"},"text":"Pub. L. 118–63, title VII, § 719(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1261"},"text":"138 Stat. 1261","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc621d33-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc621d34-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc621d35-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47151(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s6/c/1"},"text":"Pub. L. 89–670, § 6(c)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/938"},"text":"80 Stat. 938","children":[],"tail":"; Jan 12, 1983, "},{"tag":"html:a","attrib":{"href":"/us/pl/97/449/s7/b"},"text":"Pub. L. 97–449, § 7(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2444"},"text":"96 Stat. 2444","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App.:1622(g)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1944-10-03/ch479"},"text":"Oct. 3, 1944, ch. 479","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/765"},"text":"58 Stat. 765","children":[],"tail":", § 13(g)(1); added "},{"tag":"html:a","attrib":{"href":"/us/act/1947-07-30/ch404/s2"},"text":"July 30, 1947, ch. 404, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/678"},"text":"61 Stat. 678","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s1402/c"},"text":"Pub. L. 85–726, § 1402(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/807"},"text":"72 Stat. 807","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"May 21, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/258/s52/b/6"},"text":"Pub. L. 91–258, § 52(b)(6)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/235"},"text":"84 Stat. 235","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/248/s524/c"},"text":"Pub. L. 97–248, § 524(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/696"},"text":"96 Stat. 696","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47151(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App.:1622b.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1949-10-01/ch589/s3"},"text":"Oct. 1, 1949, ch. 589, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/63/700"},"text":"63 Stat. 700","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s1402/c"},"text":"Pub. L. 85–726, § 1402(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/807"},"text":"72 Stat. 807","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47151(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"50 App.:1622(g)(5), (6).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1944-10-03/ch479"},"text":"Oct. 3, 1944, ch. 479","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/765"},"text":"58 Stat. 765","children":[],"tail":", § 13(g)(5), (6); added "},{"tag":"html:a","attrib":{"href":"/us/act/1947-07-30/ch404/s2"},"text":"July 30, 1947, ch. 404, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/61/680"},"text":"61 Stat. 680","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “Notwithstanding any other provision of this Act” are omitted as surplus. The words “Subject to sections 47152 and 47153 of this title” are substituted for “but subject to the terms, conditions, reservations, and restrictions hereinafter provided for” to eliminate unnecessary words. The words “a department, agency, or instrumentality of the executive branch of the United States Government or a wholly owned Government corporation” are substituted for “any disposal agency designated pursuant to this Act” for clarity because disposal agencies were Government agencies designated under 50 App.:1619(a), that was repealed by section 602(a)(1) of the Federal Property and Administrative Services Act of 1949 (ch. 288, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/399"},"text":"63 Stat. 399","children":[],"tail":"), and Government agencies were all departments, agencies, and instrumentalities of the executive branch of the United States Government and wholly owned Government corporations. The word “give” is substituted for “convey or dispose of . . . without monetary consideration to the United States”, to eliminate unnecessary words. The word “municipality” is omitted as being included in “political subdivision”. The words “of a State” are added for clarity and consistency in the revised title and with other titles of the United States Code. The word “organization” is substituted for “institution” for consistency in the revised title. The words “all of the right, title, and . . . of the United States . . . and to . . . real or personal” are omitted as surplus. In clause (1)(A), the words “essential, suitable, or” are omitted as surplus. In clause (1)(B), the words “of the grantee” are omitted as surplus. In clause (2), the words “Administrator of General Services” are substituted for “[War Assets] Administrator” in section 13(g)(1) of the Surplus Property Act of 1944 (ch. 479, "},{"tag":"ref","attrib":{"href":"/us/stat/58/765"},"text":"58 Stat. 765","children":[],"tail":") because of section 105 of the Federal Property and Administrative Services Act of 1949 (ch. 288, "},{"tag":"ref","attrib":{"href":"/us/stat/63/381"},"text":"63 Stat. 381","children":[],"tail":"). The words “and decides the interest is not best suited for industrial use” are substituted for “(exclusive of property the highest and best use of which is determined by the Administrator of General Services to be industrial and which shall be so classified for disposal without regard to the provisions of this subsection)” to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for 50 App.:1622b to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the text of 50 App.:1622(g)(5) is omitted as obsolete because 50 App.:1621, 1622(f), and 1627(e) were repealed by section 602(a)(1) of the Federal Property and Administrative Services Act of 1949 (ch. 288, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/63/399"},"text":"63 Stat. 399","children":[],"tail":"). The words “An interest in surplus property that could be used at a public airport” are substituted for “All surplus property within the purview of this subsection” for clarity. The words “elsewhere in this Act or other applicable” are omitted as surplus. The word “law” is substituted for “Federal Statute” for consistency in the revised title and with other titles of the Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc621d36-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc621d37-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" added subsec. (d) and struck out former subsec. (d). Prior to amendment, text read as follows: “Before the Secretary may waive any condition imposed on an interest in surplus property conveyed under subsection (a) that such interest be used for an aeronautical purpose, the Secretary must provide notice to the public not less than 30 days before waiving such condition.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":" struck out “(other than real property that is subject to "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"section 2687 of title 10","children":[],"tail":", section 201 of the Defense Authorization Amendments and Base Closure and Realignment Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"10 U.S.C. 2687","children":[],"tail":" note), or section 2905 of the Defense Base Closure and Realignment Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t10/s2687"},"text":"10 U.S.C. 2687","children":[],"tail":" note))” after “subsection (a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s135/d/1/A/i"},"text":"Pub. L. 106–181, § 135(d)(1)(A)(i)","children":[],"tail":", substituted “convey to” for “give” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s135/d/1/A/ii"},"text":"Pub. L. 106–181, § 135(d)(1)(A)(ii)","children":[],"tail":", substituted “conveyance” for “gift”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s135/d/1/B"},"text":"Pub. L. 106–181, § 135(d)(1)(B)","children":[],"tail":", substituted “conveying” for “giving” and “conveyance” for “gift”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s135/d/1/C"},"text":"Pub. L. 106–181, § 135(d)(1)(C)","children":[],"tail":", substituted “Conveyed” for “Given” in heading and “conveyed” for “given” in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s125/c"},"text":"Pub. L. 106–181, § 125(c)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s136"},"text":"Pub. L. 106–181, § 136","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc621d38-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc621d39-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as a note under "},{"tag":