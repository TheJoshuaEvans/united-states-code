{"tag":"section","attrib":{"id":"idcb0f8523-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115"},"text":null,"children":[{"tag":"num","attrib":{"value":"20115"},"text":"§ 20115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" User fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb0f8524-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Schedule of Fees","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall prescribe by regulation a schedule of fees for railroad carriers subject to this chapter. The fees—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0f8525-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall cover the costs of carrying out this chapter (except section 20108(a));","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f8526-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imposed fairly on the railroad carriers, in reasonable relationship to an appropriate combination of criteria such as revenue ton-miles, track miles, passenger miles, or other relevant factors; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f8527-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not be based on that part of industry revenues attributable to a railroad carrier or class of railroad carriers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0f8528-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe procedures to collect the fees. The Secretary may use the services of a department, agency, or instrumentality of the United States Government or of a State or local authority to collect the fees, and may reimburse the department, agency, or instrumentality a reasonable amount for its services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0f8529-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collection, Deposit, and Use","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0f852a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall impose and collect fees under this section for each fiscal year before the end of the fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f852b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fees collected under this section shall be deposited in the general fund of the Treasury as offsetting receipts. The fees may be used, to the extent provided in advance in an appropriation law, only to carry out this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f852c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fees prescribed under this section shall be imposed in an amount sufficient to pay for the costs of activities under this chapter. However, the total fees received for a fiscal year may not be more than 105 percent of the total amount of the appropriations for the fiscal year for activities to be financed by the fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0f852d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Report","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0f852e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 90 days after the end of each fiscal year in which fees are collected under this section, the Secretary shall report to Congress on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0f852f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of fees collected during that fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f8530-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the impact of the fees on the financial health of the railroad industry and its competitive position relative to each competing mode of transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f8531-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total cost of Government safety activities for each other competing mode of transportation, including any part of that total cost defrayed by Government user fees.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f8532-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 90 days after submitting a report for a fiscal year, the Secretary shall submit to Congress recommendations for corrective legislation if the report includes a finding that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0f8533-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there has been an impact from the fees on the financial health of the railroad industry or its competitive position relative to each competing mode of transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f8534-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is a significant difference in the burden of Government user fees on the railroad industry and other competing modes of transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0f8535-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20115/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expiration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section expires on ","children":[{"tag":"date","attrib":{"date":"1995-09-30"},"text":"September 30, 1995","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0f8536-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/870"},"text":"108 Stat. 870","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb0f8537-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb0f8538-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb0f8539-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20115(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:447(a)(1), (3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458"},"text":"Pub. L. 91–458","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/971"},"text":"84 Stat. 971","children":[],"tail":", § 216; added "},{"tag":"html:span","attrib":{},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/508/s10501/a"},"text":"Pub. L. 101–508, § 10501(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/1388-399"},"text":"104 Stat. 1388–399","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20115(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:447(a)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20115(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:447(b)–(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20115(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:447(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20115(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:447(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “after notice and comment” are omitted as unnecessary because of 5:553.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “beginning on ","children":[{"tag":"date","attrib":{"date":"1991-03-01"},"text":"March 1, 1991","children":[],"tail":"” are omitted as obsolete."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
