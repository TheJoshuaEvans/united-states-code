{"tag":"section","attrib":{"id":"idca6b084d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s308"},"text":null,"children":[{"tag":"num","attrib":{"value":"308"},"text":"§ 308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca6b084e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As soon as practicable after the end of each fiscal year, the Secretary of Transportation shall report to the President, for submission to Congress, on the activities of the Department of Transportation during the prior fiscal year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6b084f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary shall submit to Congress each year a report on the conditions of the public ports of the United States, including the—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6b0850-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s308/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economic and technological development of the ports;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6b0851-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s308/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extent to which the ports contribute to the national welfare and security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6b0852-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s308/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" factors that may impede the continued development of the ports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6b0853-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6b0854-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s308/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall submit to Congress in March 1998, and in March of each even-numbered year thereafter, a report of estimates by the Secretary on the current performance and condition of public mass transportation systems with recommendations for necessary administrative or legislative changes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6b0855-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s308/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In reporting to Congress under this subsection, the Secretary shall prepare a complete assessment of public transportation facilities in the United States. The Secretary also shall assess future needs for those facilities and estimate future capital requirements and operation and maintenance requirements for one-year, 5-year, and 10-year periods at specified levels of service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca6b0856-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449/s1/b"},"text":"Pub. L. 97–449, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2422"},"text":"96 Stat. 2422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/216/s2/1/A"},"text":"Pub. L. 98–216, § 2(1)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-02-14"},"text":"Feb. 14, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/4"},"text":"98 Stat. 4","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/66/tI/s1121/h"},"text":"Pub. L. 104–66, title I, § 1121(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-21"},"text":"Dec. 21, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/724"},"text":"109 Stat. 724","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/362/tXV/s1502/c"},"text":"Pub. L. 105–362, title XV, § 1502(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-11-10"},"text":"Nov. 10, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/3295"},"text":"112 Stat. 3295","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tII/s218/a"},"text":"Pub. L. 118–63, title II, § 218(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1055"},"text":"138 Stat. 1055","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca6b0857-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca6b0858-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca6b0859-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","