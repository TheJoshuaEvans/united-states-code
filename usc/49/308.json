, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/424/s310"},"text":"Pub. L. 97–424, § 310","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2151"},"text":"96 Stat. 2151","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This [deletion of the last sentence of subsection (a)] is necessary because section 111(b) of the Congressional Reports Elimination Act of 1982 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/375"},"text":"Pub. L. 97–375","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1821"},"text":"96 Stat. 1821","children":[],"tail":") repealed section 602 of the Regional Rail Reorganization Act of 1973 ("},{"tag":"ref","attrib":{"href":"/us/pl/93/236"},"text":"Pub. L. 93–236","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/1022"},"text":"87 Stat. 1022","children":[],"tail":"), which was restated as section 308(a) (last sentence) of title 49 by "},{"tag":"ref","attrib":{"href":"/us/act/1983-01-12/s1"},"text":"section 1 of the Act of January 12, 1983","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/97/449"},"text":"Pub. L. 97–449","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2413"},"text":"96 Stat. 2413","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(1), the words “January of each even-numbered year” are substituted for “January of 1984 and in January of every second year thereafter” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca6b085c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca6b085d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s218/a/1"},"text":"Pub. L. 118–63, § 218(a)(1)","children":[],"tail":", (2), redesignated subsec. (c) as (b) and struck out former subsec. (b) which related to annual report on aviation activities of the Department."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s218/a/3"},"text":"Pub. L. 118–63, § 218(a)(3)","children":[],"tail":", redesignated subsec. (e) as (c). Former subsec. (c) redesignated (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/362"},"text":"Pub. L. 105–362","children":[],"tail":" substituted “submit to Congress in March 1998, and in March of each even-numbered year thereafter, a report” for “submit a report to Congress in January of each even-numbered year”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/66"},"text":"Pub. L. 104–66","children":[],"tail":" struck out subsec. (d) which related to reports to Congress listing assistance provided by Government to railroad industry."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/216/s2/1/A/i"},"text":"Pub. L. 98–216, § 2(1)(A)(i)","children":[],"tail":", substituted “Reports” for “Annual reports” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/216/s2/1/A/ii"},"text":"Pub. L. 98–216, § 2(1)(A)(ii)","children":[],"tail":", struck out requirement that the report include a complete statement on the effectiveness of the United States Railway Association and the Consolidated Rail Corporation in carrying out the purposes of the Regional Rail Reorganization Act of 1973."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/216/s2/1/A/iii"},"text":"Pub. L. 98–216, § 2(1)(A)(iii)","children":[],"tail":", added subsecs. (d) and (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca6b085e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca6b085f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Annual Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dA/tI/s11319"},"text":"Pub. L. 117–58, div. A, title I, § 11319","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/545"},"text":"135 Stat. 545","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dA/tI/s11319"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of Covered Project","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term ‘covered project’ means a project or activity carried out with funds provided by the Department [of Transportation], including a project carried out under title 23 or 49, United States Code—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is more than 5 years behind schedule; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the total amount spent on the project or activity is not less than $1,000,000,000 more than the original cost estimate for the project or activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"], and annually thereafter, the Secretary [of Transportation] shall submit to Congress a report on covered projects of the Department, which shall include, for each covered project—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a brief description of the covered project, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the purpose of the covered project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each location in which the covered project is carried out;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the contract or award number of the covered project, if applicable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the year in which the covered project was initiated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"“(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal share of the total cost of the covered project; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"“(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each primary contractor, subcontractor, grant recipient, and subgrantee recipient of the covered project;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation of any change to the original scope of the covered project, including by the addition or narrowing of the initial requirements of the covered project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original expected date for completion of the covered project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current expected date for completion of the covered project;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the original cost estimate for the covered project, as adjusted to reflect increases in the Consumer Price Index for All Urban Consumers, as published by the Bureau of Labor Statistics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the current cost estimate for the covered project, as adjusted to reflect increases in the Consumer Price Index for All Urban Consumers, as published by the Bureau of Labor Statistics;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"“(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an explanation for a delay in completion or an increase in the original cost estimate for the covered project, including, where applicable, any impact of insufficient or delayed appropriations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"“(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of and rationale for any award, incentive fee, or other type of bonus, if any, awarded for the covered project.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca6b0860-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rulemaking Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/1