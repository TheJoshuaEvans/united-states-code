{"tag":"section","attrib":{"id":"idcc66d811-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47505"},"text":null,"children":[{"tag":"num","attrib":{"value":"47505"},"text":"§ 47505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Airport noise compatibility planning grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc66d812-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may make a grant to a sponsor of an airport to develop, for planning purposes, information necessary to prepare and submit—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc66d813-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a noise exposure map and related information under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47503"},"text":"section 47503 of this title","children":[],"tail":", including the cost of obtaining the information; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc66d814-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a noise compatibility program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47504"},"text":"section 47504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc66d815-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47505/b"},"text":