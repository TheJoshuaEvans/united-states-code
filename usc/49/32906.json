{"tag":"section","attrib":{"id":"idcb86b1a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32906"},"text":null,"children":[{"tag":"num","attrib":{"value":"32906"},"text":"§ 32906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Maximum fuel economy increase for alternative fuel automobiles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb86b1a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32906/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each of model years 1993 through 2019 for each category of automobile (except an electric automobile or, beginning with model year 2016, an alternative fueled automobile that uses a fuel described in subparagraph (E) of section 32901(a)(1)), the maximum increase in average fuel economy for a manufacturer attributable to dual fueled automobiles is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb86b1a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32906/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1.2 miles a gallon for each of model years 1993 through 2014;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb86b1a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32906/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 1.0 miles per gallon for model year 2015;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb86b1aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32906/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.8 miles per gallon for model year 2016;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb86b1ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32906/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.6 miles per gallon for model year 2017;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb86b1ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32906/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.4 miles per gallon for model year 2018;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb86b1ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32906/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0.2 miles per gallon for model year 2019; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb86b1ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32906/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 0 miles per gallon for model years after 2019.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb86b1af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32906/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Calculation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In applying subsection (a), the Administrator of the Environmental Protection Agency shall determine the increase in a manufacturer’s average fuel economy attributable to dual fueled automobiles by subtracting from the manufacturer’s average fuel economy calculated under section 32905(f) the number equal to what the manufacturer’s average fuel economy would be if it were calculated by the formula under section 32904(a)(1) by including as the denominator for each model of dual fueled automobiles the fuel economy when the automobiles are operated on gasoline or diesel fuel.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb86b1b0-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1067"},"text":"108 Stat. 1067","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/58/tVII/s772/b"},"text":"Pub. L. 109–58, title VII, § 772(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-08"},"text":"Aug. 8, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/834"},"text":"119 Stat. 834","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/140/tI/s109/a"},"text":"Pub. L. 110–140, title I, § 109(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-19"},"text":"Dec. 19, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/1505"},"text":"121 Stat. 1505","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/291/dA/tIII/s318/a"},"text":"Pub. L. 113–291, div. A, title III, § 318(a)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2014-12-19"},"text":"Dec. 19, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3341"},"text":"128 Stat. 3341","children":[],"tail":", 3342.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id