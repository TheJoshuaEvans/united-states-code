{"tag":"section","attrib":{"id":"idcb0f8590-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20132"},"text":null,"children":[{"tag":"num","attrib":{"value":"20132"},"text":"§ 20132.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Visible markers for rear cars","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb0f8591-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20132/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall prescribe regulations and issue orders that may be necessary to require that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0f8592-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20132/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rear car of each passenger and commuter train has at least one highly visible marker that is lighted during darkness and when weather conditions restrict clear visibility; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f8593-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20132/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the rear car of each freight train has highly visible markers during darkness and when weather conditions restrict clear visibility.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0f8594-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20132/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20106"},"text":"section 20106 of this title","children":[],"tail":", subsection (a) of this section does not prohibit a State from continuing in force a law, regulation, or order in effect on "},{"tag":"date","attrib":{"date":"1976-07-08"},"text":"July 8, 1976","children":[],"tail":", related to lighted markers on the rear car of a freight train except to the extent it would cause the car to be in violation of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0f8595-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/873"},"text":"108 Stat. 873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb0f8596-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb0f8597-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb0f8598-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"