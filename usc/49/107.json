{"tag":"section","attrib":{"id":"idca55840c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s107"},"text":null,"children":[{"tag":"num","attrib":{"value":"107"},"text":"§ 107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Transit Administration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca55840d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Federal Transit Administration is an administration in the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca55840e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of the Administration is the Administrator who is appointed by the President, by and with the advice and consent of the Senate. The Administrator reports directly to the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca55840f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall carry out duties and powers prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca558410-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449/s1/b"},"text":"Pub. L. 97–449, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2417"},"text":"96 Stat. 2417","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/102/240/tIII/s3004/c/1"},"text":"Pub. L. 102–240, title III, § 3004(c)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2088"},"text":"105 Stat. 2088","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca558411-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca558412-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca558413-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"107","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1608 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Reorg. Plan No. 2 of 1968, eff. ","children":[{"tag":"html:span","attrib":{},"text":"July 1, 1968","children":[],"tail":", § 3, "},{"tag":"html:a","attrib":{"href":"/us/stat/82/1369"},"text":"82 Stat. 1369","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “and shall be compensated at the rate now or hereafter provided for Level III of the Executive Schedule Pay Rates (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"5 U.S.C. 5314","children":[],"tail":")” are omitted as surplus because of 5:5314."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca558414-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca558415-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1991—","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240"},"text":"Pub. L. 102–240","children":[],"tail":" substituted “Federal Transit Administration” for “Urban Mass Transportation Administration” in section catchline and subsec. (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca558416-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idca558417-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/240/tIII/s3004/a"},"text":"Pub. L. 102–240, title III, § 3004(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"1991-12-18"},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/105/2088"},"text":"105 Stat. 2088","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/240/tIII/s3004/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Redesignation of UMTA","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Urban Mass Transportation Administration of the Department of Transportation shall be known and designated as the ‘Federal Transit Administration’.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any reference in a law, map, regulation, document, paper, or other record of the United States to the Urban Mass Transportation Administration shall be deemed to be a reference to the ‘Federal Transit Administration’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
