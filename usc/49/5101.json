{"tag":"section","attrib":{"id":"idca879139-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5101"},"text":null,"children":[{"tag":"num","attrib":{"value":"5101"},"text":"§ 5101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The purpose of this chapter is to protect against the risks to life, property, and the environment that are inherent in the transportation of hazardous material in intrastate, interstate, and foreign commerce.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idca87913a-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/759"},"text":"108 Stat. 759","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII/s7101/b"},"text":"Pub. L. 109–59, title VII, § 7101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1891"},"text":"119 Stat. 1891","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca87913b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca87913c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca87913d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5101","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1801.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633/s102"},"text":"Pub. L. 93–633, § 102","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2156"},"text":"88 Stat. 2156","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “It is declared to be the policy of Congress”, “the Nation”, and “which are” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca87913e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca87913f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" substituted “The purpose of this chapter is to protect against the risks to life, property, and the environment that are inherent in the transportation of hazardous material in intrastate, interstate, and foreign commerce” for “The purpose of this chapter is to provide adequate protection against the risks to life and property inherent in the transportation of hazardous material in commerce by improving the regulatory and enforcement authority of the Secretary of Transportation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca879140-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idca879141-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tIII/s3001"},"text":"Pub. L. 114–94, div. A, title III, § 3001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1446"},"text":"129 Stat. 1446","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tIII/s3001"},"text":"“This title [amending sections 5302 to 5304, 5307, 5309 to 5312, 5314, 5315, 5323, 5325, 5327, 5329, 5336 to 5340, and 10501 of this title and sections 5313 and 5314 of Title 5, Government Organization and Employees, repealing sections 5313, 5319, and 5322 of this title, enacting provisions set out as notes under 5309, 5310, 5325, 5329, 5338 of this title, ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12143"},"text":"section 12143 of Title 42","children":[],"tail":", The Public Health and Welfare, amending provisions set out as a note under sections 5303 of this title, and repealing provisions set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5309"},"text":"section 5309 of this title","children":[],"tail":"] may be cited as the ‘Federal Public Transportation Act of 2015’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVII/s7001"},"text":"Pub. L. 114–94, div. A, title VII, § 7001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1588"},"text":"129 Stat. 1588","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tVII/s7001"},"text":"“This title [amending sections 5103, 5107 to 5109, 5116, 5117, 5121, and 5128 of this title and enacting provisions set out as notes under sections 5103, 5116, 20103, 20141, 20155, and 31305 of this title] may be cited as the ‘Hazardous Materials Transportation Safety Improvement Act of 2015’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idca879142-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dB/s20001"},"text":"Pub. L. 112–141, div. B, § 20001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/622"},"text":"126 Stat. 622","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/141/dB/s20001"},"text":"“This division [see Tables for classification] may be cited as the ‘Federal Public Transportation Act of 2012’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tIII/s33001"},"text":"Pub. L. 112–141, div. C, title III, § 33001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/832"},"text":"126 Stat. 832","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/141/dC/tIII/s33001"},"text":"“This title [see Tables for classification] may be cited as the ‘Hazardous Materials Transportation Safety Improvement Act of 2012’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idca879143-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIII/s3001"},"text":"Pub. L. 109–59, title III, § 3001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1544"},"text":"119 Stat. 1544","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/59/tIII/s3001"},"text":"“This title [see Tables for classification] may be cited as the ‘Federal Public Transportation Act of 2005’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII/s7001"},"text":"Pub. L. 109–59, title VII, § 7001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1891"},"text":"119 Stat. 1891","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/59/tVII/s7001"},"text":"“This title [see Tables for classification] may be cited as the ‘Hazardous Materials Transportation Safety and Security Reauthorization Act of 2005’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idca879144-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIII/s3001"},"text":"Pub. L. 105–178, title III, § 3001","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/338"},"text":"112 Stat. 338","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/178/tIII/s3001"},"text":"“This title [amending sections 5302 to 5305, 5307 to 5315, 5317 to 5320, 5323, 5325 to 5328, and 5333 to 5338 of this title and enacting provisions set out as notes under sections 301, 5301, 5307 to 5310, 5323, 5336, and 5338 of this title and sections 138 and 322 of Title 23, Highways] may be cited as the ‘Federal Transit Act of 1998’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idca879145-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/291/tII/s201"},"text":"Pub. L. 104–291, title II, § 201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3453"},"text":"110 Stat. 3453","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/104/291/tII/s201"},"text":"“This title [enacting ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5908"},"text":"section 5908 of this title","children":[],"tail":" and amending sections 5901 to 5903 and 5905 to 5907 of this title] may be cited as the ‘Intermodal Safe Container Transportation Amendments Act of 1996’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idca879146-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/311/tI/s101"},"text":"Pub. L. 103–311, title I, § 101","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1673"},"text":"108 Stat. 1673","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/311/tI/s101"},"text":"“This title [amending sections 5102 to 5104, 5107, 5108, 5110, 5116, 5117, 5121, and 5125 to 5127 of this title and enacting provisions set out as notes under this section, sections 5103, 5112, and 5121 of this title, and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t23/s307"},"text":"section 307 of Title 23","children":[],"tail":", Highways] may be cited as the ‘Hazardous Materials Transportation Authorization Act of 1994’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idca879147-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of duties, powers, and authority of Research and Special Programs Administration under this chapter to the Administrator of the Pipeline and Hazardous Materials Safety Administration, see ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/426/s2/b"},"text":"section 2(b) of Pub. L. 108–426","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s108"},"text":"section 108 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca879148-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Findings","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII/s7101/a"},"text":"Pub. L. 109–59, title VII, § 7101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1891"},"text":"119 Stat. 1891","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/59/tVII/s7101/a"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Congress finds with respect to hazardous materials transportation that—","children":[],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approximately 4,000,000,000 tons of regulated hazardous materials are transported each year and approximately 1,200,000 movements of hazardous materials occur each day, according to Department of Transportation estimates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the movement of hazardous materials in commerce is necessary to maintain economic vitality and meet consumer demands and must be conducted in a safe, secure, and efficient manner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accidents involving, or unauthorized access to, hazardous materials in transportation may result in a release of such materials and pose a serious threat to public health and safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" because of the potential risks to life, property, and the environment posed by unintentional releases of hazardous materials, consistency in laws and regulations governing the transportation of hazardous materials is necessary and desirable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in order to provide reasonable, adequate, and cost-effective protection from the risks posed by the transportation of hazardous materials, a network of well-trained State and local emergency response personnel and hazmat employees is essential.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca879149-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Buy American","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/311/tI/s123"},"text":"Pub. L. 103–311, title I, § 123","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1682"},"text":"108 Stat. 1682","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/311/tI/s123"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance With Buy American Act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"None of the funds made available under this title [see Short Title of 1994 Amendment note above] may be expended in violation of sections 2 through 4 of the Act of ","children":[{"tag":"date","attrib":{"date":"1933-03-03"},"text":"March 3, 1933","children":[],"tail":" ([former] "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s10a–10c"},"text":"41 U.S.C. 10a–10c","children":[],"tail":"; popularly known as the ‘Buy American Act’ [see "},{"tag":"ref","attrib":{"href":"/us/usc/t41/s8301"},"text":"41 U.S.C. 8301","children":[],"tail":" et seq.]), which are applicable to those funds."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sense of Congress; Requirement Regarding Notice.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of any equipment or products that may be authorized to be purchased with financial assistance provided under this title, it is the sense of Congress that entities receiving such assistance should, in expending such assistance, purchase only American-made equipment and products.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In providing financial assistance under this title, the Secretary of Transportation shall provide to each recipient of the assistance a notice describing the statement made in paragraph (1) by Congress.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition of Contracts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If it has been finally determined by a court or Federal agency that any person intentionally affixed a label bearing a ‘Made in America’ inscription, or any inscription with the same meaning, to any product sold in or shipped to the United States that is not made in the United States, such person shall be ineligible to receive any contract or subcontract made with funds provided pursuant to this title, pursuant to the debarment, suspension, and ineligibility procedures described in sections 9.400 through 9.409 of title 48, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reciprocity.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2), no contract or subcontract may be made with funds authorized under this title to a company organized under the laws of a foreign country unless the Secretary of Transportation finds that such country affords comparable opportunities to companies organized under laws of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation may waive the provisions of paragraph (1) if the products or services required are not reasonably available from companies organized under the laws of the United States. Any such waiver shall be reported to Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraph (1) shall not apply to the extent that to do so would violate the General Agreement on Tariffs and Trade or any other international agreement to which the United States is a party.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca87914a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"“Secretary” Defined","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tIII/s33002"},"text":"Pub. L. 112–141, div. C, title III, § 33002","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/832"},"text":"126 Stat. 832","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/141/dC/tIII/s33002"},"text":"“In this title [see Tables for classification], the term ‘Secretary’ means the Secretary of Transportation.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
