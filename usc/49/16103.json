{"tag":"section","attrib":{"id":"idcb0859b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s16103"},"text":null,"children":[{"tag":"num","attrib":{"value":"16103"},"text":"§ 16103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Unlawful disclosure of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb0859b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s16103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A pipeline carrier providing transportation subject to this part, or an officer, agent, or employee of that carrier, or another person authorized to receive information from that carrier, that knowingly discloses to another person, except the shipper or consignee, or a person who solicits or knowingly receives information about the nature, kind, quantity, destination, consignee, or routing of property tendered or delivered to that carrier for transportation provided under this part without the consent of the shipper or consignee, if that information may be used to the detriment of the shipper or consignee or may disclose improperly, to a competitor the business transactions of the shipper or consignee, is liable to the United States for a civil penalty of not more than $1,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0859b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s16103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Statutory Construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This part does not prevent a pipeline carrier providing transportation under this part from giving information—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0859b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s16103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in response to legal process issued under authority of a court of the United States or a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0859b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s16103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an officer, employee, or agent of the United States Government, a State, or a territory or possession of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0859b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s16103/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to another carrier or its agent to adjust mutual traffic accounts in the ordinary course of business.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0859b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s16103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board Employee","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An employee of the Board delegated to make an inspection or examination under section 15722 who knowingly discloses information acquired during that inspection or examination, except as directed by the Board, a court, or a judge of that court, shall be fined under title 18 or imprisoned for not more than 6 months, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0859b9-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s106/a"},"text":"Pub. L. 104–88, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/931"},"text":"109 Stat. 931","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb0859ba-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb0859bb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb0859bc-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11910"},"text":"section 11910 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb0859bd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb0859be-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
