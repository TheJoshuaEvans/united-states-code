{"tag":"section","attrib":{"id":"idcad1922f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5701"},"text":null,"children":[{"tag":"num","attrib":{"value":"5701"},"text":"§ 5701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food transportation safety inspections","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad19230-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection Procedures.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad19231-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation, in consultation with the Secretary of Health and Human Services and the Secretary of Agriculture, shall establish procedures for transportation safety inspections for the purpose of identifying suspected incidents of contamination or adulteration of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad19232-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5701/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" food in violation of regulations promulgated under section 416 of the Federal Food, Drug, and Cosmetic Act;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad19233-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5701/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a carcass, part of a carcass, meat, meat food product, or animal subject to detention under section 402 of the Federal Meat Inspection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s672"},"text":"21 U.S.C. 672","children":[],"tail":"); and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad19234-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5701/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" poultry products or poultry subject to detention under section 19 of the Poultry Products Inspection Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s467a"},"text":"21 U.S.C. 467a","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad19235-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad19236-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5701/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall develop and carry out a training program to conduct enforcement of this chapter and regulations prescribed under this chapter or compatible State laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad19237-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5701/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conduct","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this paragraph, the Secretary of Transportation shall train inspectors, including Department of Transportation personnel, State employees described under subsection (c), or personnel paid with funds authorized under sections 31102 and 31104, in the recognition of adulteration problems associated with the transportation of cosmetics, devices, drugs, food, and food additives and in the procedures for obtaining assistance of the appropriate departments, agencies, and instrumentalities of the Government and State authorities to support the enforcement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad19238-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The procedures established under paragraph (1) shall apply, at a minimum, to Department of Transportation personnel that perform commercial motor vehicle or railroad safety inspections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad19239-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notification of Secretary of Health and Human Services or Secretary of Agriculture","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall promptly notify the Secretary of Health and Human Services or the Secretary of Agriculture, as applicable, of any instances of potential food contamination or adulteration of a food identified during transportation safety inspections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad1923a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5701/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of State Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The means by which the Secretary of Transportation carries out subsection (b) may include inspections conducted by State employees using funds authorized to be appropriated under sections 31102 through 31104.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad1923b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII/s7203"},"text":"Pub. L. 109–59, title VII, § 7203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1913"},"text":"119 Stat. 1913","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad1923c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad1923d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcad1923e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 416 of the Federal Food, Drug, and Cosmetic Act, referred to in subsec. (a)(1)(A), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s350e"},"text":"section 350e of Title 21","children":[],"tail":", Food and Drugs."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcad1923f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 5701 to 5714 were omitted in the general amendment of this chapter by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7203"},"text":"Pub. L. 109–59, § 7203","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5701, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/854"},"text":"108 Stat. 854","children":[],"tail":", related to findings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5702, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/854"},"text":"108 Stat. 854","children":[],"tail":", defined terms."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 5703, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/855"},"text":"108 Stat. 855","children":[],"tail":", directed Secretary to prescribe regulations."}],"tail":"\n"},{"tag":"p","