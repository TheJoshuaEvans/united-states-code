{"tag":"section","attrib":{"id":"idcbc25b45-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706"},"text":null,"children":[{"tag":"num","attrib":{"value":"41706"},"text":"§ 41706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibitions against smoking on passenger flights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbc25b46-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Smoking Prohibition in Interstate and Intrastate Air Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual may not smoke—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc25b47-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an aircraft in scheduled passenger interstate or intrastate air transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc25b48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an aircraft in nonscheduled passenger interstate or intrastate air transportation, if a flight attendant is a required crewmember on the aircraft (as determined by the Administrator of the Federal Aviation Administration).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc25b49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Smoking Prohibition in Foreign Air Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall require all air carriers and foreign air carriers to prohibit smoking—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc25b4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an aircraft in scheduled passenger foreign air transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc25b4b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in an aircraft in nonscheduled passenger foreign air transportation, if a flight attendant is a required crewmember on the aircraft (as determined by the Administrator or a foreign government).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc25b4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Applicability.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc25b4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a foreign government objects to the application of subsection (b) on the basis that subsection (b) provides for an extraterritorial application of the laws of the United States, the Secretary shall waive the application of subsection (b) to a foreign air carrier licensed by that foreign government at such time as an alternative prohibition negotiated under paragraph (2) becomes effective and is enforced by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc25b4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, pursuant to paragraph (1), a foreign government objects to the prohibition under subsection (b), the Secretary shall enter into bilateral negotiations with the objecting foreign government to provide for an alternative smoking prohibition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc25b4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic Cigarettes.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc25b50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inclusion","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The use of an electronic cigarette shall be treated as smoking for purposes of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc25b51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic cigarette defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “electronic cigarette” means a device that delivers nicotine to a user of the device in the form of a vapor that is inhaled to simulate the experience of smoking.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc25b52-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41706/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe such regulations as are necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbc25b53-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1141"},"text":"108 Stat. 1141","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tVII/s708/a"},"text":"Pub. L. 106–181, title VII, § 708(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/159"},"text":"114 Stat. 159","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIV/s401/a"},"text":"Pub. L. 112–95, title IV, § 401(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/83"},"text":"126 Stat. 83","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIV/s409"},"text":"Pub. L. 115–254, div. B, title IV, § 409","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3331"},"text":"132 Stat. 3331","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbc25b54-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbc25b55-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbc25b56-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41706","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1374(d)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 404(d)(1); added "},{"tag":"html:span","attrib":{},"text":"Dec. 22, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/202/s328/a"},"text":"Pub. L. 100–202, § 328(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1329-382"},"text":"101 Stat. 1329–382","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/164/s335"},"text":"Pub. L. 101–164, § 335","children":[],"tail":" (less effective date), "},{"tag":"html:a","attrib":{"href":"/us/stat/103/1098"},"text":"103 Stat. 1098","children":[],"tail":", 1099."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1374 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 21, 1989","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/164/s335"},"text":"Pub. L. 101–164, § 335","children":[],"tail":" (related to effective date), "},{"tag":"html:a","attrib":{"href":"/us/stat/103/1099"},"text":"103 Stat. 1099","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “On and after the date of expiration of the 4-month period following ","children":[{"tag":"date","attrib":{"date":"1987-12-22"},"text":"December 22, 1987","children":[],"tail":"” are omitted as executed. The words “of an aircraft” are added for clarity. The text of 49 App.:1374 (note) is omitted as executed."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbc25b57-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbc25b58-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" added subsec. (d) and redesignated former subsec. (d) as (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s401/a/1"},"text":"Pub. L. 112–95, § 401(a)(1)","children":[],"tail":", substituted “passenger” for “scheduled” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s401/a/2"},"text":"Pub. L. 112–95, § 401(a)(2)","children":[],"tail":", added subsecs. (a) and (b) and struck out former subsecs. (a) and (b) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Smoking Prohibition in Intrastate and Interstate Air Transportation","children":[],"tail":".—An individual may not smoke in an aircraft in scheduled passenger interstate air transportation or scheduled passenger intrastate air transportation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Smoking Prohibition in Foreign Air Transportation","children":[],"tail":".—The Secretary of Transportation shall require all air carriers and foreign air carriers to prohibit smoking in any aircraft in scheduled passenger foreign air transportation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—An individual may not smoke in the passenger cabin or lavatory of an aircraft on a scheduled airline flight segment in air transportation or intrastate air transportation that is—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) between places in a State of the United States, the District of Columbia, Puerto Rico, or the Virgin Islands;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) between a place in any jurisdiction referred to in clause (1) of this subsection (except Alaska and Hawaii) and a place in any other of those jurisdictions; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3)(A) scheduled for not more than 6 hours’ duration; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B)(i) between a place referred to in clause (1) of this subsection (except Alaska and Hawaii) and Alaska or Hawaii; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(ii) between Alaska and Hawaii.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—The Secretary of Transportation shall prescribe regulations necessary to carry out this section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbc25b59-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbc25b5a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tVII/s708/b"},"text":"Pub. L. 106–181, title VII, § 708(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/159"},"text":"114 Stat. 159","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/181/tVII/s708/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect on the date that is 60 days after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
