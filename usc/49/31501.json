html:p","attrib":{},"text":"(no source).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"3101(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:303(a)(22).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words “going to or from” are substituted for “proceeding to or returning from” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (2) is included to ensure that the identical definitions that are relevant are used without repeating them. The source provisions for the quoted definitions are found in the revision notes for section 10102 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3), the words “including any ‘contract common carrier by motor vehicle’ ” are omitted as covered by the definition of “motor carrier”. The words “referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10521/a"},"text":"section 10521(a) of this title","children":[],"tail":"” are substituted for “in interstate or foreign commerce” for clarity and consistency in the revised title. The word “except” is substituted for “but not including” for clarity. The words “at least” are substituted for “or more”, and the words “but the term does not include” are substituted for “except”, for consistency."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb788042-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null