{"tag":"section","attrib":{"id":"idcb788038-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31501"},"text":null,"children":[{"tag":"num","attrib":{"value":"31501"},"text":"§ 31501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb788039-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “migrant worker” means an individual going to or from employment in agriculture as provided under section 3121(g) of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s3121/g"},"text":"26 U.S.C. 3121(g)","children":[],"tail":") or section 3(f) of the Fair Labor Standards Act of 1938 ("},{"tag":"ref","attrib":{"href":"/us/usc/t29/s203/f"},"text":"29 U.S.C. 203(f)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb78803a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “motor carrier”, “motor common carrier”, “motor private carrier”, “motor vehicle”, and “United States” have the same meanings given those terms in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s13102"},"text":"section 13102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb78803b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31501/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “motor carrier of migrant workers”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb78803c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31501/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a person (except a motor common carrier) providing transportation referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s13501"},"text":"section 13501 of this title","children":[],"tail":" by a motor vehicle (except a passenger automobile or station wagon) for at least 3 migrant workers at a time to or from their employment; but"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb78803d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31501/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include a migrant worker providing transportation for migrant workers and their immediate families.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb78803e-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449"},"text":"Pub. L. 97–449","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2438"},"text":"96 Stat. 2438","children":[],"tail":", § 3101; renumbered § 31501 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/c"},"text":"Pub. L. 103–272, § 1(c)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/745"},"text":"108 Stat. 745","children":[],"tail":", 1029; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/26"},"text":"Pub. L. 103–429, § 6(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib