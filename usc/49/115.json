{"tag":"section","attrib":{"id":"idca616a98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115"},"text":null,"children":[{"tag":"num","attrib":{"value":"115"},"text":"§ 115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation Security Oversight Board","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca616a99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established in the Department of Homeland Security a board to be known as the “Transportation Security Oversight Board”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca616a9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca616a9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Number and appointment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall be composed of 7 members as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca616a9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security, or the Secretary’s designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca616a9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation, or the Secretary’s designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca616a9e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General, or the Attorney General’s designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca616a9f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Defense, or the Secretary’s designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca616aa0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury, or the Secretary’s designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca616aa1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director of National Intelligence, or the Director’s designee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca616aa2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" One member appointed by the President to represent the National Security Council.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca616aa3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairperson","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chairperson of the Board shall be the Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca616aa4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca616aa5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review and ratify or disapprove any regulation or security directive issued by the Administrator of the Transportation Security Administration under section 114(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2) within 30 days after the date of issuance of such regulation or directive;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca616aa6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the coordination of intelligence, security, and law enforcement activities affecting transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca616aa7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" facilitate the sharing of intelligence, security, and law enforcement information affecting transportation among Federal agencies and with carriers and other transportation providers as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca616aa8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explore the technical feasibility of developing a common database of individuals who may pose a threat to transportation or national security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca616aa9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review plans for transportation security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca616aaa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make recommendations to the Administrator regarding matters reviewed under paragraph (5).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca616aab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quarterly Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall meet at least quarterly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca616aac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s115/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration of Security Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A majority of the Board may vote to close a meeting of the Board to the public, except that meetings shall be closed to the public whenever classified,","children":[{"tag":"ref","attrib":{"idref":"fn002006"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002006"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The word “information” probably should be inserted."}],"tail":" sensitive security information, or information protected in accordance with section 40119(b),"},{"tag":"ref","attrib":{"idref":"fn002007"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002007"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" See References in Text note below."}],"tail":" will be discussed."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca616aad-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s102/a"},"text":"Pub. L. 107–71, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/604"},"text":"115 Stat. 604","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tIV/s426/a"},"text":"Pub. L. 107–296, title IV, § 426(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2186"},"text":"116 Stat. 2186","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/259/tIV/s411"},"text":"Pub. L. 111–259, title IV, § 411","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2010-10-07"},"text":"Oct. 7, 2010","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/2725"},"text":"124 Stat. 2725","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/b"},"text":"Pub. L. 115–254, div. K, title I, § 1991(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3626"},"text":"132 Stat. 3626","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca616aae-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca616aaf-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca616ab0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40119"},"text":"Section 40119 of this title","children":[],"tail":", referred to in subsec. (e), was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/c/3"},"text":"Pub. L. 115–254, div. K, title I, § 1991(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3627"},"text":"132 Stat. 3627","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca616ab1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/b/1"},"text":"Pub. L. 115–254, § 1991(b)(1)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration” for “Under Secretary of Transportation for security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/b/2"},"text":"Pub. L. 115–254, § 1991(b)(2)","children":[],"tail":", substituted “Administrator” for “Under Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2010—Subsec. (b)(1)(F). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/111/259"},"text":"Pub. L. 111–259","children":[],"tail":" amended subpar. (F) generally. Prior to amendment, subpar. (F) read as follows: “The Director of the Central Intelligence Agency, or the Director’s designee.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s426/a/1"},"text":"Pub. L. 107–296, § 426(a)(1)","children":[],"tail":", substituted “Department of Homeland Security” for “Department of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s426/a/2"},"text":"Pub. L. 107–296, § 426(a)(2)","children":[],"tail":", added subpar. (A), redesignated former subpars. (A) to (F) as (B) to (G), respectively, and struck out former subpar. (G) which read as follows: “One member appointed by the President to represent the Office of Homeland Security.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s426/a/3"},"text":"Pub. L. 107–296, § 426(a)(3)","children":[],"tail":", substituted “Secretary of Homeland Security” for “Secretary of Transportation”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca616ab2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca616ab3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296"},"text":"Pub. L. 107–296","children":[],"tail":" effective 60 days after "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/s4"},"text":"section 4 of Pub. L. 107–296","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s101"},"text":"section 101 of Title 6","children":[],"tail":", Domestic Security."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"idca616ab4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"For transfer of functions, personnel, assets, and liabilities of the Transportation Security Administration of the Department of Transportation, including the functions of the Secretary of Transportation, and of the Under Secretary of Transportation for Security, relating thereto, to the Secretary of Homeland Security, and for treatment of related references, see sections 203(2), 551(d), 552(d), and 557 of Title 6, Domestic Security, and the Department of Homeland Security Reorganization Plan of ","children":[{"tag":"date","attrib":{"date":"2002-11-25"},"text":"November 25, 2002","children":[],"tail":", as modified, set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t6/s542"},"text":"section 542 of Title 6","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
