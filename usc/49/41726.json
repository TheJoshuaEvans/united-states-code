{"tag":"section","attrib":{"id":"idcbc71607-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41726"},"text":null,"children":[{"tag":"num","attrib":{"value":"41726"},"text":"§ 41726.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Strollers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbc71608-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41726/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), a covered air carrier shall not deny a passenger the ability to check a stroller at the departure gate if the stroller is being used by a passenger to transport a child traveling on the same flight as the passenger.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc71609-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41726/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) shall not apply in instances where the size or weight of the stroller poses a safety or security risk.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc7160a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41726/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered Air Carrier Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “covered air carrier” means an air carrier or a foreign air carrier as those terms are defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40102"},"text":"section 40102 of title 49","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbc7160b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIV/s412/a"},"text":"Pub. L. 115–254, div. B, title IV, § 412(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3331"},"text":"132 Stat. 3331","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
