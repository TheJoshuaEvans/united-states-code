{"tag":"section","attrib":{"id":"idcb0f85bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135"},"text":null,"children":[{"tag":"num","attrib":{"value":"20135"},"text":"§ 20135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Licensing or certification of locomotive operators","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb0f85c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall prescribe regulations and issue orders to establish a program requiring the licensing or certification, after one year after the program is established, of any operator of a locomotive.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0f85c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program established under subsection (a) of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0f85c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be carried out through review and approval of each railroad carrier’s operator qualification standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f85c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall provide minimum training requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f85c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall require comprehensive knowledge of applicable railroad carrier operating practices and rules;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f85c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" except as provided in subsection (c)(1) of this section, shall require consideration, to the extent the information is available, of the motor vehicle driving record of each individual seeking licensing or certification, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0f85c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any denial, cancellation, revocation, or suspension of a motor vehicle operator’s license by a State for cause within the prior 5 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f85c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any conviction within the prior 5 years of an offense described in section 30304(a)(3)(A) or (B) of this title;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f85c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may require, based on the individual’s driving record, disqualification or the granting of a license or certification conditioned on requirements the Secretary prescribes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f85c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall require an individual seeking a license or certification—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0f85ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to request the chief driver licensing official of each State in which the individual has held a motor vehicle operator’s license within the prior 5 years to provide information about the individual’s driving record to the individual’s employer, prospective employer, or the Secretary, as the Secretary requires; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb11f5cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to make the request provided for in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30305/b/4"},"text":"section 30305(b)(4) of this title","children":[],"tail":" for information to be sent to the individual’s employer, prospective employer, or the Secretary, as the Secretary requires."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb11f5cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waivers","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb11f5cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall prescribe standards and establish procedures for waiving subsection (b)(4) of this section for an individual or class of individuals who the Secretary decides are not currently unfit to operate a locomotive. However, the Secretary may waive subsection (b)(4) for an individual or class of individuals with a conviction, cancellation, revocation, or suspension described in paragraph (2)(A) or (B) of this subsection only if the individual or class, after the conviction, cancellation, revocation, or suspension, successfully completes a rehabilitation program established by a railroad carrier or approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb11f5ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If an individual, after the conviction, cancellation, revocation, or suspension, successfully completes a rehabilitation program established by a railroad carrier or approved by the Secretary, the individual may not be denied a license or certification under subsection (b)(4) of this section because of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb11f5cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conviction for operating a motor vehicle when under the influence of, or impaired by, alcohol or a controlled substance; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb11f5d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cancellation, revocation, or suspension of the individual’s motor vehicle operator’s license for operating a motor vehicle when under the influence of, or impaired by, alcohol or a controlled substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb11f5d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Opportunity for Hearing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual denied a license or certification or whose license or certification is conditioned on requirements prescribed under subsection (b)(4) of this section shall be entitled to a hearing under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20103/e"},"text":"section 20103(e) of this title","children":[],"tail":" to decide whether the license has been properly denied or conditioned."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb11f5d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20135/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Opportunity to Examine and Comment on Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, employer, or prospective employer, as appropriate, shall make information obtained under subsection (b)(6) of this section available to the individual. The individual shall be given an opportunity to comment in writing about the information. Any comment shall be included in any record or file maintained by the Secretary, employer, or prospective employer that contains information to which the comment is related.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb11f5d3-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/874"},"text":"108 Stat. 874","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb11f5d4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb11f5d5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb11f5d6-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20135(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:431(i)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458"},"text":"Pub. L. 91–458","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/971"},"text":"84 Stat. 971","children":[],"tail":", § 202(i); added "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342"},"text":"Pub. L. 100–342","children":[],"tail":", §§ 4(a), 7(b), "},{"tag":"html:a","attrib":{"href":"/us/stat/102/625"},"text":"102 Stat. 625","children":[],"tail":", 628; "},{"tag":"html:span","attrib":{},"text":"Sept. 3, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/365/s2/1"},"text":"Pub. L. 102–365, § 2(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/972"},"text":"106 Stat. 972","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20135(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:431(i)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20135(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:431(i)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20135(c)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:431(i)(6).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20135(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:431(i)(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20135(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:431(i)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “within 12 months after ","children":[{"tag":"date","attrib":{"date":"1988-06-22"},"text":"June 22, 1988","children":[],"tail":"” are omitted as executed. The words “including any locomotive engineer” are omitted as surplus. The words “after one year after” are substituted for “after the expiration of 12 months following” to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(5), the word “requirements” is substituted for “terms” for consistency in this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “In establishing the program under this subsection” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
