":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41309(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1382(a)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 412(a), (b); added "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/504/s28/c"},"text":"Pub. L. 95–504, § 28(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1729"},"text":"92 Stat. 1729","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Feb. 15, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/192/s11"},"text":"Pub. L. 96–192, § 11","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/39"},"text":"94 Stat. 39","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(a)(6) (related to 49 App.:1382).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(a)(6) (related to § 412); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/c"},"text":"Pub. L. 98–443, § 3(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(b)(1)(C) (related to 49 App.:1382(a)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(b)(1)(C) (related to § 412(a), (b)); added "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/504/s40/a"},"text":"Pub. L. 95–504, § 40(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1745"},"text":"92 Stat. 1745","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1982","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/309/s4/b"},"text":"Pub. L. 97–309, § 4(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/1454"},"text":"96 Stat. 1454","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/a"},"text":"Pub. L. 98–443, § 3(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1703"},"text":"98 Stat. 1703","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41309(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1382(a)(2)(A).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(a)(6), (b)(1)(C) (as 1551(a)(6), (b)(1)(C) relates to 49 App.:1382(a)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41309(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1382(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(a)(6), (b)(1)(C) (as 1551(a)(6), (b)(1)(C) relates to 49 App.:1382(b)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41309(c)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1382(a)(2)(B).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41309(c)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1382(a)(2)(C).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(a)(6), (b)(1)(C) (as 1551(a)(6), (b)(1)(C) relates to 49 App.:1382(a)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the word “contract” is omitted as being included in “agreement”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “(whether enforceable by provisions for liquidated damages, penalties, bonds, or otherwise)” are omitted as surplus. The words “(except an agreement related to interstate air transportation)” and “(except arrangements related to interstate air transportation)” are added because of 49 App.:1551(a)(6) (related to 49 App.:1382). The word “working” is omitted as surplus. The words “in force on ","children":[{"tag":"date","attrib":{"date":"1978-10-24"},"text":"October 24, 1978","children":[],"tail":", or thereafter entered into” are omitted as executed. The words “and any modification or cancellation of an agreement” are substituted for “or any modification or cancellation thereof” for clarity and consistency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “The Board shall by order disapprove any contract, agreement, or request . . . that it finds to be adverse to the public interest or in violation of this chapter” are omitted as surplus because of the language restated in this subsection that sets out the requirements for approval by the Secretary of Transportation before the antitrust exemption is effective. The words “whether or not previously approved by it” are omitted as surplus because of the language in clause (1) requiring periodic review and continuing approval. The words “by order” are omitted as unnecessary because of 5:ch. 5, subch. II. The text of 49 App.:1382(a)(2)(A)(iii) is omitted as obsolete because of 49 App.:1551(a)(6) (related to 49 App.:1382).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “in accordance with regulations which it prescribes” are omitted as surplus. The words “in accordance with regulations prescribed by the Board” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbbd9fe8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:41309(b)(2)(B) for consistency in the subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbbd9fe9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbbd9fea-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (b)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" substituted “carrier” for “common carrier”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (b)(2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" substituted “a carrier” for “a common carrier”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbbd9feb-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbbd9fec-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbbd9fed-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Air Transportation Arrangements in Certain States","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s116"},"text":"Pub. L. 107–71, title I, § 116","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/624"},"text":"115 Stat. 624","children":[],"tail":", which related to air transportation arrangements for flights that both originate and terminate at points within the same State, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/273/dC/tIV/s14102/g"},"text":"Pub. L. 107–273, div. C, title IV, § 14102(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-02"},"text":"Nov. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1922"},"text":"116 Stat. 1922","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
