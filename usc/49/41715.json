{"tag":"section","attrib":{"id":"idcbc4cc13-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41715"},"text":null,"children":[{"tag":"num","attrib":{"value":"41715"},"text":"§ 41715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Phase-out of slot rules at certain airports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbc4cc14-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41715/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The rules contained in subparts S and K of part 93, title 14, Code of Federal Regulations, shall not apply—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc4cc15-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41715/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"2002-07-01"},"text":"July 1, 2002","children":[],"tail":", at Chicago O’Hare International Airport; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc4cc16-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41715/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after ","children":[{"tag":"date","attrib":{"date":"2007-01-01"},"text":"January 1, 2007","children":[],"tail":", at LaGuardia Airport or John F. Kennedy International Airport."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc4cc17-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41715/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statutory Construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section and sections 41714 and 41716–41718 shall be construed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc4cc18-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41715/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as affecting the Federal Aviation Administration’s authority for safety and the movement of air traffic; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc4cc19-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41715/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as affecting any other authority of the Secretary to grant exemptions under section 41714.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc4cc1a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41715/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors To Consider.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc4cc1b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41715/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before the award of slot exemptions under sections 41714 and 41716–41718, the Secretary of Transportation may consider, among other determining factors, whether the petitioning air carrier’s proposal provides the maximum benefit to the United States economy, including the number of United States jobs created by the air carrier, its suppliers, and related activities. The Secretary should give equal consideration to the consumer benefits associated with the award of such exemptions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc4cc1c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41715/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) does not apply in any case in which the air carrier requesting the slot exemption is proposing to use under the exemption a type of aircraft for which there is not a competing United States manufacturer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbc4cc1d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tII/s231/b/2"},"text":"Pub. L. 106–181, title II, § 231(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/108"},"text":"114 Stat. 108","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbc4cc1e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbc4cc1f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcbc4cc20-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 41715 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41719"},"text":"section 41719 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbc4cc21-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcbc4cc22-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as an Effective Date of 2000 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
