{"tag":"section","attrib":{"id":"idcbd7dea7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44102"},"text":null,"children":[{"tag":"num","attrib":{"value":"44102"},"text":"§ 44102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration requirements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd7dea8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An aircraft may be registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44103"},"text":"section 44103 of this title","children":[],"tail":" only when the aircraft is—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7dea9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not registered under the laws of a foreign country and is owned by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7deaa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44102/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a citizen of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7deab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44102/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an individual citizen of a foreign country lawfully admitted for permanent residence in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7deac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44102/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a corporation not a citizen of the United States when the corporation is organized and doing business under the laws of the United States or a State, and the aircraft is based and primarily used in the United States; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7dead-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an aircraft of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd7deae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44102/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd7deaf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44102/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State, the District of Columbia, a territory or possession of the United States, or a political subdivision of a State, territory, or possession.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7deb0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duty To Define Certain Term","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out subsection (a)(1)(C) of this section, the Secretary of Transportation shall define “based and primarily used in the United States”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd7deb1-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1161"},"text":"108 Stat. 1161","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd7deb2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbd7deb3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbd7deb4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44102(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1401(b) (1st sentence cl. (1)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s501/b"},"text":"Pub. L. 85–726, § 501(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/772"},"text":"72 Stat. 772","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Nov. 9, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/163/s14"},"text":"Pub. L. 95–163, § 14","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1283"},"text":"91 Stat. 1283","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Mar. 8, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/241"},"text":"Pub. L. 95–241","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/119"},"text":"92 Stat. 119","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44102(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1401(b) (1st sentence cl. (2)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44102(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1401(b) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “may be registered” are substituted for “shall be eligible for registration”, and the words “under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44103"},"text":"section 44103 of this title","children":[],"tail":"” are added, for clarity. The words “only when” are substituted for “if, but only if” for consistency. In subclause (C), the words “not a citizen of the United States” are substituted for “(other than a corporation which is a citizen of the United States)” to eliminate unnecessary words. The word “lawfully” is omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “In carrying out subsection (a)(1)(C) of this section” are added because of the restatement. The words “by regulation” are omitted as unnecessary because of 49:322(a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
