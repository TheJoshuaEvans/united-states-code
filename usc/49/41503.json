{"tag":"section","attrib":{"id":"idcbbfe95e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41503"},"text":null,"children":[{"tag":"num","attrib":{"value":"41503"},"text":"§ 41503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishing joint prices for through routes provided by State authorized carriers","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Subject to sections 41309 and 42111 of this title, a citizen of the United States providing transportation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41101/b"},"text":"section 41101(b) of this title","children":[],"tail":" may make an agreement with an air carrier or foreign air carrier for joint prices for that transportation. The joint prices agreed to must be the lowest of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbfe95f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41503/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the sum of the applicable prices for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbbfe960-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41503/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the part of the transportation provided in the State and approved by the appropriate State authority; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbfe961-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41503/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the part of the transportation provided by the air carrier or foreign air carrier;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbfe962-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41503/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a joint price established and filed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41504"},"text":"section 41504 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbfe963-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41503/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a joint price prescribed by the Secretary of Transportation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41507"},"text":"section 41507 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbbfe964-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1132"},"text":"108 Stat. 1132","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbbfe965-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbbfe966-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbbfe967-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":