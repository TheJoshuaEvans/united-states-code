ext":"72 Stat. 731","children":[],"tail":", § 401(d) (4)(A)(ii) (related to joint rates, fares), (B); added "},{"tag":"html:span","attrib":{},"text":"Nov. 9, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/163/s9"},"text":"Pub. L. 95–163, § 9","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1281"},"text":"91 Stat. 1281","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/504/s9"},"text":"Pub. L. 95–504, § 9","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1713"},"text":"92 Stat. 1713","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(b)(1)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(b)(1)(E); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/e"},"text":"Pub. L. 98–443, § 3(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, before clause (1), the words “Notwithstanding any other provision of this chapter” are omitted as surplus. The words “a citizen of the United States providing transportation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41101/b"},"text":"section 41101(b) of this title","children":[],"tail":"” are substituted for “any citizen of the United States who undertakes, within any State, the carriage of persons or property as a common carrier for compensation or hire with aircraft capable of carrying thirty or more persons pursuant to authority for such carriage within such State granted by the appropriate State agency” for clarity and because of the restatement of 49 App.:1371(d)(4)(A)(i) and (ii) (related to joint services) in section 41101(b) of the revised title. The words “the establishment of” are omitted as surplus."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
