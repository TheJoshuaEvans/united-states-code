{"tag":"section","attrib":{"id":"idcad64de6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6311"},"text":null,"children":[{"tag":"num","attrib":{"value":"6311"},"text":"§ 6311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research and development grants","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary may make grants to, or enter into cooperative agreements or contracts with, public and nonprofit private entities (including State transportation departments, metropolitan planning organizations, and institutions of higher education) for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad64de7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6311/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" investigation of the subjects described in section 6302(b)(3)(B)(vi);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64de8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6311/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research and development of new methods of data collection, standardization, management, integration, dissemination, interpretation, and analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bde9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6311/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstration programs by States, local governments, and metropolitan planning organizations to coordinate data collection, reporting, management, storage, and archiving to simplify data comparisons across jurisdictions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bdea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6311/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development of electronic clearinghouses of transportation data and related information, as part of the Library; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bdeb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6311/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" development and improvement of methods for sharing geographic data, in support of the database under section 6310 ","children":[{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section 6309”."}],"tail":" and the National Spatial Data Infrastructure developed under Executive Order 12906 (59 Fed. Reg. 17671) (or a successor Executive Order)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad8bdec-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tII/s52011/a"},"text":"Pub. L. 112–141, div. E, title II, § 52011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/894"},"text":"126 Stat. 894","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad8bded-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad8bdee-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcad8bdef-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Executive Order 12906, referred to in par. (5), is Ex. Ord. No. 12906, ","children":[{"tag":"date","attrib":{"date":"1994-04-11"},"text":"Apr. 11, 1994","children":[],"tail":", 59 F.R. 17671, which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t43/s1457"},"text":"section 1457 of Title 43","children":[],"tail":", Public Lands."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcad8bdf0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcad8bdf1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
