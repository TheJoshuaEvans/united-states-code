{"tag":"section","attrib":{"id":"idcadb0830-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101"},"text":null,"children":[{"tag":"num","attrib":{"value":"10101"},"text":"§ 10101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rail transportation policy","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In regulating the railroad industry, it is the policy of the United States Government—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb0831-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to allow, to the maximum extent possible, competition and the demand for services to establish reasonable rates for transportation by rail;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0832-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to minimize the need for Federal regulatory control over the rail transportation system and to require fair and expeditious regulatory decisions when regulation is required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0833-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote a safe and efficient rail transportation system by allowing rail carriers to earn adequate revenues, as determined by the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0834-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the development and continuation of a sound rail transportation system with effective competition among rail carriers and with other modes, to meet the needs of the public and the national defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0835-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to foster sound economic conditions in transportation and to ensure effective competition and coordination between rail carriers and other modes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0836-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to maintain reasonable rates where there is an absence of effective competition and where rail rates provide revenues which exceed the amount necessary to maintain the rail system and to attract capital;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0837-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to reduce regulatory barriers to entry into and exit from the industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0838-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to operate transportation facilities and equipment without detriment to the public health and safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0839-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage honest and efficient management of railroads;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb083a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require rail carriers, to the maximum extent practicable, to rely on individual rate increases, and to limit the use of increases of general applicability;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb083b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage fair wages and safe and suitable working conditions in the railroad industry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb083c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit predatory pricing and practices, to avoid undue concentrations of market power, and to prohibit unlawful discrimination;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb083d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure the availability of accurate cost information in regulatory proceedings, while minimizing the burden on rail carriers of developing and maintaining the capability of providing such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb083e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage and promote energy conservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb083f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10101/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide for the expeditious handling and resolution of all proceedings required or permitted to be brought under this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcadb0840-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/805"},"text":"109 Stat. 805","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcadb0841-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcadb0842-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcadb0843-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Prior sections 10101 and 10101a were omitted in the general amendment of this subtitle by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10101, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1337"},"text":"92 Stat. 1337","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/296/s4"},"text":"Pub. L. 96–296, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-01"},"text":"July 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/793"},"text":"94 Stat. 793","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/tI/s101/b"},"text":"Pub. L. 96–448, title I, § 101(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1898"},"text":"94 Stat. 1898","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/261/s5"},"text":"Pub. L. 97–261, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-20"},"text":"Sept. 20, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1103"},"text":"96 Stat. 1103","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/311/tII/s204"},"text":"Pub. L. 103–311, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-08-26"},"text":"Aug. 26, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1683"},"text":"108 Stat. 1683","children":[],"tail":", related to transportation policy. See sections 13101 and 15101 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 10101a, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448/tI/s101/a"},"text":"Pub. L. 96–448, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1897"},"text":"94 Stat. 1897","children":[],"tail":", related to rail transportation policy."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcadb0844-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcadb0845-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idcadb0846-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tVI/s601"},"text":"Pub. L. 110–432, div. A, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4900"},"text":"122 Stat. 4900","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/432/dA/tVI/s601"},"text":"“This title [enacting sections 10908 to 10910 of this title and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10501"},"text":"section 10501 of this title","children":[],"tail":"] may be cited as the ‘Clean Railroads Act of 2008’.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/291/s1"},"text":"Pub. L. 110–291, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2915"},"text":"122 Stat. 2915","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/291/s1"},"text":"“This Act [amending sections 13102, 13902, and 13905 of this title and enacting provisions set out as notes under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s13902"},"text":"section 13902 of this title","children":[],"tail":"] may be cited as the ‘Over-the-Road Bus Transportation Accessibility Act of 2007’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idcadb0847-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4201"},"text":"Pub. L. 109–59, title IV, § 4201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1751"},"text":"119 Stat. 1751","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/59/tIV/s4201"},"text":"“This subtitle [subtitle B (§§ 4201–4216) of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", enacting sections 14710, 14711, and 14915 of this title, amending sections 13102, 13707, 13902, 14104, 14501, 14706, 14708, and 14901 of this title, and enacting provisions set out as notes under sections 13102, 14701, 14706, and 14710 of this title] may be cited as the ‘Household Goods Mover Oversight Enforcement and Reform Act of 2005’[.]”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4301"},"text":"Pub. L. 109–59, title IV, § 4301","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1761"},"text":"119 Stat. 1761","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/59/tIV/s4301"},"text":"“This subtitle [subtitle C (§§ 4301–4308) of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", enacting sections 14504a and 14506 of this title, amending sections 13902, 13905, 13906, 13908, 31102, and 31103 of this title, repealing "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s14504"},"text":"section 14504 of this title","children":[],"tail":", and enacting provisions set out as notes under sections 13902 and 14504 of this title] may be cited as the ‘Unified Carrier Registration Act of 2005’.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idcadb0848-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 2002 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/298/s1"},"text":"Pub. L. 107–298, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-26"},"text":"Nov. 26, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2342"},"text":"116 Stat. 2342","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/298/s1"},"text":"“This Act [amending sections 13102, 13506, 14501, and 31138 of this title] may be cited as the ‘Real Interstate Driver Equity Act of 2002’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idcadb0849-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1986 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/99/521/s1"},"text":"Pub. L. 99–521, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2993"},"text":"100 Stat. 2993","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/99/521/s1"},"text":"“This Act [see Tables for classification] may be cited as the ‘Surface Freight Forwarder Deregulation Act of 1986’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idcadb084a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/97/261/s1"},"text":"Pub. L. 97–261, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-20"},"text":"Sept. 20, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1102"},"text":"96 Stat. 1102","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/97/261/s1"},"text":"“That this Act [see Tables for classification] may be cited as the ‘Bus Regulatory Reform Act of 1982’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitleOfAmendment","id":"idcadb084b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title of 1980 Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/454/s1"},"text":"Pub. L. 96–454, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-15"},"text":"Oct. 15, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2011"},"text":"94 Stat. 2011","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/454/s1"},"text":"“That this Act [see Tables for classification] may be cited as the ‘Household Goods Transportation Act of 1980’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/448/s1"},"text":"Pub. L. 96–448, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1895"},"text":"94 Stat. 1895","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/448/s1"},"text":"“This Act [see Tables for classification] may be cited as the ‘Staggers Rail Act of 1980’.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/96/296/s1"},"text":"Pub. L. 96–296, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-07-01"},"text":"July 1, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/793"},"text":"94 Stat. 793","children":[],"tail":", provided: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/96/296/s1"},"text":"“That this Act [see Tables for classification] may be cited as the ‘Motor Carrier Act of 1980’.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
