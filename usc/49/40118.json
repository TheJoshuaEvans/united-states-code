{"tag":"section","attrib":{"id":"idcbaf47be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118"},"text":null,"children":[{"tag":"num","attrib":{"value":"40118"},"text":"§ 40118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government-financed air transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbaf47bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation by Air Carriers Holding Certificates","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A department, agency, or instrumentality of the United States Government shall take necessary steps to ensure that the transportation of passengers and property by air is provided by an air carrier holding a certificate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":" if—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbaf47c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the department, agency, or instrumentality—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbaf47c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtains the transportation for itself or in carrying out an arrangement under which payment is made by the Government or payment is made from amounts provided for the use of the Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbaf47c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides the transportation to or for a foreign country or international or other organization without reimbursement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaf47c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transportation is authorized by the certificate or by regulation or exemption of the Secretary of Transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaf47c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the air carrier is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbaf47c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available, if the transportation is between a place in the United States and a place outside the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbaf47c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably available, if the transportation is between 2 places outside the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbaf47c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation by Foreign Air Carriers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not preclude the transportation of passengers and property by a foreign air carrier if the transportation is provided under a bilateral or multilateral air transportation agreement to which the Government and the government of a foreign country are parties if the agreement—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbaf47c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is consistent with the goals for international aviation policy of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40101/e"},"text":"section 40101(e) of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaf47c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides for the exchange of rights or benefits of similar magnitude.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbaf47ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation of Certain Domestic Animals by Foreign Air Carriers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbaf47cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not preclude the transportation of a passenger and the property of such passenger by a foreign air carrier if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbaf47cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such passenger is a member of the Armed Forces or civilian employee of the Department of Defense;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbaf47cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such property includes at least 1 and not more than 3 domestic animals traveling with such passenger;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbaf47ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" such transportation is—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbaf47cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/c/1/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between a place in the United States and a place outside the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbaf47d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/c/1/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" between 2 places outside the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbaf47d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no air carrier holding a certificate under section 41102 is willing and able to provide such transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaf47d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibility of individual to cover certain costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the cost for the transportation of a passenger and property under paragraph (1) exceeds the cost that would have been owed had such transportation been provided by an air carrier holding a certificate under section 41102, the passenger shall be responsible for paying the difference between such amounts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaf47d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Domestic animal defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “domestic animal” means a domestic cat (Felis catus) or a domestic dog (Canis familiaris).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbaf47d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Proof","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of General Services shall prescribe regulations under which agencies may allow the expenditure of an appropriation for transportation in violation of this section only when satisfactory proof is presented showing the necessity for the transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbaf47d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Transportation by Air Outside the United States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsections (a) and (d) of this section, any amount appropriated to the Secretary of State or the Administrator of the Agency for International Development may be used to pay for the transportation of an officer or employee of the Department of State or one of those agencies, a dependent of the officer or employee, and accompanying baggage, by a foreign air carrier when the transportation is between 2 places outside the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbaf47d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not affect the application of the antidiscrimination provisions of this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbaf47d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition of Certification or Contract Clause","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbaf47d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No certification by a contractor, and no contract clause, may be required in the case of a contract for the transportation of commercial products in order to implement a requirement in this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaf47d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In paragraph (1), the term “commercial product” has the meaning given such term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s103"},"text":"section 103 of title 41","children":[],"tail":", except that it shall not include a contract for the transportation by air of passengers."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbaf47da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator of General Services shall ensure that any contract entered into for provision of air transportation with a domestic carrier under this section requires that the contracting air carrier submits to the Administrator of General Services, the Secretary of Transportation, the Administrator of the Transportation Security Administration, the Secretary of Labor and the Commissioner of U.S. Customs and Border Protection an annual report regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbaf47db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of personnel trained in the detection and reporting of potential severe forms of trafficking in persons and sex trafficking (as such terms are defined in paragraphs (11) and (12) of section 103 of the Trafficking Victims Protection Act of 2000 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t22/s7102"},"text":"22 U.S.C. 7102","children":[],"tail":")), including the training required under section 44734(a)(4);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaf47dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of notifications of potential human trafficking victims received from staff or other passengers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaf47dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40118/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the air carrier notified the National Human Trafficking Hotline or law enforcement at the relevant airport of the potential human trafficking victim for each such notification of potential human trafficking, and if so, when the notification was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbaf47de-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1116"},"text":"108 Stat. 1116","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/355/tVIII/s8301/h"},"text":"Pub. L. 103–355, title VIII, § 8301(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-13"},"text":"Oct. 13, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/3398"},"text":"108 Stat. 3398","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/68"},"text":"Pub. L. 104–287, § 5(68)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3395"},"text":"110 Stat. 3395","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s127/d"},"text":"Pub. L. 104–316, title I, § 127(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3840"},"text":"110 Stat. 3840","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dG"},"text":"Pub. L. 105–277, div. G","children":[],"tail":", subdiv. A, title XII, § 1225(h), title XIII, § 1335(p), title XIV, § 1422(b)(6), "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "