{"tag":"section","attrib":{"id":"idcb11f5ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20138"},"text":null,"children":[{"tag":"num","attrib":{"value":"20138"},"text":"§ 20138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tampering with safety and operational monitoring devices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb11f5ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20138/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall prescribe regulations and issue orders to prohibit the willful tampering with, or disabling of, any specified railroad safety or operational monitoring device.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb11f5ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20138/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb11f5ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20138/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A railroad carrier operating a train on which a safety or operational monitoring device is tampered with or disabled in violation of a regulation prescribed or order issued under subsection (a) of this section is liable to the United States Government for a civil penalty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s21301"},"text":"section 21301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb11f5f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20138/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual tampering with or disabling a safety or operational monitoring device in violation of a regulation prescribed or order issued under subsection (a) of this section, or knowingly operating or allowing to be operated a train on which such a device has been tampered with or disabled, is liable for penalties established by the Secretary. The penalties may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb11f5f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20138/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a civil penalty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s21301"},"text":"section 21301 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb11f5f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20138/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension from work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb11f5f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20138/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" suspension or loss of a license or certification issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20135"},"text":"section 20135 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb11f5f4-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/876"},"text":"108 Stat. 876","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb11f5f5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb11f5f6-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb11f5f7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text"