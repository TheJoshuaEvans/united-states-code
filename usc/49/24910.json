{"tag":"section","attrib":{"id":"idcb3cd773-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910"},"text":null,"children":[{"tag":"num","attrib":{"value":"24910"},"text":"§ 24910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rail cooperative research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb3cd774-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall establish and carry out a rail cooperative research program. The program shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3cd775-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address, among other matters, intercity rail passenger and freight rail services, including existing rail passenger and freight technologies and speeds, incrementally enhanced rail systems and infrastructure, and new high-speed wheel-on-rail systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd776-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" address ways to expand the transportation of international trade traffic by rail, enhance the efficiency of intermodal interchange at ports and other intermodal terminals, and increase capacity and availability of rail service for seasonal freight needs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd777-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider research on the interconnectedness of commuter rail, passenger rail, freight rail, and other rail networks; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd778-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give consideration to regional concerns regarding rail passenger and freight transportation, including meeting research needs common to designated high-speed corridors, long-distance rail services, and regional intercity rail corridors, projects, and entities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3cd779-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Content","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The program to be carried out under this section shall include research designed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3cd77a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to identify the unique aspects and attributes of rail passenger and freight service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd77b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop more accurate models for evaluating the impact of rail passenger and freight service, including the effects on highway and airport and airway congestion, environmental quality, and energy consumption;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd77c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to develop a better understanding of modal choice as it affects rail passenger and freight transportation, including development of better models to predict utilization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd77d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recommend priorities for technology demonstration and development;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd77e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to meet additional priorities as determined by the advisory board established under subsection (c), including any recommendations made by the National Research Council;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd77f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to explore improvements in management, financing, and institutional structures;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd780-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to address rail capacity constraints that affect passenger and freight rail service through a wide variety of options, ranging from operating improvements to dedicated new infrastructure, taking into account the impact of such options on operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd781-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve maintenance, operations, customer service, or other aspects of intercity rail passenger and freight service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd782-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recommend objective methodologies for determining intercity passenger rail routes and services, including the establishment of new routes, the elimination of existing routes, and the contraction or expansion of services or frequencies over such routes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd783-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review the impact of equipment and operational safety standards on the further development of high-speed passenger rail operations connected to or integrated with non-high-speed freight or passenger rail operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd784-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recommend any legislative or regulatory changes necessary to foster further development and implementation of high-speed passenger rail operations while ensuring the safety of such operations that are connected to or integrated with non-high-speed freight or passenger rail operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd785-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review rail crossing safety improvements, including improvements using new safety technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd786-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to review and develop technology designed to reduce train horn noise and its effect on communities, including broadband horn technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd787-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/b/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to improve overall safety of intercity passenger and freight rail operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3cd788-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory Board.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3cd789-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In consultation with the heads of appropriate Federal departments and agencies, the Secretary shall establish an advisory board to recommend research, technology, and technology transfer activities related to rail passenger and freight transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd78a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The advisory board shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb3cd78b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of State transportation agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3cd78c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transportation and environmental economists, scientists, and engineers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3cd78d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" representatives of Amtrak, the Alaska Railroad, freight railroads, transit operating agencies, intercity rail passenger agencies, railway labor organizations, and environmental organizations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3cd78e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The advisory board established under this subsection ceases to exist effective ","children":[{"tag":"date","attrib":{"date":"2019-01-01"},"text":"January 1, 2019","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3cd78f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Academy of Sciences","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make grants to, and enter into cooperative agreements with, the National Academy of Sciences to carry out such activities relating to the research, technology, and technology transfer activities described in subsection (b) as the Secretary deems appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3cd790-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24910/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Transportation $5,000,000 for each of fiscal years 2010 through 2013 for carrying out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb3cd791-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tIII/s306/a"},"text":"Pub. L. 110–432, div. B, title III, § 306(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4952"},"text":"122 Stat. 4952","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11316"},"text":"Pub. L. 114–94, div. A, title XI, § 11316","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1679"},"text":"129 Stat. 1679","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/420/s6/b"},"text":"Pub. L. 115–420, § 6(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-03"},"text":"Jan. 3, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5445"},"text":"132 Stat. 5445","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb3cd792-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb3cd793-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb3cd794-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/420"},"text":"Pub. L. 115–420","children":[],"tail":" added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (b)(14). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" added par. (14)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb3cd795-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb3cd796-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
