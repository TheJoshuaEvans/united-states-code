{"tag":"section","attrib":{"id":"idcad3dcbe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103"},"text":null,"children":[{"tag":"num","attrib":{"value":"6103"},"text":"§ 6103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minimum standards for State one-call notification programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad3dcbf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Standards.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad3dcc0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In order to qualify for a grant under section 6106, a State one-call notification program, at a minimum, shall provide for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad3dcc1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate participation by all underground facility operators, including all government operators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad3dcc2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate participation by all excavators, including all government and contract excavators; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad3dcc3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flexible and effective enforcement under State law with respect to participation in, and use of, one-call notification systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dcc4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemptions prohibited","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In order to qualify for a grant under section 6106, a State one-call notification program may not exempt municipalities, State agencies, or their contractors from the one-call notification system requirements of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad3dcc5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appropriate Participation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the appropriate extent of participation required for types of underground facilities or excavators under subsection (a), a State shall assess, rank, and take into consideration the risks to the public safety, the environment, excavators, and vital public services associated with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad3dcc6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" damage to types of underground facilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dcc7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" activities of types of excavators.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad3dcc8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A State one-call notification program also shall, at a minimum, provide for and document—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad3dcc9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consideration of the ranking of risks under subsection (b) in the enforcement of its provisions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dcca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable relationship between the benefits of one-call notification and the cost of implementing and complying with the requirements of the State one-call notification program; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dccb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" voluntary participation where the State determines that a type of underground facility or an activity of a type of excavator poses a de minimis risk to public safety or the environment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad3dccc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To the extent the State determines appropriate and necessary to achieve the purposes of this chapter, a State one-call notification program shall, at a minimum, provide for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad3dccd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" administrative or civil penalties commensurate with the seriousness of a violation by an excavator or facility owner of a State one-call notification program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dcce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increased penalties for parties that repeatedly damage underground facilities because they fail to use one-call notification systems or for parties that repeatedly fail to provide timely and accurate marking after the required call has been made to a one-call notification system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dccf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduced or waived penalties for a violation of a requirement of a State one-call notification program that results in, or could result in, damage that is promptly reported by the violator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dcd0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" equitable relief; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad3dcd1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6103/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" citation of violations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad3dcd2-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tVII/s7302/a"},"text":"Pub. L. 105–178, title VII, § 7302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/479"},"text":"112 Stat. 479","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/355/s2/a"},"text":"Pub. L. 107–355, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2985"},"text":"116 Stat. 2985","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/90/s3/a"},"text":"Pub. L. 112–90, § 3(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1906"},"text":"125 Stat. 1906","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad3dcd3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad3dcd4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcad3dcd5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90/s3/a"},"text":"Pub. L. 112–90, § 3(a)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, text read as follows: “In order to qualify for a grant under section 6106, a State one-call notification program shall, at a minimum, provide for—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) appropriate participation by all underground facility operators, including all government operators;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) appropriate participation by all excavators, including all government and contract excavators; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) flexible and effective enforcement under State law with respect to participation in, and use of, one-call notification systems.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s2/a/1/A"},"text":"Pub. L. 107–355, § 2(a)(1)(A)","children":[],"tail":", inserted “, including all government operators” before semicolon at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s2/a/1/B"},"text":"Pub. L. 107–355, § 2(a)(1)(B)","children":[],"tail":", inserted “, including all government and contract excavators” before semicolon."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s2/a/2"},"text":"Pub. L. 107–355, § 2(a)(2)","children":[],"tail":", substituted “provide for and document” for “provide for” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcad3dcd6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcad3dcd7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90/s3/c"},"text":"Pub. L. 112–90, § 3(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1906"},"text":"125 Stat. 1906","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/90/s3/c"},"text":"“The amendments made by this section [amending this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s60134"},"text":"section 60134 of this title","children":[],"tail":"] shall take effect 2 years after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
