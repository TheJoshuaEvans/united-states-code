{"tag":"section","attrib":{"id":"idcc66d878-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524"},"text":null,"children":[{"tag":"num","attrib":{"value":"47524"},"text":"§ 47524.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Airport noise and access restriction review program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc66d879-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The national aviation noise policy established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47523"},"text":"section 47523 of this title","children":[],"tail":" shall provide for establishing by regulation a national program for reviewing airport noise and access restrictions on the operation of stage 2 and stage 3 aircraft. The program shall provide for adequate public notice and opportunity for comment on the restrictions."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc66d87a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stage","children":[],"tail":" 2 "},{"tag":"inline","attrib":{},"text":"Aircraft","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in subsection (d) of this section, an airport noise or access restriction may include a restriction on the operation of stage 2 aircraft proposed after ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", only if the airport operator publishes the proposed restriction and prepares and makes available for public comment at least 180 days before the effective date of the proposed restriction—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc66d87b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an analysis of the anticipated or actual costs and benefits of the existing or proposed restriction;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc66d87c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of alternative restrictions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc66d87d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the alternative measures considered that do not involve aircraft restrictions; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc66d87e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a comparison of the costs and benefits of the alternative measures to the costs and benefits of the proposed restriction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc66d87f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Stage","children":[],"tail":" 3 "},{"tag":"inline","attrib":{},"text":"Aircraft","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc66d880-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in subsection (d) of this section, an airport noise or access restriction on the operation of stage 3 aircraft not in effect on ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", may become effective only if the restriction has been agreed to by the airport proprietor and all aircraft operators or has been submitted to and approved by the Secretary of Transportation after an airport or aircraft operator’s request for approval as provided by the program established under this section. Restrictions to which this paragraph applies include—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc66d881-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a restriction on noise levels generated on either a single event or cumulative basis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc66d882-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a restriction on the total number of stage 3 aircraft operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc66d883-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a noise budget or noise allocation program that would include stage 3 aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc66d884-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a restriction on hours of operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc66d885-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other restriction on stage 3 aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc66d886-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Not later than 180 days after the Secretary receives an airport or aircraft operator’s request for approval of an airport noise or access restriction on the operation of a stage 3 aircraft, the Secretary shall approve or disapprove the restriction. The Secretary may approve the restriction only if the Secretary finds on the basis of substantial evidence that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc66d887-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restriction is reasonable, nonarbitrary, and nondiscriminatory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc66d888-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restriction does not create an unreasonable burden on interstate or foreign commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc66d889-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restriction is not inconsistent with maintaining the safe and efficient use of the navigable airspace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc66d88a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restriction does not conflict with a law or regulation of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc66d88b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an adequate opportunity has been provided for public comment on the restriction; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc66d88c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the restriction does not create an unreasonable burden on the national aviation system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc66d88d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Paragraphs (1) and (2) of this subsection do not apply if the Administrator of the Federal Aviation Administration, before ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":", has formed a working group (outside the process established by part 150 of title 14, Code of Federal Regulations) with a local airport operator to examine the noise impact of air traffic control procedure changes at the airport. However, if an agreement on noise reductions at that airport is made between the airport proprietor and one or more air carriers or foreign air carriers that constitute a majority of the carrier use of the airport, this paragraph applies only to a local action to enforce the agreement."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc66d88e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may reevaluate an airport noise or access restriction previously agreed to or approved under this subsection on request of an aircraft operator able to demonstrate to the satisfaction of the Secretary that there has been a change in the noise environment of the affected airport that justifies a reevaluation. The Secretary shall establish by regulation procedures for conducting a reevaluation. A reevaluation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc69488f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be based on the criteria in paragraph (2) of this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc694890-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be conducted only after 2 years after a decision under paragraph (2) of this subsection has been made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc694891-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsections (b) and (c) of this section do not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc694892-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local action to enforce a negotiated or executed airport noise or access agreement between the airport operator and the aircraft operators in effect on ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694893-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local action to enforce a negotiated or executed airport noise or access restriction agreed to by the airport operator and the aircraft operators before ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694894-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an intergovernmental agreement including an airport noise or access restriction in effect on ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694895-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a subsequent amendment to an airport noise or access agreement or restriction in effect on ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":", that does not reduce or limit aircraft operations or affect aircraft safety;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694896-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc694897-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an airport noise or access restriction adopted by an airport operator not later than ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", and stayed as of "},{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", by a court order or as a result of litigation, if any part of the restriction is subsequently allowed by a court to take effect; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc694898-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a new restriction imposed by an airport operator to replace any part of a restriction described in subclause (A) of this clause that is disallowed by a court, if the new restriction would not prohibit aircraft operations in effect on ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc694899-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a local action that represents the adoption of the final part of a program of a staged airport noise or access restriction if the initial part of the program was adopted during 1988 and was in effect on ","children":[{"tag":"date","attrib":{"date":"1990-11-05"},"text":"November 5, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc69489a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning on the 91st day after the Secretary prescribes a regulation under subsection (a) of this section, a sponsor of a facility operating under an airport noise or access restriction on the operation of stage 3 aircraft that first became effective after ","children":[{"tag":"date","attrib":{"date":"1990-10-01"},"text":"October 1, 1990","children":[],"tail":", is eligible for a grant under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s47104"},"text":"section 47104 of this title","children":[],"tail":" and is eligible to impose a passenger facility charge under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40117"},"text":"section 40117 of this title","children":[],"tail":" only if the restriction has been—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc69489b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agreed to by the airport proprietor and aircraft operators;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc69489c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" approved by the Secretary as required by subsection (c)(1) of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc69489d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47524/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rescinded.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc69489e-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1288"},"text":"108 Stat. 1288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tI/s111/c/2/A/vii"},"text":"Pub. L. 112–95, title I, § 111(c)(2)(A)(vii)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},