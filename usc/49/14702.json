{"tag":"section","attrib":{"id":"idcb012dea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14702"},"text":null,"children":[{"tag":"num","attrib":{"value":"14702"},"text":"§ 14702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by the regulatory authority","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb012deb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary or the Board, as applicable, may bring a civil action—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb012dec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enforce ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s14103"},"text":"section 14103 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb012ded-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enforce this part, or a regulation or order of the Secretary or Board, as applicable, when violated by a carrier or broker providing transportation or service subject to jurisdiction under subchapter I or III of chapter 135 of this title or by a foreign motor carrier or foreign motor private carrier providing transportation registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s13902"},"text":"section 13902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb012dee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a civil action under subsection (a)(2) of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb012def-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14702/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" trial is in the judicial district in which the carrier, foreign motor carrier, foreign motor private carrier, or broker operates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb012df0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14702/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" process may be served without regard to the territorial limits of the district or of the State in which the action is instituted; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb012df1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14702/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person participating with a carrier or broker in a violation may be joined in the civil action without regard to the residence of the person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb012df2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s14702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":