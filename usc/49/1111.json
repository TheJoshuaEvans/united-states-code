{"tag":"section","attrib":{"id":"idca7938d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111"},"text":null,"children":[{"tag":"num","attrib":{"value":"1111"},"text":"§ 1111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General organization","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca7938d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Organization","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Transportation Safety Board is an independent establishment of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7938d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appointment of Members","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board is composed of 5 members appointed by the President, by and with the advice and consent of the Senate. Not more than 3 members may be appointed from the same political party. At least 3 members shall be appointed on the basis of technical qualification, professional standing, and demonstrated knowledge in accident reconstruction, safety engineering, human factors, transportation safety, or transportation regulation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7938d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms of Office and Removal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term of office of each member is 5 years. An individual appointed to fill a vacancy occurring before the expiration of the term for which the predecessor of that individual was appointed, is appointed for the remainder of that term. When the term of office of a member ends, the member may continue to serve until a successor is appointed and qualified. The President may remove a member for inefficiency, neglect of duty, or malfeasance in office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7938d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chairman and Vice Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The President shall designate, by and with the advice and consent of the Senate, a Chairman of the Board. The President also shall designate a Vice Chairman of the Board. The terms of office of both the Chairman and Vice Chairman are 3 years. When the Chairman is absent or unable to serve or when the position of Chairman is vacant, the Vice Chairman acts as Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7938d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties and Powers of Chairman","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chairman is the chief executive and administrative officer of the Board. Subject to the general policies and decisions of the Board, the Chairman shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7938d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appoint and supervise officers and employees, other than regular and full-time employees in the immediate offices of another member, necessary to carry out this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7938d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fix the pay of officers and employees necessary to carry out this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7938d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" distribute business among the officers, employees, and administrative units of the Board; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7938da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supervise the expenditures of the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7938db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Quorum","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Three members of the Board are a quorum in carrying out duties and powers of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7938dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Offices, Bureaus, and Divisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall establish offices necessary to carry out this chapter, including an office to investigate and report on the safe transportation of hazardous material. The Board shall establish distinct and appropriately staffed bureaus, divisions, or offices to investigate and report on accidents involving each of the following modes of transportation:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7938dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aviation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7ba9de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" highway and motor vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7ba9df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" rail and tracked vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7ba9e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pipeline.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7ba9e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" marine.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7ba9e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chief Financial Officer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chairman shall designate an officer or employee of the Board as the Chief Financial Officer. The Chief Financial Officer shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7ba9e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report directly to the Chairman on financial management and budget execution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7ba9e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct, manage, and provide policy guidance and oversight on financial management and property and inventory control; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7ba9e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the fees, rents, and other charges imposed by the Board for services and things of value it provides, and suggest appropriate revisions to those charges to reflect costs incurred by the Board in providing those services and things of value.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7ba9e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Board Member Staff","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Board shall select and supervise regular and full-time employees in his or her immediate office as long as any such employee has been approved for employment by the designated agency ethics official under the same guidelines that apply to all employees of the Board. Except for the Chairman, the appointment authority provided by this subsection is limited to the number of full-time equivalent positions, in addition to 1 senior professional staff at a level not to exceed the GS 15 level and 1 administrative staff, allocated to each member through the Board’s annual budget and allocation process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7ba9e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Seal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall have a seal that shall be judicially recognized.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7ba9e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Open Meetings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7ba9e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board shall be deemed to be an agency for purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7ba9ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonpublic collaborative discussions.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7ba9eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":", a majority of the members may hold a meeting that is not open to public observation to discuss official agency business if—"}],"tail":null},{"tag":"clause","attrib":{"id":"idca7ba9ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no formal or informal vote or other official agency action is taken at the meeting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca7ba9ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each individual present at the meeting is a member or an employee of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca7ba9ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 1 member of the Board from each political party is present at the meeting, if applicable; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca7ba9ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the General Counsel of the Board is present at the meeting.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7ba9f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure of nonpublic collaborative discussions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided under subparagraphs (C) and (D), not later than 2 business days after the conclusion of a meeting under subparagraph (A), the Board shall make available to the public, in a place easily accessible to the public—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca7ba9f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a list of the individuals present at the meeting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca7ba9f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the matters, including key issues, discussed at the meeting, except for any matter the Board properly determines may be withheld from the public under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b/c"},"text":"section 552b(c) of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7ba9f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Summary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Board properly determines a matter may be withheld from the public under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b/c"},"text":"section 552b(c) of title 5","children":[],"tail":", the Board shall provide a summary with as much general information as possible on each matter withheld from the public."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7ba9f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Active investigations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a discussion under subparagraph (A) directly relates to an active investigation, the Board shall make the disclosure under subparagraph (B) on the date the Board adopts the final report.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7ba9f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preservation of open meetings requirements for agency action","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this paragraph may be construed to limit the applicability of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":" with respect to a meeting of the members other than that described in this paragraph."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7ba9f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statutory construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this paragraph may be construed—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idca7ba9f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/F/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to limit the applicability of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552b"},"text":"section 552b of title 5","children":[],"tail":" with respect to any information which is proposed to be withheld from the public under subparagraph (B)(ii); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca7ba9f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1111/k/2/F/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to authorize the Board to withhold from any individual any record that is accessible to that individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"section 552a of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca7ba9f9-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/746"},"text":"108 Stat. 746","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/424/s10"},"text":"Pub. L. 106–424, § 10","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1886"},"text":"114 Stat. 1886","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/443/s9/a"},"text":"Pub. L. 109–443, § 9(a)","children":[],"tail":", (d), "},{"tag":"date","attrib":{"date":"2006-12-21"},"text":"Dec. 21, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3301"},"text":"120 Stat. 3301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dC/s1112/a"},"text":"Pub. L. 115–254, div. C, § 1112(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3436"},"text":"132 Stat. 3436","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca7ba9fa-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca7ba9fb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca7ba9fc-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}