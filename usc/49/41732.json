{"tag":"section","attrib":{"id":"idcbcbd060-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41732"},"text":null,"children":[{"tag":"num","attrib":{"value":"41732"},"text":"§ 41732.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Basic essential air service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbcbd061-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41732/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Basic essential air service provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41733"},"text":"section 41733 of this title","children":[],"tail":" is scheduled air transportation of passengers and cargo—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbcbd062-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41732/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a medium or large hub airport less than 650 miles from an eligible place (unless such airport or eligible place are located in a noncontiguous State); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbcbd063-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41732/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a small hub or nonhub airport, when in Alaska or when the nearest medium or large hub airport is more than 400 miles from an eligible place.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbcbd064-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41732/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Basic essential air service shall include at least the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbcbd065-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41732/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbcbd066-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41732/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a place not in Alaska, 2 daily round trips 6 days a week, with not more than one intermediate stop on each flight; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbcbd067-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41732/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a place in Alaska, a level of service at least equal to that provided in 1976 or 2 round trips a week, whichever is greater, except that the Secretary of Transportation and the appropriate State authority of Alaska may agree to a different level of service after consulting with the affected community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbcbd068-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41732/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" flights at reasonable times considering the needs of passengers with connecting flights at the airport and at prices that are not excessive compared to the generally prevailing prices of other air carriers for like service between similar places.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbcbd069-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41732/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" service provided in aircraft with at least 2 engines and using 2 pilots, unless scheduled air transportation has not been provided to the place in aircraft with at least 2 engines and using 2 pilots for at least 60 consecutive operating days at any time since ","children":[{"tag":"date","attrib":{"date":"1978-10-31"},"text":"October 31, 1978","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbcbd06a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41732/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waivers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 41733(e), upon request by an eligible place, the Secretary may waive, in whole or in part, subsections (a) and (b) of this section or subsections (a) through (c) of section 41734. A waiver issued under this subsection shall remain in effect for a limited period of time, as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbcbd06b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1144"},"text":"108 Stat. 1144","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIV/s456"},"text":"Pub. L. 115–254, div. B, title IV, § 456","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3350"},"text":"132 Stat. 3350","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tV/s561/b/1"},"text":"Pub. L. 118–63, title V, § 561(b)(1)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1214"},"text":"138 Stat. 1214","children":[],"tail":", 1215.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbcbd06c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbcbd06d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbcbd06e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41732(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1389(k)(1) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 419(k)(1); added "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/504/s33/a"},"text":"Pub. L. 95–504, § 33(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1732"},"text":"92 Stat. 1732","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Dec. 8, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/213/s10"},"text":"Pub. L. 98–213, § 10","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/97/1461"},"text":"97 Stat. 1461","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s9/r"},"text":"Pub. L. 98–443, § 9(r)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1708"},"text":"98 Stat. 1708","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/223/s202/a/1"},"text":"Pub. L. 100–223, § 202(a)(1)","children":[],"tail":", (2), (b)(1), "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1507"},"text":"101 Stat. 1507","children":[],"tail":", 1516."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41732(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1389(k)(1) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “provided under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41733"},"text":"section 41733 of this title","children":[],"tail":"” are added for clarity. In clause (2), the words “from an eligible place” are added for clarity."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “Basic essential air service” are substituted for “Such transportation” for clarity and consistency in the revised title. In clause (1)(B), the word “1976” is substituted for “calendar year 1976” to eliminate unnecessary words. The words “appropriate State authority of Alaska” are substituted for “State agency of the State of Alaska” for clarity and consistency with the source provisions restated in section 41734(a) of the revised title. The words “agree to a different level of service” are substituted for “otherwise specified under an agreement” for clarity. In clause (2), the word “prices” is substituted for “rates, fares, and charges” and “fares” because of the definition of “price” in section 40102(a) of the revised title. In clause (3), before subclause (A), the word “boardings” is substituted for “enplanements” for clarity and consistency in the revised title. The words “from 1976-1986” are substituted for “beginning after ","children":[{"tag":"date","attrib":{"date":"1975-12-31"},"text":"December 31, 1975","children":[],"tail":", and ending on or before "},{"tag":"date","attrib":{"date":"1986-12-31"},"text":"December 31, 1986","children":[],"tail":"” to eliminate unnecessary words. In subclause (B), the words “affected community” are substituted for “community concerned” for consistency with the source provisions restated in clause (1)(B) of this section. In clause (5), the words “for at least 60 consecutive operating days” are substituted for “on each of 60 consecutive operating days” for clarity."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbcbd06f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbcbd070-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s561/b/1"},"text":"Pub. L. 118–63, § 561(b)(1)","children":[],"tail":", amended par. (1) generally. Prior to amendment, par. (1) read as follows: “to a hub airport that has convenient connecting or single-plane air service to a substantial number of destinations beyond that airport; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s561/c/1"},"text":"Pub. L. 118–63, § 561(c)(1)","children":[],"tail":", inserted “medium or large” after “nearest”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s561/c/2"},"text":"Pub. L. 118–63, § 561(c)(2)","children":[],"tail":", redesignated par. (5) as (3) and struck out former pars. (3), (4), and (6) which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) for a place not in Alaska, service provided in an aircraft with an effective capacity of at least 15 passengers if the average daily boardings at the place in any calendar year from 1976-1986 were more than 11 passengers unless—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) that level-of-service requirement would require paying compensation in a fiscal year under section 41733(d) or 41734(d) or (e) of this title for the place when compensation otherwise would not have been paid for that place in that year; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) the affected community agrees with the Secretary in writing to the use of smaller aircraft to provide service to the place.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(4) service accommodating the estimated passenger and property traffic at an average load factor, for each class of traffic considering seasonal demands for the service, of not more than—","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) 50 percent; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) 60 percent when service is provided by aircraft with more than 14 passenger seats.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(6) service provided by pressurized aircraft when the service is provided by aircraft that regularly fly above 8,000 feet in altitude.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbcbd071-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbcbd072-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Restriction on Length of Routes","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tV/s561/b/2"},"text":"Pub. L. 118–63, title V, § 561(b)(2)","children":[],"tail":", (3), "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1215"},"text":"138 Stat. 1215","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tV/s561/b/2"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendment made by paragraph (1) [amending this section] shall not apply to an eligible place that is served by an air carrier selected to receive essential air service compensation under subchapter II of chapter 417 of title 49, United States Code, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such service is in effect upon the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"]; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such service is provided by the same air carrier that provided service on the date of enactment of this Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (2) shall cease to have effect on ","children":[{"tag":"date","attrib":{"date":"2028-10-01"},"text":"October 1, 2028","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
