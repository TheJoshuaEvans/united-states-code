{"tag":"section","attrib":{"id":"idcbd56ce3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301"},"text":null,"children":[{"tag":"num","attrib":{"value":"42301"},"text":"§ 42301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Emergency contingency plans","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd56ce4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Air Carrier and Airport Plans","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 90 days after the date of enactment of this section, each of the following air carriers and airport operators shall submit to the Secretary of Transportation for review and approval an emergency contingency plan in accordance with the requirements of this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56ce5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An air carrier providing covered air transportation at a commercial airport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56ce6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An operator of a commercial airport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56ce7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An operator of an airport used by an air carrier described in paragraph (1) for diversions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56ce8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air Carrier Plans.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56ce9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plans for individual airports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An air carrier shall submit an emergency contingency plan under subsection (a) for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd56cea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each airport at which the carrier provides covered air transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd56ceb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each airport at which the carrier has flights for which the carrier has primary responsibility for inventory control.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56cec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An emergency contingency plan submitted by an air carrier for an airport under subsection (a) shall contain a description of how the carrier will—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd56ced-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide adequate food, potable water, restroom facilities, comfortable cabin temperatures, and access to medical treatment for passengers onboard an aircraft at the airport when the departure of a flight is delayed or the disembarkation of passengers is delayed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd56cee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" share facilities and make gates available at the airport in an emergency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd56cef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow passengers to deplane following an excessive tarmac delay in accordance with paragraph (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56cf0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deplaning following an excessive tarmac delay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of paragraph (2)(C), an emergency contingency plan submitted by an air carrier under subsection (a) shall incorporate the following requirements:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd56cf1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A passenger shall have the option to deplane an aircraft and return to the airport terminal when there is an excessive tarmac delay.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd56cf2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The option described in subparagraph (A) shall be offered to a passenger even if a flight in covered air transportation is diverted to a commercial airport other than the originally scheduled airport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd56cf3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In providing the option described in subparagraph (A), the air carrier shall begin to return the aircraft to a suitable disembarkation point—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbd56cf4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a flight in interstate air transportation, not later than 3 hours after the main aircraft door is closed in preparation for departure; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbd56cf5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a flight in foreign air transportation, not later than 4 hours after the main aircraft door is closed in preparation for departure.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd56cf6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding the requirements described in subparagraphs (A), (B), and (C), a passenger shall not have an option to deplane an aircraft and return to the airport terminal in the case of an excessive tarmac delay if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbd56cf7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/3/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an air traffic controller with authority over the aircraft advises the pilot in command that permitting a passenger to deplane would significantly disrupt airport operations; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbd56cf8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/b/3/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the pilot in command determines that permitting a passenger to deplane would jeopardize passenger safety or security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56cf9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Airport Plans","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An emergency contingency plan submitted by an airport operator under subsection (a) shall contain a description of how the operator, to the maximum extent practicable, will—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56cfa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the deplanement of passengers following excessive tarmac delays;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56cfb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for the sharing of facilities and make gates available at the airport in an emergency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56cfc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a sterile area following excessive tarmac delays for passengers who have not yet cleared United States Customs and Border Protection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56cfd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Updates.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56cfe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air carriers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier shall update each emergency contingency plan submitted by the carrier under subsection (a) every 3 years and submit the update to the Secretary for review and approval.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56cff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Airports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An airport operator shall update each emergency contingency plan submitted by the operator under subsection (a) every 5 years and submit the update to the Secretary for review and approval.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d00-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Approval.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d01-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 60 days after the date of the receipt of an emergency contingency plan submitted under subsection (a) or an update submitted under subsection (d), the Secretary shall review and approve or, if necessary, require modifications to the plan or update to ensure that the plan or update will effectively address emergencies and provide for the health and safety of passengers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d02-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Failure to approve or require modifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary fails to approve or require modifications to a plan or update under paragraph (1) within the timeframe specified in that paragraph, the plan or update shall be deemed to be approved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d03-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adherence required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier or airport operator shall adhere to an emergency contingency plan of the carrier or operator approved under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d04-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish, as necessary or desirable, minimum standards for elements in an emergency contingency plan required to be submitted under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d05-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Access","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier or airport operator required to submit an emergency contingency plan under this section shall ensure public access to the plan after its approval under this section on the Internet Web site of the carrier or operator or by such other means as determined by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d06-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after any flight experiences an excessive tarmac delay, the air carrier responsible for such flight shall submit a written description of the incident and its resolution to the Aviation Consumer Protection Division of the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d08-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commercial airport","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “commercial airport” means a large hub, medium hub, small hub, or nonhub airport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d09-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered air transportation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “covered air transportation” means scheduled or public charter passenger air transportation provided by an air carrier that operates an aircraft that as originally designed has a passenger capacity of 30 or more seats.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d0a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tarmac delay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “tarmac delay” means the period during which passengers are on board an aircraft on the tarmac—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd56d0b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awaiting takeoff after the aircraft doors have been closed or after passengers have been boarded if the passengers have not been advised they are free to deplane; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd56d0c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" awaiting deplaning after the aircraft has landed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d0d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/i/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excessive tarmac delay","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “excessive tarmac delay” means a tarmac delay of more than—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd56d0e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/i/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 3 hours for a flight in interstate air transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd56d0f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42301/i/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 4 hours for a flight in foreign air transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd56d10-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIV/s415/a"},"text":"Pub. L. 112–95, title IV, § 415(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/93"},"text":"126 Stat. 93","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/190/tII/s2308/a"},"text":"Pub. L. 114–190, title II, § 2308(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/648"},"text":"130 Stat. 648","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd56d11-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbd56d12-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbd56d13-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbd56d14-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (b)(3)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/s2308/a/2"},"text":"Pub. L. 114–190, § 2308(a)(2)","children":[],"tail":", added subpar. (C). Former subpar. (C) redesignated (D)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/s2308/a/1"},"text":"Pub. L. 114–190, § 2308(a)(1)","children":[],"tail":", (3), redesignated subpar. (C) as (D) and substituted “subparagraphs (A), (B), and (C)” for “subparagraphs (A) and (B)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/s2308/b"},"text":"Pub. L. 114–190, § 2308(b)","children":[],"tail":", amended par. (4) generally. Prior to amendment, text read as follows: “The term ‘excessive tarmac delay’ means a tarmac delay that lasts for a length of time, as determined by the Secretary.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbd56d15-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcbd56d16-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIV/s415/c"},"text":"Pub. L. 112–95, title IV, § 415(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/96"},"text":"126 Stat. 96","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/95/tIV/s415/c"},"text":"“Except as otherwise provided, the requirements of chapter 423 of title 49, United States Code, as added by this section, shall begin to apply 60 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbd56d17-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/tII/s2308/c"},"text":"Pub. L. 114–190, title II, § 2308(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/648"},"text":"130 Stat. 648","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/190/tII/s2308/c"},"text":"“Not later than 90 days after the date of enactment of this section [","children":[{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":"], the Secretary of Transportation shall issue regulations and take other actions necessary to carry out the amendments made by this section [amending this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
