{"tag":"section","attrib":{"id":"idca912d90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118"},"text":null,"children":[{"tag":"num","attrib":{"value":"5118"},"text":"§ 5118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hazardous material technical assessment, research and development, and analysis program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca912d91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Risk Reduction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca912d92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program authorized","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may develop and implement a hazardous material technical assessment, research and development, and analysis program for the purpose of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca912d93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing the risks associated with the transportation of hazardous material; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca912d94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying and evaluating new technologies to facilitate the safe, secure, and efficient transportation of hazardous material.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca912d95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Coordination","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the program under paragraph (1), the Secretary shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca912d96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" utilize information gathered from other modal administrations with similar programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca912d97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with other modal administrations, as appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca912d98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate, as appropriate, with other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca912d99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out subsection (a), the Secretary shall work cooperatively with regulated and other entities, including shippers, carriers, emergency responders, State and local officials, and academic institutions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca912d9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative Research.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca912d9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"As part of the program established under subsection (a), the Secretary may carry out cooperative research on hazardous materials transport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca912d9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National academies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may enter into an agreement with the National Academies to support research described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca912d9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Research conducted under this subsection may include activities relating to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca912d9e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency planning and response, including information and programs that can be readily assessed and implemented in local jurisdictions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca912d9f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" risk analysis and perception and data assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca912da0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" commodity flow data, including voluntary collaboration between shippers and first responders for secure data exchange of critical information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca912da1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/c/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integration of safety and security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca912da2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/c/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cargo packaging and handling;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca912da3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/c/3/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hazmat release consequences; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca912da4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5118/c/3/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" materials and equipment testing.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca912da5-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tIII/s33007/a"},"text":"Pub. L. 112–141, div. C, title III, § 33007(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/835"},"text":"126 Stat. 835","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVI/s6014"},"text":"Pub. L. 114–94, div. A, title VI, § 6014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1570"},"text":"129 Stat. 1570","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca912da6-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca912da7-47c4-11f1-9671-b5c72521