{"tag":"section","attrib":{"id":"idcc3bf724-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46303"},"text":null,"children":[{"tag":"num","attrib":{"value":"46303"},"text":"§ 46303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carrying a weapon","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc3bf725-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual who, when on, or attempting to board, an aircraft in, or intended for operation in, air transportation or intrastate air transportation, has on or about the individual or the property of the individual a concealed dangerous weapon that is or would be accessible to the individual in flight is liable to the United States Government for a civil penalty of not more than $10,000 for each violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc3bf726-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compromise and Setoff","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc3bf727-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Homeland Security may compromise the amount of a civil penalty imposed under subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3bf728-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Government may deduct the amount of a civil penalty imposed or compromised under this section from amounts it owes the individual liable for the penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc3bf729-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc3bf72a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46303/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement officer of a State or political subdivision of a State, or an officer or employee of the Government, authorized to carry arms in an official capacity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3bf72b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46303/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" another individual the Administrator of the Federal Aviation Administration or the Secretary of Homeland Security by regulation authorizes to carry arms in an official capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc3bf72c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1234"},"text":"108 Stat. 1234","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s140/d/5"},"text":"Pub. L. 107–71, title I, § 140(d)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/642"},"text":"115 Stat. 642","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/458/tIV/s4027/c"},"text":"Pub. L. 108–458, title IV, § 4027(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-12-17"},"text":"Dec. 17, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/3727"},"text":"118 Stat. 3727","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc3bf72d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc3bf72e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc3bf72f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46303(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1471(d) (words after 3d comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 901(d); added "},{"tag":"html:span","attrib":{},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/473/s2014/a/1"},"text":"Pub. L. 98–473, § 2014(a)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2189"},"text":"98 Stat. 2189","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46303(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1471(a)(2) (related to 1471(d)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s901/a/2"},"text":"Pub. L. 85–726, § 901(a)(2)","children":[],"tail":" (related to § 901(d)), "},{"tag":"html:a","attrib":{"href":"/us/stat/72/784"},"text":"72 Stat. 784","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 10, 1962","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/528/s12"},"text":"Pub. L. 87–528, § 12","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/76/150"},"text":"76 Stat. 150","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/504/s35/b"},"text":"Pub. L. 95–504, § 35(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1740"},"text":"92 Stat. 1740","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 12, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/473/s2014/b"},"text":"Pub. L. 98–473, § 2014(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2189"},"text":"98 Stat. 2189","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(b)(1)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(b)(1)(E); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/e"},"text":"Pub. L. 98–443, § 3(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46303(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1471(d) (words before 3d comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “deadly or” and “which shall be recoverable in a civil action brought in the name of the United States” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “imposed under” are substituted for “provided for in” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “imposed or compromised” are substituted for “The amount of such penalty when finally determined or fixed by order of the Board, or the amount agreed upon in compromise” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “State or political subdivision of a State” are substituted for “municipal or State government” for consistency in the revised title and with other titles of the United States Code. The words “or required” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc3bf730-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc3bf731-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s4027/c/1"},"text":"Pub. L. 108–458, § 4027(c)(1)","children":[],"tail":", substituted “Secretary of Homeland Security” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/458/s4027/c/2"},"text":"Pub. L. 108–458, § 4027(c)(2)","children":[],"tail":", substituted “Secretary of Homeland Security” for “Under Secretary of Transportation for Security”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71"},"text":"Pub. L. 107–71","children":[],"tail":" inserted “or the Under Secretary of Transportation for Security” after “Federal Aviation Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
