{"tag":"section","attrib":{"id":"idca82d5fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1140"},"text":null,"children":[{"tag":"num","attrib":{"value":"1140"},"text":"§ 1140.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Information individuals ","children":[{"tag":"ref","attrib":{"idref":"fn002018"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002018"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “for”."}],"tail":" involved in accidents and families of such individuals"}],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In the course of an investigation of an accident described in section 1131(a)(1), except an aircraft accident described in section 1136 or a rail passenger accident described in section 1139, the Board may, to the maximum extent practicable, ensure that individuals involved in accidents and the families of such individuals, and other individuals the Board deems appropriate—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca82d5fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1140/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are informed as to the roles, with respect to the accident and the post-accident activities, of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d5fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1140/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are briefed, before any public briefing, about the accident, its causes, and any other findings from the investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca82d5fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1140/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are individually informed of and allowed to attend any public hearings and meetings of the Board about the accident.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca82d5fe-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dC/s1109/e/1"},"text":"Pub. L. 115–254, div. C, § 1109(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3435"},"text":"132 Stat. 3435","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tXII/s1215/e"},"text":"Pub. L. 118–63, title XII, § 1215(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1430"},"text":"138 Stat. 1430","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca82d5ff-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca82d600-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca82d601-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" substituted “individuals involved in accidents and families of such individuals” for “for families of individuals involved in accidents” in section catchline and “individuals involved in accidents and the families of such individuals” for “the families of individuals involved in the accident” in introductory provisions in text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
