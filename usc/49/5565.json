{"tag":"section","attrib":{"id":"idcad191fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5565"},"text":null,"children":[{"tag":"num","attrib":{"value":"5565"},"text":"§ 5565.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Encouraging the development of plans for converting certain rail passenger terminals","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad191fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5565/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Grant Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may make a grant of financial assistance to a qualified person (including a governmental authority) to encourage the development of plans for converting a rail passenger terminal under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5562/a/4"},"text":"section 5562(a)(4) of this title","children":[],"tail":". To receive assistance under this section, the person must—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad191fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5565/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be prepared to develop practicable plans that meet zoning, land use, and other requirements of the applicable State and local jurisdictions in which the terminal is located;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad191ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5565/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" incorporate into the designs and plans proposed for converting the terminal, features that reasonably appear likely to attract private investors willing to carry out the planned conversion and its subsequent maintenance and operation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad19200-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5565/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" complete the designs and plans for the conversion within the period of time prescribed by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad19201-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5565/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making a grant under this section, the Secretary of Transportation shall give preferential consideration to an applicant whose completed designs and plans will be carried out within 3 years after their completion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad19202-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5565/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximizing Conversion and Continued Public Use","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad19203-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5565/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amounts appropriated to carry out this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5562/a/4"},"text":"section 5562(a)(4) of this title","children":[],"tail":" shall be expended in the way most likely to maximize the conversion and continued public use of rail passenger terminals that are—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad19204-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5565/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" listed in the National Register of Historic Places maintained by the Secretary of the Interior; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad19205-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5565/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommended (on the basis of architectural integrity and quality) by the Advisory Council on Historic Preservation or the Chairman of the National Endowment for the Arts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad19206-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5565/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation may not make a grant under this section for more than 80 percent of the total cost of the project for which the financial assistance is provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad19207-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/853"},"text":"108 Stat. 853","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/15"},"text":"Pub. L. 103–429, § 6(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4379"},"text":"108 Stat. 4379","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad19208-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcad19209-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcad1920a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":nu