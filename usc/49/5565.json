":{},"text":"Oct. 5, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/421/s14"},"text":"Pub. L. 95–421, § 14","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/929"},"text":"92 Stat. 929","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 29, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/73/s128"},"text":"Pub. L. 96–73, § 128","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/553"},"text":"93 Stat. 553","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/254/s206/a"},"text":"Pub. L. 96–254, § 206(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/412"},"text":"94 Stat. 412","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5565(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1653(i)(5) (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5565(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1653(i)(5) (3d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the word “authority” is substituted for “entity” for consistency in the revised title. The words “in accordance with regulations” are omitted as unnecessary because of 49:322(a). In clause (1), the words “as well as requirements . . . under this subsection” are omitted as unnecessary because of the restatement. In clause (2), the words “into an intermodal transportation terminal, a civic or cultural center, or both” are omitted as unnecessary. In clause (3), the word “prescribed” is substituted for “establishes” as being more appropriate.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “carried out” are substituted for “implemented and effectuated” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “The Secretary of Transportation may not make a grant” are substituted for “The amount of the Federal share of any grant . . . shall not exceed” for clarity and consistency in this chapter. The word “undertaking” is omitted as being included in “project”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcad1920b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:5565 to correct an erroneous section catchline.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad1920c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcad1920d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" inserted “certain” after “converting” in section catchline."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcad1920e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcad1920f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s9"},"text":"section 9 of Pub. L. 103–429","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
