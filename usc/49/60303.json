{"tag":"section","attrib":{"id":"idcc8842d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60303"},"text":null,"children":[{"tag":"num","attrib":{"value":"60303"},"text":"§ 60303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees for compliance reviews of liquefied natural gas facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc8842d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Imposition of Fee.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8842d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation (referred to in this section as the “Secretary”) shall impose on a person who files with the Federal Energy Regulatory Commission an application for a liquefied natural gas facility that has design and construction costs totaling not less than $2,500,000,000 a fee for the necessary expenses of a review, if any, that the Secretary conducts, in connection with that application, to determine compliance with subpart B of part 193 of title 49, Code of Federal Regulations (or successor regulations).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8842d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relation to other review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not impose fees under paragraph (1) and section 60117(","children":[{"tag":"i","attrib":{},"text":"o","children":[],"tail":") or 60301(b) for the same compliance review described in paragraph (1)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8842d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Means of Collection.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8842d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe procedures to collect fees under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8842da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of government entities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8842db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60303/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use a department, agency, or instrumentality of the Federal Government or of a State or local government to collect fees under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8842dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60303/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reimburse that department, agency, or instrumentality a reasonable amount for the services provided.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8842dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established an account, to be known as the “Liquefied Natural Gas Siting Account”, in the Pipeline Safety Fund established in the Treasury of the United States under section 60301.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc8842de-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dR/tI/s103/a"},"text":"Pub. L. 116–260, div. R, title I, § 103(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2215"},"text":"134 Stat. 2215","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
