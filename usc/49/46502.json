ll,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46502(b)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1472(n)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1)(B), the words “offense of” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “as herein defined” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “the place of actual” are omitted as surplus. The words “as defined in paragraph (2) of this subsection” are omitted because of the restatement. The word “country” is substituted for “State” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc40b23b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:46502(a)(2)(B) and (b)(1)(B) to clarify the restatement of 49 App.:1472(i)(1)(B) and (n)(1)(B) by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1994-07-05/s1"},"text":"section 1 of the Act of July 5, 1994","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Public Law 103–272","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1241"},"text":"108 Stat. 1241","children":[],"tail":", 1242)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc40b23c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc40b23d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s723/b/1"},"text":"Pub. L. 104–132, § 723(b)(1)","children":[],"tail":", inserted “or conspiring” after “attempting”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132"},"text":"Pub. L. 104–132","children":[],"tail":", §§ 721(a)(1), 723(b)(2), in introductory provisions, inserted “or conspiring to commit” after “committing” and struck out “and later found in the United States” after “jurisdiction of the United States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s721/a/2"},"text":"Pub. L. 104–132, § 721(a)(2)","children":[],"tail":", amended par. (2) generally. Prior to amendment, par. (2) read as follows: “This subsection applies only if the place of takeoff or landing of the aircraft on which the individual commits the offense is located outside the territory of the country of registration of the aircraft.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/132/s721/a/3"},"text":"Pub. L. 104–132, § 721(a)(3)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsecs. (a)(2)(B), (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" inserted “notwithstanding "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3559/b"},"text":"section 3559(b) of title 18","children":[],"tail":",” before “if the death”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc40b23e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc40b23f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1994 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/429"},"text":"Pub. L. 103–429","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s9"},"text":"section 9 of Pub. L. 103–429","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s321"},"text":"section 321 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc40b240-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Death Penalty Procedures for Certain Air Piracy Cases Occurring Before Enactment of the Federal Death Penalty Act of 1994","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/177/tII/s211"},"text":"Pub. L. 109–177, title II, § 211","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/230"},"text":"120 Stat. 230","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/177/tII/s211"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 60003 of the Violent Crime Control and Law Enforcement Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Public Law 103–322","children":[],"tail":"), is amended, as of the time of its enactment ["},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":"], by adding at the end the following:"},{"tag":"p","attrib":{},"text":"“ ‘(c) [Omitted, see below.]’.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Severability Clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If any provision of section 60003(b)(2) of the Violent Crime and Law Enforcement Act of 1994 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Public Law 103–322","children":[],"tail":") [repealed "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s46503"},"text":"section 46503 of this title","children":[],"tail":"], or the application thereof to any person or any circumstance is held invalid, the remainder of such section and the application of such section to other persons or circumstances shall not be affected thereby.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/322/tVI/s60003/c"},"text":"Pub. L. 103–322, title VI, § 60003(c)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/109/177/tII/s211/a"},"text":"Pub. L. 109–177, title II, § 211(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-03-09"},"text":"Mar. 9, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/230"},"text":"120 Stat. 230","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/177/tII/s211/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Death Penalty Procedures for Certain Previous Aircraft Piracy Violations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An individual convicted of violating ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s46502"},"text":"section 46502 of title 49","children":[],"tail":", United States Code, or its predecessor, may be sentenced to death in accordance with the procedures established in chapter 228 of title 18, United States Code, if for any offense committed before the enactment of the Violent Crime Control and Law Enforcement Act of 1994 ("},{"tag":"ref","attrib":{"href":"/us/pl/103/322"},"text":"Public Law 103–322","children":[],"tail":") ["},{"tag":"date","attrib":{"date":"1994-09-13"},"text":"Sept. 13, 1994","children":[],"tail":"], but after the enactment of the Antihijacking Act of 1974 ("},{"tag":"ref","attrib":{"href":"/us/pl/93/366"},"text":"Public Law 93–366","children":[],"tail":") ["},{"tag":"date","attrib":{"date":"1974-08-05"},"text":"Aug. 5, 1974","children":[],"tail":"], it is determined by the finder of fact, before consideration of the factors set forth in sections 3591(a)(2) and 3592(a) and (c) of title 18, United States Code, that one or more of the factors set forth in former "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s46503/c/2"},"text":"section 46503(c)(2) of title 49","children":[],"tail":", United States Code, or its predecessor, has been proven by the Government to exist, beyond a reasonable doubt, and that none of the factors set forth in former "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s46503/c/1"},"text":"section 46503(c)(1) of title 49","children":[],"tail":", United States Code, or its predecessor, has been proven by the defendant to exist, by a preponderance of the information. The meaning of the term ‘especially heinous, cruel, or depraved’, as used in the factor set forth in former "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s46503/c/2/B/iv"},"text":"section 46503(c)(2)(B)(iv) of title 49","children":[],"tail":", United States Code, or its predecessor, shall be narrowed by adding the limiting language ‘in that it involved torture or serious physical abuse to the victim’, and shall be construed as when that term is used in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s3592/c/6"},"text":"section 3592(c)(6) of title 18","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc40b241-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Aircraft Piracy","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The United States is a party to the Convention for the Suppression of Unlawful Seizure of Aircraft, signed at The Hague, ","children":[{"tag":"date","attrib":{"date":"1970-12-16"},"text":"Dec. 16, 1970","children":[],"tail":", entered into force as to the United States, "},{"tag":"date","attrib":{"date":"1971-10-14"},"text":"Oct. 14, 1971","children":[],"tail":", 22 UST 1641."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
