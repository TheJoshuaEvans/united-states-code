{"tag":"section","attrib":{"id":"idcc40b226-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502"},"text":null,"children":[{"tag":"num","attrib":{"value":"46502"},"text":"§ 46502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Aircraft piracy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc40b227-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In Special Aircraft Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc40b228-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc40b229-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “aircraft piracy” means seizing or exercising control of an aircraft in the special aircraft jurisdiction of the United States by force, violence, threat of force or violence, or any form of intimidation, and with wrongful intent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc40b22a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an attempt to commit aircraft piracy is in the special aircraft jurisdiction of the United States although the aircraft is not in flight at the time of the attempt if the aircraft would have been in the special aircraft jurisdiction of the United States had the aircraft piracy been completed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc40b22b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual committing or attempting or conspiring to commit aircraft piracy—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc40b22c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned for at least 20 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc40b22d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3559/b"},"text":"section 3559(b) of title 18","children":[],"tail":", if the death of another individual results from the commission or attempt, shall be put to death or imprisoned for life."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc40b22e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Outside Special Aircraft Jurisdiction","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc40b22f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An individual committing or conspiring to commit an offense (as defined in the Convention for the Suppression of Unlawful Seizure of Aircraft) on an aircraft in flight outside the special aircraft jurisdiction of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc40b230-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be imprisoned for at least 20 years; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc40b231-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s3559/b"},"text":"section 3559(b) of title 18","children":[],"tail":", if the death of another individual results from the commission or attempt, shall be put to death or imprisoned for life."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc40b232-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is jurisdiction over the offense in paragraph (1) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc40b233-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a national of the United States was aboard the aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc40b234-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offender is a national of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc40b235-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an offender is afterwards found in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc40b236-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46502/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this subsection, the term “national of the United States” has the meaning prescribed in section 101(a)(22) of the Immigration and Nationality Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t8/s1101/a/22"},"text":"8 U.S.C. 1101(a)(22)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc40b237-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1241"},"text":"108 Stat. 1241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/61"},"text":"Pub. L. 103–429, § 6(61)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4385"},"text":"108 Stat. 4385","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/132/tVII"},"text":"Pub. L. 104–132, ti