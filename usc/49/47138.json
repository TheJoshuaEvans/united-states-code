{"tag":"section","attrib":{"id":"idcc5d6253-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47138"},"text":null,"children":[{"tag":"num","attrib":{"value":"47138"},"text":"§ 47138.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pilot program for purchase of airport development rights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc5d6254-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47138/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall establish a pilot program to support the purchase, by a State or political subdivision of a State, of development rights associated with, or directly affecting the use of, privately owned public use airports located in that State. Under the program, the Secretary may make a grant to a State or political subdivision of a State from funds apportioned under section 47114 for the purchase of such rights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d6255-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47138/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d6256-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47138/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may not make a grant under subsection (a) unless the grant is made—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc5d6257-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47138/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enable the State or political subdivision to purchase development rights in order to ensure that the airport property will continue to be available for use as a public airport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc5d6258-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47138/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to a requirement that the State or political subdivision acquire an easement or other appropriate covenant requiring that the airport shall remain a public use airport in perpetuity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d6259-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47138/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matching requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amount of a grant under the program may not exceed 90 percent of the costs of acquiring the development rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5d625a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47138/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe standards for grants under subsection (a), including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5d625b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47138/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" grant application and approval procedures; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5d625c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47138/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements for the content of the instrument recording the purchase of the development rights.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5fac4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47138/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Release of Purchased Rights and Covenant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any development rights purchased under the program shall remain the property of the State or political subdivision unless the Secretary approves the transfer or disposal of the development rights after making a determination that the transfer or disposal of that right is in the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5fac4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47138/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may not make a grant under the pilot program for the purchase of development rights at more than 10 airports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc5fac4f-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/tI/s152/a"},"text":"Pub. L. 108–176, title I, § 152(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2506"},"text":"117 Stat. 2506","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc5fac50-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc5fac51-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc5fac52-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
