{"tag":"section","attrib":{"id":"idcb67b7b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137"},"text":null,"children":[{"tag":"num","attrib":{"value":"31137"},"text":"§ 31137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic logging devices and brake maintenance regulations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb67b7b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Electronic Logging Devices","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of the Commercial Motor Vehicle Safety Enhancement Act of 2012, the Secretary of Transportation shall prescribe regulations—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb67b7b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requiring a commercial motor vehicle involved in interstate commerce and operated by a driver subject to the hours of service and the record of duty status requirements under part 395 of title 49, Code of Federal Regulations, be ","children":[{"tag":"ref","attrib":{"idref":"fn002121"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002121"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be preceded by “to”."}],"tail":" equipped with an electronic logging device to improve compliance by an operator of a vehicle with hours of service regulations prescribed by the Secretary; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb67b7b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that an electronic logging device is not used to harass a vehicle operator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb67b7ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic Logging Device Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb67b7bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations prescribed under subsection (a) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb67b7bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" require an electronic logging device—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb67b7bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to accurately record commercial driver hours of service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb67b7be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to record the location of a commercial motor vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb67b7bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be tamper resistant; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb67b7c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to be synchronized to the operation of the vehicle engine or be capable of recognizing when the vehicle is being operated;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow law enforcement to access the data contained in the device during a roadside inspection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" except as provided in paragraph (3), apply to a commercial motor vehicle beginning on the date that is 2 years after the date that the regulations are published as a final rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb67b7c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance and design standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The regulations prescribed under subsection (a) shall establish performance standards—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb67b7c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" defining a standardized user interface to aid vehicle operator compliance and law enforcement review;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establishing a secure process for standardized—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb67b7c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" and unique vehicle operator identification;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb67b7c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data access;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb67b7c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data transfer for vehicle operators between motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb67b7c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/2/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data storage for a motor carrier; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb67b7ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/2/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data transfer and transportability for law enforcement officials;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a standard security level for an electronic logging device and related components to be tamper resistant by using a methodology endorsed by a nationally recognized standards organization; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying each driver subject to the hours of service and record of duty status requirements under part 395 of title 49, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb67b7cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A motor carrier, when transporting a motor home or recreation vehicle trailer within the definition of the term “driveaway-towaway operation” (as defined in section 390.5 of title 49, Code of Federal Regulations), may comply with the hours of service requirements by requiring each driver to use—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb67b7ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a paper record of duty status form; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electronic logging device.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb67b7d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification Criteria.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb67b7d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The regulations prescribed by the Secretary under this section shall establish the criteria and a process for the certification of electronic logging devices to ensure that the device meets the performance requirements under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb67b7d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of noncertification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Electronic logging devices that are not certified in accordance with the certification process referred to in paragraph (1) shall not be acceptable evidence of hours of service and record of duty status requirements under part 395 of title 49, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb67b7d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in prescribing the regulations described in subsection (a), shall consider how such regulations may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb67b7d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reduce or eliminate requirements for drivers and motor carriers to retain supporting documentation associated with paper-based records of duty status if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb67b7d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" data contained in an electronic logging device supplants such documentation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" using such data without paper-based records does not diminish the Secretary’s ability to audit and review compliance with the Secretary’s hours of service regulations; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb67b7d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include such measures as the Secretary determines are necessary to protect the privacy of each individual whose personal data is contained in an electronic logging device.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb67b7d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Data.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb67b7d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may utilize information contained in an electronic logging device only to enforce the Secretary’s motor carrier safety and related regulations, including record-of-duty status regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb67b7da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Measures to preserve confidentiality of personal data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall institute appropriate measures to preserve the confidentiality of any personal data contained in an electronic logging device and disclosed in the course of an action taken by the Secretary or by law enforcement officials to enforce the regulations referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb67b7db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall institute appropriate measures to ensure any information collected by electronic logging devices is used by enforcement personnel only for the purpose of determining compliance with hours of service requirements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb67b7dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb67b7dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic logging device","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “electronic logging device” means an electronic device that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb67b7de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is capable of recording a driver’s hours of service and duty status accurately and automatically; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb67b7df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meets the requirements established by the Secretary through regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb67b7e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tamper resistant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “tamper resistant” means resistant to allowing any individual to cause an electronic device to record the incorrect date, time, and location for changes to on-duty driving status of a commercial motor vehicle operator under part 395 of title 49, Code of Federal Regulations, or to subsequently alter the record created by that device.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb67b7e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31137/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Brakes and Brake Systems Maintenance Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall maintain regulations on improved standards or methods to ensure that brakes and brake systems of commercial motor vehicles are maintained properly and inspected by appropriate employees. At a minimum, the regulations shall establish minimum training requirements and qualifications for employees responsible for maintaining and inspecting the brakes and brake systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb67b7e2-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1004"},"text":"108 Stat. 1004","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII"},"text":"Pub. L. 112–141, div. C, title II","children":[],"tail":", §§ 32301(b), 32931(a), "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/786"},"text":"126 Stat. 786","children":[],"tail":", 829; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV"},"text":"Pub. L. 114–94, div. A, title V","children":[],"tail":", §§ 5507, 5508(b)(2), "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1553"},"text":"129 Stat. 1553","children":[],"tail":", 1554.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb67b7e3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb67b7e4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb67b7e5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"c