{"tag":"section","attrib":{"id":"idcb595fe3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31101"},"text":null,"children":[{"tag":"num","attrib":{"value":"31101"},"text":"§ 31101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb595fe4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “commercial motor vehicle” means (except in section 31106) a self-propelled or towed vehicle used on the highways in commerce principally to transport passengers or cargo, if the vehicle—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb595fe5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31101/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a gross vehicle weight rating or gross vehicle weight of at least 10,001 pounds, whichever is greater;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb595fe6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31101/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed to transport more than 10 passengers including the driver; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb595fe7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31101/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is used in transporting material found by the Secretary of Transportation to be hazardous under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5103"},"text":"section 5103 of this title","children":[],"tail":" and transported in a quantity requiring placarding under regulations prescribed by the Secretary under section 5103."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb595fe8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employee” means a driver of a commercial motor vehicle (including an independent contractor when personally operating a commercial motor vehicle), a mechanic, a freight handler, or an individual not an employer, who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb595fe9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31101/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly affects commercial motor vehicle safety in the course of employment by a commercial motor carrier; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb595fea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31101/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not an employee of the United States Government, a State, or a political subdivision of a State acting in the course of employment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb595feb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “employer”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb595fec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31101/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means a person engaged in a business affecting commerce that owns or leases a commercial motor vehicle in connection with that business, or assigns an employee to operate the vehicle in commerce; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb595fed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31101/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not include the Government, a State, or a political subdivision of a State.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb595fee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State of the United States, the District of Columbia, Puerto Rico, the Virgin Islands, American Samoa, Guam, and the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb595fef-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/984"},"text":"108 Stat. 984","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4003/a"},"text":"Pub. L. 105–178, title IV, § 4003(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/395"},"text":"112 Stat. 395","children":[],"tail":".)"}],"tail":"\n"},{"tag":"note