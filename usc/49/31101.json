ll,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31101","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2301(1), (3)–(6).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/424/s401/1"},"text":"Pub. L. 97–424, § 401(1)","children":[],"tail":", (3)–(6), "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2154"},"text":"96 Stat. 2154","children":[],"tail":", 2155."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2301(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 6, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/424/s401/2"},"text":"Pub. L. 97–424, § 401(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2154"},"text":"96 Stat. 2154","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/554/s228/a"},"text":"Pub. L. 98–554, § 228(a)","children":[],"tail":", (b), "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2852"},"text":"98 Stat. 2852","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Before clause (1), the words “unless the context otherwise requires” are omitted as unnecessary. The text of 49 App.:2301(4) is omitted as unnecessary because of 1:1. The text of 49 App.:2301(5) is omitted as surplus because the complete name of the Secretary of Transportation is used the first time the term appears in a section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), before subclause (A), the words “(except in section 31106)” are added because the source provisions being restated in section 31106 of the revised title contain a definition of “commercial motor vehicle”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (4), the words “the Commonwealth of” are omitted for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb595ff3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb595ff4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Par. (1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4003/a/1"},"text":"Pub. L. 105–178, § 4003(a)(1)","children":[],"tail":", inserted “or gross vehicle weight” after “rating” and substituted “10,001 pounds, whichever is greater” for “10,000 pounds”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4003/a/2"},"text":"Pub. L. 105–178, § 4003(a)(2)","children":[],"tail":", inserted “and transported in a quantity requiring placarding under regulations prescribed by the Secretary under section 5103” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb595ff5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idcb595ff6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Clause","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4003/h"},"text":"Pub. L. 105–178, title IV, § 4003(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/398"},"text":"112 Stat. 398","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/178/tIV/s4003/h"},"text":"“Amendments made by this section [amending this section and sections 31102 to 31104 of this title] shall not affect any funds made available before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
