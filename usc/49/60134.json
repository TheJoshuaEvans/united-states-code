{"tag":"section","attrib":{"id":"idcc85d1d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134"},"text":null,"children":[{"tag":"num","attrib":{"value":"60134"},"text":"§ 60134.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State damage prevention programs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc85d1da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may make a grant to a State authority (including a municipality with respect to intrastate gas pipeline transportation) to assist in improving the overall quality and effectiveness of a damage prevention program of the State authority under subsection (e) if the State authority—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d1db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has in effect an annual certification under section 60105 or an agreement under section 60106;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc85d1dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has in effect an effective damage prevention program that meets the requirements of subsection (b); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d1de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstrates that it has made substantial progress toward establishing such a program, and that such program will meet the requirements of subsection (b); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" does not provide any exemptions to municipalities, State agencies, or their contractors from the one-call notification system requirements of the program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Damage Prevention Program Elements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An effective damage prevention program includes the following elements:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d1e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Participation by operators, excavators, and other stakeholders in the development and implementation of methods for establishing and maintaining effective communications between stakeholders from receipt of an excavation notification until successful completion of the excavation, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A process for fostering and ensuring the support and partnership of stakeholders, including excavators, operators, locators, designers, and local government in all phases of the program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A process for reviewing the adequacy of a pipeline operator’s internal performance measures regarding persons performing locating services and quality assurance programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Participation by operators, excavators, and other stakeholders in the development and implementation of effective employee training programs to ensure that operators, the one-call center, the enforcing agency, and the excavators have partnered to design and implement training for the employees of operators, excavators, and locators.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A process for fostering and ensuring active participation by all stakeholders in public education for damage prevention activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A process for resolving disputes that defines the State authority’s role as a partner and facilitator to resolve issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Enforcement of State damage prevention laws and regulations for all aspects of the damage prevention process, including public education, and the use of civil penalties for violations assessable by the appropriate State authority.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A process for fostering and promoting the use, by all appropriate stakeholders, of improving technologies that may enhance communications, underground pipeline locating capability, and gathering and analyzing information about the accuracy and effectiveness of locating programs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A process for review and analysis of the effectiveness of each program element, including a means for implementing improvements identified by such program reviews.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Factors to Consider","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making grants under this section, the Secretary shall take into consideration the commitment of each State to ensuring the effectiveness of its damage prevention program, including legislative and regulatory actions taken by the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a State authority files an application for a grant under this section not later than September 30 of a calendar year and demonstrates that the Governor (or chief executive) of the State has designated it as the appropriate State authority to receive the grant, the Secretary shall review the State’s damage prevention program to determine its effectiveness.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant under this section to a State authority may only be used to pay the cost of the personnel, equipment, and activities that the State authority reasonably requires for the calendar year covered by the grant to develop or carry out its damage prevention program in accordance with subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplicability of Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A grant made under this section is not subject to the section 60107(a) limitation on the maximum percentage of funds to be paid by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Use of Funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Funds provided to carry out this section may not be used for lobbying or in direct support of litigation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Damage Prevention Process Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “damage prevention process” means a process that incorporates the principles described in sections 60114(b), 60114(d), and 60114(e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60134/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary to provide grants under this section $1,500,000 for each of fiscal years 2021 through 2023. Such funds shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc85d1f1-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/468/s2/b/2"},"text":"Pub. L. 109–468, § 2(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3487"},"text":"120 Stat. 3487","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/90"},"text":"Pub. L. 112–90","children":[],"tail":", §§ 3(b), 32(d), "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1906"},"text":"125 Stat. 1906","children":[],"tail":", 1923; "},{"tag":"ref","attrib":{"href":"/us/pl/116/260/dR/tI/s101/f"},"text":"Pub. L. 116–260, div. R, title I, § 101(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/2214"},"text":"134 Stat. 2214","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc85d1f2-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc85d1f3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc85d1f4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260"},"text":"Pub. L. 116–260","children":[],"tail":" substituted “fiscal years 2021 through 2023” for “fiscal years 2012 through 2015”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90/s3/b"},"text":"Pub. L. 112–90, § 3(b)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90/s32/d"},"text":"Pub. L. 112–90, § 32(d)","children":[],"tail":", added subsec. (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc85d1f5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc85d1f6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90/s3/b"},"text":"section 3(b) of Pub. L. 112–90","children":[],"tail":" effective 2 years after "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/90/s3/c"},"text":"section 3(c) of Pub. L. 112–90","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s6103"},"text":"section 6103 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
