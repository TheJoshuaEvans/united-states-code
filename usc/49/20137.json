{"tag":"section","attrib":{"id":"idcb11f5e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20137"},"text":null,"children":[{"tag":"num","attrib":{"value":"20137"},"text":"§ 20137.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Event recorders","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb11f5e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20137/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, “event recorder” means a device that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb11f5e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20137/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" records train speed, hot box detection, throttle position, brake application, brake operations, and any other function the Secretary of Transportation considers necessary to record to assist in monitoring the safety of train operation, such as time and signal indication; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb11f5e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20137/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is designed to resist tampering.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb11f5e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20137/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations and Orders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1989-12-22"},"text":"December 22, 1989","children":[],"tail":", the Secretary shall prescribe regulations and issue orders that may be necessary to enhance safety by requiring that a train be equipped with an event recorder not later than one year after the regulations are prescribed and the orders are issued. However, if the Secretary finds it is impracticable to equip trains within that one-year period, the Secretary may extend the period to a date that is not later than 18 months after the regulations are prescribed and the orders are issued."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb11f5e8-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/875"},"text":"108 Stat. 875","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb11f5e9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb11f5ea-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb11f5eb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20137","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:431(m).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458"},"text":"Pub. L. 91–458","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/971"},"text":"84 Stat. 971","children":[],"tail":", § 202(m); added "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s10"},"text":"Pub. L. 100–342, § 10","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/629"},"text":"102 Stat. 629","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “Not later than ","children":[{"tag":"date","attrib":{"date":"1989-12-22"},"text":"December 22, 1989","children":[],"tail":"” are substituted for “within 18 months after "},{"tag":"date","attrib":{"date":"1988-06-22"},"text":"June 22, 1988","children":[],"tail":"” for clarity. The words “may extend the period to a date that is not later than 18 months after the regulations are prescribed and the orders are issued” are substituted for “may extend the deadline for compliance with such requirement, but in no event shall such deadline be extended past 18 months after such rules, regulations, orders, and standards are issued” to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
