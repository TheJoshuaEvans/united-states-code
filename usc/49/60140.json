{"tag":"section","attrib":{"id":"idcc85d22f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60140"},"text":null,"children":[{"tag":"num","attrib":{"value":"60140"},"text":"§ 60140.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Cover over buried pipelines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc85d230-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60140/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hazardous Liquid Pipeline Incidents Involving Buried Pipelines.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d231-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60140/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall conduct a study of hazardous liquid pipeline incidents at crossings of inland bodies of water with a width of at least 100 feet from high water mark to high water mark to determine if the depth of cover over the buried pipeline was a factor in any accidental release of hazardous liquids.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d232-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60140/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, the Secretary shall transmit to the Committee on Transportation and Infrastructure and the Committee on Energy and Commerce of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate a report on the results of the study.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d233-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60140/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment of Current Requirements for Depth of Cover Over Buried Pipelines.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d234-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60140/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, following completion of the study under subsection (a), the Secretary finds that the depth of cover over buried pipelines is a contributing factor in the accidental release of hazardous liquids from the pipelines, the Secretary, not later than 1 year after the date of completion of the study, shall review and determine the sufficiency of current requirements for the depth of cover over buried pipelines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d235-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60140/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Legislative recommendations.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc85d236-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60140/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary determines under paragraph (1) that the current requirements for the depth of cover over buried pipelines are insufficient, the Secretary shall develop legislative recommendations for improving the safety of buried pipelines at crossings of inland bodies of water with a width of at least 100 feet from high water mark to high water mark.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d237-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60140/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consideration of factors","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In developing legislative recommendations under subparagraph (A), the Secretary shall consider the factors specified in section 60102(b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d238-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60140/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary develops legislative recommendations under subparagraph (A), the Secretary shall submit to the committees referred to in subsection (a)(2) a report containing the legislative recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc85d239-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90/s28/a"},"text":"Pub. L. 112–90, § 28(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/125/1920"},"text":"125 Stat. 1920","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc85d23a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc85d23b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc85d23c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (a)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/90"},"text":"Pub. L. 112–90","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2012-01-03"},"text":"Jan. 3, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
