{"tag":"section","attrib":{"id":"idcc3e68b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46312"},"text":null,"children":[{"tag":"num","attrib":{"value":"46312"},"text":"§ 46312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transporting hazardous material","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc3e68b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46312/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person shall be fined under title 18, imprisoned for not more than 5 years, or both, if the person, in violation of a regulation or requirement related to the transportation of hazardous material prescribed by the Secretary of Transportation under this part or chapter 51—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc3e68b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46312/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" willfully delivers, or causes to be delivered, property containing hazardous material to an air carrier or to an operator of a civil aircraft for transportation in air commerce; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e68b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46312/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recklessly causes the transportation in air commerce of the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc3e68ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46312/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Knowledge of Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of subsection (a), knowledge by the person of the existence of a regulation or requirement related to the transportation of hazardous material prescribed by the Secretary under this part or chapter 51 is not an element of an offense under this section but shall be considered in mitigation of the penalty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc3e68bb-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1239"},"text":"108 Stat. 1239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tV/s507"},"text":"Pub. L. 106–181, title V, § 507","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/140"},"text":"114 Stat. 140","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII/s7128/a"},"text":"Pub. L. 109–59, title VII, § 7128(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1909"},"text":"119 Stat. 1909","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc3e68bc-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc3e68bd-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc3e68b