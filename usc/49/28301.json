{"tag":"section","attrib":{"id":"idcb41922a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301"},"text":null,"children":[{"tag":"num","attrib":{"value":"28301"},"text":"§ 28301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb41922b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eight Hour Day","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In contracts for labor and service, 8 hours shall be a day’s work and the standard day’s work for determining the compensation for services of an employee employed by a common carrier by railroad subject to subtitle IV of this title and actually engaged in any capacity in operating trains used for transporting passengers or property on railroads from—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb41922c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State of the United States or the District of Columbia to any other State or the District of Columbia;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb41922d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one place in a territory or possession of the United States to another place in the same territory or possession;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb41922e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a place in the United States to an adjacent foreign country; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb41922f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a place in the United States through a foreign country to any other place in the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb419230-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) of this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb419231-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does not apply to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb419232-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an independently owned and operated railroad not exceeding one hundred miles in length;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb419233-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electric street railroad; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb419234-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an electric interurban railroad; but","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb419235-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" does apply to an independently owned and operated railroad less than one hundred miles in length—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb419236-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose principal business is leasing or providing terminal or transfer facilities to other railroads; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb419237-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s28301/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engaged in transfers of freight between railroads or between railroads and industrial plants.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb419238-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/56/A"},"text":"Pub. L. 104–287, § 5(56)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3394"},"text":"110 Stat. 3394","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb419239-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb41923a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb41923b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"28301","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:65.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Sept. 3, 5, 1916, ch. 436, § 1, ","children":[{"tag":"html:a","attrib":{"href":"/us/stat/39/721"},"text":"39 Stat. 721","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(uncodified).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"Sept. 3, 5, 1916, ch. 436, §§ 2, 3, ","children":[{"tag":"html:a","attrib":{"href":"/us/stat/39/721"},"text":"39 Stat. 721","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “determining” is substituted for “reckoning” for clarity. The words “who are not or may hereafter be employed” are omitted as surplus. In clause (1), the words “or territory” are omitted because the existing territories of the United States are now connected to the United States by rail. In clause (2), the words “or possession of the United States” are added for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The text of sections 2 and 3 of the Act of September 3, 5, 1916 (ch. 436, ","children":[{"tag":"ref","attrib":{"href":"/us/stat/39/721"},"text":"39 Stat. 721","children":[],"tail":"), is omitted to eliminate executed provisions."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
