{"tag":"section","attrib":{"id":"idcc85d1f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60135"},"text":null,"children":[{"tag":"num","attrib":{"value":"60135"},"text":"§ 60135.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement transparency","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc85d1f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60135/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"2007-12-31"},"text":"December 31, 2007","children":[],"tail":", the Secretary shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d1f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60135/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a monthly updated summary to the public of all gas and hazardous liquid pipeline enforcement actions taken by the Secretary or the Pipeline and Hazardous Materials Safety Administration, from the time a notice commencing an enforcement action is issued until the enforcement action is final;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60135/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include in each such summary identification of the operator involved in the enforcement activity, the type of alleged violation, the penalty or penalties proposed, any changes in case status since the previous summary, the final assessment amount of each penalty, and the reasons for a reduction in the proposed penalty, if appropriate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d1fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60135/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a mechanism by which a pipeline operator named in an enforcement action may make information, explanations, or documents it believes are responsive to the enforcement action available to the public.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60135/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each summary under this section shall be made available to the public by electronic means.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d1fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60135/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to","children":[],"tail":" FOIA.—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to require disclosure of information or records that are exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc85d1fe-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/468/s6/a"},"text":"Pub. L. 109–468, § 6(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-29"},"text":"Dec. 29, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3491"},"text":"120 Stat. 3491","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
