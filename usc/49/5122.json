{"tag":"section","attrib":{"id":"idca937802-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5122"},"text":null,"children":[{"tag":"num","attrib":{"value":"5122"},"text":"§ 5122.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca937803-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5122/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At the request of the Secretary, the Attorney General may bring a civil action in an appropriate district court of the United States to enforce this chapter or a regulation prescribed or order, special permit, or approval issued under this chapter. The court may award appropriate relief, including a temporary or permanent injunction, punitive damages, and assessment of civil penalties considering the same penalty amounts and factors as prescribed for the Secretary in an administrative case under section 5123.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca937804-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5122/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Imminent Hazards","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca937805-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5122/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Secretary has reason to believe that an imminent hazard exists, the Secretary may bring a civil action in an appropriate district court of the United States—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca937806-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5122/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to suspend or restrict the transportation of the hazardous material responsible for the hazard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca937807-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5122/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to eliminate or mitigate the hazard.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca937808-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5122/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On request of the Secretary, the Attorney General shall bring an action under paragraph (1) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca937809-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5122/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Withholding of Clearance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca93780a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5122/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If any owner, operator, or individual in charge of a vessel is liable for a civil penalty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5123"},"text":"section 5123 of this title","children":[],"tail":" or for a fine under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5124"},"text":"section 5124 of this title","children":[],"tail":", or if reasonable cause exists to believe that such owner, operator, or individual in charge may be subject to such a civil penalty or fine, the Secretary of Homeland Security, upon the request of the Secretary, shall with respect to such vessel refuse or revoke any clearance required by "},{"tag":"ref","attrib":{"href":"/us/usc/t46/s60105"},"text":"section 60105 of title 46","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93780b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5122/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Clearance refused or revoked under this subsection may be granted upon the filing of a bond or other surety satisfactory to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca93780c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/780"},"text":"108 Stat. 780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/324/tIII/s312/a"},"text":"Pub. L. 104–324, title III, § 312(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3920"},"text":"110 Stat. 3920","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII"},"text":"Pub. L. 109–59, title VII","children":[],"tail":", §§ 7119, 7126, "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1905"},"text":"119 Stat. 1905","children":[],"tail":", 1909; "},{"tag":"ref","attrib":{"href":"/us/pl/109/304/s17/h/1"},"text":"Pub. L. 109–304, § 17(h)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-10-06"},"text":"Oct. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/1709"},"text":"120 Stat. 1709","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca93780d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca93780e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca93780f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5122(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1808(a) (last sentence words after semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633"},"text":"Pub. L. 93–633","children":[],"tail":", §§ 109(a) (last sentence words after semicolon), 111(a), "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2159"},"text":"88 Stat. 2159","children":[],"tail":", 2161."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1810(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5122(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1810(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633/s111/b"},"text":"Pub. L. 93–633, § 111(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2161"},"text":"88 Stat. 2161","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/615/s3/b"},"text":"Pub. L. 101–615, § 3(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3247"},"text":"104 Stat. 3247","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “bring a civil action” are substituted for “bring an action in” in 49 App.:1810 and “petition . . . for an order . . . for such other order” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the text of 49 App.:1808(a) (last sentence words after semicolon) and the words “for equitable relief” in 49 App.:1810(a) are omitted as surplus. The words “enforce this chapter” are substituted for “redress a violation by any person of a provision of this chapter” to eliminate unnecessary words. The words “regulation prescribed or order issued” are substituted for “order or regulation issued” for consistency in the revised title and with other titles of the Code. The words “The court may award appropriate relief, including” are substituted for “Such district courts shall have jurisdiction to determine such actions and may grant such relief as is necessary or appropriate, including mandatory or prohibitive injunctive relief, interim equitable relief, and” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “as is necessary” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca937810-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca937811-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2006—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/304"},"text":"Pub. L. 109–304","children":[],"tail":" substituted “Secretary of Homeland Security” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t46/s60105"},"text":"section 60105 of title 46","children":[],"tail":"” for “Secretary of the Treasury” and “section 4197 of the Revised Statutes of the United States (46 App. U.S.C. 91)”, respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary” for “Secretary of Transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7119/a"},"text":"Pub. L. 109–59, § 7119(a)","children":[],"tail":", substituted “this chapter or a regulation prescribed or order, special permit, or approval” for “this chapter or a regulation prescribed or order” and “The court may award appropriate relief, including a temporary or permanent injunction, punitive damages, and assessment of civil penalties considering the same penalty amounts and factors as prescribed for the Secretary in an administrative case under section 5123” for “The court may award appropriate relief, including punitive damages”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7119/b"},"text":"Pub. L. 109–59, § 7119(b)","children":[],"tail":", substituted “or mitigate the hazard” for “or ameliorate the hazard”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/324"},"text":"Pub. L. 104–324","children":[],"tail":" added subsec. (c)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
