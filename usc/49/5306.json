{"tag":"section","attrib":{"id":"idcaa1cf13-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5306"},"text":null,"children":[{"tag":"num","attrib":{"value":"5306"},"text":"§ 5306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Private enterprise participation in metropolitan planning and transportation improvement programs and relationship to other limitations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaa1cf14-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Private Enterprise Participation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A plan or program required by section 5303, 5304, or 5305 of this title shall encourage to the maximum extent feasible, as determined by local policies, criteria, and decisionmaking, the participation of private enterprise. If equipment or a facility already being used in an urban area is to be acquired under this chapter, the program shall provide that it be improved so that it will better serve the transportation needs of the area.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaa1cf15-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to Other Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Sections 5303–5305 of this title do not authorize—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaa1cf16-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a metropolitan planning organization to impose a legal requirement on a transportation facility, provider, or project not eligible under this chapter or title 23; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaa1cf17-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" intervention in the management of a transportation authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaa1cf18-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/795"},"text":"108 Stat. 795","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIII/s3008"},"text":"Pub. L. 109–59, title III, § 3008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1568"},"text":"119 Stat. 1568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaa1cf19-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcaa1cf1a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcaa1cf1b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"