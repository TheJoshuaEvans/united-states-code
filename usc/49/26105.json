{"tag":"section","attrib":{"id":"idcb3f219a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26105"},"text":null,"children":[{"tag":"num","attrib":{"value":"26105"},"text":"§ 26105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"For purposes of this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3f219b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26105/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “financial assistance” includes grants, contracts,,","children":[{"tag":"ref","attrib":{"idref":"fn002099"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002099"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" cooperative agreements, and other transactions;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f219c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26105/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “high-speed rail” means all forms of nonhighway ground transportation that run on rails or electromagnetic guideways providing transportation service which is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb3f219d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26105/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonably expected to reach sustained speeds of more than 125 miles per hour; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb3f219e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26105/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made available to members of the general public as passengers,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"but does not include rapid transit operations within an urban area that are not connected to the general rail system of transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f219f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26105/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “publicly financed costs” means the costs funded after ","children":[{"tag":"date","attrib":{"date":"1993-04-29"},"text":"April 29, 1993","children":[],"tail":", by Federal, State, and local governments;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f21a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26105/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Secretary” means the Secretary of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f21a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26105/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “State” means any of the several States, the District of Columbia, Puerto Rico, the Northern Mariana Islands, the Virgin Islands, Guam, American Samoa, and any other territory or possession of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3f21a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26105/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “United States private business” means a business entity organized under the laws of the United States, or of a State, and conducting substantial business operations in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb3f21a3-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/440/tI/s103/a/2"},"text":"Pub. L. 103–440, title I, § 103(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4618"},"text":"108 Stat. 4618","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tVII/s7201/b"},"text":"Pub. L. 105–178, title VII, § 7201(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/470"},"text":"112 Stat. 470","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIX/s9001/c"},"text":"Pub. L. 109–59, title IX, § 9001(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1919"},"text":"119 Stat. 1919","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb3f21a4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb3f21a5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb3f21a6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" substituted “, cooperative agreements, and other transactions” for “and cooperative agreements”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" amended par. (2) generally. Prior to amendment, par. (2) read as follows: “the term ‘high-speed rail’ has the meaning given such term under section 511(n) of the Railroad Revitalization and Regulatory Reform Act of 1976;”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
