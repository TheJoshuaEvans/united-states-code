{"tag":"section","attrib":{"id":"idcadd78bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10703"},"text":null,"children":[{"tag":"num","attrib":{"value":"10703"},"text":"§ 10703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority for rail carriers to establish through routes","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Rail carriers providing transportation subject to the jurisdiction of the Board under this part shall establish through routes (including physical connections) with each other and with water carriers providing transportation subject to chapter 137, shall establish rates and classifications applicable to those routes, and shall establish rules for their operation and provide—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadd78be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10703/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable facilities for operating the through route; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadd78bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10703/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reasonable compensation to persons entitled to compensation for services related to the through route.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcadd78c0-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/810"},"text":"109 Stat. 810","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"ty