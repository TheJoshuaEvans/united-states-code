{"tag":"section","attrib":{"id":"idcbdc9927-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308"},"text":null,"children":[{"tag":"num","attrib":{"value":"44308"},"text":"§ 44308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administrative","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbdc9928-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commercial Practices","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may carry out this chapter consistent with commercial practices of the aviation insurance business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbdc9929-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance of Policies and Disposition of Claims","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbdc992a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may issue insurance policies to carry out this chapter. The Secretary may prescribe the forms, amounts insured under the policies, and premiums charged. Any such policy may authorize the binding arbitration of claims made thereunder in such manner as may be agreed to by the Secretary and any commercial insurer that may be responsible for any part of a loss to which such policy relates. The Secretary may change an amount of insurance or a premium for an existing policy only with the consent of the insured.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbdc992b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For a claim under insurance authorized by this chapter, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbdc992c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" settle and pay the claim made for or against the United States Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbdc992d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay the amount of a binding arbitration award made under paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbdc992e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay the amount of a judgment entered against the Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbdc992f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Underwriting Agent","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbdc9930-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may, and when practical shall, employ an insurance carrier or group of insurance carriers to act as an underwriting agent. The Secretary may use the agent, or a claims adjuster who is independent of the underwriting agent, to adjust claims under this chapter, but claims may be paid only when approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbdc9931-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may pay reasonable compensation to an underwriting agent for servicing insurance the agent writes for the Secretary. Compensation may include payment for reasonable expenses incurred by the agent but may not include a payment by the agent for stimulation or solicitation of insurance business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbdc9932-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided by this subsection, the Secretary may not pay an insurance broker or other person acting in a similar capacity any consideration for arranging insurance when the Secretary directly insures any part of the risk.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbdc9933-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Budget","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall submit annually a budget program for carrying out this chapter as provided for wholly owned Government corporations under chapter 91 of title 31.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbdc9934-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44308/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall maintain a set of accounts for audit under chapter 35 of title 31. Notwithstanding chapter 35, the Comptroller General shall allow credit for expenditures under this chapter made consistent with commercial practices in the aviation insurance business when shown to be necessary because of the business activities authorized by this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbdc9935-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1171"},"text":"108 Stat. 1171","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s127/e"},"text":"Pub. L. 104–316, title I, § 127(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3840"},"text":"110 Stat. 3840","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/137/s4"},"text":"Pub. L. 105–137, § 4","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2640"},"text":"111 Stat. 2640","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tVII/s704"},"text":"Pub. L. 112–95, title VII, § 704","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/118"},"text":"126 Stat. 118","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbdc9936-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbdc9937-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbdc9938-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44308(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1537(c) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s1307/a"},"text":"Pub. L. 85–726, § 1307(a)","children":[],"tail":" (1st sentence), (c), (d), "},{"tag":"html:a","attrib":{"href":"/us/stat/72/803"},"text":"72 Stat. 803","children":[],"tail":", 804."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44308(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1537(a) (1st sentence words before 6th comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1537(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s1307/b"},"text":"Pub. L. 85–726, § 1307(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/804"},"text":"72 Stat. 804","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 9, 1977","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/163/s5/a"},"text":"Pub. L. 95–163, § 5(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/91/1280"},"text":"91 Stat. 1280","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44308(b)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1537(a) (1st sentence words after 6th comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44308(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1537(d) (1st, 3d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44308(c)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1537(d) (2d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44308(c)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1537(c) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44308(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1537(f) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s1307/f"},"text":"Pub. L. 85–726, § 1307(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/804"},"text":"72 Stat. 804","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 2, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/604/s702"},"text":"Pub. L. 93–604, § 702","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1964"},"text":"88 Stat. 1964","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44308(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1537(f) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “may carry out this chapter” are substituted for “in administering this subchapter, may exercise his powers, perform his duties and functions, and make his expenditures” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the word “insurance” is added for clarity. The words “rules, and regulations” are omitted as unnecessary because of 49:322(a). The words “as he deems proper” and “subject to the following provisions of this subsection” are omitted as surplus. The words “and change” and “fix, adjust, and change” are omitted as being included in “prescribe”. The words “under the policies” are added for clarity. The word “charged” is substituted for “provided for in this subchapter” for consistency in this subchapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), before clause (A), the words “the Secretary” are added because of the restatement. In clause (A), the words “adjust and . . . losses, compromise and” are omitted as included in “settle and pay the claim”. The word “made” is substituted for “whether” for clarity. In clause (B), the word “entered” is substituted for “rendered” because it is more appropriate. The words “in any suit” are omitted as surplus. The words “or the amount of any settlement agreed upon” are omitted as being included in “settle and pay the claim”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “and when practical shall” are substituted for “and whenever he finds it practical to do so shall” to eliminate unnecessary words. The word “his” is omitted as surplus. The words “The Secretary may use” are substituted for “may be utilized” for consistency. The words “The services of” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “pay reasonable compensation” are substituted for “allow . . . fair and reasonable compensation” for consistency in the revised title. The words “an underwriting agent” are substituted for “such companies or groups of companies”, and the words “the agent writes” are substituted for “written by such companies or groups of companies as underwriting agent”, for clarity. The word “payment” is substituted for “allowance” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “intermediary” and “fee or other” are omitted as surplus. The word “for” is substituted for “by virtue of his participation in” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “prepare” is omitted as being included in “submit”. The words “for carrying out this chapter” are substituted for “in the performance of, and with respect to, the functions, powers, and duties vested in him by this subchapter” for consistency and to eliminate unnecessary words. The words “under chapter 91 of title 31” are substituted for “by the Government Corporation Control Act, as amended (","children":[{"tag":"ref","attrib":{"href":"/us/stat/59/597"},"text":"59 Stat. 597","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/usc/t31/s841"},"text":"31 U.S.C. 841","children":[],"tail":")” in "},{"tag":"ref","attrib":{"href":"/us/act/1958-08-23/s1307/f"},"text":"section 1307(f) of the Act of August 23, 1958","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/804"},"text":"72 Stat. 804","children":[],"tail":") because of "},{"tag":"ref","attrib":{"href":"/us/act/1982-09-13/s4/b"},"text":"section 4(b) of the Act of September 13, 1982","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Public Law 97–258","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “under chapter 35 of title 31” are substituted for “in accordance with the provisions of the Accounting and Auditing Act of 1950” in ","children":[{"tag":"ref","attrib":{"href":"/us/act/1958-08-23/s1307/f"},"text":"section 1307(f) of the Act of August 23, 1958","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/804"},"text":"72 Stat. 804","children":[],"tail":") because of "},{"tag":"ref","attrib":{"href":"/us/act/1982-09-13/s4/b"},"text":"section 4(b) of the Act of September 13, 1982","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/97/258"},"text":"Public Law 97–258","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1067"},"text":"96 Stat. 1067","children":[],"tail":"). The words “"},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That . . . the Secretary may exercise the powers conferred in said subchapter, perform the duties and functions” are omitted as surplus. The words “Notwithstanding chapter 35” are added for clarity. The words “Comptroller General” are substituted for “General Accounting Office” because of 31:702."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbdc9939-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbdc993a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":" substituted “agent, or a claims adjuster who is independent of the underwriting agent,” for “agent” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/137/s4/a"},"text":"Pub. L. 105–137, § 4(a)","children":[],"tail":", inserted after second sentence “Any such policy may authorize the binding arbitration of claims made thereunder in such manner as may be agreed to by the Secretary and any commercial insurer that may be responsible for any part of a loss to which such policy relates.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/137/s4/b"},"text":"Pub. L. 105–137, § 4(b)","children":[],"tail":", struck out “and” at end of subpar. (A), added subpar. (B), and redesignated former subpar. (B) as (C)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/316"},"text":"Pub. L. 104–316","children":[],"tail":" substituted “for audit” for “. The Comptroller General shall audit those accounts”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
