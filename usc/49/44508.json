{"tag":"section","attrib":{"id":"idcbe60f86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508"},"text":null,"children":[{"tag":"num","attrib":{"value":"44508"},"text":"§ 44508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research advisory committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbe60f87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and Duties","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbe60f88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There is a research advisory committee in the Federal Aviation Administration. The committee shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbe60f89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide advice and recommendations to the Administrator of the Federal Aviation Administration and Congress about needs, objectives, plans, approaches, content, and accomplishments of all aviation research and development activities and programs carried out, including those under sections 44504, 44505, 44507, 44511–44513, and 44912 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe60f8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in ensuring that the research is coordinated with similar research being conducted outside the Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe60f8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the operations of the regional centers of air transportation excellence established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44513"},"text":"section 44513 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe60f8c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" annually review the allocation made by the Administrator of the amounts authorized by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s48102/a"},"text":"section 48102(a) of this title","children":[],"tail":" among the major categories of research and development activities carried out by the Administration and provide advice and recommendations to the Administrator on whether such allocation is appropriate to meet the needs and objectives identified under subparagraph (A)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe60f8d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may establish subordinate committees to provide advice on specific areas of research conducted under sections 44504, 44505, 44507, 44511–44513, and 44912 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe60f8e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members, Chairman, Pay, and Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbe60f8f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The committee is composed of not more than 30 members appointed by the Administrator from among individuals who are not employees of the Administration and who are specially qualified to serve on the committee because of their education, training, or experience. In appointing members of the committee, the Administrator shall ensure that the regional centers of air transportation excellence, universities, corporations, associations, consumers, and other departments, agencies, and instrumentalities of the United States Government are represented.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe60f90-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall designate the chairman of the committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe60f91-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member of the committee serves without pay. However, the Administrator may allow a member, when attending meetings of the committee or a subordinate committee, expenses as authorized under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe60f92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support Staff, Information, and Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall provide support staff for the committee. On request of the committee, the Administrator shall provide information, administrative services, and supplies that the Administrator considers necessary for the committee to carry out its duties and powers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe60f93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"Section 1013 of title 5","children":[],"tail":" does not apply to the committee."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe60f94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use and Limitation of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbe60f95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than .1 percent of the amounts made available to conduct research under sections 44504, 44505, 44507, 44511–44513, and 44912 of this title may be used by the Administrator to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe60f96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A limitation on amounts available for obligation by or for the committee does not apply to amounts made available to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe60f97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Written Reply.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbe60f98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 60 days after receiving any recommendation from the research advisory committee, the Administrator shall provide a written reply to the research advisory committee that, at a minimum—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbe60f99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" clearly states whether the Administrator accepts or rejects the recommendation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe60f9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" explains the rationale for the Administrator’s decision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe87f9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sets forth the timeframe in which the Administrator will implement the recommendation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe87f9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes the steps the Administrator will take to implement the recommendation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe87f9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transparency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The written reply to the research advisory committee, when transmitted to the research advisory committee, shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbe87f9e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made publicly available on the research advisory committee website; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe87f9f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmitted to the Committee on Science, Space, and Technology of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe87fa0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44508/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National aviation research plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The national aviation research plan required under section 44501(c) shall include a summary of all research advisory committee recommendations and a description of the status of their implementation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbe87fa1-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1180"},"text":"108 Stat. 1180","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/tXI/s1104"},"text":"Pub. L. 104–264, title XI, § 1104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3279"},"te