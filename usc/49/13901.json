{"tag":"section","attrib":{"id":"idcaf7b7ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13901"},"text":null,"children":[{"tag":"num","attrib":{"value":"13901"},"text":"§ 13901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for registration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf7b7af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13901/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may provide transportation as a motor carrier subject to jurisdiction under subchapter I of chapter 135 or service as a freight forwarder subject to jurisdiction under subchapter III of such chapter, or service as a broker for transportation subject to jurisdiction under subchapter I of such chapter only if the person is registered under this chapter to provide such transportation or service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf7b7b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13901/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Registration Numbers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf7b7b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13901/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary registers a person under this chapter to provide transportation or service, including as a motor carrier, freight forwarder, or broker, the Secretary shall issue a distinctive registration number to the person for each such authority to provide transportation or service for which the person is registered.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf7b7b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13901/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation or service type indicator","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A number issued under paragraph (1) shall include an indicator of the type of transportation or service for which the registration number is issued, including whether the registration number is issued for registration of a motor carrier, freight forwarder, or broker.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf7b7b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13901/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Specification of Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each agreement to provide transportation or service for which registration is required under this chapter, the registrant shall specify, in writing, the authority under which the person is providing such transportation or service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf7b7b4-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/879"},"text":"109 Stat. 879","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32914/a"},"text":"Pub. L. 112–141, div. C, title II, § 32914(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/819"},"text":"126 Stat. 819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf7b7b5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf7b7b6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcaf7b7b7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “A person may provide transportation or service subject to jurisdiction under subchapter I or III of chapter 135 or be a broker for transportation subject to jurisdiction under subchapter I of that chapter, only if the person is registered under this chapter to provide the transportation or service.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaf7b7b8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":