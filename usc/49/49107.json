{"tag":"section","attrib":{"id":"idcc6e04f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49107"},"text":null,"children":[{"tag":"num","attrib":{"value":"49107"},"text":"§ 49107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal employees at Metropolitan Washington Airports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc6e04f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Labor Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc6e04f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Metropolitan Washington Airports Authority shall adopt all labor agreements that were in effect on ","children":[{"tag":"date","attrib":{"date":"1987-06-07"},"text":"June 7, 1987","children":[],"tail":". Unless the parties otherwise agree, the agreements must be renegotiated before "},{"tag":"date","attrib":{"date":"1992-06-07"},"text":"June 7, 1992","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc6e04f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Employee protection arrangements made under this section shall ensure, during the 50-year lease term, the continuation of all collective bargaining rights enjoyed by transferred employees retained by the Airports Authority.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7074f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Service Retirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any Federal employee who transferred to the Airports Authority and who on ","children":[{"tag":"date","attrib":{"date":"1987-06-06"},"text":"June 6, 1987","children":[],"tail":", was subject to subchapter III of chapter 83 or chapter 84 of title 5, is subject to subchapter III of chapter 83 or chapter 84 for so long as continually employed by the Airports Authority without a break in service. For purposes of subchapter III of chapter 83 and chapter 84, employment by the Airports Authority without a break in continuity of service is deemed to be employment by the United States Government. The Airports Authority is the employing agency for purposes of subchapter III of chapter 83 and chapter 84 and shall contribute to the Civil Service Retirement and Disability Fund amounts required by subchapter III of chapter 83 and chapter 84."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7074f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s49107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to Records","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Airports Authority shall allow representatives of the Secretary of Transportation adequate access to employees and employee records of the Airports Authority when needed to carry out a duty or power related to the period before ","children":[{"tag":"date","attrib":{"date":"1987-06-07"},"text":"June 7, 1987","children":[],"tail":". The Secretary shall provide the Airports Authority access to employee records of transferring employees for appropriate purposes."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc7074f9-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/26"},"text":"Pub. L. 105–102, § 2(26)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2212"},"text":"111 Stat. 2212","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/225/s7/c/1/C"},"text":"Pub. L. 105–225, § 7(c)(1)(C)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1511"},"text":"112 Stat. 1511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc7074fa-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc7074fb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc7074fc-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","