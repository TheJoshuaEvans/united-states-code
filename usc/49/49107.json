":{"href":"/us/stat/100/3341-386"},"text":"100 Stat. 3341–386","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"49107(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(uncodified).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/500/tVI/s6008/g"},"text":"Pub. L. 99–500, title VI, § 6008(g)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/1783-384"},"text":"100 Stat. 1783–384","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/591/tVI/s6008/g"},"text":"Pub. L. 99–591, title VI, § 6008(g)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3341-387"},"text":"100 Stat. 3341–387","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the text of section 6008(a), (b)(2d and last sentences), (c), (d), and (f) of the Metropolitan Washington Airports Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/500"},"text":"Public Law 99–500","children":[],"tail":", 100 Stat, 1783–382, 1783–383, "},{"tag":"ref","attrib":{"href":"/us/pl/99/591"},"text":"Public Law 99–591","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-385"},"text":"100 Stat. 3341–385","children":[],"tail":", 3341–386, 3341–387) is omitted as obsolete."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “duty or power” are substituted for “functions” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc7074fd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc7074fe-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":" substituted “is subject to subchapter III” for “is subject to subchapter II”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc7074ff-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc707500-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1998 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/105/225/s7/c/3"},"text":"section 7(c)(3) of Pub. L. 105–225","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s49106"},"text":"section 49106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc707501-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Retirement Provisions Relating to Certain Members of Police Force of Metropolitan Washington Airports Authority","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/554/s1/a/3/tVI/s636"},"text":"Pub. L. 106–554, § 1(a)(3) [title VI, § 636]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/2763"},"text":"114 Stat. 2763","children":[],"tail":", 2763A–164, provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/554/s1/a/3/tVI/s636"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified MWAA Police Officer Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of this section, the term ‘qualified MWAA police officer’ means any individual who, as of the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2000-12-21"},"text":"Dec. 21, 2000","children":[],"tail":"]—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed as a member of the police force of the Metropolitan Washington Airports Authority (hereafter in this section referred to as an ‘MWAA police officer’); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is subject to the Civil Service Retirement System or the Federal Employees’ Retirement System by virtue of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s49107/b"},"text":"section 49107(b) of title 49","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility To Be Treated as a Law Enforcement Officer for Retirement Purposes.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any qualified MWAA police officer may, by written election submitted in accordance with applicable requirements under subsection (c), elect to be treated as a law enforcement officer (within the meaning of section 8331 or 8401 of title 5, United States Code, as applicable), and to have all prior service described in paragraph (2) similarly treated.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prior service described","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The service described in this paragraph is all service which an individual performed, prior to the effective date of such individual’s election under this section, as—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an MWAA police officer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member of the police force of the Federal Aviation Administration (hereafter in this section referred to as an ‘FAA police officer’).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Personnel Management shall prescribe any regulations necessary to carry out this section, including provisions relating to the time, form, and manner in which any election under this section shall be made. Such an election shall not be effective unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" it is made before the employee separates from service with the Metropolitan Washington Airports Authority, but in no event later than 1 year after the regulations under this subsection take effect; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" it is accompanied by payment of an amount equal to, with respect to all prior service of such employee which is described in subsection (b)(2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the employee deductions that would have been required for such service under chapter 83 or 84 of title 5, U.S.C. (as the case may be) if such election had then been in effect, minus","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total employee deductions and contributions under such chapter 83 and 84 (as applicable) that were actually made for such service,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"taking into account only amounts required to be credited to the Civil Service Retirement and Disability Fund. Any amount under paragraph (2) shall be computed with interest, in accordance with section 8334(e) of such title 5.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Government Contributions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever a payment under subsection (c)(2) is made by an individual with respect to such individual’s prior service (as described in subsection (b)(2)), the Metropolitan Washington Airports Authority shall pay into the Civil Service Retirement and Disability Fund any additional contributions for which it would have been liable, with respect to such service, if such individual’s election under this section had then been in effect (and, to the extent of any prior FAA police officer service, as if it had then been the employing agency). Any amount under this subsection shall be computed with interest, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s8334/e"},"text":"section 8334(e) of title 5","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Office of Personnel Management shall accept, for the purpose of this section, the certification of—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Metropolitan Washington Airports Authority (or its designee) concerning any service performed by an individual as an MWAA police officer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Federal Aviation Administration (or its designee) concerning any service performed by an individual as an FAA police officer.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"“(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursement To Compensate for Unfunded Liability.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Metropolitan Washington Airports Authority shall pay into the Civil Service Retirement and Disability Fund an amount (as determined by the Director of the Office of Personnel Management) equal to the amount necessary to reimburse the Fund for any estimated increase in the unfunded liability of the Fund (to the extent the Civil Service Retirement System is involved), and for any estimated increase in the supplemental liability of the Fund (to the extent the Federal Employees’ Retirement System is involved), resulting from the enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment method","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Metropolitan Washington Airports Authority shall pay the amount so determined in five equal annual installments, with interest (which shall be computed at the rate used in the most recent valuation of the Federal Employees’ Retirement System).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
