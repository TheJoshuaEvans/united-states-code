{"tag":"section","attrib":{"id":"idcbd56d18-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42302"},"text":null,"children":[{"tag":"num","attrib":{"value":"42302"},"text":"§ 42302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Consumer complaints","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd56d19-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d1a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain an accessible website through the Office of Aviation Consumer Protection to accept the submission of complaints from airline passengers regarding air travel service problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d1b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take appropriate actions to notify the public of such accessible website.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d1c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice to Passengers on the Internet","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An air carrier or foreign air carrier providing scheduled air transportation using any aircraft that as originally designed has a passenger capacity of 30 or more passenger seats shall include on the accessible website of the carrier—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d1d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42302/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accessible website, e-mail address, or telephone number of the air carrier for the submission of complaints by passengers about air travel service problems; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d1e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42302/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accessible website maintained pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d1f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Additional or Alternative Technologies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall periodically evaluate the benefits of using mobile phone applications or other widely used technologies to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d20-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide additional or alternative means for air passengers to submit complaints; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d21-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide such additional or alternative means as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d22-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air Ambulance Providers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each air ambulance provider shall include the accessible website, or a link to such accessible website, maintained pursuant to subsection (a) and the contact information for the Aviation Consumer Advocate established by section 424 of the FAA Reauthorization Act of 2018 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s42302"},"text":"49 U.S.C. 42302","children":[],"tail":" note) on—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d23-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42302/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any invoice, bill, or other communication provided to a passenger or customer of such provider; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d24-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42302/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the accessible website and any related mobile device application of such provider.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd56d25-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIV/s415/a"},"text":"Pub. L. 112–95, title IV, § 415(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/95"},"text":"126 Stat. 95","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIV"},"text":"Pub. L. 115–254, div. B, title IV","children":[],"tail":", §§ 405, 419(a), 423(a), "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3329"},"text":"132 Stat. 3329","children":[],"tail":", 3336, 3337; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tV/s520"},"text":"Pub. L. 118–63, title V, § 520","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1200"},"text":"138 Stat. 1200","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd56d26-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbd56d27-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbd56d28-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 424 of the FAA Reauthorization Act of 2018, referred to in subsec. (d), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s424"},"text":"section 424 of Pub. L. 115–254","children":[],"tail":", which is set out as a note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbd56d29-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" amended section generally. Prior to amendment, section related to various means by which passengers could register consumer complaints."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s419/a/1"},"text":"Pub. L. 115–254, § 419(a)(1)","children":[],"tail":", inserted “(including transportation by air ambulance (as defined by the Secretary of Transportation))” after “air transportation” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s423/a/1"},"text":"Pub. L. 115–254, § 423(a)(1)","children":[],"tail":", substituted “Each air carrier and foreign air carrier” for “An air carrier or foreign air carrier providing scheduled air transportation using any aircraft that as originally designed has a passenger capacity of 30 or more passenger seats” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s423/a/2"},"text":"Pub. L. 115–254, § 423(a)(2)","children":[],"tail":", substituted “carrier operates” for “air carrier operates”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s423/a/3"},"text":"Pub. L. 115–254, § 423(a)(3)","children":[],"tail":", substituted “carrier” for “air carrier”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s405"},"text":"Pub. L. 115–254, § 405","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s419/a/2"},"text":"Pub. L. 115–254, § 419(a)(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbd56d2a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcbd56d2b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Requirements of this section to begin to apply 60 days after ","children":[{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/s415/c"},"text":"section 415(c) of Pub. L. 112–95","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s42301"},"text":"section 42301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbd56d2c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rulemaking","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIV/s423/b"},"text":"Pub. L. 115–254, div. B, title IV, § 423(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3337"},"text":"132 Stat. 3337","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dB/tIV/s423/b"},"text":"“Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"], the Secretary of Transportation shall promulgate regulations to implement the requirements of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s42302"},"text":"section 42302 of title 49","children":[],"tail":", United States Code, as amended by this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbd56d2d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Aviation Consumer Advocate","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIV/s424"},"text":"Pub. L. 115–254, div. B, title IV, § 424","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3337"},"text":"132 Stat. 3337","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/118/15/dB/tII/s2202/s"},"text":"Pub. L. 118–15, div. B, title II, § 2202(s)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-09-30"},"text":"Sept. 30, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/84"},"text":"137 Stat. 84","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/34/tI/s102/s"},"text":"Pub. L. 118–34, title I, § 102(s)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2023-12-26"},"text":"Dec. 26, 2023","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/137/1114"},"text":"137 Stat. 1114","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/41/tI/s102/s"},"text":"Pub. L. 118–41, title I, § 102(s)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-03-08"},"text":"Mar. 8, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/22"},"text":"138 Stat. 22","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tV/s509"},"text":"Pub. L. 118–63, title V, § 509","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1193"},"text":"138 Stat. 1193","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tV/s509"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall review aviation consumer complaints received that allege a violation of law and, as appropriate, pursue enforcement or corrective actions that would be in the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In considering which cases to pursue for enforcement or corrective action under subsection (a), the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Air Carrier Access Act of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/435"},"text":"Public Law 99–435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/stat/100/1080"},"text":"100 Stat. 1080","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" unfair and deceptive practices by air carriers (including air ambulance operators), foreign air carriers, and ticket agents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms and conditions agreed to between passengers and air carriers (including air ambulance operators), foreign air carriers, or ticket agents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" aviation consumer protection and tarmac delay contingency planning requirements for both airports and airlines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protection of air ambulance consumers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"“(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aviation Consumer Advocate.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within the Aviation Consumer Protection Division of the Department of Transportation, there shall be an Aviation Consumer Advocate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Aviation Consumer Advocate shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist consumers in resolving carrier service complaints filed with the Aviation Consumer Protection Division;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the resolution by the Department of Transportation of carrier service complaints;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and recommend actions the Department can take to improve the enforcement of aviation consumer protection rules, protection of air ambulance consumers, and resolution of carrier service complaints; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify and recommend regulations and policies that can be amended to more effectively resolve carrier service complaints.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Reports","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, through the Aviation Consumer Advocate, shall submit to the appropriate committees of Congress [Committee on Commerce, Science, and Transportation of the Senate and Committee on Transportation and Infrastructure of the House of Representatives] an annual report summarizing the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of annual complaints received by the Department, including the number of complaints by the name of each air carrier and foreign air carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The total number of annual complaints by category of complaint.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of complaints referred in the preceding year for enforcement or corrective action by the Department.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any recommendations under paragraphs (2)(C) and (2)(D) of subsection (c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Such other data as the Aviation Consumer Advocate considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset on Reporting Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The reporting requirement of subsection (d) shall terminate on ","children":[{"tag":"date","attrib":{"date":"2028-10-01"},"text":"October 1, 2028","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[For definition of “ticket agent” as used in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s424"},"text":"section 424 of Pub. L. 115–254","children":[],"tail":", set out above, see "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/s401"},"text":"section 401 of Pub. L. 115–254","children":[],"tail":", set out as a Definitions of Terms in "},{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40101"},"text":"section 40101 of this title","children":[],"tail":".]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbd56d2e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"DOT Airline Consumer Complaint Investigations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIV/s408"},"text":"Pub. L. 112–95, title IV, § 408","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-1