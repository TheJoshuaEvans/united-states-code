{"tag":"section","attrib":{"id":"idca937812-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123"},"text":null,"children":[{"tag":"num","attrib":{"value":"5123"},"text":"§ 5123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca937813-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca937814-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person that knowingly violates this chapter or a regulation, order, special permit, or approval issued under this chapter is liable to the United States Government for a civil penalty of not more than $75,000 for each violation. A person acts knowingly when—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca937815-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person has actual knowledge of the facts giving rise to the violation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca937816-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a reasonable person acting in the circumstances and exercising reasonable care would have that knowledge.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca937817-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary finds that a violation under paragraph (1) results in death, serious illness, or severe injury to any person or substantial destruction of property, the Secretary may increase the amount of the civil penalty for such violation to not more than $175,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca937818-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the violation is related to training, a person described in paragraph (1) shall be liable for a civil penalty of at least $450.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca937819-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A separate violation occurs for each day the violation, committed by a person that transports or causes to be transported hazardous material, continues.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca93781a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hearing Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may find that a person has violated this chapter or a regulation prescribed or order, special permit, or approval issued under this chapter only after notice and an opportunity for a hearing. The Secretary shall impose a penalty under this section by giving the person written notice of the amount of the penalty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca93781b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In determining the amount of a civil penalty under this section, the Secretary shall consider—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca93781c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, circumstances, extent, and gravity of the violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93781d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the violator, the degree of culpability, any history of prior violations, the ability to pay, and any effect on the ability to continue to do business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca93781e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other matters that justice requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca93781f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions To Collect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General may bring a civil action in an appropriate district court of the United States to collect a civil penalty under this section and any accrued interest on the civil penalty as calculated in accordance with section 1005 of the Oil Pollution Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t33/s2705"},"text":"33 U.S.C. 2705","children":[],"tail":"). In the civil action, the amount and appropriateness of the civil penalty shall not be subject to review."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca937820-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compromise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may compromise the amount of a civil penalty imposed under this section before referral to the Attorney General.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca937821-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Setoff","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Government may deduct the amount of a civil penalty imposed or compromised under this section from amounts it owes the person liable for the penalty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca937822-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Depositing Amounts Collected","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts collected under this section shall be deposited in the Treasury as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca937823-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty for Obstruction of Inspections and Investigations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca937824-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary may impose a penalty on a person who obstructs or prevents the Secretary from carrying out inspections or investigations under subsection (c) or (i) of section 5121.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca937825-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For the purposes of this subsection, the term “obstructs” means actions that were known, or reasonably should have been known, to prevent, hinder, or impede an investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca937826-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Hazardous Material Operations After Nonpayment of Penalties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca937827-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided under paragraph (2), a person subject to the jurisdiction of the Secretary under this chapter who fails to pay a civil penalty assessed under this chapter, or fails to arrange and abide by an acceptable payment plan for such civil penalty, may not conduct any activity regulated under this chapter beginning on the 91st day after the date specified by order of the Secretary for payment of such penalty unless the person has filed a formal administrative or judicial appeal of the penalty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca937828-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall not apply to any person who is unable to pay a civil penalty because such person is a debtor in a case under chapter 11 of title 11.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca937829-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/i/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rulemaking","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 2 years after the date of enactment of this subsection, the Secretary, after providing notice and an opportunity for public comment, shall issue regulations that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca93782a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/i/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth procedures to require a person who is delinquent in paying civil penalties to cease any activity regulated under this chapter until payment has been made or an acceptable payment plan has been arranged; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca93782b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/i/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensures ","children":[{"tag":"ref","attrib":{"idref":"fn002030"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002030"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “ensure”."}],"tail":" that the person described in subparagraph (A)—"}],"tail":null},{"tag":"clause","attrib":{"id":"idca93782c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/i/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is notified in writing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idca93782d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5123/i/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is given an opportunity to respond before the person is required to cease the activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca93782e-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/780"},"text":"108 Stat. 780","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII"},"text":"Pub. L. 109–59, title VII","children":[],"tail":", §§ 7120(a)–(c), 7126, "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1905"},"text":"119 Stat. 1905","children":[],"tail":", 1906, 1909; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tIII/s33010"},"text":"Pub. L. 112–141, div. C, title III, § 33010","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/837"},"text":"126 Stat. 837","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca93782f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca937830-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca937831-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5123(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1809(a)(1) (1st sentence less 3d–16th words, 2d sentence words before 4th comma, 3d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633/s110/a/1"},"text":"Pub. L. 93–633, § 110(a)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2160"},"text":"88 Stat. 2160","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/615/s12/a/1"},"text":"Pub. L. 101–615, § 12(a)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3259"},"text":"104 Stat. 3259","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1809(a)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633"},"text":"Pub. L. 93–633","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2156"},"text":"88 Stat. 2156","children":[],"tail":", § 110(a)(3); added "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/615/s12/a/2"},"text":"Pub. L. 101–615, § 12(a)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3259"},"text":"104 Stat. 3259","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5123(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1809(a)(1) (2d sentence words after 4th comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5123(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1809(a)(1) (1st sentence 3d–16th words, 4th sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5123(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1809(a)(1) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5123(d), (e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1809(a)(2) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633/s110/a/2"},"text":"Pub. L. 93–633, § 110(a)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2160"},"text":"88 Stat. 2160","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5123(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1809(a)(2) (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5123(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1809(a)(2) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (1), the words “A person that knowingly violates this chapter or a regulation prescribed or order issued under this chapter is liable to the United States Government for a civil penalty of at least $250 but not more than $25,000 for each violation” are substituted for 49 App.:1809(a)(1) (1st sentence less 3d–16th words, 2d sentence words before 4th comma, 3d sentence) to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “impose” is substituted for “assessed” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the words “the violator” are substituted for “the person found to have committed such violation” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “imposed or compromised” are substituted for “of such penalty, when finally determined (or agreed upon in compromise)” to eliminate unnecessary words and for consistency. The words “liable for the penalty” are substituted for “charged” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca937832-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca937833-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to in subsec. (i)(3), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca937834-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s33010/1/A"},"text":"Pub. L. 112–141, § 33010(1)(A)","children":[],"tail":", in introductory provisions, struck out “at least $250 but” after “civil penalty of” and substituted “$75,000” for “$50,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s33010/1/B"},"text":"Pub. L. 112–141, § 33010(1)(B)","children":[],"tail":", substituted “$175,000” for “$100,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s33010/1/C"},"text":"Pub. L. 112–141, § 33010(1)(C)","children":[],"tail":", amended par. (3) generally. Prior to amendment, par. (3) read as follows: “If the violation is related to training, paragraph (1) shall be applied by substituting ‘$450’ for ‘$250’.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (h), (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s33010/2"},"text":"Pub. L. 112–141, § 33010(2)","children":[],"tail":", added subsecs. (h) and (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7120/a/1"},"text":"Pub. L. 109–59, § 7120(a)(1)","children":[],"tail":", in introductory provisions substituted “regulation, order, special permit, or approval issued” for “regulation prescribed or order issued” and “$50,000” for “$25,000”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7120/a/2"},"text":"Pub. L. 109–59, § 7120(a)(2)","children":[],"tail":", (3), added pars. (2) and (3) and redesignated former par. (2) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7126"},"text":"Pub. L. 109–59, § 7126","children":[],"tail":", substituted “Secretary may” for “Secretary of Transportation may”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7120/b"},"text":"Pub. L. 109–59, § 7120(b)","children":[],"tail":", substituted “regulation prescribed or order, special permit, or approval issued” for “regulation prescribed”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s7120/c"},"text":"Pub. L. 109–59, § 7120(c)","children":[],"tail":", substituted “section and any accrued interest on the civil penalty as calculated in accordance with section 1005 of the Oil Pollution Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t33/s2705"},"text":"33 U.S.C. 2705","children":[],"tail":"). In the civil action, the amount and appropriateness of the civil penalty shall not be subject to review.” for “section.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca937835-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca937836-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca937837-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2005 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tVII/s7120/d"},"text":"Pub. L. 109–59, title VII, § 7120(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1906"},"text":"119 Stat. 1906","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/59/tVII/s7120/d"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hearing requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by subsection (b) [amending this section] shall take effect on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":"], and shall apply with respect to violations described in "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5123/a"},"text":"section 5123(a) of title 49","children":[],"tail":", United States Code (as amended by this section), that occur on or after that date."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil actions to collect","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The amendment made by subsection (c) [amending this section] shall apply with respect to civil penalties imposed on violations described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s5123/a"},"text":"section 5123(a) of title 49","children":[],"tail":", United States Code (as amended by this section), that occur on or after the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
