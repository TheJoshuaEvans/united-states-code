{"tag":"section","attrib":{"id":"idcb4402d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30105"},"text":null,"children":[{"tag":"num","attrib":{"value":"30105"},"text":"§ 30105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Restriction on lobbying activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb4402d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No funds appropriated to the Secretary for the National Highway Traffic Safety Administration shall be available for any activity specifically designed to urge a State or local legislator to favor or oppose the adoption of any specific legislative proposal pending before any State or local legislative body.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4402d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appearance as Witness Not Barred","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not prohibit officers or employees of the United States from testifying before any State or local legislative body in response to the invitation of any member of that legislative body or a State executive office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb4402d6-47c4-11f1-9671-b5c725212f70"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tVII/s7104/a"},"text":"Pub. L. 105–178, title VII, § 7104(a)","children":[],"tail":", 