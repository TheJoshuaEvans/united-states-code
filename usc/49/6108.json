{"tag":"section","attrib":{"id":"idcad64d0a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6108"},"text":null,"children":[{"tag":"num","attrib":{"value":"6108"},"text":"§ 6108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Relationship to State laws","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Nothing in this chapter preempts State law or shall impose a new requirement on any State or mandate revisions to a one-call system.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcad64d0b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tVII/s7302/a"},"text":"Pub. L. 105–178, title VII, § 7302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/482"},"text":"112 Stat. 482","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
