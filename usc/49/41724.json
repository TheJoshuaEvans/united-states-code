{"tag":"section","attrib":{"id":"idcbc715e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724"},"text":null,"children":[{"tag":"num","attrib":{"value":"41724"},"text":"§ 41724.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Musical instruments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbc715e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc715e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Small instruments as carry-on baggage","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An air carrier providing air transportation shall permit a passenger to carry a violin, guitar, or other musical instrument in the aircraft cabin, without charging the passenger a fee in addition to any standard fee that carrier may require for comparable carry-on baggage, if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbc715e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the instrument can be stowed safely in a suitable baggage compartment in the aircraft cabin or under a passenger seat, in accordance with the requirements for carriage of carry-on baggage or cargo established by the Administrator; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc715e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" there is space for such stowage at the time the passenger boards the aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc715ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Larger instruments as carry-on baggage","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An air carrier providing air transportation shall permit a passenger to carry a musical instrument that is too large to meet the requirements of paragraph (1) in the aircraft cabin, without charging the passenger a fee in addition to the cost of the additional ticket described in subparagraph (E), if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbc715eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the instrument is contained in a case or covered so as to avoid injury to other passengers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc715ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the weight of the instrument, including the case or covering, does not exceed 165 pounds or the applicable weight restrictions for the aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc715ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the instrument can be stowed in accordance with the requirements for carriage of carry-on baggage or cargo established by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc715ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" neither the instrument nor the case contains any object not otherwise permitted to be carried in an aircraft cabin because of a law or regulation of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc715ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the passenger wishing to carry the instrument in the aircraft cabin has purchased an additional seat to accommodate the instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc715f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Large instruments as checked baggage","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An air carrier shall transport as baggage a musical instrument that is the property of a passenger traveling in air transportation that may not be carried in the aircraft cabin if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbc715f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sum of the length, width, and height measured in inches of the outside linear dimensions of the instrument (including the case) does not exceed 150 inches or the applicable size restrictions for the aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc715f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the weight of the instrument does not exceed 165 pounds or the applicable weight restrictions for the aircraft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc715f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the instrument can be stowed in accordance with the requirements for carriage of carry-on baggage or cargo established by the Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of enactment of this section, the Secretary shall issue final regulations to carry out subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41724/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirements of this section shall become effective on the date of issuance of the final regulations under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbc715f6-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIV/s403/a"},"text":"Pub. L. 112–95, title IV, § 403(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/84"},"text":"126 Stat. 84","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbc715f7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbc715f8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbc715f9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (b), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Final regulations, referred to in subsecs. (b) and (c), were issued ","children":[{"tag":"date","attrib":{"date":"2014-12-29"},"text":"Dec. 29, 2014","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"2015-03-06"},"text":"Mar. 6, 2015","children":[],"tail":". See 80 F.R. 161."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
