{"tag":"section","attrib":{"id":"idca879121-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1326"},"text":null,"children":[{"tag":"num","attrib":{"value":"1326"},"text":"§ 1326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of the Inspector General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca879122-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Inspector General of the Department of Transportation, in accordance with the mission of the Inspector General to prevent and detect fraud and abuse, shall have authority to review only the financial management, property management, and business operations of the Surface Transportation Board, including internal accounting and administrative control systems, to determine the Board’s compliance with applicable Federal laws, rules, and regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca879123-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Inspector General shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca879124-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1326/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" keep the Chairman of the Board, the Committee on Commerce, Science, and Transportation of the Senate, and the Committee on Transportation and Infrastructure of the House of Representatives fully and currently informed about problems relating to administration of the internal accounting and administrative control systems of the Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca879125-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1326/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue findings and recommendations for actions to address the problems referred to in paragraph (1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca879126-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1326/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit periodic reports to the Committee on Commerce, Science, and Transportation of the Senate, and the Committee on Transportation and Infrastructure of the House of Representatives that describe any progress made in implementing actions to address the problems referred to in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca879127-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this section, the Inspector General may exercise authorities granted to the Inspector General under subsections (a) and (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s406"},"text":"section 406 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca879128-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1326/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca879129-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1326/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Transportation for use by the Inspector General of the Department of Transportation such sums as may be necessary to cover expenses associated with activities pursuant to the authority exercised under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca87912a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1326/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reimbursable agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the absence of an appropriation under this subsection for an expense referred to in paragraph (1), the Inspector General and the Board shall have a reimbursement agreement to cover such expense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca87912b-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/110/s9"},"text":"Pub. L. 114–110, § 9","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2232"},"text":"129 Stat. 2232","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/97"},"text":"Pub. L. 117–286, § 4(b)(97)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4353"},"text":"136 Stat. 4353","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca87912c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca87912d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca87912e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “subsections (a) and (c) of "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s406"},"text":"section 406 of title 5","children":[],"tail":".” for “subsections (a) and (b) of section 6 of the Inspector General Act of 1978 (5 U.S.C. App.).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
