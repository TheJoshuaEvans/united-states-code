{"tag":"section","attrib":{"id":"idcb7d3bf3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32309"},"text":null,"children":[{"tag":"num","attrib":{"value":"32309"},"text":"§ 32309.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Civil penalty for labeling violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb7d3bf4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32309/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The definitions in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32304"},"text":"section 32304 of this title","children":[],"tail":" apply to this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7d3bf5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32309/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A manufacturer of a passenger motor vehicle distributed in commerce for sale in the United States that willfully fails to attach the label required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32304"},"text":"section 32304 of this title","children":[],"tail":" to a new passenger motor vehicle that the manufacturer manufactures or imports, or a dealer that fails to maintain that label as required under section 32304, is liable to the United States Government for a civil penalty of not more than $1,000 for each violation. Each failure to attach or maintain that label for each vehicle is a separate violation."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id"