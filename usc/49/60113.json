{"tag":"section","attrib":{"id":"idcc7c5c6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60113"},"text":null,"children":[{"tag":"num","attrib":{"value":"60113"},"text":"§ 60113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Customer-owned natural gas service lines","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1993-10-24"},"text":"October 24, 1993","children":[],"tail":", the Secretary of Transportation shall prescribe standards requiring an operator of a natural gas distribution pipeline that does not maintain customer-owned natural gas service lines up to building walls to advise its customers of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc7c5c6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60113/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements for maintaining those lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60113/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any resources known to the operator that could assist customers in carrying out the maintenance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60113/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information the operator has on operating and maintaining its lines that could assist customers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc7c5c70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60113/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the potential hazards of not maintaining the lines.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc7c5c71-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1318"},"text":"108 Stat. 1318","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/304"},"text":"Pub. L. 104–304","children":[],"tail":", §§ 9, 20(k), "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3801"},"text":"110 Stat. 3801","children":[],"tail":", 3805.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc7c5c72-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc7c5c73-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc7c5c74-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"