il":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60113(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1672(k).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/481"},"text":"Pub. L. 90–481","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/720"},"text":"82 Stat. 720","children":[],"tail":", § 3(k); added "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/508/s115/c"},"text":"Pub. L. 102–508, § 115(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/3297"},"text":"106 Stat. 3297","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc7c5c75-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc7c5c76-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304"},"text":"Pub. L. 104–304","children":[],"tail":" struck out subsec. (a) designation and heading, substituted “standards” for “regulations”, and struck out subsec. (b), which read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Actions To Promote Safety","children":[],"tail":".—Not later than one year after submitting the report required under section 115(b) of the Pipeline Safety Act of 1992 ("},{"tag":"ref","attrib":{"href":"/us/pl/102/508"},"text":"Public Law 102–508","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3296"},"text":"106 Stat. 3296","children":[],"tail":"), the Secretary, considering the report and in cooperation and coordination with appropriate State and local authorities, shall take appropriate action to promote the adoption of measures to improve the safety of customer-owned natural gas service lines.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc7c5c77-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc7c5c78-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Maintenance of Customer-Owned Service Lines","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/508/tI/s115/b"},"text":"Pub. L. 102–508, title I, § 115(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3296"},"text":"106 Stat. 3296","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/102/508/tI/s115/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"DOT safety review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 18 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":"], the Secretary of Transportation shall conduct a review of Department of Transportation and State rules, policies, procedures, and other measures with respect to the safety of customer-owned natural gas service lines, including the effectiveness of such rules, policies, procedures, and other measures. The Secretary of Transportation shall include in the review an evaluation of the extent to which lack of maintenance of customer-owned natural gas service lines raises safety concerns and shall make recommendations regarding maintenance of such lines, including the need for any legislative changes or regulatory action. In conducting the review and developing the recommendations, the Secretary of Transportation shall consider the following factors: State and local law, including law governing private property and rights, and including State pipeline safety regulation of distribution operators; the views of State and local regulatory authorities; the extent of operator compliance with the program for advising customers regarding maintenance of such lines required under section 18(b) of the Natural Gas Pipeline Safety Act of 1968 [see subsec. (a) of this section]; available accident information; the recommendations of the National Transportation Safety Board; costs; the civil liability implications of distribution operators taking responsibility for customer-owned service lines; and whether the service line maintenance information program required under such section 18(b) sufficiently addresses safety risks and concerns involving customer-owned service lines."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Operation and maintenance responsibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 18 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":"], the Secretary of Transportation shall conduct, with the participation of the operators of natural gas distribution facilities, a survey of owners of customer-owned service lines to determine the views of such owners regarding whether distribution companies should assume responsibility for the operation and maintenance of customer-owned service lines. In conducting the survey, the Secretary of Transportation shall ensure that such customers are aware of any potential safety benefits, any potential implementation issues (including any property rights or cost issues), the recommendations of the National Transportation Safety Board, and accidents that have occurred, related to customer-owned service lines."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Chapter 35 of title 44, United States Code (relating to coordination of Federal information policy) shall not apply to the conduct of the review or survey under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1992-10-24"},"text":"Oct. 24, 1992","children":[],"tail":"], the Secretary of Transportation shall transmit to Congress a report on the results of the review and survey conducted under this subsection, together with any recommendations (including legislative recommendations) regarding maintenance of customer-owned natural gas service lines.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
