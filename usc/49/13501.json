{"tag":"section","attrib":{"id":"idcaf2d5c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13501"},"text":null,"children":[{"tag":"num","attrib":{"value":"13501"},"text":"§ 13501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General jurisdiction","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Secretary and the Board have jurisdiction, as specified in this part, over transportation by motor carrier and the procurement of that transportation, to the extent that passengers, property, or both, are transported by motor carrier—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d5c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13501/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" between a place in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf2d5c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13501/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State and a place in another State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d5c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13501/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State and another place in the same State through another State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d5c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13501/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States and a place in a territory or possession of the United States to the extent the transportation is in the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d5c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13501/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States and another place in the United States through a foreign country to the extent the transportation is in the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d5c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13501/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the United States and a place in a foreign country to the extent the transportation is in the United States; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d5c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13501/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a reservation under the exclusive jurisdiction of the United States or on a public highway.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf2d5ca-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/859"},"text":"109 Stat. 859","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf2d5cb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf2d5cc-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"headin