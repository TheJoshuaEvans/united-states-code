{"tag":"section","attrib":{"id":"idcbfe047e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710"},"text":null,"children":[{"tag":"num","attrib":{"value":"44710"},"text":"§ 44710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Revocations of airman certificates for controlled substance violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbfe047f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, “controlled substance” has the same meaning given that term in section 102 of the Comprehensive Drug Abuse Prevention and Control Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbfe0480-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbfe0481-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator of the Federal Aviation Administration shall issue an order revoking an airman certificate issued an individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44703"},"text":"section 44703 of this title","children":[],"tail":" after the individual is convicted, under a law of the United States or a State related to a controlled substance (except a law related to simple possession of a controlled substance), of an offense punishable by death or imprisonment for more than one year if the Administrator finds that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbfe0482-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an aircraft was used to commit, or facilitate the commission of, the offense; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbfe0483-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual served as an airman, or was on the aircraft, in connection with committing, or facilitating the commission of, the offense.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe0484-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall issue an order revoking an airman certificate issued an individual under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44703"},"text":"section 44703 of this title","children":[],"tail":" if the Administrator finds that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbfe0485-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual knowingly carried out an activity punishable, under a law of the United States or a State related to a controlled substance (except a law related to simple possession of a controlled substance), by death or imprisonment for more than one year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbfe0486-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an aircraft was used to carry out or facilitate the activity; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbfe0487-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual served as an airman, or was on the aircraft, in connection with carrying out, or facilitating the carrying out of, the activity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe0488-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator has no authority under paragraph (1) of this subsection to review whether an airman violated a law of the United States or a State related to a controlled substance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbfe0489-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advice to Holders and Opportunity To Answer","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before the Administrator revokes a certificate under subsection (b) of this section, the Administrator must—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbfe048a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" advise the holder of the certificate of the charges or reasons on which the Administrator relies for the proposed revocation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe048b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the holder of the certificate an opportunity to answer the charges and be heard why the certificate should not be revoked.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbfe048c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Appeals","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbfe048d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual whose certificate is revoked by the Administrator under subsection (b) of this section may appeal the revocation order to the National Transportation Safety Board. The Board shall affirm or reverse the order after providing notice and an opportunity for a hearing on the record. When conducting the hearing, the Board is not bound by findings of fact of the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe048e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When an individual files an appeal with the Board under this subsection, the order of the Administrator revoking the certificate is stayed. However, if the Administrator advises the Board that safety in air transportation or air commerce requires the immediate effectiveness of the order—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbfe048f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the order remains effective; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbfe0490-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board shall make a final disposition of the appeal not later than 60 days after the Administrator so advises the Board.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe0491-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual substantially affected by an order of the Board under this subsection, or the Administrator when the Administrator decides that an order of the Board will have a significant adverse effect on carrying out this part, may obtain judicial review of the order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s46110"},"text":"section 46110 of this title","children":[],"tail":". The Administrator shall be made a party to the judicial review proceedings. Findings of fact of the Board are conclusive if supported by substantial evidence."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbfe0492-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Acquittal","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbfe0493-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator may not revoke, and the Board may not affirm a revocation of, an airman certificate under subsection (b)(2) of this section on the basis of an activity described in subsection (b)(2)(A) if the holder of the certificate is acquitted of all charges related to a controlled substance in an indictment or information arising from the activity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe0494-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Administrator has revoked an airman certificate under this section because of an activity described in subsection (b)(2)(A) of this section, the Administrator shall reissue a certificate to the individual if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbfe0495-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual otherwise satisfies the requirements for a certificate under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44703"},"text":"section 44703 of this title","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbfe0496-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbfe0497-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/e/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the individual subsequently is acquitted of all charges related to a controlled substance in an indictment or information arising from the activity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbfe0498-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/e/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the conviction on which a revocation under subsection (b)(1) of this section is based is reversed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbfe0499-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waivers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator may waive the requirement of subsection (b) of this section that an airman certificate of an individual be revoked if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbfe049a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a law enforcement official of the United States Government or of a State requests a waiver; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbfe049b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44710/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator decides that the waiver will facilitate law enforcement efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbfe049c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1191"},"text":"108 Stat. 1191","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/153/s2/c/3"},"text":"Pub. L. 112–153, § 2(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-08-03"},"text":"Aug. 3, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/1161"},"text":"126 Stat. 1161","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbfe049d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbfe049e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbfe049f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44710(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1429(c)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 609(