{"tag":"section","attrib":{"id":"idcc18432e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812"},"text":null,"children":[{"tag":"num","attrib":{"value":"44812"},"text":"§ 44812.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Temporary flight restrictions for unmanned aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc18432f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc184330-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary flight restrictions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Federal Aviation Administration shall, upon the request by an eligible entity, temporarily restrict unmanned aircraft operations over eligible large public gatherings.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc184331-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Denial","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding paragraph (1), the Administrator may deny a request for a temporary flight restriction sought under paragraph (1) if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc184332-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the temporary flight restriction would be inconsistent with aviation safety or security, would create a hazard to people or property on the ground, or would unnecessarily interfere with the efficient use of the airspace;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc184333-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the entity seeking the temporary flight restriction does not comply with the requirements in subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc184334-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the eligibility requirements in subsections (c) and (d) have not been met;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc184335-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a flight restriction exists to the airspace overlying the same location as the temporary flight restriction sought under this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc184336-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator determines appropriate for any other reason.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc184337-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc184338-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advance notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Eligible entities may only request a temporary flight restriction under subsection (a) not less than 30 calendar days prior to the eligible large public gathering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc184339-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required information","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Eligible entities seeking a temporary flight restriction under this section shall provide the Administrator with all relevant information, including the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc18433a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Geographic boundaries of the stadium or other venue hosting the eligible large public gathering, as applicable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc18433b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The dates and anticipated starting and ending times for the large public gathering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc18433c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Points of contact for the requesting eligible entity and the on-scene incident command responsible for securing the large public gathering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc18433d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information the Administrator considers necessary to establish the restriction.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc18433e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Large Public Gatherings.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc18433f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a temporary flight restriction under this section, large public gatherings hosted in a stadium or other venue shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc184340-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be hosted in a stadium or other venue that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc184341-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has previously hosted events qualifying for the application of special security instructions in accordance with section 521 of the Transportation, Treasury, and Independent Agencies Appropriations Act, 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199"},"text":"Public Law 108–199","children":[],"tail":"); "},{"tag":"ref","attrib":{"idref":"fn002160"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002160"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc184342-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not enclosed;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc184343-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have an estimated attendance of at least 30,000 people; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc184344-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be advertised in the public domain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc184345-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional gatherings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To be eligible for a temporary flight restriction under this section, large public gatherings hosted in a venue other than a stadium or other venue described in paragraph (1)(A) shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc184346-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have an estimated attendance of at least 100,000 people;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc184347-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be primarily outdoors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc184348-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have a defined and static geographical boundary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc184349-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be advertised in the public domain.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc18434a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Entities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An entity eligible to request a temporary flight restriction under subsection (a) shall be a credentialed law enforcement organization of the Federal Government or a State, local, Tribal, or territorial government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc18434b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timeliness","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall make every practicable effort to assess eligibility and establish temporary flight restrictions under subsection (a) in a timely fashion.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc18434c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any temporary flight restriction designated under this section shall be published by the Administrator in a publicly accessible manner at least 2 days prior to the start of the eligible large public gathering.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc18434d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition on Operations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No person may operate an unmanned aircraft within a temporary flight restriction established under this section unless—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc18434e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator authorizes the operation for operational or safety purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc18434f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operation is being conducted for safety, security, or compliance oversight purposes and is authorized by the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc184350-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft operation is conducted with the approval of the eligible entity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc184351-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed as prohibiting the Administrator from authorizing the operation of an aircraft, including an unmanned aircraft system, over, under, or within a specified distance from an eligible large public gathering for which a temporary flight restriction has been established under this section or cancelling a temporary flight restriction established under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc184352-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44812/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to prevent the Administrator from using existing processes or procedures to meet the intent of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc184353-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIX/s935/a"},"text":"Pub. L. 118–63, title IX, § 935(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1370"},"text":"138 Stat. 1370","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc184354-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc184355-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc184356-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 521 of the Transportation, Treasury, and Independent Agencies Appropriations Act, 2004 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199"},"text":"Public Law 108–199","children":[],"tail":"), referred to in subsec. (c)(1)(A)(i), probably means "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dF/tV/s521"},"text":"section 521 of title V of div. F of Pub. L. 108–199","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s40103"},"text":"section 40103 of this title","children":[],"tail":". The Act is comprised of div. F of "},{"tag":"ref","attrib":{"href":"/us/pl/108/199"},"text":"Pub. L. 108–199","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
