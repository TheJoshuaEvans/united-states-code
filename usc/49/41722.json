{"tag":"section","attrib":{"id":"idcbc715ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41722"},"text":null,"children":[{"tag":"num","attrib":{"value":"41722"},"text":"§ 41722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Delay reduction actions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbc715cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41722/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Scheduling Reduction Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may request that air carriers meet with the Administrator of the Federal Aviation Administration to discuss flight reductions at severely congested airports to reduce overscheduling and flight delays during hours of peak operation if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc715d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41722/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator determines that it is necessary to convene such a meeting; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc715d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41722/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary determines that the meeting is necessary to meet a serious transportation need or achieve an important public benefit.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41722/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meeting Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any meeting under subsection (a)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc715d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41722/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be chaired by the Administrator;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc715d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41722/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be open to all scheduled air carriers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc715d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41722/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be limited to discussions involving the airports and time periods described in the Administrator’s determination.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41722/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Flight Reduction Targets","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before any such meeting is held, the Administrator shall establish flight reduction targets for the meeting and notify the attending air carriers of those targets not less than 48 hours before the meeting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41722/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delay Reduction Offers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier attending the meeting shall make any offer to meet a flight reduction target to the Administrator rather than to another carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41722/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transcript","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall ensure that a transcript of the meeting is kept and made available to the public not later than 3 business days after the conclusion of the meeting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbc715d9-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/tIV/s422/a"},"text":"Pub. L. 108–176, title IV, § 422(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2552"},"text":"117 Stat. 2552","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbc715da-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbc715db-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcbc715dc-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbc715dd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Schedule Reduction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIV/s413"},"text":"Pub. L. 112–95, title IV, § 413","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/89"},"text":"126 Stat. 89","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/95/tIV/s413"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If the Administrator of the Federal Aviation Administration determines that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft operations of air carriers during any hour at an airport exceed the hourly maximum departure and arrival rate established by the Administrator for such operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the operations in excess of the maximum departure and arrival rate for such hour at such airport are likely to have a significant adverse effect on the safe and efficient use of navigable airspace,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Administrator shall convene a meeting of such carriers to reduce pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41722"},"text":"section 41722 of title 49","children":[],"tail":", United States Code, on a voluntary basis, the number of such operations so as not to exceed the maximum departure and arrival rate."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"No Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the air carriers participating in a meeting with respect to an airport under subsection (a) are not able to agree to a reduction in the number of flights to and from the airport so as not to exceed the maximum departure and arrival rate, the Administrator shall take such action as is necessary to ensure such reduction is implemented.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subsequent Schedule Increases","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsequent to any reduction in operations under subsection (a) or (b) at an airport, if the Administrator determines that the hourly number of aircraft operations at that airport is less than the amount that can be handled safely and efficiently, the Administrator shall ensure that priority is given to United States air carriers in permitting additional aircraft operations with respect to that hour.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
