{"tag":"section","attrib":{"id":"idcb0f8565-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120"},"text":null,"children":[{"tag":"num","attrib":{"value":"20120"},"text":"§ 20120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb0f8566-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002071"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002071"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. No subsec. (b) has been enacted."}],"tail":" "},{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Beginning not later than ","children":[{"tag":"date","attrib":{"date":"2009-12-31"},"text":"December 31, 2009","children":[],"tail":", the Secretary of Transportation shall make available to the public and publish on its public Web site an annual report that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0f8567-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides a summary of railroad safety and hazardous materials compliance inspections and audits that Federal or State inspectors conducted in the prior fiscal year organized by type of alleged violation, including track, motive power and equipment, signal, grade crossing, operating practices, accident and incident reporting, and hazardous materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f8568-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provides a summary of all enforcement actions taken by the Secretary or the Federal Railroad Administration during the prior fiscal year, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0f8569-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of civil penalties assessed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f856a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the initial amount of civil penalties assessed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f856b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of civil penalty cases settled;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f856c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the final amount of civil penalties assessed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f856d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the difference between the initial and final amounts of civil penalties assessed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f856e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of administrative hearings requested and completed related to hazardous materials transportation law violations or enforcement actions against individuals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f856f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of cases referred to the Attorney General for civil or criminal prosecution; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f8570-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number and subject matter of all compliance orders, emergency orders, or precursor agreements;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f8571-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" analyzes the effect of the number of inspections conducted and enforcement actions taken on the number and rate of reported accidents and incidents and railroad safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f8572-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" provide ","children":[{"tag":"ref","attrib":{"idref":"fn002072"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002072"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be “provides”."}],"tail":" the information required by paragraphs (2) and (3)—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0f8573-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each Class I railroad individually; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f8574-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in the aggregate for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb0f8575-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/4/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Class II railroads;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb0f8576-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/4/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Class III railroads;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb0f8577-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/4/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" hazardous materials shippers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb0f8578-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/4/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" individuals;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f8579-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" identifies the number of locomotive engineer certification denial or revocation cases appealed to and the average length of time it took to be decided by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0f857a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Locomotive Engineer Review Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f857b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an administrative hearing officer or administrative law judge; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0f857c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator of the Federal Railroad Administration;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f857d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provides an explanation regarding any changes in the Secretary’s or the Federal Railroad Administration’s enforcement programs or policies that may substantially affect the information reported; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f857e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20120/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes any additional information that the Secretary determines is useful to improve the transparency of its enforcement program.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0f857f-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tIII/s303/a"},"text":"Pub. L. 110–432, div. A, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4878"},"text":"122 Stat. 4878","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11316/d"},"text":"Pub. L. 114–94, div. A, title XI, § 11316(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1676"},"text":"129 Stat. 1676","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb0f8580-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb0f8581-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial 