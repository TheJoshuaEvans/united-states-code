{"tag":"section","attrib":{"id":"idcc09ea87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44739"},"text":null,"children":[{"tag":"num","attrib":{"value":"44739"},"text":"§ 44739.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Pets on airplanes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc09ea88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44739/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"It shall be unlawful for any person to place a live animal in an overhead storage compartment of an aircraft operated under part 121 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09ea89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44739/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator may impose a civil penalty under section 46301 for each violation of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc09ea8a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIV/s417/a"},"text":"Pub. L. 115–254, div. B, title IV, § 417(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3334"},"text":"132 Stat. 3334","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
