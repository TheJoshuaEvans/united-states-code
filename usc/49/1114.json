{"tag":"section","attrib":{"id":"idca7baa4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114"},"text":null,"children":[{"tag":"num","attrib":{"value":"1114"},"text":"§ 1114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure, availability, and use of information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca7baa4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7baa4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subsections (b), (c), (d), and (f) of this section, a copy of a record, information, or investigation submitted or received by the National Transportation Safety Board, or a member or employee of the Board, shall be made available to the public on identifiable request and at reasonable cost. This subsection does not require the release of information described by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b"},"text":"section 552(b) of title 5","children":[],"tail":" or protected from disclosure by another law of the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7baa4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall deposit in the Treasury amounts received under paragraph (1) to be credited to the appropriation of the Board as offsetting collections.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7baa50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certain Confidential Information.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7baa51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board may disclose confidential information described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":", including trade secrets, only—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7baa52-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to another department, agency, or instrumentality of the United States Government when requested for official use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7baa53-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to a committee of Congress having jurisdiction over the subject matter to which the information is related, when requested by that committee;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7baa54-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a judicial proceeding under a court order that preserves the confidentiality of the information without impairing the proceeding; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7baa55-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the public to protect health and safety after giving notice to any interested person to whom the information is related and an opportunity for that person to comment in writing, or orally in closed session, on the proposed disclosure, if the delay resulting from notice and opportunity for comment would not be detrimental to health and safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7baa56-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Information disclosed under paragraph (1) of this subsection may be disclosed only in a way designed to preserve its confidentiality.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7baa57-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection of Voluntary Submission of Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of law, neither the Board, nor any agency receiving information from the Board, shall disclose voluntarily provided safety-related information if that information is not related to the exercise of the Board’s accident or incident investigation authority under this chapter and if the Board finds that the disclosure of the information would inhibit the voluntary provision of that type of information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7baa58-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cockpit Recordings and Transcripts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7baa59-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Confidentiality of recordings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the Board may not disclose publicly any part of a cockpit voice or video recorder recording or transcript of oral communications by and between flight crew members and ground stations related to an accident or incident investigated by the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7baa5a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (b) and (g), the Board shall make public any part of a transcript, any written depiction of visual information obtained from a video recorder, or any still image obtained from a video recorder the Board decides is relevant to the accident or incident—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7baa5b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Board holds a public hearing on the accident or incident, at the time of the hearing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7baa5c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Board does not hold a public hearing, at the time a majority of the other factual reports on the accident or incident are placed in the public docket.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7baa5d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References to information in making safety recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not prevent the Board from referring at any time to cockpit voice or video recorder information in making safety recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7baa5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Surface Vehicle Recordings and Transcripts.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7baa5f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Confidentiality of recordings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), the Board may not disclose publicly any part of a surface vehicle voice or video recorder recording or transcript of oral communications by or among drivers, train employees, or other operating employees responsible for the movement and direction of the vehicle or vessel, or between such operating employees and company communication centers, related to an accident investigated by the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7baa60-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsections (b) and (g), the Board shall make public any part of a transcript, any written depiction of visual information obtained from a video recorder, or any still image obtained from a video recorder the Board decides is relevant to the accident—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7baa61-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Board holds a public hearing on the accident, at the time of the hearing; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7baa62-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the Board does not hold a public hearing, at the time a majority of the other factual reports on the accident are placed in the public docket.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7baa63-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"References to information in making safety recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subsection does not prevent the Board from referring at any time to voice or video recorder information in making safety recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7baa64-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Drug Tests","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7baa65-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding section 503(e) of the Supplemental Appropriations Act, 1987 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/71"},"text":"Public Law 100–71","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/101/471"},"text":"101 Stat. 471","children":[],"tail":"), the Secretary of Transportation shall provide the following information to the Board when requested in writing by the Board:"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7baa66-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any report of a confirmed positive toxicological test, verified as positive by a medical review officer, conducted on an officer or employee of the Department of Transportation under post-accident, unsafe practice, or reasonable suspicion toxicological testing requirements of the Department, when the officer or employee is reasonably associated with the circumstances of an accident or incident under the investigative jurisdiction of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7baa67-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any laboratory record documenting that the test is confirmed positive.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7baa68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided by paragraph (3) of this subsection, the Board shall maintain the confidentiality of, and exempt from disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/3"},"text":"section 552(b)(3) of title 5","children":[],"tail":"—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7baa69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a laboratory record provided the Board under paragraph (1) of this subsection that reveals medical use of a drug allowed under applicable regulations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7baa6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical information provided by the tested officer or employee related to the test or a review of the test.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7baa6b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board may use a laboratory record made available under paragraph (1) of this subsection to develop an evidentiary record in an investigation of an accident or incident if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7baa6c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the fitness of the tested officer or employee is at issue in the investigation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7baa6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of that record is necessary to develop the evidentiary record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7baa6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Investigations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7baa6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, neither the Board, nor any agency receiving information from the Board, shall disclose records or information relating to its participation in foreign aircraft accident investigations; except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7baa70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board shall release records pertaining to such an investigation when the country conducting the investigation issues its final report or 2 years following the date of the accident, whichever occurs first; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7baa71-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board may disclose records and information when authorized to do so by the country conducting the investigation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7baa72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Safety recommendations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subsection shall restrict the Board at any time from referring to foreign accident investigation information in making safety recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7baa73-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1114/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Privacy Protections","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before making public any still image obtained from a video recorder under subsection (c)(2) or subsection (d)(2), the Board shall take such action as appropriate to protect from public disclosure any information that readily identifies an individual, including a decedent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca7baa74-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/749"},"text":"108 Stat. 749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/291/tI"},"text":"Pub. L. 104–291, title I","children":[],"tail":", §§ 102, 103, "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3452"},"text":"110 Stat. 3452","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/424"},"text":"Pub. L. 106–424","children":[],"tail":", §§ 3(b)(2), 5(a), (b), "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1884"},"text":"114 Stat. 1884","children":[],"tail":", 1885; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dC/s1104/a"},"text":"Pub. L. 115–254, div. C, § 1104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3429"},"text":"132 Stat. 3429","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tXII/s1208/a"},"text":"Pub. L. 118–63, title XII, § 1208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1424"},"text":"138 Stat. 1424","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca7baa75-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca7baa76-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca7baa77-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attri