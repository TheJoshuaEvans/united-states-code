ag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1114(d)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1903(b) (11)(A).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633"},"text":"Pub. L. 93–633","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2156"},"text":"88 Stat. 2156","children":[],"tail":", § 304(b)(11); added "},{"tag":"html:span","attrib":{},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/641/s6"},"text":"Pub. L. 101–641, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/4656"},"text":"104 Stat. 4656","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1114(d)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1903(b) (11)(B).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1114(d)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1903(b) (11)(C).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “record, information, or investigation” are substituted for “communication, document, investigation, or other report, or information” to eliminate unnecessary words. The words “of the United States” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), before clause (A), the words “Notwithstanding any other provision of law” are omitted as surplus. The word “relevant” is substituted for “relevant and pertinent” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “officer or employee” are substituted for “employee” for clarity and consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), before clause (A), the words “maintain the confidentiality of” are substituted for “maintain in confidence” for consistency in the revised title and with other titles of the Code. In clause (A), the words “of a confirmed and verified toxicological test” are omitted as unnecessary because of the restatement of the source provisions in paragraph (1) of this subsection.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(3), the words “laboratory record made available under paragraph (1) of this subsection” are substituted for “such a laboratory record” for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca7e1a78-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca7e1a79-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 503(e) of the Supplemental Appropriations Act, 1987, referred to in subsec. (e)(1), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/71/s503/e"},"text":"section 503(e) of Pub. L. 100–71","children":[],"tail":", which is set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s7301"},"text":"section 7301 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca7e1a7a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s1208/a/1"},"text":"Pub. L. 118–63, § 1208(a)(1)","children":[],"tail":", substituted “Certain Confidential Information” for “Trade Secrets” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s1208/a/2"},"text":"Pub. L. 118–63, § 1208(a)(2)","children":[],"tail":", inserted heading and substituted “confidential information described in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":", including trade secrets,” for “information related to a trade secret referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t18/s1905"},"text":"section 1905 of title 18","children":[],"tail":"” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1104/a/1/C/i"},"text":"Pub. L. 115–254, § 1104(a)(1)(C)(i)","children":[],"tail":", inserted heading and substituted “Except as provided in paragraph (2), the Board” for “The Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1104/a/1/C/ii"},"text":"Pub. L. 115–254, § 1104(a)(1)(C)(ii)","children":[],"tail":", designated second sentence of par. (1) as par. (2) and amended it generally. Prior to amendment, second sentence of par. (1) read as follows: “However, the Board shall make public any part of a transcript or any written depiction of visual information the Board decides is relevant to the accident or incident—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) if the Board holds a public hearing on the accident or incident, at the time of the hearing; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) if the Board does not hold a public hearing, at the time a majority of the other factual reports on the accident or incident are placed in the public docket.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Former par. (2) redesignated (3).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1104/a/1/A"},"text":"Pub. L. 115–254, § 1104(a)(1)(A)","children":[],"tail":", (B), redesignated par. (2) as (3) and inserted heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1104/a/2/B/i"},"text":"Pub. L. 115–254, § 1104(a)(2)(B)(i)","children":[],"tail":", substituted “Except as provided in paragraph (2), the Board” for “The Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1104/a/2/B/ii"},"text":"Pub. L. 115–254, § 1104(a)(2)(B)(ii)","children":[],"tail":", designated second sentence of par. (1) as par. (2) and amended it generally. Prior to amendment, second sentence of par. (1) read as follows: “However, the Board shall make public any part of a transcript or any written depiction of visual information that the Board decides is relevant to the accident—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(A) if the Board holds a public hearing on the accident, at the time of the hearing; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(B) if the Board does not hold a public hearing, at the time a majority of the other factual reports on the accident are placed in the public docket.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Former par. (2) redesignated (3).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1104/a/2/A"},"text":"Pub. L. 115–254, § 1104(a)(2)(A)","children":[],"tail":", redesignated par. (2) as (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1104/a/3"},"text":"Pub. L. 115–254, § 1104(a)(3)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/424"},"text":"Pub. L. 106–424","children":[],"tail":", §§ 3(b)(2), 5(b)(2), designated existing provisions as par. (1), substituted “(d), and (f)” for “and (e)” in first sentence, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/424/s5/a/1"},"text":"Pub. L. 106–424, § 5(a)(1)","children":[],"tail":", struck out “Voice” after “Cockpit” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/424/s5/a/2"},"text":"Pub. L. 106–424, § 5(a)(2)","children":[],"tail":", (3), substituted “cockpit voice or video recorder” for “cockpit voice recorder” in first sentence and inserted “or any written depiction of visual information” after “transcript” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/424/s5/a/2"},"text":"Pub. L. 106–424, § 5(a)(2)","children":[],"tail":", substituted “cockpit voice or video recorder” for “cockpit voice recorder”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/424/s5/b/1/B"},"text":"Pub. L. 106–424, § 5(b)(1)(B)","children":[],"tail":", which directed the addition of subsec. (d) after subsec. (e), was executed by adding subsec. (d) before subsec. (e) to reflect the probable intent of Congress. Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/424/s5/b/1/A"},"text":"Pub. L. 106–424, § 5(b)(1)(A)","children":[],"tail":", redesignated subsecs. (d) and (e) as (e) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/291/s102/1"},"text":"Pub. L. 104–291, § 102(1)","children":[],"tail":", substituted “(b), (c), and (e)” for “(b) and (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/291/s103"},"text":"Pub. L. 104–291, § 103","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/291/s102/2"},"text":"Pub. L. 104–291, § 102(2)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca7e1a7b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca7e1a7c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Electronic Availability of Public Docket Records","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tXII/s1217"},"text":"Pub. L. 118–63, title XII, § 1217","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1431"},"text":"138 Stat. 1431","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tXII/s1217"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 24 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"], the National Transportation Safety Board shall make all records included in the public docket of an accident or incident investigation conducted by the Board (or the public docket of a study, report, or other product issued by the Board) electronically available in a publicly accessible database on a website of the Board, regardless of the date on which such public docket or record was created."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Database","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out subsection (a), the Board may utilize the multimodal accident database management system established pursuant to section 1108 of the FAA Reauthorization Act of 2018 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1119"},"text":"49 U.S.C. 1119","children":[],"tail":" note) or such other publicly available database as the Board determines appropriate."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Briefings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Board shall provide the appropriate committees of Congress [Committee on Commerce, Science, and Transportation of the Senate and Committee on Transportation and Infrastructure of the House of Representatives] an annual briefing on the implementation of this section until requirements of subsection (a) are fulfilled. Such briefings shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of public dockets that have been made electronically available pursuant to this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of public dockets that were unable to be made electronically available, including all reasons for such inability.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the terms ‘public docket’ and ‘record’ have the same meanings given such terms in section 801.3 of title 49, Code of Federal Regulations, as in effect on the date of enactment of this Act.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
