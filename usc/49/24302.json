ildren":[{"tag":"html:p","attrib":{},"text":"45:543(a)(6).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24302(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:543(a)(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24302(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:543(a)(2)(A) (1st sentence words after comma), (3), (8).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24302(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:543(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the words “is composed of the following 9 directors, each of whom must be a citizen” are substituted for “consisting of nine individuals who are citizens” for consistency in the revised title. The words “as follows” are omitted as surplus. In clause (A), the words “ex officio” are omitted as surplus. In clause (C)(ii), the words “chief executive officer of a State” are substituted for “Governor” for consistency in the revised title and with other titles of the United States Code. In clause (D), the text of 45:543(a)(1)(D)(i) and the words “after ","children":[{"tag":"date","attrib":{"date":"1983-01-01"},"text":"January 1, 1983","children":[],"tail":"” are omitted as executed."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “by the President” and “registered as” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3) and (4), the word “selected” is substituted for “appointed” for consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(6), the word “only” is added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the text of 45:543(a)(7) is omitted as obsolete because preferred stockholder representatives are always part of Amtrak’s board of directors. The text of 45:543(c) (words after “all stockholders”) is omitted as obsolete because Congress eliminated common stockholder representatives when it reconstituted the board.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “direct or indirect” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the word “performing” is substituted for “engaged in the actual performance of” to eliminate unnecessary words. The word “board” is added for clarity. The words “and powers” are added for consistency in the revised title and with other titles of the Code. The word “reasonable” is substituted for “which is reasonably required” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “the membership of” and “in the case of” are omitted as surplus. The words “occurring before the end of the term for which the predecessor of that individual was appointed is appointed for the remainder of the term” are substituted for “shall be appointed only for the unexpired term of the member he is appointed to succeed” for clarity and consistency in the revised title and with other titles of the Code. The words “under subsection (a)(1)(C)” the 2d time they appear are substituted for “paragraph (1)(B) of this subsection” in 45:543(a)(8) to correct an erroneous cross-reference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb2e7f11-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb2e7f12-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22202/a/1/A"},"text":"Pub. L. 117–58, § 22202(a)(1)(A)","children":[],"tail":", substituted “Chief Executive Officer” for “President”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22202/a/1/B"},"text":"Pub. L. 117–58, § 22202(a)(1)(B)","children":[],"tail":", inserted “, at least 1 of whom shall be an individual with a disability (as defined in section 3 of the Americans with Disabilities Act of 1990 ("},{"tag":"ref","attrib":{"href":"/us/usc/t42/s12102"},"text":"42 U.S.C. 12102","children":[],"tail":")) who has a demonstrated history of, or experience with, accessibility, mobility, and inclusive transportation in passenger rail or commuter rail” before period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22202/a/2"},"text":"Pub. L. 117–58, § 22202(a)(2)","children":[],"tail":", struck out before period at end “and try to provide adequate and balanced representation of the major geographic regions of the United States served by Amtrak”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4) to (6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22202/a/4"},"text":"Pub. L. 117–58, § 22202(a)(4)","children":[],"tail":", added pars. (4) to (6) and struck out former par. (4) which read as follows: “The Board shall elect a chairman and a vice chairman, other than the President of Amtrak, from among its membership. The vice chairman shall serve as chairman in the absence of the chairman.” Former par. (5) redesignated (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s22202/a/3"},"text":"Pub. L. 117–58, § 22202(a)(3)","children":[],"tail":", redesignated par. (5) as (7)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s11205/1/A"},"text":"Pub. L. 114–94, § 11205(1)(A)","children":[],"tail":", substituted “10 directors” for “9 directors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s11205/1/B"},"text":"Pub. L. 114–94, § 11205(1)(B)","children":[],"tail":", inserted “, who shall serve as a nonvoting member of the Board” after “Amtrak”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s11205/1/C"},"text":"Pub. L. 114–94, § 11205(1)(C)","children":[],"tail":", substituted “8” for “7”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s11205/2"},"text":"Pub. L. 114–94, § 11205(2)","children":[],"tail":", inserted “who are eligible to vote” after “serving”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":" amended section generally. Prior to amendment, section related, in subsec. (a), to establishment, duties, membership, and confirmation procedure of Reform Board, in subsec. (b), to selection of the Board of Directors, and in subsec. (c), to authority of Reform Board to recommend to Congress a plan to implement transfer of Amtrak’s infrastructure assets and responsibilities to a new separately governed corporation."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134"},"text":"Pub. L. 105–134","children":[],"tail":" amended section generally. Prior to amendment, section related, in subsec. (a), to composition and terms of Amtrak board of directors, in subsec. (b), to cumulative voting by stockholders, in subsec. (c), to conflicts of interest of directors, in subsec. (d), to pay and expenses of directors, in subsec. (e), to vacancies on board, and in subsec. (f), to bylaws of board."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb2e7f13-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb2e7f14-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb2e7f15-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tII/s202/b"},"text":"Pub. L. 110–432, div. B, title II, § 202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4912"},"text":"122 Stat. 4912","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/432/dB/tII/s202/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect 6 months after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":"]. The members of the Amtrak Board of Directors serving as of the date of enactment of this Act may continue to serve for the remainder of the term to which they were appointed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb2e7f16-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22202/b"},"text":"Pub. L. 117–58, div. B, title II, § 22202(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/698"},"text":"135 Stat. 698","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dB/tII/s22202/b"},"text":"“None of the amendments made by subsection (a) [amending this section] may be construed as affecting the term of any director serving on the Amtrak Board of Directors under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24302/a/1/C"},"text":"section 24302(a)(1)(C) of title 49","children":[],"tail":", United States Code, as of the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
