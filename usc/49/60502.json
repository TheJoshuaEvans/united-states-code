{"tag":"section","attrib":{"id":"idcc8842e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60502"},"text":null,"children":[{"tag":"num","attrib":{"value":"60502"},"text":"§ 60502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Energy Regulatory Commission","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Federal Energy Regulatory Commission has the duties and powers related to the establishment of a rate or charge for the transportation of oil by pipeline or the valuation of that pipeline that were vested on ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":", in the Interstate Commerce Commission or an officer or component of the Interstate Commerce Commission."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcc8842e9-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1329"},"text":"108 Stat. 1329","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc8842ea-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc8842eb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc8842ec-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":