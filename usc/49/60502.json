":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:101 (note prec.).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/473/s4/c/1/B"},"text":"Pub. L. 95–473, § 4(c)(1)(B)","children":[],"tail":", (2) (related to § 402(b) of Department of Energy Organization Act), "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1470"},"text":"92 Stat. 1470","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “duties and powers . . . that were vested . . . in” are coextensive with, and substituted for, “transferred to, and vested in . . . all functions and authority of” for clarity and to eliminate unnecessary words. The word “regulatory” is omitted as surplus. The words “on ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":"” are added to reflect the effective date of the transfer of the duties and powers to the Federal Energy Regulatory Commission."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc8842ed-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc8842ee-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Interstate Commerce Commission and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Interstate Commerce Commission abolished and functions of Commission transferred, except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", to Surface Transportation Board effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1302"},"text":"section 1302 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s101"},"text":"section 101 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":". References to Interstate Commerce Commission deemed to refer to Surface Transportation Board, a member or employee of the Board, or Secretary of Transportation, as appropriate, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s205"},"text":"section 205 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
