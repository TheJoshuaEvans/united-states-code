{"tag":"section","attrib":{"id":"idcbb67396-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41102"},"text":null,"children":[{"tag":"num","attrib":{"value":"41102"},"text":"§ 41102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General, temporary, and charter air transportation certificates of air carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbb67397-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Issuance","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may issue a certificate of public convenience and necessity to a citizen of the United States authorizing the citizen to provide any part of the following air transportation the citizen has applied for under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41108"},"text":"section 41108 of this title","children":[],"tail":":"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbb67398-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" air transportation as an air carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb67399-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" temporary air transportation as an air carrier for a limited period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb6739a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charter air transportation as a charter air carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb6739b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings Required for Issuance","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbb6739c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Before issuing a certificate under subsection (a) of this section, the Secretary must find that the citizen is fit, willing, and able to provide the transportation to be authorized by the certificate and to comply with this part and regulations of the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb6739d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to the findings under paragraph (1) of this subsection, the Secretary, before issuing a certificate under subsection (a) of this section for foreign air transportation, must find that the transportation is consistent with the public convenience and necessity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb6739e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Temporary Certificates","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may issue a certificate under subsection (a) of this section for interstate air transportation (except the transportation of passengers) or foreign air transportation for a temporary period of time (whether the application is for permanent or temporary authority) when the Secretary decides that a test period is desirable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbb6739f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41102/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to decide if the projected services, efficiencies, methods, and prices and the projected results will materialize and remain for a sustained period of time; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb673a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41102/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to evaluate the new transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb673a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41102/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Foreign Air Transportation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall submit each decision authorizing the provision of foreign air transportation to the President under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41307"},"text":"section 41307 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbb673a2-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1119"},"text":"108 Stat. 1119","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbb673a3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbb673a4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbb673a5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"h