{"tag":"section","attrib":{"id":"idcc0779ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44734"},"text":null,"children":[{"tag":"num","attrib":{"value":"44734"},"text":"§ 44734.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training of flight attendants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc077a00-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44734/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training Required","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In addition to other training required under this chapter, each air carrier shall provide to flight attendants employed or contracted by such air carrier initial and annual training regarding—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc077a01-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44734/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serving alcohol to passengers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077a02-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44734/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognizing intoxicated passengers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077a03-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44734/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" dealing with disruptive passengers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077a04-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44734/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recognizing and responding to potential human trafficking victims.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc077a05-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44734/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Situational Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the training required under subsection (a), each air carrier shall provide to flight attendants situational training on the proper method for dealing with intoxicated passengers who act in a belligerent manner.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc077a06-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44734/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc077a07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44734/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “air carrier” means a person, including a commercial enterprise, that has been issued an air carrier operating certificate under section 44705.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc077a08-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44734/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Flight attendant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “flight attendant” has the meaning given that term in section 44728(g).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc077a09-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIII/s309/a"},"text":"Pub. L. 112–95, title III, § 309(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/64"},"text":"126 Stat. 64","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/190/tII/s2113"},"text":"Pub. L. 114–190, title II, § 2113","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/628"},"text":"130 Stat. 628","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc077a0a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc077a0b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc077a0c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2016—Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190"},"text":"Pub. L. 114–190","children":[],"tail":" added par. (4)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
