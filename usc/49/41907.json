{"tag":"section","attrib":{"id":"idcbd2fc5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41907"},"text":null,"children":[{"tag":"num","attrib":{"value":"41907"},"text":"§ 41907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Weighing mail","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The United States Postal Service may weigh mail transported by aircraft between places in Alaska and make statistical and administrative computations necessary in the interest of mail service. When the Secretary of Transportation decides that additional or more frequent weighings of mail are advisable or necessary to carry out this part, the Postal Service shall provide the weighings, but it is not required to provide them for continuous periods of more than 30 days.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcbd2fc5f-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1157"},"text":"108 Stat. 1157","children":[],"tail":", § 41910; renumbered § 41907 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/110/405/s2/b/6"},"text":"Pub. L. 110–405, § 2(b)(6)","children":[],"tail":", (7)(B), "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4289"},"text":"122 Stat. 4289","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tV/s539/g"},"text":"Pub. L. 115–254, div. B, title V, § 539(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3370"},"text":"132 Stat. 3370","children":[],"tail":"