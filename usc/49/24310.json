{"tag":"section","attrib":{"id":"idcb30efc6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24310"},"text":null,"children":[{"tag":"num","attrib":{"value":"24310"},"text":"§ 24310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Management accountability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb30efc7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Within 3 years after the date of enactment of the Passenger Rail Investment and Improvement Act of 2008, and 2 years thereafter, the Inspector General of the Department of Transportation shall complete an overall assessment of the progress made by Amtrak management and the Department of Transportation in implementing the provisions of that Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb30efc8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The management assessment undertaken by the Inspector General may include a review of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb30efc9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24310/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effectiveness in improving annual financial planning;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb30efca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24310/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effectiveness in implementing improved financial accounting;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb30efcb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24310/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" efforts to implement minimum train performance standards;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb30efcc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24310/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" progress maximizing revenues, minimizing Federal subsidies, and improving financial results; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb30efcd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24310/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other aspect of Amtrak operations the Inspector General finds appropriate to review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb30efce-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dB/tII/s221/a"},"text":"Pub. L. 110–432, div. B, title II, § 221(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4931"},"text":"122 Stat. 4931","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb30efcf-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb30efd0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb30efd1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Passenger Rail Investment and Improvement Act of 2008, referred to in subsec. (a), is div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4907"},"text":"122 Stat. 4907","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2008 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s20101"},"text":"section 20101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb30efd2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 24310, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/914"},"text":"108 Stat. 914","children":[],"tail":", allowed petition or application for assistance in upgrading facilities to correct dangerous conditions or State and local violations, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/105/134/tIV/s403"},"text":"Pub. L. 105–134, title IV, § 403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2585"},"text":"111 Stat. 2585","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
