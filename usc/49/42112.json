{"tag":"section","attrib":{"id":"idcbd2fc92-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42112"},"text":null,"children":[{"tag":"num","attrib":{"value":"42112"},"text":"§ 42112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor requirements of air carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd2fc93-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd2fc94-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “copilot” means an employee whose duties include assisting or relieving the pilot in manipulating an aircraft and who is qualified to serve as, and has in effect an airman certificate authorizing the employee to serve as, a copilot.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd2fc95-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “pilot” means an employee who is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd2fc96-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42112/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responsible for manipulating or who manipulates the flight controls of an aircraft when under way, including the landing and takeoff of an aircraft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd2fc97-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42112/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualified to serve as, and has in effect an airman certificate authorizing the employee to serve as, a pilot.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd2fc98-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties of Air Carriers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An air carrier shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd2fc99-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain rates of compensation, maximum hours, and other working conditions and relations for its pilots and copilots who are providing interstate air transportation in the 48 contiguous States and the District of Columbia to conform with decision number 83, ","children":[{"tag":"date","attrib":{"date":"1934-05-10"},"text":"May 10, 1934","children":[],"tail":", National Labor Board, notwithstanding any limitation in that decision on the period of its effectiveness;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd2fc9a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain rates of compensation for its pilots and copilots who are providing foreign air transportation or air transportation only in one territory or possession of the United States; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd2fc9b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42112/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with title II of the Railway Labor Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s181"},"text":"45 U.S.C. 181","children":[],"tail":" et seq.) as long as it holds its certificate."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd2fc9c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42112/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Annual Rate of Compensation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A minimum annual rate under subsection (b)(2) of this section may not be less than the annual rate required to be paid for comparable service to a pilot or copilot under subsection (b)(1) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd2fc9d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42112/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collective Bargaining","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not prevent pilots or copilots of an air carrier from obtaining by collective bargaining higher rates of compensation or more favorable working conditions or relations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd2fc9e-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1160"},"text":"108 Stat. 1160","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd2fc9f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbd2fca0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbd2fca1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42112(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1371(k)(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s401/k"},"text":"Pub. L. 85–726, § 401(k)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/756"},"text":"72 Stat. 756","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42112(b), (c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1371(k)(1), (2), (4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"42112(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1371(k)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “properly” and “currently” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “providing” is substituted for “engaged in” for consistency in the revised title. In clause (1), the words “48 contiguous States and the District of Columbia” are substituted for “the continental United States (not including Alaska)” for clarity and consistency in the revised title. In clause (2), the words “overseas or” are omitted as obsolete. The word “only” is substituted for “wholly” for consistency. In clause (3), the words “as long as it holds” are substituted for “upon the holding” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “under subsection (b)(1) of this section” are substituted for “said decision 83 . . . engaged in interstate air transportation within the continental United States (not including Alaska)” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “or other employees” are omitted as unnecessary because this section only applies to pilots and copilots.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbd2fca2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbd2fca3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Railway Labor Act, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/act/1926-05-20/ch347"},"text":"act May 20, 1926, ch. 347","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/44/577"},"text":"44 Stat. 577","children":[],"tail":". Title II of the Act was added by "},{"tag":"ref","attrib":{"href":"/us/act/1936-04-10/ch166"},"text":"act Apr. 10, 1936, ch. 166","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1189"},"text":"49 Stat. 1189","children":[],"tail":", and is classified generally to subchapter II (§ 181 et seq.) of chapter 8 of Title 45, Railroads. For complete classification of this Act to the Code, see "},{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"section 151 of Title 45","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbd2fca4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbd2fca5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Labor Integration","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/161/dK/tI/s117"},"text":"Pub. L. 110–161, div. K, title I, § 117","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/121/2382"},"text":"121 Stat. 2382","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/161/dK/tI/s117"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Labor Integration","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to any covered transaction involving two or more covered air carriers that results in the combination of crafts or classes that are subject to the Railway Labor Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"45 U.S.C. 151","children":[],"tail":" et seq.), sections 3 and 13 of the labor protective provisions imposed by the Civil Aeronautics Board in the Allegheny-Mohawk merger (as published at 59 C.A.B. 45) shall apply to the integration of covered employees of the covered air carriers; except that—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the same collective bargaining agent represents the combining crafts or classes at each of the covered air carriers, that collective bargaining agent’s internal policies regarding integration, if any, will not be affected by and will supersede the requirements of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of any collective bargaining agreement that may be applicable to the terms of integration involving covered employees of a covered air carrier shall not be affected by the requirements of this section as to the employees covered by that agreement, so long as those provisions allow for the protections afforded by sections 3 and 13 of the Allegheny-Mohawk provisions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘air carrier’ means an air carrier that holds a certificate issued under chapter 411 of title 49, United States Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered air carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘covered air carrier’ means an air carrier that is involved in a covered transaction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered employee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘covered employee’ means an employee who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a temporary employee; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a member of a craft or class that is subject to the Railway Labor Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t45/s151"},"text":"45 U.S.C. 151","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered transaction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘covered transaction’ means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a transaction for the combination of multiple air carriers into a single air carrier; and which","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" involves the transfer of ownership or control of—","children":[],"tail":null},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"“(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent or more of the equity securities (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t11/s101"},"text":"section 101 of title 11","children":[],"tail":", United States Code) of an air carrier; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"“(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 50 percent or more (by value) of the assets of the air carrier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall not apply to any covered transaction involving a covered air carrier that took place before the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2007-12-26"},"text":"Dec. 26, 2007","children":[],"tail":"]."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effectiveness of Provision","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section shall become effective on the date of enactment of this Act and shall continue in effect in fiscal years after fiscal year 2008.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
