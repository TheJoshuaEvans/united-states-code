{"tag":"section","attrib":{"id":"idcbbd9fee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310"},"text":null,"children":[{"tag":"num","attrib":{"value":"41310"},"text":"§ 41310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Discriminatory practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbbd9fef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier or foreign air carrier may not subject a person, place, port, or type of traffic in foreign air transportation to unreasonable discrimination.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbd9ff0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review and Negotiation of Discriminatory Foreign Charges","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbd9ff1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall survey charges imposed on an air carrier by the government of a foreign country or another foreign entity for the use of airport property or airway property in foreign air transportation. If the Secretary of Transportation decides that a charge is discriminatory, the Secretary promptly shall report the decision to the Secretary of State. The Secretaries of State and Transportation promptly shall begin negotiations with the appropriate government to end the discrimination. If the discrimination is not ended in a reasonable time through negotiation, the Secretary of Transportation shall establish a compensating charge equal to the discriminatory charge. With the approval of the Secretary of State, the Secretary of the Treasury shall impose the compensating charge on a foreign air carrier of that country as a condition to accepting the general declaration of the aircraft of the foreign air carrier when it lands or takes off.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbd9ff2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Treasury shall maintain an account to credit money collected under paragraph (1) of this subsection. An air carrier shall be paid from the account an amount certified by the Secretary of Transportation to compensate the air carrier for the discriminatory charge paid to the government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbd9ff3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions Against Discriminatory Activity","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbd9ff4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation may take actions the Secretary considers are in the public interest to eliminate an activity of a government of a foreign country or another foreign entity, including a foreign air carrier, when the Secretary, on the initiative of the Secretary or on complaint, decides that the activity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbbd9ff5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an unjustifiable or unreasonable discriminatory, predatory, or anticompetitive practice against an air carrier; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbd9ff6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposes an unjustifiable or unreasonable restriction on access of an air carrier to a foreign market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbd9ff7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation may deny, amend, modify, suspend, revoke, or transfer under paragraph (1) of this subsection a foreign air carrier permit or tariff under section 41302, 41303, 41304(a), 41504(c), 41507, or 41509 of this title.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbd9ff8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing of, and Acting on, Complaints","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbd9ff9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An air carrier, computer reservations system firm, or a department, agency, or instrumentality of the United States Government may file a complaint under subsection (c) or (g) of this section with the Secretary of Transportation. The Secretary shall approve, deny, or dismiss the complaint, set the complaint for a hearing or investigation, or begin another proceeding proposing remedial action not later than 60 days after receiving the complaint. The Secretary may extend the period for acting for additional periods totaling not more than 30 days if the Secretary decides that with additional time it is likely that a complaint can be resolved satisfactorily through negotiations with the government of the foreign country or foreign entity. The Secretary must act not later than 90 days after receiving the complaint. However, the Secretary may extend this 90-day period for not more than an additional 90 days if, on the last day of the initial 90-day period, the Secretary finds that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbbd9ffa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" negotiations with the government have progressed to a point that a satisfactory resolution of the complaint appears imminent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbd9ffb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an air carrier or computer reservations system firm has not been subjected to economic injury by the government or entity as a result of filing the complaint; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbd9ffc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public interest requires additional time before the Secretary acts on the complaint.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbd9ffd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out paragraph (1) of this subsection and subsection (c) of this section, the Secretary of Transportation shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbbd9ffe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" solicit the views of the Secretaries of Commerce and State and the United States Trade Representative;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbd9fff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give an affected air carrier or foreign air carrier reasonable notice and an opportunity to submit written evidence and arguments within the time limits of this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbda000-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the President under section 41307 or 41509(f) of this title actions proposed by the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbda001-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Review","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbda002-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretaries of State, the Treasury, and Transportation and the heads of other departments, agencies, and instrumentalities of the Government shall keep under review, to the extent of each of their jurisdictions, each form of discrimination or unfair competitive practice to which an air carrier is subject when providing foreign air transportation or a computer reservations system firm is subject when providing services with respect to airline service. Each Secretary and head shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbbda003-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" take appropriate action to eliminate any discrimination or unfair competitive practice found to exist; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbda004-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request Congress to enact legislation when the authority to eliminate the discrimination or unfair practice is inadequate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda005-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation shall report to Congress annually on each action taken under paragraph (1) of this subsection and on the continuing program to eliminate discrimination and unfair competitive practices. The Secretaries of State and the Treasury each shall give the Secretary of Transportation information necessary to prepare the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbda006-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 30 days after acting on a complaint under this section, the Secretary of Transportation shall report to the Committee on Transportation and Infrastructure of the House of Representatives and the Committee on Commerce, Science, and Transportation of the Senate on action taken under this section on the complaint.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbda007-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions Against Discriminatory Activity by Foreign CRS Systems","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may take such actions as the Secretary considers are in the public interest to eliminate an activity of a foreign air carrier that owns or markets a computer reservations system, or of a computer reservations system firm whose principal offices are located outside the United States, when the Secretary, on the initiative of the Secretary or on complaint, decides that the activity, with respect to airline service—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbda008-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an unjustifiable or unreasonable discriminatory, predatory, or anticompetitive practice against a computer reservations system firm whose principal offices are located inside the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbda009-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41310/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" imposes an unjustifiable or unreasonable restriction on access of such a computer reservations system to a foreign market.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbbda00a-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1130"},"text":"108 Stat. 1130","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/9"},"text":"Pub. L. 104–287, § 5(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3389"},"text":"110 Stat. 3389","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tVII/s741"},"text":"Pub. L. 106–181, title VII, § 741","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/174"},"text":"114 Stat. 174","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbbda00b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbbda00c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbbda00d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41310(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1374(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s404/b"},"text":"Pub. L. 85–726, § 404(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/760"},"text":"72 Stat. 760","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(a)(4)(C) (related to 49 App.:1374(b)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 