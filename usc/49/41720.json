{"tag":"section","attrib":{"id":"idcbc715a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720"},"text":null,"children":[{"tag":"num","attrib":{"value":"41720"},"text":"§ 41720.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Joint venture agreements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbc715aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc715ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Joint venture agreement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “joint venture agreement” means an agreement between two or more major air carriers on or after ","children":[{"tag":"date","attrib":{"date":"1998-01-01"},"text":"January 1, 1998","children":[],"tail":", with regard to (A) code-sharing, blocked-space arrangements, long-term wet leases (as defined in section 207.1 of title 14, Code of Federal Regulations) of a substantial number (as defined by the Secretary by regulation) of aircraft, or frequent flyer programs, or (B) any other cooperative working arrangement (as defined by the Secretary by regulation) between 2 or more major air carriers that affects more than 15 percent of the total number of available seat miles offered by the major air carriers."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc715ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Major air carrier","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “major air carrier” means a passenger air carrier that is certificated under chapter 411 of this title and included in Carrier Group III under criteria contained in section 04 of part 241 of title 14, Code of Federal Regulations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Submission of Joint Venture Agreement","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At least 30 days before a joint venture agreement may take effect, each of the major air carriers that entered into the agreement shall submit to the Secretary—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc715ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a complete copy of the joint venture agreement and all related agreements; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc715af-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information and documentary material that the Secretary may require by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715b0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Extension of Waiting Period.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc715b1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may extend the 30-day period referred to in subsection (b) until—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbc715b2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a joint venture agreement with regard to code-sharing, the 150th day following the last day of such period; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbc715b3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of any other joint venture agreement, the 60th day following the last day of such period.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc715b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of reasons for extension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary extends the 30-day period referred to in subsection (b), the Secretary shall publish in the Federal Register the Secretary’s reasons for making the extension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Termination of Waiting Period","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"At any time after the date of submission of a joint venture agreement under subsection (b), the Secretary may terminate the waiting periods referred to in subsections (b) and (c) with respect to the agreement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The effectiveness of a joint venture agreement may not be delayed due to any failure of the Secretary to issue regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Memorandum To Prevent Duplicative Reviews","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Promptly after the date of enactment of this section, the Secretary shall consult with the Assistant Attorney General of the Antitrust Division of the Department of Justice in order to establish, through a written memorandum of understanding, preclearance procedures to prevent unnecessary duplication of effort by the Secretary and the Assistant Attorney General under this section and the antitrust laws of the United States, respectively.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prior Agreements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"With respect to a joint venture agreement entered into before the date of enactment of this section as to which the Secretary finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbc715b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parties submitted the agreement to the Secretary before such date of enactment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbc715ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the parties submitted all information on the agreement requested by the Secretary,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the waiting period described in paragraphs (2) and (3) shall begin on the date, as determined by the Secretary, on which all such information was submitted and end on the last day to which the period could be extended under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41720/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Statutory Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The authority granted to the Secretary under this section shall not in any way limit the authority of the Attorney General to enforce the antitrust laws as defined in the first section of the Clayton Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"15 U.S.C. 12","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbc715bc-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/dC/tI/s110/f/1"},"text":"Pub. L. 105–277, div. C, title I, § 110(f)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-588"},"text":"112 Stat. 2681–588","children":[],"tail":", § 41716; renumbered § 41720 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/tII/s231/b/1"},"text":"Pub. L. 106–181, title II, § 231(b)(1)","children":[],"tail":", title VII, § 709, "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/108"},"text":"114 Stat. 108","children":[],"tail":", 159.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbc715bd-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbc715be-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbc715bf-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (f) and (g), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277"},"text":"Pub. L. 105–277","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcbc715c0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/277/s110/f/1"},"text":"Pub. L. 105–277, § 110(f)(1)","children":[],"tail":", which directed amendment of subchapter I of chapter 417 by adding this section at the end, without specifying a Code title or Act, was executed by adding this section at the end of this subchapter to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbc715c1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s231/b/1"},"text":"Pub. L. 106–181, § 231(b)(1)","children":[],"tail":", renumbered "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s41716"},"text":"section 41716 of this title","children":[],"tail":" as this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/s709"},"text":"Pub. L. 106–181, § 709","children":[],"tail":", substituted “an agreement between two or more major air carriers” for “an agreement entered into by a major air carrier”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbc715c2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbc715c3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
