{"tag":"section","attrib":{"id":"idcadb080a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703"},"text":null,"children":[{"tag":"num","attrib":{"value":"6703"},"text":"§ 6703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National culvert removal, replacement, and restoration grant program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcadb080b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb080c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Director","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Director” means the Director of the United States Fish and Wildlife Service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb080d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Indian tribe","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Indian Tribe” has the meaning given the term in section 4 of the Indian Self-Determination and Education Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t25/s5304"},"text":"25 U.S.C. 5304","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb080e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “program” means the annual competitive grant program established under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb080f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Secretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Secretary” means the Secretary of Transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0810-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Undersecretary","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “Undersecretary” means the Undersecretary of Commerce for Oceans and Atmosphere.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb0811-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Undersecretary, shall establish an annual competitive grant program to award grants to eligible entities for projects for the replacement, removal, and repair of culverts or weirs that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb0812-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" would meaningfully improve or restore fish passage for anadromous fish; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0813-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" with respect to weirs, may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb0814-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" infrastructure to facilitate fish passage around or over the weir; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb0815-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" weir improvements.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb0816-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Entities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity eligible to receive a grant under the program is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb0817-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0818-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit of local government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0819-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an Indian Tribe.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb081a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Selection Process","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in consultation with the Undersecretary and the Director, shall establish a process for determining criteria for awarding grants under the program, subject to subsection (e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb081b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prioritization","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, in consultation with the Undersecretary and the Director, shall establish procedures to prioritize awarding grants under the program to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcadb081c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" projects that would improve fish passage for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcadb081d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anadromous fish stocks listed as an endangered species or a threatened species under section 4 of the Endangered Species Act of 1973 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t16/s1533"},"text":"16 U.S.C. 1533","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb081e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anadromous fish stocks identified by the Undersecretary or the Director that could reasonably become listed as an endangered species or a threatened species under that section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb081f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anadromous fish stocks identified by the Undersecretary or the Director as prey for endangered species, threatened species, or protected species, including Southern resident orcas (Orcinus orcas); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcadb0820-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/e/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" anadromous fish stocks identified by the Undersecretary or the Director as climate resilient stocks; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcadb0821-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" projects that would open up more than 200 meters of upstream habitat before the end of the natural habitat.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb0822-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of a project carried out with a grant to a State or a unit of local government under the program shall be not more than 80 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb0823-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Technical Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in consultation with the Undersecretary and the Director, shall develop a process to provide technical assistance to Indian Tribes and underserved communities to assist in the project design and grant process and procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb0824-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Expenses","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Of the amounts made available for each fiscal year to carry out the program, the Secretary, the Undersecretary, and the Director may use not more than 2 percent to pay the administrative expenses necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcadb0825-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6703/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to carry out the program $800,000,000 for each of fiscal years 2022 through 2026.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcadb0826-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI/s21203/a"},"text":"Pub. L. 117–58, div. B, title I, § 21203(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/676"},"text":"135 Stat. 676","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
