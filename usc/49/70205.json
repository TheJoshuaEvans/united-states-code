{"tag":"section","attrib":{"id":"idcc8ab425-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205"},"text":null,"children":[{"tag":"num","attrib":{"value":"70205"},"text":"§ 70205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National multimodal cooperative freight research program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc8ab426-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, the Secretary of Transportation (referred to in this section as the “Secretary”) shall establish and support a national cooperative freight transportation research program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8ab427-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration by National Academy of Sciences.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8ab428-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall enter into an agreement with the National Academy of Sciences to support and carry out administrative and management activities under the program established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab429-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Advisory committee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To assist the National Academy of Sciences in carrying out this subsection, the National Academy shall establish an advisory committee, the members of which represent a cross-section of multimodal freight stakeholders, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8ab42a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Department of Transportation and other relevant Federal departments and agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab42b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State (including the District of Columbia) departments of transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab42c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" units of local government, including public port authorities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab42d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab42e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" institutions of higher education;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab42f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" labor organizations representing employees in freight industries; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab430-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/b/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" private sector entities representing various transportation modes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8ab431-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8ab432-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National research agenda.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8ab433-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The advisory committee established under subsection (b)(2), in consultation with interested parties, shall recommend a national research agenda for the program in accordance with subsection (d), which shall include a multiyear strategic plan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab434-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action by interested parties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For purposes of subparagraph (A), an interested party may—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc8ab435-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit to the advisory committee research proposals;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8ab436-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in merit reviews of research proposals and peer reviews of research products; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8ab437-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" receive research results.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab438-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research contracts and grants.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8ab439-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Academy of Sciences may award research contracts and grants under the program established under subsection (a) through—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc8ab43a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" open competition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8ab43b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" merit review, conducted on a regular basis.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab43c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Evaluation.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"idcc8ab43d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Peer review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A contract or grant for research under subparagraph (A) may allow peer review of the research results.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc8ab43e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Programmatic evaluations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Academy of Sciences may conduct periodic programmatic evaluations on a regular basis of a contract or grant for research under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab43f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Dissemination of findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Academy of Sciences shall disseminate the findings of any research conducted under this paragraph to relevant researchers, practitioners, and decisionmakers through—","children":[],"tail":null},{"tag":"c