","attrib":{},"text":"The national research agenda under subsection (c)(1) shall consider research in the following areas:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8ab44b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Improving the efficiency and resiliency of freight movement, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8ab44c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the connections between rural areas and domestic and foreign markets;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab44d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximizing infrastructure utility, including improving urban curb-use efficiency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab44e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" quantifying the national impact of blocked railroad crossings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab44f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improved techniques for estimating and quantifying public benefits derived from freight transportation projects; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab450-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/d/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" low-cost methods to reduce congestion at bottlenecks.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab451-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Adapting to future trends in freight, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8ab452-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" considering the impacts of e-commerce;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab453-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab454-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" zero-emissions transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab455-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Workforce considerations in freight, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8ab456-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/d/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" diversifying the freight transportation industry workforce; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8ab457-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/d/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" creating and transitioning a workforce capable of designing, deploying, and operating emerging technologies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8ab458-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8ab459-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of an activity carried out under this section shall be up to 100 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8ab45a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of non-federal funds","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to using funds made available to carry out this section, the National Academy of Sciences may seek and accept additional funding from public and private entities capable of accepting funding from the Department of Transportation, States, units of local government, nonprofit entities, and the private sector.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8ab45b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is authorized to be appropriated to the Secretary $3,750,000 for each fiscal year to carry out the program established under subsection (a), to remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8ab45c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s70205/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program established under subsection (a) shall terminate 5 years after the date of enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc8ab45d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI/s21204/a"},"text":"Pub. L. 117–58, div. B, title I, § 21204(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/677"},"text":"135 Stat. 677","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc8ab45e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc8ab45f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc8ab460-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (a) and (g), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
