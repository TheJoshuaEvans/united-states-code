{"tag":"section","attrib":{"id":"idcb20278b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22104"},"text":null,"children":[{"tag":"num","attrib":{"value":"22104"},"text":"§ 22104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State rail plan financing","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb20278c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22104/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Entitlement and Uses","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On the first day of each fiscal year, each State is entitled to $36,000 of the amounts made available under section 22108 ","children":[{"tag":"ref","attrib":{"idref":"fn002077"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002077"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title during that fiscal year to be used—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb20278d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22104/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish, update, revise, and modify the State plan required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s22102"},"text":"section 22102 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb20278e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22104/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to carry out projects described in section 22101(a)(1), (2), or (3) of this title, as designated by the State, if those projects meet the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s22101/c/1/B"},"text":"section 22101(c)(1)(B) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb20278f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22104/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each State must apply for amounts under this section not later than the first day of the fiscal year for which the amounts are available. However, for any fiscal year for which the authorization of appropriations for financial assistance under this chapter has not been enacted by the first day of the fiscal year, the State must apply for amounts under this section not later than 60 days after the date of enactment of a law authorizing the appropriations for that fiscal year. Not later than 60 days after receiving an application, the Secretary of Transportation shall consider the application and notify the State of the approval or disapproval of the application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb202790-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22104/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amounts provided under this section remain available to a State for obligation for the first 3 months after the end of the fiscal year for which the amounts were made available. Amounts not applied for under this section or that remain unobligated after the first 3 months after the end of the fiscal year for which the amounts were made available are available to the Secretary for projects meeting the requirements of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb202791-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/896"},"text":"108 Stat. 896","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb202792-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb202793-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb202794-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Secti