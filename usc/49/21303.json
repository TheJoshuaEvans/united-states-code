ldren":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1816"},"text":"94 Stat. 1816","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s16/6/A"},"text":"Pub. L. 100–342, § 16(6)(A)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/635"},"text":"102 Stat. 635","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 3, 1992","children":[],"tail":", Pub. L,. 102–365, §§ 4(a)(2), (c)(2), 9(a)(2), "},{"tag":"html:a","attrib":{"href":"/us/stat/106/973"},"text":"106 Stat. 973","children":[],"tail":", 974, 977."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:64a(a)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939/s5/a/2"},"text":"Mar. 4, 1907, ch. 2939, § 5(a)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1417"},"text":"34 Stat. 1417","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Dec. 26, 1969","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/169/s1"},"text":"Pub. L. 91–169, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/83/464"},"text":"83 Stat. 464","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 8, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/348/s4/e"},"text":"Pub. L. 94–348, § 4(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/819"},"text":"90 Stat. 819","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/423/s12"},"text":"Pub. L. 96–423, § 12","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1816"},"text":"94 Stat. 1816","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s16/6/B"},"text":"Pub. L. 100–342, § 16(6)(B)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/635"},"text":"102 Stat. 635","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:64a(b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939/s5/b"},"text":"Mar. 4, 1907, ch. 2939, § 5(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1417"},"text":"34 Stat. 1417","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Dec. 26, 1969","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/169/s1"},"text":"Pub. L. 91–169, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/83/464"},"text":"83 Stat. 464","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:64a(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939/s5/c"},"text":"Mar. 4, 1907, ch. 2939, § 5(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1417"},"text":"34 Stat. 1417","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Dec. 26, 1969","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/169/s1"},"text":"Pub. L. 91–169, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/83/464"},"text":"83 Stat. 464","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s16/6/C"},"text":"Pub. L. 100–342, § 16(6)(C)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/635"},"text":"102 Stat. 635","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “Attorney General” are substituted for “United States attorney” because of 28:509. The words “civil action” are substituted for “suit or suits”, “action”, and “prosecutions” for consistency with rule 2 of the Federal Rules of Civil Procedure (28 App. U.S.C.).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), the words “(including but not limited to a railroad; any manager, supervisor, official, or other employee or agent of a railroad; any owner, manufacturer, lessor, or lessee of railroad equipment, track, or facilities; any independent contractor providing goods or services to a railroad; and any employee of such owner, manufacturer, lessor, lessee, or independent contractor)” are omitted as surplus because of the definition of “person” in 1:1 and because the provision being violated indicates to whom it applies. The words “violating chapter 211 of this title” are substituted for “that requires or permits any employee to go, be, or remain on duty in violation of section 62, section 63, or ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s63a"},"text":"section 63a of this title","children":[],"tail":", or that violates any other provision of this chapter” to eliminate unnecessary words. The words “to the United States Government for a civil penalty” are substituted for “for a penalty” for consistency in the revised title and with other titles of the United States Code."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “The Secretary of Transportation imposes a civil penalty under this subsection” are substituted for “as the Secretary of Transportation deems reasonable” for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(3), the words “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3711"},"text":"section 3711 of title 31","children":[],"tail":"” are substituted for “sections 3711 and 3716 to 3718 of title 31” because penalties are compromised under 31:3711. In clause (B), the words “prior or subsequent” are omitted as unnecessary."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(4), the words “the Secretary shall refer the matter to the Attorney General for collection” are substituted for “recovered in a suit or suits to be brought by” for clarity. The text of 45:64a(b) is omitted as obsolete.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “The Attorney General shall bring a civil action in a district court of the United States to collect a civil penalty that is referred to the Attorney General for collection under subsection (a) of this section after satisfactory information is presented to the Attorney General” are substituted for “It shall be the duty of the United States attorney to bring such an action upon satisfactory information being lodged with him” for clarity and consistency in this section and with other provisions of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “any proceeding” are substituted for “all prosecutions” for consistency in the revised title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb202739-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:21303(a)(1) to correct a grammatical error.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb20273a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb20273b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Rail Safety Improvement Act of 2008, referred to in subsec. (a)(1), is the date of enactment of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432"},"text":"Pub. L. 110–432","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb20273c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s108/e/2/B"},"text":"Pub. L. 110–432, § 108(e)(2)(B)","children":[],"tail":", inserted “including section 21103 (as such section was in effect on the day before the date of enactment of the Rail Safety Improvement Act of 2008),” after “chapter 211 of this title,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s302/c"},"text":"Pub. L. 110–432, § 302(c)","children":[],"tail":", substituted “$25,000.” for “$10,000.” and “$100,000.” for “$20,000.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" inserted a comma after “chapter 211 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/440"},"text":"Pub. L. 103–440","children":[],"tail":" inserted “or violating any provision of a waiver applicable to that person that has been granted under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s21108"},"text":"section 21108 of this title","children":[],"tail":",” after “chapter 211 of this title”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
