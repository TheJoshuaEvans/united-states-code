{"tag":"section","attrib":{"id":"idcb1ddd38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21303"},"text":null,"children":[{"tag":"num","attrib":{"value":"21303"},"text":"§ 21303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chapter 211 violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb1ddd39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21303/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb1ddd3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21303/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s21304"},"text":"section 21304 of this title","children":[],"tail":", a person violating chapter 211 of this title, including section 21103 (as such section was in effect on the day before the date of enactment of the Rail Safety Improvement Act of 2008), or violating any provision of a waiver applicable to that person that has been granted under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s21108"},"text":"section 21108 of this title","children":[],"tail":", is liable to the United States Government for a civil penalty. An act by an individual that causes a railroad carrier to be in violation is a violation. For a violation of "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s21106"},"text":"section 21106 of this title","children":[],"tail":", a separate violation occurs for each day a facility is not in compliance."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1ddd3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21303/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation imposes a civil penalty under this subsection. The amount of the penalty shall be at least $500 but not more than $25,000. However, when a grossly negligent violation or a pattern of repeated violations has caused an imminent hazard of death or injury to individuals, or has caused death or injury, the amount may be not more than $100,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1ddd3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21303/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary may compromise the amount of the civil penalty under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3711"},"text":"section 3711 of title 31","children":[],"tail":". In determining the amount of a compromise, the Secretary shall consider—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb1ddd3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21303/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the nature, circumstances, extent, and gravity of the violation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1ddd3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21303/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with respect to the violator, the degree of culpability, any history of violations, the ability to pay, and any effect on the ability to continue to do business; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb1ddd3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21303/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other matters that justice requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1ddd40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21303/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary does not compromise the amount of the civil penalty, the Secretary shall refer the matter to the Attorney General for collection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb1ddd41-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21303/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions To Collect","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb1ddd42-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21303/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Attorney General shall bring a civil action in a district court of the United States to collect a civil penalty that is referred to the Attorney General for collection under subsection (a) of this section after satisfactory information is presented to the Attorney General. The action may be brought in the judicial district in which the violation occurred or the defendant has its principal executive office. If the action is against an individual, the action also may be brought in the judicial district in which the individual resides.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb1ddd43-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21303/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civil action under this subsection must be brought not later than 2 years after the date of the violation unless administrative notification under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s3711"},"text":"section 3711 of title 31","children":[],"tail":" is given within that 2-year period to the person committing the violation. However, even if notification is given, the action must be brought within the period specified in "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s2462"},"text":"section 2462 of title 28","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb1ddd44-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s21303/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Imputation of Knowledge","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In any proceeding under this section, a railroad carrier is deemed to know the acts of its officers and agents.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb1ddd45-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/892"},"text":"108 Stat. 892","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/440/tII/s204"},"text":"Pub. L. 103–440, title II, § 204","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4620"},"text":"108 Stat. 4620","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/54"},"text":"Pub. L. 104–287, § 5(54)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3393"},"text":"110 Stat. 3393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tI/s108/e/2/B"},"text":"Pub. L. 110–432, div. A, title I, § 108(e)(2)(B)","children":[],"tail":", title III, § 302(c), "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4866"},"text":"122 Stat. 4866","children":[],"tail":", 4878.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb1ddd46-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb1ddd47-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb1ddd48-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"21303","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:63a(d) (related to 45:64a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1907-03-04/ch2939"},"text":"Mar. 4, 1907, ch. 2939","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/34/1415"},"text":"34 Stat. 1415","children":[],"tail":", § 3A(d) (related to § 5); added "},{"tag":"html:span","attrib":{},"text":"July 8, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/348/s4/d"},"text":"Pub. L. 94–348, § 4(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/819"},"text":"90 Stat. 819","children":[],"tail":";