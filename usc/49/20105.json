n this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “out of funds appropriated pursuant to this subchapter or otherwise made available”, “reasonably”, and “satisfactory” are omitted as surplus. The words “will be at least as much as the average amount expended” are substituted for “will be maintained at a level which does not fall below the average level of such expenditures” for clarity and to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb0d1456-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb0d1457-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1710/a/2"},"text":"Pub. L. 107–296, § 1710(a)(2)","children":[],"tail":", substituted “the Secretary concerned” for “the Secretary” in second sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1710/a/1"},"text":"Pub. L. 107–296, § 1710(a)(1)","children":[],"tail":", substituted “The Secretary concerned” for “The Secretary of Transportation” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (b), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1710/a/2"},"text":"Pub. L. 107–296, § 1710(a)(2)","children":[],"tail":", substituted “Secretary concerned” for “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1710/a/2"},"text":"Pub. L. 107–296, § 1710(a)(2)","children":[],"tail":", (3), substituted “Secretary concerned” for “Secretary” and “duties under chapters 203–213 of this title (in the case of the Secretary of Transportation) and duties under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s114"},"text":"section 114 of this title","children":[],"tail":" (in the case of the Secretary of Homeland Security)” for “Secretary’s duties under chapters 203–213 of this title”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1710/a/2"},"text":"Pub. L. 107–296, § 1710(a)(2)","children":[],"tail":", substituted “Secretary concerned” for “Secretary” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1710/a/2"},"text":"Pub. L. 107–296, § 1710(a)(2)","children":[],"tail":", (4), substituted “Secretary concerned” for “Secretary” and “chapter (in the case of the Secretary of Transportation) and duties under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s114"},"text":"section 114 of this title","children":[],"tail":" (in the case of the Secretary of Homeland Security)” for “chapter”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/296/s1710/a/5"},"text":"Pub. L. 107–296, § 1710(a)(5)","children":[],"tail":", added subsec. (g)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb0d1458-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb0d1459-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2002 Amendment","children":[],"tail":null},{"tag":"p","attri