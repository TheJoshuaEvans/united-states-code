{"tag":"section","attrib":{"id":"idcb0aca48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105"},"text":null,"children":[{"tag":"num","attrib":{"value":"20105"},"text":"§ 20105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" State participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb0aca49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Investigative and Surveillance Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may prescribe investigative and surveillance activities necessary to enforce the safety regulations prescribed and orders issued by the Secretary ","children":[{"tag":"ref","attrib":{"idref":"fn002066"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002066"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Secretary concerned”."}],"tail":" that apply to railroad equipment, facilities, rolling stock, and operations in a State. The State may participate in those activities when the safety practices for railroad equipment, facilities, rolling stock, and operations in the State are regulated by a State authority and the authority submits to the Secretary concerned an annual certification as provided in subsection (b) of this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0aca4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual Certification","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0aca4b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A State authority’s annual certification must include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0aca4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a certification that the authority—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb0aca4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/b/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has regulatory jurisdiction over the safety practices for railroad equipment, facilities, rolling stock, and operations in the State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb0aca4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/b/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" was given a copy of each safety regulation prescribed and order issued by the Secretary concerned, that applies to the equipment, facilities, rolling stock, or operations, as of the date of certification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb0aca4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/b/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is conducting the investigative and surveillance activities prescribed by the Secretary concerned under subsection (a) of this section; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0aca50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a report, in the form the Secretary concerned prescribes by regulation, that includes—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb0aca51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the name and address of each railroad carrier subject to the safety jurisdiction of the authority;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb0aca52-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each accident or incident reported during the prior 12 months by a railroad carrier involving a fatality, personal injury requiring hospitalization, or property damage of more than $750 (or a higher amount prescribed by the Secretary concerned), and a summary of the authority’s investigation of the cause and circumstances surrounding the accident or incident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb0aca53-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the record maintenance, reporting, and inspection practices conducted by the authority to aid the Secretary concerned in enforcing railroad safety regulations prescribed and orders issued by the Secretary concerned, including the number of inspections made of railroad equipment, facilities, rolling stock, and operations by the authority during the prior 12 months; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb0aca54-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other information the Secretary concerned requires.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0aca55-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An annual certification applies to a safety regulation prescribed or order issued after the date of the certification only if the State authority submits an appropriate certification to provide the necessary investigative and surveillance activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0aca56-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If, after receipt of an annual certification, the Secretary concerned decides the State authority is not complying satisfactorily with the investigative and surveillance activities prescribed under subsection (a) of this section, the Secretary concerned may reject any part of the certification or take other appropriate action to achieve adequate enforcement. The Secretary concerned must give the authority notice and an opportunity for a hearing before taking action under this paragraph. When the Secretary concerned gives notice, the burden of proof is on the authority to show that it is complying satisfactorily with the investigative and surveillance activities prescribed by the Secretary concerned.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0aca57-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement When Certification Not Received","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0aca58-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Secretary concerned does not receive an annual certification under subsection (a) of this section related to any railroad equipment, facility, rolling stock, or operation, the Secretary concerned may make an agreement with a State authority for the authority to provide any part of the investigative and surveillance activities prescribed by the Secretary concerned as necessary to enforce the safety regulations and orders applicable to the equipment, facility, rolling stock, or operation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0aca59-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary concerned may terminate any part of an agreement made under this subsection on finding that the authority has not provided every part of the investigative and surveillance activities to which the agreement relates. The Secretary concerned must give the authority notice and an opportunity for a hearing before making such a finding. The finding and termination shall be published in the Federal Register and may not become effective for at least 15 days after the date of publication.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0d144a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agreement for Investigative and Surveillance Activities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In addition to providing for State participation under this section, the Secretary concerned may make an agreement with a State to provide investigative and surveillance activities related to the duties under chapters 203–213 of this title (in the case of the Secretary of Transportation) and duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s114"},"text":"section 114 of this title","children":[],"tail":" (in the case of the Secretary of Homeland Security)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0d144b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On application by a State authority that has submitted a certification under subsections (a) and (b) of this section or made an agreement under subsection (c) or (d) of this section, the Secretary concerned shall pay not more than 50 percent of the cost of the personnel, equipment, and activities of the authority needed, during the next fiscal year, to carry out a safety program under the certification or agreement. However, the Secretary concerned may pay an authority only when the authority assures the Secretary concerned that it will provide the remaining cost of the safety program and that the total State money expended for the safety program, excluding grants of the United States Government, will be at least as much as the average amount expended for the fiscal years that ended ","children":[{"tag":"date","attrib":{"date":"1969-06-30"},"text":"June 30, 1969","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1970-06-30"},"text":"June 30, 1970","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0d144c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary concerned may monitor State investigative and surveillance practices and carry out other inspections and investigations necessary to help enforce this chapter (in the case of the Secretary of Transportation) and duties under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s114"},"text":"section 114 of this title","children":[],"tail":" (in the case of the Secretary of Homeland Security)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0d144d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0d144e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “safety” includes security; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0d144f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “Secretary concerned” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb0d1450-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/g/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Transportation, with respect to railroad safety matters concerning such Secretary under laws administered by that Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb0d1451-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20105/g/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of Homeland Security, with respect to railroad safety matters concerning such Secretary under laws administered by that Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0d1452-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/864"},"text":"108 Stat. 864","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVII/s1710/a"},"text":"Pub. L. 107–296, title XVII, § 1710(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2319"},"text":"116 Stat. 2319","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb0d1453-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb0d1454-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb0d1455-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20105(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:435(a) (1st sentence related to authority for State participation).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458/s206/a"},"text":"Pub. L. 91–458, § 206(a)","children":[],"tail":" (1st sentence), (b), (f), "},{"tag":"html:a","attrib":{"href":"/us/stat/84/972"},"text":"84 Stat. 972","children":[],"tail":", 973, 974; "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/615/s28/a/1"},"text":"Pub. L. 101–615, § 28(a)(1)","children":[],"tail":"–(3), (b), (c), "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3276"},"text":"104 Stat. 3276","children":[],"tail":", 3277."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"20105(b) (1)(A)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:435(a) (1st sentence related to contents of certification).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"20105(b) (1)(B)","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:435(b) (1s