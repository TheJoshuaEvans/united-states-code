{"tag":"section","attrib":{"id":"idcb3f2181-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26102"},"text":null,"children":[{"tag":"num","attrib":{"value":"26102"},"text":"§ 26102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" High-speed rail technology improvements","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb3f2182-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may undertake activities for the improvement, adaptation, and integration of proven technologies for commercial application in high-speed rail service in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3f2183-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible Recipients","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out activities authorized by subsection (a), the Secretary may provide financial assistance to any United States private business, educational institution located in the United States, State or local government or public authority, or agency of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb3f2184-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s26102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation With Other Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out activities authorized by subsection (a), the Secretary shall consult with such other governmental agencies as may be necessary concerning the availability of appropriate technologies for commercial application in high-speed rail service in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb3f2185-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/440/tI/s103/a/2"},"text":"Pub. L. 103–440, title I, § 103(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-11-02"},"text":"Nov. 2, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4617"},"text":"108 Stat. 4617","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb3f2186-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb3f2187-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb3f2188-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 26102 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s28102"},"text":"section 28102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
