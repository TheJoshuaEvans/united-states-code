{"tag":"section","attrib":{"id":"idcbbfe9c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41510"},"text":null,"children":[{"tag":"num","attrib":{"value":"41510"},"text":"§ 41510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Required adherence to foreign air transportation tariffs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbbfe9c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41510/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Actions by Air Carriers, Foreign Air Carriers, and Ticket Agents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An air carrier, foreign air carrier, or ticket agent may not—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbfe9ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41510/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" charge or receive compensation for foreign air transportation that is different from the price specified in the tariff of the carrier that is in effect for that transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbfe9cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41510/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" refund or remit any part of the price specified in the tariff; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbfe9cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41510/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" extend to any person a privilege or facility, related to a matter required by the Secretary of Transportation to be specified in a tariff for foreign air transportation, except as specified in the tariff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbfe9cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41510/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibited Actions by Any Person","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not knowingly—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbfe9ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41510/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay compensation for foreign air transportation of property that is different from the price specified in the tariff in effect for that transportation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbfe9cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41510/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" solicit, accept, or receive—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbbfe9d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41510/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a refund or remittance of any part of the price specified in the tariff; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbfe9d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41510/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a privilege or facility, related to a matter required by the Secretary to be specified in a tariff for foreign air transportation of property, except as specified in the tariff.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbbfe9d2-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1138"},"text":"108 Stat. 1138","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbbfe9d3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbbfe9d4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbbfe9d5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail"