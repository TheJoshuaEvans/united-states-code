tml:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(a)(4)(B) (related to 49 App.:1373(b)(1)), (b)(1)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(a)(4)(B) (related to § 403(b)), (b)(1)(E); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/c"},"text":"Pub. L. 98–443, § 3(c)","children":[],"tail":", (e), "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1703"},"text":"98 Stat. 1703","children":[],"tail":", 1704."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41510(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1373(b)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 403(b)(2); added "},{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/623/s8/a"},"text":"Pub. L. 93–623, § 8(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2105"},"text":"88 Stat. 2105","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(a)(4)(B) (related to 49 App.:1373(b)(2)), (b)(1)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “greater or less” are omitted as being included in “different”. The words “foreign air transportation” are substituted for “air transportation” because 49 App.:1551(a)(4)(B) provides that 49 App.:1373 no longer applies to interstate or overseas air transportation and 49 App.:1376(a)–(e), restated in section 41901 of the revised title, governs prices for the transportation of mail by aircraft. See section 40102(a) of the revised title defining “air transportation” to mean interstate or foreign air transportation or the transportation of mail by aircraft. The words “for any service in connection therewith” are omitted as surplus because the word “transportation” includes any services related to the transportation.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “may not” are substituted for “no . . . shall” and “no . . . shall, in any manner or by any device, directly or indirectly, or through any agent or broker, or otherwise” for clarity and to eliminate unnecessary words. In clause (1), the words “demand or collect” are omitted as being included in “charge or receive”. The words “then currently” are omitted as surplus. In clause (3), the words “tariff for foreign air transportation” are substituted for “such tariffs” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “shipper, consignor, consignee, forwarder, broker, or other . . . or any director, officer, agent, or employee thereof” are omitted as surplus. In clause (1), the words “directly or indirectly, by any device or means” and “currently” are omitted as surplus. In clause (2), before subclause (A), the words “in any manner or by any device, directly or indirectly, through any agent or broker, or otherwise” are omitted as surplus. In subclause (B), the word “favor” is omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
