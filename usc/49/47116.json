{"tag":"section","attrib":{"id":"idcc5635b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47116"},"text":null,"children":[{"tag":"num","attrib":{"value":"47116"},"text":"§ 47116.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Small airport fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc5635b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47116/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existence and Amounts in Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation has a small airport fund. The fund consists of 87.5 percent of amounts not apportioned under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47114"},"text":"section 47114 of this title","children":[],"tail":" because of section 47114(f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5635b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47116/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Distribution of Amounts","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may distribute amounts in the fund in each fiscal year for any purpose for which amounts are made available under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s48103"},"text":"section 48103 of this title","children":[],"tail":" as follows:"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5635ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47116/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not more than 25 percent for grants for projects at small hub airports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5635bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47116/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less than 25 percent for grants to sponsors of public-use airports (except commercial service airports).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5635bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47116/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not less than 50 percent for grants to sponsors of commercial service airports that are not larger than a nonhub airport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5635bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47116/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Receive Grant Not Dependent on Participation in Block Grant Pilot Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An airport in a State participating in the State block grant pilot program under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s47128"},"text":"section 47128 of this title","children":[],"tail":" may receive a grant under this section to the same extent the airport may receive a grant if the State were not participating in the program."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5635be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47116/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Priority Consideration for Certain Projects.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc5635bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47116/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction of new runways","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In making grants to sponsors described in subsection (b)(2), the Secretary shall give priority consideration to multi-year proj­ects for construction of new runways that the Secretary finds are cost beneficial and would increase capacity in a region of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc5635c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47116/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Control tower construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 47124(b)(4)(A), the Secretary may provide grants under this section to an airport sponsor participating in the contract tower program under section 47124 for the construction or improvement of a nonapproach control tower, as defined by the Secretary, and for the acquisition and installation of air traffic control, communications, and related equipment to be used in that tower. Such grants shall be subject to the distribution requirements of subsection (b) and the eligibility requirements of section 47124(b)(4)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc5635c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47116/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Aviation Transient Aprons","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In distributing amounts from the fund described in subsection (a) to sponsors described in subsection ","children":[{"tag":"ref","attrib":{"idref":"fn002180"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002180"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original."}],"tail":" (b)(2) and "},{"tag":"ref","attrib":{"idref":"fn002180"},"text":"1","children":[],"tail":" (b)(3), 5 percent of each amount shall be used for projects to construct or rehabilitate aprons intended to be used for itinerant general aviation aircraft parking."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc5635c2-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1271"},"text":"108 Stat. 1271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/264/tI/s146"},"text":"Pub. L. 104–264, title I, § 146","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-09"},"text":"Oct. 9, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3223"},"text":"110 Stat. 3223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/6/s8/b"},"text":"Pub. L. 106–6, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-03-31"},"text":"Mar. 31, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/11"},"text":"113 Stat. 11","children":[],"tail":"; "},{"tag":"ref","attrib":{"hre