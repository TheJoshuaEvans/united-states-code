{"tag":"section","attrib":{"id":"idcb7f85bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32701"},"text":null,"children":[{"tag":"num","attrib":{"value":"32701"},"text":"§ 32701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Findings and purposes","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb7f85bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32701/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Findings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Congress finds that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7f85bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32701/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buyers of motor vehicles rely heavily on the odometer reading as an index of the condition and value of a vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32701/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" buyers are entitled to rely on the odometer reading as an accurate indication of the mileage of the vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32701/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an accurate indication of the mileage assists a buyer in deciding on the safety and reliability of the vehicle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32701/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" motor vehicles move in, or affect, interstate and foreign commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7f85c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32701/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this chapter are—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7f85c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32701/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prohibit tampering with motor vehicle odometers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f85c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32701/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide safeguards to protect purchasers in the sale of motor vehicles with altered or reset odometers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb7f85c4-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1048"},"text":"108 Stat. 1048","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","at