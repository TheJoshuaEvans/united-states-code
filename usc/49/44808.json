{"tag":"section","attrib":{"id":"idcc15d1b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808"},"text":null,"children":[{"tag":"num","attrib":{"value":"44808"},"text":"§ 44808.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Carriage of property by small unmanned aircraft systems for compensation or hire","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc15d1b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of the FAA Reauthorization Act of 2018, the Administrator of the Federal Aviation Administration shall update existing regulations to authorize the carriage of property by operators of small unmanned aircraft systems for compensation or hire within the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc15d1ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any rulemaking conducted under subsection (a) shall provide for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc15d1bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Use performance-based requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d1bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consider varying levels of risk to other aircraft and to persons and property on the ground posed by different unmanned aircraft systems and their operation and tailor performance-based requirements to appropriately mitigate risk.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d1bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Consider the unique characteristics of highly automated, small unmanned aircraft systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d1be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Include requirements for the safe operation of small unmanned aircraft systems that, at a minimum, address—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc15d1bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" airworthiness of small unmanned aircraft systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d1c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifications for operators and the type and nature of the operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d1c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operating specifications governing the type and nature of the unmanned aircraft system air carrier operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d1c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the views of State, local, and tribal officials related to potential impacts of the carriage of property by operators of small unmanned aircraft systems for compensation or hire within the communities to be served.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d1c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Small uas","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may amend part 298 of title 14, Code of Federal Regulations, to update existing regulations to establish economic authority for the carriage of property by small unmanned aircraft systems for compensation or hire. Such authority shall only require—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc15d1c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" registration with the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d1c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" authorization from the Federal Aviation Administration to conduct operations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc15d1c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with chapters 401, 411, and 417.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc15d1c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44808/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Availability of current certification processes","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Pending completion of the rulemaking required in subsection (a) of this section, a person may seek an air carrier operating certificate and certificate of public convenience and necessity, or an exemption from such certificate, using existing processes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc15d1c8-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIII/s348/a"},"text":"Pub. L. 115–254, div. B, title III, § 348(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3297"},"text":"132 Stat. 3297","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc15d1c9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc15d1ca-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc15d1cb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the FAA Reauthorization Act of 2018, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
