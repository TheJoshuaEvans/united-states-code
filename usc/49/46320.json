{"tag":"section","attrib":{"id":"idcc40b203-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46320"},"text":null,"children":[{"tag":"num","attrib":{"value":"46320"},"text":"§ 46320.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Interference with wildfire suppression, law enforcement, or emergency response effort by operation of unmanned aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc40b204-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46320/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in subsection (b), an individual who operates an unmanned aircraft and in so doing knowingly or recklessly interferes with a wildfire suppression, law enforcement, or emergency response effort is liable to the United States Government for a civil penalty of not more than $20,000.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc40b205-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46320/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exceptions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to the operation of an unmanned aircraft conducted by a unit or agency of the United States Government or of a State, tribal, or local government (including any individual conducting such operation pursuant to a contract or other agreement entered into with the unit or agency) for the purpose of protecting the public safety and welfare, including firefighting, law enforcement, or emergency response.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc40b206-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46320/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compromise and Setoff.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc40b207-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46320/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compromise","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States Government may compromise the amount of a civil penalty imposed under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc40b208-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46320/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Setoff","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The United States Government may deduct the amount of a civil penalty imposed or compromised under this section from the amounts the Government owes the person liable for the penalty.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc40b209-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46320/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc40b20a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46320/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Wildfire","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “wildfire” has the meaning given that term in section 2 of the Emergency Wildfire Suppression Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s1856m"},"text":"42 U.S.C. 1856m","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc40b20b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46320/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Wildfire suppression","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “wildfire suppression” means an effort to contain, extinguish, or suppress a wildfire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc40b20c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/190/tII/s2205/a"},"text":"Pub. L. 114–190, title II, § 2205(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-07-15"},"text":"July 15, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/630"},"text":"130 Stat. 630","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
