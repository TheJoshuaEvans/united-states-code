{"tag":"section","attrib":{"id":"idcb2027b4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22107"},"text":null,"children":[{"tag":"num","attrib":{"value":"22107"},"text":"§ 22107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records, audits, and information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb2027b5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22107/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Records","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each recipient of financial assistance through an arrangement under this chapter shall keep records required by the Secretary of Transportation. The records shall be kept for 3 years after a project is completed and shall disclose—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb2027b6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22107/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of, and disposition by the recipient, of the assistance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2027b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22107/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total costs of the project for which the assistance was given or used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2027b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22107/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of that part of the costs of the project paid by other sources; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2027b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22107/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other records that will make an effective audit easier.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2027ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22107/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Audits","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall make regular financial and performance audits, as provided under chapter 75 of title 31, of activities and transactions assisted under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2027bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22107/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Surface Transportation Board shall provide the Secretary with information the Secretary requests to assist in carrying out this chapter. The Board shall provide the information not later than 30 days after receiving a request from the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2027bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22107/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"List of Rail Lines","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than August 1 of each year, each rail carrier subject to part A of subtitle IV of this title shall submit to the Secretary a list of the rail lines of the carrier that carried not more than 5,000,000 gross ton-miles of freight a mile in the prior year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb2027bd-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/898"},"text":"108 Stat. 898","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s308/f/4"},"text":"Pub. L. 104–88, title III, § 308(f)(4)","children":[],"tail":", (5), "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/947"},"text":"109 Stat. 947","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/316/tI/s127/c"},"text":"Pub. L. 104–316, title I, § 127(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-19"},"text":"Oct. 19, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3840"},"text":"110 Stat. 3840","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb2027be-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb2027bf-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb2027c0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"ht