ag":"html:span","attrib":{},"text":"46306(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1472(b)(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 902(b)(5); added "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/570/s3401/a/1"},"text":"Pub. L. 99–570, § 3401(a)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3207-99"},"text":"100 Stat. 3207–99","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/690/s7209/a"},"text":"Pub. L. 100–690, § 7209(a)","children":[],"tail":", (b)(1), "},{"tag":"html:a","attrib":{"href":"/us/stat/102/4429"},"text":"102 Stat. 4429","children":[],"tail":", 4432."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b)(9), (d), and (e), the word “Administrator” in section 902(b) of the Federal Aviation Act of 1958 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/784"},"text":"72 Stat. 784","children":[],"tail":") is retained on authority of 49:106(g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “Except as provided by subsection (c) of this section” are added for clarity. The words “It shall be unlawful for any person” and “upon conviction” are omitted as surplus. The words “fined under title 18” are substituted for “a fine of not more than $15,000” for consistency with title 18. In clause (1), the words “counterfeit” and “falsely make” are omitted as surplus. In clause (4), the words “covering up”, “representation”, and “writing” are omitted as surplus. In clause (7), the word “valid” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), before clause (A), the words “fined under title 18” are substituted for “a fine of not more than $25,000” for consistency with title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1) and (3), the words “Administrator of Drug Enforcement” are substituted for “Drug Enforcement Administration of the Department of Justice” and “Drug Enforcement Administration” because of section 5(a) of Reorganization Plan No. 2 of 1973 (eff. ","children":[{"tag":"date","attrib":{"date":"1973-07-01"},"text":"July 1, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/1092"},"text":"87 Stat. 1092","children":[],"tail":"). The words “Commissioner of Customs” and “Commissioner” are substituted for “United States Customs Service” because of 19:2071."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2)(A), the words “aircraft certificate of registration” are substituted for “registration” for consistency in this section. The words “counterfeited” and “falsely made” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (d)(2)(C)(ii) and (e), the words “aircraft certificate of registration” are substituted for “aircraft registration certificate” for consistency with 49 App.:1401, restated in chapter 441 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), before clause (1), the words “this subsection or in any other provision of” are omitted as surplus. In clause (1), the words “counterfeits” and “falsely makes” are omitted as surplus. In clause (4)(A), the words “covering up” are omitted as surplus. In clause (4)(B), the words “or representation” are omitted as surplus. In clause (4)(C), the words “writing or” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc3e6878-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This makes a clarifying amendment to 49:46306(c)(2)(B).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc3e6879-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc3e687a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—Subsec. (c)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" inserted “that is” before “provided”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc3e687b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idcc3e687c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text"