{"tag":"section","attrib":{"id":"idcc3e6848-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306"},"text":null,"children":[{"tag":"num","attrib":{"value":"46306"},"text":"§ 46306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Registration violations involving aircraft not providing air transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc3e6849-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section applies only to aircraft not used to provide air transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc3e684a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Criminal Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided by subsection (c) of this section, a person shall be fined under title 18, imprisoned for not more than 3 years, or both, if the person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc3e684b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully forges or alters a certificate authorized to be issued under this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e684c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly sells, uses, attempts to use, or possesses with the intent to use, such a certificate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e684d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully displays or causes to be displayed on an aircraft a mark that is false or misleading about the nationality or registration of the aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e684e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" obtains a certificate authorized to be issued under this part by knowingly and willfully falsifying or concealing a material fact, making a false, fictitious, or fraudulent statement, or making or using a false document knowing it contains a false, fictitious, or fraudulent statement or entry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e684f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" owns an aircraft eligible for registration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44102"},"text":"section 44102 of this title","children":[],"tail":" and knowingly and willfully operates, attempts to operate, or allows another person to operate the aircraft when—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc3e6850-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft is not registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44103"},"text":"section 44103 of this title","children":[],"tail":" or the certificate of registration is suspended or revoked; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc3e6851-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the owner knows or has reason to know that the other person does not have proper authorization to operate or navigate the aircraft without registration for a period of time after transfer of ownership;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e6852-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" knowingly and willfully operates or attempts to operate an aircraft eligible for registration under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44102"},"text":"section 44102 of this title","children":[],"tail":" knowing that—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc3e6853-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft is not registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44103"},"text":"section 44103 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc3e6854-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the certificate of registration is suspended or revoked; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc3e6855-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person does not have proper authorization to operate or navigate the aircraft without registration for a period of time after transfer of ownership;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e6856-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully serves or attempts to serve in any capacity as an airman without an airman’s certificate authorizing the individual to serve in that capacity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e6857-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully employs for service or uses in any capacity as an airman an individual who does not have an airman’s certificate authorizing the individual to serve in that capacity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e6858-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operates an aircraft with a fuel tank or fuel system that has been installed or modified knowing that the tank, system, installation, or modification does not comply with regulations and requirements of the Administrator of the Federal Aviation Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc3e6859-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Controlled Substance Criminal Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc3e685a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In this subsection, “controlled substance” has the same meaning given that term in section 102 of the Comprehensive Drug Abuse Prevention and Control Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e685b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person violating subsection (b) of this section shall be fined under title 18, imprisoned for not more than 5 years, or both, if the violation is related to transporting a controlled substance by aircraft or aiding or facilitating a controlled substance violation and the transporting, aiding, or facilitating—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc3e685c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is punishable by death or imprisonment of more than one year under a law of the United States or a State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc3e685d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that is provided is related to an act punishable by death or imprisonment for more than one year under a law of the United States or a State related to a controlled substance (except a law related to simple possession of a controlled substance).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e685e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A term of imprisonment imposed under paragraph (2) of this subsection shall be served in addition to, and not concurrently with, any other term of imprisonment imposed on the individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc3e685f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Seizure and Forfeiture","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc3e6860-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of Drug Enforcement or the Commissioner of U.S. Customs and Border Protection may seize and forfeit under the customs laws an aircraft whose use is related to a violation of subsection (b) of this section, or to aid or facilitate a violation, regardless of whether a person is charged with the violation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e6861-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An aircraft’s use is presumed to have been related to a violation of, or to aid or facilitate a violation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc3e6862-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(1) of this section if the aircraft certificate of registration has been forged or altered;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc3e6863-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(3) of this section if there is an external display of false or misleading registration numbers or country of registration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc3e6864-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subsection (b)(4) of this section if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc3e6865-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft is registered to a false or fictitious person; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc3e6866-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application form used to obtain the aircraft certificate of registration contains a material false statement;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc3e6867-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subsection (b)(5) of this section if the aircraft was operated when it was not registered under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44103"},"text":"section 44103 of this title","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc3e6868-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/d/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subsection (b)(9) of this section if the aircraft has a fuel tank or fuel system that was installed or altered—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc3e6869-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/d/2/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in violation of a regulation or requirement of the Administrator of the Federal Aviation Administration; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc3e686a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/d/2/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a certificate required to be issued for the installation or alteration is not carried on the aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e686b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator of the Federal Aviation Administration, the Administrator of Drug Enforcement, and the Commissioner shall agree to a memorandum of understanding to establish procedures to carry out this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc3e686c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relationship to State Laws","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This part does not prevent a State from establishing a criminal penalty, including providing for forfeiture and seizure of aircraft, for a person that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc3e686d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully forges or alters an aircraft certificate of registration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e686e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly sells, uses, attempts to use, or possesses with the intent to use, a fraudulent aircraft certificate of registration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e686f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully displays or causes to be displayed on an aircraft a mark that is false or misleading about the nationality or registration of the aircraft; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e6870-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" obtains an aircraft certificate of registration from the Administrator of the Federal Aviation Administration by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc3e6871-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully falsifying or concealing a material fact;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc3e6872-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making a false, fictitious, or fraudulent statement; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc3e6873-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46306/e/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making or using a false document knowing it contains a false, fictitious, or fraudulent statement or entry.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc3e6874-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1235"},"text":"108 Stat. 1235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/78"},"text":"Pub. L. 104–287, § 5(78)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3397"},"text":"110 Stat. 3397","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/125/tVIII/s802/d/2"},"text":"Pub. L. 114–125, title VIII, § 802(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-02-24"},"text":"Feb. 24, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/210"},"text":"130 Stat. 210","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc3e6875-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc3e6876-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc3e6877-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"c