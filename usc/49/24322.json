{"tag":"section","attrib":{"id":"idcb35ab49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24322"},"text":null,"children":[{"tag":"num","attrib":{"value":"24322"},"text":"§ 24322.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rolling stock purchases","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb35ab4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24322/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Prior to entering into any contract in excess of $100,000,000 for rolling stock and locomotive procurements Amtrak shall submit a business case analysis to the Secretary of Transportation, the Committee on Commerce, Science, and Transportation and the Committee on Appropriations of the Senate and the Committee on Transportation and Infrastructure and the Committee on Appropriations of the House of Representatives, on the utility of such procurements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35ab4b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24322/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The business case analysis shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb35ab4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24322/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include a cost and benefit comparison that describes the total lifecycle costs and the anticipated benefits related to revenue, operational efficiency, reliability, and other factors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35ab4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24322/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" set forth the total payments by fiscal year;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35ab4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24322/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the specific source and amounts of funding for each payment, including Federal funds, State funds, Amtrak profits, Federal, State, or private loans or loan guarantees, and other funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35ab4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24322/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include an explanation of whether any payment under the contract will increase Amtrak’s funding request in its general and legislative annual report required under section 24315(b) in a particular fiscal year; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35ab50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24322/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe how Amtrak will adjust the procurement if future funding is not available.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35ab51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24322/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed as requiring Amtrak to disclose confidential information regarding a potential vendor’s proposed pricing or other sensitive business information prior to contract execution or prohibiting Amtrak from entering into a contract after submission of a business case analysis under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb35ab52-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11208/a"},"text":"Pub. L. 114–94, div. A, title XI, § 11208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1639"},"text":"129 Stat. 1639","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb35ab53-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb35ab54-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb35ab55-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
