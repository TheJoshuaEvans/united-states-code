{"tag":"section","attrib":{"id":"idcb4d7855-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125"},"text":null,"children":[{"tag":"num","attrib":{"value":"30125"},"text":"§ 30125.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Schoolbuses and schoolbus equipment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb4d7856-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4d7857-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “schoolbus” means a passenger motor vehicle designed to carry a driver and more than 10 passengers, that the Secretary of Transportation decides is likely to be used significantly to transport preprimary, primary, and secondary school students to or from school or an event related to school.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d7858-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “schoolbus equipment” means equipment designed primarily for a schoolbus or manufactured or sold to replace or improve a system, part, or component of a schoolbus or as an accessory or addition to a schoolbus.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4d7859-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe motor vehicle safety standards for schoolbuses and schoolbus equipment manufactured in, or imported into, the United States. Standards shall include minimum performance requirements for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4d785a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency exits;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d785b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" interior protection for occupants;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d785c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" floor strength;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d785d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" seating systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d785e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" crashworthiness of body and frame (including protection against rollover hazards);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d785f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" vehicle operating systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d7860-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" windows and windshields; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d7861-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fuel systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4d7862-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30125/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Test Driving by Manufacturers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may require by regulation a schoolbus to be test-driven by a manufacturer before introduction in commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb4d7863-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attr