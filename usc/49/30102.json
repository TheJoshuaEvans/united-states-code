{"tag":"section","attrib":{"id":"idcb440288-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102"},"text":null,"children":[{"tag":"num","attrib":{"value":"30102"},"text":"§ 30102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb440289-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb44028a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “covered rental vehicle” means a motor vehicle that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb44028b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has a gross vehicle weight rating of 10,000 pounds or less;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb44028c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is rented without a driver for an initial term of less than 4 months; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb44028d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is part of a motor vehicle fleet of 35 or more motor vehicles that are used for rental purposes by a rental company.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb44028e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “dealer” means a person selling and distributing new motor vehicles or motor vehicle equipment primarily to purchasers that in good faith purchase the vehicles or equipment other than for resale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb44028f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “defect” includes any defect in performance, construction, a component, or material of a motor vehicle or motor vehicle equipment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb440290-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “distributor” means a person primarily selling and distributing motor vehicles or motor vehicle equipment for resale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb440291-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “interstate commerce” means commerce between a place in a State and a place in another State or between places in the same State through another State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb440292-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “manufacturer” means a person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb440293-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacturing or assembling motor vehicles or motor vehicle equipment; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb440294-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" importing motor vehicles or motor vehicle equipment for resale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb440295-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “motor vehicle” means a vehicle driven or drawn by mechanical power and manufactured primarily for use on public streets, roads, and highways, but does not include a vehicle operated only on a rail line.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb440296-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “motor vehicle equipment” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb440297-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any system, part, or component of a motor vehicle as originally manufactured;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb440298-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any similar part or component manufactured or sold for replacement or improvement of a system, part, or component, or as an accessory or addition to a motor vehicle; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb440299-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" any device or an article or apparel, including a motorcycle helmet and excluding medicine or eyeglasses prescribed by a licensed practitioner, that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb44029a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/8/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not a system, part, or component of a motor vehicle; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb44029b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/8/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is manufactured, sold, delivered, or offered to be sold for use on public streets, roads, and highways with the apparent purpose of safeguarding users of motor vehicles against risk of accident, injury, or death.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb44029c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “motor vehicle safety” means the performance of a motor vehicle or motor vehicle equipment in a way that protects the public against unreasonable risk of accidents occurring because of the design, construction, or performance of a motor vehicle, and against unreasonable risk of death or injury in an accident, and includes nonoperational safety of a motor vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb44029d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “motor vehicle safety standard” means a minimum standard for motor vehicle or motor vehicle equipment performance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb44029e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “rental company” means a person who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb44029f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is engaged in the business of renting covered rental vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4402a0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses for rental purposes a motor vehicle fleet of 35 or more covered rental vehicles, on average, during the calendar year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4402a1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “State” means a State of the United States, the District of Columbia, Puerto Rico, the Northern Mariana Islands, Guam, American Samoa, and the Virgin Islands.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4402a2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/a/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “United States district court” means a district court of the United States, a United States court for Guam, the Virgin Islands, and American Samoa, and the district court for the Northern Mariana Islands.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4402a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limited Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4402a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In sections 30117(b), 30118–30121, and 30166(f) of this title—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb4402a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “adequate repair” does not include repair resulting in substantially impaired operation of a motor vehicle or motor vehicle equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4402a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “first purchaser” means the first purchaser of a motor vehicle or motor vehicle equipment other than for resale;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4402a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “original equipment” means motor vehicle equipment (including a tire) installed in or on a motor vehicle at the time of delivery to the first purchaser;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4402a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “replacement equipment” means motor vehicle equipment (including a tire) that is not original equipment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4402a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brand name owner of a tire marketed under a brand name not owned by the manufacturer of the tire is deemed to be the manufacturer of the tire;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4402aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a defect in original equipment, or noncompliance of original equipment with a motor vehicle safety standard prescribed under this chapter, is deemed to be a defect or noncompliance of the motor vehicle in or on which the equipment was installed at the time of delivery to the first purchaser;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4402ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a manufacturer of a motor vehicle in or on which original equipment was installed when delivered to the first purchaser is deemed to be the manufacturer of the equipment; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4402ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/b/1/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a retreader of a tire is deemed to be the manufacturer of the tire.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4402ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30102/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation may prescribe regulations changing paragraph (1)(C), (D), (F), or (G) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb4402ae-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/941"},"text":"108 Stat. 941","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tI/s31201"},"text":"Pub. L. 112–141, div. C, title I, § 31201","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/757"},"text":"126 Stat. 757","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dB/tXXIV/s24109/b"},"text":"Pub. L. 114–94, div. B, title XXIV, § 24109(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1706"},"text":"129 Stat. 1706","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb4402af-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb4402b0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb4402b1-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"ta