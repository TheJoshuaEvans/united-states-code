l:span","attrib":{},"text":"30102(a)(9)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1391(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30102(a)(10)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1391(8).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30102(a)(11)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1391(12).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30102(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1419.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563"},"text":"Pub. L. 89–563","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/718"},"text":"80 Stat. 718","children":[],"tail":", § 159; added "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/492/s102/a"},"text":"Pub. L. 93–492, § 102(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1476"},"text":"88 Stat. 1476","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the definitions apply to the entire chapter because of references in 15:1421–1431 applying 15:1391–1420 to 15:1421–1431. Before clause (1), the words “As used” are omitted as surplus. In clause (1), the text of 15:1391(10) and 49 App.:1655(a)(6)(A) is omitted as surplus because the complete name of the Secretary of Transportation is used the first time the term appears in a section. The words “selling and distributing” are substituted for “who is engaged in the sale and distribution of” to eliminate unnecessary words. The word “purposes” is omitted as surplus. In clause (3), the words “selling and distributing” are substituted for “engaged in the sale and distribution of” to eliminate unnecessary words. In clause (5)(A), the words “manufacturing or assembling” are substituted for “engaged in the manufacturing or assembling of” to eliminate unnecessary words. In clause (7), the words “physician or other duly” and “drivers, passengers, and other” are omitted as surplus. In clause (8), the words “is also protected” and “to persons” are omitted as unnecessary. In clause (9), the words “which is practicable, which meets the need for motor vehicle safety and which provides objective criteria” are omitted as unnecessary because of 15:1392(a) which is restated in section 30111 of the revised title. In clauses (10) and (11), the words “the Northern Mariana Islands” are added because of section 502(a)(2) of the Covenant to Establish a Commonwealth of the Northern Mariana Islands in Political Union with the United States of America, as enacted by the Act of ","children":[{"tag":"date","attrib":{"date":"1976-03-24"},"text":"March 24, 1976","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/94/241"},"text":"Public Law 94–241","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/268"},"text":"90 Stat. 268","children":[],"tail":"), and as proclaimed to be in effect by the President on "},{"tag":"date","attrib":{"date":"1978-01-09"},"text":"January 9, 1978","children":[],"tail":" (Proc. No. 4534, "},{"tag":"date","attrib":{"date":"1977-10-24"},"text":"Oct. 24, 1977","children":[],"tail":", 42 F.R. 56593). The words “the Canal Zone” are omitted because of the Panama Canal Treaty of 1977. In clause (10), the word “means” is substituted for “includes” as being more appropriate. The words “a State of the United States” are substituted for “each of the several States” for consistency. The words “the Commonwealth of” are omitted as surplus. In clause (11), the word “Federal” is omitted as surplus. The words “of the Commonwealth of Puerto Rico” are omitted as unnecessary because the district court of Puerto Rico is a district court of the United States under 28:119."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “The term” and “the term” are omitted as surplus. In clause (B), the words “of a motor vehicle or motor vehicle equipment” are added for clarity. In clause (E), the words “to be” are added for consistency. The words “marketed under such brand name” are omitted as surplus. In clause (F), the words “a motor vehicle safety standard prescribed under this chapter” are added for clarity and consistency. The word “noncompliance” is substituted for “failure to comply” for consistency in the chapter. In clause (G), the words “(rather than the manufacturer of such equipment)” are omitted as surplus. The words “deemed to be” are substituted for “considered” for consistency. In clause (H), the words “which have been” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(2) is substituted for “Except as otherwise provided in regulations of the Secretary” for clarity and because of the restatement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb4402b2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb4402b3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s24109/b/3"},"text":"Pub. L. 114–94, § 24109(b)(3)","children":[],"tail":", added par. (1). Former par. (1) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2) to (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s24109/b/2"},"text":"Pub. L. 114–94, § 24109(b)(2)","children":[],"tail":", redesignated pars. (1) to (9) as (2) to (10), respectively. Former par. (10) redesignated (12)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s24109/b/4"},"text":"Pub. L. 114–94, § 24109(b)(4)","children":[],"tail":", added par. (11). Former par. (11) redesignated (13)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(12), (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s24109/b/1"},"text":"Pub. L. 114–94, § 24109(b)(1)","children":[],"tail":", redesignated pars. (10) and (11) as (12) and (13), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(7)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “any device or an article or apparel (except medicine or eyeglasses prescribed by a licensed practitioner) that is not a system, part, or component of a motor vehicle and is manufactured, sold, delivered, offered, or intended to be used only to safeguard motor vehicles and highway users against risk of accident, injury, or death.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb4402b4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb4402b5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dB/tXXIV/s24109/k"},"text":"Pub. L. 114–94, div. B, title XXIV, § 24109(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1709"},"text":"129 Stat. 1709","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dB/tXXIV/s24109/k"},"text":"“The amendments made by this section [amending this section and sections 30120, 30122, and 30166 of this title] shall take effect on the date that is 180 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb4402b6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb4402b7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rule of Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dB/tXXIV/s24109/i"},"text":"Pub. L. 114–94, div. B, title XXIV, § 24109(i)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1708"},"text":"129 Stat. 1708","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dB/tXXIV/s24109/i"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“Nothing in this section [amending this section and sections 30120, 30122, and 30166 of this title and enacting provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30101"},"text":"section 30101 of this title","children":[],"tail":"] or the amendments made by this section—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be construed to create or increase any liability, including for loss of use, for a manufacturer as a result of having manufactured or imported a motor vehicle subject to a notification of defect or noncompliance under subsection (b) or (c) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30118"},"text":"section 30118 of title 49","children":[],"tail":", United States Code; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall supersede or otherwise affect the contractual obligations, if any, between such a manufacturer and a rental company (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30102/a"},"text":"section 30102(a) of title 49","children":[],"tail":", United States Code).”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb4402b8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Rulemaking","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dB/tXXIV/s24109/j"},"text":"Pub. L. 114–94, div. B, title XXIV, § 24109(j)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1708"},"text":"129 Stat. 1708","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dB/tXXIV/s24109/j"},"text":"“The Secretary [probably means Secretary of Transportation] may promulgate rules, as appropriate, to implement this section [amending this section and sections 30120, 30122, and 30166 of this title and enacting provisions set out as notes under this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30101"},"text":"section 30101 of this title","children":[],"tail":"] and the amendments made by this section.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb4402b9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Low-Speed Electric Bicycles","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/107/319/s2"},"text":"Pub. L. 107–319, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-04"},"text":"Dec. 4, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2776"},"text":"116 Stat. 2776","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/107/319/s2"},"text":"“For purposes of motor vehicle safety standards issued and enforced pursuant to chapter 301 of title 49, United States Code, a low-speed electric bicycle (as defined in section 38(b) of the Consumer Product Safety Act [","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s2085/b"},"text":"15 U.S.C. 2085(b)","children":[],"tail":"]) shall not be considered a motor vehicle as defined by section 30102[(a)](6) [now 30102(a)(7)] of title 49, United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
