{"tag":"section","attrib":{"id":"idcc34cc48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45105"},"text":null,"children":[{"tag":"num","attrib":{"value":"45105"},"text":"§ 45105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rehabilitation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc34cc49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program for Employees of Air Carriers and Foreign Air Carriers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Federal Aviation Administration shall prescribe regulations establishing requirements for rehabilitation programs that at least provide for the identification and opportunity for treatment of employees of air carriers and foreign air carriers referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s45102/a/1"},"text":"section 45102(a)(1) of this title","children":[],"tail":" who need assistance in resolving problems with the use of alcohol or a controlled substance in violation of law or a United States Government regulation. Each air carrier and foreign air carrier is encouraged to make such a program available to all its employees in addition to the employees referred to in section 45102(a)(1). The Administrator shall decide on the circumstances under which employees shall be required to participate in a program. This subsection does not prevent an air carrier or foreign air carrier from establishing a program under this subsection in cooperation with another air carrier or foreign air carrier."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc34cc4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program for Employees of the Federal Aviation Administration","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall establish and maintain a rehabilitation program that at least provides for the identification and opportunity for treatment of employees of the Administration whose duties include responsibility for safety-sensitive functions who need assistance in resolving problems with the use of alcohol or a controlled substance.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc34cc4b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1223"},"text":"108 Stat. 1223","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/58"},"text":"Pub. L. 103–429, § 6(58)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4385"},"text":"108 Stat. 4385","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc34cc4c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc34cc4d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc34cc4e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"45105(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1434(c)(1).","children":[],"tail":null}