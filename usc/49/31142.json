{"tag":"section","attrib":{"id":"idcb6c7269-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142"},"text":null,"children":[{"tag":"num","attrib":{"value":"31142"},"text":"§ 31142.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Inspection of vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb6c726a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection of Safety Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On the instruction of an authorized enforcement official of a State or of the United States Government, a commercial motor vehicle is required to pass an inspection of all safety equipment required under the regulations issued under section 31136.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6c726b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection of Vehicles and Record Retention","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall prescribe regulations on Government standards for inspection of commercial motor vehicles and retention by employers of records of an inspection. The standards shall provide for annual or more frequent inspections of a commercial motor vehicle unless the Secretary finds that another inspection system is as effective as an annual or more frequent inspection system. Regulations prescribed under this subsection are deemed to be regulations prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31136"},"text":"section 31136 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6c726c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preemption","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6c726d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, this subchapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31102"},"text":"section 31102 of this title","children":[],"tail":" do not—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb6c726e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent a State or voluntary group of States from imposing more stringent standards for use in their own periodic roadside inspection programs of commercial motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6c726f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent a State from enforcing a program for inspection of commercial motor vehicles that the Secretary decides is as effective as the Government standards prescribed under subsection (b) of this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6c7270-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent a State from participating in the activities of a voluntary group of States enforcing a program for inspection of commercial motor vehicles; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6c7271-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require a State that is enforcing a program described in clause (B) or (C) of this paragraph to enforce a Government standard prescribed under subsection (b) of this section or to adopt a provision on inspection of commercial motor vehicles in addition to that program to comply with the Government standards.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6c7272-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Government standards prescribed under subsection (b) of this section shall preempt a program of a State described in paragraph (1)(C) of this subsection as the program applies to the inspection of commercial motor vehicles in that State. The State may not enforce the program if the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb6c7273-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" decides, after notice and an opportunity for a hearing, that the State is not enforcing the program in a way that achieves the objectives of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6c7274-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after making a decision under clause (A) of this paragraph, provides the State with a 6-month period to improve the enforcement of the program to achieve the objectives of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6c7275-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Inspection To Be Accepted as Adequate in All States","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A periodic inspection of a commercial motor vehicle under the Government standards prescribed under subsection (b) of this section or a program described in subsection (c)(1)(B) or (C) of this section that is being enforced shall be recognized as adequate in every State for the period of the inspection. This subsection does not prohibit a State from making random inspections of commercial motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6c7276-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effect of Government Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Government standards prescribed under subsection (b) of this section may not be enforced as the standards apply to the inspection of commercial motor vehicles in a State enforcing a program described in subsection (c)(1)(B) or (C) of this section if the Secretary decides that it is in the public interest and consistent with public safety for the Government standards not to be enforced as they apply to that inspection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6c7277-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31142/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of State Regulations to Government-Leased Vehicles and Operators","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State receiving financial assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31102"},"text":"section 31102 of this title","children":[],"tail":" in a fiscal year may enforce in that fiscal year a regulation on commercial motor vehicle safety adopted by the State as the regulation applies to commercial motor vehicles and operators leased to the Government."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb6c7278-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1010"},"text":"108 Stat. 1010","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4008/f"},"text":"Pub. L. 105–178, title IV, § 4008(f)","children":[],"tail":", (g), "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/405"},"text":"112 Stat. 405","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb6c7279-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb6c727a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb6c727b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31142(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2509(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/554/s210/a"},"text":"Pub. L. 98–554, § 210(a)","children":[],"tail":"–(f), "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2839"},"text":"98 Stat. 2839","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31142(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2509(b), (c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31142(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2509(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31142(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2509(e).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31142(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2509(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31142(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2509(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/554"},"text":"Pub. L. 98–554","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/2829"},"text":"98 Stat. 2829","children":[],"tail":", § 210(g); added "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/615/s24"},"text":"Pub. L. 101–615, § 24","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3273"},"text":"104 Stat. 3273","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, language about whether a State law or regulation may be “in effect” is omitted as redundant to language about whether it may be “enforced”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “shall prescribe regulations on” are substituted for “shall, by rule, establish” for consistency in the revised title and with other titles of the United States Code and because “rule” is synonymous with “regulation”. The words “For purposes of this chapter” are omitted as unnecessary. The text of 49 App.:2509(c) is omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), before clause (A), the words “this subchapter and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31102"},"text":"section 31102 of this title","children":[],"tail":" do not” are substituted for “nothing in section 2302 of this Appendix or section 2507 of this Appendix or any other provision of this chapter shall be construed as” to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb6c727c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb6c727d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4008/f"},"text":"Pub. L. 105–178, § 4008(f)","children":[],"tail":", substituted “the regulations issued under section 31136” for “part 393 of title 49, Code of Federal Regulations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(C). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/s4008/g"},"text":"Pub. L. 105–178, § 4008(g)","children":[],"tail":", amended subpar. (C) generally. Prior to amendment, subpar. (C) read as follows: “prevent a State from enforcing a program for inspection of commercial motor vehicles that meets the requirements for membership in the Commercial Vehicle Safety Alliance, as those requirements were in effect on "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"October 30, 1984","children":[],"tail":"; or”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb6c727e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb6c727f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"State Inspection of Passenger-Carrying Commercial Motor Vehicles","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tIII/s23008"},"text":"Pub. L. 117–58, div. B, title III, § 23008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/764"},"text":"135 Stat. 764","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dB/tIII/s23008"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"], the Secretary [of Transportation] shall solicit additional comment on the advance notice of proposed rulemaking entitled ‘State Inspection Programs for Passenger-Carrier Vehicles’ (81 Fed. Reg. 24769 ("},{"tag":"date","attrib":{"date":"2016-04-27"},"text":"April 27, 2016","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final Rule.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After reviewing all comments received in response to the solicitation under subsection (a), if the Secretary determines that data and information exist to support moving forward with a final rulemaking action, the Secretary shall issue a final rule relating to the advance notice of proposed rulemaking described in that subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In determining whether to issue a final rule under paragraph (1), the Secretary shall consider the impact of continuing to allow self-inspection as a means to satisfy periodic inspection requirements on the safety of passenger carrier operations.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb6c7280-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Update of Annual Inspection Regulations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/328/dL/tI/s131"},"text":"Pub. L. 117–328, div. L, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-29"},"text":"Dec. 29, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/5119"},"text":"136 Stat. 5119","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/328/dL/tI/s131"},"text":"“The Federal Motor Carrier Safety Administration shall update annual inspection regulations under Appendix G to subchapter B of chapter III of title 49, Code of Federal Regulations, as recommended by GAO–19–264.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Similar provisions were contained in the following appropriation acts:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/103/dL/tI/s131"},"text":"Pub. L. 117–103, div. L, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-03-15"},"text":"Mar. 15, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/706"},"text":"136 Stat. 706","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/260/dL/tI/s131"},"text":"Pub. L. 116–260, div. L, title I, § 131","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-12-27"},"text":"Dec. 27, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/1844"},"text":"134 Stat. 1844","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/116/94/dH/tI/s132"},"text":"Pub. L. 116–94, div. H, title I, § 132","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-12-20"},"text":"Dec. 20, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/133/2955"},"text":"133 Stat. 2955","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
