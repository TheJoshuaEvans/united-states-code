{"tag":"section","attrib":{"id":"idcc517aee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113"},"text":null,"children":[{"tag":"num","attrib":{"value":"47113"},"text":"§ 47113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Minority and disadvantaged business participation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc517aef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc517af0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “small business concern”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc517af1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has the meaning given the term in section 3 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"15 U.S.C. 632","children":[],"tail":"); but"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc517af2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a concern in the construction industry, a concern shall be considered a small business concern if the concern meets the size standard for the North American Industry Classification System Code 237310, as adjusted by the Small Business Administration;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc517af3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “socially and economically disadvantaged individual” has the same meaning given that term in section 8(d) of the Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s637/d"},"text":"15 U.S.C. 637(d)","children":[],"tail":") and relevant subcontracting regulations prescribed under section 8(d), except that women are presumed to be socially and economically disadvantaged; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc517af4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “qualified HUBZone small business concern” has the meaning given that term in section 31(b) of the Small Business Act.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc517af5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except to the extent the Secretary decides otherwise, at least 10 percent of amounts available in a fiscal year under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s48103"},"text":"section 48103 of this title","children":[],"tail":" shall be expended with small business concerns owned and controlled by socially and economically disadvantaged individuals or qualified HUBZone small business concerns."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc517af6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Uniform Criteria","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall establish minimum uniform criteria for State governments and airport sponsors to use in certifying whether a small business concern qualifies under this section. The criteria shall include on-site visits, personal interviews, licenses, analyses of stock ownership and bonding capacity, listings of equipment and work completed, resumes of principal owners, financial capacity, and type of work preferred.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc517af7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Surveys and Lists","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each State or airport sponsor annually shall survey and compile a list of small business concerns referred to in subsection (b) of this section and the location of each concern in the State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc517af8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mandatory Training Program.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc517af9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this subsection, the Secretary shall establish a mandatory training program for persons described in paragraph (3) to provide streamlined training on certifying whether a small business concern qualifies as a small business concern owned and controlled by socially and economically disadvantaged individuals under this section and section 47107(e).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc517afa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The training program may be implemented by one or more private entities approved by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc517afb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participants","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person referred to in paragraph (1) is an official or agent of an airport sponsor—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc517afc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is required to provide a written assurance under this section or section 47107(e) that the airport owner or operator will meet the percentage goal of subsection (b) of this section or section 47107(e)(1), as the case may be; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc517afd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who is responsible for determining whether or not a small business concern qualifies as a small business concern owned and controlled by socially and economically disadvantaged individuals under this section or section 47107(e).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc517afe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Supportive Services.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc517aff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary, in coordination with the Administrator of the Federal Aviation Administration, may, at the request of an airport sponsor, provide assistance under a grant issued under this subchapter to develop, conduct, and administer training programs and assistance programs in connection with any airport improvement project subject to part 26 of title 49, Code of Federal Regulations, for small business concerns referred to in subsection (b) to achieve proficiency to compete, on an equal basis for contracts and subcontracts related to such projects.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc517b00-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligible entities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An entity eligible to receive assistance under this section is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc517b01-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc517b02-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a political subdivision of a State or local government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc517b03-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/f/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a Tribal government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc517b04-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/f/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an airport sponsor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc517b05-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/f/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a metropolitan planning organization;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc517b06-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/f/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a group of entities described in subparagraphs (A) through (E); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc517b07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47113/f/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other organization considered appropriate by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc517b08-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1268"},"text":"108 Stat. 1268","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/429/s6/65"},"text":"Pub. L. 103–429, § 6(65)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-10-31"},"text":"Oct. 31, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/4386"},"text":"108 Stat. 4386","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/135/tVI/s604/h/2"},"text":"Pub. L. 105–135, title VI, § 604(h)(2)","children":[],