{"tag":"section","attrib":{"id":"idcadfc354-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10722"},"text":null,"children":[{"tag":"num","attrib":{"value":"10722"},"text":"§ 10722.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Car utilization","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In order to encourage more efficient use of freight cars, notwithstanding any other provision of this part, rail carriers shall be permitted to establish premium charges for special services or special levels of services not otherwise applicable to the movement. The Board shall facilitate development of such charges so as to increase the utilization of equipment.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcadfc355-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/819"},"text":"109 Stat. 819","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcadfc356-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcadfc357-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcadfc358-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s