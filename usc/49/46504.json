il":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1472(j).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 902(j); added "},{"tag":"html:span","attrib":{},"text":"Sept. 5, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/197/s1"},"text":"Pub. L. 87–197, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/466"},"text":"75 Stat. 466","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/449/s1/3"},"text":"Pub. L. 91–449, § 1(3)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/921"},"text":"84 Stat. 921","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “or threatens” are omitted as being included in “intimidating”. The words “(including any steward or stewardess)” are omitted as being included in “attendant”. The words “fined under title 18” are substituted for “fined not more than $10,000” for consistency with title 18. The words “deadly or” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc40b24f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc40b250-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" inserted “or attempts or conspires to do such an act,” before “shall be fined under title 18,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
