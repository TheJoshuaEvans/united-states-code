{"tag":"section","attrib":{"id":"idcb08595f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15904"},"text":null,"children":[{"tag":"num","attrib":{"value":"15904"},"text":"§ 15904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rights and remedies of persons injured by pipeline carriers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb085960-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Enforcement of Orders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person injured because a pipeline carrier providing transportation or service subject to this part does not obey an order of the Board, except an order for the payment of money, may bring a civil action to enforce that order under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb085961-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability of Carrier.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb085962-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15904/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Excessive charges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A pipeline carrier providing transportation subject to this part is liable to a person for amounts charged that exceed the applicable rate for the transportation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb085963-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15904/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Damages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A pipeline carrier providing transportation subject to this part is liable for damages sustained by a person as a result of an act or omission of that carrier in violation of this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb085964-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Complaints.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb085965-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Filing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person may file a complaint with the Board under section 15901(b) or bring a civil action under subsection (b) to enforce liability against a pipeline carrier providing transportation subject to this part.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb085966-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Payment deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Board makes an award under subsection (b), the Board shall order the carrier to pay the amount awarded by a specific date. The Board may order a carrier providing transportation subject to this part to pay damages only when the proceeding is on complaint. The person for whose benefit an order of the Board requiring the payment of money is made may bring a civil action to enforce that order under this paragraph if the carrier does not pay the amount awarded by the date payment was ordered to be made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb085967-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb085968-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15904/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Complaint","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When a person begins a civil action under subsection (b) to enforce an order of the Board requiring the payment of damages by a pipeline carrier providing transportation subject to this part, the text of the order of the Board must be included in the complaint. In addition to the district courts of the United States, a State court of general jurisdiction having jurisdiction of the parties has jurisdiction to enforce an order under this paragraph. The findings and order of the Board are competent evidence of the facts stated in them. Trial in a civil action brought in a district court of the United States under this paragraph is in the judicial district in which the plaintiff resides or in which the principal operating office of the carrier is located. In a civil action under this paragraph, the plaintiff is liable for only those costs that accrue on an appeal taken by the plaintiff.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb085969-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15904/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attorney’s fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The district court shall award a reasonable attorney’s fee as a part of the damages for which a carrier is found liable under this subsection. The district court shall tax and collect that fee as a part of the costs of the action.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb08596a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s106/a"},"text":"Pub. L. 104–88, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/927"},"text":"109 Stat. 927","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/15"},"text":"Pub. L. 105–102, § 2(15)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2205"},"text":"111 Stat. 2205","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/225/s7/b/2"},"text":"Pub. L. 105–225, § 7(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-08-12"},"text":"Aug. 12, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/1511"},"text":"112 Stat. 1511","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb08596b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb08596c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb08596d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:15904(c)(1) to correct an erroneous cross-reference.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb08596e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcb08596f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11705"},"text":"section 11705 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb085970-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1998—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/225"},"text":"Pub. L. 105–225","children":[],"tail":" inserted “section” before “15901(b)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" substituted “15901(b)” for “section 11501(b)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb085971-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb085972-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
