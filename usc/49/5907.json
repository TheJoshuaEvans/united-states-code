t":"106 Stat. 3649","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5907(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:508(a)(3) (related to effective date).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “shall initiate a proceeding to issue regulations . . . within 180 days after the date of enactment of this Act” are omitted as executed.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b) is substituted for the source provision and made applicable to the entire chapter for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad3dca2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcad3dca3-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Intermodal Safe Container Transportation Amendments Act of 1996, referred to in text, is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/291"},"text":"Pub. L. 104–291","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcad3dca4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/291"},"text":"Pub. L. 104–291","children":[],"tail":" substituted “Effective date” for “Regulations and effective date” in section catchline and amended text generally. Prior to amendment, text read as follows:"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(a) ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—Not later than "},{"tag":"date","attrib":{"date":"1993-07-25"},"text":"July 25, 1993","children":[],"tail":", the Secretary of Transportation shall prescribe final regulations to enforce this chapter. The Secretary may establish by regulation exemptions to the regulations that are in the public interest and consistent with the purposes of this chapter."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(b) ","children":[{"tag":"inline","attrib":{},"text":"Effective Date","children":[],"tail":".—This chapter is effective on the date final regulations to enforce this chapter are prescribed.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
