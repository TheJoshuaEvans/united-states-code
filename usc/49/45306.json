{"tag":"section","attrib":{"id":"idcc373d02-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45306"},"text":null,"children":[{"tag":"num","attrib":{"value":"45306"},"text":"§ 45306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Manual surcharge","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc373d03-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45306/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later 3 years after the date of enactment of the FAA Reauthorization Act of 2018, the Administrator shall impose and collect a surcharge on a Civil Aviation Registry transaction that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc373d04-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45306/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is conducted in person at the Civil Aviation Registry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373d05-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45306/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could be conducted, as determined by the Administrator, with the same or greater level of efficiency by electronic or other remote means; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc373d06-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45306/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not related to research or other non-commercial activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373d07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45306/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Surcharge","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A surcharge imposed and collected under subsection (a) shall not exceed twice the maximum fee the Administrator is authorized to charge for the registration of an aircraft, not used to provide air transportation, after the transfer of ownership under section 45302(b)(2).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc373d08-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s45306/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Credit to Account and Availability","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Monies collected from a surcharge imposed under subsection (a) shall be treated as monies collected under section 45302 and subject to the terms and conditions set forth in section 45302(d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc373d09-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tV/s546/d"},"text":"Pub. L. 115–254, div. B, title V, § 546(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3376"},"text":"132 Stat. 3376","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc373d0a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc373d0b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc373d0c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the FAA Reauthorization Act of 2018, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
