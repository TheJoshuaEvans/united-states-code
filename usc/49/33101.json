{"tag":"section","attrib":{"id":"idcb8b93c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101"},"text":null,"children":[{"tag":"num","attrib":{"value":"33101"},"text":"§ 33101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8b93c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “chop shop” means a building, lot, facility, or other structure or premise at which at least one person engages in receiving, concealing, destroying, disassembling, dismantling, reassembling, or storing a passenger motor vehicle or passenger motor vehicle part that has been unlawfully obtained—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8b93c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to alter, counterfeit, deface, destroy, disguise, falsify, forge, obliterate, or remove the identity of the vehicle or part, including the vehicle identification number or a derivative of that number; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to distribute, sell, or dispose of the vehicle or part in interstate or foreign commerce.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8b93ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “covered major part” means a major part selected under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s33104"},"text":"section 33104 of this title","children":[],"tail":" for coverage by the vehicle theft prevention standard prescribed under section 33102 or 33103 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8b93cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “existing line” means a line introduced into commerce before ","children":[{"tag":"date","attrib":{"date":"1990-01-01"},"text":"January 1, 1990","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8b93cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “first purchaser” means the person making the first purchase other than for resale.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8b93cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “line” means a name that a manufacturer of motor vehicles applies to a group of motor vehicle models of the same make that have the same body or chassis, or otherwise are similar in construction or design.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8b93ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “major part” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8b93cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the engine;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the transmission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each door to the passenger compartment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the hood;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/6/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the grille;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/6/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each bumper;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/6/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each front fender;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/6/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the deck lid, tailgate, or hatchback;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/6/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each rear quarter panel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/6/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the trunk floor pan;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/6/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the frame or, for a unitized body, the supporting structure serving as the frame; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/6/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other part of a passenger motor vehicle that the Secretary of Transportation by regulation specifies as comparable in design or function to any of the parts listed in subclauses (A)–(K) of this clause.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8b93db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “major replacement part” means a major part that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8b93dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an original major part in or on a completed motor vehicle and customized or modified after manufacture of the vehicle but before the time of its delivery to the first purchaser; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8b93dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not installed in or on a motor vehicle at the time of its delivery to the first purchaser and the equitable or legal title to the vehicle has not been transferred to a first purchaser.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8b93de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “model year” has the same meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32901/a"},"text":"section 32901(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8b93df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33101