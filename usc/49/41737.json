{"tag":"section","attrib":{"id":"idcbce40f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737"},"text":null,"children":[{"tag":"num","attrib":{"value":"41737"},"text":"§ 41737.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Compensation guidelines, limitations, and claims","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbce40f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compensation Guidelines","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbce40f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation shall prescribe guidelines governing the rate of compensation payable under this subchapter. The guidelines shall be used to determine the reasonable amount of compensation required to ensure the continuation of air service or air transportation under this subchapter. The guidelines shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbce40f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide for a reduction in compensation when an air carrier does not provide service or transportation agreed to be provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce40f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider amounts needed by an air carrier to promote public use of the service or transportation for which compensation is being paid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce40f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include expense elements based on representative costs of air carriers providing scheduled air transportation of passengers, property, and mail on aircraft of the type the Secretary decides is appropriate for providing the service or transportation for which compensation is being provided;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce40f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include provisions under which the Secretary may encourage an air carrier to improve air service for which compensation is being paid under this subchapter by incorporating financial incentives in an essential air service contract based on specified performance goals, including goals related to improving on-time performance, reducing the number of flight cancellations, establishing reasonable fares (including joint fares beyond the hub airport), establishing convenient connections to flights providing service beyond hub airports, and increasing marketing efforts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbce40f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" include provisions under which the Secretary may execute a long-term essential air service contract to encourage an air carrier to provide air service to an eligible place if it would be in the public interest to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce40f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Promotional amounts described in paragraph (1)(B) of this subsection shall be a special, segregated element of the compensation provided to a carrier under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbce40fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Required Finding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may pay compensation to an air carrier for providing air service or air transportation under this subchapter only if the Secretary finds the carrier is able to provide the service or transportation in a reliable way.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbce40fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Claims","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 15 days after receiving a written claim from an air carrier for compensation under this subchapter, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbce40fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pay or deny the United States Government’s share of a claim; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce40fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if denying the claim, notify the carrier of the denial and the reasons for the denial.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbce40fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Make Agreements and Incur Obligations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may make agreements and incur obligations from the Airport and Airway Trust Fund established under section 9502 of the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s9502"},"text":"26 U.S.C. 9502","children":[],"tail":") to pay compensation under this subchapter. An agreement by the Secretary under this subsection is a contractual obligation of the Government to pay the Government’s share of the compensation."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbce40ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adjustments to Account for Significantly Increased Costs.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbce4100-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary determines that air carriers are experiencing significantly increased costs in providing air service or air transportation for which compensation is being paid under this subchapter, the Secretary may increase the rates of compensation payable under this subchapter without regard to any agreement or requirement relating to the renegotiation of contracts or any notice requirement under section 41734.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4101-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Readjustment if costs subsequently decline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If an adjustment is made under paragraph (1), and total unit costs subsequently decrease to at least the total unit cost reflected in the compensation rate, then the Secretary may reverse the adjustment previously made under paragraph (1) without regard to any agreement or requirement relating to the renegotiation of contracts or any notice requirement under section 41734.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbce4102-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41737/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Significantly increased costs defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “significantly increased costs” means a total unit cost increase (but not increases in individual unit costs) of 10 percent or more in relation to the total unit cost reflected in the compensation rate, based on the carrier’s internal audit of its financial statements if such cost increase is incurred for a period of at least 2 consecutive months.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbce4103-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1151"},"text":"108 Stat. 1151","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tIV/s402/a"},"text":"Pub. L. 108–176, title IV, § 402(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2543"},"text":"117 Stat. 2543","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIV/s427/a"},"text":"Pub. L. 112–95, title IV, § 427(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/99"},"text":"126 Stat. 99","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tV/s561/h"},"text":"Pub. L. 118–63, title V, § 561(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1216"},"text":"138 Stat. 1216","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbce4104-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbce4105-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbce4106-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41737(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1389(f).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 419(e)(2)–(g); added "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/504/s33/a"},"text":"Pub. L. 95–504, § 33(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/1732"},"text":"92 Stat. 1732","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Dec. 8, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/213/s10"},"text":"Pub. L. 98–213, § 10","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/97/1461"},"text":"97 Stat. 1461","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s9/r"},"text":"Pub. L. 98–443, § 9(r)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1708"},"text":"98 Stat. 1708","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Dec. 30, 1987","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/223/s202/a/1"},"text":"Pub. L. 100–223, § 202(a)(1)","children":[],"tail":", (2), (b)(1), "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1507"},"text":"101 Stat. 1507","children":[],"tail":", 1515."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41737(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1389(e)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41737(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1389(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41737(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1389(","children":[{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":")."}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 419("},{"tag":"html:i","attrib":{},"text":"l","children":[],"tail":"); added "},{"tag":"html:span","attrib":{},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/508/s9113/b/1"},"text":"Pub. L. 101–508, § 9113(b)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/1388-363"},"text":"104 Stat. 1388–363","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the word “prescribe” is substituted for “establish” to eliminate an executed word. The words “air service or air transportation under this subchapter” are substituted for “air service under this section” for consistency with the source provisions restated in sections 41733, 41735, and 41736 of the revised title. In clause (C), the words “the service or transportation for which compensation is being provided” are substituted for “such service” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(2), the words “compensation provided to a carrier under this subchapter” are substituted for “required compensation” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “air service or air transportation” are substituted for “air service” for consistency with the source provisions restated in sections 41733, 41735, and 41736 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), the reference to fiscal year 1992 is omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbce4107-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbce4108-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" struck out par. (1) designation before “The Secretary” and par. (2) which read as follows: “Not more than $38,600,000 is available to the Secretary out of the Fund for each of the fiscal years ending "},{"tag":"date","attrib":{"date":"1993-09-30"},"text":"September 30, 1993","children":[],"tail":"–1998, to incur obligations under this section. Amounts made available under this section remain available until expended.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a)(1)(D), (E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95"},"text":"Pub. L. 112–95","children":[],"tail":" added subpars. (D) and (E)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" added subsec. (e)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbce4109-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbce410a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/tIV/s402/b"},"text":"Pub. L. 108–176, title IV, § 402(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2543"},"text":"117 Stat. 2543","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/176/tIV/s402/b"},"text":"“The amendment made by subsection (a) [amending this section] shall take effect 30 days after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbce410b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Emergency Across-the-Board Adjustment to Compensation for Significantly Increased Costs","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIV/s426/a"},"text":"Pub. L. 112–95, title IV, § 426(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/98"},"text":"126 Stat. 98","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tV/s539/s/1"},"text":"Pub. L. 115–254, div. B, title V, § 539(s)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3371"},"text":"132 Stat. 3371","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/254/dB/tV/s539/s/1"},"text":"“Subject to the availability of funds, the Secretary of Transportation may increase the rates of compensation payable to air carriers under subchapter II of chapter 417 of title 49, United States Code, to compensate such carriers for increased aviation fuel costs without regard to any agreement or requirement relating to the renegotiation of contracts or any notice requirement under section 41734 of such title.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcbce410c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Issuance of Revised Guidance","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/tIV/s427/b"},"text":"Pub. L. 112–95, title IV, § 427(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/99"},"text":"126 Stat. 99","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/95/tIV/s427/b"},"text":"“Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":"], the Secretary of Transportation shall issue revised guidelines governing the rate of compensation payable under subchapter II of chapter 417 that incorporate the amendments made by this section [amending this section].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
