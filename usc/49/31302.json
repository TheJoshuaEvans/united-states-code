{"tag":"section","attrib":{"id":"idcb6ee391-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31302"},"text":null,"children":[{"tag":"num","attrib":{"value":"31302"},"text":"§ 31302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Commercial driver’s license requirement","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No individual shall operate a commercial motor vehicle without a valid commercial driver’s license issued in accordance with section 31308. An individual operating a commercial motor vehicle may have only one driver’s license at any time and may have only one learner’s permit at any time.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb6ee392-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1015"},"text":"108 Stat. 1015","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4011/b/1"},"text":"Pub. L. 105–178, title IV, § 4011(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/407"},"text":"112 Stat. 407","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4122/1"},"text":"Pub. L. 109–59, title IV, § 4122(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1734"},"text":"119 Stat. 1734","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb6ee393-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"i