{"tag":"section","attrib":{"id":"idcc3e690b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46319"},"text":null,"children":[{"tag":"num","attrib":{"value":"46319"},"text":"§ 46319.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Permanent closure of an airport without providing sufficient notice","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc3e690c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46319/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A public agency (as defined in section 47102) may not permanently close an airport listed in the national plan of integrated airport systems under section 47103 without providing written notice to the Administrator of the Federal Aviation Administration at least 30 days before the date of the closure.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc40b1fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46319/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall publish each notice received under subsection (a) in the Federal Register.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc40b1fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46319/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A public agency violating subsection (a) shall be liable for a civil penalty of $10,000 for each day that the airport remains closed without having given the notice required by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc40b1ff-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/tI/s185/a"},"text":"Pub. L. 108–176, title I, § 185(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2517"},"text":"117 Stat. 2517","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc40b200-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc40b201-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc40b202-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as an Effective Date of 2003 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
