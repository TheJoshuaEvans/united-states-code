{"tag":"section","attrib":{"id":"idcb7f8550-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32504"},"text":null,"children":[{"tag":"num","attrib":{"value":"32504"},"text":"§ 32504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certificates of compliance","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Under regulations prescribed by the Secretary of Transportation, a manufacturer or distributor of a passenger motor vehicle or passenger motor vehicle equipment subject to a standard prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32502"},"text":"section 32502 of this title","children":[],"tail":" shall give the distributor or dealer at the time of delivery a certificate that the vehicle or equipment complies with the standard."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb7f8551-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1044"},"text":"108 Stat. 1044","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb7f8552-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb7f8553-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb7f8554-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{