{"tag":"section","attrib":{"id":"idcb6ee314-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31150"},"text":null,"children":[{"tag":"num","attrib":{"value":"31150"},"text":"§ 31150.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety performance history screening","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb6ee315-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31150/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall provide persons conducting preemployment screening services for the motor carrier industry electronic access to the following reports contained in the Motor Carrier Management Information System:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6ee316-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31150/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Commercial motor vehicle accident reports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6ee317-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31150/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Inspection reports that contain no driver-related safety violations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6ee318-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31150/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serious driver-related safety violation inspection reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6ee319-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31150/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Conditions on Providing Access","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Before providing a person access to the Motor Carrier Management Information System under subsection (a), the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6ee31a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31150/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any information that is released to such person will be in accordance with the Fair Credit Reporting Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s1681"},"text":"15 U.S.C. 1681","children":[],"tail":" et seq.) and all other applicable Federal law;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6ee31b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31150/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that such person will not conduct a screening without the operator-applicant’s written consent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6ee31c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31150/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that any information that is released to such person will not be released to any person or entity, other than the motor carrier requesting the screening services or the operator-applicant, unless expressly authorized or required by law; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6ee31d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31150/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a procedure for the operator-applicant to correct inaccurate information in the System in a timely manner.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6ee31e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31150/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Design","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The process for providing access to the Motor Carrier Management Information System under subsection (a) shall be designed to assist the motor carrier industry in assessing an individual operator’s crash and serious safety violation inspection history as a preemployment condition. Use of the process shall not be mandatory and may only be used during the preemployment assessment of an operator-applicant.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6ee31f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31150/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Serious Driver-Related Safety Violation Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “serious driver-related violation” means a violation by an operator of a commercial motor vehicle that the Secretary determines will result in the operator being prohibited from continuing to operate a commercial motor vehicle until the violation is corrected.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb6ee320-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4117/a"},"text":"Pub. L. 109–59, title IV, § 4117(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1728"},"text":"119 Stat. 1728","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb6ee321-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb6ee322-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb6ee323-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Fair Credit Reporting Act, referred to in subsec. (b)(1), is title VI of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/321"},"text":"Pub. L. 90–321","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/91/508/tVI/s601"},"text":"Pub. L. 91–508, title VI, § 601","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1970-10-26"},"text":"Oct. 26, 1970","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/84/1127"},"text":"84 Stat. 1127","children":[],"tail":", which is classified generally to subchapter III (§ 1681 et seq.) of chapter 41 of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1601"},"text":"section 1601 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
