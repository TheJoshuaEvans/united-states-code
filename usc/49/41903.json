{"tag":"section","attrib":{"id":"idcbd2fc2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41903"},"text":null,"children":[{"tag":"num","attrib":{"value":"41903"},"text":"§ 41903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Duty to provide certain transportation of mail","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd2fc2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air Carriers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (b) of this section, an air carrier authorized by its certificate to transport mail by aircraft between places in Alaska shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd2fc2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41903/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide facilities and services necessary and adequate to provide that transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd2fc30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41903/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transport mail between the places authorized in the certificate for transportation of mail when required, and under regulations prescribed, by the United States Postal Service.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd2fc31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Maximum Mail Load","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may prescribe the maximum mail load for a schedule or for an aircraft or type of aircraft for the transportation of mail by aircraft between places in Alaska. If the Postal Service tenders to an air carrier mail exceeding the maximum load for transportation by the carrier under a schedule designated or required to be established for the transportation of mail under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41902/c"},"text":"section 41902(c) of this title","children":[],"tail":", the carrier, as nearly in accordance with the schedule as the Secretary decides is possible, shall—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd2fc32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41903/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide facilities sufficient to transport the mail to the extent the Secretary decides the carrier reasonably is able to do so; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd2fc33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41903/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transport that mail.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd2fc34-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":", §§ 1(e), 4(k)(1), "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1154"},"text":"108 Stat. 1154","children":[],"tail":", 1370; "},{"tag