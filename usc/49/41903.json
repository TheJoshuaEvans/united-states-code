{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(a)(4)(A) (related to 49 App.:1375(c)).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(b)(1)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(b)(1)(E); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/e"},"text":"Pub. L. 98–443, § 3(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “Subject to subsection (b) of this section” are added for clarity because subsection (b) limits the effect of this section. The words “transport mail by aircraft in foreign air transportation or between places in Alaska” are substituted for “the transportation of mail” in 49 App.:1371(","children":[{"tag":"i","attrib":{},"text":"l","children":[],"tail":") and “the transportation of mail by aircraft” in 49 App.:1375(d) because 49 App.:1551(a)(4)(A) provides that 49 App.:1371("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") and 1375(d) no longer apply to interstate or overseas air transportation (except transportation of mail between 2 places in Alaska). Clause (2) is substituted for “shall transport mail whenever required by the United States Postal Service” in 49 App.:1371("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") and the text of 49 App.:1375(d) for clarity and to eliminate unnecessary words. The text of 49 App.:1371("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") (last sentence) is omitted as surplus because section 41901 of the revised title specifies how the rates of compensation are determined."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “transportation of mail by aircraft in foreign air transportation or between places in Alaska” are added because 49 App.:1551(a)(4)(A) provides that 49 App.:1375(c) no longer applies to interstate or overseas air transportation of mail (except transportation of mail between 2 places in Alaska).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbd2fc38-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbd2fc39-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Pub. L","children":[],"tail":". 103–272, § 4(k)(1)"}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"41903","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(a)(8).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(a)(8); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/c"},"text":"Pub. L. 98–443, § 3(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 30, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/457/s346"},"text":"Pub. L. 100–457, § 346","children":[],"tail":" (related to § 1601(a)(8) of Federal Aviation Act of 1958), "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2155"},"text":"102 Stat. 2155","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(b)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(b)(3); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/f"},"text":"Pub. L. 98–443, § 3(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 30, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/457/s346"},"text":"Pub. L. 100–457, § 346","children":[],"tail":" (related to § 1601(b)(3) of Federal Aviation Act of 1958), "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2155"},"text":"102 Stat. 2155","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 4(k) reflects amendments to the restatement required by section 1601(a)(8) of the Federal Aviation Act of 1958 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":"), as added by section 3(c) of the Civil Aeronautics Board Sunset Act of 1984 ("},{"tag":"ref","attrib":{"href":"/us/pl/98/443"},"text":"Public Law 98–443","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"), and section 1601(b)(3) of the Federal Aviation Act of 1958 ("},{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":"), as added by section 3(f) of the Civil Aeronautics Board Sunset Act of 1984 ("},{"tag":"ref","attrib":{"href":"/us/pl/98/443"},"text":"Public Law 98–443","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"). Section 1601(a)(8) provides that the authority under 49 App.:1371("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":") and (m) and 1375(b)–(d) as those sections relate to transportation of mail by aircraft between places in Alaska (restated in sections 41107 and 41901–41903 of the revised title) ceases on "},{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":". Section 1601(b)(3) transfers the authority for prescribing rates for transportation of mail between places in Alaska from the Secretary of Transportation to the Postal Service effective "},{"tag":"date","attrib":{"date":"1999-01-01"},"text":"January 1, 1999","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbd2fc3a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbd2fc3b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsecs. (a), (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/405"},"text":"Pub. L. 110–405","children":[],"tail":" struck out “in foreign air transportation or” before “between places in Alaska” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/31"},"text":"Pub. L. 106–31","children":[],"tail":" repealed "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/k"},"text":"Pub. L. 103–272, § 4(k)","children":[],"tail":". See 1994 Amendment note below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/k/1"},"text":"Pub. L. 103–272, § 4(k)(1)","children":[],"tail":", which directed the amendment of this section by substituting “foreign air transportation” for “foreign air transportation or between places in Alaska” in introductory provisions of subsecs. (a) and (b), effective "},{"tag":"date","attrib":{"date":"1999-01-01"},"text":"Jan. 1, 1999","children":[],"tail":", was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/106/31/s6003"},"text":"Pub. L. 106–31, § 6003","children":[],"tail":", effective "},{"tag":"date","attrib":{"date":"1998-12-31"},"text":"Dec. 31, 1998","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbd2fc3c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"