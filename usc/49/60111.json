{"tag":"section","attrib":{"id":"idcc7c5c47-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60111"},"text":null,"children":[{"tag":"num","attrib":{"value":"60111"},"text":"§ 60111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Financial responsibility for liquefied natural gas facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc7c5c48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Secretary of Transportation believes that an operator of a liquefied natural gas facility does not have adequate financial responsibility for the facility, the Secretary may issue a notice to the operator about the inadequacy and the amount of financial responsibility the Secretary considers adequate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Hearings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An operator receiving a notice under subsection (a) of this section may have a hearing on the record not later than 30 days after receiving the notice. The operator may show why the Secretary should not issue an order requiring the operator to demonstrate and maintain financial responsibility in at least the amount the Secretary considers adequate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc7c5c4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Orders","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"After an opportunity for a hearing on the record, the Secretary may issue the order if the Secretary decides it is justified in the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc7c5c4b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1317"},"text":"108 Stat. 1317","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc7c5c4c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc7c5c4d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc7c5c4e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60111(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1674b(b)(1), (c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/481"},"text":"Pub. L. 90–481","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/720"},"text":"82 Stat. 720","children":[],"tail":", § 7(b)(1)–(3), (c); added "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/129/s153"},"text":"Pub. L. 96–129, § 153","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/1002"},"text":"93 Stat. 1002","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60111(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1674b(b)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60111(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1674b(b)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “is not maintaining adequate insurance or otherwise”, the text of 49 App.:1674b(c), and the words “and serve upon” and “a statement of” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s554"},"text":"section 554 of title 5","children":[],"tail":"” are omitted for consistency in the revised title and because 5:554 applies to a hearing on the record unless otherwise stated. The words “to be held” and “cause as to” are omitted as surplus. The words “the Secretary considers adequate” are substituted for “indicated in the notice under paragraph (1)” for clarity and to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c) is substituted for 49 App.:1674b(b)(3) to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
