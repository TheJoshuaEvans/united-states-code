{"tag":"section","attrib":{"id":"idcc66d84b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47511"},"text":null,"children":[{"tag":"num","attrib":{"value":"47511"},"text":"§ 47511.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" CLEEN engine and airframe technology partnership","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc66d84c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47511/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Federal Aviation Administration shall enter into a cost-sharing cooperative agreement, using a competitive process, with institutions, entities, or consortiums to carry out a program for the development, maturation, and testing of certifiable CLEEN aircraft, engine technologies, and jet fuels for civil airplanes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc66d84d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47511/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"CLEEN Engine and Airframe Technology Defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “CLEEN aircraft and engine technology” means continuous lower energy, emissions, and noise aircraft and engine technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc66d84e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47511/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Objective","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall establish the performance objectives for the program in terms of the specific objectives to reduce fuel burn, emissions and noise.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc66d84f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47511/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Selection","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the program, the Administrator may provide that not less than 2 of the cooperative agreements entered into under this section involve the participation of an entity that is a small business concern (as defined in section 3 of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632"},"text":"15 U.S.C. 632","children":[],"tail":")), provided that the submitted technology proposal of the entity meets, at a minimum, FAA Acquisition Management System requirements and requisite technology readiness levels for entry into the agreement, as determined by the Administrator."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc66d850-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tVII/s743/a"},"text":"Pub. L. 115–254, div. B, title VII, § 743(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3413"},"text":"132 Stat. 3413","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tX/s1008"},"text":"Pub. L. 118–63, title X, § 1008","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1389"},"text":"138 Stat. 1389","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc66d851-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc66d852-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc66d853-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s1008/1"},"text":"Pub. L. 118–63, § 1008(1)","children":[],"tail":", struck out “subsonic” after “fuels for civil”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s1008/2"},"text":"Pub. L. 118–63, § 1008(2)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
