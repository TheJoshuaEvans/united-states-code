{"tag":"section","attrib":{"id":"idcb4fea05-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30143"},"text":null,"children":[{"tag":"num","attrib":{"value":"30143"},"text":"§ 30143.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor vehicles imported by individuals employed outside the United States","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb4fea06-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30143/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, “assigned place of employment” means—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4fea07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30143/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the principal location at which an individual is permanently or indefinitely assigned to work; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea08-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30143/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for a member of the uniformed services, the individual’s permanent duty station.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fea09-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30143/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30112/a"},"text":"Section 30112(a) of this title","children":[],"tail":" does not apply to a motor vehicle imported for personal use, and not for resale, by an individual—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4fea0a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30143/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whose assigned place of employment was outside the United States as of ","children":[{"tag":"date","attrib":{"date":"1988-10-31"},"text":"October 31, 1988","children":[],"tail":", and who has not had an assigned place of employment in the United States from that date through the date the vehicle is imported into the United States;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea0b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30143/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who previously had not imported a motor vehicle into the United States under this section or section 108(g) of the National Traffic and Motor Vehicle Safety Act of 1966 or, before ","children":[{"tag":"date","attrib":{"date":"1988-10-31"},"text":"October 31, 1988","children":[],"tail":", under section 108(b)(3) of that Act;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea0c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30143/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who acquired, or made a binding contract to acquire, the vehicle before ","children":[{"tag":"date","attrib":{"date":"1988-10-31"},"text":"October 31, 1988","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea0d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30143/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who imported the vehicle into the United States not later than ","children":[{"tag":"date","attrib":{"date":"1992-10-31"},"text":"October 31, 1992","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea0e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30143/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" who satisfies section 108(b)(3) of that Act as in effect on ","children":[{"tag":"date","attrib":{"date":"1988-10-30"},"text":"October 30, 1988","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4fea0f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30143/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (b) of this section is carried out by certification in the form the Secretary of Transportation or the Secretary of the Treasury may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb4fea10-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/963"},"text":"108 Stat. 963","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb4fea11-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb4fea12-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb4fea13-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30143(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(g) (3d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Sept. 9, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/563"},"text":"Pub. L. 89–563","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/718"},"text":"80 Stat. 718","children":[],"tail":", § 108(g); added "},{"tag":"html:span","attrib":{},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/562/s2/b"},"text":"Pub. L. 100–562, § 2(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2823"},"text":"102 Stat. 2823","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"30143(b), (c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:1397(g) (1st, 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “(including a member of the uniformed services)” are omitted as unnecessary because of the restatement. In clause (1), the words “from that date through the date the vehicle is imported into the United States” are substituted for “that date and the date of entry of such motor vehicle” for clarity and consistency in this chapter. In clause (2), the words “under this section or section 108(g) of the National Traffic and Motor Vehicle Safety Act of 1966” are substituted for “this subsection” to preserve the exemption for motor vehicles imported under the source provisions between ","children":[{"tag":"date","attrib":{"date":"1988-10-30"},"text":"October 30, 1988","children":[],"tail":", and the effective date of this restatement. In clause (4), the word “imports” is substituted for “enters” for clarity and consistency in this chapter. In clause (5) the word “satisfies” is substituted for “meets the terms, conditions, and other requirements . . . under” to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb4fea14-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb4fea15-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Subsections (b)(3) and (g) of section 108 of the National Traffic and Motor Vehicle Safety Act of 1966, referred to in subsec. (b)(2), (5), are subsecs. (b)(3) and (g) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/563/s108"},"text":"section 108 of Pub. L. 89–563","children":[],"tail":", which were classified to subsecs. (b)(3) and (g), respectively, of "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s1397"},"text":"section 1397 of Title 15","children":[],"tail":", Commerce and Trade, were repealed and reenacted in sections 30112(b)(1)–(3) and 30143, respectively, of this title by "},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":", §§ 1(e), 7(b), "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/945"},"text":"108 Stat. 945","children":[],"tail":", 963, 1379."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
