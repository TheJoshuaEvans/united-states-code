{"tag":"section","attrib":{"id":"idcae95fe1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123"},"text":null,"children":[{"tag":"num","attrib":{"value":"11123"},"text":"§ 11123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Situations requiring immediate action to serve the public","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcae95fe2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When the Board determines that shortage of equipment, congestion of traffic, unauthorized cessation of operations, failure of existing commuter rail passenger transportation operations caused by a cessation of service by the National Railroad Passenger Corporation, or other failure of traffic movement exists which creates an emergency situation of such magnitude as to have substantial adverse effects on shippers, or on rail service in a region of the United States, or that a rail carrier providing transportation subject to the jurisdiction of the Board under this part cannot transport the traffic offered to it in a manner that properly serves the public, the Board may, to promote commerce and service to the public, for a period not to exceed 30 days—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcae95fe3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" direct the handling, routing, and movement of the traffic of a rail carrier and its distribution over its own or other railroad lines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae95fe4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require joint or common use of railroad facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae95fe5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prescribe temporary through routes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae95fe6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" give directions for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcae95fe7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/a/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preference or priority in transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcae95fe8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/a/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" embargoes; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcae95fe9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/a/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" movement of traffic under permits; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae95fea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a failure of existing freight or commuter rail passenger transportation operations caused by a cessation of service by the National Railroad Passenger Corporation, direct the continuation of the operations and dispatching, maintenance, and other necessary infrastructure functions related to the operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae95feb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcae95fec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except with respect to proceedings under paragraph (2) of this subsection, the Board may act under this section on its own initiative or on application without regard to subchapter II of chapter 5 of title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae95fed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Rail carriers may establish between themselves the terms of compensation for operations, and use of facilities and equipment, required under this section. When rail carriers do not agree on the terms of compensation under this section, the Board may establish the terms for them. The Board may act under subsection (a) before conducting a proceeding under this paragraph.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae95fee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcae95fef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in subparagraph (B), when a rail carrier is directed under this section to operate the lines of another rail carrier due to that carrier’s cessation of operations, compensation for the directed operations shall derive only from revenues generated by the directed operations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcae95ff0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In the case of a failure of existing freight or commuter rail passenger transportation operations caused by a cessation of service by the National Railroad Passenger Corporation, the Board shall provide funding to fully reimburse the directed service provider for its costs associated with the activities directed under subsection (a), including the payment of increased insurance premiums. The Board shall order complete indemnification against any and all claims associated with the provision of service to which the directed rail carrier may be exposed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae95ff1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcae95ff2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board may extend any action taken under subsection (a) of this section beyond 30 days if the Board finds that a transportation emergency described in subsection (a) continues to exist. Action by the Board under subsection (a) of this section may not remain in effect for more than 240 days beyond the initial 30-day period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae95ff3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Board may not take action under this section that would—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcae95ff4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cause a rail carrier to operate in violation of this part; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcae95ff5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" impair substantially the ability of a rail carrier to serve its own customers adequately, or to fulfill its common carrier obligations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae95ff6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A rail carrier directed by the Board to take action under this section is not responsible, as a result of that action, for debts of any other rail carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcae95ff7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In the case of a failure of existing freight or commuter rail passenger transportation operations caused by cessation of service by the National Railroad Passenger Corporation, the Board may not direct a rail carrier to undertake activities under subsection (a) to continue such operations unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcae95ff8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/c/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board first affirmatively finds that the rail carrier is operationally capable of conducting the directed service in a safe and efficient manner; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcae95ff9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/c/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the funding for such directed service required by subparagraph (B) of subsection (b)(3) is provided in advance in appropriations Acts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae95ffa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out this section, the Board shall require, to the maximum extent practicable, the use of employees who would normally have performed work in connection with the traffic subject to the action of the Board.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae95ffb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the National Railroad Passenger Corporation and any entity providing commuter rail passenger transportation shall be considered rail carriers subject to the Board’s jurisdiction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcae95ffc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11123/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the term “commuter rail passenger transportation” has the meaning given that term in section 24102(4).","children":[{"tag":"ref","attrib":{"idref":"fn002048"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002048"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcae95ffd-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/833"},"text":"109 Stat. 833","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/108/199/dF/tI/s150/1"},"text":"Pub. L. 108–199, div. F, title I, § 150(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-01-23"},"text":"Jan. 23, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/302"},"text":"118 Stat. 302","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcae95ffe-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcae95fff-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcae96000-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s24102"},"text":"Section 24102 of this title","children":[],"tail":", referred to in subsec. (f), was subsequently amended, and section 24102(4) no longer defines “commuter rail passenger transportation”. However, such term is defined elsewhere in that section."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcae96001-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 11123, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Pub. L. 95–473","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-17"},"text":"Oct. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1422"},"text":"92 Stat. 1422","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/448/tII/s226"},"text":"Pub. L. 96–448, title II, § 226","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-14"},"text":"Oct. 14, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/1930"},"text":"94 Stat. 1930","children":[],"tail":", related to situations requiring immediate action, prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcae96002-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/s150/1/A/i"},"text":"Pub. L. 108–199, § 150(1)(A)(i)","children":[],"tail":", inserted “failure of existing commuter rail passenger transportation operations caused by a cessation of service by the National Railroad Passenger Corporation,” after “cessation of operations,” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/s150/1/A/ii"},"text":"Pub. L. 108–199, § 150(1)(A)(ii)","children":[],"tail":"–(iv), added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/s150/1/B"},"text":"Pub. L. 108–199, § 150(1)(B)","children":[],"tail":", designated existing provisions as subpar. (A), substituted “Except as provided in subparagraph (B), when” for “When”, and added subpar. (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/s150/1/C"},"text":"Pub. L. 108–199, § 150(1)(C)","children":[],"tail":", added par. (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/199/s150/1/D"},"text":"Pub. L. 108–199, § 150(1)(D)","children":[],"tail":", added subsecs. (e) and (f)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcae96003-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcae96004-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
