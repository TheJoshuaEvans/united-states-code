{"tag":"section","attrib":{"id":"idcc3e68f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46317"},"text":null,"children":[{"tag":"num","attrib":{"value":"46317"},"text":"§ 46317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalty for pilots operating in air transportation without an airman’s certificate","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc3e68f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46317/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Criminal Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual shall be fined under title 18 or imprisoned for not more than 3 years, or both, if that individual—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc3e68f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46317/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully serves or attempts to serve in any capacity as an airman operating an aircraft in air transportation without an airman’s certificate authorizing the individual to serve in that capacity; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e68f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46317/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" knowingly and willfully employs for service or uses in any capacity as an airman to operate an aircraft in air transportation an individual who does not have an airman’s certificate authorizing the individual to serve in that capacity.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc3e68f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46317/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Controlled Substance Criminal Penalty.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc3e68f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46317/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Controlled substances defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “controlled substance” has the meaning given that term in section 102 of the Comprehensive Drug Abuse Prevention and Control Act of 1970 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t21/s802"},"text":"21 U.S.C. 802","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e68f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46317/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Criminal penalty","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An individual violating subsection (a) shall be fined under title 18 or imprisoned for not more than 5 years, or both, if the violation is related to transporting a controlled substance by aircraft or aiding or facilitating a controlled substance violation and that transporting, aiding, or facilitating—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc3e68f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46317/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is punishable by death or imprisonment of more than 1 year under a Federal or State law; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc3e68fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46317/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is related to an act punishable by death or imprisonment for more than 1 year under a Federal or State law related to a controlled substance (except a law related to simple possession (as that term is used in section 46306(c)) of a controlled substance).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e68fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46317/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms of imprisonment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A term of imprisonment imposed under paragraph (2) shall be served in addition to, and not concurrently with, any other term of imprisonment imposed on the individual subject to the imprisonment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc3e68fc-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tV/s509/a"},"text":"Pub. L. 106–181, title V, § 509(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/141"},"text":"114 Stat. 141","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc3e68fd-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc3e68fe-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcc3e68ff-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as an Effective Date of 2000 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
