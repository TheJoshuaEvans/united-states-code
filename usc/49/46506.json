{"tag":"section","attrib":{"id":"idcc40b263-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46506"},"text":null,"children":[{"tag":"num","attrib":{"value":"46506"},"text":"§ 46506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application of certain criminal laws to acts on aircraft","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"An individual on an aircraft in the special aircraft jurisdiction of the United States who commits an act that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc40b264-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46506/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if committed in the special maritime and territorial jurisdiction of the United States (as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t18/s7"},"text":"section 7 of title 18","children":[],"tail":") would violate section 113, 114, 661, 662, 1111, 1112, 1113, or 2111 or chapter 109A of title 18, shall be fined under title 18, imprisoned under that section or chapter, or both; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc40b265-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46506/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if committed in the District of Columbia would violate ","children":[{"tag":"ref","attrib":{"href":"/us/act/1892-07-29/s9"},"text":"section 9 of the Act of July 29, 1892","children":[],"tail":" (D.C. Code § 22-1112), shall be fined under title 18, imprisoned under section 9 of the Act, or both."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc40b266-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1245"},"text":"108 Stat. 1245","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc40b267-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc40b268-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc40b269-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46506","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1472(k).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 902(k); added "},{"tag":"html:span","attrib":{},"text":"Sept. 5, 1961","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/87/197/s1"},"text":"Pub. L. 87–197, § 1","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/75/466"},"text":"75 Stat. 466","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 14, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/449/s1/3"},"text":"Pub. L. 91–449, § 1(3)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/921"},"text":"84 Stat. 921","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 10, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/646/s87/d/8"},"text":"Pub. L. 99–646, § 87(d)(8)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3624"},"text":"100 Stat. 3624","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 14, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/654/s3/b/8"},"text":"Pub. L. 99–654, § 3(b)(8)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3664"},"text":"100 Stat. 3664","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words “fined under title 18, imprisoned under that section or chapter, or both” are substituted for “punished as provided therein” for consistency with title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the words “fined under title 18, imprisoned under section 9 of the Act, or both” are substituted for “punished as provided therein” for consistency with title 18.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc40b26a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc40b26b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/act/1892-07-29/s9"},"text":"Section 9 of the Act of July 29, 1892","children":[],"tail":", referred to in par. (2), is section 9 of "},{"tag":"ref","attrib":{"href":"/us/act/1892-07-29/ch320"},"text":"act July 29, 1892, ch. 320","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/27/324"},"text":"27 Stat. 324","children":[],"tail":", which is not classified to the Code. Section 9 of the Act was reclassified to section 22–1312 of the D.C. Code (2014)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
