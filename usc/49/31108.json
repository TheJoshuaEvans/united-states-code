{"tag":"section","attrib":{"id":"idcb608b4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108"},"text":null,"children":[{"tag":"num","attrib":{"value":"31108"},"text":"§ 31108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Motor carrier research and technology program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb608b50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research, Technology, and Technology Transfer Activities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb608b51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall establish and carry out a motor carrier and motor coach research and technology program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b52-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Multiyear plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The program must include a multi-year research plan that focuses on nonredundant innovative research and shall be coordinated with other research programs or projects ongoing or planned within the Department of Transportation, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b53-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Research, development, and technology transfer activities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out under the program research, development, technology, and technology transfer activities with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb608b54-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the causes of accidents, injuries, and fatalities involving commercial motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b55-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" means of reducing the number and severity of accidents, injuries, and fatalities involving commercial motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b56-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the safety and efficiency of commercial motor vehicles through technological innovation and improvement;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b57-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving technology used by enforcement officers when conducting roadside inspections and compliance reviews to increase efficiency and information transfers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b58-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" increasing the safety and security of hazardous materials transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b59-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Tests and development","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may test, develop, or assist in testing and developing any material, invention, patented article, or process related to the research and technology program.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b5a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may use the funds made available to carry out this section for training or education of commercial motor vehicle safety personnel, including training in accident reconstruction and detection of controlled substances or other contraband and stolen cargo or vehicles.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b5b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedures","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may carry out this section—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb608b5c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" independently;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b5d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in cooperation with other Federal departments, agencies, and instrumentalities and Federal laboratories; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by making grants to, or entering into contracts and cooperative agreements with, any Federal laboratory, State agency, authority, association, institution, for-profit or nonprofit corporation, organization, foreign country, or person.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b5f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development and promotion of use of products","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall use funds made available to carry out this section to develop, administer, communicate, and promote the use of products of research, technology, and technology transfer programs under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb608b60-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Collaborative Research and Development.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb608b61-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To advance innovative solutions to problems involving commercial motor vehicle and motor carrier safety, security, and efficiency, and to stimulate the deployment of emerging technology, the Secretary may carry out, on a cost-shared basis, collaborative research and development with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb608b62-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-Federal entities, including State and local governments, foreign governments, colleges and universities, corporations, institutions, partnerships, and sole proprietorships that are incorporated or established under the laws of any State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b63-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal laboratories.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b64-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cooperative agreements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out this subsection, the Secretary may enter into cooperative research and development agreements (as defined in section 12 of the Stevenson-Wydler Technology Innovation Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3710a"},"text":"15 U.S.C. 3710a","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b65-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost sharing.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb608b66-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Federal share of the cost of activities carried out under a cooperative research and development agreement entered into under this subsection shall not exceed 50 percent; except that, if there is substantial public interest or benefit associated with any such activity, the Secretary may approve a greater Federal share.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb608b67-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of directly incurred non-federal costs","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All costs directly incurred by the non-Federal partners, including personnel, travel, and hardware or software development costs, shall be credited toward the non-Federal share of the cost of the activities described in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb608b68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31108/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of technology","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The research, development, or use of a technology under a cooperative research and development agreement entered into under this subsection, including the terms under which the technology may be licensed and the resulting royalties may be distributed, shall be subject to the Stevenson-Wydler Technology Innovation Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3701"},"text":"15 U.S.C. 3701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb608b69-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/993"},"text":"108 Stat. 993","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4111/a"},"text":"Pub. L. 109–59, title IV, § 4111(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1722"},"text":"119 Stat. 1722","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb608b6a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb608b6b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb608b6c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"31108","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(uncodified).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Dec. 18, 1991","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/240/s4002/j"},"text":"Pub. L. 102–240, § 4002(j)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/105/2144"},"text":"105 Stat. 2144","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The words “safety duties and powers” are substituted for “safety functions” for clarity and consistency in the revised title. The reference to fiscal year 1992 is omitted as obsolete.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb608b6d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb608b6e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Stevenson-Wydler Technology Innovation Act of 1980, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480"},"text":"Pub. L. 96–480","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2311"},"text":"94 Stat. 2311","children":[],"tail":", as amended, which is classified generally to chapter 63 (§ 3701 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3701"},"text":"section 3701 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb608b6f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" amended section catchline and text generally. Prior to amendment, text read as follows: “Not more than $_____ may be appropriated to the Secretary of Transportation for the fiscal year ending September 30, 19_, to carry out the safety duties and powers of the Federal Highway Administration.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
