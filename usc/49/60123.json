hildren":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60123(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1679a(c)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/481"},"text":"Pub. L. 90–481","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/720"},"text":"82 Stat. 720","children":[],"tail":", § 11(c)(2); added "},{"tag":"html:span","attrib":{},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/129/s104/b"},"text":"Pub. L. 96–129, § 104(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/992"},"text":"93 Stat. 992","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2007(c)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60123(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1679a(c)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/481"},"text":"Pub. L. 90–481","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/720"},"text":"82 Stat. 720","children":[],"tail":", § 11(c)(3); added "},{"tag":"html:span","attrib":{},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/561/s107"},"text":"Pub. L. 100–561, § 107","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2807"},"text":"102 Stat. 2807","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2007(c)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 30, 1979","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/129"},"text":"Pub. L. 96–129","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/93/989"},"text":"93 Stat. 989","children":[],"tail":", § 208(c)(3); added "},{"tag":"html:span","attrib":{},"text":"Oct. 31, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/561/s206"},"text":"Pub. L. 100–561, § 206","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/2811"},"text":"102 Stat. 2811","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"60123(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1687(g).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 12, 1968","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/481"},"text":"Pub. L. 90–481","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/82/720"},"text":"82 Stat. 720","children":[],"tail":", § 20(g); added "},{"tag":"html:span","attrib":{},"text":"Oct. 24, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/508/s304/a"},"text":"Pub. L. 102–508, § 304(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/3307"},"text":"106 Stat. 3307","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “upon conviction . . . subject, for each offense, to” and “a term” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (a)–(c), the words “fined under title 18” are substituted for “a fine of not more than $25,000” and “a fine of not more than $5,000” for consistency with title 18.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “prescribed” is added for consistency in the revised title and with other titles of the United States Code. The words “including any order issued under section 1677(b) and 1679b(b) of this Appendix” in 49 App.:1679a(c)(1) and “including any order issued under section 2006(b) or 2008(b) of the Appendix” in 49 App.:2007(c)(1) are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the word “damaging” is substituted for “injures”, and the word “damage” is substituted for “injure”, for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc8116b3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc8116b4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s21/4"},"text":"Pub. L. 107–355, § 21(4)","children":[],"tail":", substituted “60114(b)” for “60114(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s8/c"},"text":"Pub. L. 107–355, § 8(c)","children":[],"tail":", substituted “gas pipeline facility, an” for “gas pipeline facility or” and inserted “, or either an intrastate gas pipeline facility or intrastate hazardous liquid pipeline facility that is used in interstate or foreign commerce or in any activity affecting interstate or foreign commerce” after “liquid pipeline facility”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s3/c/1"},"text":"Pub. L. 107–355, § 3(c)(1)","children":[],"tail":", (4), struck out “knowingly and willfully” after “if the person” in introductory provisions and inserted concluding provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s3/c/2"},"text":"Pub. L. 107–355, § 3(c)(2)","children":[],"tail":", inserted “knowingly and willfully” before “engages”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/355/s3/c/3"},"text":"Pub. L. 107–355, § 3(c)(3)","children":[],"tail":", added subpar. (B) and struck out former subpar. (B) which read as follows: “a pipeline facility that does not report the damage promptly to the operator of the pipeline facility and to other appropriate authorities; or”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/56"},"text":"Pub. L. 107–56","children":[],"tail":" struck out “, or attempting to damage or destroy,” before “an interstate gas pipeline facility”, inserted “, or attempting or conspiring to do such an act,” before “shall be fined under title 18,” and substituted “20 years, or both, and, if death results to any person, shall be imprisoned for any term of years or for life.” for “15 years, or both.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s18/b/1"},"text":"Pub. L. 104–304, § 18(b)(1)","children":[],"tail":", substituted “, 60118(a), or 60128” for “or 60118(a)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/304/s14"},"text":"Pub. L. 104–304, § 14","children":[],"tail":", added subpar. (B) and redesignated former subpar. (B) as (C)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
