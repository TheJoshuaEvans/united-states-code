{"tag":"section","attrib":{"id":"idcc8116a3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60123"},"text":null,"children":[{"tag":"num","attrib":{"value":"60123"},"text":"§ 60123.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Criminal penalties","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc8116a4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60123/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Penalty","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person knowingly and willfully violating section 60114(b), 60118(a), or 60128 of this title or a regulation prescribed or order issued under this chapter shall be fined under title 18, imprisoned for not more than 5 years, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8116a5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60123/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty for Damaging or Destroying Facility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person knowingly and willfully damaging or destroying an interstate gas pipeline facility, an interstate hazardous liquid pipeline facility, or either an intrastate gas pipeline facility or intrastate hazardous liquid pipeline facility that is used in interstate or foreign commerce or in any activity affecting interstate or foreign commerce, or attempting or conspiring to do such an act, shall be fined under title 18, imprisoned for not more than 20 years, or both, and, if death results to any person, shall be imprisoned for any term of years or for life.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8116a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60123/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty for Damaging or Destroying Sign","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A person knowingly and willfully defacing, damaging, removing, or destroying a pipeline sign or right-of-way marker required by a law or regulation of the United States shall be fined under title 18, imprisoned for not more than one year, or both.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc8116a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60123/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Penalty for Not Using One-Call Notification System or Not Heeding Location Information or Markings","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person shall be fined under title 18, imprisoned for not more than 5 years, or both, if the person—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc8116a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60123/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" knowingly and willfully engages in an excavation activity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8116a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60123/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without first using an available one-call notification system to establish the location of underground facilities in the excavation area; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8116aa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60123/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" without paying attention to appropriate location information or markings the operator of a pipeline facility establishes; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc8116ab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60123/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subsequently damages—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc8116ac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60123/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pipeline facility that results in death, serious bodily harm, or actual damage to property of more than $50,000;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8116ad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60123/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a pipeline facility, and knows or has reason to know of the damage, but does not report the damage promptly to the operator of the pipeline facility and to other appropriate authorities; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc8116ae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60123/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a hazardous liquid pipeline facility that results in the release of more than 50 barrels of product.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"Penalties under this subsection may be reduced in the case of a violation that is promptly reported by the violator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc8116af-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1325"},"text":"108 Stat. 1325","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/304"},"text":"Pub. L. 104–304","children":[],"tail":", §§ 14, 18(b)(1), "},{"tag":"date","attrib":{"date":"1996-10-12"},"text":"Oct. 12, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3803"},"text":"110 Stat. 3803","children":[],"tail":", 3804; "},{"tag":"ref","attrib":{"href":"/us/pl/107/56/tVIII"},"text":"Pub. L. 107–56, title VIII","children":[],"tail":", §§ 810(h), 811(k), "},{"tag":"date","attrib":{"date":"2001-10-26"},"text":"Oct. 26, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/381"},"text":"115 Stat. 381","children":[],"tail":", 382; "},{"tag":"ref","attrib":{"href":"/us/pl/107/355"},"text":"Pub. L. 107–355","children":[],"tail":", §§ 3(c), 8(c), 21(4), "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2986"},"text":"116 Stat. 2986","children":[],"tail":", 2994, 3010.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc8116b0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc8116b1-47c4-11f1-9671-b5c725212f70"},"text":"\n