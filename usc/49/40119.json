{"tag":"section","attrib":{"id":"idcbaf47ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119"},"text":null,"children":[{"tag":"num","attrib":{"value":"40119"},"text":"§ 40119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sensitive security information","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbaf47ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbaf47ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations prohibiting disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding the establishment of a Department of Homeland Security, the Secretary of Transportation, in accordance with ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/b/3/B"},"text":"section 552(b)(3)(B) of title 5","children":[],"tail":", shall prescribe regulations prohibiting disclosure of information obtained or developed in ensuring security under this title if the Secretary of Transportation decides disclosing the information would—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbaf47f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be an unwarranted invasion of personal privacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbaf47f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reveal a trade secret or privileged or confidential commercial or financial information; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbaf47f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be detrimental to transportation safety.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaf47f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure to congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) shall not be construed to authorize information to be withheld from a committee of Congress authorized to have such information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaf47f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of construction","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in paragraph (1) shall be construed to authorize the designation of information as sensitive security information (as such term is defined in section 15.5 of title 49, Code of Federal Regulations) to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbaf47f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conceal a violation of law, inefficiency, or administrative error;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbaf47f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent embarrassment to a person, organization, or agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbaf47f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" restrain competition; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbaf47f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" prevent or delay the release of information that does not require protection in the interest of transportation security, including basic scientific research information not clearly related to transportation security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbaf47f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Law enforcement disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552a"},"text":"Section 552a of title 5","children":[],"tail":" shall not apply to disclosures that the Administrator may make from the systems of records of the Federal Aviation Administration to any Federal law enforcement, intelligence, protective service, immigration, or national security official in order to assist the official receiving the information in the performance of official duties."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbaf47fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s40119/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfers of Duties and Powers Prohibited","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as otherwise provided by law, a duty or power under this section may not be transferred to another department, agency, or instrumentality of the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbaf47fb-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tII/s223/a"},"text":"Pub. L. 118–63, title II, § 223(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1060"},"text":"138 Stat. 1060","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbaf47fc-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbaf47fd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcbaf47fe-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 40119, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1117"},"text":"108 Stat. 1117","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s101/e"},"text":"Pub. L. 107–71, title I, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/603"},"text":"115 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/296/tXVI/s1601/a"},"text":"Pub. L. 107–296, title XVI, § 1601(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-11-25"},"text":"Nov. 25, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2312"},"text":"116 Stat. 2312","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/111/83/tV/s561/c/2"},"text":"Pub. L. 111–83, title V, § 561(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2009-10-28"},"text":"Oct. 28, 2009","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/123/2182"},"text":"123 Stat. 2182","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/95/tVIII/s801"},"text":"Pub. L. 112–95, title VIII, § 801","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-02-14"},"text":"Feb. 14, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/118"},"text":"126 Stat. 118","children":[],"tail":", related to research and development activities to protect passengers and property against acts of criminal violence, aircraft piracy, and terrorism and to ensure security and regulations prohibiting disclosure of information obtained or developed in ensuring security under this title, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/c/3"},"text":"Pub. L. 115–254, div. K, title I, § 1991(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3627"},"text":"132 Stat. 3627","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbaf47ff-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcbaf4800-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tII/s223/b"},"text":"Pub. L. 118–63, title II, § 223(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1061"},"text":"138 Stat. 1061","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tII/s223/b"},"text":"“The amendments made by this section [enacting this section] shall be effective as of ","children":[{"tag":"date","attrib":{"date":"2018-10-05"},"text":"October 5, 2018","children":[],"tail":", and all authority restored to the Secretary [of Transportation] and the FAA [Federal Aviation Administration] under this section shall be treated as if such authority had never been repealed by the FAA Reauthorization Act of 2018 ("},{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Public Law 115–254","children":[],"tail":") [see Prior Provisions note above].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
