{"tag":"section","attrib":{"id":"idcc09ea6d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44737"},"text":null,"children":[{"tag":"num","attrib":{"value":"44737"},"text":"§ 44737.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Helicopter fuel system safety","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc09ea6e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44737/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prohibition.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc09ea6f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44737/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person may not operate a covered helicopter in United States airspace unless the design of the helicopter is certified by the Administrator of the Federal Aviation Administration to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc09ea70-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44737/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with the requirements applicable to the category of the helicopter under paragraphs (1), (2), (3), (5), and (6) of section 27.952(a), section 27.952(c), section 27.952(f), section 27.952(g), section 27.963(g) (but allowing for a minimum puncture force of 250 pounds if successfully drop tested in-structure), and section 27.975(b) or paragraphs (1), (2), (3), (5), and (6) of section 29.952(a), section 29.952(c), section 29.952(f), section 29.952(g), section 29.963(b) (but allowing for a minimum puncture force of 250 pounds if successfully drop tested in-structure), and 29.975(a)(7) of title 14, Code of Federal Regulations, as in effect on the date of enactment of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09ea71-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44737/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" employ other means acceptable to the Administrator to provide an equivalent level of fuel system crash resistance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09ea72-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44737/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered helicopter defined","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this subsection, the term “covered helicopter” means a helicopter not otherwise required to comply with section 27.952, section 27.963, and section 27.975, or section 29.952, section 29.963, and section 29.975 of title 14, Code of Federal Regulations as in effect on the date of enactment of this section for which manufacture was completed, as determined by the Administrator, on or after the date that is 18 months after the date of enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09ea73-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44737/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administrative Provisions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc09ea74-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44737/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" expedite the certification and validation of United States and foreign type designs and retrofit kits that improve fuel system crashworthiness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc09ea75-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44737/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 180 days after the date of enactment of this section, and periodically thereafter, issue a bulletin to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc09ea76-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44737/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform helicopter owners and operators of available modifications to improve fuel system crashworthiness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc09ea77-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44737/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" urge that such modifications be installed as soon as practicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09ea78-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44737/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rule of Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to affect the operation of a helicopter by the Department of Defense.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc09ea79-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44737/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A helicopter issued an experimental certificate under section 21.191 of title 14, Code of Federal Regulations (or any successor regulations), or operating under a Special Flight Permit issued under section 21.197 of title 14, Code of Federal Regulations (or any successor regulations), is excepted from the requirements of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc09ea7a-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/dB/tIII/s317/a"},"text":"Pub. L. 115–254, div. B, title III, § 317(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3268"},"text":"132 Stat. 3268","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tVIII/s825"},"text":"Pub. L. 118–63, title VIII, § 825","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1332"},"text":"138 Stat. 1332","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc09ea7b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc09ea7c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc09ea7d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in text, is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idcc09ea7e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another section 44737 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44740"},"text":"section 44740 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc09ea7f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s825/1"},"text":"Pub. L. 118–63, § 825(1)","children":[],"tail":", substituted “helicopter” for “rotorcraft” wherever appearing in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s825/2"},"text":"Pub. L. 118–63, § 825(2)","children":[],"tail":", substituted “helicopter” for “rotorcraft” in heading."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/s825/3"},"text":"Pub. L. 118–63, § 825(3)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc09ea80-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc09ea81-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Crash-Resistant Fuel Systems in Rotorcraft","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tIII/s320"},"text":"Pub. L. 118–63, title III, § 320","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1082"},"text":"138 Stat. 1082","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/118/63/tIII/s320"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Administrator [of the Federal Aviation Administration] shall task the Aviation Rulemaking Advisory Committee to—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the data analysis conducted and the recommendations developed by the Aviation Rulemaking Advisory Committee Rotorcraft Occupant Protection Working Group of the Administration;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" update the 2018 report of such working group on rotorcraft occupant protection by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing National Transportation Safety Board data from 2016 through 2023 on post-crash fires in helicopter accidents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining whether and to what extent crash-resistant fuel systems could have prevented fatalities in the accidents covered by the data reviewed under subparagraph (A); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" develop recommendations for either the Administrator or the helicopter industry to encourage helicopter owners and operators to expedite the installation of crash-resistant fuel systems in the aircraft of such owners and operators regardless of original certification and manufacture date.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Schedule.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the Administrator tasks the Aviation Rulemaking Advisory Committee under subsection (a), the Committee shall submit the recommendations developed under subsection (a)(2) to the Administrator.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If applicable, and not later than 180 days after receiving the recommendations under paragraph (1), the Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begin implementing, as appropriate, any safety recommendations the Administrator receives from the Aviation Rulemaking Advisory Committee, and brief the appropriate committees of Congress [Committee on Commerce, Science, and Transportation of the Senate and Committee on Transportation and Infrastructure of the House of Representatives] on any recommendations the Administrator does not implement; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" partner with the United States Helicopter Safety Team, as appropriate, to facilitate implementation of any recommendations for the helicopter industry pursuant to subsection (a)(2).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
