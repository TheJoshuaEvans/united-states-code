{"tag":"section","attrib":{"id":"idcaf54733-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13708"},"text":null,"children":[{"tag":"num","attrib":{"value":"13708"},"text":"§ 13708.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Billing and collecting practices","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf54734-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13708/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disclosure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A motor carrier subject to jurisdiction under subchapter I of chapter 135 shall disclose, when a document is presented or electronically transmitted for payment to the person responsible directly to the motor carrier for payment or agent of such responsible person, the actual rates, charges, or allowances for any transportation service and shall also disclose, at such time, whether and to whom any allowance or reduction in charges is made.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf54735-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13708/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"False or Misleading Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No person may cause a motor carrier to present false or misleading information on a document about the actual rate, charge, or allowance to any party to the transaction.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf54736-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13708/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Allowances for Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the actual rate, charge, or allowance is dependent upon the performance of a service by a party to the transportation arrangement, such as tendering a volume of freight over a stated period of time, the motor carrier shall indicate in any document presented for payment to the person responsible directly to the motor carrier that a reduction, allowance, or other adjustment may apply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf54737-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/873"},"text":"109 Stat. 873","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf54738-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf54739-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf5473a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10767"},"text":"section 10767 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaf5473b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcaf5473c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
