":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24311(b)(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:545(d)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24311(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:562(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/518"},"text":"Pub. L. 91–518","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1327"},"text":"84 Stat. 1327","children":[],"tail":", § 402(d); added "},{"tag":"html:span","attrib":{},"text":"Nov. 3, 1973","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/146/s10/2"},"text":"Pub. L. 93–146, § 10(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/552"},"text":"87 Stat. 552","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Feb. 5, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/210/s706/h"},"text":"Pub. L. 94–210, § 706(h)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/125"},"text":"90 Stat. 125","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/254/s206/a"},"text":"Pub. L. 96–254, § 206(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/412"},"text":"94 Stat. 412","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/641/s9/a"},"text":"Pub. L. 101–641, § 9(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/4658"},"text":"104 Stat. 4658","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:562 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Nov. 28, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/641/s9/b"},"text":"Pub. L. 101–641, § 9(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/4658"},"text":"104 Stat. 4658","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a)(1), before clause (A), the words “the exercise of the right of” and “right-of-way, land, or other” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1) and (2), the words “estate or” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), before clause (A), the words “A civil action to acquire an interest in property by eminent domain under subsection (a) of this section must be brought” are added, the words “any judicial district in which any piece of the property is located” are substituted for “any such court”, and the words “under this subsection” are added, for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), before clause (A), the words “When the declaration is filed and the deposit is made under paragraph (1) of this subsection” are substituted for “shall thereupon” for clarity. The word “immediately” is omitted as surplus. In clause (A), the words “possession of the property is given to Amtrak” are substituted for “the parties in possession are required to surrender possession to the Corporation” to eliminate unnecessary words. Clause (B) is substituted for 45:545(d)(5) (last sentence) to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the words “of money” are omitted as surplus. The words “awarding that amount and interest on it” are substituted for “make an award and . . . accordingly. Such judgment shall include, as part of the just compensation awarded, interest” to eliminate unnecessary words. The words “of interest” are added for clarity. The words “finally . . . as the value of the property on the date of taking” and “on such date” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(4), the word “award” is substituted for “compensation finally awarded” for consistency and to eliminate unnecessary words. The words “of the money . . . by any person entitled to compensation” and “amount of the” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), before clause (A), the words “terms for”, “at issue”, “to the Corporation”, “and conditions”, “for the property”, “in any event”, “from the Corporation”, and “to the Corporation on such reasonable terms and conditions as it may prescribe, including just compensation” are omitted as surplus. In clause (A), the words “of the property to the Corporation” are omitted as surplus. In clause (B), the words “either by sale or by exercising its right of eminent domain under subsection (a) of this section” are substituted for “which is available for sale on reasonable terms to the Corporation, or available to the Corporation by the exercise of its authority under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s545/d"},"text":"section 545(d) of this title","children":[],"tail":"” for clarity and to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “reconvey . . . an interest conveyed to Amtrak under this subsection or prior comparable provision of law” are substituted for “convey title or other interest in such property” for consistency in the revised title and to eliminate unnecessary words. The words “regardless of when the proceeding was brought” are substituted for section 9(b) (less words in parentheses) of the Independent Safety Board Act Amendments of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/641"},"text":"Public Law 101–641","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/4658"},"text":"104 Stat. 4658","children":[],"tail":") to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb30eff1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb30eff2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32932/c/2/B"},"text":"Pub. L. 112–141, § 32932(c)(2)(B)","children":[],"tail":", substituted “Board” for “Commission” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32932/c/2/A"},"text":"Pub. L. 112–141, § 32932(c)(2)(A)","children":[],"tail":", substituted “Surface Transportation Board” for “Interstate Commerce Commission”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32932/c/2/C"},"text":"Pub. L. 112–141, § 32932(c)(2)(C)","children":[],"tail":", substituted “Board’s” for “Commission’s”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb30eff3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb30eff4-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
