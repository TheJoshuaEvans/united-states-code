{"tag":"section","attrib":{"id":"idcb30efd3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311"},"text":null,"children":[{"tag":"num","attrib":{"value":"24311"},"text":"§ 24311.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Acquiring interests in property by eminent domain","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb30efd4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb30efd5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To the extent financial resources are available, Amtrak may acquire by eminent domain under subsection (b) of this section interests in property—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb30efd6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" necessary for intercity rail passenger transportation, except property of a rail carrier, a State, a political subdivision of a State, or a governmental authority; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb30efd7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requested by the Secretary of Transportation in carrying out the Secretary’s duty to design and build an intermodal transportation terminal at Union Station in the District of Columbia if the Secretary assures Amtrak that the Secretary will reimburse Amtrak.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb30efd8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Amtrak may exercise the power of eminent domain only if it cannot—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb30efd9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquire the interest in the property by contract; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb30efda-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" agree with the owner on the purchase price for the interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb30efdb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb30efdc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A civil action to acquire an interest in property by eminent domain under subsection (a) of this section must be brought in the district court of the United States for the judicial district in which the property is located or, if a single piece of property is located in more than one judicial district, in any judicial district in which any piece of the property is located. An interest is condemned and taken by Amtrak for its use when a declaration of taking is filed under this subsection and an amount of money estimated in the declaration to be just compensation for the interest is deposited in the court. The declaration may be filed with the complaint in the action or at any time before judgment. The declaration must contain or be accompanied by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb30efdd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the public use for which the interest is taken;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb30efde-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the property sufficient to identify it;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb30efdf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the interest in the property taken;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb30efe0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a plan showing the interest taken; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb30efe1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a statement of the amount of money Amtrak estimates is just compensation for the interest.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb30efe2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When the declaration is filed and the deposit is made under paragraph (1) of this subsection, title to the property vests in Amtrak in fee simple absolute or in the lesser interest shown in the declaration, and the right to the money vests in the person entitled to the money. When the declaration is filed, the court may decide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb30efe3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time by which, and the terms under which, possession of the property is given to Amtrak; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb30efe4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the disposition of outstanding charges related to the property.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb30efe5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After a hearing, the court shall make a finding on the amount that is just compensation for the interest in the property and enter judgment awarding that amount and interest on it. The rate of interest is 6 percent a year and is computed on the amount of the award less the amount deposited in the court from the date of taking to the date of payment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb30efe6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On application of a party, the court may order immediate payment of any part of the amount deposited in the court for the compensation to be awarded. If the award is more than the amount received, the court shall enter judgment against Amtrak for the deficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb30efe7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority To Condemn Rail Carrier Property Interests","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb30efe8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If Amtrak and a rail carrier cannot agree on a sale to Amtrak of an interest in property of a rail carrier necessary for intercity rail passenger transportation, Amtrak may apply to the Surface Transportation Board for an order establishing the need of Amtrak for the interest and requiring the carrier to convey the interest on reasonable terms, including just compensation. The need of Amtrak is deemed to be established, and the Board, after holding an expedited proceeding and not later than 120 days after receiving the application, shall order the interest conveyed unless the Board decides that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb30efe9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conveyance would impair significantly the ability of the carrier to carry out its obligations as a common carrier; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb30efea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the obligations of Amtrak to provide modern, efficient, and economical rail passenger transportation can be met adequately by acquiring an interest in other property, either by sale or by exercising its right of eminent domain under subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb30efeb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the amount of compensation is not determined by the date of the Board’s order, the order shall require, as part of the compensation, interest at 6 percent a year from the date prescribed for the conveyance until the compensation is paid.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb30efec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24311/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amtrak subsequently may reconvey to a third party an interest conveyed to Amtrak under this subsection or prior comparable provision of law if the Board decides that the reconveyance will carry out the purposes of this part, regardless of when the proceeding was brought (including a proceeding pending before a United States court on ","children":[{"tag":"date","attrib":{"date":"1990-11-28"},"text":"November 28, 1990","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb30efed-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/915"},"text":"108 Stat. 915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32932/c/2"},"text":"Pub. L. 112–141, div. C, title II, § 32932(c)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/829"},"text":"126 Stat. 829","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb30efee-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb30efef-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb30eff0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24311(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:545(d)(1) (less words between 11th comma and proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/518"},"text":"Pub. L. 91–518","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1327"},"text":"84 Stat. 1327","children":[],"tail":", § 305(d)(1); added "},{"tag":"html:span","attrib":{},"text":"Nov. 3, 1973","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/146/s6"},"text":"Pub. L. 93–146, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/87/550"},"text":"87 Stat. 550","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Oct. 28, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/496/s6"},"text":"Pub. L. 93–496, § 6","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/1528"},"text":"88 Stat. 1528","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Feb. 5, 1976","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/94/210/s706/g"},"text":"Pub. L. 94–210, § 706(g)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/90/125"},"text":"90 Stat. 125","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"May 30, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/254/s206/a"},"text":"Pub. L. 96–254, § 206(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/412"},"text":"94 Stat. 412","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24311(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:545(d)(1) (words between 11th comma and proviso).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text