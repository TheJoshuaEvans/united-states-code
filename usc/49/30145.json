{"tag":"section","attrib":{"id":"idcb4fea28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30145"},"text":null,"children":[{"tag":"num","attrib":{"value":"30145"},"text":"§ 30145.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Importing motor vehicles or equipment requiring further manufacturing","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s30112/a"},"text":"Section 30112(a) of this title","children":[],"tail":" does not apply to a motor vehicle or motor vehicle equipment if the vehicle or equipment—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4fea29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30145/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requires further manufacturing to perform its intended function as decided under regulations prescribed by the Secretary of Transportation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4fea2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30145/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is accompanied at the time of importation by a written statement issued by the manufacturer indicating the applicable motor vehicle safety standard prescribed under this chapter with which it does not comply.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb4fea2b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/964"},"text":"108 Stat. 964","children":[],"tail":".)"}],"tail":"\n"},{"tag":"not