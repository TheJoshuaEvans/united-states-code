{"tag":"section","attrib":{"id":"idcaf08c26-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101"},"text":null,"children":[{"tag":"num","attrib":{"value":"13101"},"text":"§ 13101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation policy","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf08c27-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"To ensure the development, coordination, and preservation of a transportation system that meets the transportation needs of the United States, including the United States Postal Service and national defense, it is the policy of the United States Government to oversee the modes of transportation and—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf08c28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in overseeing those modes—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to recognize and preserve the inherent advantage of each mode of transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promote safe, adequate, economical, and efficient transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage sound economic conditions in transportation, including sound economic conditions among carriers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage the establishment and maintenance of reasonable rates for transportation, without unreasonable discrimination or unfair or destructive competitive practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cooperate with each State and the officials of each State on transportation matters; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to encourage fair wages and working conditions in the transportation industry;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in overseeing transportation by motor carrier, to promote competitive and efficient transportation services in order to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage fair competition, and reasonable rates for transportation by motor carriers of property;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote efficiency in the motor carrier transportation system and to require fair and expeditious decisions when required;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meet the needs of shippers, receivers, passengers, and consumers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow a variety of quality and price options to meet changing market demands and the diverse requirements of the shipping and traveling public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" allow the most productive use of equipment and energy resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable efficient and well-managed carriers to earn adequate profits, attract capital, and maintain fair wages and working conditions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide and maintain service to small communities and small shippers and intrastate bus services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide and maintain commuter bus operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve and maintain a sound, safe, and competitive privately owned motor carrier system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote greater participation by minorities in the motor carrier system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promote intermodal transportation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in overseeing transportation by motor carrier of passengers—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf08c3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to cooperate with the States on transportation matters for the purpose of encouraging the States to exercise intrastate regulatory jurisdiction in accordance with the objectives of this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide Federal procedures which ensure that intrastate regulation is exercised in accordance with this part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf08c3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to ensure that Federal reform initiatives enacted by section 31138 and the Bus Regulatory Reform Act of 1982 are not nullified by State regulatory actions; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf08c3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in overseeing transportation by water carrier, to encourage and promote service and price competition in the noncontiguous domestic trade.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf08c40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Administration To Carry Out Policy","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This part shall be administered and enforced to carry out the policy of this section and to promote the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf08c41-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/853"},"text":"109 Stat. 853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf08c42-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf08c43-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcaf08c44-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Bus Regulatory Reform Act of 1982, referred to in subsec. (a)(3)(C), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/261"},"text":"Pub. L. 97–261","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-20"},"text":"Sept. 20, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1102"},"text":"96 Stat. 1102","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 1982 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s10101"},"text":"section 10101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf08c45-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10101"},"text":"section 10101 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaf08c46-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcaf08c47-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
