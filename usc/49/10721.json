{"tag":"section","attrib":{"id":"idcadfc34c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s10721"},"text":null,"children":[{"tag":"num","attrib":{"value":"10721"},"text":"§ 10721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government traffic","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A rail carrier providing transportation or service for the United States Government may transport property or individuals for the United States Government without charge or at a rate reduced from the applicable commercial rate. Section 6101(b) to (d) of title 41 does not apply when transportation for the United States Government can be obtained from a rail carrier lawfully operating in the area where the transportation would be provided.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcadfc34d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/819"},"text":"109 Stat. 819","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/111/350/s5"},"text":"Pub. L. 111–350, § 5","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":")(4), "},{"tag":"date","attrib":{"date":"2011-01-04"},"text":"Jan. 4, 2011","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/124/3853"},"text":"124 Stat. 3853","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcadfc34e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcadfc34f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"