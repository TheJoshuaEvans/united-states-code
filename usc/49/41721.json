{"tag":"section","attrib":{"id":"idcbc715c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41721"},"text":null,"children":[{"tag":"num","attrib":{"value":"41721"},"text":"§ 41721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports by carriers on incidents involving animals during air transport","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbc715c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41721/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier that provides scheduled passenger air transportation shall submit monthly to the Secretary a report on any incidents involving the loss, injury, or death of an animal (as defined by the Secretary of Transportation) during air transport provided by the air carrier. The report shall be in such form and contain such information as the Secretary determines appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41721/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training of Air Carrier Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall work with air carriers to improve the training of employees with respect to the air transport of animals and the notification of passengers of the conditions under which the air transport of animals is conducted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715c7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41721/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sharing of Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary and the Secretary of Agriculture shall enter into a memorandum of understanding to ensure the sharing of information that the Secretary receives under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41721/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication of Data","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall publish data on incidents and complaints involving the loss, injury, or death of an animal during air transport in a manner comparable to other consumer complaint and incident data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbc715c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41721/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Air Transport","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this section, the air transport of an animal includes the entire period during which an animal is in the custody of an air carrier, from check-in of the animal prior to departure until the animal is returned to the owner or guardian of the animal at the final destination of the animal.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbc715ca-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tVII/s710/a"},"text":"Pub. L. 106–181, title VII, § 710(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/159"},"text":"114 Stat. 159","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbc715cb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbc715cc-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcbc715cd-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section applicable only to fiscal years beginning after ","children":[{"tag":"date","attrib":{"date":"1999-09-30"},"text":"Sept. 30, 1999","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/106/181/s3"},"text":"section 3 of Pub. L. 106–181","children":[],"tail":", set out as an Effective Date of 2000 Amendments note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
