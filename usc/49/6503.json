{"tag":"section","attrib":{"id":"idcad8bea4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503"},"text":null,"children":[{"tag":"num","attrib":{"value":"6503"},"text":"§ 6503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation research and development 5-year strategic plan","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcad8bea5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date of publication of the Department of Transportation Strategic Plan and not less frequently than once every 5 years thereafter, the Secretary shall develop a 5-year transportation research and development strategic plan to guide future Federal transportation research and development activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8bea6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consistency","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each strategic plan developed under subsection (a) shall be consistent with—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8bea7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bea8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" sections 1115 and 1116 of title 31; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bea9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other research and development plan within the Department of Transportation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8beaa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each strategic plandeveloped under subsection (a) shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8beab-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" describe how the plan furthers the primary purposes of the transportation research and development program, which shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8beac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving mobility of people and goods;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8bead-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing congestion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8beae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" promoting safety;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8beaf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improving the durability and extending the life of transportation infrastructure;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8beb0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserving the environment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8beb1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preserving the existing transportation system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8beb2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing transportation cybersecurity risks;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8beb3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each of the purposes referred to in paragraph (1), list the primary proposed research and development activities that the Department of Transportation intends to pursue to accomplish that purpose, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8beb4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fundamental research pertaining to the applied physical and natural sciences;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8beb5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" applied science and research;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8beb6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" technology development research; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8beb7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" social science research; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8beb8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for each research and development activity—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8beb9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify the anticipated annual funding levels for the period covered by the strategic plan; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8beba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describe the research findings the Department expects to discover at the end of the period covered by the strategic plan.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcad8bebb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure that each strategic plan developed under this section—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad8bebc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflects input from a wide range of external stakeholders;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bebd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" includes and integrates the research and development programs of all of the modal administrations of the Department of Transportation, including aviation, transit, rail, and maritime and joint programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bebe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" takes into account research and development by other Federal, State, local, private sector, and nonprofit institutions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bebf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than ","children":[{"tag":"date","attrib":{"date":"2021-12-31"},"text":"December 31, 2021","children":[],"tail":", and not less frequently than once every 5 years thereafter, is published on a public website; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad8bec0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" takes into account how research and development by other Federal, State, private sector, and nonprofit institutions—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcad8bec1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/d/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" contributes to the achievement of the purposes identified under subsection (c)(1); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcad8bec2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6503/d/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" avoids unnecessary duplication of those efforts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad8bec3-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVI/s6019/b/1"},"text":"Pub. L. 114–94, div. A, title VI, § 6019(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1580"},"text":"129 Stat. 1580","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tV/s25014"},"text":"Pub. L. 117–58, div. B, title V, § 25014","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/869"},"text":"135 Stat. 869","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad8bec4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcad8bec5-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcad8bec6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25014/1"},"text":"Pub. L. 117–58, § 25014(1)","children":[],"tail":", substituted “Not later than 180 days after the date of publication of the Department of Transportation Strategic Plan and not less frequently than once every 5 years thereafter, the Secretary” for “The Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25014/2"},"text":"Pub. L. 117–58, § 25014(2)","children":[],"tail":", substituted “Each strategic” for “The strategic” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25014/3/A"},"text":"Pub. L. 117–58, § 25014(3)(A)","children":[],"tail":", substituted “Each strategic” for “The strategic” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25014/3/B"},"text":"Pub. L. 117–58, § 25014(3)(B)","children":[],"tail":", added subpar. (G)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25014/4/A"},"text":"Pub. L. 117–58, § 25014(4)(A)","children":[],"tail":", substituted “each strategic” for “the strategic” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25014/4/B"},"text":"Pub. L. 117–58, § 25014(4)(B)","children":[],"tail":", substituted “2021, and not less frequently than once every 5 years thereafter” for “2016”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/s25014/5"},"text":"Pub. L. 117–58, § 25014(5)","children":[],"tail":", struck out subsec. (e). Prior to amendment, text read as follows: “Not later than 2 ½ years after the date of enactment of this chapter, the Secretary may publish on a public website an interim report that—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) provides an assessment of the 5-year research and development strategic plan of the Department of Transportation described in this section; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) includes a description of the extent to which the research and development is or is not successfully meeting the purposes described under subsection (c)(1).”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcad8bec7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcad8bec8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
