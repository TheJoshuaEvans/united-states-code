{"tag":"section","attrib":{"id":"idca72344f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s351"},"text":null,"children":[{"tag":"num","attrib":{"value":"351"},"text":"§ 351.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Judicial review of actions in carrying out certain transferred duties and powers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca723450-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s351/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Judicial Review","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An action of the Secretary of Transportation in carrying out a duty or power transferred under the Department of Transportation Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/670"},"text":"Public Law 89–670","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/931"},"text":"80 Stat. 931","children":[],"tail":"), or an action of the Administrator of the Federal Railroad Administration, the Federal Motor Carrier Safety Administration, or the Federal Aviation Administration in carrying out a duty or power specifically assigned to the Administrator by that Act, may be reviewed judicially to the same extent and in the same way as if the action had been an action by the department, agency, or instrumentality of the United States Government carrying out the duty or power immediately before the transfer or assignment."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca723451-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s351/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application of Procedural Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A statutory requirement related to notice, an opportunity for a hearing, action on the record, or administrative review that applied to a duty or power transferred by the Act applies to the Secretary or Administrator when carrying out the duty or power.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca723452-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s351/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section does not apply to a duty or power transferred from the Interstate Commerce Commission to the Secretary under section 6(e)(1)–(4) and (6)(A) of the Act.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca723453-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/j/10/A"},"text":"Pub. L. 103–272, § 4(j)(10)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1367"},"text":"108 Stat. 1367","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4125/b"},"text":"Pub. L. 109–59, title IV, § 4125(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1738"},"text":"119 Stat. 1738","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca723454-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca723455-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca723456-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"351","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1653(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s4/c"},"text":"Pub. L. 89–670, § 4(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/933"},"text":"80 Stat. 933","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this subchapter, the words “duty or power” are substituted for “functions, powers, and duties” for clarity and consistency. The words “department, agency, or instrumentality of the United States Government” are substituted for “department or agency” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the word “orders” is omitted as being included in “action”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca723457-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca723458-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Department of Transportation Act, referred to in subsecs. (a) and (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/670"},"text":"Pub. L. 89–670","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1966-10-15"},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/931"},"text":"80 Stat. 931","children":[],"tail":", which was classified principally to sections 1651 to 1660 of former Title 49, Transportation. The Act was repealed and the provisions thereof reenacted in Title 49, Transportation, by "},{"tag":"ref","attrib":{"href":"/us/pl/97/449"},"text":"Pub. L. 97–449","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2413"},"text":"96 Stat. 2413","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Pub. L. 103–272","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/745"},"text":"108 Stat. 745","children":[],"tail":". The Act was also repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s7/5"},"text":"Pub. L. 104–287, § 7(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3400"},"text":"110 Stat. 3400","children":[],"tail":". For disposition of sections of former Title 49, see Table at the beginning of Title 49."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca723459-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2005—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" substituted “Federal Motor Carrier Safety Administration” for “Federal Highway Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca72345a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca72345b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Abolition of Interstate Commerce Commission and Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Interstate Commerce Commission abolished and functions of Commission transferred, except as otherwise provided in ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", to Surface Transportation Board effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", by "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1302"},"text":"section 1302 of this title","children":[],"tail":", and "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s101"},"text":"section 101 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":". References to Interstate Commerce Commission deemed to refer to Surface Transportation Board, a member or employee of the Board, or Secretary of Transportation, as appropriate, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s205"},"text":"section 205 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
