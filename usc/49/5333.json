"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5333(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1609(a), (b).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"July 9, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/365/s13"},"text":"Pub. L. 88–365, § 13","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/307"},"text":"78 Stat. 307","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Sept. 8, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/562/s2/a/1"},"text":"Pub. L. 89–562, § 2(a)(1)","children":[],"tail":", (b)(2), "},{"tag":"html:a","attrib":{"href":"/us/stat/80/715"},"text":"80 Stat. 715","children":[],"tail":", 716; "},{"tag":"html:span","attrib":{},"text":"May 25, 1967","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/90/19/s20/a"},"text":"Pub. L. 90–19, § 20(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/81/25"},"text":"81 Stat. 25","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"5333(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1609(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “take such action as may be necessary to”, “the performance of”, “the assistance of”, and “at rates” are omitted as surplus. The word “same” is added for clarity. The words “duties and powers” are substituted for “authority and functions” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the reference to sections 5307, 5308, 5310, and 5311 of the revised title is added for clarity because of 49 App.:1607a(e)(1), 1607a–2(a), 1612(b), and 1614(f), restated as sections 5307(n)(2), 5308(b)(1), 5310(a), and 5311(i) of the revised title. The reference to section 5312 is added for clarity because it is intended that 49 App.:1609(c) cover research, development, training, and demonstration projects. The words “terms and conditions of the protective” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), before clause (A), the words “without being limited to” are omitted as being included in “include”. The words “such provisions as may be necessary for” are omitted as surplus. In clause (C), the word “individual” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(3), the words “","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11347"},"text":"section 11347 of this title","children":[],"tail":"” are substituted for and coextensive with “"},{"tag":"ref","attrib":{"href":"/us/act/1887-02-04/s5/2/f"},"text":"section 5(2)(f) of the Act of February 4, 1887","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/stat/24/379"},"text":"24 Stat. 379","children":[],"tail":"), as amended” in section 13(c) of the Urban Mass Transportation Act of 1964 ("},{"tag":"ref","attrib":{"href":"/us/pl/88/365"},"text":"Public Law 88–365","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/307"},"text":"78 Stat. 307","children":[],"tail":") on authority of "},{"tag":"ref","attrib":{"href":"/us/act/1978-10-17/s3/b"},"text":"section 3(b) of the Act of October 17, 1978","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/95/473"},"text":"Public Law 95–473","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/1466"},"text":"92 Stat. 1466","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcabe7f36-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcabe7f37-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Reorganization Plan No. 14 of 1950, referred to in subsec. (a), is set out in the Appendix to Title 5, Government Organization and Employees.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Sections 5316 and 5328 of this title, referred to in subsec. (b)(1), were repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dB/s20002/a"},"text":"Pub. L. 112–141, div. B, § 20002(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/622"},"text":"126 Stat. 622","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcabe7f38-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" substituted “sections 3141 through 3144” for “sections 3141–3144”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s3031/1"},"text":"Pub. L. 109–59, § 3031(1)","children":[],"tail":", substituted “5316, 5318, 5323(a)(1), 5323(b), 5323(d), 5328, 5337, and 5338(b)” for “5318(d), 5323(a)(1), (b), (d), and (e), 5328, 5337, and 5338(b)” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s3002/b/4"},"text":"Pub. L. 109–59, § 3002(b)(4)","children":[],"tail":", substituted “public transportation” for “mass transportation”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(4), (5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s3031/2"},"text":"Pub. L. 109–59, § 3031(2)","children":[],"tail":", added pars. (4) and (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “sections 3141–3144, 3146, and 3147 of title 40” for “the Act of "},{"tag":"date","attrib":{"date":"1931-03-03"},"text":"March 3, 1931","children":[],"tail":" (known as the Davis-Bacon Act) ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s276a"},"text":"40 U.S.C. 276a","children":[],"tail":"—276a–5)” and “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"” for “"},{"tag":"ref","attrib":{"href":"/us/act/1934-06-13/s2"},"text":"section 2 of the Act of June 13, 1934","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s276c"},"text":"40 U.S.C. 276c","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1998—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178"},"text":"Pub. L. 105–178","children":[],"tail":" substituted “5338(b)” for “5338(j)(5)” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1995—Subsec. (b)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" substituted “11326” for “11347”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcabe7f39-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcabe7f3a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcac0c92b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"