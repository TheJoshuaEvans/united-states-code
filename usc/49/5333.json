{"tag":"section","attrib":{"id":"idcabe7f24-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333"},"text":null,"children":[{"tag":"num","attrib":{"value":"5333"},"text":"§ 5333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcabe7f25-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Prevailing Wages Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall ensure that laborers and mechanics employed by contractors and subcontractors in construction work financed with a grant or loan under this chapter be paid wages not less than those prevailing on similar construction in the locality, as determined by the Secretary of Labor under sections 3141 through 3144, 3146, and 3147 of title 40. The Secretary of Transportation may approve a grant or loan only after being assured that required labor standards will be maintained on the construction work. For a labor standard under this subsection, the Secretary of Labor has the same duties and powers stated in Reorganization Plan No. 14 of 1950 (eff. ","children":[{"tag":"date","attrib":{"date":"1950-05-24"},"text":"May 24, 1950","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/1267"},"text":"64 Stat. 1267","children":[],"tail":") and "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s3145"},"text":"section 3145 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcabe7f26-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee Protective Arrangements","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcabe7f27-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As a condition of financial assistance under sections 5307–5312, 5316,","children":[{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002037"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" 5318, 5323(a)(1), 5323(b), 5323(d), 5328,"},{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":" 5337, and 5338(b) of this title, the interests of employees affected by the assistance shall be protected under arrangements the Secretary of Labor concludes are fair and equitable. The agreement granting the assistance under sections 5307–5312, 5316,"},{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":" 5318, 5323(a)(1), 5323(b), 5323(d), 5328,"},{"tag":"ref","attrib":{"idref":"fn002037"},"text":"1","children":[],"tail":" 5337, and 5338(b) shall specify the arrangements."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcabe7f28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Arrangements under this subsection shall include provisions that may be necessary for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcabe7f29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the preservation of rights, privileges, and benefits (including continuation of pension rights and benefits) under existing collective bargaining agreements or otherwise;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcabe7f2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the continuation of collective bargaining rights;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcabe7f2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the protection of individual employees against a worsening of their positions related to employment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcabe7f2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances of employment to employees of acquired public transportation systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcabe7f2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances of priority of reemployment of employees whose employment is ended or who are laid off; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcabe7f2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333/b/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" paid training or retraining programs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcabe7f2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Arrangements under this subsection shall provide benefits at least equal to benefits established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s11326"},"text":"section 11326 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcabe7f30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Fair and equitable arrangements to protect the interests of employees utilized by the Secretary of Labor for assistance to purchase like-kind equipment or facilities, and grant amendments which do not materially revise or amend existing assistance agreements, shall be certified without referral.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcabe7f31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s5333/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Secretary is called upon to issue fair and equitable determinations involving assurances of employment when one private transit bus service contractor replaces another through competitive bidding, such decisions shall be based on the principles set forth in the Department of Labor’s decision of ","children":[{"tag":"date","attrib":{"date":"1994-09-21"},"text":"September 21, 1994","children":[],"tail":", as clarified by the supplemental ruling of "},{"tag":"date","attrib":{"date":"1994-11-07"},"text":"November 7, 1994","children":[],"tail":", with respect to grant NV–90–X021. This paragraph shall not serve as a basis for objections under section 215.3(d) of title 29, Code of Federal Regulations."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcabe7f32-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/835"},"text":"108 Stat. 835","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s308/e"},"text":"Pub. L. 104–88, title III, § 308(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/947"},"text":"109 Stat. 947","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIII/s3029/b/9"},"text":"Pub. L. 105–178, title III, § 3029(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/372"},"text":"112 Stat. 372","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3/n/3"},"text":"Pub. L. 107–217, § 3(n)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1302"},"text":"116 Stat. 1302","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIII"},"text":"Pub. L. 109–59, title III","children":[],"tail":", §§ 3002(b)(4), 3031, "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1545"},"text":"119 Stat. 1545","children":[],"tail":", 1625; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dB/s20030/h"},"text":"Pub. L. 112–141, d