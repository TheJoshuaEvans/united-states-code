{"tag":"section","attrib":{"id":"idcb05e9c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15302"},"text":null,"children":[{"tag":"num","attrib":{"value":"15302"},"text":"§ 15302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority to exempt pipeline carrier transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb05e9c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":"—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In a matter related to a pipeline carrier providing transportation subject to jurisdiction under this chapter, the Board shall exempt a person, class of persons, or a transaction or service when the Board finds that the application, in whole or in part, of a provision of this part—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb05e9c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is not necessary to carry out the transportation policy of section 15101; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb05e9c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" either (A) the transaction or service is of limited scope, or (B) the application, in whole or in part, of the provision is not needed to protect shippers from the abuse of market power.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e9c4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initiation of Proceeding","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may, where appropriate, begin a proceeding under this section on its own initiative or an interested party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e9c5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may specify the period of time during which an exemption granted under this section is effective.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb05e9c6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s15302/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Revocation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may revoke an exemption, to the extent it specifies, when it finds that application, in whole or in part, of a provision of this part to the person, class, or transportation is necessary to carry out the transportation policy of section 15101.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb05e9c7-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s106/a"},"text":"Pub. L. 104–88, title I, § 106(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/923"},"text":"109 Stat. 923","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb05e9c8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb05e9c9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb05e9ca-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
