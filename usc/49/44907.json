{"tag":"section","attrib":{"id":"idcc2673c8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907"},"text":null,"children":[{"tag":"num","attrib":{"value":"44907"},"text":"§ 44907.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Security standards at foreign airports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc2673c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc2673ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" At intervals the Secretary of Transportation considers necessary, the Secretary shall assess the effectiveness of the security measures maintained at—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc2673cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a foreign airport—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc2673cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served by an air carrier;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc2673cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from which a foreign air carrier serves the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc2673ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that poses a high risk of introducing danger to international air travel; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other foreign airports the Secretary considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2673d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation shall conduct an assessment under paragraph (1) of this subsection—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc2673d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in consultation with appropriate aeronautic authorities of the government of a foreign country concerned and each air carrier serving the foreign airport for which the Secretary is conducting the assessment;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish the extent to which a foreign airport effectively maintains and carries out security measures, including the screening and vetting of airport workers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by using a standard that will result in an analysis of the security measures at the airport based at least on the standards and appropriate recommended practices contained in Annex 17 to the Convention on International Civil Aviation in effect on the date of the assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2673d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each report to Congress required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44938/b"},"text":"section 44938(b) of this title","children":[],"tail":" shall contain a summary of the assessments conducted under this subsection."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2673d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out subsection (a) of this section, the Secretary of Transportation shall consult with the Secretary of State—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc2673d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the terrorist threat that exists in each country; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2673d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish which foreign airports are not under the de facto control of the government of the foreign country in which they are located and pose a high risk of introducing danger to international air travel.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2673d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notifying Foreign Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Secretary of Transportation, after conducting an assessment under subsection (a) of this section, decides that an airport does not maintain and carry out effective security measures, the Secretary of Transportation, after advising the Secretary of State, shall notify the appropriate authorities of the government of the foreign country of the decision and recommend the steps necessary to bring the security measures in use at the airport up to the standard used by the Secretary of Transportation in making the assessment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2673d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Actions When Airports Not Maintaining and Carrying Out Effective Security Measures","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc2673da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When the Secretary of Transportation decides under this section that an airport does not maintain and carry out effective security measures—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc2673db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the Secretary of Transportation shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc2673dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish the identity of the airport in the Federal Register;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc2673dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the identity of the airport posted and displayed prominently at all United States airports at which scheduled air carrier operations are provided regularly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc2673de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify the news media of the identity of the airport;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" each air carrier and foreign air carrier providing transportation between the United States and the airport shall provide written notice of the decision, on or with the ticket, to each passenger buying a ticket for transportation between the United States and the airport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s40105/b"},"text":"section 40105(b) of this title","children":[],"tail":", the Secretary of Transportation, after consulting with the appropriate aeronautic authorities of the foreign country concerned and each air carrier serving the airport and with the approval of the Secretary of State, may withhold, revoke, or prescribe conditions on the operating authority of an air carrier or foreign air carrier that uses that airport to provide foreign air transportation; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the President may prohibit an air carrier or foreign air carrier from providing transportation between the United States and any other foreign airport that is served by aircraft flying to or from the airport with respect to which a decision is made under this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2673e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc2673e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Paragraph (1) of this subsection becomes effective—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcc2673e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 days after the government of a foreign country is notified under subsection (c) of this section if the Secretary of Transportation finds that the government has not brought the security measures at the airport up to the standard the Secretary used in making an assessment under subsection (a) of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcc2673e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" immediately on the decision of the Secretary of Transportation under subsection (c) of this section if the Secretary of Transportation decides, after consulting with the Secretary of State, that a condition exists that threatens the safety or security of passengers, aircraft, or crew traveling to or from the airport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc2673e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation immediately shall notify the Secretary of State of a decision under subparagraph (A)(ii) of this paragraph so that the Secretary of State may issue a travel advisory required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44908/a"},"text":"section 44908(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2673e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation promptly shall submit to Congress a report (and classified annex if necessary) on action taken under paragraph (1) or (2) of this subsection, including information on attempts made to obtain the cooperation of the government of a foreign country in meeting the standard the Secretary used in assessing the airport under subsection (a) of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2673e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An action required under paragraph (1)(A) and (B) of this subsection is no longer required only if the Secretary of Transportation, in consultation with the Secretary of State, decides that effective security measures are maintained and carried out at the airport. The Secretary of Transportation shall notify Congress when the action is no longer required to be taken.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2673e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspensions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding sections 40105(b) and 40106(b) of this title, the Secretary of Transportation, with the approval of the Secretary of State and without notice or a hearing, shall suspend the right of an air carrier or foreign air carrier to provide foreign air transportation, and the right of a person to operate aircraft in foreign air commerce, to or from a foreign airport when the Secretary of Transportation decides that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc2673ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a condition exists that threatens the safety or security of passengers, aircraft, or crew traveling to or from that airport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc2673eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the public interest requires an immediate suspension of transportation between the United States and that airport.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc2673ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44907/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Condition of Carrier Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This section is a condition to authority the Secretary of Transportation grants under this part to an air carrier or foreign air carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc2673ed-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1209"},"text":"108 Stat. 1209","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1954"},"text":"Pub. L. 115–254, div. K, title I, § 1954","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3595"},"text":"132 Stat. 3595","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc2673ee-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc2673ef-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc2673f0-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44907(a)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1515(a)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1115(a), (b), (d)–(h); added "},{"tag":"html:span","attrib":{},"text":"Aug. 5, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/366/s106"},"text":"Pub. L. 93–366, § 106","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/414"},"text":"88 Stat. 414","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Aug. 8, 1985","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/83/s551/a"},"text":"Pub. L. 99–83, § 551(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/99/222"},"text":"99 Stat. 222","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44907(a)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1515(a)(2), (3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44907(a)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1515(c).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1115(c); added "},{"tag":"html:span","attrib":{},"text":"Aug. 5, 1974","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/366/s106"},"text":"Pub. L. 93–366, § 106","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/414"},"text":"88 Stat. 414","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Aug. 8, 1985","c