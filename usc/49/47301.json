{"tag":"section","attrib":{"id":"idcc648e63-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47301"},"text":null,"children":[{"tag":"num","attrib":{"value":"47301"},"text":"§ 47301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In this chapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc648e64-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47301/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “airport property” means an interest in property used or useful in operating and maintaining an airport.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e65-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47301/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “airway property” means an interest in property used or useful in operating and maintaining a ground installation, facility, or equipment desirable for the orderly and safe operation of air traffic, including air navigation, air traffic control, airway communication, and meteorological facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e66-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47301/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" “foreign territory” means an area—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc648e67-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47301/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" over which no government or a government of a foreign country has sovereignty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc648e68-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47301/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" temporarily under military occupation by the United States Government; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc648e69-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47301/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" occupied or administered by the Government or a government of a foreign country under an international agreement.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc648e6a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47301/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" “territory outside the continental United States” means territory outside the 48 contiguous States and the District of Columbia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc648e6b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1280"},"text":"108 Stat. 1280","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc648e6c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc648e6d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc648e6e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47301(1)–(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1151.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1948-06-16/ch473/s2"},"text":"June 16, 1948, ch. 473, § 2","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/62/450"},"text":"62 Stat. 450","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s1403"},"text":"Pub. L. 85–726, § 1403","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/808"},"text":"72 Stat. 808","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47301(4)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(no source).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the words “the purposes of” and “The term” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clauses (1) and (2), the words “real or personal”, “directly or indirectly”, “administration”, and “(including parts and components thereof)” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (1), the words “including . . . (1) land; (2) runways, strips, taxiways, and parking aprons; (3) buildings, structures, improvements, and facilities, whether or not used in connection with the landing and take-off of aircraft; and (4) equipment . . . furniture, vehicles, and supplies” are omitted as being included in “an interest in property”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (2), the words “necessary or” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In clause (3), before subclause (A), the words “of land or water” are omitted as surplus. In subclause (A), the words “no government or a government of a foreign country” are substituted for “no nation or a nation other than the United States” for consistency in the revised title and with other titles of the United States Code. The words “(including territory of undetermined sovereignty and the high seas)” are omitted as surplus. In subclause (C), the words “government of a foreign country” are substituted for “other nation” for consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Clause (4) is derived from the source provisions of the chapter and is included to avoid repeating the phrase “territory (including Alaska) outside the continental limits of the United States”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
