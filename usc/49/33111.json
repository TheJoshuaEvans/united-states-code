{"tag":"section","attrib":{"id":"idcb8dddb7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33111"},"text":null,"children":[{"tag":"num","attrib":{"value":"33111"},"text":"§ 33111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Verifications involving motor vehicle major parts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb8dddb8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33111/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A person engaged in the business of salvaging, dismantling, recycling, or repairing passenger motor vehicles may not knowingly sell in commerce or transfer or install a major part marked with an identification number without—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8dddb9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33111/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" first establishing, through a procedure the Attorney General by regulation prescribes in consultation with the Secretary of Transportation under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s33109"},"text":"section 33109 of this title","children":[],"tail":", that the major part has not been reported as stolen; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dddba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33111/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing the purchaser or transferee with a verification—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8dddbb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33111/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying the vehicle identification number (or derivative of that number) of that major part; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddbc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33111/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verifying that the major part has not been reported as stolen.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8dddbd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33111/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8dddbe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33111/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Subsection (a) of this section does not apply to a person that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8dddbf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33111/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is the manufacturer of the major part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddc0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33111/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has purchased the major part directly from the manufacturer; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddc1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33111/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has received a verification from an insurance carrier under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s33110"},"text":"section 33110 of this title","children":[],"tail":" that the motor vehicle from which the major part is derived has not been reported as stolen, or that the carrier has not established whether that vehicle has been stolen."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dddc2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33111/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A person described under paragraph (1)(C) of this subsection that subsequently transfers or sells in commerce the motor vehicle or a major part of the vehicle shall provide the verification received from the carrier to the person to whom the vehicle or part is transferred or sold.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8dddc3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33111/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General shall prescribe regulations to carry out this section. The regulations shall include regulations prescribed in consultation with the Secretary that are necessary to ensure that a verification a person provides under subsection (a)(2) of this section is uniform, effective, and resistant to fraudulent use.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb8dddc4-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1086"},"text":"108 Stat. 1086","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb8dddc5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb8dddc6-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb8dddc7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"33111(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2026b(a).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 20, 1972","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/92/513"},"text":"Pub. L. 92–513","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/86/947"},"text":"86 Stat. 947","children":[],"tail":", § 608; added "},{"tag":"html:span","attrib":{},"text":"Oct. 25, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/519/s306/c"},"text":"Pub. L. 102–519, § 306(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/3397"},"text":"106 Stat. 3397","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"33111(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2026b(c) (1st, 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"33111(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"15:2026b(b), (c) (last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the word “distribute” is omitted as being included in “sell”. In clause (1), the word “establishing” is substituted for “determining” for clarity and consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (b)(2) is substituted for 15:2026b(c) (2d sentence) for clarity.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb8dddc8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb8dddc9-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/v"},"text":"Pub. L. 103–272, § 4(v)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1373"},"text":"108 Stat. 1373","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/272/s4/v"},"text":"“","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s33111"},"text":"Section 33111 of title 49","children":[],"tail":", United States Code, as enacted by section 1 of this Act, is effective on the date on which the National Stolen Passenger Motor Vehicle Information System is established under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s33109"},"text":"section 33109 of title 49","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
