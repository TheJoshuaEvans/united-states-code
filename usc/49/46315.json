{"tag":"html:span","attrib":{},"text":"Oct. 27, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/570/s3401/b/1"},"text":"Pub. L. 99–570, § 3401(b)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/3207-100"},"text":"100 Stat. 3207–100","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/690/s7209/c/1"},"text":"Pub. L. 100–690, § 7209(c)(1)","children":[],"tail":", (2)(A), "},{"tag":"html:a","attrib":{"href":"/us/stat/102/4432"},"text":"102 Stat. 4432","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “fined under title 18” are substituted for “a fine not exceeding $25,000” for consistency with title 18. In clause (2), the word “knowingly” is substituted for “and with knowledge of such act” to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
