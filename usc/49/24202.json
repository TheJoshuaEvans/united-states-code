{"tag":"section","attrib":{"id":"idcb2c0eb3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24202"},"text":null,"children":[{"tag":"num","attrib":{"value":"24202"},"text":"§ 24202.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad rights-of-way","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb2c0eb4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24202/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of the Passenger Rail Reform and Investment Act of 2015, the Secretary shall submit a proposed exemption of railroad rights-of-way from the review under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t54/s306108"},"text":"section 306108 of title 54","children":[],"tail":" to the Advisory Council on Historic Preservation for consideration, consistent with the exemption for interstate highways approved on "},{"tag":"date","attrib":{"date":"2005-03-10"},"text":"March 10, 2005","children":[],"tail":" (70 Fed. Reg. 11,928)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2c0eb5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24202/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Final Exemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the date on which the Secretary submits the proposed exemption under subsection (a) to the Council, the Council shall issue a final exemption of railroad rights-of-way from review under chapter 3061 of title 54 consistent with the exemption for interstate highways approved on ","children":[{"tag":"date","attrib":{"date":"2005-03-10"},"text":"March 10, 2005","children":[],"tail":" (70 Fed. Reg. 11,928)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb2c0eb6-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11504/a"},"text":"Pub. L. 114–94, div. A, title XI, § 11504(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1692"},"text":"129 Stat. 1692","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb2c0eb7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb2c0eb8-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb2c0eb9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Passenger Rail Reform and Investment Act of 2015, referred to in subsec. (a), is the date of enactment of title XI of div. A of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb2c0eba-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"