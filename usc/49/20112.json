{"tag":"section","attrib":{"id":"idcb0f8505-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20112"},"text":null,"children":[{"tag":"num","attrib":{"value":"20112"},"text":"§ 20112.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enforcement by the Attorney General","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb0f8506-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20112/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Civil Actions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"At the request of the Secretary of Transportation, the Attorney General may bring a civil action in a district court of the United States—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0f8507-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20112/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enjoin a violation of, or to enforce, this part, except for ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20109"},"text":"section 20109 of this title","children":[],"tail":", or a railroad safety regulation prescribed or order issued by the Secretary;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f8508-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20112/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect a civil penalty imposed or an amount agreed on in compromise under section 21301, 21302, or 21303 of this title; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f8509-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20112/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to enforce a subpoena, request for admissions, request for production of documents or other tangible things, or request for testimony by deposition issued by the Secretary under this part.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb0f850a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20112/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Venue","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb0f850b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20112/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Except as provided in paragraph (2) of this subsection, a civil action under this section may be brought in the judicial district in which the violation occurred or the defendant has its principal executive office. If an action to collect a penalty is against an individual, the action also may be brought in the judicial district in which the individual resides.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb0f850c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20112/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A civil action to enforce a subpena issued by the Secretary or a compliance order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20111/b"},"text":"section 20111(b) of this title","children":[],"tail":" may be brought in the judicial district in which the defendant resides, does business, or is found."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb0f850d-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/869"},"text":"108 Stat. 869","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tIII/s309"},"text":"Pub. L. 110–432, div. A, title III, § 309","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4882"},"text":"122 Stat. 4882","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb0f850e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb0f850f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb0f8510-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","att