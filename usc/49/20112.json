:{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:437(d)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458"},"text":"Pub. L. 91–458","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/971"},"text":"84 Stat. 971","children":[],"tail":", § 208(d)(2); added "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/423/s6/b"},"text":"Pub. L. 96–423, § 6(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1814"},"text":"94 Stat. 1814","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:438(c) (4th sentence related to authority to bring actions).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458/s209/c"},"text":"Pub. L. 91–458, § 209(c)","children":[],"tail":" (4th sentence), "},{"tag":"html:a","attrib":{"href":"/us/stat/84/975"},"text":"84 Stat. 975","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/423/s8/a"},"text":"Pub. L. 96–423, § 8(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1814"},"text":"94 Stat. 1814","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"June 22, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/342/s3/a/3/A"},"text":"Pub. L. 100–342, § 3(a)(3)(A)","children":[],"tail":", (B), "},{"tag":"html:a","attrib":{"href":"/us/stat/102/624"},"text":"102 Stat. 624","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:439(a) (related to actions by Attorney General).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458/s210/a"},"text":"Pub. L. 91–458, § 210(a)","children":[],"tail":" (related to actions by Attorney General), "},{"tag":"html:a","attrib":{"href":"/us/stat/84/975"},"text":"84 Stat. 975","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/423/s9/a"},"text":"Pub. L. 96–423, § 9(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1814"},"text":"94 Stat. 1814","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/615/s28/f"},"text":"Pub. L. 101–615, § 28(f)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3277"},"text":"104 Stat. 3277","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20112(b)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:438(c) (4th sentence related to venue).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:439(c) (related to actions by Attorney General).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 16, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/458"},"text":"Pub. L. 91–458","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/971"},"text":"84 Stat. 971","children":[],"tail":", § 210(c) (related to actions by Attorney General); added "},{"tag":"html:span","attrib":{},"text":"Oct. 10, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/423/s9/b"},"text":"Pub. L. 96–423, § 9(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/1815"},"text":"94 Stat. 1815","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"20112(b)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:437(a) (last sentence related to venue).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “At the request of the Secretary of Transportation” are substituted for “at the request of the Secretary” in 45:439(a), and are made applicable to all of the source provisions restated in this subsection, for clarity and consistency. The words “at the request of the Secretary” in 45:439(a) are interpreted and restated to mean that the Secretary’s request is to the Attorney General rather than to the district court. See H.R. Rept. No. 91–1194, 91st Cong., 2d Sess., p. 20 (1970). The words “the Attorney General may bring a civil action in a district court of the United States” are substituted for “such district court shall have jurisdiction, upon petition by the Attorney General” in 45:437(a) (last sentence), “The district courts of the United States shall have jurisdiction, upon petition by the Attorney General” in 45:437(d)(2), and “The United States district court shall . . . upon petition by the Attorney General on behalf of the United States . . . have jurisdiction” in 45:439(a) for clarity and consistency. It is not necessary to restate that the district court has jurisdiction because of 28:1331 and 1345. See also the statement of Senator Prouty in 115 Cong. Rec. 40205 (1969) explaining that similar language in section 110 of S. 1933, 91st Cong., 1st Sess. (the derivative source for 45:439) would grant the Attorney General the power to seek injunctions. Clauses (1)–(3) are substituted for the source provisions to eliminate unnecessary words. In clause (1), the words “subject to the provisions of rules 65(a) and (b) of the Federal Rules of Civil Procedure” in 45:439(a) are omitted as surplus because the Federal Rules of Civil Procedure (28 App. U.S.C.) apply in the district court unless otherwise provided. In clause (2), the words “or an amount agreed on in compromise” are added for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the text of 45:439(c) (words before 1st comma) is omitted because it applies only to actions brought by a State authority. See discussion of the cross-reference in the note for section 20113(c) of the revised title. The last sentence is substituted for “in which the individual resides” in 45:438(c) because of the restatement.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “compliance order issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s20111/b"},"text":"section 20111(b) of this title","children":[],"tail":"” are substituted for “order, or directive” because the latter words are interpreted as referring to “orders directing compliance” in 45:437(a) (2d sentence), restated in section 20111(b)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb0f8511-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb0f8512-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s309/1"},"text":"Pub. L. 110–432, § 309(1)","children":[],"tail":", inserted “this part, except for "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s20109"},"text":"section 20109 of this title","children":[],"tail":", or” after “enforce,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s309/2"},"text":"Pub. L. 110–432, § 309(2)","children":[],"tail":", substituted “21301, 21302, or 21303” for “21301”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s309/3"},"text":"Pub. L. 110–432, § 309(3)","children":[],"tail":", (4), substituted “subpoena, request for admissions, request for production of documents or other tangible things, or request for testimony by deposition” for “subpena” and “part.” for “chapter.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
