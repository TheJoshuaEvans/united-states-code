{"tag":"section","attrib":{"id":"idcb6ee2ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149"},"text":null,"children":[{"tag":"num","attrib":{"value":"31149"},"text":"§ 31149.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Medical program","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb6ee2ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Medical Review Board.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6ee2ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment and function","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall establish a Medical Review Board to provide the Federal Motor Carrier Safety Administration with medical advice and recommendations on medical standards and guidelines for the physical qualifications of operators of commercial motor vehicles, medical examiner education, and medical research.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6ee2ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Medical Review Board shall be appointed by the Secretary and shall consist of 5 members selected from medical institutions and private practice. The membership shall reflect expertise in a variety of medical specialties relevant to the driver fitness requirements of the Federal Motor Carrier Safety Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6ee2f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Chief Medical Examiner","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall appoint a chief medical examiner who shall be an employee of the Federal Motor Carrier Safety Administration and who shall hold a position under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3104"},"text":"section 3104 of title 5","children":[],"tail":", United States Code, relating to employment of specially qualified scientific and professional personnel, and shall be paid under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5376"},"text":"section 5376 of title 5","children":[],"tail":", United States Code, relating to pay for certain senior-level positions."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6ee2f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Medical Standards and Requirements.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6ee2f2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, with the advice of the Medical Review Board and the chief medical examiner, shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb6ee2f3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" establish, review, and revise—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb6ee2f4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" medical standards for operators of commercial motor vehicles that will ensure that the physical condition of operators of commercial motor vehicles is adequate to enable them to operate the vehicles safely; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb6ee2f5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" requirements for periodic physical examinations of such operators performed by medical examiners who have, at a minimum, self-certified that they have completed training in physical and medical examination standards and are listed on a national registry maintained by the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6ee2f6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require each such operator to have a current valid medical certificate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6ee2f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct periodic reviews of a select number of medical examiners on the national registry to ensure that proper examinations of such operators are being conducted;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6ee2f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" not later than 1 year after enactment of the Commercial Motor Vehicle Safety Enhancement Act of 2012, develop requirements for a medical examiner to be listed in the national registry under this section, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb6ee2f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the completion of specific courses and materials;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb6ee2fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certification, including, at a minimum, self-certification, if the Secretary determines that self-certification is necessary for sufficient participation in the national registry, to verify that a medical examiner completed specific training, including refresher courses, that the Secretary determines necessary to be listed in the national registry;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb6ee2fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an examination that requires a passing grade; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb6ee2fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" demonstration of a medical examiner’s willingness to meet the reporting requirements established by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6ee2fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require medical examiners to transmit electronically, on a monthly basis, the name of the applicant, a numerical identifier, and additional information contained on the medical examiner’s certificate for any completed medical examination report required under section 391.43 of title 49, Code of Federal Regulations, to the chief medical examiner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6ee2fe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically review a representative sample of the medical examination reports associated with the name and numerical identifiers of applicants transmitted under subparagraph (E) for errors, omissions, or other indications of improper certification; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb6ee2ff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" annually review the implementation of commercial driver’s license requirements by not fewer than 10 States to assess the accuracy, validity, and timeliness of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb6ee300-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/G/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the submission of physical examination reports and medical certificates to State licensing agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb6ee301-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/1/G/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the processing of the submissions by State licensing agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6ee302-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Monitoring performance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall investigate patterns of errors or improper certification by a medical examiner. If the Secretary finds that a medical examiner has issued a medical certificate to an operator of a commercial motor vehicle who fails to meet the applicable standards at the time of the examination or that a medical examiner has falsely claimed to have completed training in physical and medical examination standards as required by this section, the Secretary may remove such medical examiner from the registry and may void the medical certificate of the applicant or holder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6ee303-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Registry of Medical Examiners","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary, acting through the Federal Motor Carrier Safety Administration—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb6ee304-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall establish and maintain a current national registry of medical examiners who are qualified to perform examinations and issue medical certificates;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6ee305-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remove from the registry the name of any medical examiner that fails to meet or maintain the qualifications established by the Secretary for being listed in the registry or otherwise does not meet the requirements of this section or regulation issued under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6ee306-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall accept as valid only medical certificates issued by persons on the national registry of medical examiners; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb6ee307-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may make participation of medical examiners in the national registry voluntary if such a change will enhance the safety of operators of commercial motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb6ee308-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31149/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall issue such regulations as may be necessary to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb6ee309-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4116/a"},"text":"Pub. L. 109–59, title IV, § 4116(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1726"},"text":"119 Stat. 1726","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32302/b"},"text":"Pub. L. 112–141, div. C, title II, § 32302(b)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/789"},"text":"126 Stat. 789","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb6ee30a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb6ee30b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb6ee30c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Commercial Motor Vehicle Safety Enhancement Act of 2012, referred to in subsec. (c)(1)(D), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII"},"text":"Pub. L. 112–141, div. C, title II","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/776"},"text":"126 Stat. 776","children":[],"tail":". For complete classification of this Act to the Code, see Short Title of 2012 Amendment note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s30101"},"text":"section 30101 of this title","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb6ee30d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2012—Subsec. (c)(1)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32302/b"},"text":"Pub. L. 112–141, § 32302(b)","children":[],"tail":", amended subpar. (D) generally. Prior to amendment, subpar. (D) read as follows: “develop, as appropriate, specific courses and materials for medical examiners listed in the national registry established under this section, and require those medical examiners to, at a minimum, self-certify that they have completed specific training, including refresher courses, to be listed in the registry;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(E). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32302/c/1/A"},"text":"Pub. L. 112–141, § 32302(c)(1)(A)","children":[],"tail":", amended subpar. (E) generally. Prior to amendment, subpar. (E) read as follows: “require medical examiners to transmit the name of the applicant and numerical identifier, as determined by the Administrator of the Federal Motor Carrier Safety Administration, for any completed medical examination report required under section 391.43 of title 49, Code of Federal Regulations, electronically to the chief medical examiner on monthly basis; and”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1)(G). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32302/c/1/B"},"text":"Pub. L. 112–141, § 32302(c)(1)(B)","children":[],"tail":", (C), added subpar. (G)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb6ee30e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb6ee30f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32302/b"},"text":"section 32302(b) of Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32302/c/2/B"},"text":"Pub. L. 112–141, div. C, title II, § 32302(c)(2)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/789"},"text":"126 Stat. 789","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV/s5508/b/3"},"text":"Pub. L. 114–94, div. A, title V, § 5508(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1554"},"text":"129 Stat. 1554","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/114/94/dA/tV/s5508/b/3"},"text":"“The amendments made by section 32302(c)(1) of this Act [amending this section] shall take effect on the date the oversight policies and procedures are established pursuant to subparagraph (A).”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV/s5508/b"},"text":"Pub. L. 114–94, div. A, title V, § 5508(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1554"},"text":"129 Stat. 1554","children":[],"tail":", provided that the amendment made by section 5508(b)(3) to "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32302/c/2/B"},"text":"section 32302(c)(2)(B) of Pub. L. 112–141","children":[],"tail":", set out above, is effective as of "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", and as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" as enacted.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb6ee310-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4116/f"},"text":"Pub. L. 109–59, title IV, § 4116(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1728"},"text":"119 Stat. 1728","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/tIII/s301/d"},"text":"Pub. L. 110–244, title III, § 301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/1616"},"text":"122 Stat. 1616","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/244/tIII/s301/d"},"text":"“The amendments made by subsections (a) and (b) [enacting this section and amending ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31136"},"text":"section 31136 of this title","children":[],"tail":"] shall take effect on the 365th day following the date of enactment of this Act ["},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" to "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4116/f"},"text":"section 4116(f) of Pub. L. 109–59","children":[],"tail":", set out above, effective as of the date of enactment of "},{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" ("},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":") and to be treated as included in "},{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" as of that date, and provisions of "},{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":", as in effect on the day before "},{"tag":"date","attrib":{"date":"2008-06-06"},"text":"June 6, 2008","children":[],"tail":", that are amended by "},{"tag":"ref","attrib":{"href":"/us/pl/110/244"},"text":"Pub. L. 110–244","children":[],"tail":" to be treated as not enacted, see "},{"tag":"ref","attrib":{"href":"/us/pl/110/244/s121/b"},"text":"section 121(b) of Pub. L. 110–244","children":[],"tail":", set out as an Effective Date of 2008 note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways.]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb6ee311-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Medical Certification of Veterans for Commercial Driver’s Licenses","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV/s5403"},"text":"Pub. L. 114–94, div. A, title V, § 5403","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1548"},"text":"129 Stat. 1548","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/105/s2/a"},"text":"Pub. L. 115–105, § 2(a)","children":[],"tail":", (b), "},{"tag":"date","attrib":{"date":"2018-01-08"},"text":"Jan. 8, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2263"},"text":"131 Stat. 2263","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/105/s2/a"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In the case of a veteran operator approved by a qualified examiner, the qualified examiner of such operator may, subject to the requirements of subsection (b), perform a medical examination and provide a medical certificate for purposes of compliance with the requirements of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31149"},"text":"section 31149 of title 49","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Certification","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The certification described under subsection (a) shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assurances that the examiner performing the medical examination meets the requirements of a qualified examiner under this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" certification that the physical condition of the operator is adequate to enable such operator to operate a commercial motor vehicle safely.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Registry of Medical Examiners","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of Transportation], in consultation with the Secretary of Veterans Affairs, shall develop a process for qualified examiners to perform a medical examination and provide a medical certificate under subsection (a) and include such examiners on the national registry of medical examiners established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31149/d"},"text":"section 31149(d) of title 49","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the following definitions apply:","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualified examiner","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘qualified examiner’ means an individual who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is employed by the Department of Veterans Affairs as an advanced practice nurse, doctor of chiropractic, doctor of medicine, doctor of osteopathy, physician assistant, or other medical professional;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is licensed, certified, or registered in a State to perform physical examinations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is familiar with the standards for, and physical requirements of, an operator required to be medically certified under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31149"},"text":"section 31149 of title 49","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has never, with respect to such section, been found to have acted fraudulently, including by fraudulently awarding a medical certificate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veteran","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘veteran’ has the meaning given the term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s101"},"text":"section 101 of title 38","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Veteran operator approved by a qualified examiner","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term ‘veteran operator approved by a qualified examiner’ means an operator of a commercial motor vehicle who—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a veteran who is enrolled in the health care system established under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t38/s1705/a"},"text":"section 1705(a) of title 38","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is required to have a current valid medical certificate pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31149"},"text":"section 31149 of title 49","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statutory Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to change any statutory penalty associated with fraud or abuse.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"[","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/105/s2/c"},"text":"Pub. L. 115–105, § 2(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-08"},"text":"Jan. 8, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2264"},"text":"131 Stat. 2264","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/115/105/s2/c"},"text":"“The amendments made by this section [amending ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s5403"},"text":"section 5403 of Pub. L. 114–94","children":[],"tail":", set out above] shall be incorporated into any rulemaking proceeding related to section 5403 of the FAST Act ("},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31149"},"text":"49 U.S.C. 31149","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/stat/129/1548"},"text":"129 Stat. 1548","children":[],"tail":") that is being conducted as of the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"2018-01-08"},"text":"Jan. 8, 2018","children":[],"tail":"].”"}],"tail":"\n]"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb6ee312-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Deadline for Establishment of National Registry of Medical Examiners","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32302/a"},"text":"Pub. L. 112–141, div. C, title II, § 32302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/788"},"text":"126 Stat. 788","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/141/dC/tII/s32302/a"},"text":"“Not later than 1 year after the date of enactment of this Act [see section 3(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", set out as Effective and Termination Dates of 2012 Amendment notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways], the Secretary [of Transportation] shall establish a national registry of medical examiners in accordance with "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31149/d/1"},"text":"section 31149(d)(1) of title 49","children":[],"tail":", United States Code.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb6ee313-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Internal Oversight Policy","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII/s32302/c/2/A"},"text":"Pub. L. 112–141, div. C, title II, § 32302(c)(2)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/789"},"text":"126 Stat. 789","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/112/141/dC/tII/s32302/c/2/A"},"text":"“Not later than 2 years after the date of enactment of this Act [see section 3(a), (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", set out as Effective and Termination Dates of 2012 Amendment notes under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways], the Secretary [of Transportation] shall establish an oversight policy and procedure to carry out "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31149/c/1/G"},"text":"section 31149(c)(1)(G) of title 49","children":[],"tail":", United States Code, as added by section 32302(c)(1) of this Act.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
