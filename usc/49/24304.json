text":"24304(d)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:544(c)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/518"},"text":"Pub. L. 91–518","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1327"},"text":"84 Stat. 1327","children":[],"tail":", § 304(c)(3); added "},{"tag":"html:span","attrib":{},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/272/s4003"},"text":"Pub. L. 99–272, § 4003","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/107"},"text":"100 Stat. 107","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24304(d)(3)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:544(c)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/518"},"text":"Pub. L. 91–518","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1327"},"text":"84 Stat. 1327","children":[],"tail":", § 304(c)(4); added "},{"tag":"html:span","attrib":{},"text":"Oct. 27, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/533/s5"},"text":"Pub. L. 102–533, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/3517"},"text":"106 Stat. 3517","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24304(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:544(e)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/518/s304/d"},"text":"Pub. L. 91–518, § 304(d)","children":[],"tail":", (e), "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1332"},"text":"84 Stat. 1332","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Aug. 13, 1981","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/35/s1175/4"},"text":"Pub. L. 97–35, § 1175(4)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/95/691"},"text":"95 Stat. 691","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24304(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:544(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24304(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:544(e)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “issue and” are omitted because they are included in “have outstanding”. The words “in such amounts as it shall determine” are omitted as surplus. The words “one issue of common stock and one issue of preferred stock” are substituted for “two issues of capital stock, a common and a preferred” for clarity. In clause (1), the word “designated” is omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(A), the words “may not hold” are substituted for “may be issued and held only by any person other than” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b)(1)(B) and (c), the words “as defined in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10102/6"},"text":"section 10102(6) of title 49","children":[],"tail":"” are omitted because of the definition of “rail carrier” in section 24102 of the revised title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1)(B), the words “after the initial issue is completed” are omitted as executed. The words “single” and “directly or indirectly through subsidiaries or affiliated companies, nominees, or any person subject to its direction or control” are omitted as surplus. The words “may vote not more than one-third of the total number of shares of outstanding common stock of Amtrak” are substituted for “At no time . . . shall the aggregate of the shares of common stock of the Corporation voted by . . . exceed 33⅓ per centum of such shares issued and outstanding” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “Additional common stock” are substituted for “a number of shares in excess of 33⅓ per centum of the total number of common shares issued and outstanding, such excess number” to eliminate unnecessary words. The words “issued and” are omitted because they are included in “outstanding”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (c)(1) is substituted for “Dividends shall be fixed at a rate not less than 6 per centum per annum, and shall be cumulative” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(2), the text of 45:544(a) (last sentence) (A) (last sentence) and the words “for any dividend period” and “at the rate fixed in the articles of incorporation” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “holders of preferred stock” are substituted for “preferred stockholders”, and the words “holders of common stock” are substituted for “common stockholders”, for consistency in this chapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(4), the words “at such time and upon such terms as the articles of incorporation shall provide” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(1), the text of 45:544(c)(1) and the words “Commencing on ","children":[{"tag":"date","attrib":{"date":"1981-10-01"},"text":"October 1, 1981","children":[],"tail":"” are omitted as executed. The words “and in consideration of receiving further Federal financial assistance”, “of the United States Government”, “additional”, and “of funds” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(3), the words “required to be issued” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (e) is substituted for 45:544(e)(2) to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “in addition to the stock authorized by subsection (a) of this section”, “securities, bonds, debentures, notes, and other”, and “as it may determine” are omitted as surplus.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsection (g) is substituted for 45:544(e)(1) to eliminate unnecessary words.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb2e7f26-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb2e7f27-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1997—","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134"},"text":"Pub. L. 105–134","children":[],"tail":" amended section catchline and text generally, substituting provisions relating to employee stock ownership plans for provisions relating to capitalization of Amtrak."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb2e7f28-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb2e7f29-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amtrak Stock","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/134/tIV/s415/b"},"text":"Pub. L. 105–134, title IV, § 415(b)","children":[],"tail":", (c), "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2590"},"text":"111 Stat. 2590","children":[],"tail":", provided that Amtrak was to redeem all common stock previously issued for the fair market value of such stock before "},{"tag":"date","attrib":{"date":"2002-10-01"},"text":"Oct. 1, 2002","children":[],"tail":", and that the preferred stock of Amtrak held by the Secretary of Transportation would confer no liquidation preference, effective 90 days after "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", and confer no voting rights, effective 60 days after "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
