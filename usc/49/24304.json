{"tag":"section","attrib":{"id":"idcb2e7f21-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24304"},"text":null,"children":[{"tag":"num","attrib":{"value":"24304"},"text":"§ 24304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Employee stock ownership plans","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In issuing stock pursuant to applicable corporate law, Amtrak is encouraged to include employee stock ownership plans.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcb2e7f22-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/908"},"text":"108 Stat. 908","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/134/tIV/s415/a/1"},"text":"Pub. L. 105–134, title IV, § 415(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-12-02"},"text":"Dec. 2, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2590"},"text":"111 Stat. 2590","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb2e7f23-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb2e7f24-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb2e7f25-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","childr