{"tag":"section","attrib":{"id":"idcb7f8573-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506"},"text":null,"children":[{"tag":"num","attrib":{"value":"32506"},"text":"§ 32506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibited acts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb7f8574-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as provided in this section and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32502"},"text":"section 32502 of this title","children":[],"tail":", a person may not—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7f8575-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manufacture for sale, sell, offer for sale, introduce or deliver for introduction in interstate commerce, or import into the United States, a passenger motor vehicle or passenger motor vehicle equipment manufactured on or after the date an applicable standard under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32502"},"text":"section 32502 of this title","children":[],"tail":" takes effect, unless it conforms to the standard;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f8576-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to comply with an applicable regulation prescribed by the Secretary of Transportation under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f8577-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to keep records, refuse access to or copying of records, fail to make reports or provide items or information, or fail or refuse to allow entry or inspection, as required by this chapter or a regulation prescribed under this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f8578-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fail to provide the certificate required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32504"},"text":"section 32504 of this title","children":[],"tail":", or provide a certificate that the person knows, or in the exercise of reasonable care has reason to know, is false or misleading in a material respect."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7f8579-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a)(1) of this section does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7f857a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the sale, offer for sale, or introduction or delivery for introduction in interstate commerce of a passenger motor vehicle or passenger motor vehicle equipment after the first purchase of the vehicle or equipment in good faith other than for resale (but this clause does not prohibit a standard from requiring that a vehicle or equipment be manufactured to comply with the standard over a specified period of operation or use); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f857b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a person—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7f857c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing that the person had no reason to know, by exercising reasonable care, that the vehicle or equipment does not comply with the standard; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7f857d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" holding, without knowing about a noncompliance and before that first purchase, a certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32504"},"text":"section 32504 of this title","children":[],"tail":" stating that the vehicle or equipment complies with the standard."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7f857e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Importing Noncomplying Vehicles and Equipment","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb7f857f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretaries of Transportation and the Treasury may prescribe joint regulations authorizing a passenger motor vehicle or passenger motor vehicle equipment not complying with a standard prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32502"},"text":"section 32502 of this title","children":[],"tail":" to be imported into the United States subject to conditions (including providing a bond) the Secretaries consider appropriate to ensure that the vehicle or equipment will—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb7f8580-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply, after importation, with the standards prescribed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s32502"},"text":"section 32502 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7f8581-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be exported; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb7f8582-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be abandoned to the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb7f8583-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretaries may prescribe joint regulations that allow a passenger motor vehicle or passenger motor vehicle equipment to be imported into the United States after the first purchase in good faith other than for resale.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb7f8584-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s32506/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Liability Under Other Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Compliance with a standard under this chapter does not exempt a person from liability provided by law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb7f8585-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1045"},"text":"108 Stat. 1045","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/277/dA/s101/g/tIII/s351/b/2"},"text":"Pub. L. 105–277, div. A, § 101(g) [title III, § 351(b)(2)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-10-21"},"text":"Oct. 21, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/2681-439"},"text":"112 Stat. 2681–439","children":[],"tail":", 2681–476.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb7f8586-47c4-11f1-9671-b5