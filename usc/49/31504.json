{"tag":"section","attrib":{"id":"idcb788085-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31504"},"text":null,"children":[{"tag":"num","attrib":{"value":"31504"},"text":"§ 31504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Identification of motor vehicles","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb788086-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31504/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Authority","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb788087-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31504/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" issue and require the display of an identification plate on a motor vehicle used in transportation provided by a motor private carrier and a motor carrier of migrant workers subject to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31502/c"},"text":"section 31502(c) of this title","children":[],"tail":", except a motor contract carrier; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb788088-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31504/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require each of those motor private carriers and motor carriers of migrant workers to pay the reasonable cost of the plate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb788089-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31504/b"},"text":null,"children":[{"tag":"num","at