{"tag":"section","attrib":{"id":"idca76ef29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508"},"text":null,"children":[{"tag":"num","attrib":{"value":"508"},"text":"§ 508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Safety performance history of new drivers; limitation on liability","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca76ef2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation on Liability","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"No action or proceeding for defamation, invasion of privacy, or interference with a contract that is based on the furnishing or use of safety performance records in accordance with regulations issued by the Secretary may be brought against—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca76ef2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor carrier requesting the safety performance records of an individual under consideration for employment as a commercial motor vehicle driver as required by and in accordance with regulations issued by the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76ef2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person who has complied with such a request; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76ef2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agents or insurers of a person described in paragraph (1) or (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca76ef2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Restrictions on Applicability.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca76ef2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motor carrier requesting","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to a motor carrier requesting safety performance records unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca76ef30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the motor carrier and any agents of the motor carrier have complied with the regulations issued by the Secretary in using the records, including the requirement that the individual who is the subject of the records be afforded a reasonable opportunity to review and comment on the records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca76ef31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the motor carrier and any agents and insurers of the motor carrier have taken all precautions reasonably necessary to protect the records from disclosure to any person, except for such an insurer, not directly involved in deciding whether to hire that individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca76ef32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the motor carrier has used those records only to assess the safety performance of the individual who is the subject of those records in deciding whether to hire that individual.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76ef33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Person complying with requests","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subsection (a) does not apply to a person complying with a request for safety performance records unless—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca76ef34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the complying person and any agents of the complying person have taken all precautions reasonably necessary to ensure the accuracy of the records and have complied with the regulations issued by the Secretary in furnishing the records, including the requirement that the individual who is the subject of the records be afforded a reasonable opportunity to review and comment on the records; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca76ef35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the complying person and any agents and insurers of the complying person have taken all precautions reasonably necessary to protect the records from disclosure to any person, except for such an insurer, not directly involved in forwarding the records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca76ef36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Persons knowingly furnishing false information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subsection (a) does not apply to persons who knowingly furnish false information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca76ef37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preemption of State and Local Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No State or political subdivision thereof may enact, prescribe, issue, continue in effect, or enforce any law (including any regulation, standard, or other provision having the force and effect of law) that prohibits, penalizes, or imposes liability for furnishing or using safety performance records in accordance with regulations issued by the Secretary to carry out this section. Notwithstanding any provision of law, written authorization shall not be required to obtain information on the motor vehicle driving record of an individual under consideration for employment with a motor carrier.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca76ef38-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4014/a/1"},"text":"Pub. L. 105–178, title IV, § 4014(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/409"},"text":"112 Stat. 409","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca76ef39-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca76ef3a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"idca76ef3b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4014/a/1"},"text":"Pub. L. 105–178, title IV, § 4014(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/409"},"text":"112 Stat. 409","children":[],"tail":", which directed the addition of section 508 at end of this chapter, was executed by adding this section at the end of subchapter I of this chapter to reflect the probable intent of Congress."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idca76ef3c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 508, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/102/548/s2/a"},"text":"Pub. L. 102–548, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-28"},"text":"Oct. 28, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/3646"},"text":"106 Stat. 3646","children":[],"tail":", related to certification of weights and description, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s4/j/11/B"},"text":"Pub. L. 103–272, § 4(j)(11)(B)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1368"},"text":"108 Stat. 1368","children":[],"tail":". See chapter 59 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca76ef3d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idca76ef3e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4014/b"},"text":"Pub. L. 105–178, title IV, § 4014(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/411"},"text":"112 Stat. 411","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/178/tIV/s4014/b"},"text":"“The amendments made by subsection (a) [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1999-01-31"},"text":"January 31, 1999","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
