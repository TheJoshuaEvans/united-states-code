ml:a","attrib":{"href":"/us/pl/97/35"},"text":"Pub. L. 97–35","children":[],"tail":", §§ 1191, 1192, "},{"tag":"html:a","attrib":{"href":"/us/stat/95/699"},"text":"95 Stat. 699","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 14, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/468/s501"},"text":"Pub. L. 97–468, § 501","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2551"},"text":"96 Stat. 2551","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Apr. 7, 1986","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/99/272/s4018"},"text":"Pub. L. 99–272, § 4018","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/100/111"},"text":"100 Stat. 111","children":[],"tail":"; restated "},{"tag":"html:span","attrib":{},"text":"Dec. 11, 1989","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/213/s2/a"},"text":"Pub. L. 101–213, § 2(a)","children":[],"tail":", (c), "},{"tag":"html:a","attrib":{"href":"/us/stat/103/1843"},"text":"103 Stat. 1843","children":[],"tail":", 1845, 1847."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"22106(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1654(d)(3) (1st, 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"22106(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1654(d)(3) (3d, last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"22106(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1654(d)(4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"22106(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1654(i).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “financial assistance for projects under this chapter” are substituted for “assistance provided under subsection (b) of this section” for clarity. The words “rail carrier providing rail transportation” are substituted for “operator of rail service” for consistency in the revised title. The word “conditions” is omitted as being included in “terms”. The words “Secretary of the Treasury” are substituted for “Department of the Treasury” because of 31:301(b).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “in the same manner and under the same conditions as if they were originally granted to the State by the Secretary” are omitted as unnecessary.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e)(2), the words “assistance under this chapter” are substituted for “Federal assistance” for clarity and consistency in this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb2027ae-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:22106(b) to clarify the restatement of 49 App.:1654(d)(3) by ","children":[{"tag":"ref","attrib":{"href":"/us/act/1994-07-05/s1"},"text":"section 1 of the Act of July 5, 1994","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/pl/103/272"},"text":"Public Law 103–272","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/897"},"text":"108 Stat. 897","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb2027af-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb2027b0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" substituted “interest thereon” for “interest thereof”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s701/a/1"},"text":"Pub. L. 110–432, § 701(a)(1)","children":[],"tail":", struck out last sentence which read as follows: “The State shall decide on the financial terms of the grant or loan, except that the time for making grant advances shall comply with regulations of the Secretary of the Treasury.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s701/a/2"},"text":"Pub. L. 110–432, § 701(a)(2)","children":[],"tail":", added subsec. (b) and struck out former subsec. (b). Prior to amendment, text read as follows: “The State shall place the United States Government’s share of money that is repaid in an interest-bearing account. However, the Secretary of Transportation may allow a borrower to place that money, for the benefit of the State, in a bank designated by the Secretary of the Treasury under "},{"tag":"ref","attrib":{"href":"/us/act/1942-06-11/s10"},"text":"section 10 of the Act of June 11, 1942","children":[],"tail":" ("},{"tag":"ref","attrib":{"href":"/us/usc/t12/s265"},"text":"12 U.S.C. 265","children":[],"tail":"). The State shall use the money and accumulated interest to make other grants and loans under this chapter in the same manner and under the same conditions as if they were originally granted to the State by the Secretary of Transportation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s701/a/3"},"text":"Pub. L. 110–432, § 701(a)(3)","children":[],"tail":", redesignated subsec. (d) as (c) and struck out former subsec. (c). Text of former subsec. (c) read as follows: “The State may pay the Secretary of Transportation the Government’s share of unused money and accumulated interest at any time. However, the State must pay the unused money and accumulated interest to the Secretary when the State ends its participation under this chapter.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/s701/a/3"},"text":"Pub. L. 110–432, § 701(a)(3)","children":[],"tail":", struck out subsec. (e). Text read as follows: “Each State shall retain a contingent interest (redeemable preference shares) for the Government’s share of amounts in a rail line receiving assistance under this chapter. The State may collect its share of the amounts used for the rail line if—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) an application for abandonment of the rail line is filed under chapter 109 of this title; or","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) the rail line is sold or disposed of after it has received assistance under this chapter.”","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" inserted “in the same manner and under the same conditions as if they were originally granted to the State by the Secretary of Transportation” after “under this chapter”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb2027b1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb2027b2-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb2027b3-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s8/1"},"text":"section 8(1) of Pub. L. 104–287","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s5303"},"text":"section 5303 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
