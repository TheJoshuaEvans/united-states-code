{"tag":"section","attrib":{"id":"idcb2027a6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22106"},"text":null,"children":[{"tag":"num","attrib":{"value":"22106"},"text":"§ 22106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitations on financial assistance","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb2027a7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22106/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grants and Loans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State shall use financial assistance for projects under this chapter to make a grant or lend money to the owner of rail property, or a rail carrier providing rail transportation, related to a project being assisted.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2027a8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22106/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"State Use of Repaid Funds and Contingent Interest Recoveries","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The State shall place the United States Government’s share of money that is repaid and any contingent interest that is recovered in an interest-bearing account. The repaid money, contingent interest, and any interest thereon shall be considered to be State funds. The State shall use such funds to make other grants and loans, consistent with the purposes for which financial assistance may be used under subsection (a), as the State considers to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2027a9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22106/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Encouraging Participation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the maximum extent possible, the State shall encourage the participation of shippers, rail carriers, and local communities in paying the State share of assistance costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb2027aa-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/897"},"text":"108 Stat. 897","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/55"},"text":"Pub. L. 104–287, § 5(55)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3393"},"text":"110 Stat. 3393","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tVII/s701/a"},"text":"Pub. L. 110–432, div. A, title VII, § 701(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4905"},"text":"122 Stat. 4905","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11316/k"},"text":"Pub. L. 114–94, div. A, title XI, § 11316(k)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1678"},"text":"129 Stat. 1678","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote"