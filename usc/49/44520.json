{"tag":"section","attrib":{"id":"idcbe8804e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520"},"text":null,"children":[{"tag":"num","attrib":{"value":"44520"},"text":"§ 44520.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Center of Excellence for Alternative Jet Fuels and Environment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbe8804f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall continue operation of the Center of Excellence for Alternative Jet Fuels and Environment (in this section referred to as the “Center”).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe88050-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Center shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbe88051-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" focus on research to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbe88052-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in the development, qualification, and certification of the use of aviation fuel from alternative and renewable sources (such as biomass, next-generation feedstocks, alcohols, organic acids, hydrogen, bioderived chemicals and gaseous carbon) for commercial aircraft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe88053-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist in informing the safe use of alternative aviation fuels in commercial aircraft that also apply electrified aircraft propulsion systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe88054-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reduce community exposure to civilian aircraft noise and pollutant emissions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe88055-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform decision making to support United States leadership on international aviation environmental issues, including the development of domestic and international standards; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe88056-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve and expand the scientific understanding of civil aviation noise and pollutant emissions and their impacts, as well as support the development of improved modeling approaches and tools;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe88057-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" examine the use of novel technologies and other forms of innovation to reduce noise, emissions, and fuel burn in commercial aircraft; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe88058-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support collaboration with other Federal agencies, industry stakeholders, research institutions, and other relevant entities to accelerate the research, development, testing, evaluation, and demonstration programs and facilitate United States sustainability and competitiveness in aviation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe88059-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator shall carry out the work of the Center through the use of grants or other measures, as determined appropriate by the Administrator pursuant to section 44513, including through interagency agreements and coordination with other Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbe8805a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbe8805b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation of educational and research institutions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out the responsibilities described in subsection (b), the Center shall include, as appropriate, participation by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbe8805c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" institutions of higher education and research institutions that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcbe8805d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/d/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have existing facilities for research, development, and testing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcbe8805e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/d/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" leverage private sector partnerships;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe8805f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe88060-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/d/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consortia with experience across the alternative fuels supply chain, including with research, feedstock development and production, small-scale development, testing, and technology evaluation related to the creation, processing, production, and transportation of alternative aviation fuel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbe88061-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/d/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consortia with experience in innovative technologies to reduce noise, emissions, and fuel burn in commercial aircraft.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbe88062-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44520/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of nasa facilities","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Center shall, in consultation with the Administrator of NASA, consider using, on a reimbursable basis, the existing and available capacity in aeronautics research facilities at the Langley Research Center, the NASA John H. Glenn Center at the Neil A. Armstrong Test Facility, and other appropriate facilities of the National Aeronautics and Space Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbe88063-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tX/s1017/a"},"text":"Pub. L. 118–63, title X, § 1017(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1396"},"text":"138 Stat. 1396","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
