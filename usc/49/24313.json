{"tag":"section","attrib":{"id":"idcb3339f7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24313"},"text":null,"children":[{"tag":"num","attrib":{"value":"24313"},"text":"§ 24313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Rail safety system program","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In consultation with rail labor organizations, Amtrak shall maintain a rail safety system program for employees working on property owned by Amtrak. The program shall be a model for other rail carriers to use in developing safety programs. The program shall include—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb3339f8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24313/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodic analyses of accident information, including primary and secondary causes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3339f9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24313/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodic evaluations of the activities of the program, particularly specific steps taken in response to an accident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3339fa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24313/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodic reports on amounts spent for occupational health and safety activities of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3339fb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24313/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodic reports on reduced costs and personal injuries because of accident prevention activities of the program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3339fc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24313/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodic reports on direct accident costs, including claims related to accidents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb3339fd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24313/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reports and evaluations of other information Amtrak considers appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb3339fe-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/917"},"text":"108 Stat. 917","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb3339ff-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb333a00-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb333a01-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"24313","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"45:646.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 30, 1970","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/91/518"},"text":"Pub. L. 91–518","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/84/1327"},"text":"84 Stat. 1327","children":[],"tail":", § 807; added "},{"tag":"html:span","attrib":{},"text":"Oct. 5, 1978","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/95/421/s13"},"text":"Pub. L. 95–421, § 13","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/92/929"},"text":"92 Stat. 929","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, before clause (1), the words “No later than ","children":[{"tag":"date","attrib":{"date":"1979-01-01"},"text":"January 1, 1979","children":[],"tail":"” are omitted as executed. The word “maintain” is substituted for “develop and implement” for clarity. The words “designed to serve as” and “required under this section” are omitted as surplus. In clause (1), the words “if known” are omitted as surplus. In clause (2), the words “undertaken” and “causes” are omitted as surplus. In clauses (3)–(6), the word “reports” is substituted for “identification” for clarity. In clause (3), the word “included” is omitted as surplus. In clause (4), the words “personal injuries” are substituted for “fatalities, and casualties” for consistency in the revised title. The word “activities” is added for clarity. In clause (6), the words “or data” and “necessary or” are omitted as surplus."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb333a02-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb333a03-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Comprehensive Rail Safety Review of Amtrak","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22407"},"text":"Pub. L. 117–58, div. B, title II, § 22407","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/739"},"text":"135 Stat. 739","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dB/tII/s22407"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comprehensive Safety Assessment","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"], the Secretary [of Transportation] shall—"}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct a focused review of Amtrak’s safety-related processes and procedures, compliance with safety regulations and requirements, and overall safety culture; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submit a report to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives that includes the findings and recommendations resulting from such assessment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Plan.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial plan","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 6 months after the completion of the comprehensive safety assessment under subsection (a)(1), Amtrak shall submit a plan to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives for addressing the findings and recommendations raised in the comprehensive safety assessment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual updates","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amtrak shall submit annual updates of its progress toward implementing the plan submitted pursuant to paragraph (1) to the committees listed in such paragraph.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
