{"tag":"section","attrib":{"id":"idcb35ab31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321"},"text":null,"children":[{"tag":"num","attrib":{"value":"24321"},"text":"§ 24321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Food and beverage service","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb35ab32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Working Group.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb35ab33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after enactment of the Passenger Rail Expansion and Rail Safety Act of 2021, Amtrak shall establish a working group to provide recommendations to improve Amtrak’s onboard food and beverage service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35ab34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Membership","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The working group shall consist of individuals representing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb35ab35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amtrak;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb35ab36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the labor organizations representing Amtrak employees who prepare or provide on-board food and beverage service;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb35ab37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" nonprofit organizations representing Amtrak passengers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb35ab38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" States that are providing funding for State-supported routes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35ab39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the establishment of the working group pursuant to subsection (a), the working group shall submit a report to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives containing recommendations for improving Amtrak’s food and beverage service, including—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb35ab3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways to improve the financial performance of Amtrak;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35ab3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways to increase and retain ridership;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35ab3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the differing needs of passengers traveling on long-distance routes, State supported routes, and the Northeast Corridor;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35ab3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Amtrak passenger survey data about the food and beverages offered on Amtrak trains;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35ab3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ways to incorporate local food and beverage items on State-supported routes; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb35ab3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other issue that the working group determines to be appropriate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35ab40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 180 days after the submission of the report pursuant to subsection (b), Amtrak shall submit a plan for implementing the recommendations of the working group, and an explanation for any of the working group’s recommendations it does not agree with and does not plan on implementing to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb35ab41-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s24321/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Savings Clause","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Amtrak shall ensure that no Amtrak employee who held a position on a long-distance or Northeast Corridor route as of the date of enactment of the Passenger Rail Expansion and Rail Safety Act of 2021, is involuntarily separated because of the development and implementation of the plan required under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb35ab42-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tXI/s11207/a"},"text":"Pub. L. 114–94, div. A, title XI, § 11207(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1638"},"text":"129 Stat. 1638","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/116/159/dB/tI/s1104/a"},"text":"Pub. L. 116–159, div. B, title I, § 1104(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-10-01"},"text":"Oct. 1, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/727"},"text":"134 Stat. 727","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tII/s22208/b/1"},"text":"Pub. L. 117–58, div. B, title II, § 22208(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/706"},"text":"135 Stat. 706","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb35ab43-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcb35ab44-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcb35ab45-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Enactment of the Passenger Rail Expansion and Rail Safety Act of 2021, referred in subsec. (a)(1), probably means the date of enactment of the Passenger Rail Expansion and Rail Safety Act of 2021, which is the date of enactment of title II of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" and was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of the Passenger Rail Expansion and Rail Safety Act of 2021, referred to in subsec. (d), is the date of enactment of title II of div. B of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcb35ab46-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58"},"text":"Pub. L. 117–58","children":[],"tail":" amended section generally. Prior to amendment, section related to Amtrak’s development and implementation of plan to eliminate operating loss associated with providing food and beverage service on board Amtrak trains."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2020—Subsecs. (d), (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/159"},"text":"Pub. L. 116–159","children":[],"tail":" redesignated subsec. (e) as (d) and struck out former subsec. (d). Text read as follows: “Beginning on the date that is 5 years after the date of enactment of the Passenger Rail Reform and Investment Act of 2015, no Federal funds may be used to cover any operating loss associated with providing food and beverage service on a route operated by Amtrak or a rail carrier that operates a route in lieu of Amtrak pursuant to section 24711.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcb35ab47-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcb35ab48-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as an Effective Date of 2015 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
