{"tag":"section","attrib":{"id":"idcbb8be04-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109"},"text":null,"children":[{"tag":"num","attrib":{"value":"41109"},"text":"§ 41109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Terms of certificates","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbb8be05-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbb8be06-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":" shall specify the type of transportation to be provided."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8be07-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Secretary of Transportation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbb8be08-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may prescribe terms for providing air transportation under the certificate that the Secretary finds may be required in the public interest; but","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbb8be09-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may not prescribe a term preventing an air carrier from adding or changing schedules, equipment, accommodations, and facilities for providing the authorized transportation to satisfy business development and public demand.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8be0a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":" to provide foreign air transportation shall specify the places between which the air carrier is authorized to provide the transportation only to the extent the Secretary considers practicable and otherwise only shall specify each general route to be followed. The Secretary shall authorize an air carrier holding a certificate to provide foreign air transportation to handle and transport mail of countries other than the United States."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8be0b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":" to provide foreign charter air transportation shall specify the places between which the air carrier is authorized to provide the transportation only to the extent the Secretary considers practicable and otherwise only shall specify each geographical area in which, or between which, the transportation may be provided."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8be0c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" As prescribed by regulation by the Secretary, an air carrier other than a charter air carrier may provide charter trips or other special services without regard to the places named or type of transportation specified in its certificate.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbb8be0d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modifying Terms","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbb8be0e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An air carrier may file with the Secretary an application to modify any term of its certificate issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41102"},"text":"section 41102 of this title","children":[],"tail":" to provide interstate or foreign air transportation. Not later than 60 days after an application is filed, the Secretary shall—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbb8be0f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide the carrier an opportunity for an oral evidentiary hearing on the record; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbb8be10-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" begin to consider the application under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41111"},"text":"section 41111 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8be11-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary shall modify each term the Secretary finds to be inconsistent with the criteria under section 40101(a) and (b) of this title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbb8be12-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41109/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An application under this subsection may not be dismissed under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41108/b/1/C"},"text":"section 41108(b)(1)(C) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbb8be13-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1123"},"text":"108 Stat. 1123","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/70"},"text":"Pub. L. 104–287, § 5(70)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[]