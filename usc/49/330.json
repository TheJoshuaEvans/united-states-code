{"tag":"section","attrib":{"id":"idca7233c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330"},"text":null,"children":[{"tag":"num","attrib":{"value":"330"},"text":"§ 330.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Research activities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca7233ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation may make contracts with educational institutions, public and private agencies and organizations, and persons for scientific or technological research into a problem related to programs carried out by the Secretary. Before making a contract, the Secretary must require the institution, agency, organization, or person to show that it is able to carry out the contract.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7233cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Secretary shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7233cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" give advice and assistance the Secretary believes will best carry out the duties and powers of the Secretary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7233cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" participate in coordinating all research started under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7233ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicate the lines of inquiry most important to the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7233cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage and assist in establishing and maintaining cooperation by and between contractors and between them and other research organizations, the Department of Transportation, and other departments, agencies, and instrumentalities of the United States Government.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7233d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may distribute publications containing information the Secretary considers relevant to research carried out under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7233d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall provide for the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7233d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordination, facilitation, and review of Department of Transportation research and development programs and activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7233d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Advancement, and research and development, of innovative technologies, including intelligent transportation systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7233d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Comprehensive transportation statistics research, analysis, and reporting.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7233d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Education and training in transportation and transportation-related fields.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7233d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Activities of the Volpe National Transportation Systems Center.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7233d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Coordination in support of multimodal and multidisciplinary research activities.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7233d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Authorities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7233d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into grants and cooperative agreements with Federal agencies, State and local government agencies, other public entities, private organizations, and other persons to conduct research into transportation service and infrastructure assurance and to carry out other research activities of the Department of Transportation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7233da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" carry out, on a cost-shared basis, collaborative research and development to encourage innovative solutions to multimodal transportation problems and stimulate the deployment of new technology with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7233db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" non-Federal entities, including State and local governments, foreign governments, institutions of higher education, corporations, institutions, partnerships, sole proprietorships, and trade associations that are incorporated or established under the laws of any State;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7233dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal laboratories; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7233dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/e/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7233de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly initiate contracts, grants, cooperative research and development agreements (as defined in section 12(d) of the Stevenson-Wydler Technology Innovation Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3710a/d"},"text":"15 U.S.C. 3710a(d)","children":[],"tail":")), and other agreements to fund, and accept funds from, the Transportation Research Board of the National Academies, State departments of transportation, cities, counties, institutions of higher education, associations, and the agents of those entities to carry out joint transportation research and technology efforts."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7233df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal Share.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7233e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Subject to paragraph (2), the Federal share of the cost of an activity carried out under subsection (e)(3) shall not exceed 50 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7233e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary determines that the activity is of substantial public interest or benefit, the Secretary may approve a greater Federal share.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7233e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Non-federal share","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All costs directly incurred by the non-Federal partners, including personnel, travel, facility, and hardware development costs, shall be credited toward the non-Federal share of the cost of an activity described in subsection (e)(3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7233e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Program Evaluation and Oversight","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For each of fiscal years 2016 through 2020, the Secretary is authorized to expend not more than 1 ½ percent of the amounts authorized to be appropriated for the coordination, evaluation, and oversight of the programs administered by the Office of the Assistant Secretary for Research and Technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7233e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Technology","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The research, development, or use of a technology under a contract, grant, cooperative research and development agreement, or other agreement entered into under this section, including the terms under which the technology may be licensed and the resulting royalties may be distributed, shall be subject to the Stevenson-Wydler Technology Innovation Act of 1980 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s3701"},"text":"15 U.S.C. 3701","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7233e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s330/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Waiver of Advertising Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s6101"},"text":"Section 6101 of title 41","children":[],"tail":" shall not apply to a contract, grant, or other agreement entered into under this section."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca7233e6-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449/s1/b"},"text":"Pub. L. 97–449, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2427"},"text":"96 Stat. 2427","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tVI/s6011/b"},"text":"Pub. L. 114–94, div. A, title VI, § 6011(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1568"},"text":"129 Stat. 1568","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca7233e7-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca7233e8-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca7233e9-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"330(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1657(q)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s9/q/1"},"text":"Pub. L. 89–670, § 9(q)(1)","children":[],"tail":"–(3), "},{"tag":"html:a","attrib":{"href":"/us/stat/80/947"},"text":"80 Stat. 947","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1657(q)(2) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"330(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1657(q)(2) (less 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"330(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1657(q)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “may make contracts” are substituted for “is authorized to enter into contracts” to eliminate unnecessary words. The words “the conduct of” before “scientific” are omitted as surplus. The words “a problem” are substituted for “any aspect of the problems” because of the style of the revised title. The words “carried out by the Secretary” are substituted for “of the Department which are authorized by statute” because the Secretary of Transportation is vested with all duties and powers. The words “Before making a contract” are substituted for “with which he expects to enter into contracts pursuant to this subsection” for clarity and to eliminate unnecessary words. The words “is able to carry out the contract” are substituted for “have the capability of doing effective work” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “In carrying out this section” are added for clarity. In clause (1), the word “give” is substituted for “furnish” before “such advice” for consistency. The words “duties and powers of the Secretary” are substituted for “mission of the Department” for clarity and consistency. In clause (4), the word “contractors” is substituted for “the institutions, agencies, organizations, or persons” to eliminate unnecessary words. The words “departments, agencies, and instrumentalities of the United States Government” are substituted for “Federal agencies” for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “considers relevant” are substituted for “as he deems pertinent” as more precise. The words “from time to time” before “disseminate” and “in the form of reports or . . . to public or private agencies or organizations, or individuals” before “such information” are omitted as unnecessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca7233ea-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idca7233eb-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The Stevenson-Wydler Technology Innovation Act of 1980, referred to in subsec. (h), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/480"},"text":"Pub. L. 96–480","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-10-21"},"text":"Oct. 21, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2311"},"text":"94 Stat. 2311","children":[],"tail":", which is classified generally to chapter 63 (§ 3701 et seq.) of Title 15, Commerce and Trade. For complete classification of this Act to the Code, see Short Title note set out under "},{"tag":"ref","attrib":{"href":"/us/usc/t15/s3701"},"text":"section 3701 of Title 15","children":[],"tail":" and Tables."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca7233ec-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2015—","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s6011/b/1"},"text":"Pub. L. 114–94, § 6011(b)(1)","children":[],"tail":", substituted “activities” for “contracts” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a) to (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s6011/b/2"},"text":"Pub. L. 114–94, § 6011(b)(2)","children":[],"tail":"–(4), inserted headings."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (d) to (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94/s6011/b/5"},"text":"Pub. L. 114–94, § 6011(b)(5)","children":[],"tail":", added subsecs. (d) to (i)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idca7233ed-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idca7233ee-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca7233ef-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Volpe Oversight","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tV/s25023"},"text":"Pub. L. 117–58, div. B, title V, § 25023","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/879"},"text":"135 Stat. 879","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/58/dB/tV/s25023"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Financial Management","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"], the Secretary [of Transportation] shall implement the recommendations of the Inspector General of the Department [of Transportation] included in the report entitled ‘DOT Needs to Strengthen Its Oversight of IAAs With Volpe’ and dated "},{"tag":"date","attrib":{"date":"2019-09-30"},"text":"September 30, 2019","children":[],"tail":", to improve planning, financial management, and the sharing of performance information with respect to intraagency agreements with the John A. Volpe National Transportation Systems Center (referred to in this section as the ‘Volpe Center’)."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"GAO Review.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":"], the Comptroller General of the United States shall submit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report that examines the surface transportation activities at the Volpe Center."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Contents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The report under paragraph (1) shall include an evaluation of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount of Department funding provided to the Volpe Center, as compared to other Federal and non-Federal research partners;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the process used by the Department to determine whether to work with the Volpe Center, as compared to any other Federal or non-Federal research partner;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the Department is collaborating with the Volpe Center to address research needs relating to emerging issues; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" whether the operation of the Volpe Center is duplicative of other public or private sector efforts.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idca7233f0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Conflicts of Interest","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159/tI/s101/g"},"text":"Pub. L. 106–159, title I, § 101(g)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1752"},"text":"113 Stat. 1752","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/106/159/tI/s101/g"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance with regulation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In awarding any contract for research, the Secretary shall comply with section 1252.209–70 of title 48, Code of Federal Regulations, as in effect on the date of the enactment of this section [","children":[{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":"]. The Secretary shall require that the text of such section be included in any request for proposal and contract for research made by the Secretary."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Study.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall conduct a study to determine whether or not compliance with the section referred to in paragraph (1) is sufficient to avoid conflicts of interest in contracts for research awarded by the Secretary and to evaluate whether or not compliance with such section unreasonably delays or burdens the awarding of such contracts.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In conducting the study under this paragraph, the Secretary shall consult, as appropriate, with the Inspector General of the Department of Transportation, the Comptroller General, the heads of other Federal agencies, research organizations, industry representatives, employee organizations, safety organizations, and other entities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 18 months after the date of the enactment of this Act [","children":[{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":"], the Secretary shall transmit to the Committee on Commerce, Science, and Transportation of the Senate and the Committee on Transportation and Infrastructure of the House of Representatives a report on the results of the study conducted under this paragraph.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
