{"tag":"section","attrib":{"id":"idca7e1a7d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1115"},"text":null,"children":[{"tag":"num","attrib":{"value":"1115"},"text":"§ 1115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Training","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca7e1a7e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, “Institute” means the Transportation Safety Institute of the Department of Transportation and any successor organization of the Institute.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7e1a7f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Use of Institute Services","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The National Transportation Safety Board may use, on a reimbursable basis, the services of the Institute. The Secretary of Transportation shall make the Institute available to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7e1a80-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1115/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Board for safety training of employees of the Board in carrying out their duties and powers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1a81-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1115/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other safety personnel of the United States Government, State and local governments, governments of foreign countries, interstate authorities, and private organizations the Board designates in consultation with the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7e1a82-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1115/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idca7e1a83-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1115/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Training at the Institute for safety personnel (except employees of the Government) shall be provided at a reasonable fee established periodically by the Board in consultation with the Secretary. The fee shall be paid directly to the Secretary, and the Secretary shall deposit the fee in the Treasury. The amount of the fee—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idca7e1a84-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1115/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be credited to the appropriate appropriation (subject to the requirements of any annual appropriation); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idca7e1a85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1115/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is an offset against any annual reimbursement agreement between the Board and the Secretary to cover all reasonable costs of providing training under this subsection that the Secretary incurs in operating the Institute.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca7e1a86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1115/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Board shall maintain an annual record of offsets under paragraph (1)(B) of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca7e1a87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s1115/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Training of board employees and others","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Board may conduct training of its employees in those subjects necessary for the proper performance of accident investigation and in those subjects furthering the personnel and workforce development needs set forth in the strategic workforce plan of the Board as required under section 1113(h). The Board may also authorize attendance at courses given under this subsection by other government personnel, personnel of foreign governments, and personnel from industry or otherwise who have a requirement for accident investigation training. The Board may require non-Board personnel to reimburse some or all of the training costs, and amounts so reimbursed shall be credited to the appropriation of the Board as offsetting collections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca7e1a88-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/d"},"text":"Pub. L. 103–272, § 1(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/750"},"text":"108 Stat. 750","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/291/tI/s104"},"text":"Pub. L. 104–291, title I, § 104","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3453"},"text":"110 Stat. 3453","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/424/s3/b/3"},"text":"Pub. L. 106–424, § 3(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-01"},"text":"Nov. 1, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1884"},"text":"114 Stat. 1884","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/63/tXII/s1204/b"},"text":"Pub. L. 118–63, title XII, § 1204(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1423"},"text":"138 Stat. 1423","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca7e1a89-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca7e1a8a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca7e1a8b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1115(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"(no source).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1115(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1903(b)(10) (1st, 2d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Jan. 3, 1975","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/93/633/s304/b/10"},"text":"Pub. L. 93–633, § 304(b)(10)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/88/2156"},"text":"88 Stat. 2156","children":[],"tail":"; added "},{"tag":"html:span","attrib":{},"text":"July 19, 1988","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/100/372/s4"},"text":"Pub. L. 100–372, § 4","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/102/876"},"text":"102 Stat. 876","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"1115(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1903(b)(10) (3d–last sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the words “or successor organization” are omitted as unnecessary because of subsection (a) of this section.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “(established for the purpose of developing courses and conducting training in safety and security for all modes of transportation)” are omitted as surplus. In clause (1), the words “carrying out their duties and powers” are substituted for “in the performance of all of their authorized functions” for consistency in the revised title and with other titles of the United States Code. In clause (2), the words “of the United States Government, State and local governments, governments of foreign countries, interstate authorities, and private organizations” are substituted for “of Federal, interstate, State, local, and foreign governments and non-governmental organizations” for clarity and consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), before clause (A), the words “the Secretary shall deposit the fee in the Treasury” are added for clarity. In clause (B), the words “direct and indirect” are omitted as surplus. The word “administration” is omitted as being included in “operating”. The text of 49 App.:1903(b)(10) (last sentence) is omitted because 5:ch. 41 applies to the National Transportation Safety Board by its own terms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca7e1a8c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca7e1a8d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2024—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" inserted “and in those subjects furthering the personnel and workforce development needs set forth in the strategic workforce plan of the Board as required under section 1113(h)” after “of accident investigation” in first sentence."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/424"},"text":"Pub. L. 106–424","children":[],"tail":" substituted “of the Board” for “of the ‘National Transportation Safety Board, Salaries and Expenses’ ”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/291"},"text":"Pub. L. 104–291","children":[],"tail":" added subsec. (d)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
