{"tag":"section","attrib":{"id":"idcc30104d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44933"},"text":null,"children":[{"tag":"num","attrib":{"value":"44933"},"text":"§ 44933.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Security Managers ","children":[{"tag":"ref","attrib":{"idref":"fn002174"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002174"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “Directors”."}],"tail":null}],"tail":null},{"tag":"subsection","attrib":{"id":"idcc30104e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44933/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment, Designation, and Stationing","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Transportation Security Administration shall establish the position of Federal Security Director at each airport in the United States described in section 44903(c). The Administrator of the Transportation Security Administration shall designate individuals as Federal Security Directors for, and station those Federal Security Directors at, those airports.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc30104f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44933/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties and Powers","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Federal Security Director at each airport shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc301050-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44933/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" oversee the screening of passengers and property at the airport; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc301051-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44933/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out other duties prescribed by the Administrator of the Transportation Security Administration.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc301052-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44933/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Information Sharing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of the enactment of the TSA Modernization Act, the Administrator shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc301053-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44933/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require each Federal Security Director of an airport to meet at least quarterly with the airport director, airport security coordinator, and law enforcement agencies serving each such airport to discuss incident management protocols, including the resolution of screening anomalies at passenger screening checkpoints; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc301054-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44933/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" require each Federal Security Director at an airport to inform, consult, and coordinate, as appropriate, with the respective airport security coordinator in a timely manner on security matters impacting airport operations and to establish and maintain operational protocols with such airport operators to ensure coordinated responses to security matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc301055-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1216"},"text":"108 Stat. 1216","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI"},"text":"Pub. L. 107–71, title I","children":[],"tail":", §§ 101(f)(4), 103, "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/603"},"text":"115 Stat. 603","children":[],"tail":", 605; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI"},"text":"Pub. L. 115–254, div. K, title I","children":[],"tail":", §§ 1989(a), 1991(d)(24), "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3624"},"text":"132 Stat. 3624","children":[],"tail":", 3637.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc301056-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc301057-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc301058-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44933(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358b(a)(1), (2), (4).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 319(a); added "},{"tag":"html:span","attrib":{},"text":"Nov. 16, 1990","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/101/604/s104"},"text":"Pub. L. 101–604, § 104","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/104/3070"},"text":"104 Stat. 3070","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44933(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358b(a)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44933(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1358b(a)(5).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “Not later than 90 days after ","children":[{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":"” are omitted as obsolete. The words “The Administrator shall designate individuals as Managers for, and station those Managers at, those airports” are substituted for “and shall begin designating persons as such Managers and stationing such Managers at such airports” for clarity and because of the restatement. The words “and designate a current field employee of the Administration as a Manager” are substituted for “assign the functions and responsibilities described in this section to existing Federal Aviation Administration field personnel and designate such personnel accordingly” to eliminate unnecessary words. The words “to the office of” are omitted as unnecessary. The words “Not later than 1 year after "},{"tag":"date","attrib":{"date":"1990-11-16"},"text":"November 16, 1990","children":[],"tail":"” are omitted as obsolete. The words “Secretary of Transportation” are substituted for “Department of Transportation” because of 49:102."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “The Manager at each airport shall” are substituted for “The responsibilities of a Federal Security Manager shall include the following” to eliminate unnecessary words. In clause (2)(A), the words “air carrier” are substituted for “such air carrier” because this is the first time the term is used in the source provisions. In clause (3), the words “United States Government” are substituted for “Federal” for clarity and consistency in the revised title and with other titles of the United States Code. In clause (7), the words “other Managers” are substituted for “Federal Security Managers at other airports, as appropriate” to eliminate unnecessary words.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “duties and powers” are substituted for “responsibilities” for clarity and consistency in the revised title and with other titles of the Code.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc301059-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc30105a-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of the TSA Modernization Act, referred to in subsec. (c), is the date of the enactment of title I of div. K of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc30105b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/24/C"},"text":"Pub. L. 115–254, § 1991(d)(24)(C)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration shall designate” for “Under Secretary shall designate”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/24/A"},"text":"Pub. L. 115–254, § 1991(d)(24)(A)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration shall establish” for “Under Secretary of Transportation for Security shall establish”, “Federal Security Director” for “Federal Security Manager”, and, in two places, “Federal Security Directors” for “Managers”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/24/B"},"text":"Pub. L. 115–254, § 1991(d)(24)(B)","children":[],"tail":", substituted “Federal Security Director” for “Manager” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1991/d/24/C"},"text":"Pub. L. 115–254, § 1991(d)(24)(C)","children":[],"tail":", substituted “Administrator of the Transportation Security Administration” for “Under Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s1989/a"},"text":"Pub. L. 115–254, § 1989(a)","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s103"},"text":"Pub. L. 107–71, § 103","children":[],"tail":", amended section generally, substituting provisions relating to designation, establishment, and stationing procedures and duties and powers for provisions which contained a more detailed listing of responsibilities and a prohibition against a Civil Aviation Security Field Officer being assigned security duties and powers at an airport having a Manager."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71/s101/f/4"},"text":"Pub. L. 107–71, § 101(f)(4)","children":[],"tail":", substituted “Under Secretary” for “Assistant Administrator for Civil Aviation Security”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
