":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcb788075-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1995 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as an Effective Date note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"savings","id":"idcb788076-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Savings Provision","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/690/tIX/s9102/c"},"text":"Pub. L. 100–690, title IX, § 9102(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-11-18"},"text":"Nov. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/4529"},"text":"102 Stat. 4529","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/690/tIX/s9102/c"},"text":"“The amendment made by subsection (a) [amending section 2505 of former Title 49, Transportation] shall not be construed as having any effect on the enactment of subsection (d) of section 3102 [now 31502] of title 49, United States Code, which subsection (d) was added to such section by section 206(h) of the Motor Carrier Safety Act of 1984 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/554"},"text":"Pub. L. 98–554","children":[],"tail":"] on "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"October 30, 1984","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb788077-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Continued Application of Safety and Maintenance Requirements","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4012/b"},"text":"Pub. L. 105–178, title IV, § 4012(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/409"},"text":"112 Stat. 409","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/105/178/tIV/s4012/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The amendment made by subsection (a) [amending this section] may not be construed—","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exempt any utility service vehicle from compliance with any applicable provision of law relating to vehicle mechanical safety, maintenance requirements, or inspections; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to exempt any driver of a utility service vehicle from any applicable provision of law (including any regulation) established for the issuance, maintenance, or periodic renewal of a commercial driver’s license for that driver.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the following definitions apply:","children":[],"tail":null},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"“(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commercial driver’s license","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘commercial driver’s license’ has the meaning that term has under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s31301"},"text":"section 31301 of title 49","children":[],"tail":", United States Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"“(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Driver of a utility service vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘driver of a utility service vehicle’ has the meaning that term has under section 31502(e)(2) of such title [probably should be section 31502(e)(4)(A) of such title].","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"“(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘regulation’ has the meaning that term has under section 31132 of such title.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"“(D)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Utility service vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term ‘utility service vehicle’ has the meaning that term has under section 345(e)(6) of the National Highway System Designation Act of 1995 [","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/59"},"text":"Pub. L. 104–59","children":[],"tail":"] ("},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31136"},"text":"49 U.S.C. 31136","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/stat/109/614-615"},"text":"109 Stat. 614–615","children":[],"tail":").”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb788078-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Study of Adequacy of Parking Facilities","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4027"},"text":"Pub. L. 105–178, title IV, § 4027","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/417"},"text":"112 Stat. 417","children":[],"tail":", directed the Secretary to conduct a study on the adequacy of parking facilities at commercial truck stops and to transmit a report on the study and authorized appropriations for fiscal years 1999, 2000, and 2001."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcb788079-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Exemptions From Requirements Relating to Commercial Motor Vehicles and Their Operator