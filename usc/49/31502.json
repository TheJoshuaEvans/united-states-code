{"tag":"section","attrib":{"id":"idcb788049-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502"},"text":null,"children":[{"tag":"num","attrib":{"value":"31502"},"text":"§ 31502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requirements for qualifications, hours of service, safety, and equipment standards","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb78804a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section applies to transportation—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb78804b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" described in sections 13501 and 13502 of this title; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb78804c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent the transportation is in the United States and is between places in a foreign country, or between a place in a foreign country and a place in another foreign country.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb78804d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motor Carrier and Private Motor Carrier Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation may prescribe requirements for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb78804e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifications and maximum hours of service of employees of, and safety of operation and equipment of, a motor carrier; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb78804f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" qualifications and maximum hours of service of employees of, and standards of equipment of, a motor private carrier, when needed to promote safety of operation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb788050-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Migrant Worker Motor Carrier Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may prescribe requirements for the comfort of passengers, qualifications and maximum hours of service of operators, and safety of operation and equipment of a motor carrier of migrant workers. The requirements only apply to a carrier transporting a migrant worker—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb788051-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at least 75 miles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb788052-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" across the boundary of a State, territory, or possession of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb788053-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Before prescribing or revising any requirement under this section, the Secretary shall consider the costs and benefits of the requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb788054-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exception.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb788055-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, regulations issued under this section or section 31136 regarding—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb788056-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/e/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maximum driving and on-duty times applicable to operators of commercial motor vehicles,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb788057-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/e/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" physical testing, reporting, or recordkeeping, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb788058-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/e/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the installation of automatic recording devices associated with establishing the maximum driving and on-duty times referred to in subparagraph (A),","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"shall not apply to any driver of a utility service vehicle during an emergency period of not more than 30 days declared by an elected State or local government official under paragraph (2) in the area covered by the declaration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb788059-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Declaration of emergency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An elected State or local government official or elected officials of more than one State or local government jointly may issue an emergency declaration for purposes of paragraph (1) after notice to the Field Administrator of the Federal Motor Carrier Safety Administration with jurisdiction over the area covered by the declaration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb78805a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Incident report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Within 30 days after the end of the declared emergency period the official who issued the emergency declaration shall file with the Field Administrator a report of each safety-related incident or accident that occurred during the emergency period involving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb78805b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a utility service vehicle driver to which the declaration applied; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb78805c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a utility service vehicle of the driver to which the declaration applied.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb78805d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/e/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this subsection, the following definitions apply:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb78805e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/e/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Driver of a utility service vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “driver of a utility service vehicle” means any driver who is considered to be a driver of a utility service vehicle for purposes of section 345(a)(4) ","children":[{"tag":"ref","attrib":{"idref":"fn002127"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002127"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of the National Highway System Designation Act of 1995 ("},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31136"},"text":"49 U.S.C. 31136","children":[],"tail":" note; "},{"tag":"ref","attrib":{"href":"/us/stat/109/613"},"text":"109 Stat. 613","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb78805f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/e/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Utility service vehicle","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “utility service vehicle” has the meaning that term has under section 345(e)(6) ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" of the National Highway System Designation Act of 1995 ("},{"tag":"ref","attrib":{"href":"/us/usc/t49/s31136"},"text":"49 U.S.C. 31136","children":[],"tail":" note; 109 Stat "},{"tag":"ref","attrib":{"idref":"fn002128"},"text":"2","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002128"},"text":null,"children":[{"tag":"num","attrib":{},"text":"2","children":[],"tail":" So in original. Probably should be followed by a period."}],"tail":" 614–615)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb788060-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Ready Mixed Concrete Delivery Vehicles.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb788061-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any other provision of law, regulations issued under this section or section 31136 (including section 395.1(e)(1)(ii) of title 49, Code of Federal Regulations) regarding reporting, recordkeeping, or documentation of duty status shall not apply to any driver of a ready mixed concrete delivery vehicle if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb788062-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the driver operates within a 100 air-mile radius of the normal work reporting location;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb788063-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the driver returns to the work reporting location and is released from work within 14 consecutive hours;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb788064-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/f/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the driver has at least 10 consecutive hours off duty following each 14 hours on duty;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb788065-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/f/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the driver does not exceed 11 hours maximum driving time following 10 consecutive hours off duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb788066-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/f/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the motor carrier that employs the driver maintains and retains for a period of 6 months accurate and true time records that show—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb788067-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/f/1/E/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time the driver reports for duty each day;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb788068-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/f/1/E/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of hours the driver is on duty each day;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb788069-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/f/1/E/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time the driver is released from duty each day; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb78806a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/f/1/E/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total time for the preceding driving week the driver is used for the first time or intermittently.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb78806b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s31502/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, the term “driver of a ready mixed concrete delivery vehicle” means a driver of a vehicle designed to deliver ready mixed concrete on a daily basis and is equipped with a mechanism under which the vehicle’s propulsion engine provides the power to operate a mixer drum to agitate and mix the product en route to the delivery site.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb78806c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449"},"text":"Pub. L. 97–449","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2438"},"text":"96 Stat. 2438","children":[],"tail":", § 3102; "},{"tag":"ref","attrib":{"href":"/us/pl/98/554/tII/s206/h"},"text":"Pub. L. 98–554, title II, § 206(h)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-30"},"text":"Oct. 30, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2835"},"text":"98 Stat. 2835","children":[],"tail":"; renumbered § 31502 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/c"},"text":"Pub. L. 103–272, § 1(c)","children":[],"tail":", (e), "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/745"},"text":"108 Stat. 745","children":[],"tail":", 1029; "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/tIII/s308/k/3"},"text":"Pub. L. 104–88, title III, § 308(k)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/948"},"text":"109 Stat. 948","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/178/tIV/s4012/a"},"text":"Pub. L. 105–178, title IV, § 4012(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1998-06-09"},"text":"June 9, 1998","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/112/408"},"text":"112 Stat. 408","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV/s4145/b"},"text":"Pub. L. 109–59, title IV, § 4145(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1749"},"text":"119 Stat. 1749","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV/s5521"},"text":"Pub. L. 114–94, div. A, title V, § 5521","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1559"},"text":"129 Stat. 1559","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb78806d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb78806e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb78806f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Sourc