{"tag":"section","attrib":{"id":"idcb18fb85-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20301"},"text":null,"children":[{"tag":"num","attrib":{"value":"20301"},"text":"§ 20301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition and nonapplication","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb18fb86-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this chapter, “vehicle” means a car, locomotive, tender, or similar vehicle.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb18fb87-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This chapter does not apply to the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb18fb88-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20301/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a train of 4-wheel coal cars.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb89-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20301/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a train of 8-wheel standard logging cars if the height of each car from the top of the rail to the center of the coupling is not more than 25 inches.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb8a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20301/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a locomotive used in hauling a train referred to in clause (2) of this subsection when the locomotive and cars of the train are used only to transport logs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb18fb8b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20301/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a car, locomotive, or train used on a street railway.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb18fb8c-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/881"},"text":"108 Stat. 881","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/52"},"text":"Pub. L. 104–287, § 5(52)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3393"},"text":"110 Stat. 3393","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb18fb8d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb18fb8e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb18fb8f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{}