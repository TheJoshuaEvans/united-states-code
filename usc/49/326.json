{"tag":"section","attrib":{"id":"idca6fc378-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s326"},"text":null,"children":[{"tag":"num","attrib":{"value":"326"},"text":"§ 326.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Gifts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idca6fc379-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s326/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of Transportation may accept and use conditional or unconditional gifts of property for the Department of Transportation. The Secretary may accept a gift of services in carrying out aviation duties and powers. Property accepted under this section and proceeds from that property must be used, as nearly as possible, under the terms of the gift.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6fc37a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s326/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Department has a fund in the Treasury. Disbursements from the fund are made on order of the Secretary. The fund consists of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idca6fc37b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s326/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" gifts of money;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6fc37c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s326/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income from property accepted under this section and proceeds from the sale of that property; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idca6fc37d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s326/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" income from securities under subsection (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6fc37e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s326/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" On request of the Secretary of Transportation, the Secretary of the Treasury may invest and reinvest amounts in the fund in securities of, or in securities whose principal and interest is guaranteed by, the United States Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idca6fc37f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s326/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Property accepted under this section is a gift to or for the use of the Government under the Internal Revenue Code of 1986 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"26 U.S.C. 1","children":[],"tail":" et seq.)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idca6fc380-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/449/s1/b"},"text":"Pub. L. 97–449, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1983-01-12"},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/2424"},"text":"96 Stat. 2424","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/99/514/s2"},"text":"Pub. L. 99–514, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-22"},"text":"Oct. 22, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/2095"},"text":"100 Stat. 2095","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idca6fc381-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idca6fc382-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idca6fc383-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"326(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1344(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s303/c/1"},"text":"Pub. L. 85–726, § 303(c)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/748"},"text":"72 Stat. 748","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1657(m)(1) (1st, 3d sentences).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s9/m"},"text":"Pub. L. 89–670, § 9(m)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/946"},"text":"80 Stat. 946","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"326(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1657(m)(1) (2d sentence), (3) (less 1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"326(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1657(m)(3) (1st sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"326(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49:1657(m)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In the section, the word “gifts” is substituted for “gifts and bequests” in 49:1657(m)(1) because it is inclusive.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “accept and use” are substituted for “accept, hold, administer, and utilize”, and the words “for the Department” are substituted for “for the purpose of aiding or facilitating the work of the Department” in 49:1657(m)(1), to eliminate unnecessary words. The word “property” is substituted for “property, both real and personal” in 49:1657(m)(1), and “gift or donation of money or other property, real and personal” in 49:1344(c)(1) to eliminate unnecessary words. The words “aviation duties and powers” are added because the source provisions being restated only applies to carrying out duties and powers related to the Federal Aviation Administration. The words “under this section and proceeds from that property” are substituted for “pursuant to this paragraph, and the proceeds thereof” in 49:1657(m)(1) for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “The Department has a” and “The fund consists of” are added for clarity and because of the restatement of the section. The word “separate” before “fund” is omitted as unnecessary and for consistency. The words “from the fund” are added for clarity. The words “accepted under this section” are substituted for “held by the Secretary pursuant to paragraph (1)” for clarity. The words “that property” are substituted for “other property received as gifts or bequests” to eliminate unnecessary words. The words “from securities under subsection (c) of this section” are substituted for “accruing from such securities” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “amounts in the fund” are substituted for “any moneys contained in the fund provided for in paragraph (1)” for clarity and consistency.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d), the words “under this section” are substituted for “under paragraph (1)” because of the restatement of the section. The words “the Internal Revenue Code of 1954 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s1"},"text":"26 U.S.C. 1","children":[],"tail":" et seq.)” are substituted for “For the purpose of Federal income, estate, and gift taxes” for consistency."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idca6fc384-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idca6fc385-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1986—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/99/514"},"text":"Pub. L. 99–514","children":[],"tail":" substituted “Internal Revenue Code of 1986” for “Internal Revenue Code of 1954”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
