{"tag":"section","attrib":{"id":"idcaf2d5d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503"},"text":null,"children":[{"tag":"num","attrib":{"value":"13503"},"text":"§ 13503.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exempt motor vehicle transportation in terminal areas","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcaf2d5da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation by Carriers.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d5db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Neither the Secretary nor the Board has jurisdiction under this subchapter over transportation by motor vehicle provided in a terminal area when the transportation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf2d5dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a transfer, collection, or delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d5dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is provided by—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcaf2d5de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rail carrier subject to jurisdiction under chapter 105;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf2d5df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a water carrier subject to jurisdiction under subchapter II of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf2d5e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a freight forwarder subject to jurisdiction under subchapter III of this chapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d5e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is incidental to transportation or service provided by the carrier or freight forwarder that is subject to jurisdiction under chapter 105 of this title or under subchapter II or III of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d5e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability of other provisions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Transportation exempt from jurisdiction under paragraph (1) of this subsection is subject to jurisdiction under chapter 105 when provided by such a rail carrier, under subchapter II of this chapter when provided by such a water carrier, and under subchapter III of this chapter when provided by such a freight forwarder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcaf2d5e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transportation by Agent.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcaf2d5e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except to the extent provided by paragraph (2) of this subsection, neither the Secretary nor the Board has jurisdiction under this subchapter over transportation by motor vehicle provided in a terminal area when the transportation—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcaf2d5e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is a transfer, collection, or delivery; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcaf2d5e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is provided by a person as an agent or under other arrangement for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcaf2d5e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/b/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a rail carrier subject to jurisdiction under chapter 105 of this title;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf2d5e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/b/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a motor carrier subject to jurisdiction under this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf2d5e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/b/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a water carrier subject to jurisdiction under subchapter II of this chapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcaf2d5ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/b/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a freight forwarder subject to jurisdiction under subchapter III of this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcaf2d5eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13503/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Treatment of transportation by principal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Transportation exempt from jurisdiction under paragraph (1) of this subsection is considered transportation provided by the carrier or service provided by the freight forwarder for whom the transportation was provided and is subject to jurisdiction under chapter 105 of this title when provided for such a rail carrier, under this subchapter when provided for such a motor carrier, under subchapter II of this chapter when provided for such a water carrier, and under subchapter III of this chapter when provided for such a freight forwarder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcaf2d5ec-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/860"},"text":"109 Stat. 860","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcaf2d5ed-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcaf2d5ee-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcaf2d5ef-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to those in this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s10523"},"text":"section 10523 of this title","children":[],"tail":" prior to the general amendment of this subtitle by "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s102/a"},"text":"Pub. L. 104–88, § 102(a)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcaf2d5f0-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcaf2d5f1-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
