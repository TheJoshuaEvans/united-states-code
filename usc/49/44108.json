{"tag":"section","attrib":{"id":"idcbd7df2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108"},"text":null,"children":[{"tag":"num","attrib":{"value":"44108"},"text":"§ 44108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Validity of conveyances, leases, and security instruments","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd7df2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Validity Before Filing","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Until a conveyance, lease, or instrument executed for security purposes that may be recorded under section 44107(a)(1) or (2) of this title is filed for recording, the conveyance, lease, or instrument is valid only against—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7df2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the person making the conveyance, lease, or instrument;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7df2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that person’s heirs and devisees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7df2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a person having actual notice of the conveyance, lease, or instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7df2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of Validity","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"When a conveyance, lease, or instrument is recorded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44107"},"text":"section 44107 of this title","children":[],"tail":", the conveyance, lease, or instrument is valid from the date of filing against all persons, without other recordation, except that—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7df30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lease or instrument recorded under section 44107(a)(2)(A) or (B) of this title is valid for a specifically identified engine or propeller without regard to a lease or instrument previously or subsequently recorded under section 44107(a)(2)(C) or (D); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7df31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lease or instrument recorded under section 44107(a)(2)(C) or (D) of this title is valid only for items at the location designated in the lease or instrument.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7df32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicable Laws","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7df33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The validity of a conveyance, lease, or instrument that may be recorded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44107"},"text":"section 44107 of this title","children":[],"tail":" is subject to the laws of the State, the District of Columbia, or the territory or possession of the United States at which the conveyance, lease, or instrument is delivered, regardless of the place at which the subject of the conveyance, lease, or instrument is located or delivered. If the conveyance, lease, or instrument specifies the place at which delivery is intended, it is presumed that the conveyance, lease, or instrument was delivered at the specified place."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7df34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection does not take precedence over the Convention on the International Recognition of Rights in Aircraft (4 U.S.T. 1830) or the Cape Town Treaty, as applicable.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd7df35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nonapplication","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"This section does not apply to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd7df36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a conveyance described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44107/a/1"},"text":"section 44107(a)(1) of this title","children":[],"tail":" that was made before "},{"tag":"date","attrib":{"date":"1938-08-22"},"text":"August 22, 1938","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd7df37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44108/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a lease or instrument described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44107/a/2"},"text":"section 44107(a)(2) of this title","children":[],"tail":" that was made before "},{"tag":"date","attrib":{"date":"1948-06-20"},"text":"June 20, 1948","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd7df38-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1165"},"text":"108 Stat. 1165","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/297/s5"},"text":"Pub. L. 108–297, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-08-09"},"text":"Aug. 9, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1097"},"text":"118 Stat. 1097","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd7df39-47c4-1