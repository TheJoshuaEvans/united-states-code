l,"children":[{"tag":"html:span","attrib":{},"text":"44108(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1403(c) (less words after semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s503/c"},"text":"Pub. L. 85–726, § 503(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/773"},"text":"72 Stat. 773","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44108(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1403(d).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726/s503/d"},"text":"Pub. L. 85–726, § 503(d)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/773"},"text":"72 Stat. 773","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"July 8, 1959","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/86/81/s3"},"text":"Pub. L. 86–81, § 3","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/73/181"},"text":"73 Stat. 181","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44108(c)(1)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1406.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 506; added "},{"tag":"html:span","attrib":{},"text":"June 30, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/346/s1/a"},"text":"Pub. L. 88–346, § 1(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/236"},"text":"78 Stat. 236","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44108(c)(2)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1406 (note).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"June 30, 1964","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/88/346/s1/c"},"text":"Pub. L. 88–346, § 1(c)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/78/236"},"text":"78 Stat. 236","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"44108(d)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1403(c) (words after semicolon).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “conveyance, lease, or instrument executed for security purposes” are substituted for “conveyance or instrument” for clarity and consistency in this subchapter. The words “in respect of such aircraft, aircraft engine or engines, propellers, appliances, or spare parts” are omitted as surplus. The text of 49 App.:1403(c) (proviso words before semicolon) is omitted because of section 7(d) of this bill. In clause (1), the words “person making the conveyance, lease, or instrument” are substituted for “the person by whom the conveyance or other instrument is made or given” to eliminate unnecessary words and for consistency in this subchapter.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), before clause (1), the words “When a conveyance, lease, or instrument is recorded under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44107"},"text":"section 44107 of this title","children":[],"tail":" . . . from the date of filing” are substituted for “Each conveyance or other instrument recorded by means of or under the system provided for in subsection (a) or (b) of the section shall from the time of its filing for recordation” for clarity and consistency in this subchapter and to eliminate unnecessary words. In clause (1), the words “is valid” are substituted for “"},{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That . . . shall not be affected” for consistency in this subchapter. The words “or engines . . . or propellers” are omitted because of 1:1. In clause (2), the words “is valid” are substituted for “shall be effective” for consistency in this subchapter. The words “for items at the location designated in the lease or instrument” are substituted for “which may from time to time be situated at the designated location or locations and only while so situated” for clarity and to eliminate unnecessary words."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(1), the words “conveyance, lease, or” are added for consistency in this subchapter. The words “the conveyance, lease, or instrument” are substituted for “therein”, and the words “it is presumed” are substituted for “it shall constitute presumptive evidence”, for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (d)(2), the words “lease or instrument” are substituted for “instrument” for clarity and consistency in this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbd7df3c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcbd7df3d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2004—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/297"},"text":"Pub. L. 108–297","children":[],"tail":" inserted “or the Cape Town Treaty, as applicable” before period at end."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcbda282e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcbda282f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2004 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/297"},"text":"Pub. L. 108–297","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2006-03-01"},"text":"Mar. 1, 2006","children":[],"tail":", and not applicable to any registration or recordation that was made before such date under this chapter or any legal rights relating to such registration or recordation, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/297/s7"},"text":"section 7 of Pub. L. 108–297","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s44101"},"text":"section 44101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
