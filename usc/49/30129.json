{"tag":"section","attrib":{"id":"idcb4d78b7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30129"},"text":null,"children":[{"tag":"num","attrib":{"value":"30129"},"text":"§ 30129.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Crash avoidance technology","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb4d78b8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30129/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall promulgate a rule—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb4d78b9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30129/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish minimum performance standards with respect to crash avoidance technology; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb4d78ba-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30129/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to require that all passenger motor vehicles manufactured for sale in the United States on or after the compliance date described in subsection (b) shall be equipped with—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb4d78bb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30129/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a forward collision warning and automatic emergency braking system that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb4d78bc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30129/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" alerts the driver if—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"idcb4d78bd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30129/a/2/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the distance to a vehicle ahead or an object in the path of travel ahead is closing too quickly; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"idcb4d78be-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30129/a/2/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a collision is imminent; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb4d78bf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30129/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" automatically applies the brakes if the driver fails to do so; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb4d78c0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30129/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a lane departure warning and lane-keeping assist system that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcb4d78c1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30129/a/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" warns the driver to maintain the lane of travel; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcb4d78c2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30129/a/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" corrects the course of travel if the driver fails to do so.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb4d78c3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s30129/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance Date","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall determine the appropriate effective date, and any phasing-in of requirements, of the final rule promulgated pursuant to subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb4d78c4-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tIV/s24208/a"},"text":"Pub. L. 117–58, div. B, title IV, § 24208(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/823"},"text":"135 Stat. 823","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
