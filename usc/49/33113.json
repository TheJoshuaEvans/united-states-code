{"tag":"section","attrib":{"id":"idcb8dddcf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113"},"text":null,"children":[{"tag":"num","attrib":{"value":"33113"},"text":"§ 33113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Theft reports","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb8dddd0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Truck, Multipurpose Passenger Vehicle, and Motorcycle Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1995-10-25"},"text":"October 25, 1995","children":[],"tail":", the Secretary of Transportation shall submit a report to Congress that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8dddd1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the number of trucks, multipurpose passenger vehicles, and motorcycles distributed for sale in interstate commerce that are stolen and recovered annually, compiled by model, make, and line;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dddd2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the extent to which trucks, multipurpose passenger vehicles, and motorcycles stolen annually are dismantled to recover parts or are exported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dddd3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the market for the stolen parts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dddd4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the premiums charged by insurers of comprehensive coverage of trucks, multipurpose passenger vehicles, or motorcycles, including any increase in the premiums charged because any of those motor vehicles is a likely candidate for theft;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dddd5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of whether the identification of parts of trucks, multipurpose passenger vehicles, and motorcycles is likely—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8dddd6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to decrease the theft rate of those motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddd7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the recovery rate of those motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddd8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/a/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to decrease the trafficking in stolen parts of those motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddd9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/a/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to stem the export and import of those stolen motor vehicles or parts; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddda-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/a/5/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have benefits greater than the costs of the identification; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddddb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" recommendations on whether, and to what extent, the identification of trucks, multipurpose passenger vehicles, and motorcycles should be required by law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8ddddc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Motor Vehicle Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than ","children":[{"tag":"date","attrib":{"date":"1997-10-25"},"text":"October 25, 1997","children":[],"tail":", the Secretary shall submit a report to Congress that includes—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8ddddd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8dddde-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the methods and procedures used by public and private entities to collect, compile, and disseminate information on the theft and recovery of motor vehicles, including classes of motor vehicles; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8ddddf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reliability and timeliness of the information and how the information can be improved;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddde0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the number of motor vehicles distributed for sale in interstate commerce that are stolen and recovered annually, compiled by class, model, make, and line;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddde1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the extent to which motor vehicles stolen annually are dismantled to recover parts or are exported;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddde2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the market for the stolen parts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddde3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8ddde4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the costs to manufacturers and purchasers of passenger motor vehicles of compliance with the standards prescribed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8ddde5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the beneficial impacts of the standards and the monetary value of the impacts; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8ddde6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the extent to which the monetary value is greater than the costs;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddde7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" information on the experience of officials of the United States Government, States, and localities in—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8ddde8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" making arrests and successfully prosecuting persons for violating a law set forth in title II or III of the Motor Vehicle Theft Law Enforcement Act of 1984;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8ddde9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing or reducing the number and rate of thefts of motor vehicles that are dismantled for parts subject to this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preventing or reducing the availability of used parts that are stolen from motor vehicles subject to this chapter;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dddeb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the premiums charged by insurers of comprehensive coverage of motor vehicles subject to this chapter, including any increase in the premiums charged because a motor vehicle is a likely candidate for theft, and the extent to which the insurers have reduced for the benefit of consumers the premiums, or foregone premium increases, because of this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dddec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information on the adequacy and effectiveness of laws of the United States and the States aimed at preventing the distribution and sale of used parts that have been removed from stolen motor vehicles and the adequacy of systems available to enforcement personnel for tracing parts to determine if they have been stolen from a motor vehicle;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8ddded-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" an assessment of whether the identification of parts of other classes of motor vehicles is likely—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8dddee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to decrease the theft rate of those vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to increase the recovery rate of those vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddf0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/9/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to decrease the trafficking in stolen parts of those vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddf1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/9/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to stem the export and import of those stolen vehicles, parts, or components; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddf2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/9/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to have benefits greater than the costs of the identification; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dddf3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant and reliable information available to the Secretary about the impact, including the beneficial impact, of the laws set forth in titles II and III of the Motor Vehicle Theft Law Enforcement Act of 1984 on law enforcement, consumers, and manufacturers; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dddf4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" recommendations (including, as appropriate, legislative and administrative recommendations) for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8dddf5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/11/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continuing without change the standards prescribed under this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddf6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/11/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amending this chapter to cover more or fewer lines of passenger motor vehicles;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddf7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/11/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" amending this chapter to cover other classes of motor vehicles; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddf8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/b/11/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ending the standards for all future motor vehicles.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb8dddf9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Bases of Reports","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb8dddfa-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The reports under subsections (a) and (b) of this section each shall be based on—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8dddfb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information reported under this chapter by insurers of motor vehicles and manufacturers of motor vehicles and major replacement parts;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddfc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information provided by the Federal Bureau of Investigation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddfd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experience obtained in carrying out this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddfe-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" experience of the Government under the laws set forth in titles II and III of the Motor Vehicle Theft Law Enforcement Act of 1984; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dddff-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other relevant and reliable information available to the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dde00-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In preparing each report, the Secretary shall consult with the Attorney General and State and local law enforcement officials, as appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dde01-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The report under subsection (b) of this section shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb8dde02-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cover a period of at least 4 years after the standards required by this chapter are prescribed; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb8dde03-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reflect any information, as appropriate, from the report under subsection (a) of this section, updated from the date of the report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb8dde04-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s33113/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 90 days before submitting each report to Congress, the Secretary shall publish a proposed report for public review and an opportunity of at least 45 days for written comment. The Secretary shall consider those comments in preparing the report to be submitted and include a summary of the comments with the submitted report.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb8dde05-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1089"},"text":"108 Stat. 1089","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb8dde06-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcb8dde07-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcb8dde08-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag"