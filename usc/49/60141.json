{"tag":"section","attrib":{"id":"idcc85d23d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141"},"text":null,"children":[{"tag":"num","attrib":{"value":"60141"},"text":"§ 60141.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Standards for underground natural gas storage facilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc85d23e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Minimum Safety Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 2 years after the date of enactment of the PIPES Act of 2016, the Secretary, in consultation with the heads of other relevant Federal agencies, shall issue minimum safety standards for underground natural gas storage facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d23f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In developing the safety standards required under subsection (a), the Secretary shall, to the extent practicable—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d240-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider consensus standards for the operation, environmental protection, and integrity management of underground natural gas storage facilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d241-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the economic impacts of the regulations on individual gas customers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d242-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the regulations do not have a significant economic impact on end users; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d243-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consider the recommendations of the Aliso Canyon natural gas leak task force established under section 31 of the PIPES Act of 2016.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d244-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Federal-State Cooperation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may authorize a State authority (including a municipality) to participate in the oversight of underground natural gas storage facilities in the same manner as provided in sections 60105 and 60106.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d245-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules of Construction.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc85d246-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section may be construed to affect any Federal regulation relating to gas pipeline facilities that is in effect on the day before the date of enactment of the PIPES Act of 2016.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc85d247-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Nothing in this section may be construed to authorize the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc85d248-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to prescribe the location of an underground natural gas storage facility; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc85d249-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to require the Secretary’s permission to construct a facility referred to in subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d24a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preemption","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A State authority may adopt additional or more stringent safety standards for intrastate underground natural gas storage facilities if such standards are compatible with the minimum standards prescribed under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc85d24b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s60141/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statutory Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this section shall be construed to affect the Secretary’s authority under this title to regulate the underground storage of gas that is not natural gas.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc85d24c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/183/s12/b"},"text":"Pub. L. 114–183, § 12(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/522"},"text":"130 Stat. 522","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc85d24d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc85d24e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc85d24f-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the PIPES Act of 2016, referred to in subsecs. (a) and (d)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/183"},"text":"Pub. L. 114–183","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 31 of the PIPES Act of 2016, referred to in subsec. (b)(4), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/183/s31"},"text":"section 31 of Pub. L. 114–183","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2016-06-22"},"text":"June 22, 2016","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/130/533"},"text":"130 Stat. 533","children":[],"tail":", which is not classified to the Code."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
