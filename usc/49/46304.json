hildren":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", §§ 901(b), 903(b)(2), (3), "},{"tag":"html:a","attrib":{"href":"/us/stat/72/784"},"text":"72 Stat. 784","children":[],"tail":", 786."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46304(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1473(b)(2).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(b)(1)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Aug. 23, 1958","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/85/726"},"text":"Pub. L. 85–726","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/72/731"},"text":"72 Stat. 731","children":[],"tail":", § 1601(b)(1)(E); added "},{"tag":"html:span","attrib":{},"text":"Oct. 4, 1984","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/98/443/s3/e"},"text":"Pub. L. 98–443, § 3(e)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/98/1704"},"text":"98 Stat. 1704","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Oct. 15, 1966","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/89/670/s6/c/1"},"text":"Pub. L. 89–670, § 6(c)(1)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/80/938"},"text":"80 Stat. 938","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Jan. 12, 1983","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/97/449/s7/b"},"text":"Pub. L. 97–449, § 7(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/96/2444"},"text":"96 Stat. 2444","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"46304(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1473(b)(3).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1551(b)(1)(E).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:1655(c)(1).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the word “civil” is added before “penalty” for consistency in the revised title and with other titles of the United States Code.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsections (b) and (c), the word “Administrator” in section 902(b)(2) and (3) of the Federal Aviation Act of 1958 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/726"},"text":"Public Law 85–726","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/786"},"text":"72 Stat. 786","children":[],"tail":") is retained on authority of 49:106(g). The words “Attorney General” are substituted for “United States attorney for the judicial district in which the seizure is made” and “United States attorney” because of 28:503 and 509."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “report on the seizure” are substituted for “report of the cause” for clarity. The words “bring a civil action in rem” are substituted for “institute proceedings” for clarity and consistency in the revised title and with other titles of the Code and the Federal Rules of Civil Procedure (28 App. U.S.C.). The words “that the action will not be brought” are substituted for “of his failure to so act” for clarity.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c)(3), the words “under a civil action in rem” are substituted for “in pursuance of process of any court in proceedings in rem” to eliminate unnecessary words and for consistency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc3e683f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc3e6840-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" substituted “or the Administrator of the Federal Aviation Administration with respect to aviation safety duties and powers designated to be carried out by the Administrator of the Federal Aviation Administration” for “or the Administrator of the Federal Aviation Administration with respect to aviation safety duties and powers designated to be carried out by the Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" struck out “, (2), or (3)” after “section 46301(a)(1)(A)–(C)”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc3e6841-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc3e6842-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
