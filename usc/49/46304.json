{"tag":"section","attrib":{"id":"idcc3bf732-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46304"},"text":null,"children":[{"tag":"num","attrib":{"value":"46304"},"text":"§ 46304.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Liens on aircraft","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc3bf733-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46304/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Aircraft Subject to Liens","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When an aircraft is involved in a violation referred to in section 46301(a)(1)(A)–(C) of this title and the violation is by the owner of, or individual commanding, the aircraft, the aircraft is subject to a lien for the civil penalty.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc3e6834-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46304/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Seizure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An aircraft subject to a lien under this section may be seized summarily and placed in the custody of a person authorized to take custody of it under regulations of the Secretary of Transportation (or the Administrator of the Federal Aviation Administration with respect to aviation safety duties and powers designated to be carried out by the Administrator of the Federal Aviation Administration). A report on the seizure shall be submitted to the Attorney General. The Attorney General promptly shall bring a civil action in rem to enforce the lien or notify the Secretary or Administrator that the action will not be brought.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc3e6835-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46304/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Release","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An aircraft seized under subsection (b) of this section shall be released from custody when—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc3e6836-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46304/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the civil penalty is paid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e6837-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46304/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a compromise amount agreed on is paid;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e6838-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46304/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the aircraft is seized under a civil action in rem to enforce the lien;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e6839-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46304/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Attorney General gives notice that a civil action will not be brought under subsection (b) of this section; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc3e683a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s46304/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a bond (in an amount and with a surety the Secretary or Administrator prescribes), conditioned on payment of the penalty or compromise, is deposited with the Secretary or Administrator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc3e683b-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1235"},"text":"108 Stat. 1235","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/tV/s503/d/2"},"text":"Pub. L. 108–176, title V, § 503(d)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2559"},"text":"117 Stat. 2559","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/g/2"},"text":"Pub. L. 115–254, div. K, title I, § 1991(g)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/3644"},"text":"132 Stat. 3644","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc3e683c-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc3e683d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc3e683e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html