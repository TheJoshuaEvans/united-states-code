{"tag":"section","attrib":{"id":"idcb16b186-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20158"},"text":null,"children":[{"tag":"num","attrib":{"value":"20158"},"text":"§ 20158.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Railroad safety technology grants","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb16b187-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20158/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Program","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary of Transportation shall establish a grant program for the deployment of train control technologies, train control component technologies, processor-based technologies, electronically controlled pneumatic brakes, rail integrity inspection systems, rail integrity warning systems, switch position indicators and monitors, remote control power switch technologies, track integrity circuit technologies, and other new or novel railroad safety technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb16b188-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20158/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grant Criteria.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb16b189-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20158/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Eligibility","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Grants shall be made under this section to eligible passenger and freight railroad carriers, railroad suppliers, and State and local governments for projects described in subsection (a) that have a public benefit of improved safety and network efficiency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b18a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20158/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Considerations","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Priority shall be given to projects that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb16b18b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20158/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" focus on making technologies interoperable between railroad systems, such as train control technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb16b18c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20158/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accelerate train control technology deployment on high-risk corridors, such as those that have high volumes of hazardous materials shipments or over which commuter or passenger trains operate; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb16b18d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20158/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" benefit both passenger and freight safety and efficiency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b18e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20158/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation plans","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Grants may not be awarded under this section to entities that fail to develop and submit to the Secretary the plans required by sections 20156(e)(2) and 20157.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb16b18f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20158/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Matching requirements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Federal funds for any eligible project under this section shall not exceed 80 percent of the total cost of such project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb16b190-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s20158/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authorization of Appropriations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There are authorized to be appropriated to the Secretary of Transportation $50,000,000 for each of fiscal years 2009 through 2013 to carry out this section. Amounts appropriated pursuant to this section shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb16b191-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/432/dA/tI/s105/a"},"text":"Pub. L. 110–432, div. A, title I, § 105(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-16"},"text":"Oct. 16, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4858"},"text":"122 Stat. 4858","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
