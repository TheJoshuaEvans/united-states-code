{"tag":"section","attrib":{"id":"idcafa0143-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905"},"text":null,"children":[{"tag":"num","attrib":{"value":"13905"},"text":"§ 13905.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effective periods of registration","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcafa0144-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Person Holding ICC Authority","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any person having authority to provide transportation or service as a motor carrier, freight forwarder, or broker under this title, as in effect on ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":", shall be deemed, for purposes of this part, to be registered to provide such transportation or service under this part."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafa0145-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Person Registered With Secretary.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafa0146-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in paragraph (2), any person having registered with the Secretary to provide transportation or service as a motor carrier or motor private carrier under this title, as in effect on ","children":[{"tag":"date","attrib":{"date":"2005-01-01"},"text":"January 1, 2005","children":[],"tail":", but not having registered pursuant to section 13902(a), shall be treated, for purposes of this part, to be registered to provide such transportation or service for purposes of sections 13908 and 14504a."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafa0147-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exclusively intrastate operators","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (1) does not apply to a motor carrier or motor private carrier (including a transporter of waste or recyclable materials) engaged exclusively in intrastate transportation operations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafa0148-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective Period.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafa0149-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this part, each registration issued under section 13902, 13903, or 13904—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcafa014a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be effective beginning on the date specified by the Secretary; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcafa014b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall remain in effect for such period as the Secretary determines appropriate by regulation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafa014c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reissuance of registration.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcafa014d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 4 years after the date of enactment of the Commercial Motor Vehicle Safety Enhancement Act of 2012, the Secretary shall require a freight forwarder or broker to renew its registration issued under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcafa014e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Effective period","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each registration renewal under subparagraph (A)—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcafa014f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/c/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall expire not later than 5 years after the date of such renewal; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcafa0150-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/c/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be further renewed as provided under this chapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafa0151-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Suspension, Amendments, and Revocations.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafa0152-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"On application of the registrant, the Secretary may amend or revoke a registration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafa0153-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Complaints and actions on secretary’s own initiative","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"On complaint or on the Secretary’s own initiative and after notice and an opportunity for a proceeding, the Secretary may—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcafa0154-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" suspend, amend, or revoke any part of the registration of a motor carrier, foreign motor carrier, foreign motor private carrier, broker, or freight forwarder for willful failure to comply with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcafa0155-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcafa0156-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable regulation or order of the Secretary or the Board, including the accessibility requirements established by the Secretary under subpart H of part 37 of title 49, Code of Federal Regulations (or successor regulations), for transportation provided by an over-the-road bus; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcafa0157-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a condition of its registration;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcafa0158-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" withhold, suspend, amend, or revoke any part of the registration of a motor carrier, foreign motor carrier, foreign motor private carrier, broker, or freight forwarder for failure—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcafa0159-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to pay a civil penalty imposed under chapter 5, 51, 149, or 311;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcafa015a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to arrange and abide by an acceptable payment plan for such civil penalty, not later than 90 days after the date specified by order of the Secretary for the payment of such penalty; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcafa015b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for failure ","children":[{"tag":"ref","attrib":{"idref":"fn002053"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002053"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. The words “for failure” probably should not appear."}],"tail":" to obey a subpoena issued by the Secretary;"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcafa015c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" withhold, suspend, amend, or revoke any part of a registration of a motor carrier, foreign motor carrier, foreign motor private carrier, broker, or freight forwarder following a determination by the Secretary that the motor carrier, broker, or freight forwarder failed to disclose, in its application for registration, a material fact relevant to its willingness and ability to comply with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"idcafa015d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" this part;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcafa015e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an applicable regulation or order of the Secretary or the Board; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"idcafa015f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a condition of its registration; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcafa0160-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" withhold, suspend, amend, or revoke any part of a registration of a motor carrier, foreign motor carrier, foreign motor private carrier, broker, or freight forwarder if the Secretary finds that the motor carrier, broker, or freight forwarder does not disclose any relationship through common ownership, common management, common control, or common familial relationship to any other motor carrier, broker, or freight forwarder, or any other applicant for motor carrier, broker, or freight forwarder registration that the Secretary determines is or was unwilling or unable to comply with the relevant requirements listed in section 13902, 13903, or 13904.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafa0161-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Paragraph (2)(B) shall not apply to a person who is unable to pay a civil penalty because the person is a debtor in a case under chapter 11 of title 11.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafa0162-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 12 months after the date of the enactment of this paragraph, the Secretary, after notice and opportunity for public comment, shall issue regulations to provide for the suspension, amendment, or revocation of a registration under this part for failure to pay a civil penalty as provided in paragraph (2)(B).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafa0163-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Procedure","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except on application of the registrant, or if the Secretary determines that the registrant failed to disclose a material fact in an application for registration in accordance with subsection (d)(2)(C), the Secretary may revoke a registration of a motor carrier, freight forwarder, or broker, only after—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafa0164-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has issued an order to the registrant under section 14701 requiring compliance with this part, a regulation of the Secretary, or a condition of the registration; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafa0165-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the registrant willfully does not comply with the order for a period of 30 days.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafa0166-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Expedited Procedure.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcafa0167-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection of safety","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Notwithstanding subchapter II of chapter 5 of title 5, the Secretary—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcafa0168-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may suspend the registration of a motor carrier, a freight forwarder, or a broker for failure to comply with requirements of the Secretary pursuant to section 13904(e) or 13906 or an order or regulation of the Secretary prescribed under those sections; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcafa0169-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall revoke the registration of a motor carrier that has been prohibited from operating in interstate commerce for failure to comply with the safety fitness requirements of section 31144.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafa016a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Imminent hazard to public health","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subchapter II of chapter 5 of title 5, the Secretary shall revoke the registration of a motor carrier if the Secretary finds that the carrier is or was conducting unsafe operations that are or were an imminent hazard to public health or property.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcafa016b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice; period of suspension","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may suspend or revoke under this subsection the registration only after giving notice of the suspension or revocation to the registrant. A suspension remains in effect until the registrant complies with the applicable sections or, in the case of a suspension under paragraph (2), until the Secretary revokes the suspension.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcafa016c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s13905/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mexico-Domiciled Motor Carriers","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding any other provision of this section, upon an order in accordance with section 324(a) of the United States-Mexico-Canada Agreement Implementation Act, the Secretary shall carry out the relief specified by revoking or imposing limitations on existing registrations of Mexico-domiciled motor carriers of cargo to operate beyond the municipalities along the United States-Mexico international border and the commercial zones of those municipalities as directed.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcafa016d-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s103"},"text":"Pub. L. 104–88, title I, § 103","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/884"},"text":"109 Stat. 884","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/287/s5/33"},"text":"Pub. L. 104–287, § 5(33)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-10-11"},"text":"Oct. 11, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/3392"},"text":"110 Stat. 3392","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/102/s2/10"},"text":"Pub. L. 105–102, § 2(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-20"},"text":"Nov. 20, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/2204"},"text":"111 Stat. 2204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/159/tII/s206/a"},"text":"Pub. L. 106–159, title II, § 206(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1763"},"text":"113 Stat. 1763","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/tIV"},"text":"Pub. L. 109–59, title IV","children":[],"tail":", §§ 4104, 4303(a), "},{"tag":"date","attrib":{"date":"2005-08-10"},"text":"Aug. 10, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/1716"},"text":"119 Stat. 1716","children":[],"tail":", 1761; "},{"tag":"ref","attrib":{"href":"/us/pl/110/291/s2/b"},"text":"Pub. L. 110–291, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-30"},"text":"July 30, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/2915"},"text":"122 Stat. 2915","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/dC/tII"},"text":"Pub. L. 112–141, div. C, title II","children":[],"tail":", §§ 32103(a), 32109, 32205, 32917, 32933(a), "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/778"},"text":"126 Stat. 778","children":[],"tail":", 782, 785, 821, 830; "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/dA/tV/s5508/a/3"},"text":"Pub. L. 114–94, div. A, title V, § 5508(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-04"},"text":"Dec. 4, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/1554"},"text":"129 Stat. 1554","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/113/tIII/s326/b"},"text":"Pub. L. 116–113, title III, § 326(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2020-01-29"},"text":"Jan. 29, 2020","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/60"},"text":"134 Stat. 60","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcafa016e-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcafa016f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcafa0170-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:13905(a) for clarity and consistency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcafa0171-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":null}],"tail":null},{"tag":"p","attrib":{},"text":"This amends 49:13905(e)(1) to correct a grammatical error.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcafa0172-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcafa0173-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of the Commercial Motor Vehicle Safety Enhancement Act of 2012, referred to in subsec. (c)(2)(A), is the date of enactment of title II of div. C of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of the enactment of this paragraph, referred to in subsec. (d)(4), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159"},"text":"Pub. L. 106–159","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"1999-12-09"},"text":"Dec. 9, 1999","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 324(a) of the United States-Mexico-Canada Agreement Implementation Act, referred to in subsec. (g), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t19/s4574/a"},"text":"section 4574(a) of Title 19","children":[],"tail":", Customs Duties."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcafa0174-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2020—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/113"},"text":"Pub. L. 116–113","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2015—Subsec. (d)(2)(D). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" substituted “the Secretary finds that” for “the Secretary finds that—”, struck out cl. (i) designation before “the motor carrier,”, and inserted period at end."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32917"},"text":"Pub. L. 112–141, § 32917","children":[],"tail":", amended subsec. (c) generally. Prior to amendment, text read as follows: “Except as otherwise provided in this part, each registration issued under section 13902, 13903, or 13904 shall be effective from the date specified by the Secretary and shall remain in effect for such period as the Secretary determines appropriate by regulation.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32103/a/1/B"},"text":"Pub. L. 112–141, § 32103(a)(1)(B)","children":[],"tail":", added par. (1) and struck out former par. (1) which authorized the Secretary to amend or revoke a registration upon application, or suspend, amend or revoke a registration upon complaint or the Secretary’s own initiative after notice and opportunity for a proceeding."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32205"},"text":"Pub. L. 112–141, § 32205","children":[],"tail":", inserted “foreign motor carrier, foreign motor private carrier,” after “registration of a motor carrier,” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32103/a/1/B"},"text":"Pub. L. 112–141, § 32103(a)(1)(B)","children":[],"tail":", added par. (2). Former par. (2) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32103/a/1/B"},"text":"Pub. L. 112–141, § 32103(a)(1)(B)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32103/a/1/C"},"text":"Pub. L. 112–141, § 32103(a)(1)(C)","children":[],"tail":", substituted “paragraph (2)(B)” for “paragraph (1)(B)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32103/a/1/A"},"text":"Pub. L. 112–141, § 32103(a)(1)(A)","children":[],"tail":", redesignated par. (2) as (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32103/a/2"},"text":"Pub. L. 112–141, § 32103(a)(2)","children":[],"tail":", inserted “or if the Secretary determines that the registrant failed to disclose a material fact in an application for registration in accordance with subsection (d)(2)(C),” after “registrant,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32933/a"},"text":"Pub. L. 112–141, § 32933(a)","children":[],"tail":", substituted “section 13904(e)” for “section 13904(c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/s32109"},"text":"Pub. L. 112–141, § 32109","children":[],"tail":", amended par. (2) generally. Prior to amendment, text read as follows: “Without regard to subchapter II of chapter 5 of title 5, the Secretary shall revoke the registration of a motor carrier of passengers if the Secretary finds that such carrier has been conducting unsafe operations which are an imminent hazard to public health or property.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2008—Subsec. (d)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/291"},"text":"Pub. L. 110–291","children":[],"tail":" inserted “(including the accessibility requirements established by the Secretary under subpart H of part 37 of title 49, Code of Federal Regulations, or such successor regulations to those accessibility requirements as the Secretary may issue, for transportation provided by an over-the-road bus)” after “Board”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2005—Subsecs. (b) to (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4303/a"},"text":"Pub. L. 109–59, § 4303(a)","children":[],"tail":", added subsec. (b) and redesignated former subsecs. (b) and (c) as (c) and (d), respectively. Former subsec. (d) redesignated (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4303/a/1"},"text":"Pub. L. 109–59, § 4303(a)(1)","children":[],"tail":", redesignated subsec. (d) as (e). Former subsec. (e) redesignated (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4104/1"},"text":"Pub. L. 109–59, § 4104(1)","children":[],"tail":", added par. (1) and struck out heading and text of former par. (1). Text read as follows: “Without regard to subchapter II of chapter 5 of title 5, the Secretary may suspend the registration of a motor carrier, a freight forwarder, or a broker for failure to comply with safety requirements of the Secretary or the safety fitness requirements pursuant to section 13904(c), 13906, or 31144 of this title, or an order or regulation of the Secretary prescribed under those sections.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4104/2"},"text":"Pub. L. 109–59, § 4104(2)","children":[],"tail":", substituted “shall revoke the registration” for “may suspend a registration”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4104/3"},"text":"Pub. L. 109–59, § 4104(3)","children":[],"tail":", added par. (3) and struck out heading and text of former par. (3). Text read as follows: “The Secretary may suspend under this subsection the registration only after giving notice of the suspension to the registrant. The suspension remains in effect until the registrant complies with those applicable sections or, in the case of a suspension under paragraph (2), until the Secretary revokes such suspension.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4303/a/1"},"text":"Pub. L. 109–59, § 4303(a)(1)","children":[],"tail":", redesignated subsec. (e) as (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/159"},"text":"Pub. L. 106–159","children":[],"tail":" inserted par. (1) designation and heading, inserted “(A)” before “suspend”, added cl. (B), realigned par. (1) margins, and added par. (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1997—Subsec. (e)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/105/102"},"text":"Pub. L. 105–102","children":[],"tail":" struck out comma after “31144”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/287"},"text":"Pub. L. 104–287","children":[],"tail":" substituted “"},{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":"” for “the day before the effective date of this section”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcafc7275-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcafc7276-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2015 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/94"},"text":"Pub. L. 114–94","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2015-10-01"},"text":"Oct. 1, 2015","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/114/94/s1003"},"text":"section 1003 of Pub. L. 114–94","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s5313"},"text":"section 5313 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcafc7277-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2012 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141"},"text":"Pub. L. 112–141","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcafc7278-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1996-01-01"},"text":"Jan. 1, 1996","children":[],"tail":", except as otherwise provided in "},{"tag":"ref","attrib":{"href":"/us/pl/104/88"},"text":"Pub. L. 104–88","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/88/s2"},"text":"section 2 of Pub. L. 104–88","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s1301"},"text":"section 1301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcafc7279-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Relationship to Other Laws","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Except as provided in sections 14504, 14504a, and 14506 of this title, subtitle C (§§ 4301–4308) of title IV of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/59"},"text":"Pub. L. 109–59","children":[],"tail":" is not intended to prohibit any State or any political subdivision of any State from enacting, imposing, or enforcing any law or regulation with respect to a motor carrier, motor private carrier, broker, freight forwarder, or leasing company that is not otherwise prohibited by law, see "},{"tag":"ref","attrib":{"href":"/us/pl/109/59/s4302"},"text":"section 4302 of Pub. L. 109–59","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s13902"},"text":"section 13902 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
