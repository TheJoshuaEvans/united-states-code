{"tag":"section","attrib":{"id":"idcae9604b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s11161"},"text":null,"children":[{"tag":"num","attrib":{"value":"11161"},"text":"§ 11161.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Implementation of cost accounting principles","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Board shall periodically review its cost accounting rules and shall make such changes in those rules as are required to achieve the regulatory purposes of this part. The Board shall insure that the rules promulgated under this section are the most efficient and least burdensome means by which the required information may be developed for regulatory purposes. To the maximum extent practicable, the Board shall conform such rules to generally accepted accounting principles.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcae9604c-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/88/tI/s102/a"},"text":"Pub. L. 104–88, title I, § 102(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-12-29"},"text":"Dec. 29, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/835"},"text":"109 Stat. 835","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcae9604d-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcae9604e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"idcae9604f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"