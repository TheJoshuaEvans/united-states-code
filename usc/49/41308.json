{"tag":"section","attrib":{"id":"idcbbd9fcf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41308"},"text":null,"children":[{"tag":"num","attrib":{"value":"41308"},"text":"§ 41308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exemption from the antitrust laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbbd9fd0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41308/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In this section, “antitrust laws” has the same meaning given that term in the first section of the Clayton Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s12"},"text":"15 U.S.C. 12","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbd9fd1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41308/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption Authorized","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"When the Secretary of Transportation decides it is required by the public interest, the Secretary, as part of an order under section 41309 or 42111 of this title, may exempt a person affected by the order from the antitrust laws to the extent necessary to allow the person to proceed with the transaction specifically approved by the order and with any transaction necessarily contemplated by the order.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbd9fd2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41308/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Exemption Required","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In an order under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41309"},"text":"section 41309 of this title","children":[],"tail":" approving an agreement, request, modification, or cancellation, the Secretary, on the basis of the findings required under section 41309(b)(1), shall exempt a person affected by the order from the antitrust laws to the extent necessary to allow the person to proceed with the transaction specifically approved by the order and with any transaction necessarily contemplated by the order."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbbd9fd3-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1128"},"text":"108 Stat. 1128","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbbd9fd4-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcbbd9fd5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcbbd9fd6-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children"