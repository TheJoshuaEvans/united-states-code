:{},"text":"The words “In developing the guidelines” are substituted for “In developing airport construction guidelines under subsection (d) of section 612 of the Federal Aviation Act of 1958, as added by section 110 of this Act” in section 106(f) of the Aviation Security Improvement Act of 1990 (","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/604"},"text":"Public Law 101–604","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/3075"},"text":"104 Stat. 3075","children":[],"tail":") to eliminate unnecessary words."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc28e49e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc28e49f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2018—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254"},"text":"Pub. L. 115–254","children":[],"tail":" substituted “with the Department of Transportation, air carriers, airport authorities, and others the Administrator of the Transportation Security Administration” for “with air carriers, airport authorities, and others the Under Secretary of Transportation for Security” and, in two places, “Administrator” for “Under Secretary”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71"},"text":"Pub. L. 107–71","children":[],"tail":" substituted “Under Secretary” for “Administrator” wherever appearing and “of Transportation for Security” for “of the Federal Aviation Administration”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
