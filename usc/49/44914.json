{"tag":"section","attrib":{"id":"idcc28e499-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s44914"},"text":null,"children":[{"tag":"num","attrib":{"value":"44914"},"text":"§ 44914.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Airport construction guidelines","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In consultation with the Department of Transportation, air carriers, airport authorities, and others the Administrator of the Transportation Security Administration considers appropriate, the Administrator shall develop guidelines for airport design and construction to allow for maximum security enhancement. In developing the guidelines, the Administrator shall consider the results of the assessment carried out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s44904/a"},"text":"section 44904(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idcc28e49a-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1214"},"text":"108 Stat. 1214","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/71/tI/s101/f/7"},"text":"Pub. L. 107–71, title I, § 101(f)(7)","children":[],"tail":", (9), "},{"tag":"date","attrib":{"date":"2001-11-19"},"text":"Nov. 19, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/603"},"text":"115 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/254/dK/tI/s1991/d/12"},"text":"Pub. L. 115–254, div. K, title I, § 1991(d)(12)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-10-05"},"text":"Oct. 5, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/