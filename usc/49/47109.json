s/pl/100/223/s111/a/2"},"text":"Pub. L. 100–223, § 111(a)(2)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/101/1503"},"text":"101 Stat. 1503","children":[],"tail":"; "},{"tag":"html:span","attrib":{},"text":"Oct. 31, 1992","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/102/581/s110/b"},"text":"Pub. L. 102–581, § 110(b)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/106/4880"},"text":"106 Stat. 4880","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), before clause (1), the words “Except as provided in subsections (b) and (c) of this section” are substituted for “Except as otherwise provided in this chapter” because subsections (b) and (c) restate the only parts of the chapter that provide exceptions to the general rule stated in subsection (a). In clauses (1) and (2), the words “for a project” are substituted for “payable on account of any project contained in an approved project grant application submitted in accordance with this chapter” in 49 App.:2209(a) and “payable on account of any project contained in an approved project grant application” in 49 App.:2209(b) for consistency in this chapter and to eliminate unnecessary words. A project cost is allowable only if it is incurred under a grant agreement made under the chapter, and a grant agreement may be made only if the project grant application is approved. In clause (1), the words “number of passenger boardings” are substituted for “enplaning . . . of the . . . passengers enplaned” because of the definition of “passenger boardings” in section 47102 of the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “If, under subsection (a) of this section, the Government’s share of allowable costs . . . is less than the share applied on ","children":[{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", under section 17(b) of the Airport and Airway Development Act of 1970” and “(3) the percentage necessary to increase the Government’s share to the percentage that applied on "},{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", under section 17(b) of the Act” are substituted for 49 App.:2209(c) (last sentence) for clarity. The words “of the total of all lands therein” are omitted as surplus."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), the words “Notwithstanding subsections (a) and (b) of this section” are substituted for “Notwithstanding any other provision of this chapter” because subsections (a) and (b) are the only other parts of the chapter that specify the United States Government’s share of allowable project costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcc4f0a4a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcc4f0a4b-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 17(b) of the Airport and Airway Development Act of 1970, referred to in subsec. (b), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/91/258/s17/b"},"text":"section 17(b) of Pub. L. 91–258","children":[],"tail":", which was classified to section 1717(b) of former Title 49, Transportation, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/97/248/tV/s523/a"},"text":"Pub. L. 97–248, title V, § 523(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-09-03"},"text":"Sept. 3, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/695"},"text":"96 Stat. 695","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The date of enactment of this subsection, referred to in subsec. (g)(3)(B), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/254"},"text":"Pub. L. 117–254","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-12-20"},"text":"Dec. 20, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idcc4f0a4c-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—Subsec. (i). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/119/60"},"text":"Pub. L. 119–60","children":[],"tail":" added subsec. (i)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2024—Subsec. (h). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":" added subsec. (h)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2022—Subsec. (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/254"},"text":"Pub. L. 117–254","children":[],"tail":" added subsec. (g)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2018—Subsec. (a)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s134/1"},"text":"Pub. L. 115–254, § 134(1)","children":[],"tail":", substituted “medium or large hub airport;” for “primary airport having at least .25 percent of the total number of passenger boardings each year at all commercial service airports;”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/254/s134/2"},"text":"Pub. L. 115–254, § 134(2)","children":[],"tail":", added par. (5) and struck out former par. (5) which read as follows: “for fiscal year 2002, 100 percent for a project described in section 47102(3)(J), 47102(3)(K), or 47102(3)(L).”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2017—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/31"},"text":"Pub. L. 115–31","children":[],"tail":" amended par. (2) generally. Prior to amendment, text read as follows: “The Government’s share of allowable project costs determined under this subsection shall not exceed the lesser of 93.75 percent or the highest percentage Government share applicable to any project in any State under subsection (b), except that at a primary non-hub airport located in a State as set forth in paragraph (1) of this subsection that is within 15 miles of another State as set forth in paragraph (1) of this subsection, the Government’s share shall be an average of the Government share applicable to any project in each of the States.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" inserted before period at end “, except that at a primary non-hub airport located in a State as set forth in paragraph (1) of this subsection that is within 15 miles of another State as set forth in paragraph (1) of this subsection, the Government’s share shall be an average of the Government share applicable to any project in each of the States”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2012—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s137/1"},"text":"Pub. L. 112–95, § 137(1)","children":[],"tail":", substituted “otherwise provided in this section” for “provided in subsection (b) or subsection (c) of this section” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (e), (f). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/95/s137/2"},"text":"Pub. L. 112–95, § 137(2)","children":[],"tail":", added subsecs. (e) and (f)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2003—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/s162/b"},"text":"Pub. L. 108–176, § 162(b)","children":[],"tail":", substituted “Except as provided in subsection (b) or subsection (c)” for “Except as provided in subsection (b)” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/s163"},"text":"Pub. L. 108–176, § 163","children":[],"tail":", substituted “70 percent” for “40 percent”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (c), (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/s162/a"},"text":"Pub. L. 108–176, § 162(a)","children":[],"tail":", added subsec. (c) and redesignated former subsec. (c) as (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2001—Subsec. (a)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/71"},"text":"Pub. L. 107–71","children":[],"tail":" added par. (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2000—Subsec. (a)(2) to (4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181"},"text":"Pub. L. 106–181","children":[],"tail":" added par. (2) and redesignated former pars. (2) and (3) as (3) and (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (a)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264/s149/c"},"text":"Pub. L. 104–264, § 149(c)","children":[],"tail":", added par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/264/s1211"},"text":"Pub. L. 104–264, § 1211","children":[],"tail":", added subsec. (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1994—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/s114/1"},"text":"Pub. L. 103–305, § 114(1)","children":[],"tail":", substituted “subsection (b)” for “subsections (b) and (c)”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/305/s114/2"},"text":"Pub. L. 103–305, § 114(2)","children":[],"tail":", struck out subsec. (c) which read as follows: “(c) "},{"tag":"inline","attrib":{},"text":"Limitation","children":[],"tail":".—Notwithstanding subsections (a) and (b) of this section, the Government’s share of project costs allowable under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s47110/d"},"text":"section 47110(d) of this title","children":[],"tail":" may not be more than 75 percent, except that the Government’s share shall be 85 percent for a project at a commercial service airport that does not have more than .05 percent of the total annual passenger boardings in the United States.”"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc4f0a4d-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc4f0a4e-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2003 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176"},"text":"Pub. L. 108–176","children":[],"tail":" applicable only to fiscal years beginning after "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", except as otherwise specifically provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/108/176/s3"},"text":"section 3 of Pub. L. 108–176","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t49/s106"},"text":"section 106 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"idcc4f0a4f-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],