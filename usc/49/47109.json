{"tag":"section","attrib":{"id":"idcc4f0a27-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109"},"text":null,"children":[{"tag":"num","attrib":{"value":"47109"},"text":"§ 47109.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Government’s share of project costs","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc4f0a28-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Except as otherwise provided in this section, the United States Government’s share of allowable project costs is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc4f0a29-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 75 percent for a project at a medium or large hub airport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc4f0a2a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not more than 90 percent for a project funded by a grant issued to and administered by a State under section 47128, relating to the State block grant program;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc4f0a2b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 90 percent for a project at any other airport;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc4f0a2c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 70 percent for a project funded by the Administrator from the discretionary fund under section 47115 at an airport receiving an exemption under section 47134; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc4f0a2d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" 95 percent for a project that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc4f0a2e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/a/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Administrator determines is a successive phase of a multiphase construction project for which the sponsor received a grant in fiscal year 2011; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc4f0a2f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/a/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for which the United States Government’s share of allowable project costs would otherwise be capped at 90 percent under paragraph (2) or (3).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc4f0a30-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Increased Government Share","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"If, under subsection (a) of this section, the Government’s share of allowable costs of a project in a State containing unappropriated and unreserved public lands and nontaxable Indian lands (individual and tribal) of more than 5 percent of the total area of all lands in the State, is less than the share applied on ","children":[{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", under section 17(b) of the Airport and Airway Development Act of 1970, the Government’s share under subsection (a) of this section shall be increased by the lesser of—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc4f0a31-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 25 percent;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc4f0a32-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one-half of the percentage that the area of unappropriated and unreserved public lands and nontaxable Indian lands in the State is of the total area of the State; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc4f0a33-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the percentage necessary to increase the Government’s share to the percentage that applied on ","children":[{"tag":"date","attrib":{"date":"1975-06-30"},"text":"June 30, 1975","children":[],"tail":", under section 17(b) of the Act."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc4f0a34-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Grandfather Rule.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc4f0a35-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of any project approved after ","children":[{"tag":"date","attrib":{"date":"2003-09-30"},"text":"September 30, 2003","children":[],"tail":", at a small hub airport or nonhub airport that is located in a State containing unappropriated and unreserved public lands and nontaxable Indian lands (individual and tribal) of more than 5 percent of the total area of all lands in the State, the Government’s share of allowable costs of the project shall be increased by the same ratio as the basic share of allowable costs of a project divided into the increased (Public Lands States) share of allowable costs of a project as shown on documents of the Federal Aviation Administration dated "},{"tag":"date","attrib":{"date":"1979-08-03"},"text":"August 3, 1979","children":[],"tail":", at airports for which the general share was 80 percent on "},{"tag":"date","attrib":{"date":"1979-08-03"},"text":"August 3, 1979","children":[],"tail":". This subsection shall apply only if—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc4f0a36-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the State contained unappropriated and unreserved public lands and nontaxable Indian lands of more than 5 percent of the total area of all lands in the State on ","children":[{"tag":"date","attrib":{"date":"1979-08-03"},"text":"August 3, 1979","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc4f0a37-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the application under subsection (b), does not increase the Government’s share of allowable costs of the project.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc4f0a38-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Government’s share of allowable project costs determined under this subsection shall not exceed the lesser of 93.75 percent or the highest percentage Government share applicable to any project in any State under subsection (b), except that at a primary non-hub and non-primary commercial service airport located in a State as set forth in paragraph (1) of this subsection that is within 15 miles of another State as set forth in paragraph (1) of this subsection, the Government’s share shall be an average of the Government share applicable to any project in each of the States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc4f0a39-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule for Privately Owned Reliever Airports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If a privately owned reliever airport contributes any lands, easements, or rights-of-way to carry out a project under this subchapter, the current fair market value of such lands, easements, or rights-of-way shall be credited toward the non-Federal share of allowable project costs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc4f0a3a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule for Transition From Small Hub to Medium Hub Status","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the status of a small hub airport changes to a medium hub airport, the Government’s share of allowable project costs for the airport may not exceed 90 percent for the first 2 fiscal years after such change in hub status.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc4f0a3b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule for Economically Distressed Communities","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Government’s share of allowable project costs shall be 95 percent for a project at an airport that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc4f0a3c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is receiving essential air service for which compensation was provided to an air carrier under subchapter II of chapter 417; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc4f0a3d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is located in an area that meets one or more of the criteria established in section 301(a) of the Public Works and Economic Development Act of 1965 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s3161/a"},"text":"42 U.S.C. 3161(a)","children":[],"tail":"), as determined by the Secretary of Commerce."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc4f0a3e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule for Covered Equipment.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc4f0a3f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Government’s share of allowable project costs for covered equipment and its installation shall be 100 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc4f0a40-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definition of covered equipment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of this subsection, the term “covered equipment” means aqueous film forming foam input-based testing equipment that is eligible for Airport Improvement Program funding based on Federal Aviation Administration PGL 21–01, titled “Extension of Eligibility for stand-alone acquisition of input-based testing equipment and truck modification”, dated ","children":[{"tag":"date","attrib":{"date":"2021-10-05"},"text":"October 5, 2021","children":[],"tail":" (or any other successor program guidance letter)."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc4f0a41-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sunset","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The higher cost share authority established in this subsection shall terminate on the earlier of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcc4f0a42-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/g/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 180 days after the date on which the eligibility of covered equipment for Airport Improvement Program funding under the authority described in paragraph (2) terminates or is discontinued by the Administrator; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcc4f0a43-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/g/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" 5 years after the date of enactment of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc4f0a44-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule for Fiscal Years","children":[],"tail":" 2025 "},{"tag":"inline","attrib":{},"text":"and","children":[],"tail":" 2026.—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding subsection (a), the Government’s share of allowable project costs for a grant made to a nonhub or nonprimary airport in each of fiscal years 2025 and 2026 shall be 95 percent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc4f0a45-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47109/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Special Rule for Sound Insulation Repair and Replacement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"With respect to a project to carry out sound insulation that is granted a waiver under section 47110(j), the allowable project cost for such project shall be calculated without consideration of any costs that were previously paid by the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc4f0a46-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1264"},"text":"108 Stat. 1264","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/103/305/tI/s114"},"text":"Pub. L. 103–305, title I, § 114","children":[],"tail":", "},{"tag":"date","attrib":{"d