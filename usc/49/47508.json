{"tag":"section","attrib":{"id":"idcc66d82e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47508"},"text":null,"children":[{"tag":"num","attrib":{"value":"47508"},"text":"§ 47508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Noise standards for air carriers and foreign air carriers providing foreign air transportation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcc66d82f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47508/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General Requirements","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary of Transportation shall require each air carrier and foreign air carrier providing foreign air transportation to comply with noise standards—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcc66d830-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47508/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary prescribed for new subsonic aircraft in regulations of the Secretary in effect on ","children":[{"tag":"date","attrib":{"date":"1977-01-01"},"text":"January 1, 1977","children":[],"tail":"; or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcc66d831-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47508/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" of the International Civil Aviation Organization that are substantially compatible with standards of the Secretary for new subsonic aircraft in regulations of the Secretary at parts 36 and 91 of title 14, Code of Federal Regulations, prescribed between ","children":[{"tag":"date","attrib":{"date":"1977-01-02"},"text":"January 2, 1977","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1982-01-01"},"text":"January 1, 1982","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc66d832-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47508/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance at Phased Rate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall require each air carrier and foreign air carrier providing foreign air transportation to comply with the noise standards at a phased rate similar to the rate for aircraft registered in the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcc66d833-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s47508/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Nondiscrimination","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The requirement for air carriers providing foreign air transportation may not be more stringent than the requirement for foreign air carriers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcc66d834-47c4-11f1-9671-b5c725212f70"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/272/s1/e"},"text":"Pub. L. 103–272, § 1(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1994-07-05"},"text":"July 5, 1994","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/108/1287"},"text":"108 Stat. 1287","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcc66d835-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"idcc66d836-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"idcc66d837-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47508(a)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2122(a) (1st sentence words before last comma, last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Feb. 18, 1980","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/pl/96/193/s302/a"},"text":"Pub. L. 96–193, § 302(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/94/56"},"text":"94 Stat. 56","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47508(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2122(a) (1st sentence words after last comma).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"47508(c)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"49 App.:2122(a) (2d sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In this section, the word “providing” is substituted for “engaging in” for consistency in the revised title.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “acting through the Administrator” and “acting through the Administrator of the Federal Aviation Administration (14 CFR part 36)” are omitted for consistency. Section 6(c)(1) of the Department of Transportation Act (","children":[{"tag":"ref","attrib":{"href":"/us/pl/89/670"},"text":"Public Law 89–670","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/80/938"},"text":"80 Stat. 938","children":[],"tail":") transferred all duties and powers of the Federal Aviation Agency and the Administrator to the Secretary of Transportation. However, the Secretary was to carry out certain provisions through the Administrator. In addition, various laws enacted since then have vested duties and powers in the Administrator. All provisions of law the Secretary is required to carry out through the Administrator are included in 49:106(g). Before clause (1), the words “If, by "},{"tag":"date","attrib":{"date":"1980-01-01"},"text":"January 1, 1980","children":[],"tail":", the International Civil Aviation Organization (hereafter referred to as ‘ICAO’) does not reach an agreement” and “commence a rulemaking to” and 49 App.:2122(a) (last sentence) are omitted as executed. In clause (1), the words “as such regulations were” are omitted as surplus. In clause (2), the words “on noise standards and an international schedule” and “(annex 16)” are omitted as surplus. The words “of the Secretary for new subsonic aircraft in regulations of the Secretary at parts 36 and 91 of title 14, Code of Federal Regulations, prescribed between "},{"tag":"date","attrib":{"date":"1977-01-02"},"text":"January 2, 1977","children":[],"tail":", and "},{"tag":"date","attrib":{"date":"1982-01-01"},"text":"January 1, 1982","children":[],"tail":"” are substituted for “set forth in such regulations issued by the Secretary (14 CFR parts 36 and 91) during the 5-year period thereafter” for clarity and consistency."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “in effect” are omitted as surplus.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcc66d838-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc66d839-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Implementation of Chapter 4 Noise Standards","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/108/176/tIII/s325"},"text":"Pub. L. 108–176, title III, § 325","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-12-12"},"text":"Dec. 12, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/2542"},"text":"117 Stat. 2542","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/176/tIII/s325"},"text":"“Not later than ","children":[{"tag":"date","attrib":{"date":"2005-04-01"},"text":"April 1, 2005","children":[],"tail":", the Secretary of Transportation shall issue final regulations to implement Chapter 4 noise standards, consistent with the recommendations adopted by the International Civil Aviation Organization.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc66d83a-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Standards for Aircraft and Aircraft Engines To Reduce Noise Levels","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/181/tVII/s726"},"text":"Pub. L. 106–181, title VII, § 726","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-04-05"},"text":"Apr. 5, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/167"},"text":"114 Stat. 167","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/188/tXV/s1501/f"},"text":"Pub. L. 113–188, title XV, § 1501(f)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2025"},"text":"128 Stat. 2025","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/188/tXV/s1501/f"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Development of New Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary [of Transportation] shall continue to work to develop through the International Civil Aviation Organization new performance standards for aircraft and aircraft engines that will lead to a further reduction in aircraft noise levels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goals To Be Considered in Developing New Standards","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In negotiating standards under subsection (a), the Secretary shall give high priority to developing standards that—","children":[],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are performance based and can be achieved by use of a full range of certifiable noise reduction technologies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the useful economic value of existing Stage 3 aircraft in the United States fleet;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"“(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that United States air carriers and aircraft engine and hushkit manufacturers are not competitively disadvantaged;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"“(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use dynamic economic modeling capable of determining impacts on all aircraft in service in the United States fleet; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"“(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continue the use of a balanced approach to address aircraft environmental issues, taking into account aircraft technology, land use planning, economic feasibility, and airspace operational improvements.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"idcc66d83b-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Aircraft Noise Research Program","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/102/581/tIII/s304"},"text":"Pub. L. 102–581, title III, § 304","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1992-10-31"},"text":"Oct. 31, 1992","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/106/4896"},"text":"106 Stat. 4896","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/109/155/tVII/s706/b"},"text":"Pub. L. 109–155, title VII, § 706(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2005-12-30"},"text":"Dec. 30, 2005","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/2937"},"text":"119 Stat. 2937","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/109/155/tVII/s706/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Federal Aviation Administration and the Administrator of the National Aeronautics and Space Administration shall jointly conduct a research program to develop new technologies for quieter subsonic jet aircraft engines and airframes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Goal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The goal of the research program established by subsection (a) is to develop by the year 2010 technologies for subsonic jet aircraft engines and airframes which would permit a subsonic jet aircraft to operate at reduced noise levels.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Participation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In carrying out the program established by subsection (a), the Administrator of the Federal Aviation Administration and the Administrator of the National Aeronautics and Space Administration shall encourage the participation of representatives of the aviation industry and academia.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Administrator of the Federal Aviation Administration and the Administrator of the National Aeronautics and Space Administration shall jointly submit to Congress, on an annual basis during the term of the program established by subsection (a), a report on the progress being made under the program toward meeting the goal described in subsection (b).”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
