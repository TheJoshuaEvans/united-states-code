{"tag":"section","attrib":{"id":"idcbbb2eac-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41305"},"text":null,"children":[{"tag":"num","attrib":{"value":"41305"},"text":"§ 41305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Applications for permits","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbbb2ead-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Form, Contents, Notice, Response, and Actions on Applications","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbbb2eae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A person must apply in writing to the Secretary of Transportation to be issued a permit under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t49/s41302"},"text":"section 41302 of this title","children":[],"tail":". The Secretary shall prescribe regulations to require that the application be—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbbb2eaf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41305/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" verified;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbb2eb0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41305/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in a certain form and contain certain information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbb2eb1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41305/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" served on interested persons; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbbb2eb2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41305/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accompanied by proof of service on those persons.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbbb2eb3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When an application is filed, the Secretary shall post a notice of the application in the office of the Secretary and give notice of the application to other persons as required by regulations of the Secretary. An interested person may file a response with the Secretary opposing or supporting the issuance of the permit. The Secretary shall act on an application as expeditiously as possible.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbbb2eb4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s41305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Terms","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may impose terms for providing foreign air transportation under the permit that the Secretary finds may be required in the public interest.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbbb2eb5-47c4-11f1-9671-b5c725212f70"},"t