{"tag":"section","attrib":{"id":"idcbd56d46-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305"},"text":null,"children":[{"tag":"num","attrib":{"value":"42305"},"text":"§ 42305.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Refunds for cancelled or significantly delayed or changed flights","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcbd56d47-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In the case of a passenger that holds a nonrefundable ticket on a scheduled flight to, from, or within the United States, an air carrier or a foreign air carrier shall, upon request as set forth in subsection (f), provide a full refund, including any taxes and ancillary fees, for the fare such carrier collected for any cancelled flight or significantly delayed or changed flight where the passenger chooses not to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d48-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" fly on the significantly delayed or changed flight or accept rebooking on an alternative flight; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d49-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept any voucher, credit, or other form of compensation offered by the air carrier or foreign air carrier pursuant to subsection (c).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d4a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing of Refund","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Any refund required under subsection (a) shall be issued by the air carrier or foreign air carrier—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d4b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a ticket purchased with a credit card, not later than 7 business days after the earliest date the refund was requested as set forth in subsection (f); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d4c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a ticket purchased with cash or another form of payment, not later than 20 days after the earliest date the refund was requested as set forth in subsection (f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d4d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Alternative to Refund","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An air carrier and a foreign air carrier may offer a voucher, credit, or other form of compensation as an explicit alternative to providing a refund required by subsection (a) but only if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d4e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the offer includes a clear and conspicuous notice of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd56d4f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the terms of the offer; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd56d50-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the passenger’s right to a full refund under this section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d51-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the voucher, credit, or other form of compensation offered explicitly as an alternative to providing a refund required by subsection (a) remains valid and redeemable by the consumer for a period of at least 5 years from the date on which such voucher, credit, or other form of compensation is issued;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d52-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon the issuance of such voucher, credit, or other form of compensation, an air carrier, foreign air carrier, or ticket agent, where applicable, notifies the recipient of the expiration date of the voucher, credit, or other form of compensation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d53-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" upon request by an individual who self-identifies as having a disability (as defined in section 382.3 of title 14, Code of Federal Regulations), an air carrier, foreign air carrier, or ticket agent provides a notification under paragraph (3) in an electronic format that is accessible to the recipient.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d54-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Significantly Delayed or Changed Flight Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “significantly delayed or changed flight” includes, at a minimum, a flight where the passenger arrives at a destination airport—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d55-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of a domestic flight, 3 or more hours after the original scheduled arrival time; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d56-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in the case of an international flight, 6 or more hours after the original scheduled arrival time.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d57-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Application to Ticket Agents.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d58-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, the Secretary shall issue a final rule to apply refund requirements to ticket agents in the case of cancelled flights and significantly delayed or changed flights.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d59-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Transfer of funds","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall issue regulations requiring air carriers and foreign air carriers to promptly transfer funds to a ticket agent if—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd56d5a-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/e/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary has determined that the ticket agent is responsible for providing the refund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd56d5b-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/e/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the ticket agent does not possess the funds of the passenger.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d5c-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Timing and alternatives","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A refund provided by a ticket agent shall comply with the requirements in subsections (b) and (c) of this section.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d5d-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Refund","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An air carrier and a foreign air carrier shall consider a passenger to have requested a refund if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcbd56d5e-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a flight is cancelled and a passenger is not offered an alternative flight or any voucher, credit, or other form of compensation by the air carrier or foreign air carrier pursuant to subsection (c);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d5f-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a passenger rejects the significantly delayed or changed flight, rebooking on an alternative flight, or any voucher, credit, or other form of compensation offered by the air carrier or foreign air carrier pursuant to subsection (c); or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcbd56d60-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/f/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a passenger does not respond to an offer of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcbd56d61-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/f/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a significantly delayed or changed flight or an alternative flight and the flight departs without the passenger; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcbd56d62-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/f/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a voucher, credit, or other form of compensation by the date on which the cancelled flight was scheduled to depart or the date that the significantly delayed or changed flight departs.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcbd56d63-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s42305/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Refund Notification","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An air carrier and a foreign air carrier shall update their passenger notification systems to ensure passengers owed a refund under this section are notified of their right to receive a refund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcbd56d64-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63/tV/s503/a"},"text":"Pub. L. 118–63, title V, § 503(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/1188"},"text":"138 Stat. 1188","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcbd56d65-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idcbd56d66-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"idcbd56d67-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsec. (e)(1), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/63"},"text":"Pub. L. 118–63","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2024-05-16"},"text":"May 16, 2024","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
