{"tag":"section","attrib":{"id":"idcad64dad-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6306"},"text":null,"children":[{"tag":"num","attrib":{"value":"6306"},"text":"§ 6306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transportation statistical collection, analysis, and dissemination","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"To ensure that all transportation statistical collection, analysis, and dissemination is carried out in a coordinated manner, the Director may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcad64dae-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6306/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" use the services, equipment, records, personnel, information, and facilities of other Federal agencies, or State, local, and private agencies and instrumentalities, subject to the conditions that the applicable agency or instrumentality consents to that use and with or without reimbursement for such use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64daf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6306/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into agreements with the agencies and instrumentalities described in paragraph (1) for purposes of data collection and analysis;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64db0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6306/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confer and cooperate with foreign governments, international organizations, and State, municipal, and other local agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64db1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6306/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" request such information, data, and reports from any Federal agency as the Director determines necessary to carry out this chapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64db2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6306/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encourage replication, coordination, and sharing of information among transportation agencies regarding information systems, information policy, and data; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcad64db3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s6306/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confer and cooperate with Federal statistical agencies as the Director determines necessary to carry out this chapter, including by entering into cooperative data sharing agreements in conformity with all laws and regulations applicable to the disclosure and use of data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcad64db4-47c4-11f1-9671-b5c725212f70"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/112/141/dE/tII/s52011/a"},"text":"Pub. L. 112–141, div. E, title II, § 52011(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2012-07-06"},"text":"July 6, 2012","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/126/892"},"text":"126 Stat. 892","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcad64db5-47c4-11f1-9671-b5c725212f70"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idcad64db6-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"idcad64db7-47c4-11f1-9671-b5c725212f70"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"2012-10-01"},"text":"Oct. 1, 2012","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/112/141/s3/a"},"text":"section 3(a) of Pub. L. 112–141","children":[],"tail":", set out as an Effective and Termination Dates of 2012 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t23/s101"},"text":"section 101 of Title 23","children":[],"tail":", Highways."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
