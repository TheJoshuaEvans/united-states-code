{"tag":"section","attrib":{"id":"idcb2298c9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403"},"text":null,"children":[{"tag":"num","attrib":{"value":"22403"},"text":"§ 22403.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Administration of direct loans and loan guarantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idcb2298ca-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applications.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb2298cb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall prescribe the form and contents required of applications for assistance under section 22402, to enable the Secretary to determine the eligibility of the applicant’s proposal, and shall establish terms and conditions for direct loans and loan guarantees made under that section, including a program guide, a standard term sheet, and specific timetables.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2298cc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Documentation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"An applicant meeting the size standard for small business concerns established under section 3(a)(2) of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/a/2"},"text":"15 U.S.C. 632(a)(2)","children":[],"tail":") may provide unaudited financial statements as documentation of historical financial information if such statements are accompanied by the applicant’s Federal tax returns and Internal Revenue Service tax verifications for the corresponding years."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2298cd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Full Faith and Credit","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"All guarantees entered into by the Secretary under section 22402 shall constitute general obligations of the United States of America backed by the full faith and credit of the United States of America.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2298ce-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assignment of Loan Guarantees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The holder of a loan guarantee made under section 22402 may assign the loan guarantee in whole or in part, subject to such requirements as the Secretary may prescribe.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2298cf-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Modifications","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may approve the modification of any term or condition of a direct loan, loan guarantee, direct loan obligation, or loan guarantee commitment, including the rate of interest, time of payment of interest or principal, or security requirements, if the Secretary finds in writing that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb2298d0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification is equitable and is in the overall best interests of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2298d1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consent has been obtained from the applicant and, in the case of a loan guarantee or loan guarantee commitment, the holder of the obligation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2298d2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the modification cost has been covered under section 22402(f).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2298d3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Compliance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary shall assure compliance, by an applicant, any other party to the loan, and any railroad or railroad partner for whose benefit assistance is intended, with the provisions of this chapter, regulations issued hereunder, and the terms and conditions of the direct loan or loan guarantee, including through regular periodic inspections.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2298d4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Commercial Validity","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"For purposes of claims by any party other than the Secretary, a loan guarantee or loan guarantee commitment shall be conclusive evidence that the underlying obligation is in compliance with the provisions of this chapter, and that such obligation has been approved and is legal as to principal, interest, and other terms. Such a guarantee or commitment shall be valid and incontestable in the hands of a holder thereof, including the original lender or any other holder, as of the date when the Secretary granted the application therefor, except as to fraud or material misrepresentation by such holder.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2298d5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Default","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall prescribe regulations setting forth procedures in the event of default on a loan made or guaranteed under section 22402. The Secretary shall ensure that each loan guarantee made under that section contains terms and conditions that provide that—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb2298d6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if a payment of principal or interest under the loan is in default for more than 30 days, the Secretary shall pay to the holder of the obligation, or the holder’s agent, the amount of unpaid guaranteed interest;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2298d7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" if the default has continued for more than 90 days, the Secretary shall pay to the holder of the obligation, or the holder’s agent, 90 percent of the unpaid guaranteed principal;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2298d8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after final resolution of the default, through liquidation or otherwise, the Secretary shall pay to the holder of the obligation, or the holder’s agent, any remaining amounts guaranteed but which were not recovered through the default’s resolution;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2298d9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/g/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary shall not be required to make any payment under paragraphs (1) through (3) if the Secretary finds, before the expiration of the periods described in such paragraphs, that the default has been remedied; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2298da-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/g/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the holder of the obligation shall not receive payment or be entitled to retain payment in a total amount which, together with all other recoveries (including any recovery based upon a security interest in equipment or facilities) exceeds the actual loss of such holder.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2298db-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rights of the Secretary.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb2298dc-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Subrogation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If the Secretary makes payment to a holder, or a holder’s agent, under subsection (g) in connection with a loan guarantee made under section 22402, the Secretary shall be subrogated to all of the rights of the holder with respect to the obligor under the loan.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2298dd-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Disposition of property","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may complete, recondition, reconstruct, renovate, repair, maintain, operate, charter, rent, sell, or otherwise dispose of any property or other interests obtained pursuant to this section. The Secretary shall not be subject to any Federal or State regulatory requirements when carrying out this paragraph.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2298de-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Action Against Obligor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may bring a civil action in an appropriate Federal court in the name of the United States in the event of a default on a direct loan made under section 22402, or in the name of the United States or of the holder of the obligation in the event of a default on a loan guaranteed under section 22402. The holder of a guarantee shall make available to the Secretary all records and evidence necessary to prosecute the civil action. The Secretary may accept property in full or partial satisfaction of any sums owed as a result of a default. If the Secretary receives, through the sale or other disposition of such property, an amount greater than the aggregate of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb2298df-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amount paid to the holder of a guarantee under subsection (g) of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2298e0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other cost to the United States of remedying the default,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"the Secretary shall pay such excess to the obligor.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2298e1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Breach of Conditions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Attorney General shall commence a civil action in an appropriate Federal court to enjoin any activity which the Secretary finds is in violation of this chapter, regulations issued hereunder, or any conditions which were duly agreed to, and to secure any other appropriate relief.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2298e2-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/k"},"text":null,"children":[{"tag":"num","attrib":{"value":"k"},"text":"(k)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Attachment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"No attachment or execution may be issued against the Secretary, or any property in the control of the Secretary, prior to the entry of final judgment to such effect in any State, Federal, or other court.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2298e3-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l"},"text":null,"children":[{"tag":"num","attrib":{"value":"l"},"text":"(l)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Charges and Loan Servicing.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"idcb2298e4-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary may collect from each applicant, obligor, or loan party a reasonable charge for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb2298e5-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of evaluating the application, amendments, modifications, and waivers, including for evaluating project viability, applicant creditworthiness, and the appraisal of the value of the equipment or facilities for which the direct loan or loan guarantee is sought, and for making necessary determinations and findings;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2298e6-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of award management and project management oversight;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2298e7-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of services from expert firms, including counsel, and independent financial advisors to assist in the underwriting, auditing, servicing, and exercise of rights with respect to direct loans and loan guarantees; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2298e8-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the cost of all other expenses incurred as a result of a breach of any term or condition or any event of default on a direct loan or loan guarantee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2298e9-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standards","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may charge different amounts under this subsection based on the different costs incurred under paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2298ea-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Servicer.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb2298eb-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Secretary may appoint a financial entity to assist the Secretary in servicing a direct loan or loan guarantee under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2298ec-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A servicer appointed under subparagraph (A) shall act as the agent of the Secretary in servicing a direct loan or loan guarantee under this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2298ed-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A servicer appointed under subparagraph (A) shall receive a servicing fee from the obligor or other loan party, subject to approval by the Secretary.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"idcb2298ee-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National surface transportation and innovative finance bureau account","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Amounts collected under this subsection shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"idcb2298ef-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be credited directly to the National Surface Transportation and Innovative Finance Bureau account; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"idcb2298f0-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/l/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" remain available until expended to pay for the costs described in this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idcb2298f1-47c4-11f1-9671-b5c725212f70","identifier":"/us/usc/t49/s22403/m"},"text":null,"children":[{"tag":"num","attrib":{"value":"m"},"text":"(m)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Fees and Charges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided in this chapter, the Secretary may not assess any fees, including user fees, or charges in connection with a direct loan or loan guarantee provided under section 22402.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idcb2298f2-47c4-11f1-9671-b5c725212f70"},"text":"(Added and amended ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/58/dB/tI/s21301/a/2"},"text":"Pub. L. 117–58, div. B, title I, § 21301(a)(2)","children":[],"tail":", (5), (e), "},{"tag":"date","attrib":{"date":"2021-11-15"},"text":"Nov. 15, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/683"},"text":"135 Stat. 683","children":[],"tail":", 689.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idcb2298f3-47c4-11f1-9671-b5c725212f70"},"text":"\n"