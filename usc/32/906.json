{"tag":"section","attrib":{"id":"ida1de1126-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s906"},"text":null,"children":[{"tag":"num","attrib":{"value":"906"},"text":"§ 906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Requests for funding assistance","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A Governor of a State may request funding assistance for the homeland defense activities of the National Guard of that State from the Secretary of Defense. Any such request shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1de1127-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s906/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The specific intended homeland defense activities of the National Guard of that State.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1de1128-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s906/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An explanation of why participation of National Guard units or members, as the case may be, in the homeland defense activities is necessary and appropriate.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1de1129-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s906/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A certification that homeland defense activities are to be conducted at a time when the personnel involved are not in Federal service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1de112a-2930-11f1-9ed5-c078b45cfa95"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/375/dA/tV/s512/a/1"},"text":"Pub. L. 108–375, div. A, title V, § 512(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-28"},"text":"Oct. 28, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/1879"},"text":"118 Stat. 1879","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
