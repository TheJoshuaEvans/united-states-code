{"tag":"section","attrib":{"id":"ida1d49ab1-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s506"},"text":null,"children":[{"tag":"num","attrib":{"value":"506"},"text":"§ 506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment and detail of members of Regular Army or Regular Air Force for instruction of National Guard","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1d49ab2-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President shall assign for instruction of the National Guard such members of the Regular Army or the Regular Air Force as he considers necessary.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1d49ab3-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Army may detail members of the Regular Army to attend an encampment, maneuver, or other exercise, for field or coast-defense instruction of the Army National Guard. Similarly, the Secretary of the Air Force may detail members of the Regular Air Force to attend exercises for field or coast-defense instruction of the Air National Guard. Members so detailed shall instruct the members of the National Guard at the exercise, as directed by the Secretary concerned, or as requested by the governor or commanding officer of the National Guard there assembled.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1d49ab4-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/611"},"text":"70A Stat. 611","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1d49ab5-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1d49ab6-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1d49ab7-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"506(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"506(b)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:66.","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:67.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s81"},"text":"June 3, 1916, ch. 134, § 81","children":[],"tail":" (1st sentence of 2d par., less 1st 7 words); added "},{"tag":"html:a","attrib":{"href":"/us/act/1920-06-04/ch227"},"text":"June 4, 1920, ch. 227","children":[],"tail":", subch. I, § 44 (5th sentence, less 1st 6 words); restated "},{"tag":"html:span","attrib":{},"text":"Sept. 22, 1922","children":[],"tail":" ch. 423, § 4 (6th sentence, less 1st 6 words); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1925-02-28/ch371/s3"},"text":"Feb. 28, 1925, ch. 371, § 3","children":[],"tail":" (6th sentence, less 1st 6 words); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1933-06-15/ch87/s16"},"text":"June 15, 1933, ch. 87, § 16","children":[],"tail":" (1st sentence of 2d par., less 1st 7 words), "},{"tag":"html:a","attrib":{"href":"/us/stat/48/160"},"text":"48 Stat. 160","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s96"},"text":"June 3, 1916, ch. 134, § 96","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/39/207"},"text":"39 Stat. 207","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (a), the words “members of the Regular Army and the Regular Air Force” are substituted for the words “officers of the Regular Army” and “enlisted men of the Regular Army”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b), the words “members” is substituted for the words “officers and enlisted men”. The words “one or more”, “information”, and “encampment, maneuver, or other” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
