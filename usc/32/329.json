{"tag":"section","attrib":{"id":"ida1d22a44-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s329"},"text":null,"children":[{"tag":"num","attrib":{"value":"329"},"text":"§ 329.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Prohibition on private funding for interstate deployment","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A member of the National Guard may not be ordered to cross a border of a State to perform duty (under this title or title 10) if such duty is paid for with private funds, unless such duty is in response to a major disaster or emergency under section 401 of the Robert T. Stafford Disaster Relief and Emergency Assistance Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s5170"},"text":"42 U.S.C. 5170","children":[],"tail":")."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida1d22a45-2930-11f1-9ed5-c078b45cfa95"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/81/dA/tV/s512/a"},"text":"Pub. L. 117–81, div. A, title V, § 512(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-12-27"},"text":"Dec. 27, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/135/1682"},"text":"135 Stat. 1682","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1d22a46-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1d22a47-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"ida1d22a48-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 329, ","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"act Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/608"},"text":"70A Stat. 608","children":[],"tail":", which related to summary courts-martial of National Guard not in Federal service, was repealed by "},{"tag":"ref","attrib":{"href":"/us/pl/107/314/dA/tV/s512/c/1"},"text":"Pub. L. 107–314, div. A, title V, § 512(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-02"},"text":"Dec. 2, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2537"},"text":"116 Stat. 2537","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
