ail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Revised section","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (U.S. Code)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:i","attrib":{},"text":"Source (Statutes at Large)","children":[],"tail":null}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tbody","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"708(a)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"708(b)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"708(c)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"708(d)","children":[],"tail":null}],"tail":null},{"tag":"html:p","attrib":{},"text":" ","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"708(e)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:49 (last sentence; and 2d sentence, less last 24 words).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:49 (3d and 4th sentences).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:49 (last 24 words of 2d sentence).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:49 (5th and 6th sentences).","children":[],"tail":null},{"tag":"html:p","attrib":{},"text":"32:49 (last sentence, less 1st 18 words).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s67"},"text":"June 3, 1916, ch. 134, § 67","children":[],"tail":" (last par.), "},{"tag":"html:a","attrib":{"href":"/us/stat/39/200"},"text":"39 Stat. 200","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1918-07-09/ch143"},"text":"July 9, 1918, ch. 143","children":[],"tail":", subch. III (last par.); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1954-07-06/ch462"},"text":"July 6, 1954, ch. 462","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/58/451"},"text":"58 Stat. 451","children":[],"tail":"."}],"tail":null},{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1924-06-03/ch244/s5"},"text":"June 3, 1924, ch. 244, § 5","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/43/365"},"text":"43 Stat. 365","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1954-07-06/ch462"},"text":"July 6, 1954, ch. 462","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/68/451"},"text":"68 Stat. 451","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"708(f)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:49 (1st 18 words of last sentence).","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":null,"children":[{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"708(g)","children":[],"tail":null}],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":"32:50.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(1), the words “the duties of that assignment” are substituted for the words “his duties as property and fiscal officer”. The words “be required to” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (b)(2), the words “of the National Guard for which he is property and fiscal officer” are substituted for the words “of the National Guard or Air National Guard of the State, Territory, or District of Columbia”.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (c), 32:49 (5th sentence) is omitted, since the officer concerned would be entitled, under section 201 of the Career Compensation Act of 1949 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t37/s232"},"text":"37 U.S.C. 232","children":[],"tail":"), to the pay and allowances of the grade in which he is serving."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (e), the words “The Secretaries shall prescribe” are substituted for the words “which rules and regulations shall establish”. The word “duties” is omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (f), the words “rules and” and “the provisions of” are omitted as surplusage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In subsection (g), the words “Under such regulations as may be prescribed by the Secretary of the Army” are omitted, since the Secretary has inherent authority to issue regulations appropriate to exercising his statutory functions. The words “an officer” are substituted for the words “other officers”, since, under revised subsection (a), the property and fiscal officer is not required to be an officer of the National Guard. The words “accountable for public moneys” and “as agent” are omitted as surplusage.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1d6e562-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1d6e563-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/92"},"text":"Pub. L. 116–92","children":[],"tail":" inserted “, in consultation with the Chief of the National Guard Bureau,” after “shall”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2006—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s1057/b/4"},"text":"Pub. L. 109–163, § 1057(b)(4)","children":[],"tail":", substituted “State, the Commonwealth of Puerto Rico, Guam, and the Virgin Islands” for “State or Territory and Puerto Rico”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/109/163/s1057/b/2"},"text":"Pub. L. 109–163, § 1057(b)(2)","children":[],"tail":", substituted “State, the Commonwealth of Puerto Rico, the District of Columbia, Guam, and the Virgin Islands” for “State or Territory, Puerto Rico, and the District of Columbia”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1989—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/189"},"text":"Pub. L. 101–189","children":[],"tail":" substituted “The Governor of each State or Territory and Puerto Rico” for “The governor of each State and Territory, Puerto Rico, and the Canal Zone”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/456"},"text":"Pub. L. 100–456","children":[],"tail":" struck out “the Canal Zone,” after “Puerto Rico,”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" redesignated pars. (2) and (3) as (1) and (2), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/79/s804/b/1"},"text":"Pub. L. 95–79, § 804(b)(1)","children":[],"tail":", (2), redesignated subsec. (e) as (d). Former subsec. (d), which authorized inspections at least once a year by Inspectors General of the departments concerned, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/79/s804/b/2"},"text":"Pub. L. 95–79, § 804(b)(2)","children":[],"tail":", (3), redesignated subsec. (f) as (e) and substituted “(d)” for “(e)”. Former subsec. (e) redesignated (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (f), (g). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/79/s804/b/2"},"text":"Pub. L. 95–79, § 804(b)(2)","children":[],"tail":", redesignated subsecs. (f) and (g) as (e) and (f), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/310"},"text":"Pub. L. 92–310","children":[],"tail":" repealed provisions which related to the bond required of property and fiscal officers."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida1d6e564-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1980 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/513"},"text":"Pub. L. 96–513","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1980-12-12"},"text":"Dec. 12, 1980","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/96/513/s701/b/3"},"text":"section 701(b)(3) of Pub. L. 96–513","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s101"},"text":"section 101 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
