{"tag":"section","attrib":{"id":"ida1c18862-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s103"},"text":null,"children":[{"tag":"num","attrib":{"value":"103"},"text":"§ 103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Branches and organizations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Army National Guard of each State, the Commonwealth of Puerto Rico, the District of Columbia, Guam, and the Virgin Islands includes such members of the staff corps corresponding to the staff corps of the Army as the Secretary of the Army may authorize.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida1c18863-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/597"},"text":"70A Stat. 597","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/b/1"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/b/2"},"text":"Pub. L. 109–163, div. A, title X, § 1057(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3441"},"text":"119 Stat. 3441","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1c18864-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1c18865-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","i