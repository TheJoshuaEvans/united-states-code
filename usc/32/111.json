{"tag":"section","attrib":{"id":"ida1c642bf-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s111"},"text":null,"children":[{"tag":"num","attrib":{"value":"111"},"text":"§ 111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Suspension of certain provisions of this title","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In time of war, or of emergency declared by Congress, the President may suspend the operation of any provision of sections 307(e), 309, 310, and 323(d) and (e) ","children":[{"tag":"ref","attrib":{"idref":"fn002000"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002000"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" of this title with respect to the Army National Guard or the Air National Guard."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"ida1c642c0-2930-11f1-9ed5-c078b45cfa95"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/85/861/s2/3"},"text":"Pub. L. 85–861, § 2(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1958-09-02"},"text":"Sept. 2, 1958","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/72/1543"},"text":"72 Stat. 1543","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1c642c1-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1c642c2-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1c642c3-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"