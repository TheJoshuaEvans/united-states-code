{"tag":"section","attrib":{"id":"ida1db9fb2-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s712"},"text":null,"children":[{"tag":"num","attrib":{"value":"712"},"text":"§ 712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposition of proceeds of condemned stores issued to National Guard","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The following shall be covered into the Treasury:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1db9fb3-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s712/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The proceeds from sales of condemned stores issued to the National Guard of a State, the Commonwealth of Puerto Rico, the District of Columbia, Guam, or the Virgin Islands, and not charged against its allotment.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1db9fb4-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s712/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The net proceeds from collections made from any person to reimburse the United States for the loss or destruction of, or damage to, property described in clause (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1db9fb5-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s712/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Stoppage against members of the National Guard for the loss or destruction of, or damage to, property described in clause (1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1db9fb6-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/616"},"text":"70A Stat. 616","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/456/dA/tXII/s1234/b/1"},"text":"Pub. L. 100–456, div. A, title XII, § 1234(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-09-29"},"text":"Sept. 29, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2059"},"text":"102 Stat. 2059","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/163/dA/tX/s1057/b/3"},"text":"Pub. L. 109–163, div. A, title X, § 1057(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-01-06"},"text":"Jan. 6, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/119/3441"},"text":"119 Stat. 3441","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1db9fb7-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"ida1db9fb8-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:table","attrib":{"width":"50%","id":"ida1db9fb9-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":[{"tag":"html:colgroup","attrib":{},"text":"\n","children":[{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"},{"tag":"html:col","attrib":{},"text":null,"children":[],"tail":"\n"}],"tail":"\n"},{"tag":"html:thead","attrib":{},"text":"\n","children":[{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{"colspan":"3"},"text":"\n","children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:span","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"html:tr","attrib":{},"text":"\n","children":[{"tag":"html:th","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"t