{"tag":"section","attrib":{"id":"ida1cafe23-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s302"},"text":null,"children":[{"tag":"num","attrib":{"value":"302"},"text":"§ 302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enlistments, reenlistments, and extensions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"ida1cafe24-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s302/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Under regulations to be prescribed by the Secretary concerned, original enlistments in the National Guard may be accepted for—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1cafe25-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s302/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any specified term, not less than three years, for persons who have not served in an armed force; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1cafe26-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s302/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any specified term, not less than one year, for persons who have served in any armed force.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cafe27-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s302/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Under regulations to be prescribed by the Secretary concerned, reenlistment in the National Guard may be accepted for any specified period, or, if the person last served in one of the highest five enlisted grades, for an unspecified period.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"ida1cafe28-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s302/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Enlistments or reenlistments in the National Guard may be extended—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"ida1cafe29-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s302/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" under regulations to be prescribed by the Secretary concerned, at the request of the member, for any period not less than six months; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"ida1cafe2a-2930-11f1-9ed5-c078b45cfa95","identifier":"/us/usc/t32/s302/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by proclamation of the President, if Congress declares an emergency, until six months after termination of that emergency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"ida1cafe2b-2930-11f1-9ed5-c078b45cfa95"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1956-08-10/ch1041"},"text":"Aug. 10, 1956, ch. 1041","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70A/601"},"text":"70A Stat. 601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/87/378/s5/1"},"text":"Pub. L. 87–378, § 5(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-04"},"text":"Oct. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/808"},"text":"75 Stat. 808","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"ida1cafe2c-2930-11f1-9ed5-c078b45cfa95"},"text":"\n","children":