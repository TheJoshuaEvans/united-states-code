l:p","attrib":{},"text":"32:124.","children":[],"tail":null}],"tail":null},{"tag":"html:td","attrib":{},"text":null,"children":[{"tag":"html:p","attrib":{},"text":null,"children":[{"tag":"html:a","attrib":{"href":"/us/act/1916-06-03/ch134/s69"},"text":"June 3, 1916, ch. 134, § 69","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1919-07-11/ch8"},"text":"July 11, 1919, ch. 8","children":[],"tail":" (20th par. under “National Guard”); restated "},{"tag":"html:a","attrib":{"href":"/us/act/1920-06-04/ch227"},"text":"June 4, 1920, ch. 227","children":[],"tail":", subch. I, § 37; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1924-06-06/ch275/s4"},"text":"June 6, 1924, ch. 275, § 4","children":[],"tail":"; restated "},{"tag":"html:a","attrib":{"href":"/us/act/1933-06-15/ch87/s7"},"text":"June 15, 1933, ch. 87, § 7","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/48/156"},"text":"48 Stat. 156","children":[],"tail":"; "},{"tag":"html:a","attrib":{"href":"/us/act/1952-07-09/ch608/s806/a"},"text":"July 9, 1952, ch. 608, § 806(a)","children":[],"tail":", "},{"tag":"html:a","attrib":{"href":"/us/stat/66/506"},"text":"66 Stat. 506","children":[],"tail":"."}],"tail":null}],"tail":null}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"32:124 (1st proviso) is omitted as executed. The word “reenlistments” is substituted for the words “subsequent enlistments”.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"ida1cafe2f-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"ida1cafe30-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1961—","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/378"},"text":"Pub. L. 87–378","children":[],"tail":" permitted original enlistments for any specified term, not less than three years, for persons who have not served in an armed force, authorized reenlistments for any specified period, or if the person last served in one of the highest five enlisted grades, for an unspecified period, extensions of enlistments or reenlistments at the request of the member for any period not less than six months after termination of the emergency."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"ida1cafe31-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"ida1cafe32-2930-11f1-9ed5-c078b45cfa95"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1961 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/87/378/s6"},"text":"Pub. L. 87–378, § 6","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1961-10-04"},"text":"Oct. 4, 1961","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/75/808"},"text":"75 Stat. 808","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/87/378/s6"},"text":"“The amendments made by sections 3, 4, and 5 of this Act [amending this section and sections 3261 and 8261 of Title 10, Armed Forces] shall not affect any enlistment, reenlistment, or appointment entered into or made before the effective date of this Act [","children":[{"tag":"date","attrib":{"date":"1961-10-04"},"text":"Oct. 4, 1961","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
